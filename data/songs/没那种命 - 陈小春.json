  "lyrics": [
    {
      "time": 27.02,
      "time_str": "00:27.020",
      "text": "爱情这东西 没道理的",
      "translation": null
    },
    {
      "time": 33.71,
      "time_str": "00:33.710",
      "text": "有人很抢手 有人没资格",
      "translation": null
    },
    {
      "time": 38.63,
      "time_str": "00:38.630",
      "text": "路是人走的 我害怕什么",
      "translation": null
    },
    {
      "time": 45.53,
      "time_str": "00:45.530",
      "text": "大不了 别爱了",
      "translation": null
    },
    {
      "time": 54.15,
      "time_str": "00:54.150",
      "text": "她像个天仙 她太美了",
      "translation": null
    },
    {
      "time": 60.89,
      "time_str": "01:00.890",
      "text": "我那么平凡 我开不了口",
      "translation": null
    },
    {
      "time": 65.69,
      "time_str": "01:05.690",
      "text": "心里面晓得 追她的结果",
      "translation": null
    },
    {
      "time": 75.79,
      "time_str": "01:15.790",
      "text": "幸运的 不是我",
      "translation": null
    },
    {
      "time": 82.41,
      "time_str": "01:22.410",
      "text": "唉",
      "translation": null
    },
    {
      "time": 83.52,
      "time_str": "01:23.520",
      "text": "我没那种命呀 她没道理爱上我",
      "translation": null
    },
    {
      "time": 88.65,
      "time_str": "01:28.650",
      "text": "英雄和美人呐 是一国的",
      "translation": null
    },
    {
      "time": 94.85,
      "time_str": "01:34.850",
      "text": "只怪 爱人太少了 对手太好了",
      "translation": null
    },
    {
      "time": 98.59,
      "time_str": "01:38.590",
      "text": "劝自己别傻了",
      "translation": null
    },
    {
      "time": 101.49,
      "time_str": "01:41.490",
      "text": "以前甭提了 以后非加油不可",
      "translation": null
    },
    {
      "time": 108.86,
      "time_str": "01:48.860",
      "text": "我没那种命呀 轮也不会轮到我",
      "translation": null
    },
    {
      "time": 115.19,
      "time_str": "01:55.190",
      "text": "爱情老是缺货 我争什么",
      "translation": null
    },
    {
      "time": 121.8,
      "time_str": "02:01.800",
      "text": "时间 越来越少了 越来越老了",
      "translation": null
    },
    {
      "time": 125.63,
      "time_str": "02:05.630",
      "text": "我剩下一个梦",
      "translation": null
    },
    {
      "time": 128.46,
      "time_str": "02:08.460",
      "text": "她走过来说 其实我错了 她爱我",
      "translation": null
    },
    {
