    {
      "time": 6.89,
      "time_str": "00:06.890",
      "text": "啦啦啦……",
      "translation": null
    },
    {
      "time": 39.25,
      "time_str": "00:39.250",
      "text": "【前奏】",
      "translation": null
    },
    {
      "time": 65.7,
      "time_str": "01:05.700",
      "text": "看不穿 是你失落的魂魄",
      "translation": null
    },
    {
      "time": 72.46,
      "time_str": "01:12.460",
      "text": "猜不透 是你瞳孔的颜色",
      "translation": null
    },
    {
      "time": 79.23,
      "time_str": "01:19.230",
      "text": "一阵风 一场梦 爱如生命般莫测",
      "translation": null
    },
    {
      "time": 86.04,
      "time_str": "01:26.040",
      "text": "你的心到底被什么蛊惑",
      "translation": null
    },
    {
      "time": 92.7,
      "time_str": "01:32.700",
      "text": "你的轮廓在黑夜之中淹没",
      "translation": null
    },
    {
      "time": 99.93,
      "time_str": "01:39.930",
      "text": "看桃花开出怎样的结果",
      "translation": null
    },
    {
      "time": 106.67,
      "time_str": "01:46.670",
      "text": "看着你抱着我 目光似月色寂寞",
      "translation": null
    },
    {
      "time": 113.54,
      "time_str": "01:53.540",
      "text": "就让你在别人怀里快乐",
      "translation": null
    },
    {
      "time": 120.41,
      "time_str": "02:00.410",
      "text": "爱着你 像心跳难触摸",
      "translation": null
    },
    {
      "time": 127.18,
      "time_str": "02:07.180",
      "text": "画着你 画不出你的骨骼",
      "translation": null
    },
    {
      "time": 134.03,
      "time_str": "02:14.030",
      "text": "记着你的脸色 是我等你的执着",
      "translation": null
    },
    {
      "time": 140.86,
      "time_str": "02:20.860",
      "text": "你是我一首唱不完的歌",
