  "lyrics": [
    {
      "time": 2.4,
      "time_str": "00:02.400",
      "text": "演唱：独朽、星一问水",
      "translation": null
    },
    {
      "time": 5.8,
      "time_str": "00:05.800",
      "text": "后期： Jove、星一问水",
      "translation": null
    },
    {
      "time": 15.8,
      "time_str": "00:15.800",
      "text": "（独）",
      "translation": null
    },
    {
      "time": 15.84,
      "time_str": "00:15.840",
      "text": "我想我是迷上了白月光",
      "translation": null
    },
    {
      "time": 19.32,
      "time_str": "00:19.320",
      "text": "每每在黑夜飞翔有他照亮",
      "translation": null
    },
    {
      "time": 23.09,
      "time_str": "00:23.090",
      "text": "可他高高挂天上只能仰望",
      "translation": null
    },
    {
      "time": 26.81,
      "time_str": "00:26.810",
      "text": "我没有星际翅膀只配云端",
      "translation": null
    },
    {
      "time": 30.71,
      "time_str": "00:30.710",
      "text": "太空有没有邮局",
      "translation": null
    },
    {
      "time": 32.2,
      "time_str": "00:32.200",
      "text": "能够将信寄往",
      "translation": null
    },
    {
      "time": 34.43,
      "time_str": "00:34.430",
      "text": "一字一句地写上我的念想",
      "translation": null
    },
    {
      "time": 38.08,
      "time_str": "00:38.080",
      "text": "信封里还要夹一块花生糖",
      "translation": null
    },
    {
      "time": 41.61,
      "time_str": "00:41.610",
      "text": "承诺花一生让你Sweet Sweet像糖",
      "translation": null
    },
    {
      "time": 45.2,
      "time_str": "00:45.200",
      "text": "（星）",
      "translation": null
    },
    {
      "time": 45.25,
      "time_str": "00:45.250",
      "text": "Hey Yoo 我如果加盟火箭队",
      "translation": null
    },
    {
      "time": 46.8,
      "time_str": "00:46.800",
      "text": "有没有机会去飞呀",
      "translation": null
    },
    {
      "time": 48.72,
      "time_str": "00:48.720",
      "text": "或者是拜师莱特兄弟",
      "translation": null
    },
    {
      "time": 50.58,
      "time_str": "00:50.580",
      "text": "一起造飞机起飞呀",
      "translation": null
    },
    {
      "time": 52.57,
      "time_str": "00:52.570",
      "text": "我争取英勇又强悍",
      "translation": null
    },
    {
      "time": 54.3,
      "time_str": "00:54.300",
      "text": "身体里埋一颗核弹",
      "translation": null
    },
    {
      "time": 56.22,
      "time_str": "00:56.220",
      "text": "等有天来到你身旁",
      "translation": null
    },
    {
      "time": 57.77,
      "time_str": "00:57.770",
      "text": "轻松能让你破防",
      "translation": null
    },
    {
      "time": 60.5,
      "time_str": "01:00.500",
      "text": "（独&星）",
      "translation": null
    },
    {
      "time": 60.56,
      "time_str": "01:00.560",
      "text": "我想我想撞进你的心里",
      "translation": null
    },
    {
      "time": 64.09,
      "time_str": "01:04.090",
      "text": "我想扑通跳进你温柔的sea",
      "translation": null
    },
    {
      "time": 67.84,
      "time_str": "01:07.840",
      "text": "我想陪你转圈哪怕窒息",
      "translation": null
    },
    {
      "time": 71.62,
      "time_str": "01:11.620",
      "text": "三十八万公里不算距离",
      "translation": null
    },
    {
      "time": 75.4,
      "time_str": "01:15.400",
      "text": "我想我想马上去太空找你",
      "translation": null
    },
    {
      "time": 78.99,
      "time_str": "01:18.990",
      "text": "我想横冲直撞说我喜欢你",
      "translation": null
    },
    {
      "time": 82.64,
      "time_str": "01:22.640",
      "text": "我想带你降落到布达佩斯",
      "translation": null
    },
    {
      "time": 86.86,
      "time_str": "01:26.860",
      "text": "举办一场专属的夏日Party",
      "translation": null
    },
    {
