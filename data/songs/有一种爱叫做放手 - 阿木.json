    {
      "time": 14.92,
      "time_str": "00:14.920",
      "text": "如果两个人的天堂",
      "translation": null
    },
    {
      "time": 17.73,
      "time_str": "00:17.730",
      "text": "像是温馨的墙",
      "translation": null
    },
    {
      "time": 19.52,
      "time_str": "00:19.520",
      "text": "囚禁你的梦想",
      "translation": null
    },
    {
      "time": 21.83,
      "time_str": "00:21.830",
      "text": "幸福是否像是一扇铁窗",
      "translation": null
    },
    {
      "time": 25.46,
      "time_str": "00:25.460",
      "text": "候鸟失去了南方",
      "translation": null
    },
    {
      "time": 29.57,
      "time_str": "00:29.570",
      "text": "如果你对天空向往",
      "translation": null
    },
    {
      "time": 32.469,
      "time_str": "00:32.469",
      "text": "渴望一双翅膀",
      "translation": null
    },
    {
      "time": 35.2,
      "time_str": "00:35.200",
      "text": "放手让你飞翔",
      "translation": null
    },
    {
      "time": 36.639,
      "time_str": "00:36.639",
      "text": "你的羽翼不该伴随玫瑰",
      "translation": null
    },
    {
      "time": 40.219,
      "time_str": "00:40.219",
      "text": "听从凋谢的时光",
      "translation": null
    },
    {
      "time": 43.489,
      "time_str": "00:43.489",
      "text": "浪漫如果变成了牵绊",
      "translation": null
    },
    {
      "time": 47.149,
      "time_str": "00:47.149",
      "text": "我愿为你选择回到孤单",
      "translation": null
    },
    {
      "time": 51.339,
      "time_str": "00:51.339",
      "text": "缠绵如果变成了锁链",
      "translation": null
    },
    {
      "time": 55.069,
      "time_str": "00:55.069",
      "text": "抛开诺言",
      "translation": null
    },
    {
      "time": 58.759,
      "time_str": "00:58.759",
      "text": "有一种爱叫做放手",
      "translation": null
    },
    {
      "time": 62.299,
      "time_str": "01:02.299",
      "text": "为爱放弃天长地久",
      "translation": null
    },
    {
      "time": 66.469,
      "time_str": "01:06.469",
      "text": "我们相守若让你付出所有",
