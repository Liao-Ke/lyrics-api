  "lyrics": [
    {
      "time": 9.47,
      "time_str": "00:09.470",
      "text": "初めに 地は混沌であって",
      "translation": "起初 地是空虚混沌 渊面黑暗"
    },
    {
      "time": 12.87,
      "time_str": "00:12.870",
      "text": "暗がしえんの面にあり あなたは言われた 光あれ",
      "translation": "你说要有光 就有了光"
    },
    {
      "time": 23.59,
      "time_str": "00:23.590",
      "text": "こうして光があたった その光をよしとし 光と暗に分けられた",
      "translation": "而光是好的 所以光和暗分开了"
    },
    {
      "time": 32.83,
      "time_str": "00:32.830",
      "text": "光を昼と呼び 暗を夜と呼ばれた",
      "translation": "光叫做白天 暗叫做夜晚"
    },
    {
      "time": 39.89,
      "time_str": "00:39.890",
      "text": "そして夕べがあり 朝があった",
      "translation": "所以 就有了夜晚 有了白天"
    },
    {
      "time": 45.88,
      "time_str": "00:45.880",
      "text": "空ができ 陆ができ 海ができた",
      "translation": "有了天空 有了土地 有了大海"
    },
    {
      "time": 52.42,
      "time_str": "00:52.420",
      "text": "应该学习婴儿 再宽容一点",
      "translation": null
    },
    {
      "time": 57.43,
      "time_str": "00:57.430",
      "text": "哭过就忘了",
      "translation": null
    },
    {
      "time": 59.84,
      "time_str": "00:59.840",
      "text": "别再记着昨天 还有什么悲伤",
      "translation": null
    },
    {
      "time": 64.73,
      "time_str": "01:04.730",
      "text": "Baby Don't Cry",
      "translation": null
    },
    {
      "time": 66.82,
      "time_str": "01:06.820",
      "text": "快乐是片大海 我是飞翔的翅膀",
      "translation": null
    },
    {
      "time": 72.08,
      "time_str": "01:12.080",
      "text": "要自由要寻找",
      "translation": null
    },
    {
      "time": 74.14,
      "time_str": "01:14.140",
      "text": "一群闪亮小岛 排成很大的微笑",
      "translation": null
    },
    {
      "time": 79.47,
      "time_str": "01:19.470",
      "text": "叫幸福群岛",
      "translation": null
    },
    {
      "time": 88.89,
      "time_str": "01:28.890",
      "text": "爱存在 这美丽新世界",
      "translation": null
    },
    {
      "time": 92.61,
      "time_str": "01:32.610",
      "text": "我喜欢 自信的感觉",
      "translation": null
    },
    {
      "time": 96.35,
      "time_str": "01:36.350",
      "text": "我看见 你微笑像天使",
      "translation": null
    },
    {
      "time": 100.04,
      "time_str": "01:40.040",
      "text": "这就是 爱的奇妙",
      "translation": null
    },
    {
      "time": 103.68,
      "time_str": "01:43.680",
      "text": "我愿意 陪在你的身边",
      "translation": null
    },
    {
      "time": 107.5,
      "time_str": "01:47.500",
      "text": "让心跳不会变老",
      "translation": null
    },
    {
      "time": 111.13,
      "time_str": "01:51.130",
      "text": "欢迎来 这美丽新世界",
      "translation": null
    },
    {
      "time": 114.8,
      "time_str": "01:54.800",
      "text": "让感动 一个一个实现",
      "translation": null
    },
    {
      "time": 135.57,
      "time_str": "02:15.570",
      "text": "不管你在哪里 发射心电讯号",
      "translation": null
    },
    {
