  "lyrics": [
    {
      "time": 15.623,
      "time_str": "00:15.623",
      "text": "你仍然当我是情人",
      "translation": null
    },
    {
      "time": 20.557,
      "time_str": "00:20.557",
      "text": "因为现在先变心太薄幸",
      "translation": null
    },
    {
      "time": 24.933,
      "time_str": "00:24.933",
      "text": "何以我发现你不爱我",
      "translation": null
    },
    {
      "time": 28.62,
      "time_str": "00:28.620",
      "text": "我仍然全没戒心",
      "translation": null
    },
    {
      "time": 31.371,
      "time_str": "00:31.371",
      "text": "分开假如难为谁",
      "translation": null
    },
    {
      "time": 33.869,
      "time_str": "00:33.869",
      "text": "一起一样是负累",
      "translation": null
    },
    {
      "time": 35.748,
      "time_str": "00:35.748",
      "text": "相恋仿如悬崖悬着离合都太累",
      "translation": null
    },
    {
      "time": 40.59,
      "time_str": "00:40.590",
      "text": "要行刑时你若畏罪",
      "translation": null
    },
    {
      "time": 42.807,
      "time_str": "00:42.807",
      "text": "必须解脱的当我要争取",
      "translation": null
    },
    {
      "time": 46.807,
      "time_str": "00:46.807",
      "text": "无能为力接收就放手让我走",
      "translation": null
    },
    {
      "time": 50.621,
      "time_str": "00:50.621",
      "text": "必须粉身碎骨仍然独自接受",
      "translation": null
    },
    {
      "time": 54.369,
      "time_str": "00:54.369",
      "text": "肯牺牲我又可以获救",
      "translation": null
    },
    {
      "time": 57.121,
      "time_str": "00:57.121",
      "text": "就含笑分手",
      "translation": null
    },
    {
      "time": 59.368,
      "time_str": "00:59.368",
      "text": "高尚地赢得我伤口",
      "translation": null
    },
    {
      "time": 61.368,
      "time_str": "01:01.368",
      "text": "悬崖如若太深就放手让我走",
      "translation": null
    },
    {
      "time": 66.56,
      "time_str": "01:06.560",
      "text": "苦恋拖得太久让我默默退后",
      "translation": null
    },
    {
      "time": 69.992,
      "time_str": "01:09.992",
      "text": "将一起跌下去一边应该放手",
      "translation": null
    },
    {
      "time": 72.992,
      "time_str": "01:12.992",
      "text": "得不到你但我能够",
      "translation": null
    },
    {
      "time": 77.119,
      "time_str": "01:17.119",
      "text": "要你永不担忧",
      "translation": null
    },
    {
