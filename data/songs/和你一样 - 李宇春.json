  "lyrics": [
    {
      "time": 25.26,
      "time_str": "00:25.260",
      "text": "谁在最需要的时候轻轻拍着我肩膀",
      "translation": null
    },
    {
      "time": 31.22,
      "time_str": "00:31.220",
      "text": "谁在最快乐的时候愿意和我分享",
      "translation": null
    },
    {
      "time": 36.94,
      "time_str": "00:36.940",
      "text": "日子那么长 我在你身旁",
      "translation": null
    },
    {
      "time": 42.6,
      "time_str": "00:42.600",
      "text": "见证你成长让我感到充满力量",
      "translation": null
    },
    {
      "time": 48.3,
      "time_str": "00:48.300",
      "text": "谁能忘记过去一路走来陪你受的伤",
      "translation": null
    },
    {
      "time": 53.55,
      "time_str": "00:53.550",
      "text": "谁能预料未来茫茫漫长你在何方",
      "translation": null
    },
    {
      "time": 59.64,
      "time_str": "00:59.640",
      "text": "笑容在脸上 和你一样",
      "translation": null
    },
    {
      "time": 65.39,
      "time_str": "01:05.390",
      "text": "大声唱 为自己鼓掌",
      "translation": null
    },
    {
      "time": 70.37,
      "time_str": "01:10.370",
      "text": "我和你一样 一样的坚强",
      "translation": null
    },
    {
      "time": 76.2,
      "time_str": "01:16.200",
      "text": "一样的全力以赴追逐我的梦想",
      "translation": null
    },
    {
      "time": 81.69,
      "time_str": "01:21.690",
      "text": "哪怕会受伤 哪怕有风浪",
      "translation": null
    },
    {
      "time": 87.47,
      "time_str": "01:27.470",
      "text": "风雨之后才会有迷人芬芳",
      "translation": null
    },
    {
      "time": 92.74,
      "time_str": "01:32.740",
      "text": "我和你一样 一样的善良",
      "translation": null
    },
    {
      "time": 98.89,
      "time_str": "01:38.890",
      "text": "一样为需要的人打造一个天堂",
      "translation": null
    },
    {
