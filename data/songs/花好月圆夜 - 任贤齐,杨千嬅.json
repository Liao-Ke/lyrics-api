      "text": "女：",
      "translation": null
    },
    {
      "time": 20.18,
      "time_str": "00:20.180",
      "text": "情话寄呀寄春意飞呀飞",
      "translation": null
    },
    {
      "time": 25.11,
      "time_str": "00:25.110",
      "text": "谁在跳呀跳",
      "translation": null
    },
    {
      "time": 27.64,
      "time_str": "00:27.640",
      "text": "心也比我厚脸皮",
      "translation": null
    },
    {
      "time": 30.17,
      "time_str": "00:30.170",
      "text": "可惜你呀你",
      "translation": null
    },
    {
      "time": 32.7,
      "time_str": "00:32.700",
      "text": "错不该当我后备",
      "translation": null
    },
    {
      "time": 35.18,
      "time_str": "00:35.180",
      "text": "枉将满月空照你绝美",
      "translation": null
    },
    {
      "time": 39.18,
      "time_str": "00:39.180",
      "text": "男：",
      "translation": null
    },
    {
      "time": 40.49,
      "time_str": "00:40.490",
      "text": "明月美呀美",
      "translation": null
    },
    {
      "time": 42.86,
      "time_str": "00:42.860",
      "text": "只怪花好燕单飞",
      "translation": null
    },
    {
      "time": 45.35,
      "time_str": "00:45.350",
      "text": "谁在唱呀唱",
      "translation": null
    },
    {
      "time": 47.92,
      "time_str": "00:47.920",
      "text": "拂揽春意笑画眉",
      "translation": null
    },
    {
      "time": 50.4,
      "time_str": "00:50.400",
      "text": "最憎你呀你",
      "translation": null
    },
    {
      "time": 52.98,
      "time_str": "00:52.980",
      "text": "错将飞吻接落地",
      "translation": null
    },
    {
      "time": 55.46,
      "time_str": "00:55.460",
      "text": "上青天",
      "translation": null
    },
    {
      "time": 57.08,
      "time_str": "00:57.080",
      "text": "宫阙中点醒你",
      "translation": null
