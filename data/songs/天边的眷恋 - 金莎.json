    "arranger": null
  },
  "lyrics": [
    {
      "time": 33.6,
      "time_str": "00:33.600",
      "text": "天上人间 昨日别年",
      "translation": null
    },
    {
      "time": 41.36,
      "time_str": "00:41.360",
      "text": "流逝的 经过的 越来越远",
      "translation": null
    },
    {
      "time": 48.59,
      "time_str": "00:48.590",
      "text": "但只有你的脸 清晰得越明显",
      "translation": null
    },
    {
      "time": 55.12,
      "time_str": "00:55.120",
      "text": "不觉中 胜过了时间",
      "translation": null
    },
    {
      "time": 63.259,
      "time_str": "01:03.259",
      "text": "枫叶正红 飞雁又南迁",
      "translation": null
    },
    {
      "time": 70.79,
      "time_str": "01:10.790",
      "text": "百转千结的是眷恋",
      "translation": null
    },
    {
      "time": 77.96,
      "time_str": "01:17.960",
      "text": "多少个日夜 辗转不成眠",
      "translation": null
    },
    {
      "time": 84.58,
      "time_str": "01:24.580",
      "text": "终有一天心愿都实现",
      "translation": null
    },
    {
      "time": 91.4,
      "time_str": "01:31.400",
      "text": "缠绵望不穿 还记得那誓言",
      "translation": null
    },
    {
      "time": 100.33,
      "time_str": "01:40.330",
      "text": "相信有最后的圆满",
      "translation": null
    },
    {
      "time": 105.339,
      "time_str": "01:45.339",
      "text": "陪你去天边 经历过久久磨难",
      "translation": null
    },
    {
      "time": 114.6,
      "time_str": "01:54.600",
      "text": "放眼天下 信念不变",
      "translation": null
    },
    {
      "time": 155.0,
      "time_str": "02:35.000",
      "text": "记得昨日 故乡的秋天",
      "translation": null
    },
    {
      "time": 163.04,
      "time_str": "02:43.040",
      "text": "朝朝暮暮又再浮现",
      "translation": null
    },
    {
      "time": 170.31,
      "time_str": "02:50.310",
      "text": "这一世情牵 再不会搁浅",
      "translation": null
    },
    {
      "time": 176.98,
      "time_str": "02:56.980",
      "text": "终有一刻魂梦里相牵",
      "translation": null
    },
    {
      "time": 183.69,
      "time_str": "03:03.690",
      "text": "缠绵望不穿 还记得那誓言",
      "translation": null
    },
    {
      "time": 192.42,
      "time_str": "03:12.420",
      "text": "相信有最后的圆满",
      "translation": null
    },
    {
      "time": 197.54,
      "time_str": "03:17.540",
      "text": "陪你去天边 经历过久久磨难",
      "translation": null
    },
    {
      "time": 206.39,
      "time_str": "03:26.390",
      "text": "放眼天下 信念不变",
      "translation": null
    },
    {
      "time": 213.41,
      "time_str": "03:33.410",
      "text": "命运轮回转 听见了那彼岸",
      "translation": null
    },
    {
      "time": 222.06,
      "time_str": "03:42.060",
      "text": "是悠悠远去的呼唤",
      "translation": null
    },
    {
      "time": 227.02,
      "time_str": "03:47.020",
      "text": "虔诚一颗心 踏过了万水千山",
      "translation": null
    },
    {
      "time": 235.92,
      "time_str": "03:55.920",
      "text": "归来时盼相守相伴",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "天边的眷恋 - 金莎.lrc"
}