    {
      "time": 0.31,
      "time_str": "00:00.310",
      "text": "Por los momentos difíciles",
      "translation": "因为艰难岁月"
    },
    {
      "time": 2.59,
      "time_str": "00:02.590",
      "text": "Ya entendí que la flor más bella sería siempre para mÍ.",
      "translation": "我才明白 最美的花只为自己盛开"
    },
    {
      "time": 18.24,
      "time_str": "00:18.240",
      "text": "Lydia",
      "translation": null
    },
    {
      "time": 20.46,
      "time_str": "00:20.460",
      "text": "迷离的眼眶",
      "translation": null
    },
    {
      "time": 24.17,
      "time_str": "00:24.170",
      "text": "为何流浪 心碎的海洋",
      "translation": null
    },
    {
      "time": 30.09,
      "time_str": "00:30.090",
      "text": "受了伤 连微笑都彷徨",
      "translation": null
    },
    {
      "time": 36.04,
      "time_str": "00:36.040",
      "text": "Gypsy女郎 为谁而唱",
      "translation": null
    },
    {
      "time": 40.92,
      "time_str": "00:40.920",
      "text": "你会看见雾 看见云 看见太阳",
      "translation": null
    },
    {
      "time": 46.84,
      "time_str": "00:46.840",
      "text": "皲裂的大地 重复着悲伤",
      "translation": null
    },
    {
      "time": 53.16,
      "time_str": "00:53.160",
      "text": "他走了 带不走你的天堂",
      "translation": null
    },
    {
      "time": 59.0,
      "time_str": "00:59.000",
      "text": "风干后 会留下彩虹泪光",
      "translation": null
    },
    {
      "time": 64.93,
      "time_str": "01:04.930",
      "text": "他走了 你可以把梦留下",
      "translation": null
    },
    {
      "time": 70.89,
      "time_str": "01:10.890",
      "text": "总会有个地方 等待爱飞翔",
      "translation": null
    },
    {
      "time": 96.09,
      "time_str": "01:36.090",
      "text": "Lydia",
      "translation": null
    },
    {
      "time": 98.27,
