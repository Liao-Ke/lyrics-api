  "lyrics": [
    {
      "time": 1.21,
      "time_str": "00:01.210",
      "text": "女：",
      "translation": null
    },
    {
      "time": 1.28,
      "time_str": "00:01.280",
      "text": "没话讲 我们互相在假装",
      "translation": null
    },
    {
      "time": 5.65,
      "time_str": "00:05.650",
      "text": "你的电话还在响",
      "translation": null
    },
    {
      "time": 8.9,
      "time_str": "00:08.900",
      "text": "下一场",
      "translation": null
    },
    {
      "time": 10.18,
      "time_str": "00:10.180",
      "text": "什么人约你去了什么地方",
      "translation": null
    },
    {
      "time": 14.44,
      "time_str": "00:14.440",
      "text": "我 喜欢用眼睛说谎",
      "translation": null
    },
    {
      "time": 18.49,
      "time_str": "00:18.490",
      "text": "单纯善良的模样",
      "translation": null
    },
    {
      "time": 21.65,
      "time_str": "00:21.650",
      "text": "这是我",
      "translation": null
    },
    {
      "time": 22.96,
      "time_str": "00:22.960",
      "text": "掩饰流血和受伤最好的红装",
      "translation": null
    },
    {
      "time": 27.7,
      "time_str": "00:27.700",
      "text": "男：",
      "translation": null
    },
    {
      "time": 27.98,
      "time_str": "00:27.980",
      "text": "你说过让我成为你唯一的肩膀",
      "translation": null
    },
    {
      "time": 30.79,
      "time_str": "00:30.790",
      "text": "可是我和前面的一二三四一样",
      "translation": null
    },
    {
      "time": 33.96,
      "time_str": "00:33.960",
      "text": "你很忙 总没时间来理我",
      "translation": null
    },
    {
      "time": 37.21,
      "time_str": "00:37.210",
      "text": "现场编出的借口却漂亮",
      "translation": null
    },
    {
      "time": 40.34,
      "time_str": "00:40.340",
      "text": "你说过想要跟我去任何的地方",
      "translation": null
    },
    {
      "time": 43.55,
      "time_str": "00:43.550",
      "text": "可是你还是选择自由自在飞翔",
      "translation": null
    },
    {
      "time": 46.77,
      "time_str": "00:46.770",
      "text": "能不能 有一点点的哀伤",
      "translation": null
    },
    {
      "time": 50.01,
      "time_str": "00:50.010",
      "text": "假装出一个不舍的模样",
      "translation": null
    },
    {
      "time": 52.81,
      "time_str": "00:52.810",
      "text": "你在我的身旁化妆",
      "translation": null
    },
    {
      "time": 55.68,
      "time_str": "00:55.680",
      "text": "超短裙撩人的模样",
      "translation": null
    },
    {
      "time": 58.9,
      "time_str": "00:58.900",
      "text": "有点稍刺鼻的芳香",
      "translation": null
    },
    {
      "time": 62.07,
      "time_str": "01:02.070",
      "text": "调皮的问我你今天漂不漂亮",
      "translation": null
    },
    {
      "time": 65.85,
      "time_str": "01:05.850",
      "text": "车窗里谁在等",
      "translation": null
    },
    {
      "time": 68.57,
      "time_str": "01:08.570",
      "text": "和你的朋友不太像",
      "translation": null
    },
    {
      "time": 71.85,
      "time_str": "01:11.850",
      "text": "我微笑着送你出门",
      "translation": null
    },
    {
      "time": 74.62,
      "time_str": "01:14.620",
      "text": "然后对自己说谎",
      "translation": null
    },
