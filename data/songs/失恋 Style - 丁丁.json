  "lyrics": [
    {
      "time": 1.98,
      "time_str": "00:01.980",
      "text": "（电视剧《失恋33天》主题曲）",
      "translation": null
    },
    {
      "time": 7.49,
      "time_str": "00:07.490",
      "text": "花开过就会凋落 全落全落",
      "translation": null
    },
    {
      "time": 10.73,
      "time_str": "00:10.730",
      "text": "我爱过也会爱错 N多N多",
      "translation": null
    },
    {
      "time": 14.1,
      "time_str": "00:14.100",
      "text": "劝我的话都别说 罗嗦罗嗦",
      "translation": null
    },
    {
      "time": 17.67,
      "time_str": "00:17.670",
      "text": "过去的事都翻过 不说不说",
      "translation": null
    },
    {
      "time": 21.11,
      "time_str": "00:21.110",
      "text": "谁还没有失恋过 拜托拜托",
      "translation": null
    },
    {
      "time": 24.48,
      "time_str": "00:24.480",
      "text": "找理由的话不说 沉默沉默",
      "translation": null
    },
    {
      "time": 27.86,
      "time_str": "00:27.860",
      "text": "别想要重新来过 太弱太弱",
      "translation": null
    },
    {
      "time": 31.4,
      "time_str": "00:31.400",
      "text": "从此以后你是你 而我是我",
      "translation": null
    },
    {
      "time": 34.77,
      "time_str": "00:34.770",
      "text": "千万种开始有千万种结局",
      "translation": null
    },
    {
      "time": 37.78,
      "time_str": "00:37.780",
      "text": "就像千万种相遇有千万种分离",
      "translation": null
    },
    {
      "time": 41.15,
      "time_str": "00:41.150",
      "text": "大街上人来人往装模作样的人啊",
      "translation": null
    },
    {
      "time": 44.71,
      "time_str": "00:44.710",
      "text": "十个里面七个八个受过伤的心啊",
      "translation": null
    },
    {
      "time": 48.4,
      "time_str": "00:48.400",
      "text": "这年月 谁还没挨过甩",
      "translation": null
    },
    {
      "time": 52.03,
      "time_str": "00:52.030",
      "text": "哭哭啼啼不是我的失恋style",
      "translation": null
    },
    {
      "time": 55.33,
      "time_str": "00:55.330",
      "text": "能失去的都不是属于我的爱",
      "translation": null
    },
    {
      "time": 58.71,
      "time_str": "00:58.710",
      "text": "大声的说bye 你快给我滚开",
      "translation": null
    },
    {
      "time": 61.9,
      "time_str": "01:01.900",
      "text": "过去全当是一次彩排",
      "translation": null
    },
    {
      "time": 65.65,
      "time_str": "01:05.650",
      "text": "磨磨唧唧不是我的失恋style",
      "translation": null
    },
    {
      "time": 68.84,
      "time_str": "01:08.840",
      "text": "会过期的都不是我想要的菜",
      "translation": null
    },
    {
      "time": 72.33,
      "time_str": "01:12.330",
      "text": "勇敢的说爱 等下一次到来",
      "translation": null
    },
    {
