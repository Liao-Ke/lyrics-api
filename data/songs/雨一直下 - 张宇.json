  "lyrics": [
    {
      "time": 40.139,
      "time_str": "00:40.139",
      "text": "雨一直下",
      "translation": null
    },
    {
      "time": 43.502,
      "time_str": "00:43.502",
      "text": "气氛不算融洽",
      "translation": null
    },
    {
      "time": 48.152,
      "time_str": "00:48.152",
      "text": "在同个屋檐下",
      "translation": null
    },
    {
      "time": 49.797,
      "time_str": "00:49.797",
      "text": "你渐渐感到心在变化",
      "translation": null
    },
    {
      "time": 53.769,
      "time_str": "00:53.769",
      "text": "你爱着他",
      "translation": null
    },
    {
      "time": 57.017,
      "time_str": "00:57.017",
      "text": "也许也带着恨吧",
      "translation": null
    },
    {
      "time": 61.545,
      "time_str": "01:01.545",
      "text": "青春耗了一大半",
      "translation": null
    },
    {
      "time": 63.384,
      "time_str": "01:03.384",
      "text": "原来只是陪他玩耍",
      "translation": null
    },
    {
      "time": 67.336,
      "time_str": "01:07.336",
      "text": "正想离开他",
      "translation": null
    },
    {
      "time": 70.831,
      "time_str": "01:10.831",
      "text": "他却拿着鲜花",
      "translation": null
    },
    {
      "time": 75.396,
      "time_str": "01:15.396",
      "text": "说不着边的话",
      "translation": null
    },
    {
      "time": 77.09,
      "time_str": "01:17.090",
      "text": "让整个场面更加尴尬",
      "translation": null
    },
    {
      "time": 80.982,
      "time_str": "01:20.982",
      "text": "不可思议吧",
      "translation": null
    },
    {
      "time": 84.582,
      "time_str": "01:24.582",
      "text": "梦在瞬间崩塌",
      "translation": null
    },
    {
      "time": 88.921,
      "time_str": "01:28.921",
      "text": "为何当初那么傻",
      "translation": null
    },
    {
      "time": 90.772,
      "time_str": "01:30.772",
      "text": "还一心想要嫁给他",
      "translation": null
    },
    {
      "time": 95.34,
      "time_str": "01:35.340",
      "text": "就是爱到深处 才怨他",
      "translation": null
    },
    {
      "time": 99.621,
      "time_str": "01:39.621",
      "text": "舍不舍得 都断了吧",
      "translation": null
    },
    {
      "time": 102.56,
      "time_str": "01:42.560",
      "text": "那是从来",
      "translation": null
    },
    {
      "time": 103.675,
      "time_str": "01:43.675",
      "text": "都没有后路的悬崖",
      "translation": null
    },
    {
      "time": 109.03,
      "time_str": "01:49.030",
      "text": "就是爱到深处 才由他",
      "translation": null
    },
    {
      "time": 113.205,
      "time_str": "01:53.205",
      "text": "碎了心 也要放得下",
      "translation": null
    },
    {
      "time": 116.308,
      "time_str": "01:56.308",
      "text": "难道忘了那爱他的伤",
      "translation": null
    },
    {
      "time": 119.076,
      "time_str": "01:59.076",
      "text": "已密密麻麻",
      "translation": null
    },
