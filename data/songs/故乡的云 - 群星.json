    {
      "time": 34.85,
      "time_str": "00:34.850",
      "text": "天边飘过故乡的云",
      "translation": null
    },
    {
      "time": 40.41,
      "time_str": "00:40.410",
      "text": "它不停的向我召唤",
      "translation": null
    },
    {
      "time": 46.09,
      "time_str": "00:46.090",
      "text": "当身边的微风轻轻吹起",
      "translation": null
    },
    {
      "time": 51.78,
      "time_str": "00:51.780",
      "text": "有个声音在对我呼唤",
      "translation": null
    },
    {
      "time": 57.43,
      "time_str": "00:57.430",
      "text": "归来吧归来哟",
      "translation": null
    },
    {
      "time": 63.48,
      "time_str": "01:03.480",
      "text": "浪迹天涯的游子",
      "translation": null
    },
    {
      "time": 69.15,
      "time_str": "01:09.150",
      "text": "归来吧归来哟",
      "translation": null
    },
    {
      "time": 74.99,
      "time_str": "01:14.990",
      "text": "别再四处飘泊",
      "translation": null
    },
    {
      "time": 81.26,
      "time_str": "01:21.260",
      "text": "踏著沉重的脚步",
      "translation": null
    },
    {
      "time": 86.88,
      "time_str": "01:26.880",
      "text": "归乡路是那么漫长",
      "translation": null
    },
    {
      "time": 92.85,
      "time_str": "01:32.850",
      "text": "当身边的微风轻轻吹起",
      "translation": null
    },
    {
      "time": 98.5,
      "time_str": "01:38.500",
      "text": "吹来故乡泥土的芳香",
      "translation": null
    },
    {
      "time": 104.27,
      "time_str": "01:44.270",
      "text": "归来吧归来哟",
      "translation": null
