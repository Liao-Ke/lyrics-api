      "translation": null
    },
    {
      "time": 121.69,
      "time_str": "02:01.690",
      "text": "我已厌倦飘泊",
      "translation": null
    },
    {
      "time": 128.4,
      "time_str": "02:08.400",
      "text": "我已是满怀疲惫",
      "translation": null
    },
    {
      "time": 133.86,
      "time_str": "02:13.860",
      "text": "眼里是酸楚的泪",
      "translation": null
    },
    {
      "time": 139.21,
      "time_str": "02:19.210",
      "text": "那故乡的风和故乡的云",
      "translation": null
    },
    {
      "time": 145.12,
      "time_str": "02:25.120",
      "text": "为我抹去创痕",
