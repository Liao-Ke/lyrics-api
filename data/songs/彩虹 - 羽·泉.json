  "lyrics": [
    {
      "time": 20.55,
      "time_str": "00:20.550",
      "text": "爱了就别伪装",
      "translation": null
    },
    {
      "time": 25.641,
      "time_str": "00:25.641",
      "text": "迷失了也别彷徨",
      "translation": null
    },
    {
      "time": 30.478,
      "time_str": "00:30.478",
      "text": "不管未来怎样",
      "translation": null
    },
    {
      "time": 35.064,
      "time_str": "00:35.064",
      "text": "你都要保持坚强",
      "translation": null
    },
    {
      "time": 39.642,
      "time_str": "00:39.642",
      "text": "如果明天你的心",
      "translation": null
    },
    {
      "time": 44.477,
      "time_str": "00:44.477",
      "text": "依然还在流浪",
      "translation": null
    },
    {
      "time": 49.298,
      "time_str": "00:49.298",
      "text": "我愿意承受这份爱",
      "translation": null
    },
    {
      "time": 52.36,
      "time_str": "00:52.360",
      "text": "陪着你 打造一片天地",
      "translation": null
    },
    {
      "time": 57.953,
      "time_str": "00:57.953",
      "text": "我的世界从此以后多了一个你",
      "translation": null
    },
    {
      "time": 62.271,
      "time_str": "01:02.271",
      "text": "每天都是一出戏",
      "translation": null
    },
    {
      "time": 67.089,
      "time_str": "01:07.089",
      "text": "无论情节浪漫或多离奇",
      "translation": null
    },
    {
      "time": 71.16,
      "time_str": "01:11.160",
      "text": "这主角是你",
      "translation": null
    },
    {
      "time": 76.777,
      "time_str": "01:16.777",
      "text": "我的世界从此以后多了一个你",
      "translation": null
    },
    {
      "time": 81.124,
      "time_str": "01:21.124",
      "text": "有时天晴 有时雨",
      "translation": null
    },
    {
      "time": 84.93,
      "time_str": "01:24.930",
      "text": "阴天时候我会告诉你",
      "translation": null
    },
    {
