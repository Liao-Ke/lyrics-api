    {
      "time": 9.0,
      "time_str": "00:09.000",
      "text": "出品人 : 潘鸿业",
      "translation": null
    },
    {
      "time": 16.23,
      "time_str": "00:16.230",
      "text": "我预演过千次百次的重逢",
      "translation": null
    },
    {
      "time": 23.73,
      "time_str": "00:23.730",
      "text": "你却始终站在梦里难触碰",
      "translation": null
    },
    {
      "time": 31.17,
      "time_str": "00:31.170",
      "text": "太难回头只能一直走不停",
      "translation": null
    },
    {
      "time": 37.83,
      "time_str": "00:37.830",
      "text": "曾经两个人流失人海之中",
      "translation": null
    },
    {
      "time": 45.75,
      "time_str": "00:45.750",
      "text": "明明不甘心 明明还在等",
      "translation": null
    },
    {
      "time": 49.29,
      "time_str": "00:49.290",
      "text": "却偏要假装 早就不痛",
      "translation": null
    },
    {
      "time": 53.28,
      "time_str": "00:53.280",
      "text": "明明奢望着 你也再次心动",
      "translation": null
    },
    {
      "time": 60.78,
      "time_str": "01:00.780",
      "text": "越美好期待 越容易落空",
      "translation": null
    },
    {
      "time": 64.53,
      "time_str": "01:04.530",
      "text": "承认我不配 反倒更轻松",
      "translation": null
    },
    {
      "time": 68.31,
      "time_str": "01:08.310",
      "text": "有些爱与妒 只有自己才懂",
      "translation": null
    },
    {
      "time": 75.99,
      "time_str": "01:15.990",
      "text": "时光洪流中这份爱多渺小",
      "translation": null
    },
    {
      "time": 79.02,
      "time_str": "01:19.020",
      "text": "一放手就消散掉",
      "translation": null
    },
    {
      "time": 82.62,
      "time_str": "01:22.620",
      "text": "我也想洒脱一笑",
      "translation": null
    },
    {
      "time": 84.39,
      "time_str": "01:24.390",
      "text": "说一生那么长",
      "translation": null
    },
    {
      "time": 86.4,
      "time_str": "01:26.400",
      "text": "爱与你都不重要",
      "translation": null
    },
    {
      "time": 91.02,
      "time_str": "01:31.020",
      "text": "也许还会遇到另一个人",
      "translation": null
    },
    {
      "time": 93.78,
      "time_str": "01:33.780",
      "text": "许下相似的诺言",
      "translation": null
    },
    {
      "time": 98.64,
      "time_str": "01:38.640",
      "text": "我知道我难以做到",
      "translation": null
    },
