    },
    {
      "time": 14.67,
      "time_str": "00:14.670",
      "text": "SP : Sony/ATV Music Publishing",
      "translation": null
    },
    {
      "time": 19.6,
      "time_str": "00:19.600",
      "text": "糖果罐里好多颜色 微笑却不甜了",
      "translation": null
    },
    {
      "time": 28.04,
      "time_str": "00:28.040",
      "text": "你的某些快乐 在没有我的时刻",
      "translation": null
    },
    {
      "time": 36.48,
      "time_str": "00:36.480",
      "text": "中古世纪的城市里 我想就走到这",
      "translation": null
    },
    {
      "time": 44.88,
      "time_str": "00:44.880",
      "text": "海鸥不再眷恋大海 可以飞更远",
      "translation": null
    },
    {
      "time": 52.0,
      "time_str": "00:52.000",
      "text": "远方传来风笛 我只在意有你的消息",
      "translation": null
    },
    {
      "time": 60.2,
      "time_str": "01:00.200",
      "text": "城堡为爱守着秘密 而我为你守着回忆",
      "translation": null
    },
    {
      "time": 68.23,
      "time_str": "01:08.230",
      "text": "明明就 不习惯 牵手",
      "translation": null
    },
    {
      "time": 72.08,
      "time_str": "01:12.080",
      "text": "为何却主动把手勾",
      "translation": null
    },
    {
      "time": 76.27,
      "time_str": "01:16.270",
      "text": "你的心事太多 我不会戳破",
      "translation": null
    },
    {
      "time": 84.82,
      "time_str": "01:24.820",
      "text": "明明就 他比较 温柔",
      "translation": null
    },
    {
      "time": 88.91,
      "time_str": "01:28.910",
      "text": "也许他能给你更多",
      "translation": null
    },
    {
      "time": 94.32,
      "time_str": "01:34.320",
      "text": "不用抉择 我会自动变朋友",
      "translation": null
    },
    {
