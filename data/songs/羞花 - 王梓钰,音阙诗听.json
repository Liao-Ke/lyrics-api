    {
      "time": 2.3,
      "time_str": "00:02.300",
      "text": "摘处丹色点眉头",
      "translation": null
    },
    {
      "time": 4.1,
      "time_str": "00:04.100",
      "text": "春意含羞",
      "translation": null
    },
    {
      "time": 6.08,
      "time_str": "00:06.080",
      "text": "摘得百花占鳌头",
      "translation": null
    },
    {
      "time": 7.95,
      "time_str": "00:07.950",
      "text": "华清更漏",
      "translation": null
    },
    {
      "time": 9.93,
      "time_str": "00:09.930",
      "text": "人间不许美人愁",
      "translation": null
    },
    {
      "time": 11.88,
      "time_str": "00:11.880",
      "text": "酩酊解忧",
      "translation": null
    },
    {
      "time": 13.79,
      "time_str": "00:13.790",
      "text": "摘片相思挂心头",
      "translation": null
    },
    {
      "time": 15.81,
      "time_str": "00:15.810",
      "text": "好梦长留",
      "translation": null
    },
    {
      "time": 17.72,
      "time_str": "00:17.720",
      "text": "雾里花似你",
      "translation": null
    },
    {
      "time": 21.49,
      "time_str": "00:21.490",
      "text": "云间月不及",
      "translation": null
    },
    {
      "time": 25.38,
      "time_str": "00:25.380",
      "text": "红尘内寻觅",
      "translation": null
    },
    {
      "time": 29.31,
      "time_str": "00:29.310",
      "text": "一点透灵犀",
      "translation": null
    },
    {
