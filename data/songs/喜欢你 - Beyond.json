  "lyrics": [
    {
      "time": 16.058,
      "time_str": "00:16.058",
      "text": "细雨带风湿透黄昏的街道",
      "translation": null
    },
    {
      "time": 22.29,
      "time_str": "00:22.290",
      "text": "抹去雨水双眼无故地仰望",
      "translation": null
    },
    {
      "time": 27.778,
      "time_str": "00:27.778",
      "text": "望向孤单的晚灯",
      "translation": null
    },
    {
      "time": 30.837,
      "time_str": "00:30.837",
      "text": "是那伤感的记忆",
      "translation": null
    },
    {
      "time": 37.979,
      "time_str": "00:37.979",
      "text": "再次泛起心里无数的思念",
      "translation": null
    },
    {
      "time": 44.216,
      "time_str": "00:44.216",
      "text": "以往片刻欢笑仍挂在脸上",
      "translation": null
    },
    {
      "time": 49.701,
      "time_str": "00:49.701",
      "text": "愿你此刻可会知",
      "translation": null
    },
    {
      "time": 52.818,
      "time_str": "00:52.818",
      "text": "是我衷心的说声",
      "translation": null
    },
    {
      "time": 58.359,
      "time_str": "00:58.359",
      "text": "喜欢你 那双眼动人",
      "translation": null
    },
    {
      "time": 64.586,
      "time_str": "01:04.586",
      "text": "笑声更迷人",
      "translation": null
    },
    {
      "time": 67.761,
      "time_str": "01:07.761",
      "text": "愿再可 轻抚你",
