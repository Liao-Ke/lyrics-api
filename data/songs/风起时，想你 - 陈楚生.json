    {
      "time": 19.12,
      "time_str": "00:19.120",
      "text": "谁 能让我忘了你",
      "translation": null
    },
    {
      "time": 23.18,
      "time_str": "00:23.180",
      "text": "我 用什么写日记",
      "translation": null
    },
    {
      "time": 27.31,
      "time_str": "00:27.310",
      "text": "心 在半空中飞行",
      "translation": null
    },
    {
      "time": 31.37,
      "time_str": "00:31.370",
      "text": "已习惯孤寂",
      "translation": null
    },
    {
      "time": 35.56,
      "time_str": "00:35.560",
      "text": "遇见了你 爱上了你",
      "translation": null
    },
    {
      "time": 39.37,
      "time_str": "00:39.370",
      "text": "最后重归于平静",
      "translation": null
    },
    {
      "time": 43.62,
      "time_str": "00:43.620",
      "text": "我用回忆剪成一部无声电影",
      "translation": null
    },
    {
      "time": 47.49,
      "time_str": "00:47.490",
      "text": "纪念我们真挚的曾经",
      "translation": null
    },
    {
      "time": 51.24,
      "time_str": "00:51.240",
      "text": "珍贵的你",
      "translation": null
    },
    {
      "time": 53.18,
      "time_str": "00:53.180",
      "text": "每当温柔的风把头发吹起",
      "translation": null
    },
    {
      "time": 57.43,
      "time_str": "00:57.430",
      "text": "总让我想起那时别离情景",
      "translation": null
    },
    {
      "time": 61.68,
      "time_str": "01:01.680",
      "text": "你的眼泪是那样晶莹透明",
      "translation": null
    },
    {
      "time": 65.74,
      "time_str": "01:05.740",
      "text": "每一滴 在我心里",
