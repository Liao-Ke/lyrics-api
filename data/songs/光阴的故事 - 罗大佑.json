{
  "title": "光阴的故事",
  "title_raw": "光阴的故事",
  "version": null,
  "artist": "罗大佑",
  "group_key": "光阴的故事|罗大佑",
  "writers": {
    "lyricist": "罗大佑",
    "composer": "罗大佑",
    "arranger": "罗大佑"
  },
  "lyrics": [
    {
      "time": 16.88,
      "time_str": "00:16.880",
      "text": "春天的花开秋天的风以及冬天的落阳",
      "translation": null
    },
    {
      "time": 24.08,
      "time_str": "00:24.080",
      "text": "忧郁的青春年少的我曾经无知的这么想",
      "translation": null
    },
    {
      "time": 31.54,
      "time_str": "00:31.540",
      "text": "风车在四季轮回的歌里它天天地流转",
      "translation": null
    },
    {
      "time": 38.3,
      "time_str": "00:38.300",
      "text": "风花雪月的诗句里我在年年的成长",
      "translation": null
    },
    {
      "time": 47.0,
      "time_str": "00:47.000",
      "text": "流水他带走光阴的故事改变了一个人",
      "translation": null
    },
    {
      "time": 53.19,
      "time_str": "00:53.190",
      "text": "就在那多愁善感而初次等待的青春",
      "translation": null
    },
    {
      "time": 74.38,
      "time_str": "01:14.380",
      "text": "发黄的相片古老的信以及褪色的圣诞卡",
      "translation": null
    },
    {
      "time": 82.22,
      "time_str": "01:22.220",
      "text": "年轻时为你写的歌恐怕你早已忘了吧",
      "translation": null
    },
    {
      "time": 89.38,
      "time_str": "01:29.380",
      "text": "过去的誓言就像那课本里缤纷的书签",
      "translation": null
    },
    {
      "time": 95.35,
      "time_str": "01:35.350",
      "text": "刻划着多少美丽的诗 可是终究是一阵烟",
      "translation": null
    },
    {
      "time": 102.53,
      "time_str": "01:42.530",
      "text": "流水它带走光阴的故事改变了两个人",
      "translation": null
    },
    {
      "time": 110.03,
      "time_str": "01:50.030",
      "text": "就在那多愁善感而初次流泪的青春",
      "translation": null
    },
    {
      "time": 132.22,
      "time_str": "02:12.220",
      "text": "遥远的路程昨日的梦以及远去的笑声",
      "translation": null
    },
    {
      "time": 139.02,
      "time_str": "02:19.020",
      "text": "再次的见面我们又历经了多少的路程",
      "translation": null
    },
    {
      "time": 145.99,
      "time_str": "02:25.990",
      "text": "不再是旧日熟悉的我有着旧日狂热的梦",
      "translation": null
    },
    {
      "time": 151.77,
      "time_str": "02:31.770",
      "text": "也不是旧日熟悉的你有着依然的笑容",
      "translation": null
    },
    {
      "time": 160.52,
      "time_str": "02:40.520",
      "text": "流水它带走光阴的故事改变了我们",
      "translation": null
    },
    {
      "time": 167.31,
      "time_str": "02:47.310",
      "text": "就在那多愁善感而初次回忆的青春",
      "translation": null
    },
    {
      "time": 174.42,
      "time_str": "02:54.420",
      "text": "流水它带走光阴的故事改变了我们",
      "translation": null
    },
    {
      "time": 181.21,
      "time_str": "03:01.210",
      "text": "就在那多愁善感而初次回忆的青春",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "光阴的故事 - 罗大佑.lrc"
}