    {
      "time": 11.01,
      "time_str": "00:11.010",
      "text": "说好的 三年不见面",
      "translation": null
    },
    {
      "time": 16.3,
      "time_str": "00:16.300",
      "text": "用我们的爱把时间留住",
      "translation": null
    },
    {
      "time": 21.2,
      "time_str": "00:21.200",
      "text": "你笑着说这是我们的考验",
      "translation": null
    },
    {
      "time": 26.07,
      "time_str": "00:26.070",
      "text": "我们的约定",
      "translation": null
    },
    {
      "time": 31.4,
      "time_str": "00:31.400",
      "text": "就这样 三年又过了",
      "translation": null
    },
    {
      "time": 37.15,
      "time_str": "00:37.150",
      "text": "我还是回到这个地方",
      "translation": null
    },
    {
      "time": 41.57,
      "time_str": "00:41.570",
      "text": "闭上眼等你的出现",
      "translation": null
    },
    {
      "time": 46.73,
      "time_str": "00:46.730",
      "text": "空气中吻你的脸",
      "translation": null
    },
    {
      "time": 51.61,
      "time_str": "00:51.610",
      "text": "我还记得 我们的约定",
      "translation": null
    },
    {
      "time": 56.9,
      "time_str": "00:56.900",
      "text": "一辈子幸福的约定",
      "translation": null
    },
    {
      "time": 61.81,
      "time_str": "01:01.810",
      "text": "为你写的那首歌",
      "translation": null
    },
    {
      "time": 66.77,
      "time_str": "01:06.770",
      "text": "他也偷偷的掉泪了",
      "translation": null
    },
    {
      "time": 71.57,
      "time_str": "01:11.570",
      "text": "我还记得 我们的约定",
      "translation": null
    },
    {
      "time": 76.79,
      "time_str": "01:16.790",
      "text": "我比以前还更爱你了",
      "translation": null
    },
    {
      "time": 81.87,
      "time_str": "01:21.870",
      "text": "连那风都笑我了",
      "translation": null
    },
    {
      "time": 86.79,
      "time_str": "01:26.790",
      "text": "我想他会告诉你的",
      "translation": null
    },
    {
