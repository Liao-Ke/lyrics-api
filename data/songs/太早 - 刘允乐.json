    {
      "time": 27.06,
      "time_str": "00:27.060",
      "text": "我知道你装成听不到",
      "translation": null
    },
    {
      "time": 33.229,
      "time_str": "00:33.229",
      "text": "我也能知道我的你都不要",
      "translation": null
    },
    {
      "time": 40.009,
      "time_str": "00:40.009",
      "text": "我知道我都知道 这是分手预兆",
      "translation": null
    },
    {
      "time": 48.309,
      "time_str": "00:48.309",
      "text": "却还要讨你不停的笑",
      "translation": null
    },
    {
      "time": 55.69,
      "time_str": "00:55.690",
      "text": "我知道就快没完没了",
      "translation": null
    },
    {
      "time": 61.038,
      "time_str": "01:01.038",
      "text": "你对我的好都来不及回报",
      "translation": null
    },
    {
      "time": 68.689,
      "time_str": "01:08.689",
      "text": "你知道我不知道 该用什么计较",
      "translation": null
    },
    {
      "time": 76.099,
      "time_str": "01:16.099",
      "text": "去换每一个天黑的拥抱",
      "translation": null
    },
    {
      "time": 84.09,
      "time_str": "01:24.090",
      "text": "我明知道你走得太早",
      "translation": null
    },
    {
      "time": 90.39,
      "time_str": "01:30.390",
      "text": "还要为你帮他买对车票",
      "translation": null
    },
    {
