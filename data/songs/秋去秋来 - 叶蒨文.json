{
  "title": "秋去秋来",
  "title_raw": "秋去秋来",
  "version": null,
  "artist": "叶蒨文",
  "group_key": "秋去秋来|叶蒨文",
  "writers": {
    "lyricist": "林振强",
    "composer": "熊美玲",
    "arranger": "钟定一"
  },
  "lyrics": [
    {
      "time": 0.629,
      "time_str": "00:00.629",
      "text": "红红黄黄叶儿伴我窗",
      "translation": null
    },
    {
      "time": 6.619,
      "time_str": "00:06.619",
      "text": "飘他方的你可有着凉",
      "translation": null
    },
    {
      "time": 13.28,
      "time_str": "00:13.280",
      "text": "静问为何是你使我等待",
      "translation": null
    },
    {
      "time": 18.799,
      "time_str": "00:18.799",
      "text": "怎么要千滴热泪滴进我梦乡",
      "translation": null
    },
    {
      "time": 24.898,
      "time_str": "00:24.898",
      "text": "又是凉的秋 愁无尽的秋",
      "translation": null
    },
    {
      "time": 31.398,
      "time_str": "00:31.398",
      "text": "知否当你远去后牵挂到倦透",
      "translation": null
    },
    {
      "time": 41.699,
      "time_str": "00:41.699",
      "text": "旁人常问何事要等",
      "translation": null
    },
    {
      "time": 47.809,
      "time_str": "00:47.809",
      "text": "怎么可一世不爱别人",
      "translation": null
    },
    {
      "time": 54.129,
      "time_str": "00:54.129",
      "text": "自问若忘掉你都算应份",
      "translation": null
    },
    {
      "time": 60.39,
      "time_str": "01:00.390",
      "text": "可惜每当叶落便念你更深",
      "translation": null
    },
    {
      "time": 66.5,
      "time_str": "01:06.500",
      "text": "背着人心酸 人如愿相恋",
      "translation": null
    },
    {
      "time": 72.289,
      "time_str": "01:12.289",
      "text": "推搪当世界再没秋季再算",
      "translation": null
    },
    {
      "time": 79.38,
      "time_str": "01:19.380",
      "text": "秋来也秋去 秋风教人掉眼泪",
      "translation": null
    },
    {
      "time": 85.719,
      "time_str": "01:25.719",
      "text": "何时才跟你可重聚",
      "translation": null
    },
    {
      "time": 91.99,
      "time_str": "01:31.990",
      "text": "秋来也秋去 要到几多岁",
      "translation": null
    },
    {
      "time": 97.89,
      "time_str": "01:37.890",
      "text": "方信你与我早早告吹",
      "translation": null
    },
    {
      "time": 105.3,
      "time_str": "01:45.300",
      "text": "秋来也秋去 千千片红叶跌坠",
      "translation": null
    },
    {
      "time": 110.96,
      "time_str": "01:50.960",
      "text": "如完成凄美的程序",
      "translation": null
    },
    {
      "time": 117.179,
      "time_str": "01:57.179",
      "text": "秋来也秋去 我似秋空虚",
      "translation": null
    },
    {
      "time": 123.109,
      "time_str": "02:03.109",
      "text": "只有信会跟你再共对",
      "translation": null
    },
    {
      "time": 155.128,
      "time_str": "02:35.128",
      "text": "旁人常问何事要等",
