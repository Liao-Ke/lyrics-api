  "lyrics": [
    {
      "time": 25.24,
      "time_str": "00:25.240",
      "text": "（男）九九那个艳阳天来哟",
      "translation": null
    },
    {
      "time": 30.91,
      "time_str": "00:30.910",
      "text": "（男）十八岁的哥哥坐在河边",
      "translation": null
    },
    {
      "time": 36.28,
      "time_str": "00:36.280",
      "text": "（男）东风呀吹得那个风车转哪",
      "translation": null
    },
    {
      "time": 41.83,
      "time_str": "00:41.830",
      "text": "（男）蚕豆花儿香呀　麦苗儿鲜",
      "translation": null
    },
    {
      "time": 47.47,
      "time_str": "00:47.470",
      "text": "（合）风车呀风车那个依呀呀地唱哪",
      "translation": null
    },
    {
      "time": 53.38,
      "time_str": "00:53.380",
      "text": "（合）小哥哥为什么呀　不开言",
      "translation": null
    },
    {
      "time": 59.04,
      "time_str": "00:59.040",
      "text": "（女）九九那个艳阳天来哟",
      "translation": null
    },
    {
      "time": 64.22,
      "time_str": "01:04.220",
      "text": "（女）十八岁的哥哥想把军来参",
      "translation": null
    },
    {
      "time": 69.76,
      "time_str": "01:09.760",
      "text": "（女）风车呀跟着那个东风转",
      "translation": null
    },
    {
      "time": 75.23,
      "time_str": "01:15.230",
      "text": "（女）哥哥惦记着呀小英莲",
      "translation": null
    },
    {
      "time": 80.8,
      "time_str": "01:20.800",
      "text": "（合）风向不定那个车难转",
      "translation": null
    },
    {
      "time": 86.37,
      "time_str": "01:26.370",
      "text": "（合）决心没有下呀怎么开言",
      "translation": null
    },
    {
      "time": 91.96,
      "time_str": "01:31.960",
      "text": "********",
      "translation": null
    },
    {
      "time": 113.96,
      "time_str": "01:53.960",
      "text": "（男）九九那个艳阳天来哟",
      "translation": null
    },
    {
      "time": 119.62,
      "time_str": "01:59.620",
      "text": "（男）十八岁的哥哥告诉小英莲",
      "translation": null
    },
    {
      "time": 125.29,
      "time_str": "02:05.290",
      "text": "（男）这一去翻山又过海呀",
      "translation": null
    },
    {
      "time": 130.66,
      "time_str": "02:10.660",
      "text": "（男）这一去三年两载呀不回还",
      "translation": null
    },
    {
      "time": 136.25,
      "time_str": "02:16.250",
      "text": "（合）这一去呀枪如林弹如雨呀",
      "translation": null
    },
    {
      "time": 141.82,
      "time_str": "02:21.820",
      "text": "（合）这一去革命胜利呀再相见",
      "translation": null
    },
    {
      "time": 147.79,
      "time_str": "02:27.790",
      "text": "（女）九九那个艳阳天来哟",
      "translation": null
    },
    {
      "time": 153.1,
      "time_str": "02:33.100",
      "text": "（女）十八岁的哥哥细听我小英莲",
      "translation": null
    },
    {
      "time": 158.58,
      "time_str": "02:38.580",
      "text": "（女）哪怕你一去呀千万里呀",
      "translation": null
    },
    {
      "time": 164.24,
      "time_str": "02:44.240",
      "text": "（女）哪怕你十年八载不回还",
      "translation": null
    },
    {
      "time": 169.84,
      "time_str": "02:49.840",
      "text": "（合）只要你不把我英莲（哥哥）忘呀",
      "translation": null
    },
    {
      "time": 175.4,
      "time_str": "02:55.400",
      "text": "（合）只要你（我）胸佩红花呀回家转",
      "translation": null
    },
    {
      "time": 181.3,
      "time_str": "03:01.300",
      "text": "（合）只要你（我）胸佩红花呀回家转",
      "translation": null
    },
    {
      "time": 186.96,
      "time_str": "03:06.960",
      "text": "***END***",
      "translation": null
    }
