  "lyrics": [
    {
      "time": 26.27,
      "time_str": "00:26.270",
      "text": "夜风凛凛 独回望旧事前尘",
      "translation": null
    },
    {
      "time": 32.17,
      "time_str": "00:32.170",
      "text": "是以往的我 充满怒愤",
      "translation": null
    },
    {
      "time": 38.2,
      "time_str": "00:38.200",
      "text": "诬告与指责积压着满肚气不忿",
      "translation": null
    },
    {
      "time": 43.18,
      "time_str": "00:43.180",
      "text": "对谣言反应甚为着紧",
      "translation": null
    },
    {
      "time": 50.0,
      "time_str": "00:50.000",
      "text": "受了教训 得了书经的指引",
      "translation": null
    },
    {
      "time": 55.06,
      "time_str": "00:55.060",
      "text": "现已看得透 不再自困",
      "translation": null
    },
    {
      "time": 61.84,
      "time_str": "01:01.840",
      "text": "但觉有分数",
      "translation": null
    },
    {
      "time": 63.53,
      "time_str": "01:03.530",
      "text": "不再像以往那般笨",
      "translation": null
    },
    {
      "time": 66.0,
      "time_str": "01:06.000",
      "text": "抹泪痕轻快笑着行",
      "translation": null
    },
    {
      "time": 73.0,
      "time_str": "01:13.000",
      "text": "冥冥中都早注定你富或贫",
      "translation": null
    },
    {
      "time": 79.03,
      "time_str": "01:19.030",
      "text": "是错永不对真永是真",
      "translation": null
    },
    {
      "time": 84.0,
      "time_str": "01:24.000",
      "text": "任你怎说安守我本分",
      "translation": null
    },
    {
      "time": 89.0,
      "time_str": "01:29.000",
      "text": "始终相信沉默是金",
      "translation": null
    },
    {
      "time": 96.04,
      "time_str": "01:36.040",
      "text": "是非有公理 慎言莫冒犯别人",
      "translation": null
    },
    {
      "time": 102.0,
      "time_str": "01:42.000",
      "text": "遇上冷风雨休太认真",
      "translation": null
    },
    {
      "time": 108.05,
      "time_str": "01:48.050",
      "text": "自信满心里 休理会讽刺与质问",
      "translation": null
    },
    {
      "time": 112.08,
      "time_str": "01:52.080",
      "text": "笑骂由人 洒脱地做人",
      "translation": null
