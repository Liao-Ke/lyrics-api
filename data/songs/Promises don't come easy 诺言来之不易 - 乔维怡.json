  },
  "lyrics": [
    {
      "time": 23.12,
      "time_str": "00:23.120",
      "text": "I should have known all along,",
      "translation": "我本应一直明白"
    },
    {
      "time": 26.26,
      "time_str": "00:26.260",
      "text": "there was something wrong",
      "translation": "我们之间出现了问题"
    },
    {
      "time": 29.15,
      "time_str": "00:29.150",
      "text": "I just never read between the lines",
      "translation": "我从未读懂你的弦外之音"
    },
    {
      "time": 35.9,
      "time_str": "00:35.900",
      "text": "Then I woke up one day",
      "translation": "于是有一天我醒来"
    },
    {
      "time": 37.49,
      "time_str": "00:37.490",
      "text": "and found you on your way",
      "translation": "发现你已离去"
    },
    {
      "time": 40.75,
      "time_str": "00:40.750",
      "text": "Leaving nothing but my heart behind",
      "translation": "只留下了我的心"
    },
    {
      "time": 47.31,
      "time_str": "00:47.310",
      "text": "What can I do to make it up to you",
      "translation": "我能做什么来补偿你呢"
    },
    {
      "time": 51.76,
      "time_str": "00:51.760",
      "text": "Promises donte easy",
      "translation": "承诺来的不易"
    },
    {
      "time": 57.86,
      "time_str": "00:57.860",
      "text": "But tell me if theres a way",
      "translation": "但我能否"
    },
    {
      "time": 60.69,
      "time_str": "01:00.690",
      "text": "to bring you back home to stay",
      "translation": "让你回心转意"
    },
    {
      "time": 63.95,
      "time_str": "01:03.950",
      "text": "Well Id promise anything to you",
      "translation": "我将承诺一切"
    },
    {
      "time": 72.61,
      "time_str": "01:12.610",
      "text": "Ive been walkin around",
      "translation": "我四处游荡"
    },
    {
      "time": 75.36,
      "time_str": "01:15.360",
      "text": "with my head hanging down",
      "translation": "脑袋低垂"
    },
    {
      "time": 79.27,
      "time_str": "01:19.270",
      "text": "Wondrin what Im gonna do",
      "translation": "不知何去何从"
    },
    {
      "time": 83.87,
      "time_str": "01:23.870",
      "text": "Cause when you walked out that door,",
      "translation": "因为当你离去"
    },
    {
      "time": 86.789,
      "time_str": "01:26.789",
      "text": "I knew I needed you more",
      "translation": "我将更加需要你"
    },
    {
      "time": 89.96,
      "time_str": "01:29.960",
      "text": "Than to take a chance on losing you",
      "translation": "那么放手一搏吧"
    },
    {
      "time": 96.46,
      "time_str": "01:36.460",
      "text": "What can I do to make it up to you",
      "translation": "我能做什么来补偿你呢"
    },
    {
      "time": 101.97,
      "time_str": "01:41.970",
      "text": "Promises donte easy",
      "translation": "承诺来的不易"
    },
    {
      "time": 106.97,
      "time_str": "01:46.970",
      "text": "You know Ive made up my mind",
      "translation": "你知道这次我将全心全意"
    },
    {
      "time": 109.91,
      "time_str": "01:49.910",
      "text": "to make it work this time",
      "translation": "这是我给你的承诺"
    },
    {
      "time": 113.1,
      "time_str": "01:53.100",
      "text": "Thats the promise that I give to you",
      "translation": "你从不认为我爱你"
    },
    {
      "time": 119.91,
      "time_str": "01:59.910",
      "text": "You never thought I loved you",
      "translation": "我猜你没想过我在乎"
    },
    {
      "time": 124.89,
      "time_str": "02:04.890",
      "text": "I guess you never thought I cared",
      "translation": "但我只不过是太矜持"
    },
    {
      "time": 130.669,
      "time_str": "02:10.669",
      "text": "I was just too proud to say it out loud",
      "translation": "而无法大声表白"
    },
    {
      "time": 137.36,
      "time_str": "02:17.360",
      "text": "Now I know,",
      "translation": "现在我知道"
    },
    {
      "time": 139.61,
      "time_str": "02:19.610",
      "text": "to let my feelings go (so tell me)",
      "translation": "应该让情感释放"
    },
    {
      "time": 143.13,
      "time_str": "02:23.130",
      "text": "What can I do to make it up to you",
      "translation": "所以告诉我吧"
    },
    {
      "time": 148.55,
      "time_str": "02:28.550",
      "text": "Promises donte easy",
      "translation": "我能做什么来补偿你呢"
    },
    {
      "time": 153.6,
      "time_str": "02:33.600",
      "text": "You know Ive made up my mind",
      "translation": "承诺来的不易"
    },
    {
      "time": 156.5,
      "time_str": "02:36.500",
      "text": "to make it work this time",
      "translation": "你知道这次我将全心全意"
    },
    {
      "time": 159.31,
      "time_str": "02:39.310",
      "text": "Thats the promise I can give to you",
      "translation": "这是我给你的承诺"
    },
    {
      "time": 165.9,
      "time_str": "02:45.900",
      "text": "What can I do to make it up to you",
      "translation": "我能做什么来补偿你呢？"
    },
    {
      "time": 171.84,
      "time_str": "02:51.840",
      "text": "----",
      "translation": null
    }
  ],
