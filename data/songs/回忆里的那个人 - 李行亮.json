  "lyrics": [
    {
      "time": 20.21,
      "time_str": "00:20.210",
      "text": "路灯下的恋人",
      "translation": null
    },
    {
      "time": 23.79,
      "time_str": "00:23.790",
      "text": "多像是曾经的我们",
      "translation": null
    },
    {
      "time": 28.04,
      "time_str": "00:28.040",
      "text": "深情拥抱亲吻",
      "translation": null
    },
    {
      "time": 32.01,
      "time_str": "00:32.010",
      "text": "爱的难舍又难分",
      "translation": null
    },
    {
      "time": 36.21,
      "time_str": "00:36.210",
      "text": "曾相爱的光阴",
      "translation": null
    },
    {
      "time": 39.94,
      "time_str": "00:39.940",
      "text": "全世界只有两个人",
      "translation": null
    },
    {
      "time": 44.26,
      "time_str": "00:44.260",
      "text": "为何一个转身",
      "translation": null
    },
    {
      "time": 48.33,
      "time_str": "00:48.330",
      "text": "就能变成陌路人",
      "translation": null
    },
    {
      "time": 52.1,
      "time_str": "00:52.100",
      "text": "藏在我回忆里的那个人",
      "translation": null
    },
    {
      "time": 56.74,
      "time_str": "00:56.740",
      "text": "愿你现在过得幸福安稳",
      "translation": null
    },
    {
      "time": 60.76,
      "time_str": "01:00.760",
      "text": "若再相遇人海黄昏",
      "translation": null
    },
    {
      "time": 64.48,
      "time_str": "01:04.480",
      "text": "你是否还记得我的眼神",
      "translation": null
    },
    {
      "time": 67.86,
      "time_str": "01:07.860",
      "text": "藏在我回忆里的那个人",
      "translation": null
    },
    {
      "time": 72.61,
      "time_str": "01:12.610",
      "text": "有你我的青春才算完整",
      "translation": null
    },
    {
      "time": 76.56,
      "time_str": "01:16.560",
      "text": "感谢曾经你的认真",
      "translation": null
    },
    {
      "time": 80.51,
      "time_str": "01:20.510",
      "text": "让我知道爱一个人会奋不顾身",
      "translation": null
    },
