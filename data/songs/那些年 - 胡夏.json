  "lyrics": [
    {
      "time": 18.1,
      "time_str": "00:18.100",
      "text": "又回到最初的起点",
      "translation": null
    },
    {
      "time": 20.89,
      "time_str": "00:20.890",
      "text": "记忆中你青涩的脸",
      "translation": null
    },
    {
      "time": 24.24,
      "time_str": "00:24.240",
      "text": "我们终于",
      "translation": null
    },
    {
      "time": 25.95,
      "time_str": "00:25.950",
      "text": "来到了这一天",
      "translation": null
    },
    {
      "time": 30.33,
      "time_str": "00:30.330",
      "text": "桌垫下的老照片",
      "translation": null
    },
    {
      "time": 33.46,
      "time_str": "00:33.460",
      "text": "无数回忆连结",
      "translation": null
    },
    {
      "time": 35.7,
      "time_str": "00:35.700",
      "text": "今天男孩要赴女孩最后的约",
      "translation": null
    },
    {
      "time": 42.45,
      "time_str": "00:42.450",
      "text": "又回到最初的起点",
      "translation": null
    },
    {
      "time": 45.37,
      "time_str": "00:45.370",
      "text": "呆呆地站在镜子前",
      "translation": null
    },
    {
      "time": 48.58,
      "time_str": "00:48.580",
      "text": "笨拙系上红色领带的结",
      "translation": null
    },
    {
      "time": 53.57,
      "time_str": "00:53.570",
      "text": "将头发梳成大人模样",
      "translation": null
    },
    {
      "time": 57.41,
      "time_str": "00:57.410",
      "text": "穿上一身帅气西装",
      "translation": null
    },
    {
      "time": 59.97,
      "time_str": "00:59.970",
      "text": "等会儿见你一定比想象美",
      "translation": null
    },
    {
      "time": 67.19,
      "time_str": "01:07.190",
      "text": "好想再回到那些年的时光",
      "translation": null
    },
    {
      "time": 71.53,
      "time_str": "01:11.530",
      "text": "回到教室座位前后",
      "translation": null
    },
    {
      "time": 74.49,
      "time_str": "01:14.490",
      "text": "故意讨你温柔的骂",
      "translation": null
    },
    {
      "time": 79.31,
      "time_str": "01:19.310",
      "text": "黑板上排列组合",
      "translation": null
    },
    {
      "time": 82.25,
      "time_str": "01:22.250",
      "text": "你舍得解开吗",
      "translation": null
    },
    {
      "time": 85.39,
      "time_str": "01:25.390",
      "text": "谁与谁坐他又爱着她",
      "translation": null
    },
    {
      "time": 94.04,
      "time_str": "01:34.040",
      "text": "那些年错过的大雨",
      "translation": null
    },
    {
      "time": 97.05,
      "time_str": "01:37.050",
      "text": "那些年错过的爱情",
      "translation": null
    },
    {
      "time": 99.87,
      "time_str": "01:39.870",
      "text": "好想拥抱你",
      "translation": null
    },
    {
      "time": 102.0,
      "time_str": "01:42.000",
      "text": "拥抱错过的勇气",
      "translation": null
    },
    {
      "time": 106.16,
      "time_str": "01:46.160",
      "text": "曾经想征服全世界",
      "translation": null
    },
    {
      "time": 109.14,
      "time_str": "01:49.140",
      "text": "到最后回首才发现",
      "translation": null
    },
    {
      "time": 111.57,
      "time_str": "01:51.570",
      "text": "这世界滴滴点点全部都是你",
      "translation": null
    },
    {
      "time": 118.44,
      "time_str": "01:58.440",
      "text": "那些年错过的大雨",
      "translation": null
    },
    {
      "time": 121.32,
      "time_str": "02:01.320",
      "text": "那些年错过的爱情",
      "translation": null
    },
    {
      "time": 124.17,
      "time_str": "02:04.170",
      "text": "好想告诉你",
      "translation": null
    },
    {
      "time": 126.21,
      "time_str": "02:06.210",
      "text": "告诉你我没有忘记",
      "translation": null
    },
    {
      "time": 130.48,
      "time_str": "02:10.480",
      "text": "那天晚上满天星星",
      "translation": null
    },
    {
      "time": 133.45,
      "time_str": "02:13.450",
      "text": "平行时空下的约定",
      "translation": null
    },
    {
      "time": 135.95,
      "time_str": "02:15.950",
      "text": "再一次相遇我会",
      "translation": null
    },
    {
      "time": 138.5,
      "time_str": "02:18.500",
      "text": "紧紧抱着你",
      "translation": null
    },
    {
