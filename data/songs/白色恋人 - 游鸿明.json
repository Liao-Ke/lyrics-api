    {
      "time": 45.799,
      "time_str": "00:45.799",
      "text": "冷空气 却清晰",
      "translation": null
    },
    {
      "time": 50.49,
      "time_str": "00:50.490",
      "text": "你在南极冰山雪地里",
      "translation": null
    },
    {
      "time": 55.8,
      "time_str": "00:55.800",
      "text": "极光中雪白的肌肤",
      "translation": null
    },
    {
      "time": 59.6,
      "time_str": "00:59.600",
      "text": "是哀愁是美丽",
      "translation": null
    },
    {
      "time": 64.03,
      "time_str": "01:04.030",
      "text": "为了要遇见你",
      "translation": null
    },
    {
      "time": 71.4,
      "time_str": "01:11.400",
      "text": "我连呼吸都反复练习",
      "translation": null
    },
    {
      "time": 75.169,
      "time_str": "01:15.169",
      "text": "兰伯特仁慈的冰川",
      "translation": null
    },
    {
      "time": 80.18,
      "time_str": "01:20.180",
      "text": "带领我走向你",
      "translation": null
    },
    {
      "time": 84.9,
      "time_str": "01:24.900",
      "text": "零下九十一度的酷寒",
      "translation": null
    },
    {
      "time": 91.169,
      "time_str": "01:31.169",
      "text": "滚滚红尘千年的呼喊",
      "translation": null
    },
    {
      "time": 96.6,
      "time_str": "01:36.600",
      "text": "藏在沃斯托克的湖岸",
      "translation": null
    },
    {
      "time": 100.529,
      "time_str": "01:40.529",
      "text": "沉寂轻叹",
      "translation": null
    },
    {
      "time": 104.209,
      "time_str": "01:44.209",
      "text": "撒哈拉漫天狂沙 金字塔谁能解答",
      "translation": null
    },
    {
      "time": 112.308,
      "time_str": "01:52.308",
      "text": "兵马俑谁与争锋 长城万里相逢",
      "translation": null
    },
    {
      "time": 121.919,
      "time_str": "02:01.919",
      "text": "人世间悲欢聚散 一页页写在心上",
      "translation": null
    },
    {
      "time": 131.288,
      "time_str": "02:11.288",
      "text": "含着泪白色恋人 却有灰色的年轮",
