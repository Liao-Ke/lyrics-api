    },
    {
      "time": 27.2,
      "time_str": "00:27.200",
      "text": "纵马江湖道 今生任逍遥",
      "translation": null
    },
    {
      "time": 31.83,
      "time_str": "00:31.830",
      "text": "英雄不为红颜折腰",
      "translation": null
    },
    {
      "time": 36.25,
      "time_str": "00:36.250",
      "text": "豪情比天高 一身冷傲骨",
      "translation": null
    },
    {
      "time": 40.59,
      "time_str": "00:40.590",
      "text": "天地来打造",
      "translation": null
    },
    {
      "time": 43.14,
      "time_str": "00:43.140",
      "text": "剑荡群魔鬼神惊",
      "translation": null
    },
    {
      "time": 47.13,
      "time_str": "00:47.130",
      "text": "男儿正侠少",
      "translation": null
    },
    {
      "time": 49.3,
      "time_str": "00:49.300",
      "text": "手握残阳沥血剑",
      "translation": null
    },
    {
      "time": 51.51,
      "time_str": "00:51.510",
      "text": "心有冷月凝霜刀",
      "translation": null
    },
    {
      "time": 54.12,
      "time_str": "00:54.120",
      "text": "绝顶一览众山小",
