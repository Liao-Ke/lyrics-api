  "lyrics": [
    {
      "time": 24.54,
      "time_str": "00:24.540",
      "text": "只想把你装进我行李",
      "translation": null
    },
    {
      "time": 27.26,
      "time_str": "00:27.260",
      "text": "打包带走住进你心底",
      "translation": null
    },
    {
      "time": 30.26,
      "time_str": "00:30.260",
      "text": "别再说我是个好人好吗",
      "translation": null
    },
    {
      "time": 33.14,
      "time_str": "00:33.140",
      "text": "不想让你被骗去坏人家",
      "translation": null
    },
    {
      "time": 35.98,
      "time_str": "00:35.980",
      "text": "只是想要跟你在一起",
      "translation": null
    },
    {
      "time": 38.82,
      "time_str": "00:38.820",
      "text": "可是你为什么不同意",
      "translation": null
    },
    {
      "time": 41.74,
      "time_str": "00:41.740",
      "text": "给我发了无数张好人卡",
      "translation": null
    },
    {
      "time": 44.5,
      "time_str": "00:44.500",
      "text": "是个好人真的打扰了",
      "translation": null
    },
    {
      "time": 46.72,
      "time_str": "00:46.720",
      "text": "Oh宝贝别再让我难过",
      "translation": null
    },
    {
      "time": 48.56,
      "time_str": "00:48.560",
      "text": "你知道孤单的夜我一个人早就受够",
      "translation": null
    },
    {
      "time": 51.74,
      "time_str": "00:51.740",
      "text": "关系变得尴尬在跟你表白之后",
      "translation": null
    },
    {
      "time": 54.44,
      "time_str": "00:54.440",
      "text": "你说只把我当成好朋友而不是男朋友",
      "translation": null
    },
    {
      "time": 57.41,
      "time_str": "00:57.410",
      "text": "OK好吧我也不想让你难做",
      "translation": null
    },
    {
      "time": 60.11,
      "time_str": "01:00.110",
      "text": "一个人生活早就习惯其实过的也不错",
      "translation": null
    },
    {
      "time": 63.21,
      "time_str": "01:03.210",
      "text": "除了吃不到你之外",
      "translation": null
    },
    {
      "time": 64.5,
      "time_str": "01:04.500",
      "text": "还是能吃到大鱼大肉",
      "translation": null
    },
    {
      "time": 65.95,
      "time_str": "01:05.950",
      "text": "这个凌乱的房间袜子依然很臭",
      "translation": null
    },
    {
      "time": 68.89,
      "time_str": "01:08.890",
      "text": "可变化就在某天早上打开朋友圈",
      "translation": null
    },
    {
      "time": 71.56,
      "time_str": "01:11.560",
      "text": "看到你和陌生男的秀恩爱的照片",
      "translation": null
    },
    {
      "time": 74.32,
      "time_str": "01:14.320",
      "text": "我至少拿着手机懵逼了三分钟的时间",
      "translation": null
    },
    {
      "time": 77.43,
      "time_str": "01:17.430",
      "text": "感觉到被欺骗跪在地上思绪万千",
      "translation": null
    },
    {
      "time": 80.31,
      "time_str": "01:20.310",
      "text": "怎么办我找到你的电话打给你说干就干",
      "translation": null
    },
    {
      "time": 84.04,
      "time_str": "01:24.040",
      "text": "我问你为什么跟别人在一起",
      "translation": null
    },
    {
      "time": 86.1,
      "time_str": "01:26.100",
      "text": "你说我是个好人是我配不上你（wonderful）",
      "translation": null
    },
    {
      "time": 93.1,
      "time_str": "01:33.100",
      "text": "只想把你装进我行李",
      "translation": null
    },
    {
      "time": 95.93,
      "time_str": "01:35.930",
      "text": "打包带走住进你心底",
      "translation": null
    },
    {
      "time": 98.69,
