  "lyrics": [
    {
      "time": 29.72,
      "time_str": "00:29.720",
      "text": "如早春初醒 催促我的心",
      "translation": null
    },
    {
      "time": 34.9,
      "time_str": "00:34.900",
      "text": "将不可再等",
      "translation": null
    },
    {
      "time": 39.0,
      "time_str": "00:39.000",
      "text": "含情待放那岁月",
      "translation": null
    },
    {
      "time": 42.05,
      "time_str": "00:42.050",
      "text": "空出了痴心 令人动心",
      "translation": null
    },
    {
      "time": 49.57,
      "time_str": "00:49.570",
      "text": "幸福的光阴 它不会偏心",
      "translation": null
    },
    {
      "time": 54.63,
      "time_str": "00:54.630",
      "text": "将分给每颗心",
      "translation": null
    },
    {
      "time": 58.75,
      "time_str": "00:58.750",
      "text": "情缘亦远亦近 将交错一生",
      "translation": null
    },
    {
      "time": 64.349,
      "time_str": "01:04.349",
      "text": "情侣爱得更甚",
      "translation": null
    },
    {
      "time": 69.697,
      "time_str": "01:09.697",
      "text": "甜蜜地与爱人 风里飞奔",
      "translation": null
    },
    {
      "time": 74.299,
      "time_str": "01:14.299",
      "text": "高声欢呼你有情 不枉这生",
      "translation": null
    },
    {
      "time": 79.15,
      "time_str": "01:19.150",
      "text": "一声你愿意 一声我愿意",
      "translation": null
    },
    {
      "time": 84.388,
      "time_str": "01:24.388",
      "text": "惊天爱再没遗憾",
      "translation": null
    },
    {
      "time": 89.498,
      "time_str": "01:29.498",
      "text": "明月雾里照人 相爱相亲",
      "translation": null
    },
    {
      "time": 94.409,
      "time_str": "01:34.409",
      "text": "让对对的恋人 增添性感",
      "translation": null
    },
    {
      "time": 99.209,
      "time_str": "01:39.209",
      "text": "一些恋爱变恨",
      "translation": null
    },
    {
      "time": 101.54,
      "time_str": "01:41.540",
      "text": "更多恋爱故事动人",
      "translation": null
    },
    {
      "time": 104.01,
      "time_str": "01:44.010",
      "text": "划上了丝丝美感",
      "translation": null
    },
