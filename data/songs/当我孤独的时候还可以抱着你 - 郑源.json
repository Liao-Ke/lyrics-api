{
  "title": "当我孤独的时候还可以抱着你",
  "title_raw": "当我孤独的时候还可以抱着你",
  "version": null,
  "artist": "郑源",
  "group_key": "当我孤独的时候还可以抱着你|郑源",
  "writers": {
