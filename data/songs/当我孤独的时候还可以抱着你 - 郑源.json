  },
  "lyrics": [
    {
      "time": 19.47,
      "time_str": "00:19.470",
      "text": "我以为自己应该是最寂寞的人",
      "translation": null
    },
    {
      "time": 23.44,
      "time_str": "00:23.440",
      "text": "却忘记了身边那双温暖的眼神",
      "translation": null
    },
    {
      "time": 27.72,
      "time_str": "00:27.720",
      "text": "再怎么寂寞 又算得上什么",
      "translation": null
    },
    {
      "time": 31.84,
      "time_str": "00:31.840",
      "text": "只要有你陪着我",
      "translation": null
    },
    {
      "time": 35.85,
      "time_str": "00:35.850",
      "text": "我以为自己可能是最孤独的人",
      "translation": null
    },
    {
      "time": 39.95,
      "time_str": "00:39.950",
      "text": "却忽略了心中那份美丽的温存",
      "translation": null
    },
    {
      "time": 44.28,
      "time_str": "00:44.280",
      "text": "再怎么孤独 也算不上无助",
      "translation": null
    },
    {
      "time": 48.34,
      "time_str": "00:48.340",
      "text": "身边有你的脚步",
      "translation": null
    },
    {
      "time": 52.0,
      "time_str": "00:52.000",
      "text": "当我孤独的时候还可以抱着你",
      "translation": null
    },
    {
      "time": 56.58,
      "time_str": "00:56.580",
      "text": "那该有多甜蜜",
      "translation": null
    },
    {
      "time": 60.24,
      "time_str": "01:00.240",
      "text": "当我寂寞的时候还可以想着你",
      "translation": null
    },
    {
      "time": 64.89,
      "time_str": "01:04.890",
      "text": "那该有多幸运",
      "translation": null
    },
    {
      "time": 68.39,
      "time_str": "01:08.390",
      "text": "当我孤独的时候就这样抱着你",
      "translation": null
    },
    {
      "time": 73.19,
      "time_str": "01:13.190",
      "text": "一辈子不放弃",
      "translation": null
    },
    {
      "time": 76.78,
      "time_str": "01:16.780",
      "text": "当我寂寞的时候就这样想着你",
      "translation": null
    },
    {
      "time": 81.44,
      "time_str": "01:21.440",
      "text": "一生都只为你珍惜",
      "translation": null
    },
