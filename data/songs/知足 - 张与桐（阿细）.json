  "lyrics": [
    {
      "time": 22.032,
      "time_str": "00:22.032",
      "text": "雨后那天空 有没有风",
      "translation": null
    },
    {
      "time": 28.023,
      "time_str": "00:28.023",
      "text": "记下这时空 想象着抱拥",
      "translation": null
    },
    {
      "time": 34.024,
      "time_str": "00:34.024",
      "text": "你害怕不懂 要走的冲动",
      "translation": null
    },
    {
      "time": 39.774,
      "time_str": "00:39.774",
      "text": "片刻的感动 才可止一下痛",
      "translation": null
    },
    {
      "time": 52.031,
      "time_str": "00:52.031",
      "text": "贴近那分钟 有没接通",
      "translation": null
    },
    {
      "time": 57.781,
      "time_str": "00:57.781",
      "text": "我习惯悬空 竟然又扑空",
      "translation": null
    },
    {
      "time": 63.526,
      "time_str": "01:03.526",
      "text": "你没法知足 够钟的心动",
      "translation": null
    },
    {
      "time": 69.774,
      "time_str": "01:09.774",
      "text": "缘分的觉梦 在不知间放纵",
      "translation": null
    },
    {
      "time": 74.778,
      "time_str": "01:14.778",
      "text": "从一开始 那年",
      "translation": null
    },
    {
      "time": 77.527,
      "time_str": "01:17.527",
      "text": "追风找到 天使",
      "translation": null
    },
    {
      "time": 81.022,
      "time_str": "01:21.022",
      "text": "愿奉献 却生厌",
      "translation": null
    },
    {
      "time": 84.029,
      "time_str": "01:24.029",
      "text": "像停电 在那天",
      "translation": null
    },
    {
      "time": 86.781,
      "time_str": "01:26.781",
      "text": "离开得很远 但我知",
      "translation": null
    },
    {
      "time": 90.775,
      "time_str": "01:30.775",
      "text": "无可避免",
      "translation": null
    },
    {
      "time": 93.526,
      "time_str": "01:33.526",
      "text": "人在变 情难见 真言",
      "translation": null
    },
    {
      "time": 103.023,
      "time_str": "01:43.023",
      "text": "那年那首歌 你在唱么",
      "translation": null
    },
    {
      "time": 108.784,
      "time_str": "01:48.784",
      "text": "再没有漩涡 闯入过耳朵",
      "translation": null
    },
    {
      "time": 114.775,
      "time_str": "01:54.775",
      "text": "你留下很多 记忆的感觉",
      "translation": null
    },
    {
