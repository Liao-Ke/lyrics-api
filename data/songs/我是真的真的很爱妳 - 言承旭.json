  "lyrics": [
    {
      "time": 38.3,
      "time_str": "00:38.300",
      "text": "听说感情要慢慢累积",
      "translation": null
    },
    {
      "time": 45.01,
      "time_str": "00:45.010",
      "text": "由不得让我放肆任性",
      "translation": null
    },
    {
      "time": 51.17,
      "time_str": "00:51.170",
      "text": "怎么我循规蹈矩",
      "translation": null
    },
    {
      "time": 55.87,
      "time_str": "00:55.870",
      "text": "拼了命付出",
      "translation": null
    },
    {
      "time": 58.76,
      "time_str": "00:58.760",
      "text": "你没有回应",
      "translation": null
    },
    {
      "time": 62.95,
      "time_str": "01:02.950",
      "text": "听说感情难免力不从心",
      "translation": null
    },
    {
      "time": 68.31,
      "time_str": "01:08.310",
      "text": "亦步亦趋却不见踪影",
      "translation": null
    },
    {
      "time": 76.12,
      "time_str": "01:16.120",
      "text": "你给的眼神好比",
      "translation": null
    },
    {
      "time": 80.65,
      "time_str": "01:20.650",
      "text": "大热天里一道冷空气",
      "translation": null
    },
    {
      "time": 88.48,
      "time_str": "01:28.480",
      "text": "我是真的真的真的很爱你",
      "translation": null
    },
    {
      "time": 99.11,
      "time_str": "01:39.110",
      "text": "以为付出了一切就非得有意义",
      "translation": null
    },
    {
      "time": 105.86,
      "time_str": "01:45.860",
      "text": "你给的难题",
      "translation": null
    },
    {
      "time": 108.93,
      "time_str": "01:48.930",
      "text": "我不曾逃避",
      "translation": null
    },
    {
      "time": 112.02,
      "time_str": "01:52.020",
      "text": "谁叫我已爱你成性",
      "translation": null
    },
    {
      "time": 117.13,
      "time_str": "01:57.130",
      "text": "总有一天可以用力紧紧抱住你",
      "translation": null
    },
    {
      "time": 124.33,
      "time_str": "02:04.330",
      "text": "毕竟继续的呼吸也要有点目的",
      "translation": null
    },
    {
      "time": 130.83,
      "time_str": "02:10.830",
      "text": "一身的伤痛",
      "translation": null
    },
    {
      "time": 134.8,
      "time_str": "02:14.800",
      "text": "委屈的痕迹",
      "translation": null
    },
    {
      "time": 137.98,
      "time_str": "02:17.980",
      "text": "在你防备的眼睛里",
      "translation": null
    },
    {
      "time": 143.05,
      "time_str": "02:23.050",
      "text": "都是零",
