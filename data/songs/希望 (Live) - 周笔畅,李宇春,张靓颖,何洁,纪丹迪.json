    {
      "time": 13.65,
      "time_str": "00:13.650",
      "text": "看天空飘的云还有梦",
      "translation": null
    },
    {
      "time": 19.35,
      "time_str": "00:19.350",
      "text": "看生命回家路路长漫漫",
      "translation": null
    },
    {
      "time": 25.2,
      "time_str": "00:25.200",
      "text": "看明天的岁月越走越远",
      "translation": null
    },
    {
      "time": 30.98,
      "time_str": "00:30.980",
      "text": "远方的回忆的你的微笑",
      "translation": null
    },
    {
      "time": 38.32,
      "time_str": "00:38.320",
      "text": "天黑路茫茫心中的彷徨",
      "translation": null
    },
    {
      "time": 41.3,
      "time_str": "00:41.300",
      "text": "没犹豫的方向",
      "translation": null
    },
    {
      "time": 44.09,
      "time_str": "00:44.090",
      "text": "心中的翅膀一天终张开",
      "translation": null
    },
    {
      "time": 47.13,
      "time_str": "00:47.130",
      "text": "飞翔天上",
      "translation": null
    },
    {
