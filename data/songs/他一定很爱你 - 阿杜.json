      "time": 31.749,
      "time_str": "00:31.749",
      "text": "我躲在车里",
      "translation": null
    },
    {
      "time": 34.789,
      "time_str": "00:34.789",
      "text": "手握着香槟",
      "translation": null
    },
    {
      "time": 37.289,
      "time_str": "00:37.289",
      "text": "想要给你",
      "translation": null
    },
    {
      "time": 38.789,
      "time_str": "00:38.789",
      "text": "生日的惊喜",
      "translation": null
    },
    {
      "time": 41.69,
      "time_str": "00:41.690",
      "text": "你越走越近",
      "translation": null
