{
  "title": "四季歌",
  "title_raw": "四季歌",
  "version": null,
  "artist": "姜苏,柏菲音乐",
  "group_key": "四季歌|姜苏,柏菲音乐",
  "writers": {
    "lyricist": "田汉",
