    {
      "time": 23.48,
      "time_str": "00:23.480",
      "text": "还记得 妈妈说",
      "translation": null
    },
    {
      "time": 25.72,
      "time_str": "00:25.720",
      "text": "陪一个男孩子长大要用",
      "translation": null
    },
    {
      "time": 28.68,
      "time_str": "00:28.680",
      "text": "青春来做赌注",
      "translation": null
    },
    {
      "time": 31.78,
      "time_str": "00:31.780",
      "text": "我要听着亲戚们的闲话",
      "translation": null
    },
    {
      "time": 35.91,
      "time_str": "00:35.910",
      "text": "等你为我送来一束鲜花",
      "translation": null
    },
    {
      "time": 39.97,
      "time_str": "00:39.970",
      "text": "到后来 我们俩",
      "translation": null
    },
    {
      "time": 42.2,
      "time_str": "00:42.200",
      "text": "连一句不咸不淡的问候",
      "translation": null
    },
    {
      "time": 45.24,
      "time_str": "00:45.240",
      "text": "终于也没有了",
      "translation": null
    },
    {
      "time": 48.29,
      "time_str": "00:48.290",
      "text": "我为你把所有人都推开",
      "translation": null
    },
    {
      "time": 52.42,
      "time_str": "00:52.420",
      "text": "只为了那不确定的未来",
      "translation": null
    },
    {
      "time": 56.44,
      "time_str": "00:56.440",
      "text": "先生的一句喜欢",
      "translation": null
    },
    {
      "time": 59.69,
      "time_str": "00:59.690",
      "text": "三言两语我就投降",
      "translation": null
    },
    {
      "time": 64.63,
      "time_str": "01:04.630",
      "text": "后来我身边有他 身后有家",
      "translation": null
    },
    {
      "time": 67.48,
      "time_str": "01:07.480",
      "text": "但我只想问你一句 你 爱过吗",
      "translation": null
    },
    {
      "time": 74.45,
      "time_str": "01:14.450",
      "text": "从前对妈妈说谎",
      "translation": null
    },
    {
      "time": 76.53,
      "time_str": "01:16.530",
      "text": "翻山越岭只为能与你拥抱一场",
      "translation": null
    },
    {
      "time": 79.94,
      "time_str": "01:19.940",
      "text": "幻想 披上红妆",
      "translation": null
    },
    {
      "time": 83.5,
      "time_str": "01:23.500",
      "text": "后来你娶了理想",
      "translation": null
    },
    {
      "time": 85.85,
      "time_str": "01:25.850",
      "text": "我嫁给了户对门当",
      "translation": null
    },
    {
      "time": 88.22,
      "time_str": "01:28.220",
      "text": "爱与不爱又何妨",
      "translation": null
    },
    {
      "time": 91.08,
      "time_str": "01:31.080",
      "text": "从前说无惧山海",
      "translation": null
    },
    {
      "time": 93.14,
      "time_str": "01:33.140",
      "text": "用九百九十九张车票换有你的",
      "translation": null
    },
    {
      "time": 96.51,
      "time_str": "01:36.510",
      "text": "未来 只要你在",
      "translation": null
    },
    {
      "time": 100.07,
      "time_str": "01:40.070",
      "text": "后来你把我归还人海",
      "translation": null
    },
    {
      "time": 104.15,
      "time_str": "01:44.150",
      "text": "哭着说欠我的未来 下辈子再爱",
