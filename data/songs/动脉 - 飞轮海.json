  "lyrics": [
    {
      "time": 26.85,
      "time_str": "00:26.850",
      "text": "当月光被寂寞遮盖",
      "translation": null
    },
    {
      "time": 28.9,
      "time_str": "00:28.900",
      "text": "心情像末日般黑暗",
      "translation": null
    },
    {
      "time": 31.02,
      "time_str": "00:31.020",
      "text": "你怀疑城市快崩坏",
      "translation": null
    },
    {
      "time": 33.88,
      "time_str": "00:33.880",
      "text": "谁可以信赖",
      "translation": null
    },
    {
      "time": 35.44,
      "time_str": "00:35.440",
      "text": "当生命被推向悬崖",
      "translation": null
    },
    {
      "time": 37.62,
      "time_str": "00:37.620",
      "text": "回忆瞬间快格倒带",
      "translation": null
    },
    {
      "time": 39.78,
      "time_str": "00:39.780",
      "text": "你知道最后的呼喊",
      "translation": null
    },
    {
      "time": 42.03,
      "time_str": "00:42.030",
      "text": "谁会立刻回响",
      "translation": null
    },
    {
      "time": 44.37,
      "time_str": "00:44.370",
      "text": "我知道我就是答案",
      "translation": null
    },
    {
      "time": 46.87,
      "time_str": "00:46.870",
      "text": "不怕你来麻烦",
      "translation": null
    },
    {
      "time": 52.94,
      "time_str": "00:52.940",
      "text": "我知道当角色互换",
      "translation": null
    },
    {
      "time": 55.73,
      "time_str": "00:55.730",
      "text": "你也一样照办",
      "translation": null
    },
    {
      "time": 63.62,
      "time_str": "01:03.620",
      "text": "连接我的动脉",
      "translation": null
    },
    {
      "time": 65.49,
      "time_str": "01:05.490",
      "text": "感受彼此存在",
      "translation": null
    },
    {
      "time": 67.87,
      "time_str": "01:07.870",
      "text": "热血互相灌溉",
      "translation": null
    },
    {
      "time": 69.98,
      "time_str": "01:09.980",
      "text": "温暖澎湃",
      "translation": null
    },
    {
      "time": 72.32,
      "time_str": "01:12.320",
      "text": "流过我的动脉",
      "translation": null
    },
    {
      "time": 74.3,
      "time_str": "01:14.300",
      "text": "传送喜悦悲哀",
      "translation": null
    },
    {
      "time": 76.49,
      "time_str": "01:16.490",
      "text": "同步心跳节拍",
      "translation": null
    },
    {
      "time": 78.73,
      "time_str": "01:18.730",
      "text": "同一个未来",
      "translation": null
    },
    {
      "time": 101.13,
      "time_str": "01:41.130",
      "text": "当我在旅途上落难",
      "translation": null
    },
    {
      "time": 103.16,
      "time_str": "01:43.160",
      "text": "恶梦像蜘蛛网纠缠",
      "translation": null
    },
    {
      "time": 105.3,
      "time_str": "01:45.300",
      "text": "就快被撕裂的梦想",
      "translation": null
    },
    {
      "time": 108.14,
      "time_str": "01:48.140",
      "text": "谁帮我保管",
      "translation": null
    },
    {
      "time": 109.72,
      "time_str": "01:49.720",
      "text": "当我又做错了判断",
      "translation": null
    },
    {
      "time": 111.78,
      "time_str": "01:51.780",
      "text": "失败像崩塌了的山",
      "translation": null
    },
    {
      "time": 113.98,
      "time_str": "01:53.980",
      "text": "天空中只亮着绝望",
      "translation": null
    },
    {
      "time": 116.51,
      "time_str": "01:56.510",
      "text": "谁还肯给我光",
      "translation": null
    },
    {
      "time": 118.38,
      "time_str": "01:58.380",
      "text": "你就是不变的答案",
      "translation": null
    },
    {
      "time": 121.0,
      "time_str": "02:01.000",
      "text": "没嫌过我麻烦",
      "translation": null
    },
    {
      "time": 127.16,
      "time_str": "02:07.160",
      "text": "下一次当角色互换",
      "translation": null
    },
    {
