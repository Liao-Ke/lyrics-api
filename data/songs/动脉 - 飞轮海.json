    {
      "time": 155.3,
      "time_str": "02:35.300",
      "text": "空气里飘散危险讯息在蔓延",
      "translation": null
    },
    {
      "time": 157.51,
      "time_str": "02:37.510",
      "text": "不约而同我们都抢先一步",
      "translation": null
    },
    {
      "time": 159.11,
      "time_str": "02:39.110",
      "text": "想挡在对方面前",
      "translation": null
    },
    {
      "time": 160.27,
      "time_str": "02:40.270",
      "text": "深陷在暗黑世界",
      "translation": null
    },
    {
      "time": 161.41,
      "time_str": "02:41.410",
      "text": "正义是阳光铸造的宝剑",
      "translation": null
    },
    {
      "time": 163.15,
      "time_str": "02:43.150",
      "text": "好与坏同进同退",
      "translation": null
