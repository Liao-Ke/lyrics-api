    {
      "time": 164.61,
      "time_str": "02:44.610",
      "text": "团结是无坚不摧的堡垒",
      "translation": null
    },
    {
      "time": 166.25,
      "time_str": "02:46.250",
      "text": "我们还能相信明天",
      "translation": null
    },
    {
      "time": 167.62,
      "time_str": "02:47.620",
      "text": "交会的眼神就是信念",
      "translation": null
