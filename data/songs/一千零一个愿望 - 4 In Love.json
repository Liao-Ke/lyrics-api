    {
      "time": 0.86,
      "time_str": "00:00.860",
      "text": "明天就像是盒子里的巧克力糖",
      "translation": null
    },
    {
      "time": 5.29,
      "time_str": "00:05.290",
      "text": "什么滋味",
      "translation": null
    },
    {
      "time": 7.86,
      "time_str": "00:07.860",
      "text": "充满想象",
      "translation": null
    },
    {
      "time": 10.69,
      "time_str": "00:10.690",
      "text": "失望是偶尔拨不通的电话号码",
      "translation": null
    },
    {
      "time": 15.48,
      "time_str": "00:15.480",
      "text": "多试几次",
      "translation": null
    },
    {
      "time": 17.95,
      "time_str": "00:17.950",
      "text": "总会回答",
      "translation": null
    },
    {
      "time": 20.72,
      "time_str": "00:20.720",
      "text": "心里有好多的梦想",
      "translation": null
    },
    {
      "time": 25.21,
      "time_str": "00:25.210",
      "text": "未来正要开始闪闪发亮",
      "translation": null
    },
    {
      "time": 29.8,
      "time_str": "00:29.800",
      "text": "就算天再高那又怎样",
      "translation": null
    },
    {
      "time": 34.54,
      "time_str": "00:34.540",
      "text": "踮起脚尖",
      "translation": null
    },
    {
      "time": 36.86,
      "time_str": "00:36.860",
      "text": "就更靠近阳光",
      "translation": null
    },
    {
      "time": 42.95,
      "time_str": "00:42.950",
      "text": "许下我第一千零一个愿望",
      "translation": null
    },
    {
      "time": 47.54,
      "time_str": "00:47.540",
      "text": "有一天幸福总会听我的话",
      "translation": null
    },
    {
      "time": 52.08,
      "time_str": "00:52.080",
      "text": "不怕要多少时间多少代价",
      "translation": null
    },
    {
      "time": 56.26,
      "time_str": "00:56.260",
      "text": "青春是我的筹码",
      "translation": null
    },
    {
      "time": 61.4,
      "time_str": "01:01.400",
      "text": "我只有这一千零一个愿望",
      "translation": null
    },
    {
      "time": 66.05,
      "time_str": "01:06.050",
      "text": "有一天幸福总会在我手上",
      "translation": null
    },
    {
      "time": 70.78,
      "time_str": "01:10.780",
      "text": "每一颗心都有一双翅膀",
