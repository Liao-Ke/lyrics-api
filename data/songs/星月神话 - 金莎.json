    {
      "time": 37.3,
      "time_str": "00:37.300",
      "text": "我的一生最美好的场景",
      "translation": null
    },
    {
      "time": 42.99,
      "time_str": "00:42.990",
      "text": "就是遇见你",
      "translation": null
    },
    {
      "time": 48.11,
      "time_str": "00:48.110",
      "text": "在人海茫茫中静静凝望着你",
      "translation": null
    },
    {
      "time": 54.55,
      "time_str": "00:54.550",
      "text": "陌生又熟悉",
      "translation": null
    },
    {
      "time": 60.36,
      "time_str": "01:00.360",
      "text": "啊...... 啊 ......",
      "translation": null
    },
    {
      "time": 71.37,
      "time_str": "01:11.370",
      "text": "尽管呼吸着同一天空的气息",
      "translation": null
    },
    {
      "time": 77.74,
      "time_str": "01:17.740",
      "text": "却无法拥抱到你",
      "translation": null
    },
    {
      "time": 82.74,
      "time_str": "01:22.740",
      "text": "如果转换了时空身份和姓名",
      "translation": null
    },
    {
      "time": 88.55,
      "time_str": "01:28.550",
      "text": "但愿认得你眼睛",
      "translation": null
    },
    {
      "time": 94.36,
      "time_str": "01:34.360",
      "text": "千年之后的你会在哪里",
      "translation": null
    },
    {
      "time": 100.3,
      "time_str": "01:40.300",
      "text": "身边有怎样风景",
      "translation": null
    },
    {
      "time": 105.93,
      "time_str": "01:45.930",
      "text": "我们的故事并不算美丽",
      "translation": null
    },
    {
      "time": 111.67,
      "time_str": "01:51.670",
      "text": "却如此难以忘记",
      "translation": null
    },
    {
      "time": 141.61,
      "time_str": "02:21.610",
      "text": "啊 ...啊 ...",
      "translation": null
    },
    {
