    {
      "time": 0.8,
      "time_str": "00:00.800",
      "text": "I complicated our lives",
      "translation": "我的生活被打乱"
    },
    {
      "time": 2.62,
      "time_str": "00:02.620",
      "text": "By falling in love with him",
      "translation": "因为我爱上了他"
    },
    {
      "time": 7.8,
      "time_str": "00:07.800",
      "text": "I complicated our lives",
      "translation": "我的生活被打乱"
    },
    {
      "time": 9.88,
      "time_str": "00:09.880",
      "text": "Now I'm losing my only friend",
      "translation": "现在我没有朋友"
    },
    {
      "time": 15.6,
      "time_str": "00:15.600",
      "text": "I don't know why, I had to try",
      "translation": "我不知道为什么，只想试一试"
    },
    {
      "time": 18.33,
      "time_str": "00:18.330",
      "text": "Living my life on the other side",
      "translation": "我在离你很远的地方生活"
    },
    {
      "time": 21.53,
      "time_str": "00:21.530",
      "text": "Now I'm so confused",
      "translation": "现在我很迷茫"
    },
    {
      "time": 24.96,
      "time_str": "00:24.960",
      "text": "I don't know what to do",
      "translation": "我不知道该怎么办"
    },
    {
      "time": 29.44,
      "time_str": "00:29.440",
      "text": "He loves me, He loves me not",
      "translation": "他爱我，他不爱我"
    },
    {
      "time": 33.1,
      "time_str": "00:33.100",
      "text": "She loves me, She loves me not",
      "translation": "她爱我，她不爱我"
