  "lyrics": [
    {
      "time": 26.982,
      "time_str": "00:26.982",
      "text": "风吹动窗 吹动叶声响",
      "translation": null
    },
    {
      "time": 32.267,
      "time_str": "00:32.267",
      "text": "梦在游荡 去更远地方",
      "translation": null
    },
    {
      "time": 37.54,
      "time_str": "00:37.540",
      "text": "天上的月 露出半只角",
      "translation": null
    },
    {
      "time": 42.552,
      "time_str": "00:42.552",
      "text": "看地上有个人 还睡不着",
      "translation": null
    },
    {
      "time": 48.079,
      "time_str": "00:48.079",
      "text": "云遮住光 遮住夜更长",
      "translation": null
    },
    {
      "time": 53.342,
      "time_str": "00:53.342",
      "text": "风轻轻穿过你的头发",
      "translation": null
    },
    {
      "time": 58.627,
      "time_str": "00:58.627",
      "text": "夜闭上双眼不说话",
      "translation": null
    },
    {
      "time": 63.71,
      "time_str": "01:03.710",
      "text": "我知道你在听 我怎么讲",
      "translation": null
    },
    {
      "time": 68.226,
      "time_str": "01:08.226",
      "text": "我想说我会爱你多一点点",
      "translation": null
    },
    {
      "time": 73.826,
      "time_str": "01:13.826",
      "text": "一直就在你的耳边",
      "translation": null
    },
    {
      "time": 79.05,
      "time_str": "01:19.050",
      "text": "相信你也爱我有一点点",
      "translation": null
    },
    {
      "time": 84.335,
      "time_str": "01:24.335",
      "text": "只是你一直没发现",
      "translation": null
    },
    {
      "time": 89.264,
      "time_str": "01:29.264",
      "text": "我想说我会爱你多一点点",
      "translation": null
    },
    {
      "time": 94.945,
      "time_str": "01:34.945",
      "text": "一直就在你的耳边",
      "translation": null
    },
    {
      "time": 100.145,
      "time_str": "01:40.145",
      "text": "相信我会爱你永远不变",
      "translation": null
    },
    {
      "time": 105.418,
      "time_str": "01:45.418",
      "text": "知道你一定会发现",
      "translation": null
    },
