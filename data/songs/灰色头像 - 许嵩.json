  "lyrics": [
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "昨夜做了一个梦  梦里我们回到手牵着手",
      "translation": null
    },
    {
      "time": 40.56,
      "time_str": "00:40.560",
      "text": "醒来的失落  无法言说",
      "translation": null
    },
    {
      "time": 47.54,
      "time_str": "00:47.540",
      "text": "打开了OICQ 聊天 记录停步去年的深秋",
      "translation": null
    },
    {
      "time": 55.43,
      "time_str": "00:55.430",
      "text": "最后的挽留  没有说出口",
      "translation": null
    },
    {
      "time": 62.24,
      "time_str": "01:02.240",
      "text": "我们还是朋友  是那种最遥远的朋友",
      "translation": null
    },
    {
      "time": 69.71,
      "time_str": "01:09.710",
      "text": "你给过的温柔  在记录之中  全部都保有",
      "translation": null
    },
    {
      "time": 78.73,
      "time_str": "01:18.730",
      "text": "你灰色头像不 会再跳动",
      "translation": null
    },
    {
      "time": 82.53,
      "time_str": "01:22.530",
      "text": "哪怕是一句简单的问候",
      "translation": null
    },
    {
      "time": 85.89,
      "time_str": "01:25.890",
      "text": "心贴心的交流 一页页翻阅 多难过",
      "translation": null
    },
    {
      "time": 90.72,
      "time_str": "01:30.720",
      "text": "是什么 坠落 升空",
      "translation": null
    },
    {
      "time": 93.15,
      "time_str": "01:33.150",
      "text": "又想起你曾说的陪我到最后",
      "translation": null
    },
    {
      "time": 97.23,
      "time_str": "01:37.230",
      "text": "暖色的梦变冰凉的枷锁",
      "translation": null
    },
    {
      "time": 100.69,
      "time_str": "01:40.690",
      "text": "如果时光倒流 我们又能 抓得住什么",
      "translation": null
    },
