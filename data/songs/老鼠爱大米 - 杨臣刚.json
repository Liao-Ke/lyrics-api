    {
      "time": 99.36,
      "time_str": "01:39.360",
      "text": "我都会依然陪着你",
      "translation": null
    },
    {
      "time": 103.07,
      "time_str": "01:43.070",
      "text": "我想你",
      "translation": null
    },
    {
      "time": 104.57,
      "time_str": "01:44.570",
      "text": "想着你",
      "translation": null
    },
    {
      "time": 106.6,
      "time_str": "01:46.600",
      "text": "不管有多么的苦",
