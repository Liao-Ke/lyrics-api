  "lyrics": [
    {
      "time": 28.99,
      "time_str": "00:28.990",
      "text": "我听见你的声音",
      "translation": null
    },
    {
      "time": 33.07,
      "time_str": "00:33.070",
      "text": "有种特别的感觉",
      "translation": null
    },
    {
      "time": 36.49,
      "time_str": "00:36.490",
      "text": "让我不断想",
      "translation": null
    },
    {
      "time": 40.27,
      "time_str": "00:40.270",
      "text": "不敢再忘记你",
      "translation": null
    },
    {
      "time": 43.1,
      "time_str": "00:43.100",
      "text": "我记的有一个人",
      "translation": null
    },
    {
      "time": 46.65,
      "time_str": "00:46.650",
      "text": "永远留在我心中",
      "translation": null
    },
    {
      "time": 50.49,
      "time_str": "00:50.490",
      "text": "那怕只能够这样的想你",
      "translation": null
    },
    {
      "time": 57.21,
      "time_str": "00:57.210",
      "text": "如果真的有一天",
      "translation": null
    },
    {
      "time": 60.7,
      "time_str": "01:00.700",
      "text": "爱情理想会实现",
      "translation": null
    },
    {
      "time": 64.64,
      "time_str": "01:04.640",
      "text": "我会加倍努力好好对你",
      "translation": null
    },
    {
      "time": 68.48,
      "time_str": "01:08.480",
      "text": "永远不改变",
      "translation": null
    },
    {
      "time": 71.69,
      "time_str": "01:11.690",
      "text": "不管路有多么远",
      "translation": null
    },
    {
      "time": 74.85,
      "time_str": "01:14.850",
      "text": "一定会让它实现",
      "translation": null
    },
    {
      "time": 78.74,
      "time_str": "01:18.740",
      "text": "我会轻轻在你耳边",
      "translation": null
    },
    {
      "time": 81.95,
      "time_str": "01:21.950",
      "text": "对你说 对你说",
      "translation": null
    },
    {
      "time": 88.86,
      "time_str": "01:28.860",
      "text": "我爱你",
      "translation": null
    },
    {
      "time": 90.76,
      "time_str": "01:30.760",
      "text": "爱着你",
      "translation": null
    },
    {
      "time": 92.47,
      "time_str": "01:32.470",
      "text": "就像老鼠爱大米",
      "translation": null
    },
    {
      "time": 96.4,
      "time_str": "01:36.400",
      "text": "不管有多少风雨",
      "translation": null
