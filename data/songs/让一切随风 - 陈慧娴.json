  "lyrics": [
    {
      "time": 29.08,
      "time_str": "00:29.080",
      "text": "风中风中 心里冷风",
      "translation": null
    },
    {
      "time": 32.65,
      "time_str": "00:32.650",
      "text": "吹失了梦",
      "translation": null
    },
    {
      "time": 36.08,
      "time_str": "00:36.080",
      "text": "事未过去 就已失踪",
      "translation": null
    },
    {
      "time": 39.87,
      "time_str": "00:39.870",
      "text": "此刻有种种心痛",
      "translation": null
    },
    {
      "time": 43.42,
      "time_str": "00:43.420",
      "text": "心中心中 一切似空",
      "translation": null
    },
    {
      "time": 47.28,
      "time_str": "00:47.280",
      "text": "天黑天光都似梦",
      "translation": null
    },
    {
      "time": 50.62,
      "time_str": "00:50.620",
      "text": "迷迷惘惘 聚满心中",
      "translation": null
    },
    {
      "time": 54.17,
      "time_str": "00:54.170",
      "text": "追踪一片冷的风",
      "translation": null
    },
    {
      "time": 57.65,
      "time_str": "00:57.650",
      "text": "各种空虚 冷冷冷",
      "translation": null
    },
    {
      "time": 62.11,
      "time_str": "01:02.110",
      "text": "吹起吹起风里梦",
      "translation": null
    },
    {
      "time": 65.25,
      "time_str": "01:05.250",
      "text": "过去的心 火般灼热",
      "translation": null
    },
    {
      "time": 69.0,
      "time_str": "01:09.000",
      "text": "今天已变了冰冻",
      "translation": null
    },
    {
      "time": 72.07,
      "time_str": "01:12.070",
      "text": "记忆中 突然又痛",
      "translation": null
    },
    {
      "time": 76.46,
      "time_str": "01:16.460",
      "text": "只因空虚再作弄",
      "translation": null
    },
    {
      "time": 79.7,
      "time_str": "01:19.700",
      "text": "你似北风 吹走我梦",
      "translation": null
    },
    {
      "time": 83.99,
      "time_str": "01:23.990",
      "text": "就让一切随风",
      "translation": null
    },
    {
