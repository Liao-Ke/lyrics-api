    {
      "time": 13.399,
      "time_str": "00:13.399",
      "text": "人潮渐散去痴心已粉碎",
      "translation": null
    },
    {
      "time": 20.169,
      "time_str": "00:20.169",
      "text": "这里故事仍然望有再继续",
      "translation": null
    },
    {
      "time": 27.15,
      "time_str": "00:27.150",
      "text": "缘分在这里盼望能再追",
      "translation": null
    },
    {
      "time": 33.37,
      "time_str": "00:33.370",
      "text": "不知不觉心冷空虚",
      "translation": null
    },
    {
      "time": 39.22,
      "time_str": "00:39.220",
      "text": "匆匆转身去我默然允许",
      "translation": null
    },
    {
      "time": 46.64,
      "time_str": "00:46.640",
      "text": "独剩低心痛自我默默承受了罪",
      "translation": null
    },
    {
      "time": 55.5,
      "time_str": "00:55.500",
      "text": "啊……",
      "translation": null
    },
    {
      "time": 56.98,
      "time_str": "00:56.980",
      "text": "她已伤我心不理我是谁",
      "translation": null
    },
    {
      "time": 63.26,
      "time_str": "01:03.260",
      "text": "回望已别去栖身冰冷中",
