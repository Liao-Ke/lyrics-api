    {
      "time": 11.14,
      "time_str": "00:11.140",
      "text": "尼龙吉他 : 苏孟风",
      "translation": null
    },
    {
      "time": 12.07,
      "time_str": "00:12.070",
      "text": "伴唱 : 毕见晟/宋豪/杨美娇/陈虹利",
      "translation": null
    },
    {
      "time": 13.0,
      "time_str": "00:13.000",
      "text": "PGM : 陈佑峰",
      "translation": null
    },
    {
      "time": 14.87,
      "time_str": "00:14.870",
      "text": "圣权：",
      "translation": null
    },
    {
      "time": 16.67,
      "time_str": "00:16.670",
      "text": "春天的风 能否吹来夏天的雨",
      "translation": null
    },
    {
      "time": 24.44,
      "time_str": "00:24.440",
      "text": "秋天的月 能否照亮冬天的雪",
      "translation": null
    },
    {
      "time": 31.66,
      "time_str": "00:31.660",
      "text": "合：",
      "translation": null
    },
    {
      "time": 32.2,
      "time_str": "00:32.200",
      "text": "夜空的星 能否落向晨曦的海",
      "translation": null
    },
    {
      "time": 39.97,
      "time_str": "00:39.970",
      "text": "山间的泉 能否遇上南飞的雁",
      "translation": null
    },
    {
      "time": 47.39,
      "time_str": "00:47.390",
      "text": "能否早一点 看透命运的伏线",
      "translation": null
    },
    {
      "time": 51.13,
      "time_str": "00:51.130",
      "text": "能否不轻易就深陷",
      "translation": null
    },
    {
      "time": 55.08,
      "time_str": "00:55.080",
      "text": "能否慢一点 挥霍有限的时间",
      "translation": null
    },
    {
      "time": 58.86,
      "time_str": "00:58.860",
      "text": "能否许我一个永远",
      "translation": null
    },
    {
      "time": 63.78,
      "time_str": "01:03.780",
      "text": "石凯：",
      "translation": null
    },
    {
      "time": 64.58,
      "time_str": "01:04.580",
      "text": "可能我撞了南墙才会回头吧",
      "translation": null
    },
    {
      "time": 68.62,
      "time_str": "01:08.620",
      "text": "圣权：",
      "translation": null
    },
    {
      "time": 69.01,
      "time_str": "01:09.010",
      "text": "可能我见了黄河才会死心吧",
      "translation": null
    },
    {
      "time": 72.47,
      "time_str": "01:12.470",
      "text": "合：",
      "translation": null
    },
    {
      "time": 72.71,
      "time_str": "01:12.710",
      "text": "可能我偏要一条路走到黑吧",
      "translation": null
    },
    {
      "time": 76.49,
      "time_str": "01:16.490",
      "text": "可能我还没遇见 那个她吧",
      "translation": null
    },
    {
      "time": 100.16,
      "time_str": "01:40.160",
      "text": "石凯：",
      "translation": null
    },
    {
      "time": 100.67,
      "time_str": "01:40.670",
      "text": "断掉的弦 能否扯开自缚的茧",
      "translation": null
    },
    {
      "time": 108.21,
      "time_str": "01:48.210",
      "text": "熄灭的火 能否烧光残留的念",
      "translation": null
    },
    {
      "time": 115.07,
      "time_str": "01:55.070",
      "text": "合：",
      "translation": null
    },
    {
      "time": 116.04,
      "time_str": "01:56.040",
      "text": "梦中的云 能否化作熟悉的脸",
      "translation": null
    },
    {
      "time": 123.84,
      "time_str": "02:03.840",
      "text": "前世的劫 能否换来今生的缘",
      "translation": null
    },
    {
      "time": 131.15,
      "time_str": "02:11.150",
      "text": "能否早一点 相信年少的誓言",
      "translation": null
    },
    {
      "time": 135.0,
      "time_str": "02:15.000",
      "text": "能否不轻易说再见",
      "translation": null
    },
    {
      "time": 138.97,
      "time_str": "02:18.970",
      "text": "能否慢一点 感受岁月的缱绻",
      "translation": null
    },
    {
      "time": 142.7,
      "time_str": "02:22.700",
      "text": "能否许我一次成全",
