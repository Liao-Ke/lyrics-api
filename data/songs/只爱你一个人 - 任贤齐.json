  "lyrics": [
    {
      "time": 40.36,
      "time_str": "00:40.360",
      "text": "下雨的天空 突然雷声轰隆隆",
      "translation": null
    },
    {
      "time": 45.6,
      "time_str": "00:45.600",
      "text": "有谁知道我心痛",
      "translation": null
    },
    {
      "time": 50.92,
      "time_str": "00:50.920",
      "text": "爱情有独钟 偏偏它是痴人梦",
      "translation": null
    },
    {
      "time": 56.31,
      "time_str": "00:56.310",
      "text": "我实在不该对她心动",
      "translation": null
    },
    {
      "time": 61.6,
      "time_str": "01:01.600",
      "text": "爱上一个不该去爱的人",
      "translation": null
    },
    {
      "time": 66.659,
      "time_str": "01:06.659",
      "text": "我总是加倍包容牺牲",
      "translation": null
    },
    {
      "time": 72.18,
      "time_str": "01:12.180",
      "text": "明知不可能 还勉强自己要去撑",
      "translation": null
    },
    {
      "time": 77.37,
      "time_str": "01:17.370",
      "text": "越撑心越闷 越闷心越冷",
      "translation": null
    },
    {
      "time": 82.569,
      "time_str": "01:22.569",
      "text": "你知道我心里 只爱你一个人",
      "translation": null
    },
    {
      "time": 87.879,
      "time_str": "01:27.879",
      "text": "你的态度我不能平衡",
      "translation": null
    },
    {
      "time": 93.09,
      "time_str": "01:33.090",
      "text": "我给的爱太深 我忍不住想问",
      "translation": null
    },
    {
      "time": 98.379,
      "time_str": "01:38.379",
      "text": "我到底哪里比不上他",
      "translation": null
    },
    {
      "time": 106.56,
      "time_str": "01:46.560",
      "text": "灰暗的天空 不见昨日灯朦胧",
      "translation": null
    },
    {
      "time": 111.84,
      "time_str": "01:51.840",
      "text": "你到底在想什么",
      "translation": null
    },
    {
      "time": 116.959,
      "time_str": "01:56.959",
      "text": "爱依稀结束",
      "translation": null
    },
    {
      "time": 119.16,
      "time_str": "01:59.160",
      "text": "怎么说你都不清楚",
      "translation": null
    },
    {
      "time": 122.319,
