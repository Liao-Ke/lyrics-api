      "text": "\\",
      "translation": null
    },
    {
      "time": 21.442,
      "time_str": "00:21.442",
      "text": "再见我的爱I wanna say goodbye",
      "translation": null
    },
    {
      "time": 24.327,
      "time_str": "00:24.327",
      "text": "再见我的过去I want a new life",
      "translation": null
    },
    {
      "time": 26.967,
      "time_str": "00:26.967",
      "text": "再见我的眼泪跌倒和失败",
      "translation": null
    },
    {
      "time": 29.731,
      "time_str": "00:29.731",
      "text": "再见那个年少轻狂的时代",
      "translation": null
    },
    {
      "time": 32.475,
      "time_str": "00:32.475",
      "text": "再见我的烦恼不再孤单",
      "translation": null
    },
    {
      "time": 35.171,
      "time_str": "00:35.171",
      "text": "再见我的懦弱不再哭喊",
      "translation": null
    },
    {
      "time": 37.612,
      "time_str": "00:37.612",
      "text": "Now I wanna say",
      "translation": null
    },
    {
      "time": 38.882,
      "time_str": "00:38.882",
      "text": "Hello Hello 我的未来（Hello Hello）",
      "translation": null
    },
    {
      "time": 43.309,
      "time_str": "00:43.309",
      "text": "在无尽的黑夜",
      "translation": null
    },
    {
      "time": 46.101,
      "time_str": "00:46.101",
      "text": "所有都快要毁灭",
      "translation": null
    },
    {
      "time": 48.437,
      "time_str": "00:48.437",
      "text": "至少我还有梦",
      "translation": null
    },
    {
      "time": 51.232,
      "time_str": "00:51.232",
      "text": "也为你而感动",
      "translation": null
    },
    {
      "time": 54.178,
      "time_str": "00:54.178",
      "text": "原来黎明的起点",
      "translation": null
    },
    {
      "time": 57.25,
      "time_str": "00:57.250",
      "text": "就在我的心里面",
      "translation": null
    },
    {
      "time": 59.511,
      "time_str": "00:59.511",
      "text": "只要我还有梦",
      "translation": null
    },
    {
      "time": 62.305,
      "time_str": "01:02.305",
      "text": "就会看到彩虹",
      "translation": null
    },
    {
      "time": 65.275,
      "time_str": "01:05.275",
      "text": "在我的天空",
      "translation": null
    },
    {
      "time": 71.878,
      "time_str": "01:11.878",
      "text": "挫折和离别不过是生命中的点缀",
      "translation": null
    },
    {
      "time": 74.318,
      "time_str": "01:14.318",
      "text": "过了多年我才读懂了家人的眼泪",
      "translation": null
    },
    {
      "time": 77.469,
      "time_str": "01:17.469",
      "text": "发现原来自己没有说再见的勇气",
      "translation": null
    },
    {
      "time": 80.258,
      "time_str": "01:20.258",
      "text": "离别的伤感感染了满城的空气",
      "translation": null
    },
    {
      "time": 83.5,
      "time_str": "01:23.500",
      "text": "失去后才知道那些有多么的珍贵",
      "translation": null
    },
    {
      "time": 85.643,
      "time_str": "01:25.643",
      "text": "亲爱的朋友们是否已经展翅纷飞",
      "translation": null
    },
    {
      "time": 88.589,
      "time_str": "01:28.589",
      "text": "不飞到高处怎么开阔自己的视野",
      "translation": null
    },
    {
      "time": 91.284,
      "time_str": "01:31.284",
      "text": "你已经长大了快告诉全世界",
      "translation": null
    },
    {
      "time": 93.978,
      "time_str": "01:33.978",
      "text": "外面的世界散发着强大的磁场",
      "translation": null
    },
    {
      "time": 96.772,
      "time_str": "01:36.772",
      "text": "诱惑着每一双即将展开的翅膀",
      "translation": null
    },
    {
      "time": 99.509,
      "time_str": "01:39.509",
      "text": "热恋的火在懵懂中凶猛的燃烧",
      "translation": null
    },
    {
      "time": 102.251,
      "time_str": "01:42.251",
      "text": "美丽的火花在恋人的周围环绕",
      "translation": null
    },
    {
      "time": 105.48,
      "time_str": "01:45.480",
      "text": "这过程很美尽管有无奈和失落",
      "translation": null
    },
    {
      "time": 107.794,
      "time_str": "01:47.794",
      "text": "刻骨铭心地爱过 尽管爱的并不是我",
      "translation": null
    },
    {
      "time": 110.69,
      "time_str": "01:50.690",
      "text": "如果没有离别如何学会承受打击",
      "translation": null
    },
    {
      "time": 113.329,
      "time_str": "01:53.329",
      "text": "如果没有跌倒如何能够学会爬起",
      "translation": null
    },
    {
