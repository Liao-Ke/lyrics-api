  "lyrics": [
    {
      "time": 14.53,
      "time_str": "00:14.530",
      "text": "我来到 你的城市",
      "translation": null
    },
    {
      "time": 22.15,
      "time_str": "00:22.150",
      "text": "走过你来时的路",
      "translation": null
    },
    {
      "time": 28.47,
      "time_str": "00:28.470",
      "text": "想象着 没我的日子",
      "translation": null
    },
    {
      "time": 34.64,
      "time_str": "00:34.640",
      "text": "你是怎样的孤独",
      "translation": null
    },
    {
      "time": 42.27,
      "time_str": "00:42.270",
      "text": "拿着你 给的照片",
      "translation": null
    },
    {
      "time": 48.56,
      "time_str": "00:48.560",
      "text": "熟悉的那一条街",
      "translation": null
    },
    {
      "time": 54.54,
      "time_str": "00:54.540",
      "text": "只是没了你的画面",
      "translation": null
    },
    {
      "time": 60.59,
      "time_str": "01:00.590",
      "text": "我们回不到那天",
      "translation": null
    },
    {
      "time": 67.75,
      "time_str": "01:07.750",
      "text": "你会不会忽然地出现",
      "translation": null
    },
    {
      "time": 74.6,
      "time_str": "01:14.600",
      "text": "在街角的咖啡店",
      "translation": null
    },
    {
      "time": 80.66,
      "time_str": "01:20.660",
      "text": "我会带着笑脸 挥手寒暄",
      "translation": null
    },
    {
      "time": 86.67,
      "time_str": "01:26.670",
      "text": "和你 坐着聊聊天",
      "translation": null
    },
    {
      "time": 93.8,
      "time_str": "01:33.800",
      "text": "我多么想和你见一面",
      "translation": null
    },
    {
      "time": 100.47,
      "time_str": "01:40.470",
      "text": "看看你最近改变",
      "translation": null
    },
    {
      "time": 106.7,
      "time_str": "01:46.700",
      "text": "不再去说从前 只是寒暄",
      "translation": null
    },
    {
      "time": 113.07,
      "time_str": "01:53.070",
      "text": "对你说一句",
      "translation": null
    },
    {
      "time": 116.07,
      "time_str": "01:56.070",
      "text": "只是说一句",
      "translation": null
    },
