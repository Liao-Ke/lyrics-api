      "time": 28.398,
      "time_str": "00:28.398",
      "text": "一开始我只相信",
      "translation": null
    },
    {
      "time": 34.589,
      "time_str": "00:34.589",
      "text": "伟大的是感情",
      "translation": null
    },
    {
      "time": 41.58,
      "time_str": "00:41.580",
      "text": "最后我无力的看清",
      "translation": null
    },
    {
      "time": 47.338,
      "time_str": "00:47.338",
      "text": "强悍的是命运",
      "translation": null
    },
    {
      "time": 54.758,
      "time_str": "00:54.758",
      "text": "你还是选择回去",
      "translation": null
    },
    {
      "time": 60.788,
      "time_str": "01:00.788",
      "text": "他刺痛你的心",
      "translation": null
    },
    {
      "time": 64.089,
      "time_str": "01:04.089",
      "text": "但你不肯觉醒",
      "translation": null
    },
    {
      "time": 69.189,
      "time_str": "01:09.189",
      "text": "你说爱本就是梦境",
      "translation": null
    },
    {
      "time": 74.538,
      "time_str": "01:14.538",
      "text": "跟你借的幸福 我只能还你",
      "translation": null
    },
    {
      "time": 81.179,
      "time_str": "01:21.179",
      "text": "想留不能留 才最寂寞",
