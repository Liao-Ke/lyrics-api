  "lyrics": [
    {
      "time": 18.3,
      "time_str": "00:18.300",
      "text": "在躲过雨的香樟树下等你",
      "translation": null
    },
    {
      "time": 21.48,
      "time_str": "00:21.480",
      "text": "在天桥上的转角擦肩而遇",
      "translation": null
    },
    {
      "time": 25.94,
      "time_str": "00:25.940",
      "text": "制造每个邂逅的缘分累积",
      "translation": null
    },
    {
      "time": 30.298,
      "time_str": "00:30.298",
      "text": "终于可以牵你的手保护你",
      "translation": null
    },
    {
      "time": 34.228,
      "time_str": "00:34.228",
      "text": "有你的地方就格外的清新",
      "translation": null
    },
    {
      "time": 39.189,
      "time_str": "00:39.189",
      "text": "想着你我的嘴角都会扬起",
      "translation": null
    },
    {
      "time": 43.48,
      "time_str": "00:43.480",
      "text": "倾城的轮廓 沾满我的憧憬",
      "translation": null
    },
    {
      "time": 47.838,
      "time_str": "00:47.838",
      "text": "天空都变透明 听到你的亲口允许",
      "translation": null
    },
    {
      "time": 54.388,
      "time_str": "00:54.388",
      "text": "对全世界宣布爱你",
      "translation": null
    },
    {
      "time": 58.548,
      "time_str": "00:58.548",
      "text": "我只想和你在一起",
      "translation": null
    },
    {
      "time": 62.898,
      "time_str": "01:02.898",
      "text": "这颗心 没畏惧 太坚定",
      "translation": null
    },
    {
      "time": 67.318,
      "time_str": "01:07.318",
      "text": "庆幸让我能够遇见你",
      "translation": null
    },
    {
      "time": 72.49,
      "time_str": "01:12.490",
      "text": "就算全世界都否定",
      "translation": null
    },
    {
      "time": 75.999,
      "time_str": "01:15.999",
      "text": "我也要跟你在一起",
      "translation": null
    },
    {
      "time": 80.469,
      "time_str": "01:20.469",
      "text": "想牵手 想拥抱 想爱你",
      "translation": null
    },
    {
