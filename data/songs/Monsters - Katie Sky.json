  "lyrics": [
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "I see your monsters, I see your pain.",
      "translation": "我看到你心里的野兽 看到你的痛苦"
    },
    {
      "time": 5.14,
      "time_str": "00:05.140",
      "text": "Tell me your problems,I'll chase them away.",
      "translation": "告诉我你的麻烦 我会把它们赶走"
    },
    {
      "time": 10.96,
      "time_str": "00:10.960",
      "text": "I'll be your lighthouse.",
      "translation": "我会是你的灯塔"
    },
    {
      "time": 13.82,
      "time_str": "00:13.820",
      "text": "I'll make it okay.",
      "translation": "我会保护你"
    },
    {
      "time": 16.24,
      "time_str": "00:16.240",
      "text": "When I see your monsters",
      "translation": "当我看到你内心的野兽"
    },
    {
      "time": 18.96,
      "time_str": "00:18.960",
      "text": "I'll stand there so brave,",
      "translation": "我会勇敢地站出来"
    },
    {
      "time": 21.11,
      "time_str": "00:21.110",
      "text": "and chase them all away.",
      "translation": "把它们全部赶走"
    },
    {
      "time": 26.89,
      "time_str": "00:26.890",
      "text": "In the dark we, we, we,",
      "translation": "在黑暗里我们....."
    },
    {
      "time": 29.95,
      "time_str": "00:29.950",
      "text": "stand apart we, we,",
      "translation": "分开站着.....我们"
    },
    {
      "time": 32.61,
      "time_str": "00:32.610",
      "text": "never see that the things we need are staring right at us.",
      "translation": "永远看不到需要的东西都在盯着我们"
    },
    {
      "time": 38.23,
      "time_str": "00:38.230",
      "text": "You just wanna hide, hide,hide",
      "translation": "你只是想逃避，逃避，逃避"
    },
    {
      "time": 40.78,
      "time_str": "00:40.780",
      "text": "never show your smile, smile.",
      "translation": "从不展现你的友好，友好"
    },
    {
      "time": 43.6,
      "time_str": "00:43.600",
      "text": "Stand alone when you need someone",
      "translation": "当你需要陪伴时我旁观"
    },
    {
      "time": 46.41,
      "time_str": "00:46.410",
      "text": "its the hardest thing of all",
      "translation": "是最困难的事情"
    },
    {
      "time": 48.32,
      "time_str": "00:48.320",
      "text": "that you see are the bad, bad, bad memories",
      "translation": "因为你所想都是坏的回忆"
    },
    {
      "time": 53.58,
      "time_str": "00:53.580",
      "text": "take your time, you'll find me.",
      "translation": "别着急，你会找到我的"
