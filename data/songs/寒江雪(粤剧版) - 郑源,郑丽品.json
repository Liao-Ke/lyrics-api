    {
      "time": 25.49,
      "time_str": "00:25.490",
      "text": "寒江雪 映出孤独的离别",
      "translation": null
    },
    {
      "time": 32.49,
      "time_str": "00:32.490",
      "text": "这一夜 寒风冷落无明月",
      "translation": null
    },
    {
      "time": 38.49,
      "time_str": "00:38.490",
      "text": "谁来解 此时心中的情结",
      "translation": null
    },
    {
      "time": 44.49,
      "time_str": "00:44.490",
      "text": "我孤寂 谁来填我心空缺",
      "translation": null
    },
    {
      "time": 50.49,
      "time_str": "00:50.490",
      "text": "心碎着你给的风雪",
      "translation": null
    },
    {
      "time": 56.49,
      "time_str": "00:56.490",
      "text": "思念着不分昼夜",
      "translation": null
    },
    {
      "time": 63.49,
      "time_str": "01:03.490",
      "text": "等待着重逢的季节",
      "translation": null
    },
    {
      "time": 70.49,
      "time_str": "01:10.490",
      "text": "寒江雪终映明月",
      "translation": null
    },
    {
      "time": 75.49,
      "time_str": "01:15.490",
      "text": "雾雪间 仿佛骤来夜雨门外唏嘘声",
      "translation": null
    },
    {
      "time": 82.49,
      "time_str": "01:22.490",
      "text": "梦已醒 早更未寒夜冷清",
      "translation": null
    },
    {
      "time": 88.49,
      "time_str": "01:28.490",
      "text": "望雪飘 叹息艳华逝去情像满江叶",
      "translation": null
    },
    {
      "time": 95.49,
      "time_str": "01:35.490",
      "text": "眼中泪 是你那一句离别",
