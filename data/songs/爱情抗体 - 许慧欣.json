    {
      "time": 19.49,
      "time_str": "00:19.490",
      "text": "我不知道今天星期几",
      "translation": null
    },
    {
      "time": 22.18,
      "time_str": "00:22.180",
      "text": "是个坏天气",
      "translation": null
    },
    {
      "time": 24.69,
      "time_str": "00:24.690",
      "text": "一年又一天",
      "translation": null
    },
    {
      "time": 26.8,
      "time_str": "00:26.800",
      "text": "忽然又想到你",
      "translation": null
    },
    {
      "time": 29.67,
      "time_str": "00:29.670",
      "text": "翻翻小说 弹一弹钢琴",
      "translation": null
    },
    {
      "time": 34.33,
      "time_str": "00:34.330",
      "text": "顺手回几封电子信",
      "translation": null
    },
    {
      "time": 39.24,
      "time_str": "00:39.240",
      "text": "我在捷运线的车子里",
      "translation": null
    },
    {
      "time": 41.96,
      "time_str": "00:41.960",
      "text": "像低空飞行",
      "translation": null
    },
    {
      "time": 44.53,
      "time_str": "00:44.530",
      "text": "飞过这城市",
      "translation": null
    },
    {
      "time": 46.59,
      "time_str": "00:46.590",
      "text": "才不管目的地",
      "translation": null
    },
    {
      "time": 49.13,
      "time_str": "00:49.130",
      "text": "那些我和你有过的事情",
      "translation": null
    },
    {
      "time": 54.2,
      "time_str": "00:54.200",
      "text": "都像逃走的水蒸气",
      "translation": null
    },
    {
      "time": 58.44,
      "time_str": "00:58.440",
      "text": "I’ll be leaving you",
      "translation": null
    },
    {
