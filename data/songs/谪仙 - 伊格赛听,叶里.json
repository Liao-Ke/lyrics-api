      "text": "策划：李亚男",
      "translation": null
    },
    {
      "time": 12.21,
      "time_str": "00:12.210",
      "text": "仙歌音  玉笛灵  酒盏玉露清",
      "translation": null
    },
    {
      "time": 18.77,
      "time_str": "00:18.770",
      "text": "剑舞轻   潇洒过白袍影",
      "translation": null
    },
    {
      "time": 25.65,
      "time_str": "00:25.650",
      "text": "新殿又细雕流金   声声箜篌鸣",
      "translation": null
    },
    {
      "time": 32.84,
      "time_str": "00:32.840",
      "text": "一笔浓墨留诗狂情",
      "translation": null
    },
    {
      "time": 39.08,
      "time_str": "00:39.080",
      "text": "玉袍长剑堪风流",
      "translation": null
    },
    {
      "time": 43.15,
      "time_str": "00:43.150",
      "text": "山川不念旧",
      "translation": null
    },
    {
      "time": 45.65,
      "time_str": "00:45.650",
      "text": "赋诗为狂也无有愁",
      "translation": null
    },
    {
      "time": 52.21,
      "time_str": "00:52.210",
      "text": "称谪仙瑶宫难留",
      "translation": null
    },
    {
      "time": 55.34,
      "time_str": "00:55.340",
      "text": "去凡间红楼斗酒",
      "translation": null
    },
    {
      "time": 59.084,
      "time_str": "00:59.084",
      "text": "多情眸   落墨诗卷又几斗",
      "translation": null
    },
    {
      "time": 65.332,
      "time_str": "01:05.332",
      "text": "斟世间最烈的酒",
      "translation": null
    },
    {
      "time": 69.091,
      "time_str": "01:09.091",
      "text": "卧长安巍巍高楼",
      "translation": null
    },
    {
      "time": 72.515,
