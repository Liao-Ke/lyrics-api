{
  "title": "Demons",
  "title_raw": "Demons",
  "version": null,
  "artist": "Imagine Dragons",
  "group_key": "demons|imagine dragons",
  "writers": {
    "lyricist": "Josh Mosser/A. Grant/Dan Reynolds/Wayne Sermon/Ben McKee",
    "composer": "Josh Mosser/A. Grant/Dan Reynolds/Wayne Sermon/Ben McKee",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 0.33,
      "time_str": "00:00.330",
      "text": "When the days are cold",
      "translation": "当冰冷降临世间"
    },
    {
      "time": 3.03,
      "time_str": "00:03.030",
      "text": "And the cards all fold",
      "translation": "当希望灭绝人间"
    },
    {
      "time": 5.57,
      "time_str": "00:05.570",
      "text": "And the saints we see",
      "translation": "我们能寄予希望的圣人"
    },
    {
      "time": 7.92,
      "time_str": "00:07.920",
      "text": "Are all made of gold",
      "translation": "都不过是一个个无力的金铸雕像"
    },
    {
      "time": 10.95,
      "time_str": "00:10.950",
      "text": "When your dreams all fail",
      "translation": "当你的美梦沦落"
    },
    {
      "time": 13.32,
      "time_str": "00:13.320",
      "text": "And the ones we hail",
      "translation": "当我们只得以崇拜强权"
    },
    {
      "time": 15.91,
      "time_str": "00:15.910",
      "text": "Are the worst of all",
      "translation": "前所未有的噩梦底下"
    },
    {
      "time": 18.4,
      "time_str": "00:18.400",
      "text": "And the blood’s run stale",
      "translation": "连血液都渐趋陈腐"
    },
    {
      "time": 22.48,
      "time_str": "00:22.480",
      "text": "I wanna hide the truth",
      "translation": "我想要隐藏内心的真相"
    },
    {
      "time": 25.09,
      "time_str": "00:25.090",
      "text": "I wanna shelter you",
      "translation": "好构筑庇护你的天国"
    },
    {
      "time": 27.87,
      "time_str": "00:27.870",
      "text": "But with the beast inside",
      "translation": "只是我内心的野兽凶猛强横"
    },
    {
      "time": 30.56,
      "time_str": "00:30.560",
      "text": "There’s nowhere we can hide",
      "translation": "令我们无处可藏"
    },
    {
      "time": 33.16,
      "time_str": "00:33.160",
      "text": "No matter what we breed",
      "translation": "不管各自以何为食"
    },
    {
      "time": 35.77,
      "time_str": "00:35.770",
      "text": "We still are made of greed",
      "translation": "我们同是被贪婪堆砌而成的动物"
    },
    {
      "time": 38.46,
      "time_str": "00:38.460",
      "text": "This is my kingdom come",
      "translation": "由我主宰的欲望王国平地而起"
    },
    {
      "time": 41.28,
      "time_str": "00:41.280",
      "text": "This is my kingdom come",
      "translation": "君临天下，唯我独尊"
    },
    {
      "time": 44.25,
      "time_str": "00:44.250",
      "text": "When you feel my heat",
      "translation": "当你感受到我的炙热"
    },
    {
      "time": 46.79,
      "time_str": "00:46.790",
      "text": "Look into my eyes",
      "translation": "请凝视我的双眸"
    },
    {
      "time": 49.26,
      "time_str": "00:49.260",
      "text": "It’s where my demons hide",
      "translation": "我内心的恶魔就在那里"
    },
    {
      "time": 51.84,
      "time_str": "00:51.840",
      "text": "It’s where my demons hide",
      "translation": "它以我的心灵为居所"
    },
    {
      "time": 54.89,
      "time_str": "00:54.890",
      "text": "Don’t get too close",
      "translation": "不要靠太近"
    },
    {
      "time": 57.62,
      "time_str": "00:57.620",
      "text": "It’s dark inside",
      "translation": "里面暗无天日"
    },
    {
      "time": 59.86,
      "time_str": "00:59.860",
      "text": "It’s where my demons hide",
      "translation": "我内心的恶魔就在那"
    },
    {
      "time": 62.5,
      "time_str": "01:02.500",
      "text": "It’s where my demons hide",
      "translation": "我内心的恶魔就在那"
    },
    {
      "time": 65.82,
      "time_str": "01:05.820",
      "text": "When the curtain’s call",
      "translation": "当帘幕降下"
    },
    {
      "time": 66.79,
      "time_str": "01:06.790",
      "text": "Is the last of all",
      "translation": "一切都将宣告终结"
    },
    {
      "time": 69.07,
      "time_str": "01:09.070",
      "text": "When the lights fade out",
      "translation": "光明渐淡"
    },
    {
      "time": 71.72,
      "time_str": "01:11.720",
      "text": "All the sinners crawl",
      "translation": "所有罪恶都蠢蠢欲动"
    },
    {
      "time": 74.49,
      "time_str": "01:14.490",
      "text": "So they dug your grave",
      "translation": "他们翻挖你的坟墓"
    },
    {
      "time": 77.33,
      "time_str": "01:17.330",
      "text": "And the masquerade",
      "translation": "撕下你的伪装"
    },
    {
      "time": 79.76,
      "time_str": "01:19.760",
      "text": "Will come calling out",
      "translation": "我撕心裂肺地嘶吼"
    },
    {
      "time": 82.58,
      "time_str": "01:22.580",
      "text": "At the mess you made",
      "translation": "在因你而起的这片狼藉中"
    },
    {
      "time": 86.54,
      "time_str": "01:26.540",
      "text": "Don’t want to let you down",
      "translation": "我不愿让你悲伤"
    },
    {
      "time": 89.35,
      "time_str": "01:29.350",
      "text": "But I am hell bound",
      "translation": "但我身不由己"
    },
    {
      "time": 92.05,
      "time_str": "01:32.050",
      "text": "Though this is all for you",
      "translation": "尽管我为你做下了一切"
    },
    {
      "time": 94.5,
      "time_str": "01:34.500",
      "text": "Don't wanna hide the truth",
      "translation": "但我决心不再隐瞒真相"
    },
    {
      "time": 97.04,
      "time_str": "01:37.040",
      "text": "No matter what we breed",
      "translation": "无论你我以何为生"
    },
    {
      "time": 99.78,
      "time_str": "01:39.780",
      "text": "We still are made of greed",
      "translation": "我们都是被贪婪堆砌的动物"
    },
    {
      "time": 102.45,
      "time_str": "01:42.450",
      "text": "This is my kingdom come",
      "translation": "由我构筑起的欲望王国"
    },
    {
      "time": 105.09,
      "time_str": "01:45.090",
      "text": "This is my kingdom come",
      "translation": "它已然矗立大地，埋下一片阴影"
    },
    {
      "time": 110.4,
      "time_str": "01:50.400",
      "text": "When you feel my heat",
      "translation": "当你感受到我的炙热"
    },
    {
      "time": 110.87,
      "time_str": "01:50.870",
      "text": "Look into my eyes",
      "translation": "请凝视我的双眸"
    },
    {
      "time": 113.24,
      "time_str": "01:53.240",
      "text": "It’s where my demons hide",
      "translation": "我内心的恶魔就在那"
    },
    {
      "time": 115.77,
      "time_str": "01:55.770",
      "text": "It’s where my demons hide",
      "translation": "它就躲藏在那一方天地"
    },
    {
      "time": 118.78,
      "time_str": "01:58.780",
      "text": "Don’t get too close",
      "translation": "不要轻易涉足"
    },
    {
      "time": 121.51,
      "time_str": "02:01.510",
      "text": "It’s dark inside",
      "translation": "那里暗无天日"
    },
    {
      "time": 123.89,
      "time_str": "02:03.890",
      "text": "It’s where my demons hide",
      "translation": "它躲藏在那里"
    },
    {
      "time": 126.45,
      "time_str": "02:06.450",
      "text": "It’s where my demons hide",
      "translation": "它蛰伏在那里！"
    },
    {
      "time": 129.5,
      "time_str": "02:09.500",
      "text": "They say it's what you make",
      "translation": "人们讥讽我咎由自取"
    },
    {
      "time": 131.86,
      "time_str": "02:11.860",
      "text": "I say it's up to fate",
      "translation": "我笑答这是命中注定"
    },
    {
      "time": 134.66,
      "time_str": "02:14.660",
      "text": "It's woven in my soul",
      "translation": "尽管灵魂深处依旧纠结"
    },
    {
      "time": 137.2,
      "time_str": "02:17.200",
      "text": "I need to let you go",
      "translation": "但我还是选择将你放下"
    },
    {
      "time": 139.88,
      "time_str": "02:19.880",
      "text": "Your eyes, they shine so bright",
      "translation": "你的双瞳明亮如皓日当空"
    },
    {
      "time": 142.49,
      "time_str": "02:22.490",
      "text": "I want to save that light",
      "translation": "我希望能将其占为己有"
    },
    {
      "time": 145.11,
      "time_str": "02:25.110",
      "text": "I can't escape this now",
      "translation": "但我已经无从挣脱桎梏"
    },
    {
      "time": 147.77,
      "time_str": "02:27.770",
      "text": "Unless you show me how",
      "translation": "除非你能引领我走出黑暗"
    },
    {
      "time": 151.4,
      "time_str": "02:31.400",
      "text": "When you feel my heat",
      "translation": "当你被我的炙热迷惑时"
    },
    {
      "time": 153.46,
      "time_str": "02:33.460",
      "text": "Look into my eyes",
      "translation": "直视我的双眸"
    },
    {
      "time": 155.94,
      "time_str": "02:35.940",
      "text": "It’s where my demons hide",
      "translation": "看清深藏于此的恶魔"
    },
    {
      "time": 158.48,
      "time_str": "02:38.480",
      "text": "It’s where my demons hide",
      "translation": "看清它的狰狞面貌！"
    },
    {
      "time": 161.47,
      "time_str": "02:41.470",
      "text": "Don’t get too close",
      "translation": "不要轻易接近我！"
    },
    {
      "time": 163.99,
      "time_str": "02:43.990",
      "text": "It’s dark inside",
      "translation": "我的内心暗无天日！"
    },
    {
      "time": 166.53,
      "time_str": "02:46.530",
      "text": "It’s where my demons hide",
      "translation": "因为我是恶魔寄居的容器！"
    },
    {
      "time": 169.1,
      "time_str": "02:49.100",
      "text": "It’s where my demons hide",
      "translation": "因为我是被恶魔凭依的傀儡！"
    }
  ],
  "has_translation": true,
  "source_file": "Demons - Imagine Dragons.lrc"
}