  "lyrics": [
    {
      "time": 7.82,
      "time_str": "00:07.820",
      "text": "I've been reading books of old",
      "translation": "我曾饱览古老的书籍"
    },
    {
      "time": 10.14,
      "time_str": "00:10.140",
      "text": "The legends and the myths",
      "translation": "那些传说与神话"
    },
    {
      "time": 12.28,
      "time_str": "00:12.280",
      "text": "Achilles and his gold",
      "translation": "阿喀琉斯和他的战利品"
    },
    {
      "time": 14.62,
      "time_str": "00:14.620",
      "text": "Hercules and his gifts",
      "translation": "赫拉克勒斯与他的天赋神力"
    },
    {
      "time": 17.1,
      "time_str": "00:17.100",
      "text": "Spiderman's control",
      "translation": "**侠的控制力"
    },
    {
      "time": 19.34,
      "time_str": "00:19.340",
      "text": "And Batman with his fists",
      "translation": "和蝙蝠侠的铁拳"
    },
    {
      "time": 22.31,
      "time_str": "00:22.310",
      "text": "And clearly I don't see myself upon that list",
      "translation": "显而易见我未能名列其中"
    },
    {
      "time": 26.07,
      "time_str": "00:26.070",
      "text": "But she said, where'd you wanna go?",
      "translation": "她说，你想去何方？"
    },
    {
      "time": 28.7,
      "time_str": "00:28.700",
      "text": "How much you wanna risk?",
      "translation": "你甘愿承担多大的风险？"
    },
    {
      "time": 30.7,
      "time_str": "00:30.700",
      "text": "I'm not looking for somebody",
      "translation": "我并不渴求"
    },
    {
      "time": 32.97,
      "time_str": "00:32.970",
      "text": "With some superhuman gifts",
      "translation": "那些超人类的天赋"
    },
    {
      "time": 35.61,
      "time_str": "00:35.610",
      "text": "Some superhero",
      "translation": "那种超级英雄"
    },
    {
      "time": 37.92,
      "time_str": "00:37.920",
      "text": "Some fairytale bliss",
      "translation": "那些童话般的天赐之福"
    },
    {
      "time": 40.38,
      "time_str": "00:40.380",
      "text": "Just something I can turn to",
      "translation": "只是一些我能力所能及的事情"
    },
    {
      "time": 42.6,
      "time_str": "00:42.600",
      "text": "Somebody I can kiss",
      "translation": "吻到我爱的人就好"
    },
    {
      "time": 44.67,
      "time_str": "00:44.670",
      "text": "I want something just like this",
      "translation": "我想要的仅此而已"
    },
    {
      "time": 47.35,
      "time_str": "00:47.350",
