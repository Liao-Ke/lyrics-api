  "lyrics": [
    {
      "time": 3.0,
      "time_str": "00:03.000",
      "text": "Publisher : Fujipacific Ms Inc. / PolyGram",
      "translation": null
    },
    {
      "time": 17.62,
      "time_str": "00:17.620",
      "text": "繁星流动 和你同路",
      "translation": null
    },
    {
      "time": 26.41,
      "time_str": "00:26.410",
      "text": "从不相识 开始心接近",
      "translation": null
    },
    {
      "time": 30.51,
      "time_str": "00:30.510",
      "text": "默默以真挚待人",
      "translation": null
    },
    {
      "time": 35.16,
      "time_str": "00:35.160",
      "text": "人生如梦 朋友如雾",
      "translation": null
    },
    {
      "time": 43.92,
      "time_str": "00:43.920",
      "text": "难得知心 几经风暴",
      "translation": null
    },
    {
      "time": 48.1,
      "time_str": "00:48.100",
      "text": "为着我不退半步 正是你",
      "translation": null
    },
    {
      "time": 55.76,
      "time_str": "00:55.760",
      "text": "遥遥晚空 点点星光 息息相关",
      "translation": null
    },
    {
      "time": 59.56,
      "time_str": "00:59.560",
      "text": "你我哪怕荆棘铺满路",
      "translation": null
    },
    {
      "time": 66.23,
      "time_str": "01:06.230",
      "text": "替我解开心中的孤单 是谁明白我",
      "translation": null
    },
    {
      "time": 73.32,
      "time_str": "01:13.320",
      "text": "情同两手 一起开心 一起悲伤",
      "translation": null
    },
    {
      "time": 77.08,
      "time_str": "01:17.080",
      "text": "彼此分担 总不分我或你",
      "translation": null
    },
    {
      "time": 83.73,
      "time_str": "01:23.730",
      "text": "你为了我 我为了你",
      "translation": null
    },
    {
      "time": 88.7,
      "time_str": "01:28.700",
      "text": "共赴患难 绝望里紧握你手",
      "translation": null
    },
    {
      "time": 95.8,
      "time_str": "01:35.800",
      "text": "朋友",
      "translation": null
    },
