  "lyrics": [
    {
      "time": 18.59,
      "time_str": "00:18.590",
      "text": "人渐醉了夜更深 在这一刻多么接近",
      "translation": null
    },
    {
      "time": 25.869,
      "time_str": "00:25.869",
      "text": "思想仿似在摇撼 矛盾也更深",
      "translation": null
    },
    {
      "time": 33.898,
      "time_str": "00:33.898",
      "text": "曾被破碎过的心 让你今天轻轻贴近",
      "translation": null
    },
    {
      "time": 40.347,
      "time_str": "00:40.347",
      "text": "多少安慰及疑问 偷偷的再生",
      "translation": null
    },
    {
      "time": 47.789,
      "time_str": "00:47.789",
      "text": "情难自禁 我却其实属于",
      "translation": null
    },
    {
      "time": 50.877,
      "time_str": "00:50.877",
      "text": "极度容易受伤的女人",
      "translation": null
    },
    {
      "time": 54.447,
      "time_str": "00:54.447",
      "text": "不要 不要 不要骤来骤去",
      "translation": null
    },
    {
      "time": 58.37,
      "time_str": "00:58.370",
      "text": "请珍惜我的心",
      "translation": null
    },
    {
      "time": 61.697,
      "time_str": "01:01.697",
      "text": "如明白我   继续情愿热恋",
      "translation": null
    },
    {
      "time": 65.379,
      "time_str": "01:05.379",
      "text": "这个容易受伤的女人",
      "translation": null
    },
    {
      "time": 69.079,
      "time_str": "01:09.079",
      "text": "不要等 这一刻 请热吻",
      "translation": null
    },
    {
      "time": 76.688,
      "time_str": "01:16.688",
      "text": "长夜有你醉也真 让我终于找到信任",
      "translation": null
    },
    {
      "time": 83.888,
      "time_str": "01:23.888",
      "text": "不管一切是疑问 快乐是情人",
      "translation": null
    },
    {
      "time": 120.099,
      "time_str": "02:00.099",
      "text": "曾害怕了这一生 是你始终甘心靠近",
      "translation": null
    },
    {
