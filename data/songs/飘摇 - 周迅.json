  "lyrics": [
    {
      "time": 21.39,
      "time_str": "00:21.390",
      "text": "风停了云知道",
      "translation": null
    },
    {
      "time": 25.01,
      "time_str": "00:25.010",
      "text": "爱走了心自然明了",
      "translation": null
    },
    {
      "time": 29.77,
      "time_str": "00:29.770",
      "text": "它来时躲不掉",
      "translation": null
    },
    {
      "time": 34.13,
      "time_str": "00:34.130",
      "text": "它走得静悄悄",
      "translation": null
    },
    {
      "time": 38.52,
      "time_str": "00:38.520",
      "text": "你不在我预料",
      "translation": null
    },
    {
      "time": 42.21,
      "time_str": "00:42.210",
      "text": "扰乱我平静的步调",
      "translation": null
    },
    {
      "time": 47.02,
      "time_str": "00:47.020",
      "text": "怕爱了找苦恼",
      "translation": null
    },
    {
      "time": 51.46,
      "time_str": "00:51.460",
      "text": "怕不爱睡不着",
      "translation": null
    },
    {
      "time": 57.56,
      "time_str": "00:57.560",
      "text": "我飘啊飘你摇啊摇",
      "translation": null
    },
    {
      "time": 62.29,
      "time_str": "01:02.290",
      "text": "无根的野草",
      "translation": null
    },
    {
      "time": 66.62,
      "time_str": "01:06.620",
      "text": "当梦醒了天晴了",
      "translation": null
    },
    {
      "time": 70.82,
      "time_str": "01:10.820",
      "text": "如何再飘摇",
      "translation": null
    },
    {
      "time": 74.84,
      "time_str": "01:14.840",
      "text": "（啊）爱多一秒恨不会少",
      "translation": null
    },
    {
      "time": 79.38,
      "time_str": "01:19.380",
      "text": "承诺是煎熬",
      "translation": null
    },
    {
      "time": 83.8,
      "time_str": "01:23.800",
      "text": "若不计较",
      "translation": null
    },
    {
      "time": 85.96,
      "time_str": "01:25.960",
      "text": "就一次痛快燃烧",
      "translation": null
    },
