    {
      "time": 28.34,
      "time_str": "00:28.340",
      "text": "看不穿是你失落的魂魄",
      "translation": null
    },
    {
      "time": 34.99,
      "time_str": "00:34.990",
      "text": "猜不透是你瞳孔的颜色",
      "translation": null
    },
    {
      "time": 42.04,
      "time_str": "00:42.040",
      "text": "一阵风一场梦爱如生命般莫测",
      "translation": null
    },
    {
      "time": 48.73,
      "time_str": "00:48.730",
      "text": "你的心到底被什么蛊惑",
      "translation": null
    },
    {
      "time": 55.55,
      "time_str": "00:55.550",
      "text": "你的轮廓在黑夜之中淹没",
      "translation": null
    },
    {
      "time": 62.05,
      "time_str": "01:02.050",
      "text": "看桃花开出怎样的结果",
      "translation": null
    },
    {
      "time": 69.24,
      "time_str": "01:09.240",
      "text": "看着你抱着我目光似月色寂寞",
      "translation": null
    },
    {
      "time": 75.99,
      "time_str": "01:15.990",
      "text": "就让你在别人怀里快乐",
      "translation": null
    },
    {
      "time": 83.17,
      "time_str": "01:23.170",
      "text": "爱着你像心跳难触摸",
      "translation": null
    },
    {
      "time": 90.17,
      "time_str": "01:30.170",
      "text": "画着你画不出你的骨骼",
      "translation": null
    },
    {
      "time": 96.92,
      "time_str": "01:36.920",
      "text": "记着你的脸色是我等你的执着",
