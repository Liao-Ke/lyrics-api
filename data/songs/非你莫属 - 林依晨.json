    {
      "time": 25.11,
      "time_str": "00:25.110",
      "text": "懂得让我微笑的人",
      "translation": null
    },
    {
      "time": 33.489,
      "time_str": "00:33.489",
      "text": "再没有谁比你有天份",
      "translation": null
    },
    {
      "time": 41.29,
      "time_str": "00:41.290",
      "text": "轻易闯进我的心门",
      "translation": null
    },
    {
      "time": 47.699,
      "time_str": "00:47.699",
      "text": "明天的美梦你完成",
      "translation": null
    },
    {
      "time": 55.449,
      "time_str": "00:55.449",
      "text": "整个宇宙 浩瀚无边的尽头",
      "translation": null
    },
    {
      "time": 63.279,
      "time_str": "01:03.279",
      "text": "每颗渺小星球",
      "translation": null
    },
    {
      "time": 66.38,
      "time_str": "01:06.380",
      "text": "全都绕着你走",
      "translation": null
    },
    {
      "time": 69.929,
      "time_str": "01:09.929",
      "text": "爱我 非你莫属",
      "translation": null
    },
    {
      "time": 75.77,
      "time_str": "01:15.770",
      "text": "我只愿 守护",
      "translation": null
    },
    {
      "time": 79.98,
      "time_str": "01:19.980",
      "text": "由你给我的幸福",
      "translation": null
    },
    {
      "time": 83.26,
      "time_str": "01:23.260",
      "text": "爱我 非你莫属",
      "translation": null
