    {
      "time": 51.497,
      "time_str": "00:51.497",
      "text": "当山峰没有棱角的时候",
      "translation": null
    },
    {
      "time": 54.865,
      "time_str": "00:54.865",
      "text": "当河水不再流",
      "translation": null
    },
    {
      "time": 58.285,
      "time_str": "00:58.285",
      "text": "当时间停住 日夜不分",
      "translation": null
    },
    {
      "time": 62.159,
      "time_str": "01:02.159",
      "text": "当天地万物化为虚有",
      "translation": null
    },
    {
      "time": 65.429,
      "time_str": "01:05.429",
      "text": "我还是不能和你分手",
      "translation": null
    },
    {
