    {
      "time": 27.18,
      "time_str": "00:27.180",
      "text": "时间一转眼就过去了三年",
      "translation": null
    },
    {
      "time": 31.71,
      "time_str": "00:31.710",
      "text": "一切在我心里开得好皎洁",
      "translation": null
    },
    {
      "time": 36.01,
      "time_str": "00:36.010",
      "text": "现在倒计时也不剩几天",
      "translation": null
    },
    {
      "time": 40.16,
      "time_str": "00:40.160",
      "text": "脚边的纸片来不及去捡",
      "translation": null
    },
    {
      "time": 44.66,
      "time_str": "00:44.660",
      "text": "仿佛是快要冲破压力的茧",
      "translation": null
    },
    {
      "time": 49.13,
      "time_str": "00:49.130",
      "text": "离校后大家又各自熬夜",
      "translation": null
    },
    {
