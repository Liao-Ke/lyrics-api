  "lyrics": [
    {
      "time": 1.542,
      "time_str": "00:01.542",
      "text": "她住在七月的洪流上",
      "translation": null
    },
    {
      "time": 4.724,
      "time_str": "00:04.724",
      "text": "天台倾倒理想一万丈",
      "translation": null
    },
    {
      "time": 7.534,
      "time_str": "00:07.534",
      "text": "她午睡在北风仓皇途经的芦苇荡",
      "translation": null
    },
    {
      "time": 15.974,
      "time_str": "00:15.974",
      "text": "她梦中的草原白茫茫",
      "translation": null
    },
    {
      "time": 19.337,
      "time_str": "00:19.337",
      "text": "列车搭上悲欢去辗转",
      "translation": null
    },
    {
      "time": 22.353,
      "time_str": "00:22.353",
      "text": "她尝遍了每个异乡限时赠送的糖",
      "translation": null
    },
    {
      "time": 30.913,
      "time_str": "00:30.913",
      "text": "若我站在朝阳上能否脱去昨日的惆怅",
      "translation": null
    },
    {
      "time": 38.1,
      "time_str": "00:38.100",
      "text": "单薄语言能否传达我所有的牵挂",
      "translation": null
    },
    {
      "time": 45.95,
      "time_str": "00:45.950",
      "text": "若有天我不复勇往能否坚持走完这一场",
      "translation": null
    },
    {
      "time": 51.756,
      "time_str": "00:51.756",
      "text": "踏遍万水千山总有一地故乡",
      "translation": null
    },
    {
      "time": 60.335,
      "time_str": "01:00.335",
      "text": "城市慷慨亮整夜光",
      "translation": null
    },
    {
      "time": 64.374,
      "time_str": "01:04.374",
      "text": "如同少年不惧岁月长",
      "translation": null
    },
    {
      "time": 66.532,
      "time_str": "01:06.532",
      "text": "她想要的不多只是和别人的不一样",
      "translation": null
    },
    {
      "time": 75.12,
      "time_str": "01:15.120",
      "text": "烛光倒影为我添茶",
      "translation": null
    },
    {
      "time": 78.23,
      "time_str": "01:18.230",
      "text": "相逢太短不等茶水凉",
      "translation": null
    },
    {
      "time": 80.995,
      "time_str": "01:20.995",
      "text": "你扔下的习惯还顽强活在我身上",
      "translation": null
    },
    {
      "time": 89.946,
      "time_str": "01:29.946",
      "text": "如果我站在朝阳上能否脱去昨日的惆怅",
      "translation": null
    },
    {
