    {
      "time": 170.003,
      "time_str": "02:50.003",
      "text": "踏遍万水千山总有一地故乡",
      "translation": null
    },
    {
      "time": 178.96,
      "time_str": "02:58.960",
      "text": "她走在马蹄的余声中",
      "translation": null
    },
    {
      "time": 181.795,
      "time_str": "03:01.795",
      "text": "夕阳燃烧离别多少场",
      "translation": null
    },
    {
      "time": 185.11,
      "time_str": "03:05.110",
      "text": "她向陌生人们解说陌生人的风光",
      "translation": null
    },
    {
      "time": 193.127,
      "time_str": "03:13.127",
      "text": "等她归来坐下对我讲",
      "translation": null
    },
    {
      "time": 196.441,
      "time_str": "03:16.441",
      "text": "故人旧时容颜未沧桑",
      "translation": null
    },
    {
      "time": 199.506,
      "time_str": "03:19.506",
      "text": "我们仍旧想要当初想要的不一样",
      "translation": null
    }
