  "lyrics": [
    {
      "time": 28.94,
      "time_str": "00:28.940",
      "text": "今夜我又来到你的窗外",
      "translation": null
    },
    {
      "time": 33.31,
      "time_str": "00:33.310",
      "text": "窗帘上你的影子多么可爱",
      "translation": null
    },
    {
      "time": 38.42,
      "time_str": "00:38.420",
      "text": "悄悄的爱过你这么多年",
      "translation": null
    },
    {
      "time": 42.87,
      "time_str": "00:42.870",
      "text": "明天我就要离开",
      "translation": null
    },
    {
      "time": 47.62,
      "time_str": "00:47.620",
      "text": "多少回我来到你的窗外",
      "translation": null
    },
    {
      "time": 52.36,
      "time_str": "00:52.360",
      "text": "也曾想敲敲门叫你出来",
      "translation": null
    },
    {
      "time": 56.7,
      "time_str": "00:56.700",
      "text": "想一想你的美丽",
      "translation": null
    },
    {
      "time": 59.31,
      "time_str": "00:59.310",
      "text": "我的平凡",
      "translation": null
    },
    {
      "time": 61.47,
      "time_str": "01:01.470",
      "text": "一次次默默走开",
      "translation": null
    },
    {
      "time": 66.15,
      "time_str": "01:06.150",
      "text": "再见了心爱的梦中女孩",
      "translation": null
    },
    {
      "time": 70.92,
      "time_str": "01:10.920",
      "text": "我将要去远方寻找未来",
      "translation": null
    },
    {
      "time": 75.3,
      "time_str": "01:15.300",
      "text": "假如我有一天荣归故里",
      "translation": null
    },
    {
      "time": 79.63,
      "time_str": "01:19.630",
      "text": "再到你窗外诉说情怀",
      "translation": null
    },
    {
      "time": 84.51,
      "time_str": "01:24.510",
      "text": "再见了心爱的梦中女孩",
      "translation": null
    },
    {
      "time": 89.39,
      "time_str": "01:29.390",
      "text": "对着你的影子说声珍重",
      "translation": null
    },
    {
      "time": 93.93,
      "time_str": "01:33.930",
      "text": "假如我永远不再回来",
      "translation": null
    },
    {
      "time": 97.99,
      "time_str": "01:37.990",
      "text": "就让月亮守在你窗外",
      "translation": null
    },
