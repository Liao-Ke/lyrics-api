    {
      "time": 3.85,
      "time_str": "00:03.850",
      "text": "专辑：情爱怨女",
      "translation": null
    },
    {
      "time": 6.05,
      "time_str": "00:06.050",
      "text": "制作助理：陈建宁",
      "translation": null
    },
    {
      "time": 8.11,
      "time_str": "00:08.110",
      "text": "贝斯：邱培荣",
      "translation": null
    },
    {
      "time": 10.9,
      "time_str": "00:10.900",
      "text": "键盘：杨长杰",
      "translation": null
    },
    {
      "time": 14.35,
      "time_str": "00:14.350",
      "text": "混音工程师：黄钦胜",
      "translation": null
    },
    {
      "time": 30.8,
      "time_str": "00:30.800",
      "text": "爱到心破碎也别去怪谁",
      "translation": null
    },
    {
      "time": 35.72,
      "time_str": "00:35.720",
      "text": "只因为相遇太美",
      "translation": null
    },
    {
      "time": 39.18,
      "time_str": "00:39.180",
      "text": "就算流干泪伤到底",
      "translation": null
    },
    {
      "time": 41.57,
      "time_str": "00:41.570",
      "text": "心成灰也无所谓",
      "translation": null
    },
    {
      "time": 46.71,
      "time_str": "00:46.710",
      "text": "我破茧成蝶愿和你双飞",
      "translation": null
    },
    {
      "time": 50.68,
      "time_str": "00:50.680",
      "text": "最怕你会一去不回",
      "translation": null
    },
    {
      "time": 54.22,
      "time_str": "00:54.220",
      "text": "虽然爱过我给过我",
      "translation": null
    },
    {
      "time": 56.58,
      "time_str": "00:56.580",
      "text": "想过我就是安慰嘿",
      "translation": null
    },
    {
      "time": 61.29,
      "time_str": "01:01.290",
      "text": "我向你飞雨温柔的坠",
      "translation": null
    },
    {
      "time": 65.0,
      "time_str": "01:05.000",
      "text": "像你的拥抱把我包围",
      "translation": null
    },
    {
      "time": 68.74,
      "time_str": "01:08.740",
      "text": "我向你飞多远都不累",
      "translation": null
    },
    {
      "time": 72.29,
      "time_str": "01:12.290",
      "text": "虽然旅途中有过痛和泪",
      "translation": null
    },
    {
      "time": 76.21,
      "time_str": "01:16.210",
      "text": "我向你追风温柔的吹",
      "translation": null
    },
    {
      "time": 79.99,
      "time_str": "01:19.990",
      "text": "只要你无怨我也无悔",
      "translation": null
    },
    {
      "time": 83.78,
      "time_str": "01:23.780",
      "text": "爱是那么美我心陶醉",
      "translation": null
    },
    {
      "time": 87.32,
      "time_str": "01:27.320",
      "text": "被爱的感觉",
      "translation": null
    },
