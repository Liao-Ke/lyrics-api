    {
      "time": 29.431,
      "time_str": "00:29.431",
      "text": "真情像草原广阔",
      "translation": null
    },
    {
      "time": 36.314,
      "time_str": "00:36.314",
      "text": "层层风雨不能阻隔",
      "translation": null
    },
    {
      "time": 43.115,
      "time_str": "00:43.115",
      "text": "总有云开日出时候",
      "translation": null
    },
    {
      "time": 50.398,
      "time_str": "00:50.398",
      "text": "万丈阳光照耀你我",
      "translation": null
    },
    {
      "time": 56.824,
      "time_str": "00:56.824",
      "text": "真情像梅花开过",
      "translation": null
    },
    {
      "time": 63.668,
      "time_str": "01:03.668",
      "text": "冷冷冰雪不能淹没",
      "translation": null
    },
    {
      "time": 70.537,
      "time_str": "01:10.537",
      "text": "就在最冷枝头绽放",
      "translation": null
    },
    {
      "time": 77.78,
      "time_str": "01:17.780",
      "text": "看见春天走向你我",
      "translation": null
    },
    {
      "time": 84.655,
      "time_str": "01:24.655",
      "text": "雪花飘飘北风萧萧",
      "translation": null
    },
    {
      "time": 91.472,
      "time_str": "01:31.472",
      "text": "天地一片苍茫",
      "translation": null
    },
    {
      "time": 98.304,
      "time_str": "01:38.304",
      "text": "一剪寒梅傲立雪中",
      "translation": null
    },
    {
      "time": 105.129,
      "time_str": "01:45.129",
      "text": "只为伊人飘香",
      "translation": null
    },
    {
      "time": 111.994,
      "time_str": "01:51.994",
      "text": "爱我所爱无怨无悔",
      "translation": null
    },
    {
      "time": 118.785,
      "time_str": "01:58.785",
      "text": "此情长留心间",
      "translation": null
    },
