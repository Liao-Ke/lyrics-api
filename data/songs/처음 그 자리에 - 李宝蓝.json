{
  "title": "처음 그 자리에",
  "title_raw": "처음 그 자리에",
  "version": null,
  "artist": "李宝蓝",
  "group_key": "처음 그 자리에|李宝蓝",
  "writers": {
    "lyricist": "한성호",
    "composer": "李京燮",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 6.58,
      "time_str": "00:06.580",
      "text": "그대 지금 내 가슴에 들어와 사랑을 말하고 있죠",
      "translation": "现在，你进入我的心里，诉说着爱恋"
    },
    {
      "time": 13.78,
      "time_str": "00:13.780",
      "text": "꿈이 아니기를 나는 기도해봐요",
      "translation": "我祈望这不是梦境"
    },
    {
      "time": 20.67,
      "time_str": "00:20.670",
      "text": "내 맘이 자꾸 그대란 사람 놓지 말라고 하네요",
      "translation": "我的心底在说，千万不能错过你"
    },
    {
      "time": 27.46,
      "time_str": "00:27.460",
      "text": "욕심을 빼라며 바보같은 말을 하네요",
      "translation": "可我也许像个贪得无厌的傻瓜吧"
    },
    {
      "time": 43.44,
      "time_str": "00:43.440",
      "text": "우연히 다가온 그대 사랑이",
      "translation": "那么偶然间出现在我身边的你的爱"
    },
    {
      "time": 50.7,
      "time_str": "00:50.700",
      "text": "왠지 낯설지 않았죠",
      "translation": "为何竟然让我感到如此习惯"
    },
    {
      "time": 56.76,
      "time_str": "00:56.760",
      "text": "하지만 약속된 인연이기에",
      "translation": "然而这一切都不过是约定好的因缘"
    },
    {
      "time": 64.42,
      "time_str": "01:04.420",
      "text": "사랑이 될 줄 몰랐죠",
      "translation": "谁料到竟然会真的陷入爱恋"
    },
    {
      "time": 70.35,
      "time_str": "01:10.350",
      "text": "조금 후면 그대, 보내야 할 텐데",
      "translation": "再过不久就要把你送走"
    },
    {
      "time": 77.59,
      "time_str": "01:17.590",
      "text": "그럴 자신이 없죠",
      "translation": "可是，我真的没自信能够做到"
    },
    {
      "time": 83.38,
      "time_str": "01:23.380",
      "text": "나홀로 있던 그 자리를 찾아",
      "translation": "我去寻找过去的自己"
    },
    {
      "time": 87.54,
      "time_str": "01:27.540",
      "text": "이제 돌아갈 뿐인데 당연한 일인데",
      "translation": "现在，就要恢复到过去的自己，这是理所当然的事情"
    },
    {
      "time": 94.59,
      "time_str": "01:34.590",
      "text": "왜 맘이 아프죠",
      "translation": "可为何心却在不停地作痛"
    },
    {
      "time": 97.47,
      "time_str": "01:37.470",
      "text": "그대 원하던 사랑을 찾아",
      "translation": "你要寻找你所希望的爱情"
    },
    {
      "time": 101.29,
      "time_str": "01:41.290",
      "text": "이제 돌아갈 뿐인데",
      "translation": "现在，就应该离去"
    },
    {
      "time": 104.76,
      "time_str": "01:44.760",
      "text": "행복할 그대를 웃으며 보내야 할텐데…",
      "translation": "…我应该微笑着送走即将得到幸福的你"
    },
    {
      "time": 117.08,
      "time_str": "01:57.080",
      "text": "내 눈을 보며 사랑을 말하죠",
      "translation": "可你为何却看着我的眼睛，对我诉说着爱恋"
    },
    {
      "time": 130.4,
      "time_str": "02:10.400",
      "text": "스쳐간 사랑이지만,",
      "translation": "虽然是已经逝去的爱"
    },
    {
      "time": 137.29,
      "time_str": "02:17.290",
      "text": "이 순간만은 너무 행복해요",
      "translation": "却在这一瞬间，觉得那么幸福"
    },
    {
      "time": 143.91,
      "time_str": "02:23.910",
      "text": "마치 꿈을 꾼 것 처럼",
      "translation": "仿佛是在做梦一样"
    },
    {
      "time": 147.57,
      "time_str": "02:27.570",
      "text": "이제야 알았어요",
      "translation": "终于明白了"
    },
    {
      "time": 151.39,
      "time_str": "02:31.390",
      "text": "처음부터 우린 사랑했었다는 걸",
      "translation": "我们是从一开始就爱上了对方"
    },
    {
      "time": 157.0,
      "time_str": "02:37.000",
      "text": "나홀로 있던 그 자리를 찾아",
      "translation": "我去寻找过去的自己"
    },
    {
      "time": 161.06,
      "time_str": "02:41.060",
      "text": "이제 돌아갈 뿐인데 당연한 일인데",
      "translation": "现在，就要恢复到过去的自己，这是理所当然的事情"
    },
    {
      "time": 168.19,
      "time_str": "02:48.190",
      "text": "왜 맘이 아프죠",
      "translation": "可为何心却在不停地作痛"
    },
    {
      "time": 171.22,
      "time_str": "02:51.220",
      "text": "그대 원하던 사랑을 찾아",
      "translation": "你要寻找你所希望的爱情"
    },
    {
      "time": 174.77,
      "time_str": "02:54.770",
      "text": "이제 돌아갈 뿐인데",
      "translation": "现在，就应该离去"
    },
    {
      "time": 178.52,
      "time_str": "02:58.520",
      "text": "행복할 그대를 웃으며 보내야할텐데..",
      "translation": "..我应该微笑着送走即将得到幸福的你"
    },
    {
      "time": 198.38,
      "time_str": "03:18.380",
      "text": "내게 사랑을 주면 안돼나요",
      "translation": "真的不可以爱上我么？"
    },
    {
      "time": 202.41,
      "time_str": "03:22.410",
      "text": "그대 정말 안돼나요",
      "translation": "你，真的不可以么？"
    },
    {
      "time": 206.07,
      "time_str": "03:26.070",
      "text": "이제 난 그대를 이토록 사랑하는데..",
      "translation": "..就算现在，我是这样地爱你..."
    }
  ],
