  "lyrics": [
    {
      "time": 17.69,
      "time_str": "00:17.690",
      "text": "床是我床",
      "translation": null
    },
    {
      "time": 19.86,
      "time_str": "00:19.860",
      "text": "但你的汗",
      "translation": null
    },
    {
      "time": 22.34,
      "time_str": "00:22.340",
      "text": "能令我这世界泛巨浪",
      "translation": null
    },
    {
      "time": 26.5,
      "time_str": "00:26.500",
      "text": "沉默脸庞",
      "translation": null
    },
    {
      "time": 28.8,
      "time_str": "00:28.800",
      "text": "像隔彼岸",
      "translation": null
    },
    {
      "time": 31.21,
      "time_str": "00:31.210",
      "text": "明白你永远拒绝",
      "translation": null
    },
    {
      "time": 34.62,
      "time_str": "00:34.620",
      "text": "属于这个地方",
      "translation": null
    },
    {
      "time": 44.63,
      "time_str": "00:44.630",
      "text": "怀着厚望",
      "translation": null
    },
    {
      "time": 46.72,
      "time_str": "00:46.720",
      "text": "定会失望",
      "translation": null
    },
    {
      "time": 49.09,
      "time_str": "00:49.090",
      "text": "其实这个说法我未忘",
      "translation": null
    },
    {
      "time": 53.39,
      "time_str": "00:53.390",
      "text": "情若太狂",
      "translation": null
    },
    {
      "time": 55.62,
      "time_str": "00:55.620",
      "text": "叫你怯慌",
      "translation": null
    },
    {
      "time": 58.29,
      "time_str": "00:58.290",
      "text": "然后我要背起这罪状",
      "translation": null
    },
    {
      "time": 62.83,
      "time_str": "01:02.830",
      "text": "连坐立亦会不安",
      "translation": null
    },
    {
      "time": 67.17,
      "time_str": "01:07.170",
      "text": "若然让欲念曝了光",
      "translation": null
    },
    {
      "time": 71.57,
      "time_str": "01:11.570",
      "text": "明日追忆都变得肮脏",
      "translation": null
    },
    {
      "time": 76.07,
      "time_str": "01:16.070",
      "text": "无谓勉强爱你去韬光",
      "translation": null
    },
    {
      "time": 82.08,
      "time_str": "01:22.080",
      "text": "不想唉声叹气",
      "translation": null
    },
    {
      "time": 84.24,
      "time_str": "01:24.240",
      "text": "陪你一起",
      "translation": null
    },
    {
      "time": 86.6,
      "time_str": "01:26.600",
      "text": "不想委屈了你",
      "translation": null
    },
    {
      "time": 88.75,
      "time_str": "01:28.750",
      "text": "为我医心理",
      "translation": null
    },
    {
      "time": 91.11,
      "time_str": "01:31.110",
      "text": "即使唉声叹气",
      "translation": null
    },
    {
      "time": 93.25,
      "time_str": "01:33.250",
      "text": "还要当趣味再没更卑微",
      "translation": null
    },
    {
      "time": 98.94,
      "time_str": "01:38.940",
      "text": "Oh No",
      "translation": null
    },
    {
      "time": 100.1,
      "time_str": "01:40.100",
      "text": "不想唉声叹气",
      "translation": null
    },
    {
      "time": 102.16,
      "time_str": "01:42.160",
      "text": "唯有心死",
      "translation": null
    },
    {
      "time": 104.56,
      "time_str": "01:44.560",
      "text": "不想委屈了我",
      "translation": null
    },
    {
      "time": 106.74,
      "time_str": "01:46.740",
      "text": "成了张三李四不敢唉声叹气",
      "translation": null
    },
    {
