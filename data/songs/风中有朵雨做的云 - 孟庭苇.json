    },
    {
      "time": 26.75,
      "time_str": "00:26.750",
      "text": "一朵雨做的云",
      "translation": null
    },
    {
      "time": 31.28,
      "time_str": "00:31.280",
      "text": "云的心里全都是雨",
      "translation": null
    },
    {
      "time": 36.46,
      "time_str": "00:36.460",
      "text": "滴滴全都是你",
