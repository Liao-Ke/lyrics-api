      "time": 9.14,
      "time_str": "00:09.140",
      "text": "当初相遇时回头在笑",
      "translation": null
    },
    {
      "time": 12.7,
      "time_str": "00:12.700",
      "text": "望着笑脸感觉像似首诗",
      "translation": null
    },
    {
      "time": 16.77,
      "time_str": "00:16.770",
      "text": "每次见他将心意合成字句",
      "translation": null
    },
    {
      "time": 20.85,
      "time_str": "00:20.850",
      "text": "偷偷的Say \"Hello\"",
      "translation": null
    },
    {
      "time": 22.74,
      "time_str": "00:22.740",
      "text": "如阳光伴我 清新笑迎面",
      "translation": null
    },
    {
      "time": 32.82,
      "time_str": "00:32.820",
      "text": "愿照遍我心 自视每天快乐过",
      "translation": null
    },
    {
      "time": 39.9,
      "time_str": "00:39.900",
      "text": "如阳光伴我 心中更明亮",
      "translation": null
    },
    {
      "time": 48.75,
      "time_str": "00:48.750",
      "text": "在细细说声 但愿每天也望见",
