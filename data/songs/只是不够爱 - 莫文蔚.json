    {
      "time": 1.343,
      "time_str": "00:01.343",
      "text": "还有什么不接受",
      "translation": null
    },
    {
      "time": 4.426,
      "time_str": "00:04.426",
      "text": "我也可以很成熟",
      "translation": null
    },
    {
      "time": 7.626,
      "time_str": "00:07.626",
      "text": "如果想放手",
      "translation": null
    },
    {
      "time": 10.179,
      "time_str": "00:10.179",
      "text": "就为你找借口",
      "translation": null
    },
    {
      "time": 13.798,
      "time_str": "00:13.798",
      "text": "不勉强挽留",
      "translation": null
    },
    {
      "time": 17.04,
      "time_str": "00:17.040",
      "text": "不假装愧疚",
      "translation": null
    },
    {
      "time": 20.062,
      "time_str": "00:20.062",
      "text": "你等待已久",
      "translation": null
    },
    {
      "time": 22.495,
      "time_str": "00:22.495",
      "text": "由我说出口",
      "translation": null
    },
    {
      "time": 26.414,
      "time_str": "00:26.414",
      "text": "是你不明白",
      "translation": null
    },
    {
      "time": 32.529,
      "time_str": "00:32.529",
      "text": "是你想不开",
      "translation": null
    },
    {
      "time": 38.492,
