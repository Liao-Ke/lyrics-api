  },
  "lyrics": [
    {
      "time": 4.437,
      "time_str": "00:04.437",
      "text": "演奏乐队：高速公路乐队",
      "translation": null
    },
    {
      "time": 14.61,
      "time_str": "00:14.610",
      "text": "站在狂风的天台一望无际",
      "translation": null
    },
    {
      "time": 20.61,
      "time_str": "00:20.610",
      "text": "这一座孤独的城市",
      "translation": null
    },
    {
      "time": 26.589,
      "time_str": "00:26.589",
      "text": "在天空与高楼交接的尽头",
      "translation": null
    },
    {
      "time": 33.9,
      "time_str": "00:33.900",
      "text": "谁追寻空旷的自由",
      "translation": null
    },
    {
      "time": 40.102,
      "time_str": "00:40.102",
      "text": "阳光覆满这一刻宁静的我",
      "translation": null
    },
    {
      "time": 46.535,
      "time_str": "00:46.535",
      "text": "隔绝了喧嚣和冷漠",
      "translation": null
    },
    {
      "time": 52.552,
      "time_str": "00:52.552",
      "text": "川流不息的人游荡在街头",
      "translation": null
    },
    {
      "time": 59.3,
      "time_str": "00:59.300",
      "text": "各自寻找心底的梦",
      "translation": null
    },
    {
      "time": 64.38,
      "time_str": "01:04.380",
      "text": "找一个梦紧紧相依",
      "translation": null
    },
    {
      "time": 67.981,
      "time_str": "01:07.981",
      "text": "找一颗心坚定不移",
      "translation": null
    },
    {
      "time": 71.481,
      "time_str": "01:11.481",
      "text": "在这个宇宙我是独一无二",
      "translation": null
    },
    {
      "time": 75.265,
      "time_str": "01:15.265",
      "text": "没人能取代",
      "translation": null
    },
    {
      "time": 77.365,
      "time_str": "01:17.365",
      "text": "不管怎样 怎样都会受伤",
      "translation": null
    },
    {
      "time": 81.666,
      "time_str": "01:21.666",
      "text": "伤了又怎样",
      "translation": null
    },
    {
      "time": 84.616,
      "time_str": "01:24.616",
      "text": "至少我很坚强 我很坦荡",
      "translation": null
    },
    {
      "time": 101.671,
      "time_str": "01:41.671",
      "text": "夜幕笼罩灿烂的一片灯海",
      "translation": null
    },
    {
      "time": 108.97,
      "time_str": "01:48.970",
      "text": "多少人多少种无奈",
      "translation": null
    },
    {
      "time": 114.203,
      "time_str": "01:54.203",
      "text": "在星光里遗忘昨天的伤害",
      "translation": null
    },
    {
      "time": 120.554,
      "time_str": "02:00.554",
      "text": "一觉醒来还有期待",
      "translation": null
    },
    {
      "time": 126.58,
      "time_str": "02:06.580",
      "text": "我不放弃梦想前进",
      "translation": null
    },
    {
      "time": 129.608,
      "time_str": "02:09.608",
      "text": "我不怀疑我的艰辛",
      "translation": null
    },
    {
      "time": 133.255,
      "time_str": "02:13.255",
      "text": "我要握住一个最美的梦",
      "translation": null
    },
    {
      "time": 136.255,
      "time_str": "02:16.255",
      "text": "给未来的自己",
      "translation": null
    },
    {
      "time": 138.907,
      "time_str": "02:18.907",
      "text": "一天一天 一天推翻一天",
      "translation": null
    },
    {
      "time": 143.384,
      "time_str": "02:23.384",
      "text": "坚持的信仰",
      "translation": null
    },
    {
      "time": 146.234,
      "time_str": "02:26.234",
      "text": "我会记住自己今天的模样",
      "translation": null
    },
    {
      "time": 152.24,
      "time_str": "02:32.240",
      "text": "有一颗心紧紧相依",
      "translation": null
    },
    {
      "time": 155.668,
      "time_str": "02:35.668",
      "text": "找一个梦紧紧坚信",
      "translation": null
    },
    {
      "time": 159.195,
      "time_str": "02:39.195",
      "text": "这个宇宙我是独一无二",
      "translation": null
    },
    {
      "time": 162.828,
      "time_str": "02:42.828",
      "text": "没人能取代",
      "translation": null
    },
    {
      "time": 164.928,
      "time_str": "02:44.928",
      "text": "不管怎样 怎样都会受伤",
      "translation": null
    },
    {
      "time": 169.319,
      "time_str": "02:49.319",
      "text": "伤了又怎样",
      "translation": null
    },
    {
      "time": 172.219,
      "time_str": "02:52.219",
      "text": "至少我很坚强 我很坦荡",
      "translation": null
    },
    {
      "time": 178.619,
      "time_str": "02:58.619",
      "text": "未来的你会懂 我的疯狂",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "给未来的自己 - 王祥如.lrc"
}