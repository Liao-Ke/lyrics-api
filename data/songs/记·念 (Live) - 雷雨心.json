      "text": "我们一起走过的光年",
      "translation": null
    },
    {
      "time": 115.59,
      "time_str": "01:55.590",
      "text": "我只想要拉住流年",
      "translation": null
    },
    {
      "time": 118.63,
      "time_str": "01:58.630",
      "text": "好好的说声再见",
      "translation": null
    },
    {
      "time": 120.79,
      "time_str": "02:00.790",
      "text": "在心中刻下你们的笑脸",
      "translation": null
    },
    {
      "time": 124.83,
      "time_str": "02:04.830",
      "text": "当流星划过天边",
      "translation": null
    },
    {
      "time": 128.37,
      "time_str": "02:08.370",
      "text": "许下我们的心愿",
      "translation": null
    },
    {
      "time": 133.3,
      "time_str": "02:13.300",
      "text": "让现在成为永远",
      "translation": null
    },
    {
      "time": 141.63,
      "time_str": "02:21.630",
      "text": "永远 永远",
