  "lyrics": [
    {
      "time": 9.79,
      "time_str": "00:09.790",
      "text": "时间一转眼就过去了三年",
      "translation": null
    },
    {
      "time": 14.08,
      "time_str": "00:14.080",
      "text": "一切在我心里开的好皎洁",
      "translation": null
    },
    {
      "time": 18.48,
      "time_str": "00:18.480",
      "text": "现在倒计时也不剩几天",
      "translation": null
    },
    {
      "time": 22.55,
      "time_str": "00:22.550",
      "text": "脚边的纸片",
      "translation": null
    },
    {
      "time": 24.78,
      "time_str": "00:24.780",
      "text": "来不及去捡",
      "translation": null
    },
    {
      "time": 27.08,
      "time_str": "00:27.080",
      "text": "仿佛是快要冲破压力的茧",
      "translation": null
    },
    {
      "time": 31.47,
      "time_str": "00:31.470",
      "text": "离校后大家又各自熬夜",
      "translation": null
    },
    {
      "time": 35.92,
      "time_str": "00:35.920",
      "text": "早上的黑眼圈",
      "translation": null
    },
    {
      "time": 38.06,
      "time_str": "00:38.060",
      "text": "课上的小困倦",
      "translation": null
    },
    {
      "time": 40.31,
      "time_str": "00:40.310",
      "text": "一天一天又一天",
      "translation": null
    },
    {
      "time": 45.98,
      "time_str": "00:45.980",
      "text": "我只想要拉住流年",
      "translation": null
    },
    {
      "time": 48.98,
      "time_str": "00:48.980",
      "text": "好好的说声再见",
      "translation": null
    },
    {
      "time": 51.18,
      "time_str": "00:51.180",
      "text": "遗憾感谢都回不去昨天",
      "translation": null
    },
    {
      "time": 54.98,
      "time_str": "00:54.980",
      "text": "我只想铭记这瞬间",
      "translation": null
    },
    {
      "time": 58.61,
      "time_str": "00:58.610",
      "text": "我们一起走过的光年",
      "translation": null
    },
    {
      "time": 64.31,
      "time_str": "01:04.310",
      "text": "六月后 光年成纪念",
      "translation": null
    },
    {
      "time": 76.47,
      "time_str": "01:16.470",
      "text": "这个班级太傲娇",
      "translation": null
    },
    {
      "time": 78.52,
      "time_str": "01:18.520",
      "text": "什么课都不发言",
      "translation": null
    },
    {
      "time": 80.6,
      "time_str": "01:20.600",
      "text": "但是还是很温暖",
      "translation": null
    },
    {
      "time": 83.06,
      "time_str": "01:23.060",
      "text": "同学之间的寒暄",
      "translation": null
    },
    {
      "time": 85.86,
      "time_str": "01:25.860",
      "text": "压着课本抄作业",
      "translation": null
    },
    {
      "time": 87.97,
      "time_str": "01:27.970",
      "text": "考试上的看一眼",
      "translation": null
    },
    {
      "time": 90.1,
      "time_str": "01:30.100",
      "text": "现在想起来",
      "translation": null
    },
    {
      "time": 91.27,
      "time_str": "01:31.270",
      "text": "会不会觉得很亲切",
      "translation": null
    },
    {
      "time": 97.83,
      "time_str": "01:37.830",
      "text": "我只想要拉住流年",
      "translation": null
    },
    {
      "time": 101.09,
      "time_str": "01:41.090",
      "text": "好好的说声再见",
      "translation": null
    },
    {
      "time": 103.55,
      "time_str": "01:43.550",
      "text": "遗憾感谢都回不去昨天",
