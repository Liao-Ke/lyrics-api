      "time": 2.445,
      "time_str": "00:02.445",
      "text": "恩赐",
      "translation": null
    },
    {
      "time": 15.946,
      "time_str": "00:15.946",
      "text": "录音、混音：陈绍楠",
      "translation": null
    },
    {
      "time": 18.944,
      "time_str": "00:18.944",
      "text": "车厢里再留下回忆",
      "translation": null
    },
    {
      "time": 23.446,
      "time_str": "00:23.446",
      "text": "偷偷看你扮诈不知",
      "translation": null
    },
    {
      "time": 27.442,
      "time_str": "00:27.442",
      "text": "幻想与你再度旅行",
      "translation": null
    },
    {
      "time": 31.196,
      "time_str": "00:31.196",
      "text": "沿路风景美丽画致",
      "translation": null
    },
    {
      "time": 35.455,
      "time_str": "00:35.455",
      "text": "也许荆棘路途经已",
      "translation": null
    },
    {
      "time": 39.198,
      "time_str": "00:39.198",
      "text": "相信世界定有天意",
      "translation": null
    },
    {
      "time": 43.457,
      "time_str": "00:43.457",
      "text": "春风化雨世间讽刺",
      "translation": null
    },
    {
      "time": 47.192,
      "time_str": "00:47.192",
      "text": "再怎么 都感动恩赐",
      "translation": null
    },
    {
      "time": 54.951,
      "time_str": "00:54.951",
      "text": "也许天天生活常变",
      "translation": null
    },
    {
      "time": 59.452,
      "time_str": "00:59.452",
      "text": "亲亲爱你胜过万语千言",
      "translation": null
    },
    {
      "time": 63.449,
      "time_str": "01:03.449",
      "text": "年月逝去都不紧要",
      "translation": null
    },
    {
      "time": 67.454,
      "time_str": "01:07.454",
      "text": "常伴开心好运不止",
      "translation": null
    },
    {
      "time": 71.449,
      "time_str": "01:11.449",
      "text": "地冧天崩岁月常变",
      "translation": null
    },
    {
      "time": 75.195,
      "time_str": "01:15.195",
      "text": "星空斗转仍永久保存",
      "translation": null
    },
    {
      "time": 79.2,
      "time_str": "01:19.200",
      "text": "期待与你再续情缘",
      "translation": null
    },
    {
