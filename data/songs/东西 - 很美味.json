  "lyrics": [
    {
      "time": 11.662,
      "time_str": "00:11.662",
      "text": "收到需要赶快回复的信息",
      "translation": null
    },
    {
      "time": 14.988,
      "time_str": "00:14.988",
      "text": "那就考虑看看是不是要回应你",
      "translation": null
    },
    {
      "time": 17.831,
      "time_str": "00:17.831",
      "text": "如果说以后都不用对你讲客气",
      "translation": null
    },
    {
      "time": 20.667,
      "time_str": "00:20.667",
      "text": "我就等着对你说一句欢迎光临",
      "translation": null
    },
    {
      "time": 23.96,
      "time_str": "00:23.960",
      "text": "在无人的海岛上有美丽风景",
      "translation": null
    },
    {
      "time": 26.504,
      "time_str": "00:26.504",
      "text": "想有梦里的竹蜻蜓带我去远行",
      "translation": null
    },
    {
      "time": 28.988,
      "time_str": "00:28.988",
      "text": "去到你心里的那个神秘的巴黎",
      "translation": null
    },
    {
      "time": 32.366,
      "time_str": "00:32.366",
      "text": "再想和你生一群baby",
      "translation": null
    },
    {
      "time": 34.502,
      "time_str": "00:34.502",
      "text": "我开始美丽的际遇",
      "translation": null
    },
    {
      "time": 37.782,
      "time_str": "00:37.782",
      "text": "你来自东或西",
      "translation": null
    },
    {
      "time": 40.132,
      "time_str": "00:40.132",
      "text": "都没有太大的关系",
      "translation": null
    },
    {
      "time": 43.14,
      "time_str": "00:43.140",
      "text": "都听你",
      "translation": null
    },
    {
      "time": 45.941,
      "time_str": "00:45.941",
      "text": "因为始终和你前进",
      "translation": null
    },
    {
      "time": 49.42,
      "time_str": "00:49.420",
      "text": "回忆并肩旅行",
      "translation": null
    },
    {
      "time": 52.348,
      "time_str": "00:52.348",
      "text": "我愿意陪着你去东和西",
      "translation": null
    },
    {
