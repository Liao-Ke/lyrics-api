    {
      "time": 23.321,
      "time_str": "00:23.321",
      "text": "因为梦见你离开",
      "translation": null
    },
    {
      "time": 27.616,
      "time_str": "00:27.616",
      "text": "我从哭泣中醒来",
      "translation": null
    },
    {
      "time": 32.403,
      "time_str": "00:32.403",
      "text": "看夜风吹过窗台",
      "translation": null
    },
    {
      "time": 36.026,
      "time_str": "00:36.026",
      "text": "你能否感受我的爱",
      "translation": null
    },
    {
      "time": 42.294,
      "time_str": "00:42.294",
      "text": "等到老去那一天",
      "translation": null
    },
    {
      "time": 46.819,
      "time_str": "00:46.819",
      "text": "你是否还在我身边",
      "translation": null
    },
    {
      "time": 51.546,
      "time_str": "00:51.546",
      "text": "看那些誓言谎言",
      "translation": null
    },
    {
      "time": 55.166,
      "time_str": "00:55.166",
      "text": "随往事慢慢飘散",
      "translation": null
    },
    {
      "time": 63.051,
      "time_str": "01:03.051",
      "text": "多少人曾爱慕你年轻时的容颜",
