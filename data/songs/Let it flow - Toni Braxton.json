    {
      "time": 35.33,
      "time_str": "00:35.330",
      "text": "First thing early monday morning",
      "translation": "星期一早晨的第一件事"
    },
    {
      "time": 38.3,
      "time_str": "00:38.300",
      "text": "I'm gonna pack my tears away",
      "translation": "我要收起我的眼泪"
    },
    {
