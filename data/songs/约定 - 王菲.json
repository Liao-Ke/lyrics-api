  "lyrics": [
    {
      "time": 32.59,
      "time_str": "00:32.590",
      "text": "还记得当天旅馆的门牌",
      "translation": null
    },
    {
      "time": 39.15,
      "time_str": "00:39.150",
      "text": "还留住笑着离开的神态",
      "translation": null
    },
    {
      "time": 45.59,
      "time_str": "00:45.590",
      "text": "当天整个城市 那样轻快",
      "translation": null
    },
    {
      "time": 51.11,
      "time_str": "00:51.110",
      "text": "沿路一起走半里长街",
      "translation": null
    },
    {
      "time": 57.28,
      "time_str": "00:57.280",
      "text": "还记得街灯照出一脸黄",
      "translation": null
    },
    {
      "time": 63.05,
      "time_str": "01:03.050",
      "text": "还燃亮那份微温的便当",
      "translation": null
    },
    {
      "time": 69.49,
      "time_str": "01:09.490",
      "text": "剪影的你轮廓太好看",
      "translation": null
    },
    {
      "time": 74.59,
      "time_str": "01:14.590",
      "text": "凝住眼泪才敢细看",
      "translation": null
    },
    {
      "time": 83.77,
      "time_str": "01:23.770",
      "text": "忘掉天地 仿佛也想不起自己",
      "translation": null
    },
    {
      "time": 89.71,
      "time_str": "01:29.710",
      "text": "仍未忘相约看漫天黄叶远飞",
      "translation": null
    },
    {
      "time": 96.23,
      "time_str": "01:36.230",
      "text": "就算会与你分离 凄绝的戏",
      "translation": null
    },
    {
      "time": 101.54,
      "time_str": "01:41.540",
      "text": "要决心忘记我便记不起",
      "translation": null
    },
    {
      "time": 107.67,
      "time_str": "01:47.670",
      "text": "明日天地 只恐怕认不出自己",
      "translation": null
    },
    {
      "time": 113.65,
      "time_str": "01:53.650",
      "text": "仍未忘跟你约定假如没有死",
      "translation": null
    },
    {
      "time": 120.16,
      "time_str": "02:00.160",
      "text": "就算你壮阔胸膛 不敌天气",
      "translation": null
    },
    {
      "time": 126.14,
      "time_str": "02:06.140",
      "text": "两鬓斑白都可认得你",
      "translation": null
    },
    {
      "time": 158.78,
      "time_str": "02:38.780",
      "text": "还记得当天吉他的和弦",
      "translation": null
    },
    {
      "time": 165.11,
      "time_str": "02:45.110",
      "text": "还明白每段旋律的伏线",
      "translation": null
    },
    {
      "time": 171.47,
      "time_str": "02:51.470",
      "text": "当天街角流过你声线",
      "translation": null
    },
    {
      "time": 176.69,
      "time_str": "02:56.690",
      "text": "沿路旅程如歌褪变",
      "translation": null
    },
    {
      "time": 185.79,
      "time_str": "03:05.790",
      "text": "忘掉天地 仿佛也想不起自己",
