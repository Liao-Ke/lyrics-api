{
  "title": "我们都一样",
  "title_raw": "我们都一样",
  "version": null,
  "artist": "张杰",
  "group_key": "我们都一样|张杰",
  "writers": {
    "lyricist": "苟庆/曹轩宾",
    "composer": "曹轩宾",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 17.4,
      "time_str": "00:17.400",
      "text": "推开窗看见星星 依然守在夜空中",
      "translation": null
    },
    {
      "time": 24.99,
      "time_str": "00:24.990",
      "text": "心中不免多了些暖暖的感动",
      "translation": null
    },
    {
      "time": 33.49,
      "time_str": "00:33.490",
      "text": "一闪一闪的光 努力把黑夜点亮",
      "translation": null
    },
    {
      "time": 42.44,
      "time_str": "00:42.440",
      "text": "气氛如此安详",
      "translation": null
    },
    {
      "time": 49.17,
      "time_str": "00:49.170",
      "text": "你在我的生命中 是那最闪亮的星",
      "translation": null
    },
    {
      "time": 57.16,
      "time_str": "00:57.160",
      "text": "一直在无声夜空 守护着我们的梦",
      "translation": null
    },
    {
      "time": 65.42,
      "time_str": "01:05.420",
      "text": "这世界那么大",
      "translation": null
    },
    {
      "time": 69.47,
      "time_str": "01:09.470",
      "text": "我的爱只想要你懂 陪伴我无尽旅程",
      "translation": null
    },
    {
      "time": 80.56,
      "time_str": "01:20.560",
      "text": "你知道我的梦 你知道我的痛",
      "translation": null
    },
    {
      "time": 84.31,
      "time_str": "01:24.310",
      "text": "你知道我们感受都相同",
      "translation": null
    },
    {
      "time": 88.2,
      "time_str": "01:28.200",
      "text": "就算有再大的风 也挡不住勇敢的冲动",
      "translation": null
    },
    {
      "time": 96.27,
      "time_str": "01:36.270",
      "text": "努力的往前飞 再累也无所谓",
      "translation": null
    },
    {
      "time": 100.11,
      "time_str": "01:40.110",
      "text": "黑夜过后的光芒有多美",
      "translation": null
    },
    {
      "time": 104.22,
      "time_str": "01:44.220",
      "text": "分享你我的力量 就能把对方的路照亮",
      "translation": null
    },
    {
      "time": 129.07,
      "time_str": "02:09.070",
      "text": "我想我们都一样",
      "translation": null
    },
    {
      "time": 132.32,
      "time_str": "02:12.320",
      "text": "渴望梦想的光芒",
      "translation": null
    },
    {
      "time": 137.43,
      "time_str": "02:17.430",
      "text": "这一路喜悦彷徨",
      "translation": null
    },
    {
      "time": 140.25,
      "time_str": "02:20.250",
      "text": "不要轻易说失望",
      "translation": null
    },
    {
      "time": 145.62,
      "time_str": "02:25.620",
      "text": "回到最初时光",
      "translation": null
    },
    {
      "time": 149.62,
      "time_str": "02:29.620",
      "text": "当时的你多么坚强",
      "translation": null
    },
    {
      "time": 154.77,
      "time_str": "02:34.770",
      "text": "那鼓励让我难忘",
      "translation": null
    },
    {
      "time": 160.54,
      "time_str": "02:40.540",
      "text": "你知道我的梦 你知道我的痛",
      "translation": null
