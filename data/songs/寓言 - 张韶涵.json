    {
      "time": 34.07,
      "time_str": "00:34.070",
      "text": "我逛到这条热闹的街",
      "translation": null
    },
    {
      "time": 38.06,
      "time_str": "00:38.060",
      "text": "太阳晒得我有点累",
      "translation": null
    },
    {
      "time": 40.61,
      "time_str": "00:40.610",
      "text": "奇怪最近我爱碎碎念",
      "translation": null
    },
    {
      "time": 42.93,
      "time_str": "00:42.930",
      "text": "但又觉得 I Don't Care",
      "translation": null
    },
    {
      "time": 45.43,
      "time_str": "00:45.430",
      "text": "我站在喜怒哀乐面前",
      "translation": null
    },
    {
      "time": 47.71,
      "time_str": "00:47.710",
      "text": "阅读我下一个画面",
      "translation": null
    },
    {
      "time": 50.59,
      "time_str": "00:50.590",
      "text": "我想去冒险",
      "translation": null
    },
    {
      "time": 51.12,
      "time_str": "00:51.120",
      "text": "不管一路多危险",
      "translation": null
    },
    {
      "time": 52.59,
      "time_str": "00:52.590",
      "text": "Na Na Na Na Na",
      "translation": null
    },
    {
      "time": 55.03,
      "time_str": "00:55.030",
      "text": "我期待童话般的爱情",
      "translation": null
    },
    {
      "time": 57.34,
      "time_str": "00:57.340",
      "text": "却不想那样的绝对",
      "translation": null
    },
    {
      "time": 59.8,
      "time_str": "00:59.800",
      "text": "给我一个大大的拥抱",
      "translation": null
    },
    {
