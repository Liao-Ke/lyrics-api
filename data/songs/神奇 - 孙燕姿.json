  "lyrics": [
    {
      "time": 41.69,
      "time_str": "00:41.690",
      "text": "就在一瞬间 我们两人眼前",
      "translation": null
    },
    {
      "time": 44.12,
      "time_str": "00:44.120",
      "text": "一道光出现 到了另个世界",
      "translation": null
    },
    {
      "time": 46.43,
      "time_str": "00:46.430",
      "text": "眉中间 有个红点",
      "translation": null
    },
    {
      "time": 48.92,
      "time_str": "00:48.920",
      "text": "头纱遮住脸",
      "translation": null
    },
    {
      "time": 61.34,
      "time_str": "01:01.340",
      "text": "好像每个人 都有特別气味",
      "translation": null
    },
    {
      "time": 63.62,
      "time_str": "01:03.620",
      "text": "闻了才发现 那是咖哩作祟",
      "translation": null
    },
    {
      "time": 66.06,
      "time_str": "01:06.060",
      "text": "恒河水 菩提树叶",
      "translation": null
    },
    {
      "time": 68.52,
      "time_str": "01:08.520",
      "text": "古老的情节",
      "translation": null
    },
    {
      "time": 70.96,
      "time_str": "01:10.960",
      "text": "时间在倒回",
      "translation": null
    },
    {
      "time": 73.48,
      "time_str": "01:13.480",
      "text": "我们俩 穿着布纱",
      "translation": null
    },
    {
      "time": 74.31,
      "time_str": "01:14.310",
      "text": "听着梵乐",
      "translation": null
    },
    {
      "time": 74.95,
      "time_str": "01:14.950",
      "text": "还想着 是幻觉",
      "translation": null
    },
    {
      "time": 76.27,
      "time_str": "01:16.270",
      "text": "奇怪的语言",
      "translation": null
    },
    {
      "time": 78.36,
      "time_str": "01:18.360",
      "text": "催着我 快快起舞",
      "translation": null
    },
    {
      "time": 79.32,
      "time_str": "01:19.320",
      "text": "碎碎念啊念",
      "translation": null
    },
    {
      "time": 90.67,
      "time_str": "01:30.670",
      "text": "时空换换换",
      "translation": null
    },
    {
      "time": 91.76,
      "time_str": "01:31.760",
      "text": "分割的画面",
      "translation": null
    },
    {
      "time": 93.07,
      "time_str": "01:33.070",
      "text": "轮回转转转",
      "translation": null
    },
    {
      "time": 94.15,
      "time_str": "01:34.150",
      "text": "有一样的信念",
      "translation": null
    },
    {
      "time": 95.96,
      "time_str": "01:35.960",
      "text": "我的爱 从古代",
      "translation": null
    },
    {
      "time": 98.33,
      "time_str": "01:38.330",
      "text": "和你回来",
      "translation": null
    },
    {
      "time": 100.22,
      "time_str": "01:40.220",
      "text": "时空换换换",
      "translation": null
    },
    {
      "time": 101.42,
      "time_str": "01:41.420",
      "text": "你回到过去",
      "translation": null
    },
    {
      "time": 102.81,
      "time_str": "01:42.810",
      "text": "轮回转转转",
      "translation": null
    },
    {
      "time": 103.97,
      "time_str": "01:43.970",
      "text": "我经历了悲喜",
      "translation": null
    },
    {
      "time": 105.44,
      "time_str": "01:45.440",
      "text": "好神奇",
      "translation": null
    },
