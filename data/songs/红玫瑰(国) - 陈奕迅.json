  "lyrics": [
    {
      "time": 16.27,
      "time_str": "00:16.270",
      "text": "梦里梦到醒不来的梦",
      "translation": null
    },
    {
      "time": 18.82,
      "time_str": "00:18.820",
      "text": "红线里被软禁的红",
      "translation": null
    },
    {
      "time": 23.74,
      "time_str": "00:23.740",
      "text": "所有刺激剩下疲乏的痛",
      "translation": null
    },
    {
      "time": 26.85,
      "time_str": "00:26.850",
      "text": "再无动于衷",
      "translation": null
    },
    {
      "time": 30.31,
      "time_str": "00:30.310",
      "text": "从背后抱你的时候",
      "translation": null
    },
    {
      "time": 34.02,
      "time_str": "00:34.020",
      "text": "期待的却是她的面容",
      "translation": null
    },
    {
      "time": 37.83,
      "time_str": "00:37.830",
      "text": "说来实在嘲讽",
      "translation": null
    },
    {
      "time": 40.09,
      "time_str": "00:40.090",
      "text": "我不太懂",
      "translation": null
    },
    {
      "time": 41.34,
      "time_str": "00:41.340",
      "text": "偏渴望你懂",
      "translation": null
    },
    {
      "time": 44.85,
      "time_str": "00:44.850",
      "text": "是否幸福轻得太沉重",
      "translation": null
    },
    {
      "time": 48.61,
      "time_str": "00:48.610",
      "text": "过度使用不痒不痛",
      "translation": null
    },
    {
      "time": 52.32,
      "time_str": "00:52.320",
      "text": "烂熟透红",
      "translation": null
    },
    {
      "time": 54.03,
      "time_str": "00:54.030",
      "text": "空洞了的瞳孔",
      "translation": null
    },
    {
      "time": 56.63,
      "time_str": "00:56.630",
      "text": "终于掏空",
      "translation": null
    },
    {
      "time": 57.48,
      "time_str": "00:57.480",
      "text": "终于有始无终",
      "translation": null
    },
    {
      "time": 59.84,
      "time_str": "00:59.840",
      "text": "得不到的永远在骚动",
      "translation": null
    },
    {
      "time": 63.54,
      "time_str": "01:03.540",
      "text": "被偏爱的",
      "translation": null
    },
    {
      "time": 65.31,
      "time_str": "01:05.310",
      "text": "都有恃无恐",
      "translation": null
    },
    {
      "time": 67.41,
      "time_str": "01:07.410",
      "text": "玫瑰的红",
      "translation": null
