    {
      "time": 32.63,
      "time_str": "00:32.630",
      "text": "格桑花开那一朵朵",
      "translation": null
    },
    {
      "time": 36.63,
      "time_str": "00:36.630",
      "text": "（好像那天边的云彩哟）",
      "translation": null
    },
    {
      "time": 40.36,
      "time_str": "00:40.360",
      "text": "贡嘎山头那云飘过",
      "translation": null
    },
    {
      "time": 44.08,
      "time_str": "00:44.080",
      "text": "（好像那飞来的白天鹅）",
      "translation": null
    },
    {
      "time": 47.73,
      "time_str": "00:47.730",
      "text": "美丽善良姑娘卓玛",
      "translation": null
    },
    {
      "time": 51.41,
      "time_str": "00:51.410",
      "text": "她是天上吉祥菩萨",
      "translation": null
    },
    {
      "time": 55.26,
      "time_str": "00:55.260",
      "text": "带着善良的一颗心",
      "translation": null
    },
    {
      "time": 58.83,
      "time_str": "00:58.830",
      "text": "（从此呀我们就不害怕）",
      "translation": null
    },
