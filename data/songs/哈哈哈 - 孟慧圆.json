      "time": 15.883,
      "time_str": "00:15.883",
      "text": "亲爱的我们还不懂得什么是爱情",
      "translation": null
    },
    {
      "time": 19.826,
      "time_str": "00:19.826",
      "text": "但心里却不停的惦记你",
      "translation": null
    },
    {
      "time": 23.841,
      "time_str": "00:23.841",
      "text": "傻傻的我们还是以为这就是爱情",
      "translation": null
    },
    {
      "time": 27.659,
      "time_str": "00:27.659",
      "text": "把好的留下坏的都给你",
      "translation": null
    },
    {
      "time": 31.975,
      "time_str": "00:31.975",
      "text": "经常梦见你",
      "translation": null
    },
    {
      "time": 33.882,
      "time_str": "00:33.882",
      "text": "也不管星期几",
      "translation": null
    },
    {
      "time": 35.692,
