  "lyrics": [
    {
      "time": 22.797,
      "time_str": "00:22.797",
      "text": "如果痴痴的等某日",
      "translation": null
    },
    {
      "time": 25.149,
      "time_str": "00:25.149",
      "text": "终于可等到一生中最爱",
      "translation": null
    },
    {
      "time": 30.641,
      "time_str": "00:30.641",
      "text": "谁介意你我这段情",
      "translation": null
    },
    {
      "time": 32.795,
      "time_str": "00:32.795",
      "text": "每每碰上了意外",
      "translation": null
    },
    {
      "time": 34.657,
      "time_str": "00:34.657",
      "text": "不清楚未来",
      "translation": null
    },
    {
      "time": 37.988,
      "time_str": "00:37.988",
      "text": "何曾愿意 我心中所爱",
      "translation": null
    },
    {
      "time": 46.584,
      "time_str": "00:46.584",
      "text": "每天要孤单看海",
      "translation": null
    },
    {
      "time": 53.535,
      "time_str": "00:53.535",
      "text": "宁愿一生都不说话",
      "translation": null
    },
    {
      "time": 55.623,
      "time_str": "00:55.623",
      "text": "都不想讲假说话欺骗你",
      "translation": null
    },
    {
      "time": 61.138,
      "time_str": "01:01.138",
      "text": "留意到你我这段情",
      "translation": null
    },
    {
      "time": 63.254,
      "time_str": "01:03.254",
      "text": "你会发觉间隔着一点点距离",
      "translation": null
    },
    {
      "time": 68.516,
      "time_str": "01:08.516",
      "text": "无言地爱 我偏不敢说",
      "translation": null
    },
    {
      "time": 77.075,
      "time_str": "01:17.075",
      "text": "说一句想跟你一起",
      "translation": null
    },
    {
      "time": 83.624,
      "time_str": "01:23.624",
      "text": "WOOH...OH...",
      "translation": null
    },
    {
      "time": 87.72,
      "time_str": "01:27.720",
      "text": "如真如假",
      "translation": null
    },
    {
      "time": 91.58,
      "time_str": "01:31.580",
      "text": "如可分身饰演自己",
      "translation": null
    },
    {
      "time": 95.452,
      "time_str": "01:35.452",
      "text": "会将心中的温柔",
      "translation": null
    },
    {
      "time": 97.556,
      "time_str": "01:37.556",
      "text": "献出给你唯有的知己",
      "translation": null
    },
    {
      "time": 103.06,
      "time_str": "01:43.060",
      "text": "如痴如醉",
      "translation": null
    },
    {
      "time": 106.826,
      "time_str": "01:46.826",
      "text": "还盼你懂珍惜自己",
      "translation": null
    },
    {
      "time": 110.669,
      "time_str": "01:50.669",
      "text": "有天即使分离我都想你",
      "translation": null
    },
    {
      "time": 114.762,
      "time_str": "01:54.762",
      "text": "我真的想你",
      "translation": null
    },
    {
