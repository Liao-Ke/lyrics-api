    {
      "time": 30.86,
      "time_str": "00:30.860",
      "text": "女：",
      "translation": null
    },
    {
      "time": 32.55,
      "time_str": "00:32.550",
      "text": "昨天那缠绵",
      "translation": null
    },
    {
      "time": 35.3,
      "time_str": "00:35.300",
      "text": "孤独静静摆一边",
      "translation": null
    },
    {
      "time": 39.54,
      "time_str": "00:39.540",
      "text": "云朵把天空装点",
      "translation": null
    },
    {
      "time": 42.39,
      "time_str": "00:42.390",
      "text": "变幻成你的脸噢",
      "translation": null
    },
    {
      "time": 46.82,
      "time_str": "00:46.820",
      "text": "难道这是失恋",
      "translation": null
    },
    {
      "time": 49.98,
      "time_str": "00:49.980",
      "text": "的确什么都不想干",
      "translation": null
    },
    {
      "time": 54.63,
      "time_str": "00:54.630",
      "text": "懦弱这词太打眼",
      "translation": null
    },
    {
      "time": 60.69,
      "time_str": "01:00.690",
      "text": "一个人走在街头",
      "translation": null
    },
    {
      "time": 64.17,
      "time_str": "01:04.170",
      "text": "想着温柔的某某某",
      "translation": null
    },
    {
      "time": 67.75,
      "time_str": "01:07.750",
      "text": "她还住在这星球",
      "translation": null
    },
    {
      "time": 70.76,
      "time_str": "01:10.760",
      "text": "但我被遗漏",
      "translation": null
    },
    {
      "time": 73.24,
      "time_str": "01:13.240",
      "text": "男：",
      "translation": null
    },
    {
      "time": 74.76,
      "time_str": "01:14.760",
      "text": "你离开了我",
      "translation": null
    },
    {
      "time": 76.61,
      "time_str": "01:16.610",
      "text": "还附送折磨",
      "translation": null
    },
    {
      "time": 78.44,
      "time_str": "01:18.440",
      "text": "只有天晓得我该怎么做",
      "translation": null
    },
    {
      "time": 82.37,
      "time_str": "01:22.370",
      "text": "女：",
      "translation": null
    },
    {
      "time": 82.92,
      "time_str": "01:22.920",
      "text": "痴情这种罪过",
      "translation": null
    },
    {
      "time": 86.7,
      "time_str": "01:26.700",
      "text": "我一直都不能挣脱",
      "translation": null
    },
    {
      "time": 89.47,
      "time_str": "01:29.470",
      "text": "男：",
      "translation": null
    },
    {
      "time": 89.51,
      "time_str": "01:29.510",
      "text": "你离开了我还附送折磨",
      "translation": null
    },
    {
      "time": 93.22,
      "time_str": "01:33.220",
      "text": "只有天晓得我该怎么做",
      "translation": null
    },
    {
      "time": 97.39,
      "time_str": "01:37.390",
      "text": "女：",
      "translation": null
    },
    {
      "time": 97.86,
      "time_str": "01:37.860",
      "text": "心已不知下落",
      "translation": null
    },
    {
      "time": 101.06,
      "time_str": "01:41.060",
      "text": "怎样找回单纯的我",
      "translation": null
    },
    {
      "time": 105.71,
      "time_str": "01:45.710",
      "text": "倔强的你遇上倔强的我",
      "translation": null
    },
    {
      "time": 108.48,
      "time_str": "01:48.480",
      "text": "矛盾从来没有停止过",
      "translation": null
    },
    {
      "time": 110.13,
      "time_str": "01:50.130",
      "text": "从来没有想象分手的结果",
      "translation": null
    },
    {
      "time": 112.74,
      "time_str": "01:52.740",
      "text": "多想老去还是牵着你的手",
      "translation": null
    },
    {
      "time": 116.7,
      "time_str": "01:56.700",
      "text": "你说愿意为我妥协",
      "translation": null
    },
    {
      "time": 118.29,
      "time_str": "01:58.290",
      "text": "并停留直到生命的最后",
      "translation": null
    },
