  "lyrics": [
    {
      "time": 24.589,
      "time_str": "00:24.589",
      "text": "如果分手 是你给的回答",
      "translation": null
    },
    {
      "time": 28.829,
      "time_str": "00:28.829",
      "text": "难道注定 就这样了吗",
      "translation": null
    },
    {
      "time": 32.849,
      "time_str": "00:32.849",
      "text": "我的心啊 痛的无法自拔",
      "translation": null
    },
    {
      "time": 36.659,
      "time_str": "00:36.659",
      "text": "可是有谁能明白啊",
      "translation": null
    },
    {
      "time": 41.139,
      "time_str": "00:41.139",
      "text": "送你的花 你已丢掉了吧",
      "translation": null
    },
    {
      "time": 45.329,
      "time_str": "00:45.329",
      "text": "刺痛的心 还在不断挣扎",
      "translation": null
    },
    {
      "time": 49.449,
      "time_str": "00:49.449",
      "text": "回忆过去 那些你说的话",
      "translation": null
    },
    {
      "time": 53.639,
      "time_str": "00:53.639",
      "text": "事到如今还在牵挂",
      "translation": null
    },
    {
      "time": 59.259,
      "time_str": "00:59.259",
      "text": "眼泪啊不停的落下啊",
      "translation": null
    },
    {
      "time": 67.569,
      "time_str": "01:07.569",
      "text": "不相信就不要再犯傻",
      "translation": null
    },
    {
      "time": 75.619,
      "time_str": "01:15.619",
      "text": "为何我苦苦挽留还是不能把你留下",
      "translation": null
    },
    {
      "time": 80.219,
      "time_str": "01:20.219",
      "text": "是不是你心里早已有个他",
      "translation": null
    },
    {
      "time": 84.399,
      "time_str": "01:24.399",
      "text": "你让我彻底把你忘了吧",
      "translation": null
    },
    {
      "time": 88.159,
      "time_str": "01:28.159",
      "text": "可是叫我怎么放得下",
      "translation": null
    },
    {
      "time": 92.239,
      "time_str": "01:32.239",
      "text": "为何我苦苦挽留还是不能把你留下",
      "translation": null
    },
    {
      "time": 96.539,
      "time_str": "01:36.539",
      "text": "难道真心付出换来一道伤疤",
      "translation": null
    },
    {
      "time": 100.869,
      "time_str": "01:40.869",
      "text": "给你的爱你真的忘了吗",
      "translation": null
    },
    {
      "time": 105.29,
      "time_str": "01:45.290",
      "text": "你怎么狠心把我 推入悬崖",
      "translation": null
