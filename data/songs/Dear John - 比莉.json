      "text": "铃声响 dear john",
      "translation": null
    },
    {
      "time": 29.49,
      "time_str": "00:29.490",
      "text": "在电话那头",
      "translation": null
    },
    {
      "time": 31.0,
      "time_str": "00:31.000",
      "text": "你说话很温柔",
      "translation": null
    },
    {
      "time": 32.56,
      "time_str": "00:32.560",
      "text": "像一颗石头",
      "translation": null
    },
    {
      "time": 34.36,
