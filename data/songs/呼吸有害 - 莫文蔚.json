{
  "title": "呼吸有害",
  "title_raw": "呼吸有害",
  "version": null,
  "artist": "莫文蔚",
  "group_key": "呼吸有害|莫文蔚",
  "writers": {
    "lyricist": "罗健成",
    "composer": "邓智伟",
    "arranger": "邓鼓"
  },
  "lyrics": [
    {
      "time": 1.49,
      "time_str": "00:01.490",
      "text": "缺氧到似有幻象",
      "translation": null
    },
    {
      "time": 4.44,
      "time_str": "00:04.440",
      "text": "乏力地躺于地上",
      "translation": null
    },
    {
      "time": 8.15,
      "time_str": "00:08.150",
      "text": "合上双眼 用皮肤感应无常",
      "translation": null
    },
    {
      "time": 14.33,
      "time_str": "00:14.330",
      "text": "这里有过你 未及步离场",
      "translation": null
    },
    {
      "time": 20.14,
      "time_str": "00:20.140",
      "text": "被你的气味 筑起了围墙",
      "translation": null
    },
    {
      "time": 26.48,
      "time_str": "00:26.480",
      "text": "从头再呼吸 残存那种美",
      "translation": null
    },
    {
      "time": 38.41,
      "time_str": "00:38.410",
      "text": "现在尝到的苦",
      "translation": null
    },
    {
      "time": 44.49,
      "time_str": "00:44.490",
      "text": "从前是最动人甜味",
      "translation": null
    },
    {
      "time": 50.75,
      "time_str": "00:50.750",
      "text": "旧事物充斥空气内",
      "translation": null
    },
    {
      "time": 54.56,
      "time_str": "00:54.560",
      "text": "一呼一吸都有害",
      "translation": null
    },
    {
      "time": 57.9,
      "time_str": "00:57.900",
      "text": "床边有你 厅有你 进出于脑海",
      "translation": null
    },
    {
      "time": 63.57,
      "time_str": "01:03.570",
      "text": "寂寞充斥空气内 抑郁吸入来",
      "translation": null
    },
    {
      "time": 70.15,
      "time_str": "01:10.150",
      "text": "宁愿闭气 吸进你会沾湿眼袋",
      "translation": null
    },
    {
      "time": 81.39,
      "time_str": "01:21.390",
      "text": "勉强再试试站立",
      "translation": null
    },
    {
      "time": 84.4,
      "time_str": "01:24.400",
      "text": "自愿地展开学习",
      "translation": null
    },
    {
      "time": 88.0,
      "time_str": "01:28.000",
      "text": "尽快适应着 残忍的低气压",
      "translation": null
    },
    {
      "time": 94.25,
      "time_str": "01:34.250",
      "text": "似欠缺勇气 不敢失去你",
      "translation": null
    },
    {
      "time": 100.31,
      "time_str": "01:40.310",
      "text": "亦欠骨气让 身心也逃离",
      "translation": null
    },
    {
      "time": 106.46,
      "time_str": "01:46.460",
      "text": "从头再呼吸 沉沉那死气",
      "translation": null
    },
    {
      "time": 118.39,
      "time_str": "01:58.390",
      "text": "渗满氧化浪漫",
      "translation": null
    },
    {
      "time": 124.68,
      "time_str": "02:04.680",
      "text": "沉迷在这耐人寻味",
      "translation": null
    },
    {
      "time": 130.79,
      "time_str": "02:10.790",
      "text": "旧事物充斥空气内",
      "translation": null
    },
    {
      "time": 134.67,
      "time_str": "02:14.670",
      "text": "一呼一吸都有害",
      "translation": null
    },
    {
      "time": 137.95,
      "time_str": "02:17.950",
      "text": "床边有你 厅有你 进出于脑海",
      "translation": null
    },
    {
      "time": 143.51,
      "time_str": "02:23.510",
      "text": "寂寞充斥空气内 抑郁吸入来",
      "translation": null
    },
    {
      "time": 150.25,
      "time_str": "02:30.250",
      "text": "宁愿闭气 吸进你会沾湿眼袋",
      "translation": null
    },
    {
      "time": 156.19,
      "time_str": "02:36.190",
      "text": "窒息都不意外 不呼不吸不盼待",
      "translation": null
    },
    {
      "time": 162.67,
      "time_str": "02:42.670",
      "text": "不要你 不要你 要清空脑袋",
      "translation": null
    },
    {
      "time": 167.96,
      "time_str": "02:47.960",
      "text": "尽量振作也应该",
      "translation": null
    },
    {
      "time": 171.72,
      "time_str": "02:51.720",
      "text": "每一扇窗也打开",
      "translation": null
    },
    {
      "time": 174.99,
      "time_str": "02:54.990",
      "text": "不怕你 不怕你 怕呼吸有害",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "呼吸有害 - 莫文蔚.lrc"
}