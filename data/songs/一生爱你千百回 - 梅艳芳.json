  "lyrics": [
    {
      "time": 23.05,
      "time_str": "00:23.050",
      "text": "日夜为你着迷时刻为你挂虑",
      "translation": null
    },
    {
      "time": 27.16,
      "time_str": "00:27.160",
      "text": "思念是不留余地",
      "translation": null
    },
    {
      "time": 31.38,
      "time_str": "00:31.380",
      "text": "已是曾经沧海即使百般煎熬",
      "translation": null
    },
    {
      "time": 35.42,
      "time_str": "00:35.420",
      "text": "终究觉得你最好",
      "translation": null
    },
    {
      "time": 38.77,
      "time_str": "00:38.770",
      "text": "管不了外面风风雨雨心中念的是你",
      "translation": null
    },
    {
      "time": 43.43,
      "time_str": "00:43.430",
      "text": "只想和你在一起",
      "translation": null
    },
    {
      "time": 46.72,
      "time_str": "00:46.720",
      "text": "我要你看清我的决心相信我的柔情",
      "translation": null
    },
    {
      "time": 51.03,
      "time_str": "00:51.030",
      "text": "明白我给你的爱",
      "translation": null
    },
    {
      "time": 54.53,
      "time_str": "00:54.530",
      "text": "一转眼青春如梦岁月如梭不回头",
      "translation": null
    },
    {
      "time": 58.55,
      "time_str": "00:58.550",
      "text": "而我完全付出不保留",
      "translation": null
    },
    {
      "time": 62.584,
      "time_str": "01:02.584",
      "text": "天知道什么时候地点原因会分手",
      "translation": null
    },
    {
      "time": 66.555,
      "time_str": "01:06.555",
      "text": "只要能爱就要爱个够",
      "translation": null
    },
    {
      "time": 70.281,
      "time_str": "01:10.281",
      "text": "我要飞越春夏秋冬飞越千山万水",
      "translation": null
    },
    {
      "time": 75.04,
      "time_str": "01:15.040",
      "text": "带给你所有沉醉",
      "translation": null
    },
    {
      "time": 78.349,
      "time_str": "01:18.349",
      "text": "我要天天与你相对夜夜拥你入睡",
      "translation": null
    },
    {
      "time": 83.203,
      "time_str": "01:23.203",
      "text": "梦过了尽头也不归",
      "translation": null
    },
    {
      "time": 86.48,
      "time_str": "01:26.480",
      "text": "我要飞越春夏秋冬飞越千山万水",
      "translation": null
    },
    {
      "time": 91.173,
      "time_str": "01:31.173",
      "text": "守住你给我的美",
      "translation": null
    },
    {
      "time": 94.533,
      "time_str": "01:34.533",
      "text": "我要天天与你相对夜夜拥你入睡",
      "translation": null
    },
    {
