{
  "title": "小城大事",
  "title_raw": "小城大事",
  "version": null,
  "artist": "杨千嬅",
  "group_key": "小城大事|杨千嬅",
  "writers": {
    "lyricist": "林夕",
    "composer": "雷颂德",
    "arranger": "雷颂德"
  },
  "lyrics": [
    {
      "time": 16.63,
      "time_str": "00:16.630",
      "text": "青春仿佛因我爱你开始",
      "translation": null
    },
    {
      "time": 21.29,
      "time_str": "00:21.290",
      "text": "但却令我看破爱这个字",
      "translation": null
    },
    {
      "time": 25.36,
      "time_str": "00:25.360",
      "text": "自你患上失忆 便是我扭转命数的事",
      "translation": null
    },
    {
      "time": 33.13,
      "time_str": "00:33.130",
      "text": "只因当失忆症发作加深",
      "translation": null
    },
    {
      "time": 36.77,
      "time_str": "00:36.770",
      "text": "没记住我但却另有更新蜜运",
      "translation": null
    },
    {
      "time": 41.13,
      "time_str": "00:41.130",
      "text": "像狐狸精般 并未允许我步近",
      "translation": null
    },
    {
      "time": 48.74,
      "time_str": "00:48.740",
      "text": "无回忆的余生 忘掉往日情人",
      "translation": null
    },
    {
      "time": 53.14,
      "time_str": "00:53.140",
      "text": "却又记住移情别爱的命运",
      "translation": null
    },
    {
      "time": 57.15,
      "time_str": "00:57.150",
      "text": "无回忆的男人 就当偷厄与瞒骗",
      "translation": null
    },
    {
      "time": 61.96,
      "time_str": "01:01.960",
      "text": "抱抱我不过分",
      "translation": null
    },
    {
      "time": 64.34,
      "time_str": "01:04.340",
      "text": "吻下来 豁出去 这吻别似覆水",
      "translation": null
    },
    {
      "time": 72.62,
      "time_str": "01:12.620",
      "text": "再来也许要天上团聚",
      "translation": null
    },
    {
      "time": 79.16,
      "time_str": "01:19.160",
      "text": "再回头 你不许 如曾经不登对",
      "translation": null
    },
    {
      "time": 88.15,
      "time_str": "01:28.150",
      "text": "你何以双眼好像流泪",
      "translation": null
    },
    {
      "time": 110.2,
      "time_str": "01:50.200",
      "text": "彼此追忆不怕爱要终止",
      "translation": null
    },
    {
      "time": 115.94,
      "time_str": "01:55.940",
      "text": "但我大概上世做过太多坏事",
      "translation": null
    },
    {
      "time": 119.68,
      "time_str": "01:59.680",
      "text": "能从头开始 跪在教堂说愿意",
      "translation": null
    },
    {
      "time": 128.1,
      "time_str": "02:08.100",
      "text": "娱乐行的人影 还在继续繁荣",
      "translation": null
    },
    {
      "time": 132.27,
      "time_str": "02:12.270",
      "text": "我在算着甜言蜜语的寿命",
      "translation": null
    },
    {
      "time": 135.85,
      "time_str": "02:15.850",
      "text": "人造的蠢卫星 没探测出我们已",
      "translation": null
    },
    {
      "time": 140.91,
      "time_str": "02:20.910",
      "text": "已再见不再认",
      "translation": null
    },
    {
      "time": 144.67,
      "time_str": "02:24.670",
      "text": "吻下来 豁出去 这吻别似覆水",
      "translation": null
    },
    {
      "time": 154.93,
      "time_str": "02:34.930",
      "text": "再来也许要天上团聚",
      "translation": null
    },
    {
      "time": 161.19,
      "time_str": "02:41.190",
      "text": "我下来 你出去 讲再会也心虚",
      "translation": null
    },
    {
      "time": 170.15,
      "time_str": "02:50.150",
      "text": "我还记得到天上团聚",
      "translation": null
    },
    {
      "time": 177.25,
      "time_str": "02:57.250",
      "text": "吻下来 豁出去 从前多么登对",
      "translation": null
    },
    {
      "time": 185.44,
      "time_str": "03:05.440",
      "text": "你何以双眼好像流泪 每年这天记得再流泪",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "小城大事 - 杨千嬅.lrc"
}