  },
  "lyrics": [
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "监唱：王滔",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "还记得你说的那个远方",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "稚气的少年有大人的模样",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "后来的我时常独自想象",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "夜不能寐到天亮",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "所谓青春是一场自我流放",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "追逐着风景却迷失了方向",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "走过四季只为旅途多些光影",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "用你微笑的样子",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "看雨过天晴",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "想留在这里",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "看时光老去",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "不同的风景有同样的你",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "遗憾是青春泛黄的印记",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "那些时过境迁的告别",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "是为了再相遇",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "如此 完美",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "曾在爱的路上走过一回",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "拥抱的瞬间那么弥足珍贵",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "并肩回味",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "故事结局已无所谓",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "如此 完美",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "能在爱的路上再走一回",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "模糊了答案心却变的纯粹",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "你的远方 我会珍藏",
      "translation": null
    },
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "像那时一样",
      "translation": null
    },
    {
