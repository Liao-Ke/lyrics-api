    {
      "time": 48.216,
      "time_str": "00:48.216",
      "text": "城市一片漆黑 谁都不能看见谁",
      "translation": null
    },
    {
      "time": 55.45,
      "time_str": "00:55.450",
      "text": "除非紧紧依偎",
      "translation": null
    },
    {
      "time": 61.605,
      "time_str": "01:01.605",
      "text": "我让自己喝醉",
      "translation": null
    },
    {
      "time": 66.575,
      "time_str": "01:06.575",
      "text": "没有你我就不能入睡",
      "translation": null
    },
    {
      "time": 73.5,
      "time_str": "01:13.500",
      "text": "整夜又整夜的徘徊",
      "translation": null
    },
    {
      "time": 80.35,
      "time_str": "01:20.350",
      "text": "我说过我绝对不会后悔",
      "translation": null
    },
    {
      "time": 89.35,
      "time_str": "01:29.350",
      "text": "寂寞是被原谅的罪",
      "translation": null
    },
    {
      "time": 98.95,
      "time_str": "01:38.950",
      "text": "爱情怎么让每个人都心碎",
      "translation": null
    },
    {
      "time": 104.495,
      "time_str": "01:44.495",
      "text": "怎么去安慰",
      "translation": null
    },
    {
      "time": 106.805,
      "time_str": "01:46.805",
      "text": "爱情怎么让每个人都流泪",
      "translation": null
    },
    {
      "time": 115.875,
      "time_str": "01:55.875",
      "text": "你的泪烫伤我的脸",
      "translation": null
    },
    {
      "time": 120.515,
      "time_str": "02:00.515",
      "text": "那一次我尝到伤悲",
      "translation": null
    },
    {
      "time": 127.565,
      "time_str": "02:07.565",
      "text": "去爱谁",
      "translation": null
    }
