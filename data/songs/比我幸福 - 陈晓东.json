  "lyrics": [
    {
      "time": 19.0,
      "time_str": "00:19.000",
      "text": "望着广场的时钟 你还在我的怀里躲风",
      "translation": null
    },
    {
      "time": 28.0,
      "time_str": "00:28.000",
      "text": "不习惯言不由衷 沉默如何能让你都懂",
      "translation": null
    },
    {
      "time": 36.0,
      "time_str": "00:36.000",
      "text": "此刻与你相拥 也算有始有终",
      "translation": null
    },
    {
      "time": 46.0,
      "time_str": "00:46.000",
      "text": "祝福有许多种 心痛却尽在不言中",
      "translation": null
    },
    {
      "time": 53.0,
      "time_str": "00:53.000",
      "text": "请你一定要比我幸福 才不枉费我狼狈退出",
      "translation": null
    },
    {
      "time": 64.0,
      "time_str": "01:04.000",
      "text": "再痛也不说苦 爱不用抱歉来弥补",
      "translation": null
    },
    {
      "time": 70.0,
      "time_str": "01:10.000",
      "text": "至少我能成全你的追逐",
      "translation": null
    },
    {
      "time": 73.0,
      "time_str": "01:13.000",
      "text": "请记得你要比我幸福 才值得我对自己残酷",
      "translation": null
    },
    {
      "time": 83.0,
      "time_str": "01:23.000",
      "text": "我默默地倒数 最后再把你看清楚",
      "translation": null
    },
    {
      "time": 88.0,
      "time_str": "01:28.000",
      "text": "看你眼里的我好模糊 慢慢被放逐",
      "translation": null
    },
