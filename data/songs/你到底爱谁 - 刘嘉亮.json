      "time": 24.962,
      "time_str": "00:24.962",
      "text": "一个人喝醉好想找个人来陪",
      "translation": null
    },
    {
      "time": 31.73,
      "time_str": "00:31.730",
      "text": "我们之间有太多的误会",
      "translation": null
    },
    {
      "time": 38.769,
      "time_str": "00:38.769",
      "text": "爱不能再沉睡",
      "translation": null
    },
    {
      "time": 41.915,
      "time_str": "00:41.915",
      "text": "是可悲是摧毁",
      "translation": null
    },
    {
      "time": 45.496,
      "time_str": "00:45.496",
      "text": "我不要再为谁掉眼泪",
      "translation": null
    },
    {
      "time": 53.107,
      "time_str": "00:53.107",
      "text": "爱过才后悔想要用酒来麻醉",
      "translation": null
    },
