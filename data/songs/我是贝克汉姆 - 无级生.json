{
  "title": "我是贝克汉姆",
  "title_raw": "我是贝克汉姆",
  "version": null,
  "artist": "无级生",
  "group_key": "我是贝克汉姆|无级生",
  "writers": {
    "lyricist": null,
    "composer": null,
    "arranger": null
  },
  "lyrics": [
    {
      "time": 15.1,
      "time_str": "00:15.100",
      "text": "我是贝克汉姆 有电眼超高压",
      "translation": null
    },
    {
      "time": 19.1,
      "time_str": "00:19.100",
      "text": "帅的一塌糊涂 我双脚有魔法",
      "translation": null
    },
    {
      "time": 23.1,
      "time_str": "00:23.100",
      "text": "我是贝克汉姆 我住在西班牙",
      "translation": null
    },
    {
      "time": 29.1,
      "time_str": "00:29.100",
      "text": "身披白色战甲 爱我就欢呼吧",
      "translation": null
    },
    {
      "time": 36.99,
      "time_str": "00:36.990",
      "text": "足球场上凌空抽射 就属我最红",
      "translation": null
    },
    {
      "time": 40.99,
      "time_str": "00:40.990",
      "text": "左右开弓气势如虹 我百发百中",
      "translation": null
    },
    {
      "time": 45.99,
      "time_str": "00:45.990",
      "text": "发型衣装我都很酷 很多人跟风",
      "translation": null
    },
    {
      "time": 50.99,
      "time_str": "00:50.990",
      "text": "我有温柔眼神 我是大帅哥",
      "translation": null
    },
    {
      "time": 55.99,
      "time_str": "00:55.990",
      "text": "中国美国亚洲美洲欧洲或中东",
      "translation": null
    },
    {
      "time": 60.99,
      "time_str": "01:00.990",
      "text": "黄的白的高的矮的美女或恐龙",
      "translation": null
    },
    {
      "time": 65.99,
      "time_str": "01:05.990",
      "text": "不怕伤害不怕失败冲向最巅峰",
      "translation": null
    },
    {
      "time": 70.99,
      "time_str": "01:10.990",
      "text": "球迷为我加油 疯狂的呐喊",
      "translation": null
    },
    {
      "time": 74.99,
      "time_str": "01:14.990",
      "text": "我是贝克汉姆 有身材超热辣",
      "translation": null
    },
    {
      "time": 79.99,
      "time_str": "01:19.990",
      "text": "人们叫我神话 比的过蝙蝠侠",
      "translation": null
    },
    {
      "time": 84.99,
      "time_str": "01:24.990",
      "text": "我是贝克汉姆 我英国也有家",
      "translation": null
    },
    {
      "time": 88.99,
      "time_str": "01:28.990",
      "text": "老婆维多利亚 我一直爱着她",
      "translation": null
    },
    {
      "time": 97.99,
      "time_str": "01:37.990",
      "text": "我左脚一个弧 迎风35度",
      "translation": null
    },
    {
      "time": 99.99,
      "time_str": "01:39.990",
      "text": "全场都欢呼 拉拉呜",
      "translation": null
    },
    {
      "time": 102.99,
      "time_str": "01:42.990",
      "text": "进球的感觉太舒服",
      "translation": null
    },
    {
      "time": 104.99,
      "time_str": "01:44.990",
      "text": "我来自遥远的国度",
      "translation": null
    },
    {
      "time": 107.99,
      "time_str": "01:47.990",
      "text": "你说我帅的让女孩们想哭",
      "translation": null
    },
    {
      "time": 108.99,
      "time_str": "01:48.990",
      "text": "哈 因为我是贝克汉姆",
      "translation": null
    },
    {
      "time": 111.99,
      "time_str": "01:51.990",
      "text": "无论是队服西服或者礼服",
      "translation": null
    },
    {
      "time": 114.99,
      "time_str": "01:54.990",
      "text": "我都是帅得一塌糊涂",
      "translation": null
    },
    {
      "time": 117.99,
      "time_str": "01:57.990",
      "text": "足球就是我的教科书",
      "translation": null
    },
    {
      "time": 119.99,
      "time_str": "01:59.990",
      "text": "我让你看得心服口服",
      "translation": null
    },
    {
      "time": 121.99,
      "time_str": "02:01.990",
      "text": "只要你是爱我的哈姆族",
      "translation": null
    },
    {
      "time": 123.99,
      "time_str": "02:03.990",
      "text": "就别吃维多利亚的醋",
      "translation": null
    },
    {
      "time": 126.99,
      "time_str": "02:06.990",
      "text": "管他黄的黑白的什么皮肤",
      "translation": null
    },
    {
      "time": 128.99,
      "time_str": "02:08.990",
      "text": "拥有你们是我的幸福",
      "translation": null
    },
    {
      "time": 130.1,
      "time_str": "02:10.100",
      "text": "请接受我的进球 我的礼物",
      "translation": null
    },
    {
      "time": 133.1,
      "time_str": "02:13.100",
      "text": "一起欢呼 拉拉拉拉拉拉呜",
      "translation": null
    },
    {
      "time": 136.1,
      "time_str": "02:16.100",
      "text": "中国美国亚洲美洲欧洲或中东",
      "translation": null
    },
