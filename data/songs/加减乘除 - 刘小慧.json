  "lyrics": [
    {
      "time": 17.306,
      "time_str": "00:17.306",
      "text": "你眼内柔情多多 急需于我的援助",
      "translation": null
    },
    {
      "time": 21.146,
      "time_str": "00:21.146",
      "text": "日夕那身躯也不能坐",
      "translation": null
    },
    {
      "time": 25.456,
      "time_str": "00:25.456",
      "text": "在心底竟只想这样那样",
      "translation": null
    },
    {
      "time": 29.61,
      "time_str": "00:29.610",
      "text": "用尽那甜言和我拔河",
      "translation": null
    },
    {
      "time": 33.92,
      "time_str": "00:33.920",
      "text": "你我是何生疏 偏于我身旁坐",
      "translation": null
    },
    {
      "time": 38.126,
      "time_str": "00:38.126",
      "text": "热烫的呼吸会起灾祸",
      "translation": null
    },
    {
      "time": 42.331,
      "time_str": "00:42.331",
      "text": "但愿你想想想今晚谁个是傻",
      "translation": null
    },
    {
      "time": 46.354,
      "time_str": "00:46.354",
      "text": "应该更自律自重休想太多",
      "translation": null
    },
    {
      "time": 53.068,
      "time_str": "00:53.068",
      "text": "加一些真的关心 减去些傻念",
      "translation": null
    },
    {
      "time": 56.908,
      "time_str": "00:56.908",
      "text": "令你倾侧身躯再懂安坐",
      "translation": null
    },
    {
      "time": 61.505,
      "time_str": "01:01.505",
      "text": "剩一点小恋火 请你乘友情",
      "translation": null
    },
    {
      "time": 65.424,
      "time_str": "01:05.424",
      "text": "把洒脱情怀除去如何",
      "translation": null
    },
    {
      "time": 69.629,
      "time_str": "01:09.629",
      "text": "加一些真的关心 减去些傻念",
      "translation": null
    },
    {
      "time": 73.94,
      "time_str": "01:13.940",
      "text": "就是你给的最好帮助",
      "translation": null
    },
    {
      "time": 78.093,
      "time_str": "01:18.093",
      "text": "慢慢去新开始这美丽故事",
      "translation": null
    },
    {
      "time": 82.194,
      "time_str": "01:22.194",
      "text": "若未会依规则爱莫能助",
