  "lyrics": [
    {
      "time": 3.51,
      "time_str": "00:03.510",
      "text": "只对你有感觉",
      "translation": null
    },
    {
      "time": 8.6,
      "time_str": "00:08.600",
      "text": "演唱：林俊杰",
      "translation": null
    },
    {
      "time": 19.3,
      "time_str": "00:19.300",
      "text": "无解的眼神 心像海底针",
      "translation": null
    },
    {
      "time": 24.04,
      "time_str": "00:24.040",
      "text": "光是猜测 我食欲不振",
      "translation": null
    },
    {
      "time": 28.61,
      "time_str": "00:28.610",
      "text": "有点烦人 又有点迷人",
      "translation": null
    },
    {
      "time": 37.42,
      "time_str": "00:37.420",
      "text": "浪漫没天份 反应够迟钝",
      "translation": null
    },
    {
      "time": 42.38,
      "time_str": "00:42.380",
      "text": "不够谨慎 花挑错颜色",
      "translation": null
    },
    {
      "time": 46.85,
      "time_str": "00:46.850",
      "text": "但很矛盾 喜欢你的笨",
      "translation": null
    },
    {
      "time": 55.18,
      "time_str": "00:55.180",
      "text": "微笑 再美 再甜 不是你的 都不特别",
      "translation": null
    },
    {
      "time": 59.67,
      "time_str": "00:59.670",
      "text": "眼泪 再苦 再咸 有你安慰 又是晴天",
      "translation": null
    },
    {
      "time": 64.08,
      "time_str": "01:04.080",
      "text": "靠的 再近 再贴 少了拥抱 就算太远",
      "translation": null
    },
    {
      "time": 68.81,
      "time_str": "01:08.810",
      "text": "全世界只对你有感觉",
      "translation": null
    },
    {
      "time": 73.29,
      "time_str": "01:13.290",
      "text": "玩得 再疯 再野 你瞪一眼 我就收敛",
      "translation": null
    },
    {
      "time": 77.81,
      "time_str": "01:17.810",
      "text": "马路 再宽 再远 只要你牵 就很安全",
      "translation": null
    },
    {
      "time": 82.44,
      "time_str": "01:22.440",
      "text": "我会 又乖 又黏 温柔体贴 绝不敷衍",
      "translation": null
    },
    {
      "time": 87.21,
      "time_str": "01:27.210",
      "text": "我只对你有感觉",
      "translation": null
    },
    {
      "time": 91.89,
      "time_str": "01:31.890",
      "text": "我只对你有感觉",
      "translation": null
    },
    {
      "time": 107.25,
      "time_str": "01:47.250",
      "text": "体贴却黏人 爱哭却温顺",
      "translation": null
    },
    {
      "time": 112.07,
      "time_str": "01:52.070",
      "text": "有时天真 有时很邪恶",
      "translation": null
    },
    {
      "time": 116.61,
      "time_str": "01:56.610",
      "text": "对你耍狠 就是舍不得",
      "translation": null
    },
    {
      "time": 125.48,
      "time_str": "02:05.480",
      "text": "请吸收养分 让脑袋平衡",
      "translation": null
    },
    {
      "time": 130.41,
      "time_str": "02:10.410",
      "text": "要你现身 动作慢吞吞",
      "translation": null
    },
    {
      "time": 134.81,
      "time_str": "02:14.810",
      "text": "怎么承认 我非你不可",
      "translation": null
    },
