    {
      "time": 34.85,
      "time_str": "00:34.850",
      "text": "哭不尽多情梦",
      "translation": null
    },
    {
      "time": 38.6,
      "time_str": "00:38.600",
      "text": "已忘了伤心痛",
      "translation": null
    },
    {
      "time": 42.24,
      "time_str": "00:42.240",
      "text": "我的一世一生只有你最懂",
      "translation": null
    },
    {
      "time": 50.02,
      "time_str": "00:50.020",
      "text": "醒不了痴情夜",
      "translation": null
    },
    {
      "time": 53.77,
      "time_str": "00:53.770",
      "text": "不在乎孤枕眠",
      "translation": null
    },
    {
      "time": 57.57,
      "time_str": "00:57.570",
      "text": "我的千辛万苦都藏在心中",
      "translation": null
    },
    {
      "time": 66.81,
      "time_str": "01:06.810",
      "text": "我爱上你给的痛",
      "translation": null
    },
    {
      "time": 70.74,
      "time_str": "01:10.740",
      "text": "心甘情愿等你的梦",
      "translation": null
    },
    {
      "time": 74.73,
      "time_str": "01:14.730",
      "text": "藏起泪眼只用笑容相送",
      "translation": null
    },
    {
      "time": 82.53,
      "time_str": "01:22.530",
      "text": "我爱上你给的痛",
      "translation": null
    },
    {
      "time": 86.03,
      "time_str": "01:26.030",
      "text": "只要活在你的怀中",
      "translation": null
    },
    {
      "time": 90.09,
      "time_str": "01:30.090",
      "text": "但求今生化作伴你的风",
