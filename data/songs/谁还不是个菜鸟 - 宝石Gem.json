  },
  "lyrics": [
    {
      "time": 6.96,
      "time_str": "00:06.960",
      "text": "\"实在不好意思万总，不是故意迟到的……”",
      "translation": null
    },
    {
      "time": 20.17,
      "time_str": "00:20.170",
      "text": "领导是我不好上班第一天就迟到",
      "translation": null
    },
    {
      "time": 22.36,
      "time_str": "00:22.360",
      "text": "早上坐电梯要排队我之前不知道",
      "translation": null
    },
    {
      "time": 24.6,
      "time_str": "00:24.600",
      "text": "你沉默不语只是冲我微微一笑",
      "translation": null
    },
    {
      "time": 26.6,
      "time_str": "00:26.600",
      "text": "心里怎么有种感觉 大事不妙",
      "translation": null
    },
    {
      "time": 28.82,
      "time_str": "00:28.820",
      "text": "还好有惊无险 人事带我来到工位",
      "translation": null
    },
    {
      "time": 30.94,
      "time_str": "00:30.940",
      "text": "点头哈腰握手认识部门各位前辈",
      "translation": null
    },
    {
      "time": 33.13,
      "time_str": "00:33.130",
      "text": "强装镇定 打起精神 做好准备",
      "translation": null
    },
    {
      "time": 35.27,
      "time_str": "00:35.270",
      "text": "一不小心端着咖啡烫到同事小魏",
      "translation": null
    },
    {
      "time": 37.96,
      "time_str": "00:37.960",
      "text": "好不容易熬到了 下午开会",
      "translation": null
    },
    {
      "time": 39.99,
      "time_str": "00:39.990",
      "text": "每个人的PPT都讲得天花乱坠",
      "translation": null
    },
    {
      "time": 42.12,
      "time_str": "00:42.120",
      "text": "什么赋能闭环腰部赛道根本不会",
      "translation": null
    },
    {
      "time": 44.31,
      "time_str": "00:44.310",
      "text": "领导忽然抬头看我 吓得差点崩溃",
      "translation": null
    },
    {
      "time": 46.57,
      "time_str": "00:46.570",
      "text": "擦干口水醒来已经干了半年",
      "translation": null
    },
    {
      "time": 48.82,
      "time_str": "00:48.820",
      "text": "上午开会下午咖啡不能断地往前",
      "translation": null
    },
    {
      "time": 51.05,
      "time_str": "00:51.050",
      "text": "格子间里的菜鸟还要努力赚钱",
      "translation": null
    },
    {
      "time": 53.25,
      "time_str": "00:53.250",
      "text": "我还年轻力壮还想尝尝爱情的甜",
      "translation": null
    },
    {
      "time": 56.0,
      "time_str": "00:56.000",
      "text": "我走你左边 你往我右边（粵)",
      "translation": null
    },
    {
      "time": 60.51,
      "time_str": "01:00.510",
      "text": "尴尬的堵在电梯的中间（粵)",
      "translation": null
    },
    {
      "time": 64.81,
      "time_str": "01:04.810",
      "text": "晕头又转向忙碌的每天（粵)",
      "translation": null
    },
    {
      "time": 68.57,
      "time_str": "01:08.570",
      "text": "仍然要露出笑脸（粵)",
      "translation": null
    },
    {
      "time": 73.64,
      "time_str": "01:13.640",
      "text": "菜鸟上门请多关照",
      "translation": null
    },
    {
      "time": 77.95,
      "time_str": "01:17.950",
      "text": "于明日成为你的骄傲（粵）",
      "translation": null
    },
    {
      "time": 82.29,
      "time_str": "01:22.290",
      "text": "我要努力向前奔跑",
      "translation": null
    },
    {
      "time": 86.61,
      "time_str": "01:26.610",
      "text": "来日定会飞的更高（粤)",
      "translation": null
    },
    {
      "time": 92.05,
      "time_str": "01:32.050",
      "text": "\"诶，不好意思啊，你往这边走，我往这边走，我就出去了，好吗？”",
      "translation": null
    },
    {
      "time": 100.24,
      "time_str": "01:40.240",
      "text": "各位前辈你们好我叫徐小建",
      "translation": null
    },
    {
      "time": 102.41,
      "time_str": "01:42.410",
      "text": "国际物流专业今年刚刚才毕业",
      "translation": null
    },
    {
      "time": 104.61,
      "time_str": "01:44.610",
      "text": "不太熟悉路线也没什么经验",
      "translation": null
    },
    {
      "time": 106.72,
      "time_str": "01:46.720",
      "text": "麻烦哪位大哥能教我给电瓶车充电",
      "translation": null
    },
    {
      "time": 108.9,
      "time_str": "01:48.900",
      "text": "耽误你们时间我实在抱歉",
      "translation": null
    },
    {
      "time": 111.03,
      "time_str": "01:51.030",
      "text": "目前什么都不会现在只会道歉",
      "translation": null
    },
    {
      "time": 113.13,
      "time_str": "01:53.130",
      "text": "马路上的小哥都是咱的教练",
      "translation": null
    },
    {
      "time": 115.36,
      "time_str": "01:55.360",
      "text": "菜鸟先飞我要尽快熟悉这一片",
      "translation": null
    },
    {
      "time": 118.01,
      "time_str": "01:58.010",
      "text": "3单元丽姐 502李姐",
      "translation": null
    },
    {
      "time": 120.09,
      "time_str": "02:00.090",
      "text": "上次我送错了希望你们能多理解",
      "translation": null
    },
    {
      "time": 122.33,
      "time_str": "02:02.330",
      "text": "左手一双皮鞋我右手一袋番茄",
      "translation": null
    },
    {
      "time": 124.34,
      "time_str": "02:04.340",
      "text": "真的不是故意让您做蛋炒皮鞋",
      "translation": null
    },
    {
      "time": 126.74,
      "time_str": "02:06.740",
      "text": "不知不觉 就这样跑了半年",
      "translation": null
    },
    {
      "time": 128.7,
      "time_str": "02:08.700",
      "text": "求求你们别再投诉扣我的钱",
      "translation": null
    },
    {
      "time": 130.89,
      "time_str": "02:10.890",
      "text": "不要挂我电话让我勇往直前",
      "translation": null
    },
    {
      "time": 133.21,
      "time_str": "02:13.210",
      "text": "生活难免苦涩也尝到了爱情的咸",
      "translation": null
    },
    {
      "time": 136.11,
      "time_str": "02:16.110",
      "text": "我走你左边 你往我右边（粵）",
      "translation": null
    },
    {
      "time": 140.44,
      "time_str": "02:20.440",
      "text": "尴尬的堵在电梯的中间（粵）",
      "translation": null
    },
    {
      "time": 144.62,
      "time_str": "02:24.620",
      "text": "晕头又转向忙碌的每天（粵）",
      "translation": null
    },
    {
