    {
      "time": 10.64,
      "time_str": "00:10.640",
      "text": "Semper crescis",
      "translation": "始终满盈"
    },
    {
      "time": 12.78,
      "time_str": "00:12.780",
      "text": "Aut decrescis",
      "translation": "或又虚亏"
    },
    {
      "time": 15.08,
      "time_str": "00:15.080",
      "text": "Vita detestabilis",
      "translation": "可恶的生活"
    },
    {
      "time": 18.37,
      "time_str": "00:18.370",
      "text": "Nunc obdurat",
      "translation": "时而铁石心肠"
    },
    {
      "time": 20.41,
      "time_str": "00:20.410",
      "text": "Et tunc curat",
      "translation": "时而又关心抚慰"
    },
    {
      "time": 22.67,
      "time_str": "00:22.670",
      "text": "Ludo mentis aciem",
      "translation": "当作游戏一般"
    },
