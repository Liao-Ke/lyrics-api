      "time": 21.54,
      "time_str": "00:21.540",
      "text": "我匆匆地走入森林中",
      "translation": null
    },
    {
      "time": 26.7,
      "time_str": "00:26.700",
      "text": "森林它一丛丛",
      "translation": null
    },
    {
      "time": 30.41,
      "time_str": "00:30.410",
      "text": "我找不到他的行踪",
      "translation": null
    },
    {
      "time": 34.8,
      "time_str": "00:34.800",
      "text": "只看到那树摇风",
      "translation": null
