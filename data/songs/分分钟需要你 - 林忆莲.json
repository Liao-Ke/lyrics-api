  "lyrics": [
    {
      "time": 17.368,
      "time_str": "00:17.368",
      "text": "愿我会揸火箭 带你到天空去 在太空中两人住",
      "translation": null
    },
    {
      "time": 26.366,
      "time_str": "00:26.366",
      "text": "活到一千岁 都一般心醉 有你在身边多乐趣",
      "translation": null
    },
    {
      "time": 34.636,
      "time_str": "00:34.636",
      "text": "共你双双对 好得戚好得意",
      "translation": null
    },
    {
      "time": 39.119,
      "time_str": "00:39.119",
      "text": "地冧天崩当闲事 就算翻风雨 只需睇到你",
      "translation": null
    },
    {
      "time": 47.821,
      "time_str": "00:47.821",
      "text": "似见阳光千万里",
      "translation": null
    },
    {
      "time": 52.078,
      "time_str": "00:52.078",
      "text": "有了你开心点 乜都称心满意",
      "translation": null
    },
    {
      "time": 56.563,
      "time_str": "00:56.563",
      "text": "咸鱼白菜也好好味",
      "translation": null
    },
    {
      "time": 60.571,
      "time_str": "01:00.571",
      "text": "我与你永共聚",
      "translation": null
    },
    {
      "time": 62.819,
      "time_str": "01:02.819",
      "text": "分分钟需要你",
      "translation": null
    },
    {
      "time": 65.066,
      "time_str": "01:05.066",
      "text": "你似是阳光空气",
      "translation": null
    },
    {
      "time": 69.567,
      "time_str": "01:09.567",
      "text": "扮靓点皆因你 颠颠地皆因你",
      "translation": null
    },
    {
      "time": 74.063,
      "time_str": "01:14.063",
      "text": "为你甘心做傻事",
      "translation": null
    },
    {
      "time": 78.324,
      "time_str": "01:18.324",
      "text": "扮下猩猩叫 睇到乜都笑",
      "translation": null
    },
    {
      "time": 82.574,
      "time_str": "01:22.574",
      "text": "有你在身边多乐趣",
      "translation": null
    },
    {
      "time": 87.064,
      "time_str": "01:27.064",
      "text": "若有朝失左你 花开都不美",
      "translation": null
    },
    {
      "time": 91.572,
      "time_str": "01:31.572",
      "text": "愿到荒岛去长住",
      "translation": null
    },
    {
      "time": 95.819,
      "time_str": "01:35.819",
      "text": "做个假的你 天天都相对",
      "translation": null
