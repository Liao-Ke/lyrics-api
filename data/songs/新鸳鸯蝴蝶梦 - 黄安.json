  "lyrics": [
    {
      "time": 36.46,
      "time_str": "00:36.460",
      "text": "昨日像那东流水  离我远去不可留",
      "translation": null
    },
    {
      "time": 42.33,
      "time_str": "00:42.330",
      "text": "今日乱我心  多烦忧",
      "translation": null
    },
    {
      "time": 46.86,
      "time_str": "00:46.860",
      "text": "抽刀断水水更流  举杯消愁愁更愁",
      "translation": null
    },
    {
      "time": 52.85,
      "time_str": "00:52.850",
      "text": "明朝清风四飘流",
      "translation": null
    },
    {
      "time": 59.9,
      "time_str": "00:59.900",
      "text": "由来只有新人笑  有谁听到旧人哭",
      "translation": null
    },
    {
      "time": 65.79,
      "time_str": "01:05.790",
      "text": "爱情两个字  好辛苦",
      "translation": null
    },
    {
      "time": 70.26,
      "time_str": "01:10.260",
      "text": "是要问一个明白  还是要装作糊涂",
      "translation": null
    },
    {
      "time": 76.17,
      "time_str": "01:16.170",
      "text": "知多知少难知足",
      "translation": null
    },
    {
      "time": 82.909,
      "time_str": "01:22.909",
      "text": "看似个鸳鸯蝴蝶  不应该的年代",
      "translation": null
    },
    {
      "time": 88.58,
      "time_str": "01:28.580",
      "text": "可是谁又能摆脱人世间的悲哀",
      "translation": null
    },
    {
      "time": 94.459,
      "time_str": "01:34.459",
      "text": "花花世界  鸳鸯蝴蝶",
      "translation": null
    },
    {
      "time": 100.12,
      "time_str": "01:40.120",
      "text": "在人间已是癫  何苦要上青天",
      "translation": null
    },
    {
      "time": 105.18,
      "time_str": "01:45.180",
      "text": "不如温柔同眠",
      "translation": null
    },
    {
