  "lyrics": [
    {
      "time": 5.86,
      "time_str": "00:05.860",
      "text": "小生的花伞还落在你家",
      "translation": null
    },
    {
      "time": 9.17,
      "time_str": "00:09.170",
      "text": "你美眷如花 我浪迹天涯",
      "translation": null
    },
    {
      "time": 12.54,
      "time_str": "00:12.540",
      "text": "为我泡杯花茶 和你有些不搭",
      "translation": null
    },
    {
      "time": 15.91,
      "time_str": "00:15.910",
      "text": "气氛开始有一点尴尬",
      "translation": null
    },
    {
      "time": 19.21,
      "time_str": "00:19.210",
      "text": "你腼腆一笑 竟如此融洽",
      "translation": null
    },
    {
      "time": 22.52,
      "time_str": "00:22.520",
      "text": "我情不自禁会为你牵挂",
      "translation": null
    },
    {
      "time": 26.27,
      "time_str": "00:26.270",
      "text": "什么时代 早已经不想回家",
      "translation": null
    },
    {
      "time": 32.88,
      "time_str": "00:32.880",
      "text": "你微微一笑 蝴蝶为你倾倒",
      "translation": null
    },
    {
      "time": 36.32,
      "time_str": "00:36.320",
      "text": "凝眸几秒 不知道该干嘛",
      "translation": null
    },
    {
      "time": 39.69,
      "time_str": "00:39.690",
      "text": "你拂袖模样 情千变万化",
      "translation": null
    },
    {
      "time": 46.44,
      "time_str": "00:46.440",
      "text": "一壶好酒 趁着夜还未央",
      "translation": null
    },
    {
      "time": 49.87,
      "time_str": "00:49.870",
      "text": "独自品尝 这大把好时光",
      "translation": null
    },
    {
      "time": 53.3,
      "time_str": "00:53.300",
      "text": "夜深人静 略显一丝凄凉",
      "translation": null
    },
    {
      "time": 59.9,
      "time_str": "00:59.900",
      "text": "东奔西走 微醺不宜骑马",
      "translation": null
    },
    {
      "time": 62.64,
      "time_str": "01:02.640",
      "text": "听着浪人 弹着断了弦的琵琶",
      "translation": null
    },
    {
      "time": 66.32,
      "time_str": "01:06.320",
      "text": "路过青楼酒馆  官人进来坐坐 好吗",
      "translation": null
    },
    {
      "time": 72.94,
      "time_str": "01:12.940",
      "text": "我的思念 似六月里的小雨哗哗",
      "translation": null
    },
    {
