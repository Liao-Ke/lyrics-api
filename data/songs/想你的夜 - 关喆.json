    {
      "time": 10.84,
      "time_str": "00:10.840",
      "text": "分手那天",
      "translation": null
    },
    {
      "time": 14.84,
      "time_str": "00:14.840",
      "text": "我看着你走远",
      "translation": null
    },
    {
      "time": 18.96,
      "time_str": "00:18.960",
      "text": "所有承诺化成了句点",
      "translation": null
    },
    {
      "time": 25.96,
      "time_str": "00:25.960",
      "text": "独自守在空荡的房间",
      "translation": null
    },
    {
      "time": 34.71,
      "time_str": "00:34.710",
      "text": "爱与痛在我心里纠缠",
      "translation": null
    },
    {
      "time": 41.09,
      "time_str": "00:41.090",
      "text": "我们的爱走到了今天",
      "translation": null
    },
    {
      "time": 48.4,
      "time_str": "00:48.400",
      "text": "是不是我太自私了一点",
      "translation": null
    },
    {
      "time": 58.27,
      "time_str": "00:58.270",
      "text": "如果爱可以重来",
      "translation": null
    },
    {
      "time": 65.4,
      "time_str": "01:05.400",
      "text": "我会为你放弃一切",
      "translation": null
    },
    {
      "time": 71.77,
      "time_str": "01:11.770",
      "text": "想你的夜",
      "translation": null
    },
    {
      "time": 75.58,
      "time_str": "01:15.580",
      "text": "多希望你能在我身边",
      "translation": null
    },
    {
      "time": 79.83,
      "time_str": "01:19.830",
      "text": "不知道你心里还能否为我改变",
      "translation": null
    },
    {
      "time": 87.08,
      "time_str": "01:27.080",
      "text": "想你的夜",
