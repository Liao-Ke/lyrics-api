  "lyrics": [
    {
      "time": 23.65,
      "time_str": "00:23.650",
      "text": "你曾说我的心像玻璃杯",
      "translation": null
    },
    {
      "time": 27.25,
      "time_str": "00:27.250",
      "text": "单纯得透明如水",
      "translation": null
    },
    {
      "time": 31.37,
      "time_str": "00:31.370",
      "text": "就算盛满了心碎",
      "translation": null
    },
    {
      "time": 34.24,
      "time_str": "00:34.240",
      "text": "也能轻易洒掉装着无所谓",
      "translation": null
    },
    {
      "time": 38.99,
      "time_str": "00:38.990",
      "text": "我用手握紧一只玻璃杯",
      "translation": null
    },
    {
      "time": 42.7,
      "time_str": "00:42.700",
      "text": "心痛得无言以对",
      "translation": null
    },
    {
      "time": 46.73,
      "time_str": "00:46.730",
      "text": "就算再洒脱笑的再美",
      "translation": null
    },
    {
      "time": 50.89,
      "time_str": "00:50.890",
      "text": "心碎了要用什么来赔",
      "translation": null
    },
    {
      "time": 56.36,
      "time_str": "00:56.360",
      "text": "拈一只小小的玻璃杯",
      "translation": null
    },
    {
      "time": 60.27,
      "time_str": "01:00.270",
      "text": "盛不下太多泪水",
      "translation": null
    },
    {
      "time": 64.86,
      "time_str": "01:04.860",
      "text": "多一点爱就多一点疲惫",
      "translation": null
    },
    {
      "time": 68.69,
      "time_str": "01:08.690",
      "text": "洒掉一些给自己放飞",
      "translation": null
    },
    {
      "time": 72.12,
      "time_str": "01:12.120",
      "text": "那轻轻巧巧的玻璃杯",
      "translation": null
    },
    {
      "time": 75.74,
      "time_str": "01:15.740",
      "text": "总是太容易破碎",
      "translation": null
    },
    {
      "time": 81.09,
      "time_str": "01:21.090",
      "text": "盛下了泪水就盛不下妩媚",
      "translation": null
    },
    {
      "time": 84.56,
      "time_str": "01:24.560",
      "text": "究竟谁湮灭了谁",
      "translation": null
    },
    {
      "time": 88.11,
      "time_str": "01:28.110",
      "text": "谁又能体会",
      "translation": null
    },
