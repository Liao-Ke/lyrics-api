  "lyrics": [
    {
      "time": 15.1,
      "time_str": "00:15.10",
      "text": "你在遥远天空闪烁",
      "translation": null
    },
    {
      "time": 21.95,
      "time_str": "00:21.95",
      "text": "是我心中最美星座",
      "translation": null
    },
    {
      "time": 27.3,
      "time_str": "00:27.30",
      "text": "月光如水",
      "translation": null
    },
    {
      "time": 30.58,
      "time_str": "00:30.58",
      "text": "将你我都融化",
      "translation": null
    },
    {
      "time": 34.3,
      "time_str": "00:34.30",
      "text": "星语星愿",
      "translation": null
    },
    {
      "time": 36.5,
      "time_str": "00:36.50",
      "text": "晶莹又剔透",
      "translation": null
    },
    {
      "time": 42.6,
      "time_str": "00:42.60",
      "text": "我正坐在世界边缘",
      "translation": null
    },
    {
      "time": 49.35,
      "time_str": "00:49.35",
      "text": "悬浮光芒轻抚我的脸",
      "translation": null
    },
    {
      "time": 54.72,
      "time_str": "00:54.72",
      "text": "眼泪悄悄在不知觉中滑落",
      "translation": null
    },
    {
      "time": 61.4,
      "time_str": "01:01.40",
      "text": "我如何能够飞去你身边",
      "translation": null
    },
    {
      "time": 69.01,
      "time_str": "01:09.01",
      "text": "那是命运里我无法抗拒的追随",
      "translation": null
    },
    {
      "time": 75.71,
      "time_str": "01:15.71",
      "text": "像流星一道轻轻闪过就被粉碎",
      "translation": null
    },
    {
      "time": 82.76,
      "time_str": "01:22.76",
      "text": "那是我生命里一朵含泪的玫瑰",
      "translation": null
    },
    {
      "time": 89.4,
      "time_str": "01:29.40",
      "text": "颤抖在风中孤独而高贵",
      "translation": null
    },
