  "lyrics": [
    {
      "time": 14.447,
      "time_str": "00:14.447",
      "text": "寻寻觅觅",
      "translation": null
    },
    {
      "time": 17.509,
      "time_str": "00:17.509",
      "text": "在无声无息中消逝",
      "translation": null
    },
    {
      "time": 21.465,
      "time_str": "00:21.465",
      "text": "总是找不到回忆",
      "translation": null
    },
    {
      "time": 23.874,
      "time_str": "00:23.874",
      "text": "找不到曾被遗忘的真实",
      "translation": null
    },
    {
      "time": 28.577,
      "time_str": "00:28.577",
      "text": "一生一世的过去",
      "translation": null
    },
    {
      "time": 31.647,
      "time_str": "00:31.647",
      "text": "你一点一滴的遗弃",
      "translation": null
    },
    {
      "time": 35.653,
      "time_str": "00:35.653",
      "text": "痛苦痛悲痛心痛恨痛失去你",
      "translation": null
    },
    {
      "time": 42.725,
      "time_str": "00:42.725",
      "text": "也许分开不容易",
      "translation": null
    },
    {
      "time": 45.554,
      "time_str": "00:45.554",
      "text": "也许相亲相爱不可以",
      "translation": null
    },
    {
      "time": 49.784,
      "time_str": "00:49.784",
      "text": "痛苦痛悲痛心痛恨痛失自己",
      "translation": null
    },
    {
      "time": 56.798,
      "time_str": "00:56.798",
      "text": "情深缘浅不得已",
      "translation": null
    },
    {
      "time": 59.877,
      "time_str": "00:59.877",
      "text": "你我也知道去珍惜",
      "translation": null
    },
    {
      "time": 63.865,
      "time_str": "01:03.865",
      "text": "只好等在来生里",
      "translation": null
    },
    {
      "time": 66.284,
      "time_str": "01:06.284",
      "text": "再踏上彼此故事的开始",
      "translation": null
    },
    {
      "time": 77.945,
      "time_str": "01:17.945",
      "text": "生生世世",
      "translation": null
    },
    {
      "time": 81.088,
      "time_str": "01:21.088",
      "text": "在无穷无尽的梦里",
      "translation": null
    },
    {
      "time": 85.06,
      "time_str": "01:25.060",
      "text": "偶尔翻起了日记",
      "translation": null
    },
    {
