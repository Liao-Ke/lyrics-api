  "lyrics": [
    {
      "time": 13.8,
      "time_str": "00:13.800",
      "text": "You're picture perfect blue",
      "translation": "你是如此的忧郁深蓝（Charli曾提及自己的联觉症 这首歌中的Boy让她联想到了蓝色）"
    },
    {
      "time": 16.23,
      "time_str": "00:16.230",
      "text": "Sunbathing on the moon",
      "translation": "如月亮反射着阳光"
    },
    {
      "time": 18.67,
      "time_str": "00:18.670",
      "text": "Stars shining as your bones illuminate",
      "translation": "群星闪耀 一如你骨髓中的光斑（在电影The Fault in The Stars中 男主的病症即会在照片时 在骨头里留下光斑）"
    },
    {
      "time": 21.56,
      "time_str": "00:21.560",
      "text": "First kiss just like a drug",
      "translation": "初吻好似一剂猛药"
    },
    {
      "time": 26.59,
      "time_str": "00:26.590",
      "text": "Under your influence",
      "translation": "让我沦陷于你"
    },
    {
      "time": 29.12,
      "time_str": "00:29.120",
      "text": "You take me over you're the magic in my veins",
      "translation": "你已将我占据 就像我的血液里流淌的魔力"
    },
    {
      "time": 32.64,
      "time_str": "00:32.640",
      "text": "This must be love",
      "translation": "这一定就是爱"
    },
    {
      "time": 34.11,
      "time_str": "00:34.110",
      "text": "Boom Clap",
      "translation": "掌声雷动"
    },
    {
      "time": 35.34,
      "time_str": "00:35.340",
      "text": "The sound of my heart",
      "translation": "就像我的心跳"
    },
    {
      "time": 36.73,
      "time_str": "00:36.730",
      "text": "The beat goes on and on and on and on and",
      "translation": "一声声 从不停歇"
    },
    {
      "time": 39.43,
      "time_str": "00:39.430",
      "text": "Boom Clap",
      "translation": "掌声雷动"
    },
    {
      "time": 40.32,
      "time_str": "00:40.320",
      "text": "You make me feel good",
      "translation": "你让我欣喜雀跃"
    },
