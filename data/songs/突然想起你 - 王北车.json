    {
      "time": 0.92,
      "time_str": "00:00.920",
      "text": "编曲/吉他：牛子健",
      "translation": null
    },
    {
      "time": 2.75,
      "time_str": "00:02.750",
      "text": "配唱监制：开开（赵锴羿）",
      "translation": null
    },
    {
      "time": 3.74,
      "time_str": "00:03.740",
      "text": "和声/制作人：胜屿",
      "translation": null
    },
    {
      "time": 19.86,
      "time_str": "00:19.860",
      "text": "都是因为那灯泡",
      "translation": null
    },
    {
      "time": 24.39,
      "time_str": "00:24.390",
      "text": "突然闪了一下于是想起你",
      "translation": null
    },
    {
      "time": 29.9,
      "time_str": "00:29.900",
      "text": "怕你 还没休息",
      "translation": null
    },
    {
      "time": 38.14,
      "time_str": "00:38.140",
      "text": "都是因为这场雨",
      "translation": null
    },
    {
      "time": 42.68,
      "time_str": "00:42.680",
      "text": "忽然间下的那么大怕来不及",
      "translation": null
    },
    {
      "time": 48.36,
      "time_str": "00:48.360",
      "text": "跟你 走在一起",
      "translation": null
    },
    {
      "time": 54.88,
      "time_str": "00:54.880",
      "text": "一个人的夜",
      "translation": null
    },
    {
      "time": 56.55,
      "time_str": "00:56.550",
      "text": "我的心 应该放在哪里",
      "translation": null
    },
    {
      "time": 59.75,
      "time_str": "00:59.750",
      "text": "拥抱过后",
      "translation": null
    },
    {
      "time": 61.21,
      "time_str": "01:01.210",
      "text": "我的双手应该放在哪里",
      "translation": null
    },
    {
      "time": 64.36,
      "time_str": "01:04.360",
      "text": "我始终学不会控制 我的呼吸",
      "translation": null
    },
    {
      "time": 68.99,
      "time_str": "01:08.990",
      "text": "在玻璃窗上 呵出你美丽的名字",
      "translation": null
    },
    {
      "time": 73.6,
      "time_str": "01:13.600",
      "text": "寂寞来袭",
      "translation": null
    },
    {
      "time": 74.95,
      "time_str": "01:14.950",
      "text": "旧雨衣 应该放在哪里",
      "translation": null
    },
    {
      "time": 78.23,
      "time_str": "01:18.230",
      "text": "想念着你",
      "translation": null
    },
    {
      "time": 79.64,
      "time_str": "01:19.640",
      "text": "我的念头应该想到哪里",
      "translation": null
    },
    {
