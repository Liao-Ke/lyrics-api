  "lyrics": [
    {
      "time": 17.46,
      "time_str": "00:17.460",
      "text": "曾经拥有 你给我的爱那么深",
      "translation": null
    },
    {
      "time": 21.63,
      "time_str": "00:21.630",
      "text": "以为你会宠爱我一生",
      "translation": null
    },
    {
      "time": 25.91,
      "time_str": "00:25.910",
      "text": "是我太贪心是我太天真",
      "translation": null
    },
    {
      "time": 30.13,
      "time_str": "00:30.130",
      "text": "始终不见你犹豫的眼神",
      "translation": null
    },
    {
      "time": 34.43,
      "time_str": "00:34.430",
      "text": "曾经想过 深爱一个人怎么够",
      "translation": null
    },
    {
      "time": 38.5,
      "time_str": "00:38.500",
      "text": "还要刹那和天长地久",
      "translation": null
    },
    {
      "time": 43.13,
      "time_str": "00:43.130",
      "text": "是我太贪心是我太天真",
      "translation": null
    },
    {
      "time": 47.14,
      "time_str": "00:47.140",
      "text": "始终不信你的爱变冷",
      "translation": null
    },
    {
      "time": 54.08,
      "time_str": "00:54.080",
      "text": "该是最后一次让你心疼",
      "translation": null
    },
    {
      "time": 57.83,
      "time_str": "00:57.830",
      "text": "分不清这是梦还是真",
      "translation": null
    },
    {
      "time": 62.56,
      "time_str": "01:02.560",
      "text": "不能肯定对你没有恨",
      "translation": null
    },
    {
      "time": 66.36,
      "time_str": "01:06.360",
      "text": "我会如何继续你别问",
      "translation": null
    },
    {
      "time": 74.18,
      "time_str": "01:14.180",
      "text": "一生把你放在心里头",
      "translation": null
    },
    {
      "time": 78.11,
      "time_str": "01:18.110",
      "text": "尽管未必能够长相厮守",
      "translation": null
    },
    {
      "time": 82.36,
      "time_str": "01:22.360",
      "text": "只要偶尔深夜想起有你",
      "translation": null
    },
    {
      "time": 86.61,
      "time_str": "01:26.610",
      "text": "会有一丝微微的酒意",
      "translation": null
    },
    {
      "time": 91.44,
      "time_str": "01:31.440",
      "text": "一生把你放在梦里头",
      "translation": null
    },
    {
      "time": 95.17,
      "time_str": "01:35.170",
      "text": "尽管就要和你从此分手",
      "translation": null
    },
    {
      "time": 99.55,
      "time_str": "01:39.550",
      "text": "让我能够感觉一些暖意",
      "translation": null
    },
    {
      "time": 103.61,
      "time_str": "01:43.610",
      "text": "让我以为还在你怀里",
      "translation": null
    },
