    {
      "time": 14.186,
      "time_str": "00:14.186",
      "text": "美工：朝豫依",
      "translation": null
    },
    {
      "time": 25.436,
      "time_str": "00:25.436",
      "text": "长街上，假魑魅伪魍魉，人群中我徜徉",
      "translation": null
    },
    {
      "time": 33.935,
      "time_str": "00:33.935",
      "text": "我怀抱枯骨，来赴约前世的业障",
      "translation": null
    },
    {
      "time": 39.197,
      "time_str": "00:39.197",
      "text": "敲响你门窗",
      "translation": null
    },
    {
      "time": 44.198,
      "time_str": "00:44.198",
      "text": "你说 什么永世难忘 却辨不出我模样",
      "translation": null
    },
    {
      "time": 52.377,
      "time_str": "00:52.377",
      "text": "或许在掩埋我之后，你转身去亲吻他",
      "translation": null
    },
    {
      "time": 57.635,
      "time_str": "00:57.635",
      "text": "才如此健忘？",
      "translation": null
    },
    {
      "time": 61.64,
      "time_str": "01:01.640",
      "text": "为何要 挟我坠入 无望的爱啊",
      "translation": null
    },
    {
      "time": 64.636,
      "time_str": "01:04.636",
      "text": "你说情爱啊，允诺先许下",
      "translation": null
    },
    {
      "time": 66.878,
      "time_str": "01:06.878",
      "text": "他挑着 南瓜灯嬉笑 来向你讨赏",
      "translation": null
    },
    {
      "time": 69.14,
      "time_str": "01:09.140",
      "text": "我在这旁，你还赠给他糖",
      "translation": null
    },
    {
      "time": 72.88,
      "time_str": "01:12.880",
      "text": "还赠给他糖",
      "translation": null
    },
    {
      "time": 110.88,
      "time_str": "01:50.880",
      "text": "华灯下，假魑魅伪魍魉 人群中我徜徉",
      "translation": null
