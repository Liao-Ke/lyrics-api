  "lyrics": [
    {
      "time": 21.29,
      "time_str": "00:21.290",
      "text": "想起你的可爱模样",
      "translation": null
    },
    {
      "time": 24.73,
      "time_str": "00:24.730",
      "text": "生气时嘴嘟着撒娇",
      "translation": null
    },
    {
      "time": 28.31,
      "time_str": "00:28.310",
      "text": "那一天发现了你的好",
      "translation": null
    },
    {
      "time": 31.94,
      "time_str": "00:31.940",
      "text": "爱上你的微笑",
      "translation": null
    },
    {
      "time": 35.81,
      "time_str": "00:35.810",
      "text": "想在晴天与你紧靠",
      "translation": null
    },
    {
      "time": 39.19,
      "time_str": "00:39.190",
      "text": "把烦恼都变成气泡",
      "translation": null
    },
    {
      "time": 42.75,
      "time_str": "00:42.750",
      "text": "别人猜不到",
      "translation": null
    },
    {
      "time": 44.37,
      "time_str": "00:44.370",
      "text": "让你知道",
      "translation": null
    },
    {
      "time": 46.31,
      "time_str": "00:46.310",
      "text": "有你就是最好",
      "translation": null
    },
    {
      "time": 49.87,
      "time_str": "00:49.870",
      "text": "想与你分享拥抱",
      "translation": null
    },
    {
      "time": 53.31,
      "time_str": "00:53.310",
      "text": "感觉你心跳",
      "translation": null
    },
    {
      "time": 57.19,
      "time_str": "00:57.190",
      "text": "你有专属的味道",
      "translation": null
    },
    {
      "time": 60.61,
      "time_str": "01:00.610",
      "text": "心紧紧依靠",
      "translation": null
    },
    {
      "time": 66.17,
      "time_str": "01:06.170",
      "text": "遇见你我才知道你对我多重要",
      "translation": null
    },
    {
      "time": 69.48,
      "time_str": "01:09.480",
      "text": "没有人能感觉到你最甜美的笑",
      "translation": null
    },
    {
      "time": 72.92,
      "time_str": "01:12.920",
      "text": "我再不用把别人寻找",
      "translation": null
    },
    {
      "time": 76.67,
      "time_str": "01:16.670",
      "text": "因为我已经找到",
      "translation": null
    },
    {
      "time": 80.49,
      "time_str": "01:20.490",
      "text": "我们的缘分刚好不许别人打扰",
      "translation": null
    },
    {
      "time": 83.8,
      "time_str": "01:23.800",
      "text": "搭配爱情的美妙只有我们知道",
      "translation": null
    },
    {
