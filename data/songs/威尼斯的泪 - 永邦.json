    {
      "time": 23.79,
      "time_str": "00:23.790",
      "text": "你将喧闹世界 按下静音",
      "translation": null
    },
    {
      "time": 30.86,
      "time_str": "00:30.860",
      "text": "选择最激烈地 无声抗议",
      "translation": null
    },
    {
      "time": 38.07,
      "time_str": "00:38.070",
      "text": "你比谁都清楚",
      "translation": null
    },
    {
      "time": 40.48,
      "time_str": "00:40.480",
      "text": "真心离伤心最近",
      "translation": null
    },
    {
      "time": 43.98,
      "time_str": "00:43.980",
      "text": "感情细腻 竟是命运伏笔",
      "translation": null
    },
    {
      "time": 52.58,
      "time_str": "00:52.580",
      "text": "你潺潺的泪水",
      "translation": null
    },
    {
      "time": 54.84,
      "time_str": "00:54.840",
      "text": "汇成威尼斯流域",
      "translation": null
    },
    {
      "time": 59.6,
      "time_str": "00:59.600",
      "text": "数着你的回忆",
      "translation": null
    },
    {
      "time": 61.96,
      "time_str": "01:01.960",
      "text": "竟是繁华和美丽",
      "translation": null
    },
    {
      "time": 66.8,
      "time_str": "01:06.800",
      "text": "看着你 线条很清晰的手心",
      "translation": null
    },
    {
      "time": 72.59,
      "time_str": "01:12.590",
      "text": "这一刻我迟了",
      "translation": null
    },
    {
      "time": 75.32,
      "time_str": "01:15.320",
      "text": "却懂了你对爱的坚定",
      "translation": null
    },
    {
      "time": 80.38,
      "time_str": "01:20.380",
      "text": "威尼斯的泪 像琉璃易碎",
      "translation": null
    },
    {
      "time": 86.97,
      "time_str": "01:26.970",
      "text": "说到感情有人懂得转圜",
      "translation": null
    },
    {
      "time": 91.1,
      "time_str": "01:31.100",
      "text": "有人太绝对",
      "translation": null
    },
    {
      "time": 94.52,
      "time_str": "01:34.520",
      "text": "为你湿的泪 在午夜梦回",
      "translation": null
    },
    {
      "time": 101.3,
      "time_str": "01:41.300",
      "text": "其实明明了解 就是在当时",
      "translation": null
    },
    {
