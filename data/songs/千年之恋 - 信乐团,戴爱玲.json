  },
  "lyrics": [
    {
      "time": 21.87,
      "time_str": "00:21.870",
      "text": "谁在悬崖砌一壶茶 温热前世的牵挂",
      "translation": null
    },
    {
      "time": 30.8,
      "time_str": "00:30.800",
      "text": "而我在调整千年的时差 爱恨全喝下",
      "translation": null
    },
    {
      "time": 40.7,
      "time_str": "00:40.700",
      "text": "岁月在岩石上敲打 我又留长了头发",
      "translation": null
    },
    {
      "time": 50.34,
      "time_str": "00:50.340",
      "text": "耐心地等海岸线的变化 大雨就要下",
      "translation": null
    },
    {
      "time": 60.62,
      "time_str": "01:00.620",
      "text": "风狠狠的刮 谁在害怕",
      "translation": null
    },
    {
      "time": 80.35,
      "time_str": "01:20.350",
      "text": "海风一直眷恋着沙 你却错过我的年华",
      "translation": null
    },
    {
      "time": 90.61,
      "time_str": "01:30.610",
      "text": "错过我新长的枝丫 和我的白发",
      "translation": null
    },
    {
      "time": 100.36,
      "time_str": "01:40.360",
      "text": "蝴蝶依旧狂恋着花 你却错过我的年华",
      "translation": null
    },
    {
      "time": 110.51,
      "time_str": "01:50.510",
      "text": "错过我转世的脸颊 你还爱我吗 我等你一句话",
      "translation": null
    },
    {
      "time": 138.64,
      "time_str": "02:18.640",
      "text": "一生行走望断天涯 最远不过是晚霞",
      "translation": null
    },
    {
      "time": 148.44,
      "time_str": "02:28.440",
      "text": "而你今世又在哪户人家 欲语泪先下",
      "translation": null
    },
    {
      "time": 156.04,
      "time_str": "02:36.040",
      "text": "沙滩上消失的浪花 让我慢慢想起家",
      "translation": null
    },
    {
      "time": 167.77,
      "time_str": "02:47.770",
      "text": "曾经许下的永远又在哪 总是放不下",
      "translation": null
    },
    {
      "time": 178.45,
      "time_str": "02:58.450",
      "text": "哈~轮回的记忆在风化 我将它牢牢记下",
      "translation": null
    },
    {
      "time": 197.84,
      "time_str": "03:17.840",
      "text": "海风一直眷恋着沙 你却错过我的年华",
      "translation": null
