    {
      "time": 46.424,
      "time_str": "00:46.424",
      "text": "让我将你心儿摘下",
      "translation": null
    },
    {
      "time": 49.811,
      "time_str": "00:49.811",
      "text": "试着将它慢慢溶化",
      "translation": null
    },
    {
      "time": 53.272,
      "time_str": "00:53.272",
      "text": "看我在你心中是否仍完美无瑕",
      "translation": null
    },
    {
      "time": 59.551,
      "time_str": "00:59.551",
      "text": "是否依然为我丝丝牵挂",
      "translation": null
    },
    {
      "time": 63.492,
      "time_str": "01:03.492",
      "text": "依然爱我无法自拔",
      "translation": null
    },
    {
      "time": 66.919,
      "time_str": "01:06.919",
      "text": "心中是否有我未曾到过的地方啊",
      "translation": null
    },
    {
      "time": 73.274,
      "time_str": "01:13.274",
      "text": "那里湖面总是澄清",
      "translation": null
    },
    {
      "time": 76.733,
      "time_str": "01:16.733",
      "text": "那里空气充满宁静",
      "translation": null
    },
    {
      "time": 80.128,
      "time_str": "01:20.128",
      "text": "雪白明月照在大地",
      "translation": null
    },
    {
      "time": 83.583,
      "time_str": "01:23.583",
      "text": "藏着你不愿提起的回忆",
      "translation": null
    },
    {
      "time": 88.68,
      "time_str": "01:28.680",
      "text": "你说真心总是可以从头",
      "translation": null
    },
    {
      "time": 92.562,
      "time_str": "01:32.562",
      "text": "真爱总是可以长久",
      "translation": null
    },
    {
      "time": 96.034,
      "time_str": "01:36.034",
      "text": "为何你的眼神还有孤独时的落寞",
      "translation": null
    },
    {
      "time": 102.394,
      "time_str": "01:42.394",
      "text": "是否我只是你一种寄托",
      "translation": null
    },
    {
      "time": 106.285,
      "time_str": "01:46.285",
      "text": "填满你感情的缺口",
      "translation": null
    },
    {
      "time": 109.718,
      "time_str": "01:49.718",
      "text": "心中那片森林何时能让我停留",
      "translation": null
