    {
      "time": 16.006,
      "time_str": "00:16.006",
      "text": "你的脸有几分憔悴",
      "translation": null
    },
    {
      "time": 19.541,
      "time_str": "00:19.541",
      "text": "你的眼有残留的泪",
      "translation": null
    },
    {
      "time": 23.202,
      "time_str": "00:23.202",
      "text": "你的唇美丽中有疲惫",
      "translation": null
    },
    {
      "time": 30.588,
      "time_str": "00:30.588",
      "text": "我用去整夜的时间",
      "translation": null
    },
    {
      "time": 34.177,
      "time_str": "00:34.177",
      "text": "想分辨在你我之间",
      "translation": null
    },
    {
      "time": 38.037,
      "time_str": "00:38.037",
      "text": "到底谁会爱谁多一点",
      "translation": null
    },
    {
      "time": 45.228,
      "time_str": "00:45.228",
      "text": "我宁愿看着你",
      "translation": null
    },
    {
      "time": 48.842,
      "time_str": "00:48.842",
      "text": "睡得如此沉静",
      "translation": null
    },
    {
      "time": 52.509,
      "time_str": "00:52.509",
      "text": "胜过你醒时决裂般无情",
      "translation": null
    },
    {
      "time": 59.22,
      "time_str": "00:59.220",
      "text": "你说你 想要逃",
      "translation": null
    },
    {
      "time": 62.933,
      "time_str": "01:02.933",
      "text": "偏偏注定要落脚",
      "translation": null
    },
    {
      "time": 66.559,
      "time_str": "01:06.559",
      "text": "情灭了 爱熄了",
      "translation": null
    },
    {
      "time": 70.278,
      "time_str": "01:10.278",
      "text": "剩下空心要不要",
      "translation": null
    },
    {
      "time": 73.899,
      "time_str": "01:13.899",
      "text": "春已走 花又落",
      "translation": null
    },
    {
      "time": 77.622,
      "time_str": "01:17.622",
      "text": "用心良苦却成空",
      "translation": null
    },
    {
      "time": 81.388,
      "time_str": "01:21.388",
      "text": "我的痛怎么形容",
      "translation": null
    },
    {
      "time": 84.949,
      "time_str": "01:24.949",
      "text": "一生爱错放你的手",
      "translation": null
    },
