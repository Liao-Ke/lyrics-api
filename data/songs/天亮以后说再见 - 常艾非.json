      "text": "常艾非",
      "translation": null
    },
    {
      "time": 4.06,
      "time_str": "00:04.060",
      "text": "天亮以后说再见",
      "translation": null
    },
    {
      "time": 29.25,
      "time_str": "00:29.250",
      "text": "2006.9.8",
      "translation": null
    },
    {
      "time": 31.32,
      "time_str": "00:31.320",
      "text": "男）没有时间",
      "translation": null
    },
    {
      "time": 34.4,
      "time_str": "00:34.400",
      "text": "再多看你一遍",
      "translation": null
    },
    {
      "time": 38.44,
      "time_str": "00:38.440",
      "text": "记不住你眼里残留的缠绵",
      "translation": null
    },
    {
      "time": 46.26,
      "time_str": "00:46.260",
      "text": "你撕碎的纸屑",
      "translation": null
    },
    {
      "time": 49.53,
      "time_str": "00:49.530",
      "text": "像记忆的碎片",
      "translation": null
    },
    {
      "time": 54.05,
      "time_str": "00:54.050",
      "text": "清晨的风一吹就散",
      "translation": null
    },
    {
      "time": 62.04,
      "time_str": "01:02.040",
      "text": "（女）没有空间",
      "translation": null
    },
    {
      "time": 65.14,
      "time_str": "01:05.140",
      "text": "把你留在心田",
      "translation": null
    },
    {
      "time": 69.18,
      "time_str": "01:09.180",
      "text": "反正不能把你留在我身边",
      "translation": null
    },
    {
      "time": 75.7,
      "time_str": "01:15.700",
      "text": "昙花凋谢之前",
      "translation": null
    },
    {
      "time": 80.31,
      "time_str": "01:20.310",
      "text": "离开我房间",
      "translation": null
    },
    {
      "time": 85.14,
      "time_str": "01:25.140",
      "text": "把我的心带走一片",
      "translation": null
    },
    {
      "time": 91.96,
      "time_str": "01:31.960",
      "text": "（合）情不深 缘更浅",
      "translation": null
    },
    {
      "time": 93.65,
      "time_str": "01:33.650",
      "text": "浅得仿佛你从来不曾",
      "translation": null
    },
    {
      "time": 95.83,
      "time_str": "01:35.830",
      "text": "在我生命之中出现",
      "translation": null
    },
    {
      "time": 99.09,
      "time_str": "01:39.090",
      "text": "（男）可是你独一无二侧面",
      "translation": null
    },
    {
      "time": 101.85,
      "time_str": "01:41.850",
      "text": "是滑过我生命的一道弧线",
      "translation": null
    },
    {
      "time": 106.56,
      "time_str": "01:46.560",
      "text": "天亮以后 我们说再见",
      "translation": null
    },
    {
      "time": 113.03,
      "time_str": "01:53.030",
      "text": "把温柔遗落在枕边",
      "translation": null
    },
    {
      "time": 121.67,
      "time_str": "02:01.670",
      "text": "（女）把说不出的那一句爱恋",
      "translation": null
    },
    {
      "time": 127.78,
      "time_str": "02:07.780",
      "text": "（男）埋葬在彼此指缝间",
      "translation": null
    },
    {
      "time": 135.79,
      "time_str": "02:15.790",
      "text": "（男）天亮以后 不再见 （不再见）",
      "translation": null
    },
    {
      "time": 231.14,
      "time_str": "03:51.140",
      "text": "把吻别留在你的脸",
      "translation": null
    },
    {
      "time": 238.38,
      "time_str": "03:58.380",
      "text": "（合）从今后不管多少年（多少年）",
      "translation": null
    },
    {
      "time": 244.88,
      "time_str": "04:04.880",
      "text": "（男）我们说好不思念 不思念",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "天亮以后说再见 - 常艾非.lrc"
}