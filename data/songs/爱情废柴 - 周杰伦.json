  "lyrics": [
    {
      "time": 14.81,
      "time_str": "00:14.810",
      "text": "圣诞节  剩下单人的剩单节",
      "translation": null
    },
    {
      "time": 17.85,
      "time_str": "00:17.850",
      "text": "过条街  最好又给我下起雪",
      "translation": null
    },
    {
      "time": 21.04,
      "time_str": "00:21.040",
      "text": "这么衰  这么刚好  这么狼狈",
      "translation": null
    },
    {
      "time": 24.45,
      "time_str": "00:24.450",
      "text": "要不要拍成MV干脆",
      "translation": null
    },
    {
      "time": 28.51,
      "time_str": "00:28.510",
      "text": "淡淡忧伤还是最美",
      "translation": null
    },
    {
      "time": 32.27,
      "time_str": "00:32.270",
      "text": "剧情是你在写  有点无解  我们之间",
      "translation": null
    },
    {
      "time": 40.53,
      "time_str": "00:40.530",
      "text": "踏着雪  不知不觉走了很远",
      "translation": null
    },
    {
      "time": 43.65,
      "time_str": "00:43.650",
      "text": "绕着圈  我叛逆点起一根烟",
      "translation": null
    },
    {
      "time": 46.99,
      "time_str": "00:46.990",
      "text": "一整天  我旋律哼了一千遍",
      "translation": null
    },
    {
      "time": 50.47,
      "time_str": "00:50.470",
      "text": "千遍一律我不醉不归",
      "translation": null
    },
    {
      "time": 54.25,
      "time_str": "00:54.250",
      "text": "没有你的冬天",
      "translation": null
    },
    {
      "time": 59.15,
      "time_str": "00:59.150",
      "text": "我会一直唱着唱着",
      "translation": null
    },
    {
      "time": 62.21,
      "time_str": "01:02.210",
      "text": "直到你出现",
      "translation": null
    },
    {
      "time": 64.13,
      "time_str": "01:04.130",
      "text": "为你封麦  只唱你爱",
      "translation": null
    },
    {
      "time": 70.81,
      "time_str": "01:10.810",
      "text": "Goodbye Don't Cry  哭个痛快",
      "translation": null
    },
    {
      "time": 77.33,
      "time_str": "01:17.330",
      "text": "曲终人散  你也走散",
      "translation": null
    },
    {
      "time": 83.9,
      "time_str": "01:23.900",
      "text": "我承认我是爱情里的废柴",
      "translation": null
    },
    {
      "time": 90.33,
      "time_str": "01:30.330",
      "text": "你的离开  喊得太快",
      "translation": null
    },
    {
      "time": 96.82,
      "time_str": "01:36.820",
      "text": "我的依赖  还在耍赖",
      "translation": null
    },
    {
      "time": 103.3,
      "time_str": "01:43.300",
      "text": "眼泪打转  转不回来",
      "translation": null
    },
    {
      "time": 109.02,
      "time_str": "01:49.020",
      "text": "你的笑容灿烂",
      "translation": null
    },
