  "lyrics": [
    {
      "time": 1.16,
      "time_str": "00:01.160",
      "text": "Hast Du Bach gehört?",
      "translation": null
    },
    {
      "time": 3.58,
      "time_str": "00:03.580",
      "text": "Kannst Du Bach spielen?",
      "translation": null
    },
    {
      "time": 5.87,
      "time_str": "00:05.870",
      "text": "Ich singe jetzt diesen Song für dich",
      "translation": null
    },
    {
      "time": 9.07,
      "time_str": "00:09.070",
      "text": "Hast du verstehen?",
      "translation": null
    },
    {
      "time": 11.47,
      "time_str": "00:11.470",
      "text": "Liebe,ich liebe dich",
      "translation": null
    },
    {
      "time": 16.07,
      "time_str": "00:16.070",
      "text": "八五三月二十一",
      "translation": null
    },
    {
      "time": 17.37,
      "time_str": "00:17.370",
      "text": "爱森纳赫小镇里",
      "translation": null
    },
    {
      "time": 18.82,
      "time_str": "00:18.820",
      "text": "赫瑟尔河畔边流淌的旋律",
      "translation": null
    },
    {
      "time": 21.42,
      "time_str": "00:21.420",
      "text": "在圣托马斯的教堂里",
      "translation": null
    },
    {
      "time": 23.17,
      "time_str": "00:23.170",
      "text": "没人会去在意",
      "translation": null
    },
    {
      "time": 24.57,
      "time_str": "00:24.570",
      "text": "那管风琴的声音",
      "translation": null
    },
    {
      "time": 27.27,
      "time_str": "00:27.270",
      "text": "勃兰登堡协奏曲",
      "translation": null
    },
    {
      "time": 28.57,
      "time_str": "00:28.570",
      "text": "克膝宫的大键琴",
      "translation": null
    },
    {
      "time": 29.87,
      "time_str": "00:29.870",
      "text": "巴赫为了生计写着平均律",
      "translation": null
    },
    {
      "time": 32.72,
      "time_str": "00:32.720",
      "text": "魏玛宫廷的月光是咏叹的前奏曲",
      "translation": null
    },
    {
      "time": 38.77,
      "time_str": "00:38.770",
      "text": "你拉着提琴",
      "translation": null
    },
    {
      "time": 40.17,
      "time_str": "00:40.170",
      "text": "优雅美丽",
      "translation": null
    },
    {
      "time": 41.62,
      "time_str": "00:41.620",
      "text": "眼神却逃避",
      "translation": null
    },
    {
      "time": 44.42,
      "time_str": "00:44.420",
      "text": "我会像巴赫记录我们约定的爱情",
      "translation": null
    },
    {
      "time": 49.87,
      "time_str": "00:49.870",
      "text": "古典钢琴弹不出的回忆",
      "translation": null
    },
    {
      "time": 52.67,
      "time_str": "00:52.670",
      "text": "像巴赫音乐隐没人海里",
      "translation": null
    },
    {
      "time": 55.48,
      "time_str": "00:55.480",
      "text": "我为你创作了几百世纪",
      "translation": null
    },
    {
      "time": 58.23,
      "time_str": "00:58.230",
      "text": "也是注定没结局",
      "translation": null
    },
    {
      "time": 61.18,
      "time_str": "01:01.180",
      "text": "用笔在乐谱雕刻着唯一",
      "translation": null
    },
    {
      "time": 63.93,
      "time_str": "01:03.930",
      "text": "叹息你永远不懂我的心",
      "translation": null
    },
    {
      "time": 66.78,
      "time_str": "01:06.780",
      "text": "我的旧约圣经",
      "translation": null
    },
    {
      "time": 68.48,
      "time_str": "01:08.480",
      "text": "也没挽回你",
      "translation": null
    },
