    },
    {
      "time": 81.43,
      "time_str": "01:21.430",
      "text": "真理藏在心里",
      "translation": null
    },
    {
      "time": 82.81,
      "time_str": "01:22.810",
      "text": "Keep real for my world(在我的世界里保持绝对的真实)",
      "translation": null
