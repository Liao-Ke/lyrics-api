      "time": 14.0,
      "time_str": "00:14.000",
      "text": "有时候我会问自己",
      "translation": null
    },
    {
      "time": 19.17,
      "time_str": "00:19.170",
      "text": "到底为了什么努力",
      "translation": null
    },
    {
      "time": 24.86,
      "time_str": "00:24.860",
      "text": "赢得什么才叫胜利",
      "translation": null
    },
    {
      "time": 30.04,
      "time_str": "00:30.040",
      "text": "你曾否问自己",
      "translation": null
    },
    {
      "time": 36.13,
      "time_str": "00:36.130",
      "text": "我们明白很多时候",
      "translation": null
    },
    {
      "time": 37.45,
      "time_str": "00:37.450",
      "text": "当你醒来渴望自由",
      "translation": null
    },
    {
      "time": 38.86,
      "time_str": "00:38.860",
      "text": "但现实总变质",
      "translation": null
    },
    {
      "time": 40.17,
      "time_str": "00:40.170",
      "text": "并不是你想要的样子",
      "translation": null
    },
    {
      "time": 41.53,
      "time_str": "00:41.530",
      "text": "有人在逆境中蜕变",
      "translation": null
    },
    {
      "time": 42.67,
      "time_str": "00:42.670",
      "text": "想在机遇中兑现",
      "translation": null
    },
    {
      "time": 44.03,
      "time_str": "00:44.030",
      "text": "说过的承诺",
      "translation": null
    },
    {
      "time": 44.71,
      "time_str": "00:44.710",
      "text": "更多时候",
      "translation": null
    },
    {
      "time": 45.36,
      "time_str": "00:45.360",
      "text": "都被打磨成碎片",
      "translation": null
    },
    {
      "time": 46.79,
      "time_str": "00:46.790",
      "text": "是因为生活要继续",
      "translation": null
    },
    {
      "time": 48.12,
      "time_str": "00:48.120",
      "text": "想振作 获得惊喜",
      "translation": null
    },
    {
      "time": 49.5,
      "time_str": "00:49.500",
      "text": "要更多 要心意",
      "translation": null
    },
    {
      "time": 50.82,
      "time_str": "00:50.820",
      "text": "更精细 更尽力",
      "translation": null
    },
    {
      "time": 52.18,
      "time_str": "00:52.180",
      "text": "让经历跟新意",
      "translation": null
    },
    {
      "time": 53.59,
      "time_str": "00:53.590",
      "text": "更亲密 更凝聚",
      "translation": null
    },
    {
      "time": 54.84,
      "time_str": "00:54.840",
      "text": "这就是我想要的",
      "translation": null
    },
    {
      "time": 56.23,
      "time_str": "00:56.230",
      "text": "我想要我能被铭记",
      "translation": null
    },
    {
      "time": 58.0,
      "time_str": "00:58.000",
      "text": "想忘记那些",
      "translation": null
    },
    {
      "time": 58.94,
      "time_str": "00:58.940",
      "text": "华丽的浮夸的装点",
      "translation": null
    },
    {
      "time": 60.45,
      "time_str": "01:00.450",
      "text": "滑稽的实话里",
      "translation": null
    },
    {
      "time": 61.29,
      "time_str": "01:01.290",
      "text": "藏着谎话却又很庄严",
      "translation": null
    },
    {
      "time": 63.17,
      "time_str": "01:03.170",
      "text": "Do what I do (做我想做的)",
      "translation": null
    },
    {
      "time": 64.45,
      "time_str": "01:04.450",
      "text": "是因为不想停止迈步",
      "translation": null
    },
    {
      "time": 65.66,
      "time_str": "01:05.660",
      "text": "不是不在乎",
      "translation": null
    },
    {
      "time": 66.93,
      "time_str": "01:06.930",
      "text": "而是我害怕心思败露",
      "translation": null
    },
    {
      "time": 68.51,
      "time_str": "01:08.510",
      "text": "世界的面积",
      "translation": null
    },
    {
      "time": 69.36,
      "time_str": "01:09.360",
      "text": "可能大到让人抵触",
      "translation": null
    },
    {
      "time": 70.77,
      "time_str": "01:10.770",
      "text": "但时间的延续",
      "translation": null
    },
    {
      "time": 71.92,
      "time_str": "01:11.920",
      "text": "就是你最大的礼物",
      "translation": null
    },
    {
      "time": 73.52,
      "time_str": "01:13.520",
      "text": "别畏惧",
      "translation": null
    },
    {
      "time": 74.18,
      "time_str": "01:14.180",
      "text": "像是暴露你某个意图",
      "translation": null
    },
    {
      "time": 76.21,
      "time_str": "01:16.210",
      "text": "让阳光彻底照着你",
      "translation": null
    },
    {
      "time": 77.68,
      "time_str": "01:17.680",
      "text": "每寸皮肤",
      "translation": null
    },
    {
      "time": 78.87,
      "time_str": "01:18.870",
      "text": "I pray for myself(为我自己祈祷)",
      "translation": null
    },
    {
