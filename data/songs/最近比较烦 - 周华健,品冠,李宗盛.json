  "lyrics": [
    {
      "time": 25.408,
      "time_str": "00:25.408",
      "text": "品：最近比较烦 比较烦 比较烦",
      "translation": null
    },
    {
      "time": 29.452,
      "time_str": "00:29.452",
      "text": "总觉得日子过得有一些极端",
      "translation": null
    },
    {
      "time": 34.296,
      "time_str": "00:34.296",
      "text": "我想我还是不习惯",
      "translation": null
    },
    {
      "time": 38.592,
      "time_str": "00:38.592",
      "text": "从默默无闻到有人喜欢",
      "translation": null
    },
    {
      "time": 42.592,
      "time_str": "00:42.592",
      "text": "周：最近比较烦 比较烦 比较烦",
      "translation": null
    },
    {
      "time": 46.605,
      "time_str": "00:46.605",
      "text": "总觉得钞票一天比一天难赚",
      "translation": null
    },
    {
      "time": 51.431,
      "time_str": "00:51.431",
      "text": "朋友常常有意无意调侃",
      "translation": null
    },
    {
      "time": 55.691,
      "time_str": "00:55.691",
      "text": "我也许有天改名叫周转",
      "translation": null
    },
    {
      "time": 59.753,
      "time_str": "00:59.753",
      "text": "李：最近比较烦 比较烦 比较烦",
      "translation": null
    },
    {
      "time": 63.783,
      "time_str": "01:03.783",
      "text": "我看那前方怎么也看不到岸",
      "translation": null
    },
    {
      "time": 68.589,
      "time_str": "01:08.589",
      "text": "那个后面还有一班天才追赶",
      "translation": null
    },
    {
      "time": 72.017,
      "time_str": "01:12.017",
      "text": "哎唷 写一首皆大欢喜的歌 是越来越难",
      "translation": null
    },
    {
      "time": 76.875,
      "time_str": "01:16.875",
      "text": "品：最近比较烦 比较烦 比较烦",
      "translation": null
    },
    {
      "time": 80.905,
      "time_str": "01:20.905",
      "text": "陌生的城市何处有我的期盼",
      "translation": null
    },
    {
      "time": 85.703,
      "time_str": "01:25.703",
      "text": "挥别了家乡的伙伴",
      "translation": null
    },
    {
      "time": 89.978,
      "time_str": "01:29.978",
      "text": "现在的我更觉得孤单",
      "translation": null
    },
    {
      "time": 94.001,
      "time_str": "01:34.001",
      "text": "周：最近比较烦 比较烦 比较烦",
      "translation": null
    },
    {
      "time": 98.055,
      "time_str": "01:38.055",
      "text": "女儿说六加六结果等于十三",
      "translation": null
    },
    {
      "time": 103.133,
      "time_str": "01:43.133",
      "text": "我问老段说 怎么办",
      "translation": null
    },
    {
      "time": 107.382,
      "time_str": "01:47.382",
      "text": "他说基本上这个很难",
      "translation": null
    },
    {
      "time": 111.118,
      "time_str": "01:51.118",
      "text": "李：最近比较烦 比你烦 也比你烦",
      "translation": null
    },
    {
      "time": 115.234,
      "time_str": "01:55.234",
      "text": "我梦见和饭岛爱一起晚餐",
      "translation": null
    },
    {
      "time": 120.038,
      "time_str": "02:00.038",
      "text": "梦中的餐厅 灯光太昏暗",
      "translation": null
    },
    {
      "time": 124.319,
      "time_str": "02:04.319",
      "text": "我遍寻不着那蓝色的小药丸",
      "translation": null
    },
    {
      "time": 137.993,
      "time_str": "02:17.993",
      "text": "周：人生总有远的近的麻烦",
      "translation": null
    },
    {
      "time": 142.029,
      "time_str": "02:22.029",
      "text": "太太每天嫌我回家太晚",
      "translation": null
    },
    {
      "time": 146.096,
      "time_str": "02:26.096",
      "text": "品：女友妈妈嫌我长得寒酸",
      "translation": null
    },
    {
      "time": 150.173,
      "time_str": "02:30.173",
      "text": "虽然我已每天苦干实干",
      "translation": null
    },
    {
      "time": 154.201,
      "time_str": "02:34.201",
      "text": "合：管它什么天大麻烦",
      "translation": null
    },
    {
      "time": 156.219,
      "time_str": "02:36.219",
      "text": "久而久之我会习惯",
      "translation": null
    },
    {
      "time": 158.231,
      "time_str": "02:38.231",
      "text": "天下没有不要钱的午餐",
      "translation": null
    },
    {
      "time": 162.353,
      "time_str": "02:42.353",
      "text": "李：太太发现秘书裙子很短",
      "translation": null
    },
    {
      "time": 166.449,
      "time_str": "02:46.449",
      "text": "她就买了八千块的耳环",
      "translation": null
    },
    {
      "time": 170.432,
      "time_str": "02:50.432",
      "text": "周：女儿太胖 儿子不肯吃饭",
      "translation": null
    },
    {
      "time": 174.524,
      "time_str": "02:54.524",
      "text": "品：车子太烂 银行没有存款",
      "translation": null
    },
    {
      "time": 178.102,
      "time_str": "02:58.102",
      "text": "合：麻烦 麻烦 麻烦 麻烦 麻烦",
      "translation": null
    },
    {
      "time": 188.014,
      "time_str": "03:08.014",
