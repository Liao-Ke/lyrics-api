  "lyrics": [
    {
      "time": 13.94,
      "time_str": "00:13.940",
      "text": "感受不易形容 就算会有一点唐突也要说",
      "translation": null
    },
    {
      "time": 18.6,
      "time_str": "00:18.600",
      "text": "请搬进我心窝 如果你不幸福再离家出走",
      "translation": null
    },
    {
      "time": 22.9,
      "time_str": "00:22.900",
      "text": "我心窝做你的新窝 也许平数不太够",
      "translation": null
    },
    {
      "time": 25.9,
      "time_str": "00:25.900",
      "text": "甚至会拥挤到 只装得下你我",
      "translation": null
    },
    {
      "time": 29.87,
      "time_str": "00:29.870",
      "text": "请快准备行李 丢掉用不到的伤心旧回忆",
      "translation": null
    },
    {
      "time": 37.85,
      "time_str": "00:37.850",
      "text": "脑海中 相本日记 从此更新 只有彼此专署甜蜜",
      "translation": null
    },
    {
      "time": 46.29,
      "time_str": "00:46.290",
      "text": "抱枕就丢掉 有肩膀就够",
      "translation": null
    },
    {
      "time": 54.36,
      "time_str": "00:54.360",
      "text": "最后用关心问候 捆绑我们的手完工",
      "translation": null
    },
    {
      "time": 61.91,
      "time_str": "01:01.910",
      "text": "只要在你身边 我就省掉思念 时间只用来眷恋",
      "translation": null
    },
    {
      "time": 77.93,
      "time_str": "01:17.930",
      "text": "我要在你身边 尽情浪费喜悦 也许一待就永远",
      "translation": null
    },
    {
      "time": 121.25,
      "time_str": "02:01.250",
      "text": "管它金窝银窝 怎样都比不过彼此的心窝",
      "translation": null
    },
    {
      "time": 125.12,
      "time_str": "02:05.120",
      "text": "打包一箱温柔 今后多多指教就相互宽容",
      "translation": null
    },
    {
      "time": 129.199,
      "time_str": "02:09.199",
      "text": "你心窝做我的新窝 暖气不需要使用",
      "translation": null
    },
    {
      "time": 132.98,
      "time_str": "02:12.980",
      "text": "我已经温暖到 融化所有冷漠",
      "translation": null
    },
    {
