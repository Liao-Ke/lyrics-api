    {
      "time": 0.869,
      "time_str": "00:00.869",
      "text": "陈奕迅-碌卡",
      "translation": null
    },
    {
      "time": 15.533,
      "time_str": "00:15.533",
      "text": "珍惜亲戚老友与旧同学",
      "translation": null
    },
    {
      "time": 19.397,
      "time_str": "00:19.397",
      "text": "即管千方百计策动娱乐",
      "translation": null
    },
    {
      "time": 22.905,
      "time_str": "00:22.905",
      "text": "彼此饮饱吃醉看着荧幕",
      "translation": null
    },
    {
      "time": 26.61,
      "time_str": "00:26.610",
      "text": "东拉西扯口吃的我跟你讲",
      "translation": null
    },
    {
      "time": 30.111,
      "time_str": "00:30.111",
      "text": "亲疏真假你我哪样量度",
      "translation": null
    },
    {
      "time": 33.947,
      "time_str": "00:33.947",
      "text": "赏面撑腰接济兑现承诺",
      "translation": null
    },
    {
      "time": 37.399,
      "time_str": "00:37.399",
      "text": "炒股供楼世界过份凉薄",
      "translation": null
    },
    {
      "time": 41.15,
      "time_str": "00:41.150",
      "text": "伸出手板眨眼的我想你帮",
      "translation": null
    },
    {
      "time": 44.503,
      "time_str": "00:44.503",
      "text": "人人负债",
      "translation": null
    },
    {
      "time": 46.323,
      "time_str": "00:46.323",
      "text": "轻轻松松的欠下人情巨债",
      "translation": null
    },
    {
      "time": 49.652,
      "time_str": "00:49.652",
      "text": "嘻嘻哈哈花光信用何其愉快",
      "translation": null
    },
    {
      "time": 53.509,
      "time_str": "00:53.509",
      "text": "位位手执一副牌",
      "translation": null
    },
    {
      "time": 57.356,
      "time_str": "00:57.356",
      "text": "靠友谊之光放大",
      "translation": null
    },
    {
      "time": 58.956,
      "time_str": "00:58.956",
      "text": "碌卡要抱住最大期望",
      "translation": null
    },
    {
      "time": 62.549,
      "time_str": "01:02.549",
      "text": "碌卡尴尬亦切忌流汗",
      "translation": null
    },
    {
      "time": 66.162,
      "time_str": "01:06.162",
      "text": "碌卡过两日我就还",
      "translation": null
    },
    {
      "time": 71.336,
      "time_str": "01:11.336",
      "text": "还完又系老友鬼鬼",
