  "lyrics": [
    {
      "time": 25.74,
      "time_str": "00:25.740",
      "text": "我想偷偷望呀望一望他",
      "translation": null
    },
    {
      "time": 29.95,
      "time_str": "00:29.950",
      "text": "假装欣赏欣赏一瓶花",
      "translation": null
    },
    {
      "time": 34.37,
      "time_str": "00:34.370",
      "text": "只能偷偷看呀看一看他",
      "translation": null
    },
    {
      "time": 38.67,
      "time_str": "00:38.670",
      "text": "就像正要浏览一幅画",
      "translation": null
    },
    {
      "time": 42.96,
      "time_str": "00:42.960",
      "text": "只怕给他知道笑我傻",
      "translation": null
    },
    {
      "time": 47.43,
      "time_str": "00:47.430",
      "text": "我的眼光只好回避他",
      "translation": null
    },
    {
      "time": 51.71,
      "time_str": "00:51.710",
      "text": "虽然也想和他说一说话",
      "translation": null
    },
    {
      "time": 56.12,
      "time_str": "00:56.120",
      "text": "怎奈他的身旁有个她",
      "translation": null
    },
