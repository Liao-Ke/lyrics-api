  "lyrics": [
    {
      "time": 23.5,
      "time_str": "00:23.500",
      "text": "背靠着背坐在地毯上",
      "translation": null
    },
    {
      "time": 27.91,
      "time_str": "00:27.910",
      "text": "听听音乐聊聊愿望",
      "translation": null
    },
    {
      "time": 32.71,
      "time_str": "00:32.710",
      "text": "你希望我越来越温柔",
      "translation": null
    },
    {
      "time": 36.54,
      "time_str": "00:36.540",
      "text": "我希望你放我在心上",
      "translation": null
    },
    {
      "time": 43.36,
      "time_str": "00:43.360",
      "text": "你说想送我个浪漫的梦想",
      "translation": null
    },
    {
      "time": 47.54,
      "time_str": "00:47.540",
      "text": "谢谢我带你找到天堂",
      "translation": null
    },
    {
      "time": 52.27,
      "time_str": "00:52.270",
      "text": "哪怕用一辈子才能完成",
      "translation": null
    },
    {
      "time": 56.34,
      "time_str": "00:56.340",
      "text": "只要我讲你就记住不忘",
      "translation": null
    },
    {
      "time": 62.69,
      "time_str": "01:02.690",
      "text": "我能想到最浪漫的事",
      "translation": null
    },
    {
      "time": 66.85,
      "time_str": "01:06.850",
      "text": "就是和你一起慢慢变老",
      "translation": null
    },
    {
      "time": 71.28,
      "time_str": "01:11.280",
      "text": "一路上收藏点点滴滴的欢笑",
      "translation": null
    },
    {
      "time": 75.59,
      "time_str": "01:15.590",
      "text": "留到以后坐着摇椅慢慢聊",
      "translation": null
    },
    {
      "time": 80.12,
      "time_str": "01:20.120",
      "text": "我能想到最浪漫的事",
      "translation": null
    },
    {
      "time": 84.84,
      "time_str": "01:24.840",
      "text": "就是和你一起慢慢变老",
      "translation": null
    },
    {
      "time": 89.11,
      "time_str": "01:29.110",
      "text": "直到我们老得哪儿也去不了",
      "translation": null
    },
    {
      "time": 93.47,
      "time_str": "01:33.470",
      "text": "你还依然把我当成手心里的宝",
      "translation": null
    },
