  "lyrics": [
    {
      "time": 23.3,
      "time_str": "00:23.300",
      "text": "翻开随身携带的记事本",
      "translation": null
    },
    {
      "time": 28.19,
      "time_str": "00:28.190",
      "text": "写着许多事都是关于你",
      "translation": null
    },
    {
      "time": 33.28,
      "time_str": "00:33.280",
      "text": "你讨厌被冷落",
      "translation": null
    },
    {
      "time": 35.57,
      "time_str": "00:35.570",
      "text": "习惯被守候",
      "translation": null
    },
    {
      "time": 38.58,
      "time_str": "00:38.580",
      "text": "寂寞才找我",
      "translation": null
    },
    {
      "time": 46.54,
      "time_str": "00:46.540",
      "text": "我看见自己写下的心情",
      "translation": null
    },
    {
      "time": 50.96,
      "time_str": "00:50.960",
      "text": "把自己放在卑微的后头",
      "translation": null
    },
    {
      "time": 56.15,
      "time_str": "00:56.150",
      "text": "等你等太久",
      "translation": null
    },
    {
      "time": 58.53,
      "time_str": "00:58.530",
      "text": "想你泪会流",
      "translation": null
    },
    {
      "time": 61.37,
      "time_str": "01:01.370",
      "text": "而幸福快乐是什么",
      "translation": null
    },
    {
      "time": 68.02,
      "time_str": "01:08.020",
      "text": "爱得痛了 痛得哭了",
      "translation": null
    },
    {
      "time": 72.49,
      "time_str": "01:12.490",
      "text": "哭得累了",
      "translation": null
    },
    {
      "time": 74.66,
      "time_str": "01:14.660",
      "text": "日记本里页页执着",
      "translation": null
    },
    {
      "time": 78.68,
      "time_str": "01:18.680",
      "text": "记载着你的好",
      "translation": null
    },
    {
      "time": 81.46,
      "time_str": "01:21.460",
      "text": "像上瘾的毒药",
      "translation": null
    },
    {
      "time": 84.26,
      "time_str": "01:24.260",
      "text": "它反复骗着我",
      "translation": null
    },
    {
      "time": 90.85,
      "time_str": "01:30.850",
      "text": "爱得痛了 痛得哭了",
      "translation": null
    },
    {
      "time": 95.32,
      "time_str": "01:35.320",
      "text": "哭得累了",
      "translation": null
    },
    {
      "time": 97.65,
      "time_str": "01:37.650",
      "text": "矛盾心里总是强求",
      "translation": null
    },
    {
      "time": 101.66,
      "time_str": "01:41.660",
      "text": "劝自己要放手",
      "translation": null
    },
    {
      "time": 104.21,
      "time_str": "01:44.210",
      "text": "闭上眼让你走",
      "translation": null
    },
    {
      "time": 106.99,
      "time_str": "01:46.990",
      "text": "烧掉日记重新来过",
      "translation": null
    },
    {
