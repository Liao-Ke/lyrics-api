    {
      "time": 12.81,
      "time_str": "00:12.810",
      "text": "Red cups and sweaty bodies everywhere",
      "translation": "举杯欢庆，激情热舞"
    },
    {
      "time": 15.45,
      "time_str": "00:15.450",
      "text": "Hands in the air like we don't care",
      "translation": "挥动双臂，毫不在乎"
    },
    {
      "time": 18.35,
      "time_str": "00:18.350",
      "text": "'Cause we came to have so much fun now",
      "translation": "欢乐无限，乐趣无穷"
    },
    {
      "time": 21.41,
      "time_str": "00:21.410",
      "text": "Bet somebody here might be the one now",
      "translation": "寻觅派对达人，调动派对气氛"
    },
    {
      "time": 24.37,
      "time_str": "00:24.370",
      "text": "If you're not ready to go home",
      "translation": "你若无归家之心"
    },
    {
      "time": 29.2,
      "time_str": "00:29.200",
      "text": "Can I get a \"Hell, no？！\"",
      "translation": "就尽情狂欢吧"
    },
    {
      "time": 31.2,
      "time_str": "00:31.200",
      "text": "Cause we're gonna go all night",
      "translation": "今夜派对，风光无限"
    },
    {
      "time": 33.09,
      "time_str": "00:33.090",
      "text": "Till we see the sunlight, alright",
      "translation": "彻夜狂欢，直至天明"
    },
    {
      "time": 35.57,
      "time_str": "00:35.570",
      "text": "So la da di da di",
      "translation": "准备好，啦答嘀答嘀"
    },
    {
      "time": 37.33,
      "time_str": "00:37.330",
      "text": "We like to party",
      "translation": "我们爱派对"
    },
    {
      "time": 38.87,
      "time_str": "00:38.870",
      "text": "Dancing you and me",
      "translation": "你我共舞"
    },
    {
      "time": 40.37,
      "time_str": "00:40.370",
      "text": "Doing whatever we want",
      "translation": "随心所欲"
    },
    {
      "time": 44.28,
      "time_str": "00:44.280",
      "text": "And this is our house  And this is our rules",
      "translation": "我们的地盘，我们做主"
    },
    {
