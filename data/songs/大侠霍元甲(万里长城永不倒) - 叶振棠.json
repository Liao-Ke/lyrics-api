    {
      "time": 19.3,
      "time_str": "00:19.300",
      "text": "昏睡百年，国人渐已醒",
      "translation": null
    },
    {
      "time": 38.5,
      "time_str": "00:38.500",
      "text": "睁开眼吧，小心看吧",
      "translation": null
    },
    {
      "time": 41.1,
      "time_str": "00:41.100",
      "text": "哪个愿臣虏自认",
      "translation": null
    },
    {
      "time": 45.999,
      "time_str": "00:45.999",
      "text": "因为畏缩与忍让",
      "translation": null
    },
    {
      "time": 51.899,
      "time_str": "00:51.899",
      "text": "人家骄气日盛",
      "translation": null
    },
    {
      "time": 54.699,
      "time_str": "00:54.699",
      "text": "开口叫吧，高声叫吧",
      "translation": null
    },
    {
      "time": 59.999,
      "time_str": "00:59.999",
      "text": "这里是全国皆兵",
      "translation": null
    },
    {
      "time": 63.999,
      "time_str": "01:03.999",
      "text": "历来强盗要侵入",
      "translation": null
    },
    {
      "time": 68.999,
      "time_str": "01:08.999",
      "text": "最终必送命",
      "translation": null
    },
    {
      "time": 72.999,
      "time_str": "01:12.999",
      "text": "万里长城永不倒",
      "translation": null
    },
    {
      "time": 77.999,
      "time_str": "01:17.999",
      "text": "千里黄河水滔滔",
      "translation": null
    },
    {
      "time": 81.999,
      "time_str": "01:21.999",
      "text": "江山秀丽叠彩峰岭",
      "translation": null
    },
    {
      "time": 86.999,
      "time_str": "01:26.999",
      "text": "问我国家哪像染病",
      "translation": null
    },
    {
      "time": 90.999,
      "time_str": "01:30.999",
      "text": "冲开血路，挥手上吧",
      "translation": null
    },
    {
      "time": 95.999,
      "time_str": "01:35.999",
      "text": "要致力国家中兴",
      "translation": null
    },
    {
      "time": 99.999,
      "time_str": "01:39.999",
      "text": "岂让国土再遭践踏",
      "translation": null
    },
    {
      "time": 104.999,
      "time_str": "01:44.999",
      "text": "个个负起使命",
      "translation": null
    },
    {
      "time": 128.0,
      "time_str": "02:08.000",
      "text": "万里长城永不倒",
      "translation": null
    },
