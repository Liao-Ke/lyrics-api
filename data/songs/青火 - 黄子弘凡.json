  "lyrics": [
    {
      "time": 17.04,
      "time_str": "00:17.040",
      "text": "穿过山峰 追过汹涌流",
      "translation": null
    },
    {
      "time": 23.88,
      "time_str": "00:23.880",
      "text": "然后醒来发现世界依旧",
      "translation": null
    },
    {
      "time": 30.66,
      "time_str": "00:30.660",
      "text": "在一遍遍重复的街口",
      "translation": null
    },
    {
      "time": 36.59,
      "time_str": "00:36.590",
      "text": "看每个人 都在找 都在丢",
      "translation": null
    },
    {
      "time": 43.82,
      "time_str": "00:43.820",
      "text": "多少个迷茫的夜晚",
      "translation": null
    },
    {
      "time": 47.21,
      "time_str": "00:47.210",
      "text": "望着宇宙 想着以后",
      "translation": null
    },
    {
      "time": 50.67,
      "time_str": "00:50.670",
      "text": "多少次无谓的羁绊",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "不断纠缠",
      "translation": null
    },
    {
      "time": 57.42,
      "time_str": "00:57.420",
      "text": "终于踏上了四海的航船",
      "translation": null
    },
    {
      "time": 60.9,
      "time_str": "01:00.900",
      "text": "作别后各自寻找着",
      "translation": null
    },
    {
      "time": 64.31,
      "time_str": "01:04.310",
      "text": "青春的宝藏",
      "translation": null
    },
    {
      "time": 66.1,
      "time_str": "01:06.100",
      "text": "找到了 是你和我",
      "translation": null
    },
    {
      "time": 71.11,
      "time_str": "01:11.110",
      "text": "看那山河远阔",
      "translation": null
    },
    {
      "time": 73.76,
      "time_str": "01:13.760",
      "text": "听那青火的呐喊",
      "translation": null
    },
    {
      "time": 78.08,
      "time_str": "01:18.080",
      "text": "想要素履以往",
      "translation": null
    },
    {
      "time": 80.56,
      "time_str": "01:20.560",
      "text": "我们总是不甘平凡",
      "translation": null
    },
    {
      "time": 84.89,
      "time_str": "01:24.890",
      "text": "任岁月似水流年",
      "translation": null
    },
    {
      "time": 88.36,
      "time_str": "01:28.360",
      "text": "仍在灯火中看见",
      "translation": null
    },
    {
      "time": 91.7,
      "time_str": "01:31.700",
      "text": "彼此的脸 骄傲的眼",
      "translation": null
    },
    {
      "time": 95.2,
      "time_str": "01:35.200",
      "text": "骄傲的少年",
      "translation": null
    },
    {
      "time": 126.56,
      "time_str": "02:06.560",
      "text": "穿过山峰 追过汹涌流",
      "translation": null
    },
    {
      "time": 133.53,
      "time_str": "02:13.530",
      "text": "终有一天知道这不是梦",
      "translation": null
    },
    {
      "time": 140.31,
      "time_str": "02:20.310",
      "text": "回到那个熟悉的街口",
      "translation": null
    },
    {
