{
  "title": "披着羊皮的狼",
  "title_raw": "披着羊皮的狼",
  "version": null,
  "artist": "郑源",
  "group_key": "披着羊皮的狼|郑源",
  "writers": {
    "lyricist": "刀郎",
    "composer": "刀郎",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 43.2,
      "time_str": "00:43.200",
      "text": "我小心翼翼的接近",
      "translation": null
    },
    {
      "time": 47.83,
      "time_str": "00:47.830",
      "text": "怕你在梦中惊醒",
      "translation": null
    },
    {
      "time": 53.03,
      "time_str": "00:53.030",
      "text": "我只是想轻轻的吻吻你",
      "translation": null
    },
    {
      "time": 59.2,
      "time_str": "00:59.200",
      "text": "你别担心",
      "translation": null
    },
    {
      "time": 65.89,
      "time_str": "01:05.890",
      "text": "我知道想要和你在一起并不容易",
      "translation": null
    },
    {
      "time": 71.12,
      "time_str": "01:11.120",
      "text": "我们来自不同的天和地",
      "translation": null
    },
    {
      "time": 76.71,
      "time_str": "01:16.710",
      "text": "你总是感觉和我一起",
      "translation": null
    },
    {
      "time": 81.91,
      "time_str": "01:21.910",
      "text": "是漫无边际阴冷的恐惧",
      "translation": null
    },
    {
      "time": 86.48,
      "time_str": "01:26.480",
      "text": "我真的好爱你",
      "translation": null
    },
    {
      "time": 89.08,
      "time_str": "01:29.080",
      "text": "我愿意改变自己",
      "translation": null
    },
    {
      "time": 91.66,
      "time_str": "01:31.660",
      "text": "我愿意为你流浪在戈壁",
      "translation": null
    },
    {
      "time": 96.86,
      "time_str": "01:36.860",
      "text": "只求你不要拒绝",
      "translation": null
    },
    {
      "time": 100.38,
      "time_str": "01:40.380",
      "text": "不要离别",
      "translation": null
    },
    {
      "time": 102.8,
      "time_str": "01:42.800",
      "text": "不要给我风雪",
      "translation": null
    },
    {
      "time": 107.24,
      "time_str": "01:47.240",
      "text": "我真的好爱你",
      "translation": null
    },
    {
      "time": 109.79,
      "time_str": "01:49.790",
      "text": "我愿意改变自己",
      "translation": null
    },
    {
      "time": 112.34,
      "time_str": "01:52.340",
      "text": "我愿意为你背负一身羊皮",
      "translation": null
    },
    {
      "time": 117.7,
      "time_str": "01:57.700",
      "text": "只求你让我靠近",
      "translation": null
    },
    {
      "time": 121.29,
      "time_str": "02:01.290",
      "text": "让我爱你 相偎相依",
      "translation": null
    },
    {
      "time": 130.45,
      "time_str": "02:10.450",
      "text": "我确定我就是那一只披着羊皮的狼",
      "translation": null
    },
    {
      "time": 136.05,
      "time_str": "02:16.050",
      "text": "而你是我的猎物是我嘴里的羔羊",
      "translation": null
    },
    {
      "time": 141.7,
      "time_str": "02:21.700",
      "text": "我拋却同伴独自流浪",
      "translation": null
    },
    {
      "time": 146.52,
      "time_str": "02:26.520",
      "text": "就是不愿别人把你分享",
      "translation": null
    },
    {
      "time": 151.43,
      "time_str": "02:31.430",
      "text": "我确定这一辈子都会在你身旁",
      "translation": null
    },
    {
      "time": 156.88,
      "time_str": "02:36.880",
      "text": "带着火热的心随你到任何地方",
      "translation": null
    },
    {
      "time": 162.33,
      "time_str": "02:42.330",
      "text": "你让我痴 让我狂",
      "translation": null
    },
    {
      "time": 167.66,
      "time_str": "02:47.660",
      "text": "爱你的嚎叫还在山谷回荡",
      "translation": null
    },
    {
      "time": 177.4,
      "time_str": "02:57.400",
      "text": "（Music）",
      "translation": null
    },
    {
      "time": 186.44,
      "time_str": "03:06.440",
      "text": "我确定你就是我心中如花的羔羊",
      "translation": null
    },
    {
      "time": 192.47,
      "time_str": "03:12.470",
      "text": "你是我的天使是我的梦想",
      "translation": null
    },
    {
      "time": 197.96,
      "time_str": "03:17.960",
      "text": "我搂你在怀里",
      "translation": null
    },
    {
      "time": 200.93,
      "time_str": "03:20.930",
      "text": "装进我的身体",
      "translation": null
    },
    {
      "time": 203.27,
      "time_str": "03:23.270",
      "text": "让你我的血液交融在一起",
      "translation": null
    },
    {
      "time": 207.87,
      "time_str": "03:27.870",
      "text": "你确定看到我为你披上那温柔的羊皮",
      "translation": null
    },
    {
      "time": 213.25,
      "time_str": "03:33.250",
      "text": "是一个男人无法表露脆弱的感情",
      "translation": null
    },
    {
      "time": 219.05,
      "time_str": "03:39.050",
      "text": "我有多爱你",
      "translation": null
    },
    {
      "time": 221.64,
      "time_str": "03:41.640",
      "text": "就有多少柔情",
      "translation": null
    },
    {
      "time": 224.14,
      "time_str": "03:44.140",
      "text": "我相信这柔情定能感动天地",
      "translation": null
    },
    {
      "time": 238.35,
      "time_str": "03:58.350",
      "text": "（End）",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "披着羊皮的狼 - 郑源.lrc"
}