  "lyrics": [
    {
      "time": 12.25,
      "time_str": "00:12.250",
      "text": "Оля недовольна Мерседесом,",
      "translation": "梅赛德斯无法俘获奥莉亚的心"
    },
    {
      "time": 18.0,
      "time_str": "00:18.000",
      "text": "Коля недоволен лишним весом,",
      "translation": "科利亚因自己的体重而烦恼"
    },
    {
      "time": 23.97,
      "time_str": "00:23.970",
      "text": "Он и свой Маздой недоволен,",
      "translation": "他的马自达也不能让他开心起来"
    },
    {
      "time": 29.69,
      "time_str": "00:29.690",
      "text": "Мерседес его б устроил Олин.",
      "translation": "他一定会爱上奥莉亚的梅赛德斯"
    },
    {
      "time": 35.2,
      "time_str": "00:35.200",
      "text": "А я вам так скажу, а я вам так скажу",
      "translation": "那么让我告诉你，那么让我告诉你"
    },
    {
      "time": 40.53,
      "time_str": "00:40.530",
      "text": "Я же вот езжу на Пежо и не пи.жу",
      "translation": "我来这就为一辆标致，才不是来这胡扯的"
    },
    {
      "time": 47.66,
      "time_str": "00:47.660",
      "text": "Жу-жу-жу-жу! Жу-жу-жу-жу!",
      "translation": "就是，就是，就是，就是！就是，就是，就是，就是！"
    },
    {
      "time": 50.54,
      "time_str": "00:50.540",
      "text": "Езжу на Пежо и не пи.жу",
      "translation": "我来这就为一辆标致不是来这胡扯"
    },
    {
      "time": 53.44,
      "time_str": "00:53.440",
      "text": "Жу-жу-жу-жу! Жу-жу-жу-жу!",
      "translation": "就是，就是，就是，就是！就是，就是，就是，就是！"
    },
    {
      "time": 56.46,
      "time_str": "00:56.460",
      "text": "Жу-жу-жу-жу!",
      "translation": "就是，就是，就是，就是！"
    },
    {
      "time": 60.54,
      "time_str": "01:00.540",
      "text": "Толя часто недоволен Олей,",
      "translation": "托尼亚经常不满意奥莉亚"
    },
    {
      "time": 66.36,
      "time_str": "01:06.360",
      "text": "И зарплатой тоже недоволен,",
      "translation": "他也不满意自己的工资"
    },
    {
      "time": 72.01,
      "time_str": "01:12.010",
      "text": "Крутятся как белки в колесе,",
      "translation": "如同车轮里转动的松鼠"
    },
    {
      "time": 78.05,
      "time_str": "01:18.050",
      "text": "В нашем офисе и недовольны все.",
      "translation": "我们办公室里没有人是快乐的"
    },
    {
      "time": 83.18,
      "time_str": "01:23.180",
      "text": "А я вам так скажу, а я вам так скажу",
      "translation": "那么让我告诉你，那么让我告诉你"
    },
    {
      "time": 88.84,
      "time_str": "01:28.840",
      "text": "Я же вот езжу на Пежо и не пи.жу",
      "translation": "我来这就为一辆标致，才不是来这胡扯的"
    },
    {
