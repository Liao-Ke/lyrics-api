  "lyrics": [
    {
      "time": 11.04,
      "time_str": "00:11.040",
      "text": "椰风挑动银浪",
      "translation": null
    },
    {
      "time": 15.75,
      "time_str": "00:15.750",
      "text": "夕阳躲云偷看",
      "translation": null
    },
    {
      "time": 19.53,
      "time_str": "00:19.530",
      "text": "看见金色的沙滩上",
      "translation": null
    },
    {
      "time": 24.42,
      "time_str": "00:24.420",
      "text": "独坐一位美丽的姑娘",
      "translation": null
    },
    {
      "time": 30.69,
      "time_str": "00:30.690",
      "text": "眼睛星样灿烂",
      "translation": null
    },
    {
      "time": 35.48,
      "time_str": "00:35.480",
      "text": "眉似星月弯弯",
      "translation": null
    },
    {
      "time": 39.15,
      "time_str": "00:39.150",
      "text": "穿着一件红色的纱笼",
      "translation": null
    },
    {
      "time": 44.26,
      "time_str": "00:44.260",
      "text": "红得像她嘴上的槟榔",
      "translation": null
    },
    {
      "time": 50.36,
      "time_str": "00:50.360",
      "text": "她在轻叹",
      "translation": null
    },
    {
      "time": 55.03,
      "time_str": "00:55.030",
      "text": "叹那无情郎",
      "translation": null
    },
    {
      "time": 59.9,
      "time_str": "00:59.900",
      "text": "想到泪汪汪",
      "translation": null
    },
    {
      "time": 64.82,
      "time_str": "01:04.820",
      "text": "湿了红色纱笼白衣裳",
      "translation": null
    },
    {
      "time": 70.46,
      "time_str": "01:10.460",
      "text": "呀南海姑娘",
      "translation": null
    },
    {
      "time": 75.09,
      "time_str": "01:15.090",
      "text": "何必太过悲伤",
      "translation": null
    },
    {
      "time": 78.52,
      "time_str": "01:18.520",
      "text": "年纪轻轻只十六半",
      "translation": null
    },
    {
      "time": 83.54,
      "time_str": "01:23.540",
      "text": "旧梦失去有新侣作伴",
      "translation": null
