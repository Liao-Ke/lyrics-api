  "lyrics": [
    {
      "time": 22.87,
      "time_str": "00:22.870",
      "text": "夜里难以入睡　用什么可以麻醉",
      "translation": null
    },
    {
      "time": 28.66,
      "time_str": "00:28.660",
      "text": "情绪太多怎堪面对",
      "translation": null
    },
    {
      "time": 36.61,
      "time_str": "00:36.610",
      "text": "不是不要你陪　有些事你无法体会",
      "translation": null
    },
    {
      "time": 46.41,
      "time_str": "00:46.410",
      "text": "卸下了防备 孤独跟随",
      "translation": null
    },
    {
      "time": 54.05,
      "time_str": "00:54.050",
      "text": "我想要一个自己的空间",
      "translation": null
    },
    {
      "time": 60.7,
      "time_str": "01:00.700",
      "text": "能够好好想想我们之间的明天",
      "translation": null
    },
    {
      "time": 65.34,
      "time_str": "01:05.340",
      "text": "如果爱情不如我们想像的甜美",
      "translation": null
    },
    {
      "time": 69.42,
      "time_str": "01:09.420",
      "text": "那么所有的罪让我来背",
      "translation": null
    },
    {
      "time": 74.73,
      "time_str": "01:14.730",
      "text": "我的心太乱　要一些空白",
      "translation": null
    },
    {
      "time": 78.49,
      "time_str": "01:18.490",
      "text": "你若是明白　让我暂时的离开",
      "translation": null
    },
    {
      "time": 82.92,
      "time_str": "01:22.920",
      "text": "我的心太乱　不敢再贪更多爱",
      "translation": null
    },
    {
      "time": 87.15,
      "time_str": "01:27.150",
      "text": "想哭的我　却怎么哭也哭不出来",
      "translation": null
    },
    {
      "time": 93.36,
      "time_str": "01:33.360",
      "text": "我的心太乱　要一些空白",
      "translation": null
    },
    {
      "time": 97.91,
      "time_str": "01:37.910",
      "text": "老天在不在　忘了为我来安排",
      "translation": null
    },
    {
      "time": 102.27,
      "time_str": "01:42.270",
      "text": "我的心太乱　害怕爱情的背叛",
      "translation": null
    },
    {
      "time": 106.59,
      "time_str": "01:46.590",
      "text": "想哭的我像是一个迷路小孩",
      "translation": null
    },
    {
      "time": 112.8,
      "time_str": "01:52.800",
      "text": "迷路的小孩",
      "translation": null
    },
