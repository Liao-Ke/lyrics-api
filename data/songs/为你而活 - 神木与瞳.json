  "lyrics": [
    {
      "time": 27.05,
      "time_str": "00:27.050",
      "text": "看生命 像阵风",
      "translation": null
    },
    {
      "time": 33.6,
      "time_str": "00:33.600",
      "text": "抱不住的痛 所以紧握双手",
      "translation": null
    },
    {
      "time": 41.27,
      "time_str": "00:41.270",
      "text": "抬起头 那流星般的笑容",
      "translation": null
    },
    {
      "time": 48.61,
      "time_str": "00:48.610",
      "text": "只不过 坠落在心中",
      "translation": null
    },
    {
      "time": 55.28,
      "time_str": "00:55.280",
      "text": "天空会裂缝 我肩头",
      "translation": null
    },
    {
      "time": 59.72,
      "time_str": "00:59.720",
      "text": "添上的爱那么重",
      "translation": null
    },
    {
      "time": 62.72,
      "time_str": "01:02.720",
      "text": "就不怕 滂沱",
      "translation": null
    },
    {
      "time": 69.75,
      "time_str": "01:09.750",
      "text": "用眼泪庆贺 跨过了",
      "translation": null
    },
    {
      "time": 73.88,
      "time_str": "01:13.880",
      "text": "坚信这一扇门后",
      "translation": null
    },
    {
      "time": 76.8,
      "time_str": "01:16.800",
      "text": "真的有 天国",
      "translation": null
    },
    {
      "time": 83.43,
      "time_str": "01:23.430",
      "text": "为了你而活 为了你而梦",
      "translation": null
    },
    {
      "time": 87.58,
      "time_str": "01:27.580",
      "text": "为了爱我会撑到最后",
      "translation": null
    },
    {
      "time": 90.93,
      "time_str": "01:30.930",
      "text": "当世界都乌有",
      "translation": null
    },
    {
      "time": 94.55,
      "time_str": "01:34.550",
      "text": "守着你的人是我",
      "translation": null
    },
    {
      "time": 97.76,
      "time_str": "01:37.760",
      "text": "为了你而活 为了你而梦",
      "translation": null
    },
    {
      "time": 101.45,
      "time_str": "01:41.450",
      "text": "伤痕再深心无法划破",
      "translation": null
    },
    {
      "time": 104.94,
      "time_str": "01:44.940",
      "text": "跟命运在逆流 就算错了",
      "translation": null
    },
    {
      "time": 111.86,
      "time_str": "01:51.860",
      "text": "也不退后",
      "translation": null
    },
    {
      "time": 132.82,
      "time_str": "02:12.820",
      "text": "不闪躲 在这荆棘遍布中",
      "translation": null
    },
    {
