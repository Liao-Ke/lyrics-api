{
  "title": "最佳损友",
  "title_raw": "最佳损友",
  "version": null,
  "artist": "陈奕迅",
  "group_key": "最佳损友|陈奕迅",
  "writers": {
    "lyricist": "黄伟文",
    "composer": "Eric Kwok",
    "arranger": "Eric Kwok/Jerald"
  },
  "lyrics": [
    {
      "time": 0.9,
      "time_str": "00:00.900",
      "text": "朋友 我当你一秒朋友",
      "translation": null
    },
    {
      "time": 7.081,
      "time_str": "00:07.081",
      "text": "朋友 我当你一世朋友",
      "translation": null
    },
    {
      "time": 13.691,
      "time_str": "00:13.691",
      "text": "奇怪 过去再不堪回首",
      "translation": null
    },
    {
      "time": 20.46,
      "time_str": "00:20.460",
      "text": "怀缅 时时其实还有",
      "translation": null
    },
    {
      "time": 27.047,
      "time_str": "00:27.047",
      "text": "朋友 你试过将我营救",
      "translation": null
    },
    {
      "time": 33.797,
      "time_str": "00:33.797",
      "text": "朋友 你试过把我批斗",
      "translation": null
    },
    {
      "time": 40.401,
      "time_str": "00:40.401",
      "text": "无法 再与你交心联手",
      "translation": null
    },
    {
      "time": 46.241,
      "time_str": "00:46.241",
      "text": "毕竟 难得有过最佳损友",
      "translation": null
    },
    {
      "time": 52.169,
      "time_str": "00:52.169",
      "text": "从前共你 促膝把酒",
      "translation": null
    },
    {
      "time": 54.987,
      "time_str": "00:54.987",
      "text": "倾通宵都不够",
      "translation": null
    },
    {
      "time": 56.531,
      "time_str": "00:56.531",
      "text": "我有痛快过 你有没有",
      "translation": null
    },
    {
      "time": 60.851,
      "time_str": "01:00.851",
      "text": "很多东西今生只可给你",
      "translation": null
    },
    {
      "time": 63.21,
      "time_str": "01:03.210",
      "text": "保守至到永久",
      "translation": null
    },
    {
      "time": 65.004,
      "time_str": "01:05.004",
      "text": "别人如何明白透",
      "translation": null
    },
    {
      "time": 67.441,
      "time_str": "01:07.441",
      "text": "实实在在 踏入过我宇宙",
      "translation": null
    },
    {
      "time": 69.849,
      "time_str": "01:09.849",
      "text": "即使相处到 有个裂口",
      "translation": null
    },
    {
      "time": 73.343,
      "time_str": "01:13.343",
      "text": "命运决定了 以后再没法聚头",
      "translation": null
    },
    {
      "time": 76.908,
      "time_str": "01:16.908",
      "text": "但说过去 却那样厚",
      "translation": null
    },
    {
      "time": 79.631,
      "time_str": "01:19.631",
      "text": "问我有没有 确实也没有",
      "translation": null
    },
    {
      "time": 82.851,
      "time_str": "01:22.851",
      "text": "一直躲避的借口 非甚么大仇",
      "translation": null
    },
    {
      "time": 86.145,
      "time_str": "01:26.145",
      "text": "为何旧知己 在最后",
      "translation": null
    },
    {
      "time": 89.574,
      "time_str": "01:29.574",
      "text": "变不到老友",
      "translation": null
    },
    {
      "time": 92.844,
      "time_str": "01:32.844",
      "text": "不知你是我敌友 已没法望透",
      "translation": null
    },
    {
      "time": 96.573,
      "time_str": "01:36.573",
      "text": "被推着走 跟着生活流",
      "translation": null
    },
    {
      "time": 99.493,
      "time_str": "01:39.493",
      "text": "来年陌生的",
      "translation": null
    },
    {
      "time": 101.617,
      "time_str": "01:41.617",
      "text": "是昨日最亲的某某",
      "translation": null
    },
    {
      "time": 110.868,
      "time_str": "01:50.868",
      "text": "生死之交当天不知罕有",
      "translation": null
    },
    {
      "time": 113.298,
      "time_str": "01:53.298",
      "text": "到你变节了 至觉未够",
      "translation": null
    },
    {
      "time": 117.411,
      "time_str": "01:57.411",
      "text": "多想一天 彼此都不追究",
      "translation": null
    },
    {
      "time": 119.923,
      "time_str": "01:59.923",
      "text": "相邀再次喝酒",
      "translation": null
    },
    {
      "time": 121.629,
      "time_str": "02:01.629",
      "text": "待 葡萄成熟透",
      "translation": null
    },
    {
      "time": 124.106,
      "time_str": "02:04.106",
      "text": "但是命运入面 每个邂逅",
      "translation": null
    },
    {
      "time": 126.537,
      "time_str": "02:06.537",
      "text": "一起走到了 某个路口",
      "translation": null
    },
    {
      "time": 129.955,
      "time_str": "02:09.955",
      "text": "是敌与是友 各自也没有自由",
      "translation": null
    },
    {
      "time": 133.506,
      "time_str": "02:13.506",
      "text": "位置变了 各有队友",
      "translation": null
    },
    {
      "time": 136.234,
      "time_str": "02:16.234",
      "text": "问我有没有 确实也没有",
      "translation": null
    },
    {
      "time": 139.554,
      "time_str": "02:19.554",
      "text": "一直躲避的借口 非甚么大仇",
      "translation": null
    },
    {
      "time": 142.767,
      "time_str": "02:22.767",
      "text": "为何旧知己 在最后",
      "translation": null
    },
    {
      "time": 146.142,
      "time_str": "02:26.142",
      "text": "变不到老友",
      "translation": null
    },
    {
      "time": 149.481,
      "time_str": "02:29.481",
      "text": "不知你是我敌友 已没法望透",
      "translation": null
    },
    {
      "time": 153.258,
      "time_str": "02:33.258",
      "text": "被推着走 跟着生活流",
      "translation": null
    },
    {
      "time": 156.138,
      "time_str": "02:36.138",
      "text": "来年陌生的",
      "translation": null
    },
    {
      "time": 158.199,
      "time_str": "02:38.199",
      "text": "是昨日最亲的某某",
      "translation": null
    },
    {
      "time": 161.528,
      "time_str": "02:41.528",
      "text": "早知解散后 各自有际遇作导游",
      "translation": null
    },
    {
      "time": 166.188,
      "time_str": "02:46.188",
      "text": "奇就奇在 接受了 各自有路走",
      "translation": null
    },
    {
      "time": 169.493,
      "time_str": "02:49.493",
      "text": "却没人像你 让我 眼泪背着流",
      "translation": null
    },
    {
      "time": 172.794,
      "time_str": "02:52.794",
      "text": "严重似情侣 讲分手",
      "translation": null
    },
    {
      "time": 190.314,
      "time_str": "03:10.314",
      "text": "有没有 确实也没有",
      "translation": null
    },
    {
      "time": 192.832,
      "time_str": "03:12.832",
      "text": "一直躲避的借口 非甚么大仇",
      "translation": null
    },
    {
      "time": 196.127,
      "time_str": "03:16.127",
      "text": "为何旧知己 在最后 变不到老友",
      "translation": null
    },
    {
      "time": 202.82,
      "time_str": "03:22.820",
      "text": "不知你又有没有 挂念这旧友",
      "translation": null
    },
    {
      "time": 206.647,
      "time_str": "03:26.647",
      "text": "或者自己 早就想通透",
      "translation": null
    },
    {
      "time": 209.442,
      "time_str": "03:29.442",
      "text": "来年陌生的 是昨日 最亲的某某",
      "translation": null
    },
    {
      "time": 214.779,
      "time_str": "03:34.779",
      "text": "总好于 那日我 没有",
      "translation": null
    },
    {
      "time": 219.925,
      "time_str": "03:39.925",
      "text": "没有 遇过 某某",
      "translation": null
    },
