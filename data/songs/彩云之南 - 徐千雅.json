  "lyrics": [
    {
      "time": 27.83,
      "time_str": "00:27.830",
      "text": "彩云之南 我心的方向",
      "translation": null
    },
    {
      "time": 33.47,
      "time_str": "00:33.470",
      "text": "孔雀飞去 回忆悠长",
      "translation": null
    },
    {
      "time": 39.31,
      "time_str": "00:39.310",
      "text": "玉龙雪山 闪耀着银光",
      "translation": null
    },
    {
      "time": 45.44,
      "time_str": "00:45.440",
      "text": "秀色丽江 人在路上",
      "translation": null
    },
    {
      "time": 50.77,
      "time_str": "00:50.770",
      "text": "彩云之南 归去的地方",
      "translation": null
    },
    {
      "time": 56.45,
      "time_str": "00:56.450",
      "text": "往事芬芳 随风飘扬",
      "translation": null
    },
    {
      "time": 62.24,
      "time_str": "01:02.240",
      "text": "蝴蝶泉边 歌声在流淌",
      "translation": null
    },
    {
      "time": 68.3,
      "time_str": "01:08.300",
      "text": "泸沽湖畔 心仍荡漾",
      "translation": null
    },
    {
      "time": 73.93,
      "time_str": "01:13.930",
      "text": "记得那时那里的天多湛蓝",
      "translation": null
    },
    {
      "time": 77.389,
      "time_str": "01:17.389",
      "text": "你的眼里闪着温柔的阳光",
      "translation": null
    },
    {
      "time": 80.24,
      "time_str": "01:20.240",
      "text": "这世界变幻无常 如今你又在何方",
      "translation": null
    },
    {
      "time": 85.93,
      "time_str": "01:25.930",
      "text": "原谅我无法陪你走那么长",
      "translation": null
    },
    {
      "time": 88.48,
      "time_str": "01:28.480",
      "text": "别人的天堂不是我们的远方",
      "translation": null
    },
    {
      "time": 92.1,
      "time_str": "01:32.100",
      "text": "不虚此行别遗憾",
      "translation": null
    },
