    {
      "time": 13.599,
      "time_str": "00:13.599",
      "text": "啦...啦... 啦...",
      "translation": null
    },
    {
      "time": 20.599,
      "time_str": "00:20.599",
      "text": "啦...啦... 啦...",
      "translation": null
    },
    {
      "time": 26.599,
      "time_str": "00:26.599",
      "text": "我要你陪着我 看着那海龟水中游",
      "translation": null
    },
    {
      "time": 32.6,
      "time_str": "00:32.600",
      "text": "慢慢的趴在沙滩上 数着浪花一朵朵",
      "translation": null
    },
    {
      "time": 38.6,
      "time_str": "00:38.600",
      "text": "你不要害怕 你不会寂寞",
      "translation": null
    },
    {
      "time": 45.6,
      "time_str": "00:45.600",
      "text": "我会一直陪在你的左右 让你乐悠悠",
      "translation": null
    },
    {
      "time": 53.6,
      "time_str": "00:53.600",
      "text": "日子一天一天过 我们会慢慢长大",
      "translation": null
    },
    {
      "time": 59.6,
      "time_str": "00:59.600",
      "text": "我不管你懂不懂我在唱什么噢",
      "translation": null
    },
    {
      "time": 65.6,
      "time_str": "01:05.600",
      "text": "我知道有一天 你 一定会爱上我",
      "translation": null
    },
    {
      "time": 71.6,
      "time_str": "01:11.600",
      "text": "因为我觉得我真的很不错噢",
      "translation": null
    },
    {
      "time": 77.6,
      "time_str": "01:17.600",
      "text": "时光匆匆匆匆流走 也也也不回头",
      "translation": null
    },
    {
      "time": 81.6,
      "time_str": "01:21.600",
      "text": "美女变成老太婆 哎哟那那那个时候",
      "translation": null
    },
    {
      "time": 86.6,
      "time_str": "01:26.600",
      "text": "我我我我也也 已经是个糟老头",
      "translation": null
    },
    {
      "time": 90.6,
      "time_str": "01:30.600",
      "text": "啦...啦... 我们一起手牵手",
      "translation": null
    },
    {
      "time": 96.6,
      "time_str": "01:36.600",
      "text": "啦...啦... 数着浪花一朵朵",
