  "lyrics": [
    {
      "time": 17.169,
      "time_str": "00:17.169",
      "text": "那片笑声让我想起我的那些花儿",
      "translation": null
    },
    {
      "time": 24.74,
      "time_str": "00:24.740",
      "text": "在我生命每个角落静静为我开着",
      "translation": null
    },
    {
      "time": 33.2,
      "time_str": "00:33.200",
      "text": "我曾以为我会永远守在他身旁",
      "translation": null
    },
    {
      "time": 41.7,
      "time_str": "00:41.700",
      "text": "今天我们已经离去在人海茫茫",
      "translation": null
    },
    {
      "time": 49.34,
      "time_str": "00:49.340",
      "text": "他们都老了吧？",
      "translation": null
    },
    {
      "time": 53.2,
      "time_str": "00:53.200",
      "text": "他们在哪里呀？",
      "translation": null
    },
    {
      "time": 57.7,
      "time_str": "00:57.700",
      "text": "我们就这样各自奔天涯",
      "translation": null
    },
    {
      "time": 66.58,
      "time_str": "01:06.580",
      "text": "啦……想她。",
      "translation": null
    },
    {
      "time": 74.67,
      "time_str": "01:14.670",
      "text": "啦…她还在开吗？",
      "translation": null
    },
    {
      "time": 82.79,
      "time_str": "01:22.790",
      "text": "啦……去呀！",
      "translation": null
    },
    {
      "time": 90.89,
      "time_str": "01:30.890",
      "text": "她们已经被风吹走散落在天涯",
      "translation": null
    },
    {
      "time": 116.31,
      "time_str": "01:56.310",
      "text": "有些故事还没讲完那就算了吧",
      "translation": null
    },
    {
      "time": 124.2,
      "time_str": "02:04.200",
      "text": "那些心情在岁月中已经难辨真假",
      "translation": null
    },
    {
      "time": 132.609,
      "time_str": "02:12.609",
      "text": "如今这里荒草丛生没有了鲜花",
      "translation": null
    },
    {
