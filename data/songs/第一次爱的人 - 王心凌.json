    {
      "time": 181.234,
      "time_str": "03:01.234",
      "text": "有一天　也许我能把自己治好",
      "translation": null
    },
    {
      "time": 185.526,
      "time_str": "03:05.526",
      "text": "再一次想起来　应该要怎么笑",
      "translation": null
    },
    {
      "time": 191.013,
      "time_str": "03:11.013",
      "text": "第一次爱的人他的坏他的好",
      "translation": null
