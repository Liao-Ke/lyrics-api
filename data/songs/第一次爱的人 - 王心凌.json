  "lyrics": [
    {
      "time": 20.342,
      "time_str": "00:20.342",
      "text": "灰色的天　你的脸",
      "translation": null
    },
    {
      "time": 24.956,
      "time_str": "00:24.956",
      "text": "爱过也哭过笑过痛过之后只剩再见",
      "translation": null
    },
    {
      "time": 30.051,
      "time_str": "00:30.051",
      "text": "我的眼泪　湿了脸",
      "translation": null
    },
    {
      "time": 35.489,
      "time_str": "00:35.489",
      "text": "失去第一次爱的人竟然是这种感觉",
      "translation": null
    },
    {
      "time": 40.543,
      "time_str": "00:40.543",
      "text": "总以为　爱是全部的心跳　失去爱我们就要",
      "translation": null
    },
    {
      "time": 47.095,
      "time_str": "00:47.095",
      "text": "就要　一点点慢慢地死掉",
      "translation": null
    },
    {
      "time": 51.197,
      "time_str": "00:51.197",
      "text": "当我　失去你那一秒　心突然就变老",
      "translation": null
    },
    {
      "time": 58.252,
      "time_str": "00:58.252",
      "text": "The day you went away",
      "translation": null
    },
    {
      "time": 60.853,
      "time_str": "01:00.853",
      "text": "喧闹的街　没发现我的泪　被遗忘在街角",
      "translation": null
    },
    {
      "time": 67.65,
      "time_str": "01:07.650",
      "text": "The day you went away",
      "translation": null
    },
    {
      "time": 83.877,
      "time_str": "01:23.877",
      "text": "我看着你　走过街",
      "translation": null
    },
    {
      "time": 89.256,
      "time_str": "01:29.256",
      "text": "还穿着去年夏天我送你的那双球鞋",
      "translation": null
    },
    {
      "time": 93.986,
      "time_str": "01:33.986",
      "text": "银色手链　还耀眼",
      "translation": null
    },
    {
      "time": 99.264,
      "time_str": "01:39.264",
      "text": "你的世界似乎一点也没有因此改变",
      "translation": null
    },
