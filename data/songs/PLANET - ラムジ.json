  "lyrics": [
    {
      "time": 10.28,
      "time_str": "00:10.280",
      "text": "どうやってこうやって",
      "translation": "要怎么做？就这么做"
    },
    {
      "time": 13.93,
      "time_str": "00:13.930",
      "text": "またほら君と話そうか",
      "translation": "现在还能和你说话吧"
    },
    {
      "time": 19.36,
      "time_str": "00:19.360",
      "text": "あれだってこれだって",
      "translation": "那样也好，这样也好"
    },
    {
      "time": 22.93,
      "time_str": "00:22.930",
      "text": "今すぐ気付いてくれ",
      "translation": "真希望现在你能快点觉察到我"
    },
    {
      "time": 28.42,
      "time_str": "00:28.420",
      "text": "僕は君の惑星",
      "translation": "我是一颗不停地围绕你"
    },
    {
      "time": 32.99,
      "time_str": "00:32.990",
      "text": "回り続けて",
      "translation": "转动的行星"
    },
    {
      "time": 37.51,
      "time_str": "00:37.510",
      "text": "いつも君のそばで",
      "translation": "我本会一直在你的身边"
    },
    {
      "time": 41.98,
      "time_str": "00:41.980",
      "text": "黒点数えてたけれど",
      "translation": "即使只是细数你的小缺点"
    },
    {
      "time": 47.15,
      "time_str": "00:47.150",
      "text": "サヨナラなんてないよ",
      "translation": "不要说再见"
    },
    {
      "time": 51.66,
      "time_str": "00:51.660",
      "text": "今日から軌道を外れんだ",
      "translation": "今天我要开始偏离你的轨道"
    },
    {
      "time": 56.13,
      "time_str": "00:56.130",
      "text": "最後まで見送ってよ",
      "translation": "目送你，直到最后"
    },
    {
      "time": 60.71,
      "time_str": "01:00.710",
      "text": "永遠に離れてくんだ",
      "translation": "因为我将要永远与你分离"
    },
    {
      "time": 65.17,
      "time_str": "01:05.170",
      "text": "lalala",
      "translation": "ラララ ララララララ"
    },
    {
