    {
      "time": 92.96,
      "time_str": "01:32.960",
      "text": "どうなってこうなって",
      "translation": "为什么会变成这样"
    },
    {
      "time": 96.6,
      "time_str": "01:36.600",
      "text": "結局独り佇んで",
      "translation": "最终仍旧是我独自一人伫立在这"
    },
    {
      "time": 102.01,
      "time_str": "01:42.010",
      "text": "失って勘づいて",
      "translation": "失去之后才意识到"
    },
    {
      "time": 105.66,
      "time_str": "01:45.660",
      "text": "今さら戻れやしない",
      "translation": "事到如今再也回不去了"
    },
    {
      "time": 111.02,
      "time_str": "01:51.020",
      "text": "君のいない場所で",
      "translation": "在没有你的场所"
    },
    {
      "time": 115.6,
      "time_str": "01:55.600",
      "text": "途方に暮れて",
      "translation": "我完全不知所措"
    },
    {
      "time": 120.07,
      "time_str": "02:00.070",
      "text": "もう一度引力を",
      "translation": "你对我的吸引力"
    },
    {
      "time": 124.71,
      "time_str": "02:04.710",
      "text": "感じたかったんだけれど",
      "translation": "到现在都还想感受一下"
    },
    {
      "time": 128.65,
      "time_str": "02:08.650",
      "text": "神様なんていないよ",
      "translation": "这世上并没有什么神明"
    },
    {
      "time": 133.18,
      "time_str": "02:13.180",
      "text": "いつまで待っても巡回中",
      "translation": "无论期盼到何时都只能在自己的轨道中巡回"
    },
    {
      "time": 137.73,
      "time_str": "02:17.730",
      "text": "選ばれない悲しみを",
      "translation": "没有被选择的悲伤"
    },
    {
      "time": 142.15,
      "time_str": "02:22.150",
      "text": "何度でも噛みしめるんだ",
      "translation": "究竟还要再尝多少次"
    },
    {
