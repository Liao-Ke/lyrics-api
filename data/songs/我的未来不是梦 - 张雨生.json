  "lyrics": [
    {
      "time": 24.068,
      "time_str": "00:24.068",
      "text": "你是不是像我在太阳下低头",
      "translation": null
    },
    {
      "time": 31.629,
      "time_str": "00:31.629",
      "text": "流着汗水默默辛苦地工作",
      "translation": null
    },
    {
      "time": 39.209,
      "time_str": "00:39.209",
      "text": "你是不是像我就算受了冷落",
      "translation": null
    },
    {
      "time": 46.803,
      "time_str": "00:46.803",
      "text": "也不放弃自己想要的生活",
      "translation": null
    },
    {
      "time": 54.393,
      "time_str": "00:54.393",
      "text": "你是不是像我整天忙着追求",
      "translation": null
    },
    {
      "time": 61.963,
      "time_str": "01:01.963",
      "text": "追求一种意想不到的温柔",
      "translation": null
    },
    {
      "time": 69.476,
      "time_str": "01:09.476",
      "text": "你是不是像我曾经茫然失措",
      "translation": null
    },
    {
      "time": 77.075,
      "time_str": "01:17.075",
      "text": "一次一次徘徊在十字街头",
      "translation": null
    },
    {
      "time": 83.243,
      "time_str": "01:23.243",
      "text": "因为我不在乎 别人怎么说",
      "translation": null
    },
    {
      "time": 91.518,
      "time_str": "01:31.518",
      "text": "我从来没有忘记我",
      "translation": null
    },
    {
      "time": 95.264,
      "time_str": "01:35.264",
      "text": "对自己的承诺",
      "translation": null
    },
    {
      "time": 99.767,
      "time_str": "01:39.767",
      "text": "对爱的执着",
      "translation": null
    },
    {
      "time": 105.946,
      "time_str": "01:45.946",
      "text": "我知道我的未来不是梦",
      "translation": null
    },
    {
      "time": 112.67,
      "time_str": "01:52.670",
      "text": "我认真地过每一分钟",
      "translation": null
    },
    {
      "time": 116.724,
      "time_str": "01:56.724",
      "text": "我的未来不是梦",
      "translation": null
    },
    {
      "time": 120.079,
      "time_str": "02:00.079",
      "text": "我的心跟着希望在动",
      "translation": null
    },
