  "lyrics": [
    {
      "time": 46.538,
      "time_str": "00:46.538",
      "text": "光 轻如纸张",
      "translation": null
    },
    {
      "time": 47.85,
      "time_str": "00:47.850",
      "text": "光 散落地方",
      "translation": null
    },
    {
      "time": 49.187,
      "time_str": "00:49.187",
      "text": "光 在掌声渐息中它慌忙",
      "translation": null
    },
    {
      "time": 51.925,
      "time_str": "00:51.925",
      "text": "她在传唱 不堪的伤",
      "translation": null
    },
    {
      "time": 54.562,
      "time_str": "00:54.562",
      "text": "脚本在台上 演出最后一场",
      "translation": null
    },
    {
      "time": 57.295,
      "time_str": "00:57.295",
      "text": "而全村的人们在座位上",
      "translation": null
    },
    {
      "time": 59.623,
      "time_str": "00:59.623",
      "text": "静静的看 时间如何遗弃这剧场",
      "translation": null
    },
    {
      "time": 62.639,
      "time_str": "01:02.639",
      "text": "战火弄脏 她的泪光",
      "translation": null
    },
    {
      "time": 64.011,
      "time_str": "01:04.011",
      "text": "谁在风中 吵着吃糖",
      "translation": null
    },
    {
      "time": 65.355,
      "time_str": "01:05.355",
      "text": "这故事一开始的镜头灰尘就已经遮蔽了阳光",
      "translation": null
    },
    {
      "time": 67.741,
      "time_str": "01:07.741",
      "text": "ㄅㄧㄤˋ",
      "translation": null
    },
    {
      "time": 68.086,
      "time_str": "01:08.086",
      "text": "恐惧刻在孩子们脸上",
      "translation": null
    },
    {
      "time": 70.21,
      "time_str": "01:10.210",
      "text": "麦田已倒向战车经过的方向",
      "translation": null
    },
    {
      "time": 72.932,
      "time_str": "01:12.932",
      "text": "蒲公英的形状 在飘散",
      "translation": null
    },
    {
      "time": 74.822,
      "time_str": "01:14.822",
      "text": "它绝望 的飞翔",
      "translation": null
    },
    {
      "time": 76.165,
      "time_str": "01:16.165",
      "text": "她只唱 只想",
      "translation": null
    },
    {
      "time": 77.471,
      "time_str": "01:17.471",
      "text": "这首止战 之殇",
      "translation": null
    },
    {
      "time": 78.846,
      "time_str": "01:18.846",
      "text": "恶夜燃烛光 天破息战乱",
      "translation": null
    },
    {
      "time": 81.555,
      "time_str": "01:21.555",
      "text": "殇歌传千里 家乡平饥荒",
      "translation": null
    },
    {
      "time": 84.223,
      "time_str": "01:24.223",
      "text": "天真在这条路上",
      "translation": null
    },
    {
      "time": 86.633,
      "time_str": "01:26.633",
      "text": "跌跌撞撞",
      "translation": null
    },
    {
      "time": 87.938,
      "time_str": "01:27.938",
      "text": "她被芒草割伤",
      "translation": null
    },
    {
      "time": 89.65,
      "time_str": "01:29.650",
      "text": "孩子们眼中的希望 是什么形状",
      "translation": null
    },
    {
      "time": 94.662,
      "time_str": "01:34.662",
      "text": "是否醒来有面包当早餐 再喝碗热汤",
      "translation": null
    },
    {
      "time": 100.057,
      "time_str": "01:40.057",
      "text": "农夫被烧毁土地跟村庄 终于拿起枪",
      "translation": null
    },
    {
      "time": 105.449,
      "time_str": "01:45.449",
      "text": "她却慢慢习惯放弃了抵抗",
      "translation": null
    },
    {
      "time": 111.22,
      "time_str": "01:51.220",
      "text": "孩子们眼中的希望 是什么形状",
      "translation": null
    },
    {
      "time": 116.244,
      "time_str": "01:56.244",
      "text": "是否院子有秋千可以荡 口袋里有糖",
      "translation": null
    },
    {
      "time": 121.626,
      "time_str": "02:01.626",
      "text": "刺刀的光被仇恨所擦亮 在远方野蛮",
      "translation": null
    },
    {
      "time": 127.028,
      "time_str": "02:07.028",
      "text": "而她却微笑着不知道慌张",
      "translation": null
    },
    {
      "time": 149.008,
      "time_str": "02:29.008",
      "text": "恐惧刻在孩子们脸上",
      "translation": null
