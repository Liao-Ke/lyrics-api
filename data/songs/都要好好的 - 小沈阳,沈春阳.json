  "lyrics": [
    {
      "time": 11.19,
      "time_str": "00:11.190",
      "text": "唱一首情歌送给我的老婆",
      "translation": null
    },
    {
      "time": 16.5,
      "time_str": "00:16.500",
      "text": "这么多年你默默付出真的辛苦了",
      "translation": null
    },
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "艰难幸福的岁月我们曾一起走过",
      "translation": null
    },
    {
      "time": 26.85,
      "time_str": "00:26.850",
      "text": "眼泪笑声填满了我们平凡的生活",
      "translation": null
    },
    {
      "time": 32.5,
      "time_str": "00:32.500",
      "text": "亲爱的你是我生命中的一首歌",
      "translation": null
    },
    {
      "time": 37.81,
      "time_str": "00:37.810",
      "text": "有动人的篇章有真实的快乐",
      "translation": null
    },
    {
      "time": 42.94,
      "time_str": "00:42.940",
      "text": "这么多年我知道你是苦苦奋斗着",
      "translation": null
    },
    {
      "time": 48.7,
      "time_str": "00:48.700",
      "text": "为了我们的家为了孩子和我",
      "translation": null
    },
    {
      "time": 59.43,
      "time_str": "00:59.430",
      "text": "我们都说过无论 以后怎样都要好好的",
      "translation": null
    },
    {
      "time": 65.04,
      "time_str": "01:05.040",
      "text": "不要忘了当初有些天真许下的承诺",
      "translation": null
    },
    {
      "time": 70.44,
      "time_str": "01:10.440",
      "text": "男：当你不开心时让我为你唱首歌",
      "translation": null
    },
    {
      "time": 75.84,
      "time_str": "01:15.840",
      "text": "就算再大的风雨手拉手一起走过",
      "translation": null
    },
    {
      "time": 81.5,
      "time_str": "01:21.500",
      "text": "我们都说过无论贫穷富有都要好好的",
      "translation": null
    },
    {
      "time": 86.93,
      "time_str": "01:26.930",
      "text": "不要忘了当初我们的路是怎样走过",
      "translation": null
    },
    {
      "time": 92.31,
      "time_str": "01:32.310",
      "text": "男：当你伤心的时候 女：就请对我诉说",
      "translation": null
    },
    {
      "time": 97.89,
      "time_str": "01:37.890",
      "text": "等到老的时候一起 看日落",
      "translation": null
