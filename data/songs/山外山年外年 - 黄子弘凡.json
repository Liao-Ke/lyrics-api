    },
    {
      "time": 32.49,
      "time_str": "00:32.490",
      "text": "谁在闺中抛残绣线",
      "translation": null
    },
    {
      "time": 40.14,
      "time_str": "00:40.140",
      "text": "谁在铜镜顾影自怜",
      "translation": null
    },
    {
      "time": 46.7,
      "time_str": "00:46.700",
      "text": "晓来梅花开遍",
      "translation": null
    },
    {
      "time": 50.94,
      "time_str": "00:50.940",
      "text": "折一朵送到你面前",
      "translation": null
    },
    {
      "time": 59.2,
      "time_str": "00:59.200",
      "text": "谁在红烛前宿妆残",
      "translation": null
    },
    {
      "time": 66.73,
      "time_str": "01:06.730",
      "text": "谁在窗边等待少年",
      "translation": null
    },
    {
      "time": 73.68,
      "time_str": "01:13.680",
      "text": "春来梦回莺啭",
      "translation": null
    },
    {
      "time": 77.64,
      "time_str": "01:17.640",
      "text": "望断年光风尘傍晚",
      "translation": null
    },
    {
      "time": 84.79,
      "time_str": "01:24.790",
      "text": "君不见牡丹开遍山外山",
