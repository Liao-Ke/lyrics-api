    {
      "time": 15.254,
      "time_str": "00:15.254",
      "text": "天上下凡三圣母",
      "translation": null
    },
    {
      "time": 17.44,
      "time_str": "00:17.440",
      "text": "生下沉香和爹住",
      "translation": null
    },
    {
      "time": 21.38,
      "time_str": "00:21.380",
      "text": "沉香日夜哭着要寻母",
      "translation": null
    },
    {
      "time": 24.752,
      "time_str": "00:24.752",
      "text": "哭着哭着要寻母",
      "translation": null
    },
    {
      "time": 27.815,
      "time_str": "00:27.815",
      "text": "哮天犬追二郎神堵",
      "translation": null
    },
    {
      "time": 31.07,
      "time_str": "00:31.070",
      "text": "四大天王常拦路",
      "translation": null
    },
    {
      "time": 34.317,
      "time_str": "00:34.317",
      "text": "砸炼丹炉改生死薄",
      "translation": null
    },
    {
      "time": 35.881,
      "time_str": "00:35.881",
      "text": "背天书修法术",
      "translation": null
    },
    {
      "time": 37.57,
      "time_str": "00:37.570",
      "text": "应付自如",
      "translation": null
    },
    {
      "time": 40.695,
      "time_str": "00:40.695",
      "text": "玉皇大帝王母娘娘不食人间五谷",
      "translation": null
    },
    {
      "time": 43.948,
      "time_str": "00:43.948",
      "text": "也犯错误也犯错误也犯错误",
      "translation": null
    },
    {
      "time": 47.196,
      "time_str": "00:47.196",
      "text": "八戒悟空世间万物",
      "translation": null
    },
    {
      "time": 48.823,
      "time_str": "00:48.823",
      "text": "教我真功夫啊",
      "translation": null
    },
    {
      "time": 50.383,
      "time_str": "00:50.383",
      "text": "天兵天将天兵天将挡不住",
      "translation": null
    },
    {
      "time": 53.634,
      "time_str": "00:53.634",
      "text": "我是娘的全部",
