  "lyrics": [
    {
      "time": 19.69,
      "time_str": "00:19.690",
      "text": "你的拥抱像微风经过了树梢",
      "translation": null
    },
    {
      "time": 25.47,
      "time_str": "00:25.470",
      "text": "轻轻吹着那一边等待你的懊恼",
      "translation": null
    },
    {
      "time": 31.22,
      "time_str": "00:31.220",
      "text": "等了多久用不着让你知道",
      "translation": null
    },
    {
      "time": 35.23,
      "time_str": "00:35.230",
      "text": "噢 因为爱你比我重要",
      "translation": null
    },
    {
      "time": 42.78,
      "time_str": "00:42.780",
      "text": "你说抱歉我觉得总是忘不掉",
      "translation": null
    },
    {
      "time": 48.55,
      "time_str": "00:48.550",
      "text": "我只能用微笑来掩饰那种难熬",
      "translation": null
    },
    {
      "time": 54.27,
      "time_str": "00:54.270",
      "text": "有的悲伤总不想让你看到",
      "translation": null
    },
    {
      "time": 58.33,
      "time_str": "00:58.330",
      "text": "噢 你的快乐比我重要",
      "translation": null
    },
    {
      "time": 65.61,
      "time_str": "01:05.610",
      "text": "我对你太在意",
      "translation": null
    },
    {
      "time": 68.45,
      "time_str": "01:08.450",
      "text": "这辈都舍不得用力",
      "translation": null
    },
    {
      "time": 71.39,
      "time_str": "01:11.390",
      "text": "怕你又被伤了心",
      "translation": null
    },
    {
      "time": 75.23,
      "time_str": "01:15.230",
      "text": "如果我挥不去",
      "translation": null
    },
    {
      "time": 77.14,
      "time_str": "01:17.140",
      "text": "多努力的爱你",
      "translation": null
    },
    {
      "time": 80.6,
      "time_str": "01:20.600",
      "text": "直到都闭不上回忆",
      "translation": null
    },
    {
      "time": 82.56,
      "time_str": "01:22.560",
      "text": "我 我还是愿意",
      "translation": null
    },
    {
      "time": 89.75,
      "time_str": "01:29.750",
      "text": "陪着你忘记",
      "translation": null
    },
