{
  "title": "我的美丽feat.海洋Bo",
  "title_raw": "我的美丽feat.海洋Bo",
  "version": null,
  "artist": "海洋Bo,高睿",
  "group_key": "我的美丽feat.海洋bo|海洋bo,高睿",
  "writers": {
    "lyricist": "李蘑菇",
    "composer": "李蘑菇/秦四风",
    "arranger": "曾吴秋杰"
  },
  "lyrics": [
    {
      "time": 16.65,
      "time_str": "00:16.650",
      "text": "午后温暖的阳光温柔闪耀",
      "translation": null
    },
    {
      "time": 24.81,
      "time_str": "00:24.810",
      "text": "雨后绚烂的彩虹五彩斑斓",
      "translation": null
    },
    {
      "time": 31.8,
      "time_str": "00:31.800",
      "text": "炎热的夏日 一丝凉⻛ 掠过耳边",
      "translation": null
    },
    {
      "time": 40.02,
      "time_str": "00:40.020",
      "text": "一道美丽的风景 留恋留恋",
      "translation": null
    },
    {
      "time": 49.08,
      "time_str": "00:49.080",
      "text": "抚摸斑驳的树影转圈盘旋",
      "translation": null
    },
    {
      "time": 57.24,
      "time_str": "00:57.240",
      "text": "金色夕阳的呓语绕耳缠绵",
      "translation": null
    },
    {
      "time": 64.29,
      "time_str": "01:04.290",
      "text": "你看我看的 这个世界 美好至极",
      "translation": null
    },
    {
      "time": 72.45,
      "time_str": "01:12.450",
      "text": "你看呐我的所有 都是我的美丽",
      "translation": null
    },
    {
      "time": 81.3,
      "time_str": "01:21.300",
      "text": "生活的方式从来不换",
      "translation": null
    },
    {
      "time": 83.22,
      "time_str": "01:23.220",
      "text": "早上到傍晚也一成不变",
      "translation": null
    },
    {
      "time": 85.26,
      "time_str": "01:25.260",
      "text": "马路上的人们匆匆奔走",
      "translation": null
    },
    {
      "time": 87.12,
      "time_str": "01:27.120",
      "text": "安静的路口早已车满为患",
      "translation": null
    },
    {
      "time": 89.34,
      "time_str": "01:29.340",
      "text": "每个人的梦里都存在焦虑",
      "translation": null
    },
    {
      "time": 91.35,
      "time_str": "01:31.350",
      "text": "晚睡早起又白黑交替",
      "translation": null
    },
    {
      "time": 93.36,
      "time_str": "01:33.360",
      "text": "书包装的也换成压力",
      "translation": null
    },
    {
      "time": 95.28,
      "time_str": "01:35.280",
      "text": "在同世界却没共同话题",
      "translation": null
    },
    {
      "time": 97.35,
      "time_str": "01:37.350",
      "text": "也许还有人坐在",
      "translation": null
    },
    {
      "time": 99.33,
      "time_str": "01:39.330",
      "text": "回家的路口等你等你下班",
      "translation": null
    },
    {
      "time": 102.33,
      "time_str": "01:42.330",
      "text": "木质的圆桌摆满了他给你做的大餐",
      "translation": null
    },
    {
      "time": 106.35,
      "time_str": "01:46.350",
      "text": "千万不要放弃你所追求的东西",
      "translation": null
    },
    {
      "time": 109.77,
      "time_str": "01:49.770",
      "text": "我始终相信每个人都有独特的美丽",
      "translation": null
    },
    {
      "time": 130.47,
      "time_str": "02:10.470",
      "text": "抚摸斑驳的树影转圈盘旋",
      "translation": null
    },
    {
      "time": 138.6,
      "time_str": "02:18.600",
      "text": "金色夕阳的呓语绕耳缠绵",
      "translation": null
    },
    {
      "time": 145.68,
      "time_str": "02:25.680",
      "text": "你看我看的 这个世界 美好至极",
      "translation": null
    },
    {
      "time": 153.84,
      "time_str": "02:33.840",
      "text": "你看呐我的所有 都是我的美丽",
      "translation": null
    },
    {
      "time": 162.3,
      "time_str": "02:42.300",
      "text": "你说你受到了不公平",
      "translation": null
    },
    {
      "time": 164.43,
      "time_str": "02:44.430",
      "text": "可是大多人的生活也差不多",
      "translation": null
    },
    {
      "time": 166.35,
      "time_str": "02:46.350",
      "text": "要走的路刚好又不通行",
      "translation": null
    },
    {
      "time": 168.45,
      "time_str": "02:48.450",
      "text": "又背上莫名其妙的锅",
      "translation": null
    },
    {
      "time": 170.4,
      "time_str": "02:50.400",
      "text": "想去看看世界的另一边",
      "translation": null
    },
    {
      "time": 172.5,
      "time_str": "02:52.500",
      "text": "可是现在没钱也没时间",
      "translation": null
    },
    {
      "time": 174.54,
      "time_str": "02:54.540",
      "text": "往后又要拿钱换时间",
      "translation": null
    },
    {
      "time": 176.52,
      "time_str": "02:56.520",
      "text": "现在要拿时间换钱",
      "translation": null
    },
    {
      "time": 178.62,
      "time_str": "02:58.620",
      "text": "为什么",
      "translation": null
    },
    {
      "time": 179.61,
      "time_str": "02:59.610",
      "text": "这世界如此的悲观",
      "translation": null
    },
    {
      "time": 181.65,
      "time_str": "03:01.650",
      "text": "眼睛看到的只有黑暗",
      "translation": null
    },
    {
      "time": 183.69,
      "time_str": "03:03.690",
      "text": "18年都没女孩喜欢",
      "translation": null
    },
    {
      "time": 185.67,
      "time_str": "03:05.670",
      "text": "这种成就也相当极端",
      "translation": null
    },
    {
      "time": 187.77,
      "time_str": "03:07.770",
      "text": "刚攒好钱球鞋又涨价",
      "translation": null
    },
    {
      "time": 189.78,
      "time_str": "03:09.780",
      "text": "又被朋友们讽刺的想法",
      "translation": null
    },
    {
      "time": 191.79,
      "time_str": "03:11.790",
      "text": "幻想早被现实给绑架",
      "translation": null
    },
    {
      "time": 193.77,
      "time_str": "03:13.770",
      "text": "想要野马却只有桑塔纳",
      "translation": null
    },
    {
      "time": 195.69,
      "time_str": "03:15.690",
      "text": "（指尖）时间总不给我机会",
      "translation": null
    },
    {
      "time": 197.82,
      "time_str": "03:17.820",
      "text": "（旋转）也怪我追不到机位",
      "translation": null
    },
    {
      "time": 199.77,
      "time_str": "03:19.770",
      "text": "（萦绕）任何故事当不了主角做的决定也太过于愚昧",
      "translation": null
    },
    {
      "time": 204.15,
      "time_str": "03:24.150",
      "text": "（耳边）还好没人看见我失态",
      "translation": null
    },
    {
      "time": 205.74,
      "time_str": "03:25.740",
      "text": "（心跳）我的人生充斥着失败",
      "translation": null
    },
    {
      "time": 207.84,
      "time_str": "03:27.840",
      "text": "（疯狂）只是这世界变化太快",
      "translation": null
    },
    {
      "time": 209.91,
      "time_str": "03:29.910",
      "text": "（留恋）我被排除在节奏之外",
      "translation": null
    },
    {
      "time": 222.57,
      "time_str": "03:42.570",
      "text": "我的美丽",
      "translation": null
    },
    {
      "time": 239.44,
      "time_str": "03:59.440",
      "text": "原唱 : 小霞",
      "translation": null
    },
    {
      "time": 239.99,
      "time_str": "03:59.990",
      "text": "改编词： young-seven67 / 海洋Bo",
      "translation": null
    },
    {
