    {
      "time": 29.6,
      "time_str": "00:29.600",
      "text": "我到了这个时候还是一样",
      "translation": null
    },
    {
      "time": 34.9,
      "time_str": "00:34.900",
      "text": "夜里的寂寞容易叫人悲伤",
      "translation": null
    },
    {
      "time": 40.3,
      "time_str": "00:40.300",
      "text": "我不敢想的太多",
      "translation": null
    },
    {
      "time": 44.31,
      "time_str": "00:44.310",
      "text": "因为我一个人",
      "translation": null
    },
    {
      "time": 50.97,
      "time_str": "00:50.970",
      "text": "迎面而来的月光拉长身影",
      "translation": null
    },
    {
      "time": 56.32,
      "time_str": "00:56.320",
      "text": "漫无目的地走在冷冷的街",
      "translation": null
    },
    {
      "time": 61.63,
      "time_str": "01:01.630",
      "text": "我没有你的消息",
      "translation": null
    },
    {
      "time": 65.52,
      "time_str": "01:05.520",
      "text": "因为我在想你",
      "translation": null
    },
    {
      "time": 72.64,
      "time_str": "01:12.640",
      "text": "爱我别走",
      "translation": null
    },
    {
      "time": 75.38,
      "time_str": "01:15.380",
      "text": "如果你说你不爱我",
      "translation": null
    },
    {
      "time": 83.27,
      "time_str": "01:23.270",
      "text": "不要听见你真的说出口",
      "translation": null
    },
    {
      "time": 86.91,
      "time_str": "01:26.910",
      "text": "再给我一点温柔",
