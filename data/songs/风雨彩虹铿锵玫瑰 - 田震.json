  "lyrics": [
    {
      "time": 20.3,
      "time_str": "00:20.300",
      "text": "一切美好只是昨日沉醉",
      "translation": null
    },
    {
      "time": 25.8,
      "time_str": "00:25.800",
      "text": "淡淡苦涩才是今天滋味",
      "translation": null
    },
    {
      "time": 31.29,
      "time_str": "00:31.290",
      "text": "想想明天又是日晒风吹",
      "translation": null
    },
    {
      "time": 36.08,
      "time_str": "00:36.080",
      "text": "再苦再累无惧无畏",
      "translation": null
    },
    {
      "time": 40.788,
      "time_str": "00:40.788",
      "text": "身上的痛让我难以入睡",
      "translation": null
    },
    {
      "time": 46.048,
      "time_str": "00:46.048",
      "text": "脚下的路还有更多的累",
      "translation": null
    },
    {
      "time": 52.189,
      "time_str": "00:52.189",
      "text": "追逐梦想总是百转千回",
      "translation": null
    },
    {
      "time": 57.338,
      "time_str": "00:57.338",
      "text": "无怨无悔从容面对",
      "translation": null
    },
    {
      "time": 63.789,
      "time_str": "01:03.789",
      "text": "风雨彩虹铿锵玫瑰",
      "translation": null
    },
    {
      "time": 69.389,
      "time_str": "01:09.389",
      "text": "再多忧伤再多痛苦自己去背",
      "translation": null
    },
    {
      "time": 75.08,
      "time_str": "01:15.080",
      "text": "风雨彩虹铿锵玫瑰",
      "translation": null
    },
    {
      "time": 79.429,
      "time_str": "01:19.429",
      "text": "纵横四海笑傲天涯永不后退",
      "translation": null
    },
    {
      "time": 106.28,
      "time_str": "01:46.280",
      "text": "思绪飘飞带着梦想去追",
      "translation": null
    },
    {
      "time": 110.828,
      "time_str": "01:50.828",
      "text": "我行我素做人要敢做敢为",
      "translation": null
    },
    {
      "time": 116.899,
      "time_str": "01:56.899",
      "text": "人生苦短哪能半途而废",
      "translation": null
    },
    {
      "time": 121.339,
      "time_str": "02:01.339",
      "text": "不气不馁无惧无畏",
      "translation": null
    },
    {
      "time": 127.39,
      "time_str": "02:07.390",
      "text": "桃李争辉飒爽英姿斗艳",
      "translation": null
    },
    {
      "time": 131.619,
      "time_str": "02:11.619",
      "text": "成功失败总是欢乐伤悲",
      "translation": null
    },
    {
      "time": 136.98,
      "time_str": "02:16.980",
      "text": "红颜娇美承受雨打风吹",
      "translation": null
    },
    {
      "time": 142.5,
      "time_str": "02:22.500",
      "text": "拔剑扬眉豪情快慰",
      "translation": null
    },
    {
      "time": 150.6,
      "time_str": "02:30.600",
      "text": "风雨彩虹铿锵玫瑰",
      "translation": null
    },
    {
      "time": 156.1,
      "time_str": "02:36.100",
      "text": "芳心似水激情如火梦想鼎沸",
      "translation": null
    },
    {
      "time": 160.99,
      "time_str": "02:40.990",
      "text": "风雨彩虹铿锵玫瑰",
      "translation": null
    },
    {
      "time": 166.24,
