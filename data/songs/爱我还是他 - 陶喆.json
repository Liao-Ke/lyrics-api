    },
    {
      "time": 17.81,
      "time_str": "00:17.810",
      "text": "黑暗中的我们都没有说话",
      "translation": null
    },
    {
      "time": 24.24,
      "time_str": "00:24.240",
      "text": "你只想回家 不想你回家",
      "translation": null
    },
    {
      "time": 32.28,
      "time_str": "00:32.280",
      "text": "寂寞深得像海太让人害怕",
      "translation": null
    },
    {
      "time": 38.96,
      "time_str": "00:38.960",
      "text": "温柔你的手 轻轻揉着我的发",
      "translation": null
    },
    {
      "time": 46.24,
      "time_str": "00:46.240",
      "text": "你的眉眼说 你好渴望我拥抱",
      "translation": null
    },
    {
      "time": 53.41,
      "time_str": "00:53.410",
      "text": "你身体却在拼命逃",
      "translation": null
    },
    {
      "time": 57.04,
      "time_str": "00:57.040",
      "text": "当欲望在燃烧",
      "translation": null
    },
    {
      "time": 66.27,
      "time_str": "01:06.270",
      "text": "你爱我还是他",
      "translation": null
    },
    {
      "time": 72.73,
      "time_str": "01:12.730",
      "text": "是不是真的他有比我好",
      "translation": null
    },
    {
      "time": 77.14,
      "time_str": "01:17.140",
      "text": "你为谁在挣扎",
