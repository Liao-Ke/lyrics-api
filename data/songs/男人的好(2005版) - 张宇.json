  "lyrics": [
    {
      "time": 25.85,
      "time_str": "00:25.850",
      "text": "你对他好 把他的依靠当做回报",
      "translation": null
    },
    {
      "time": 31.92,
      "time_str": "00:31.920",
      "text": "即使他无理向你取闹",
      "translation": null
    },
    {
      "time": 35.64,
      "time_str": "00:35.640",
      "text": "最后还是见你泪中带笑",
      "translation": null
    },
    {
      "time": 40.33,
      "time_str": "00:40.330",
      "text": "你看不到 心在那一天一地里越缩越小",
      "translation": null
    },
    {
      "time": 47.55,
      "time_str": "00:47.550",
      "text": "才会 明知深渊还往里跳",
      "translation": null
    },
    {
      "time": 54.5,
      "time_str": "00:54.500",
      "text": "我想男人的好 只有在他身边的那个女人才知道",
      "translation": null
    },
    {
      "time": 61.8,
      "time_str": "01:01.800",
      "text": "只是谁是毒药 谁才是你的珍宝",
      "translation": null
    },
    {
      "time": 69.05,
      "time_str": "01:09.050",
      "text": "要是男人的好 总要你委屈自己处处讨好",
      "translation": null
    },
    {
      "time": 75.09,
      "time_str": "01:15.090",
      "text": "才能塑造 才能得到 你何必自寻苦恼",
