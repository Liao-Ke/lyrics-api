{
  "title": "阿Sam与阿Tam",
  "title_raw": "阿Sam与阿Tam (Happy Together Version)",
  "version": "Happy Together Version",
  "artist": "谭咏麟,许冠杰",
  "group_key": "阿sam与阿tam|谭咏麟,许冠杰",
  "writers": {
    "lyricist": "许冠杰/潘源良/林振强",
    "composer": "许冠杰/芹泽广明",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 3.4,
      "time_str": "00:03.400",
      "text": "《暴风女神lorelei》",
      "translation": null
    },
    {
      "time": 11.4,
      "time_str": "00:11.400",
      "text": "曾在那揭不开的漆黑中",
      "translation": null
    },
    {
      "time": 14.4,
      "time_str": "00:14.400",
      "text": "压不低的恋火中",
      "translation": null
    },
    {
      "time": 16.4,
      "time_str": "00:16.400",
      "text": "猛风当中她拥抱我 OH OH OH OH",
      "translation": null
    },
    {
      "time": 23.4,
      "time_str": "00:23.400",
      "text": "这刻身边只有风",
      "translation": null
    },
    {
      "time": 26.4,
      "time_str": "00:26.400",
      "text": "停在那抹不清的追忆中",
      "translation": null
    },
    {
      "time": 28.4,
      "time_str": "00:28.400",
      "text": "割不穿的空虚中",
      "translation": null
    },
    {
      "time": 30.4,
      "time_str": "00:30.400",
      "text": "猛风当中只有我",
      "translation": null
    },
    {
      "time": 33.4,
      "time_str": "00:33.400",
      "text": "跌跌碰碰再次发觉她于风中",
      "translation": null
    },
    {
      "time": 38.4,
      "time_str": "00:38.400",
      "text": "LORELEI",
      "translation": null
    },
    {
      "time": 41.4,
      "time_str": "00:41.400",
      "text": "《最紧要好玩》",
      "translation": null
    },
    {
      "time": 44.4,
      "time_str": "00:44.400",
      "text": "人其实天生奔放贪玩",
      "translation": null
    },
    {
      "time": 47.4,
      "time_str": "00:47.400",
      "text": "原没有拘束只有笑颜",
      "translation": null
    },
    {
      "time": 51.4,
      "time_str": "00:51.400",
      "text": "悲观我唔惯",
      "translation": null
    },
    {
      "time": 53.4,
      "time_str": "00:53.400",
      "text": "追赶太阳似子弹",
      "translation": null
    },
    {
      "time": 57.4,
      "time_str": "00:57.400",
      "text": "乘坐穿梭机打个空翻",
      "translation": null
    },
    {
      "time": 61.4,
      "time_str": "01:01.400",
      "text": "云雾里绑起双脚跳栏",
      "translation": null
    },
    {
      "time": 64.4,
      "time_str": "01:04.400",
      "text": "威风似神探",
      "translation": null
    },
    {
      "time": 65.4,
      "time_str": "01:05.400",
      "text": "追踪爱神眼不眨",
      "translation": null
    },
    {
      "time": 70.4,
      "time_str": "01:10.400",
      "text": "我想攀登火山执块石头用来煎蛋",
      "translation": null
    },
    {
      "time": 77.4,
      "time_str": "01:17.400",
      "text": "其实开心好简单 最紧要好玩",
      "translation": null
    },
    {
      "time": 86.4,
      "time_str": "01:26.400",
      "text": "《夏日寒风》",
      "translation": null
    },
    {
      "time": 91.4,
      "time_str": "01:31.400",
      "text": "挤迫的沙滩里金啡色的肌肤里",
      "translation": null
    },
    {
      "time": 95.4,
      "time_str": "01:35.400",
      "text": "闪烁暑天的汗水",
      "translation": null
    },
    {
      "time": 98.4,
      "time_str": "01:38.400",
      "text": "我却觉冷又寒缩起双肩苦笑着",
      "translation": null
    },
    {
      "time": 101.4,
      "time_str": "01:41.400",
      "text": "北风仿佛身边四吹",
      "translation": null
    },
    {
      "time": 105.4,
      "time_str": "01:45.400",
      "text": "只因心中温暖都跟她消失去",
      "translation": null
    },
    {
      "time": 108.4,
      "time_str": "01:48.400",
      "text": "今天只得一串泪水",
      "translation": null
    },
    {
      "time": 111.4,
      "time_str": "01:51.400",
      "text": "说爱我百万年的她 今爱着谁",
      "translation": null
    },
    {
      "time": 117.4,
      "time_str": "01:57.400",
      "text": "我虽不怪她带走旭日",
      "translation": null
    },
    {
      "time": 124.4,
      "time_str": "02:04.400",
      "text": "却一生怪她 只带走痴痴的心剩低眼泪",
      "translation": null
    },
    {
      "time": 131.4,
      "time_str": "02:11.400",
      "text": "狂呼我空虚 空虚",
      "translation": null
    },
    {
      "time": 135.4,
      "time_str": "02:15.400",
      "text": "恨极为她心碎",
      "translation": null
    },
    {
      "time": 138.4,
      "time_str": "02:18.400",
      "text": "明知结局 何必去做玩耍器具",
      "translation": null
    },
    {
      "time": 144.4,
      "time_str": "02:24.400",
      "text": "狂呼我空虚 空虚",
      "translation": null
    },
    {
      "time": 148.4,
      "time_str": "02:28.400",
      "text": "怒骂是她不对",
      "translation": null
    },
    {
      "time": 151.4,
      "time_str": "02:31.400",
      "text": "强忍眼泪 从此我愿",
      "translation": null
    },
    {
      "time": 155.4,
      "time_str": "02:35.400",
      "text": "独在痛苦中活下去",
      "translation": null
    },
    {
      "time": 161.4,
      "time_str": "02:41.400",
      "text": "《半斤八两》",
      "translation": null
    },
    {
      "time": 164.4,
      "time_str": "02:44.400",
      "text": "我吔呢班打工仔",
      "translation": null
    },
    {
      "time": 167.4,
      "time_str": "02:47.400",
      "text": "通街走籴直头系坏肠胃",
      "translation": null
    },
    {
      "time": 170.4,
      "time_str": "02:50.400",
      "text": "揾嗰些少到月底点够使(奀个鬼)",
      "translation": null
    },
    {
      "time": 174.4,
      "time_str": "02:54.400",
      "text": "确系认真湿滞",
      "translation": null
    },
    {
      "time": 177.4,
      "time_str": "02:57.400",
      "text": "最弊波士郁啲发威（癫过鸡）",
      "translation": null
    },
    {
      "time": 180.4,
      "time_str": "03:00.400",
      "text": "一味喺处系唔系就乱黎吠（汪汪汪）",
      "translation": null
    },
    {
      "time": 183.4,
      "time_str": "03:03.400",
      "text": "翳亲加薪块面嗱起恶睇（扭下计）",
      "translation": null
    },
    {
      "time": 187.4,
      "time_str": "03:07.400",
      "text": "你就认真开胃",
      "translation": null
    },
    {
      "time": 191.4,
      "time_str": "03:11.400",
      "text": "半斤八两 做到只积咁嘅样",
      "translation": null
    },
    {
      "time": 194.4,
      "time_str": "03:14.400",
      "text": "半斤八两 湿水炮仗点会响",
      "translation": null
    },
    {
      "time": 197.4,
      "time_str": "03:17.400",
      "text": "半斤八两 够姜就揸枪走去抢",
      "translation": null
    },
    {
      "time": 201.4,
      "time_str": "03:21.400",
      "text": "出咗半斤力 想话摞番足八两",
      "translation": null
    },
    {
      "time": 204.4,
      "time_str": "03:24.400",
      "text": "家阵恶揾食 边有半斤八两咁理想（吹涨）",
      "translation": null
    },
    {
      "time": 211.4,
      "time_str": "03:31.400",
      "text": "《爱情陷阱》",
      "translation": null
    },
    {
      "time": 229.4,
      "time_str": "03:49.400",
      "text": "拨着大雾默默地在觅我的去路",
      "translation": null
    },
    {
      "time": 232.4,
      "time_str": "03:52.400",
      "text": "但愿路上幸运遇着是你的脚步",
      "translation": null
    },
    {
      "time": 235.4,
      "time_str": "03:55.400",
      "text": "我要再见你",
      "translation": null
    },
    {
      "time": 236.4,
      "time_str": "03:56.400",
      "text": "只想将心声透露 爱慕",
      "translation": null
    },
    {
      "time": 241.4,
      "time_str": "04:01.400",
      "text": "独自望着路上密密画满的记号",
      "translation": null
    },
    {
      "time": 244.4,
      "time_str": "04:04.400",
      "text": "像是混乱又像特别为了指我路",
      "translation": null
    },
    {
      "time": 247.4,
      "time_str": "04:07.400",
      "text": "到处去碰 到处去看",
      "translation": null
    },
    {
      "time": 249.4,
      "time_str": "04:09.400",
      "text": "堕入陷阱 方知太糊涂",
      "translation": null
    },
    {
      "time": 252.4,
      "time_str": "04:12.400",
      "text": "真心被俘虏 仿佛遭圈套",
      "translation": null
    },
    {
      "time": 256.4,
      "time_str": "04:16.400",
      "text": "探索这爱路",
      "translation": null
    },
    {
      "time": 259.4,
      "time_str": "04:19.400",
      "text": "你那美态已叫我醉倒",
      "translation": null
    },
    {
      "time": 264.4,
      "time_str": "04:24.400",
      "text": "我堕入情网 你却在网外看",
      "translation": null
    },
    {
      "time": 268.4,
      "time_str": "04:28.400",
      "text": "始终不释放",
      "translation": null
    },
    {
      "time": 271.4,
      "time_str": "04:31.400",
      "text": "你笑笑看看我 像是望着猎物",
      "translation": null
    },
    {
      "time": 274.4,
      "time_str": "04:34.400",
      "text": "我心已伤",
      "translation": null
    },
    {
      "time": 278.4,
      "time_str": "04:38.400",
      "text": "我堕入情网 你却在网外看",
      "translation": null
    },
    {
      "time": 282.4,
      "time_str": "04:42.400",
      "text": "始终不释放",
      "translation": null
    },
    {
      "time": 285.4,
      "time_str": "04:45.400",
      "text": "恨 爱 心中激荡",
      "translation": null
    },
    {
      "time": 291.4,
      "time_str": "04:51.400",
      "text": "这陷阱 这陷阱 这陷阱",
      "translation": null
    },
    {
      "time": 293.4,
      "time_str": "04:53.400",
      "text": "偏我遇上",
      "translation": null
    },
    {
      "time": 297.4,
      "time_str": "04:57.400",
      "text": "这陷阱 这陷阱 这陷阱",
      "translation": null
    },
    {
      "time": 299.4,
      "time_str": "04:59.400",
      "text": "偏我遇上",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "阿Sam与阿Tam (Happy Together Version) - 谭咏麟,许冠杰.lrc"
}