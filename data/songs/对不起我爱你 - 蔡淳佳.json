    {
      "time": 13.97,
      "time_str": "00:13.970",
      "text": "你空出一双手",
      "translation": null
    },
    {
      "time": 17.09,
      "time_str": "00:17.090",
      "text": "穿过黑夜握住我",
      "translation": null
    },
    {
      "time": 20.47,
      "time_str": "00:20.470",
      "text": "两个人的手心里有",
      "translation": null
    },
    {
      "time": 23.84,
      "time_str": "00:23.840",
      "text": "一整片宽阔的天空",
      "translation": null
    },
    {
      "time": 27.15,
      "time_str": "00:27.150",
      "text": "谁都没有开口",
      "translation": null
    },
    {
      "time": 30.41,
      "time_str": "00:30.410",
      "text": "星星也忘了闪烁",
      "translation": null
    },
    {
      "time": 33.84,
      "time_str": "00:33.840",
      "text": "有你陪着我就可以",
      "translation": null
    },
    {
      "time": 37.03,
      "time_str": "00:37.030",
      "text": "走到天涯的尽头",
      "translation": null
    },
    {
      "time": 41.78,
      "time_str": "00:41.780",
      "text": "那时候还记得那时候",
      "translation": null
    },
    {
      "time": 48.34,
      "time_str": "00:48.340",
      "text": "从手心传过来的温柔",
      "translation": null
    },
    {
      "time": 54.97,
      "time_str": "00:54.970",
      "text": "如果说只能活这一天",
      "translation": null
    },
    {
      "time": 60.34,
      "time_str": "01:00.340",
      "text": "曾经与你深深相爱",
      "translation": null
    },
    {
      "time": 64.97,
      "time_str": "01:04.970",
      "text": "我已没有遗憾",
      "translation": null
    },
    {
      "time": 68.53,
      "time_str": "01:08.530",
      "text": "我用回忆温暖了",
      "translation": null
    },
    {
      "time": 71.34,
      "time_str": "01:11.340",
      "text": "想你的每一刻",
      "translation": null
    },
    {
      "time": 74.53,
      "time_str": "01:14.530",
      "text": "不让你离我太遥远",
      "translation": null
    },
    {
      "time": 78.47,
      "time_str": "01:18.470",
      "text": "走在这个适合拥抱的季节",
      "translation": null
    },
    {
      "time": 82.47,
      "time_str": "01:22.470",
      "text": "爱在心里所以我不可怜",
      "translation": null
    },
    {
      "time": 86.03,
      "time_str": "01:26.030",
      "text": "回忆温暖了想你的每一刻",
      "translation": null
    },
    {
      "time": 91.09,
      "time_str": "01:31.090",
      "text": "紧紧抱着你说过的誓言",
      "translation": null
    },
    {
      "time": 95.09,
      "time_str": "01:35.090",
      "text": "等待着我们说好的永远",
      "translation": null
    },
    {
      "time": 112.46,
      "time_str": "01:52.460",
      "text": "并肩的两个人",
      "translation": null
    },
    {
      "time": 115.47,
      "time_str": "01:55.470",
      "text": "在银白色的街头",
      "translation": null
    },
    {
      "time": 118.97,
      "time_str": "01:58.970",
      "text": "印下的脚印还一直",
      "translation": null
    },
    {
      "time": 122.16,
