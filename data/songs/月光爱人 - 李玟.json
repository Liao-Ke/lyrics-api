  },
  "lyrics": [
    {
      "time": 28.2,
      "time_str": "00:28.200",
      "text": "我醒来",
      "translation": null
    },
    {
      "time": 31.2,
      "time_str": "00:31.200",
      "text": "睡在月光里",
      "translation": null
    },
    {
      "time": 34.2,
      "time_str": "00:34.200",
      "text": "下弦月",
      "translation": null
    },
    {
      "time": 36.2,
      "time_str": "00:36.200",
      "text": "让我想你",
      "translation": null
    },
    {
      "time": 41.2,
      "time_str": "00:41.200",
      "text": "不想醒过来",
      "translation": null
    },
    {
      "time": 44.2,
      "time_str": "00:44.200",
      "text": "谁明白",
      "translation": null
    },
    {
      "time": 48.2,
      "time_str": "00:48.200",
      "text": "怕眼睁开",
      "translation": null
    },
    {
      "time": 51.2,
      "time_str": "00:51.200",
      "text": "你不在",
      "translation": null
    },
    {
      "time": 55.2,
      "time_str": "00:55.200",
      "text": "爱人心",
      "translation": null
    },
    {
      "time": 59.2,
      "time_str": "00:59.200",
      "text": "沉入海",
      "translation": null
    },
    {
      "time": 62.2,
      "time_str": "01:02.200",
      "text": "带我去",
      "translation": null
    },
    {
      "time": 65.2,
      "time_str": "01:05.200",
      "text": "把它找回来",
      "translation": null
    },
    {
      "time": 69.2,
      "time_str": "01:09.200",
      "text": "请爱我",
      "translation": null
    },
    {
      "time": 72.2,
      "time_str": "01:12.200",
      "text": "一万年",
      "translation": null
    },
    {
      "time": 77.2,
      "time_str": "01:17.200",
      "text": "用心爱",
      "translation": null
    },
    {
      "time": 78.2,
      "time_str": "01:18.200",
      "text": "（爱是月光的礼物）",
      "translation": null
    },
    {
      "time": 80.2,
      "time_str": "01:20.200",
      "text": "（我等待天使的情书）",
      "translation": null
    },
    {
      "time": 83.2,
      "time_str": "01:23.200",
      "text": "（说你 爱我）",
      "translation": null
    },
    {
      "time": 87.2,
      "time_str": "01:27.200",
      "text": "我愿为了爱沉睡",
      "translation": null
    },
    {
      "time": 92.2,
      "time_str": "01:32.200",
      "text": "别醒来",
      "translation": null
    },
    {
      "time": 103.2,
      "time_str": "01:43.200",
      "text": "永恒哪",
      "translation": null
    },
    {
      "time": 105.2,
      "time_str": "01:45.200",
      "text": "在不在",
      "translation": null
    },
    {
      "time": 109.2,
      "time_str": "01:49.200",
      "text": "怪我的心",
      "translation": null
    },
    {
      "time": 112.2,
      "time_str": "01:52.200",
      "text": "放不开",
      "translation": null
    },
    {
      "time": 116.2,
      "time_str": "01:56.200",
      "text": "北极星",
      "translation": null
    },
    {
      "time": 119.2,
      "time_str": "01:59.200",
      "text": "带我走",
      "translation": null
    },
    {
      "time": 123.2,
      "time_str": "02:03.200",
      "text": "别躲藏",
      "translation": null
    },
    {
      "time": 126.2,
      "time_str": "02:06.200",
      "text": "把爱找出来",
      "translation": null
    },
    {
      "time": 130.2,
      "time_str": "02:10.200",
      "text": "我爱你",
      "translation": null
    },
    {
      "time": 134.2,
      "time_str": "02:14.200",
      "text": "每一夜",
      "translation": null
    },
    {
      "time": 137.2,
      "time_str": "02:17.200",
      "text": "我等待（等你）",
      "translation": null
    },
    {
      "time": 141.2,
      "time_str": "02:21.200",
      "text": "我的心",
      "translation": null
    },
    {
      "time": 144.2,
      "time_str": "02:24.200",
      "text": "为了爱",
      "translation": null
    },
    {
      "time": 147.2,
      "time_str": "02:27.200",
      "text": "睡在月之海",
      "translation": null
    },
    {
      "time": 151.2,
      "time_str": "02:31.200",
      "text": "孤单的我",
      "translation": null
    },
    {
      "time": 154.2,
      "time_str": "02:34.200",
      "text": "想念谁",
      "translation": null
    },
    {
      "time": 158.2,
      "time_str": "02:38.200",
      "text": "谁明白",
      "translation": null
    },
    {
      "time": 160.2,
      "time_str": "02:40.200",
      "text": "（我在月光下流泪）",
      "translation": null
    },
    {
      "time": 162.2,
      "time_str": "02:42.200",
      "text": "（我也在月光下沉睡）",
      "translation": null
    },
    {
      "time": 165.2,
      "time_str": "02:45.200",
      "text": "（没有 后悔）",
      "translation": null
    },
    {
      "time": 169.2,
      "time_str": "02:49.200",
      "text": "等待真心人把我吻醒",
      "translation": null
    },
    {
      "time": 173.2,
      "time_str": "02:53.200",
      "text": "（我在睡梦中一天）",
      "translation": null
    },
    {
      "time": 176.2,
      "time_str": "02:56.200",
      "text": "（也是在回忆中一年）",
      "translation": null
    },
    {
      "time": 178.2,
      "time_str": "02:58.200",
      "text": "（说你 爱我）",
      "translation": null
    },
    {
      "time": 183.2,
      "time_str": "03:03.200",
      "text": "我愿为了爱沉睡 到永远",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "月光爱人 - 李玟.lrc"
}