    {
      "time": 13.3,
      "time_str": "00:13.300",
      "text": "朝早钟意浮沉在泡泡",
      "translation": null
    },
    {
      "time": 16.24,
      "time_str": "00:16.240",
      "text": "也爱夏季出外带张地图",
      "translation": null
    },
    {
      "time": 19.3,
      "time_str": "00:19.300",
      "text": "喜欢家里流行乐满布",
      "translation": null
    },
    {
      "time": 22.43,
      "time_str": "00:22.430",
      "text": "探索伴侣深夜看星座图",
      "translation": null
    },
    {
      "time": 25.49,
      "time_str": "00:25.490",
      "text": "我最爱画簿 也爱化妆扫",
      "translation": null
    },
    {
      "time": 28.67,
      "time_str": "00:28.670",
      "text": "我最爱清水 韵味最好",
      "translation": null
    },
    {
      "time": 31.67,
      "time_str": "00:31.670",
      "text": "我最爱花草 也会爱珠宝",
      "translation": null
    },
    {
      "time": 34.71,
      "time_str": "00:34.710",
      "text": "从梦里的阶梯翩翩起舞",
      "translation": null
    },
    {
      "time": 37.03,
      "time_str": "00:37.030",
      "text": "多么钟意它 生命无价",
      "translation": null
    },
    {
      "time": 40.96,
      "time_str": "00:40.960",
      "text": "钟意自己 一切有些少变化",
      "translation": null
    },
    {
      "time": 44.14,
      "time_str": "00:44.140",
      "text": "我有难题吗 欢乐无价",
      "translation": null
    },
    {
      "time": 46.96,
      "time_str": "00:46.960",
      "text": "安慰自己 活要活到灿烂吧",
      "translation": null
    },
    {
      "time": 50.32,
      "time_str": "00:50.320",
      "text": "Da da di da 钟意笑 钟意说 钟意休假",
      "translation": null
    },
    {
      "time": 53.57,
      "time_str": "00:53.570",
      "text": "地球是太美 尽情认识他",
      "translation": null
    },
    {
      "time": 56.43,
      "time_str": "00:56.430",
      "text": "Da da di da 钟意看 钟意听 钟意简化",
      "translation": null
    },
    {
      "time": 59.62,
      "time_str": "00:59.620",
      "text": "任何事哪怕用纯真的心拥抱一下",
      "translation": null
    },
    {
      "time": 74.85,
      "time_str": "01:14.850",
      "text": "即影即有 随时在拍照",
      "translation": null
    },
    {
