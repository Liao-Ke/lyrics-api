  "lyrics": [
    {
      "time": 18.85,
      "time_str": "00:18.850",
      "text": "今天我 寒夜里看雪飘过",
      "translation": null
    },
    {
      "time": 25.5,
      "time_str": "00:25.500",
      "text": "怀着冷却了的心窝漂远方",
      "translation": null
    },
    {
      "time": 31.33,
      "time_str": "00:31.330",
      "text": "风雨里追赶 雾里分不清影踪",
      "translation": null
    },
    {
      "time": 37.62,
      "time_str": "00:37.620",
      "text": "天空海阔你与我",
      "translation": null
    },
    {
      "time": 40.69,
      "time_str": "00:40.690",
      "text": "可会变 (谁没在变)",
      "translation": null
    },
    {
      "time": 43.84,
      "time_str": "00:43.840",
      "text": "多少次 迎着冷眼与嘲笑",
      "translation": null
    },
    {
      "time": 50.45,
      "time_str": "00:50.450",
      "text": "从没有放弃过心中的理想",
      "translation": null
    },
    {
      "time": 56.3,
      "time_str": "00:56.300",
      "text": "一刹那恍惚 若有所失的感觉",
      "translation": null
    },
    {
      "time": 62.53,
      "time_str": "01:02.530",
      "text": "不知不觉已变淡",
      "translation": null
    },
    {
      "time": 65.63,
      "time_str": "01:05.630",
      "text": "心里爱 (谁明白我)",
      "translation": null
    },
    {
      "time": 69.2,
      "time_str": "01:09.200",
      "text": "原谅我这一生不羁放纵爱自由",
      "translation": null
    },
    {
      "time": 76.18,
      "time_str": "01:16.180",
      "text": "也会怕有一天会跌倒",
      "translation": null
    },
    {
      "time": 82.4,
      "time_str": "01:22.400",
      "text": "背弃了理想 谁人都可以",
      "translation": null
    },
    {
      "time": 88.66,
      "time_str": "01:28.660",
      "text": "哪会怕有一天只你共我",
      "translation": null
    },
    {
