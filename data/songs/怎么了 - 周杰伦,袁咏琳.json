      "time_str": "00:04.000",
      "text": "女声 : 袁咏琳(Cindy Yen)",
      "translation": null
    },
    {
      "time": 8.0,
      "time_str": "00:08.000",
      "text": "混音室 : VIP Music",
      "translation": null
    },
    {
      "time": 27.68,
      "time_str": "00:27.680",
      "text": "上车了",
      "translation": null
    },
    {
      "time": 28.88,
      "time_str": "00:28.880",
      "text": "收拾心情背上",
      "translation": null
    },
    {
      "time": 30.08,
      "time_str": "00:30.080",
      "text": "行李我走了",
      "translation": null
    },
    {
      "time": 32.03,
      "time_str": "00:32.030",
      "text": "一再重复听",
      "translation": null
    },
    {
      "time": 33.08,
      "time_str": "00:33.080",
      "text": "你喜欢听的歌",
      "translation": null
    },
    {
      "time": 35.29,
      "time_str": "00:35.290",
      "text": "甜蜜回忆太多心乱了",
      "translation": null
    },
    {
      "time": 38.45,
      "time_str": "00:38.450",
      "text": "真的结束了",
      "translation": null
    },
    {
      "time": 40.5,
      "time_str": "00:40.500",
      "text": "舍不得你唱的生日快乐歌",
      "translation": null
    },
    {
      "time": 43.55,
      "time_str": "00:43.550",
      "text": "还记得",
      "translation": null
    },
    {
      "time": 44.8,
      "time_str": "00:44.800",
      "text": "你的温柔方式",
      "translation": null
    },
    {
      "time": 46.1,
      "time_str": "00:46.100",
      "text": "终于我懂了",
      "translation": null
    },
    {
      "time": 47.98,
      "time_str": "00:47.980",
      "text": "话题聊到这里你笑了",
      "translation": null
    },
    {
      "time": 51.28,
      "time_str": "00:51.280",
      "text": "却也太迟了",
      "translation": null
    },
    {
      "time": 53.33,
      "time_str": "00:53.330",
      "text": "我用咖啡拉花",
      "translation": null
    },
    {
      "time": 54.48,
      "time_str": "00:54.480",
      "text": "拉出白色的线",
      "translation": null
    },
    {
      "time": 55.58,
      "time_str": "00:55.580",
      "text": "煮一杯眷恋",
      "translation": null
    },
    {
      "time": 56.58,
      "time_str": "00:56.580",
      "text": "你侧脸在咖啡表面",
      "translation": null
    },
    {
      "time": 57.98,
      "time_str": "00:57.980",
      "text": "形成了思念形成怀念",
      "translation": null
    },
    {
      "time": 60.03,
      "time_str": "01:00.030",
      "text": "你长发披肩我",
      "translation": null
    },
    {
      "time": 61.17,
      "time_str": "01:01.170",
      "text": "渐渐的勾划出",
      "translation": null
    },
    {
      "time": 62.17,
      "time_str": "01:02.170",
      "text": "你嘴角弧线",
      "translation": null
    },
    {
      "time": 63.17,
      "time_str": "01:03.170",
      "text": "所有的从前我",
      "translation": null
    },
    {
