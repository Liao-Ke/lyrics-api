      "text": "保持距离 是个难题",
      "translation": null
    },
    {
      "time": 74.66,
      "time_str": "01:14.660",
      "text": "我用全心全意 爱上你",
      "translation": null
    },
    {
      "time": 77.09,
      "time_str": "01:17.090",
      "text": "你说怎么办",
      "translation": null
    },
    {
      "time": 78.44,
      "time_str": "01:18.440",
      "text": "是爱情让人心悸",
      "translation": null
    },
    {
      "time": 83.07,
      "time_str": "01:23.070",
      "text": "不敢正视 你的脸",
      "translation": null
    },
    {
      "time": 85.39,
      "time_str": "01:25.390",
      "text": "当你眼神不小心带电",
      "translation": null
    },
    {
      "time": 87.7,
      "time_str": "01:27.700",
      "text": "我已经陷入热恋",
      "translation": null
    },
    {
      "time": 93.35,
