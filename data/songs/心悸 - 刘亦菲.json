  "lyrics": [
    {
      "time": 16.7,
      "time_str": "00:16.700",
      "text": "你给的语言",
      "translation": null
    },
    {
      "time": 17.68,
      "time_str": "00:17.680",
      "text": "好的太危险",
      "translation": null
    },
    {
      "time": 18.82,
      "time_str": "00:18.820",
      "text": "该怎么分辨",
      "translation": null
    },
    {
      "time": 20.04,
      "time_str": "00:20.040",
      "text": "不要被你抓住心里的弱点",
      "translation": null
    },
    {
      "time": 27.1,
      "time_str": "00:27.100",
      "text": "给我多一点 甜蜜时间",
      "translation": null
    },
    {
      "time": 29.41,
      "time_str": "00:29.410",
      "text": "又不想太黏",
      "translation": null
    },
    {
      "time": 30.79,
      "time_str": "00:30.790",
      "text": "还不是因为爱我才会善变",
      "translation": null
    },
    {
      "time": 37.52,
      "time_str": "00:37.520",
      "text": "你在我的世界飘移",
      "translation": null
    },
    {
      "time": 40.72,
      "time_str": "00:40.720",
      "text": "你说我们有没有默契",
      "translation": null
    },
    {
      "time": 48.17,
      "time_str": "00:48.170",
      "text": "你在我的心里偷袭",
      "translation": null
    },
    {
      "time": 50.09,
      "time_str": "00:50.090",
      "text": "我也想要我的爱情胜利",
      "translation": null
    },
    {
      "time": 56.69,
      "time_str": "00:56.690",
      "text": "或许我是太过爱你",
      "translation": null
    },
    {
      "time": 59.45,
      "time_str": "00:59.450",
      "text": "爱情的战局",
      "translation": null
    },
    {
      "time": 60.29,
      "time_str": "01:00.290",
      "text": "不能被你吃定",
      "translation": null
    },
    {
      "time": 61.37,
      "time_str": "01:01.370",
      "text": "你就像谜 让人好奇",
      "translation": null
    },
    {
      "time": 64.16,
      "time_str": "01:04.160",
      "text": "如果要更亲密",
      "translation": null
    },
    {
      "time": 65.42,
      "time_str": "01:05.420",
      "text": "不能被你吃定",
      "translation": null
    },
    {
      "time": 66.65,
      "time_str": "01:06.650",
      "text": "没有办法 不去爱你",
      "translation": null
    },
    {
      "time": 69.3,
      "time_str": "01:09.300",
      "text": "爱情的战局",
      "translation": null
    },
    {
