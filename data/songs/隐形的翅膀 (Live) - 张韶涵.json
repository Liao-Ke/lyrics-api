    {
      "time": 26.88,
      "time_str": "00:26.880",
      "text": "每一次都在徘徊孤单中坚强",
      "translation": null
    },
    {
      "time": 33.25,
      "time_str": "00:33.250",
      "text": "每一次就算很受伤也不闪泪光",
      "translation": null
    },
    {
      "time": 39.94,
      "time_str": "00:39.940",
      "text": "我知道我一直有双隐形的翅膀",
      "translation": null
    },
    {
      "time": 46.48,
      "time_str": "00:46.480",
      "text": "带我飞飞过绝望",
      "translation": null
    },
    {
      "time": 53.3,
      "time_str": "00:53.300",
      "text": "不去想他们拥有美丽的太阳",
      "translation": null
    },
    {
      "time": 59.8,
      "time_str": "00:59.800",
      "text": "我看见每天的夕阳也会有变化",
      "translation": null
    },
    {
      "time": 66.54,
      "time_str": "01:06.540",
      "text": "我知道我一直有双隐形的翅膀",
      "translation": null
    },
    {
      "time": 73.16,
      "time_str": "01:13.160",
      "text": "带我飞给我希望",
      "translation": null
    },
    {
      "time": 79.99,
      "time_str": "01:19.990",
      "text": "我终于看到所有梦想都开花",
      "translation": null
    },
    {
      "time": 86.44,
      "time_str": "01:26.440",
      "text": "追逐的年轻 歌声多嘹亮",
      "translation": null
    },
    {
      "time": 93.12,
      "time_str": "01:33.120",
      "text": "我终于翱翔 用心凝望不害怕",
      "translation": null
    },
    {
      "time": 99.77,
      "time_str": "01:39.770",
      "text": "哪里会有风就飞多远吧",
