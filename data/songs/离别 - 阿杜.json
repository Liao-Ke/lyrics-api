  "lyrics": [
    {
      "time": 14.9,
      "time_str": "00:14.900",
      "text": "深情吻住了你的嘴",
      "translation": null
    },
    {
      "time": 18.23,
      "time_str": "00:18.230",
      "text": "却无能停止你的流泪",
      "translation": null
    },
    {
      "time": 22.9,
      "time_str": "00:22.900",
      "text": "这一刻我的心和你一起碎",
      "translation": null
    },
    {
      "time": 29.119,
      "time_str": "00:29.119",
      "text": "大雨下疯了的长夜",
      "translation": null
    },
    {
      "time": 32.468,
      "time_str": "00:32.468",
      "text": "沉睡的人们毫无知觉",
      "translation": null
    },
    {
      "time": 36.498,
      "time_str": "00:36.498",
      "text": "突然恨透这个世界",
      "translation": null
    },
    {
      "time": 39.898,
      "time_str": "00:39.898",
      "text": "因为要离别",
      "translation": null
    },
    {
      "time": 43.508,
      "time_str": "00:43.508",
      "text": "就走破这双鞋",
      "translation": null
    },
    {
      "time": 47.89,
      "time_str": "00:47.890",
      "text": "我陪你走一夜",
      "translation": null
    },
    {
      "time": 49.88,
      "time_str": "00:49.880",
      "text": "直到心不再滴血",
      "translation": null
    },
    {
      "time": 53.498,
      "time_str": "00:53.498",
      "text": "而你流尽泪水",
      "translation": null
    },
    {
      "time": 57.328,
      "time_str": "00:57.328",
      "text": "天空不停地闪着雷",
      "translation": null
    },
    {
      "time": 60.878,
      "time_str": "01:00.878",
      "text": "照不亮我心中黑黑黑黑黑的一切",
      "translation": null
    },
    {
      "time": 67.19,
      "time_str": "01:07.190",
      "text": "希望都早已经",
      "translation": null
    },
    {
      "time": 71.149,
      "time_str": "01:11.149",
      "text": "破灭我和你",
      "translation": null
    },
    {
      "time": 76.899,
      "time_str": "01:16.899",
      "text": "要离别 离别",
      "translation": null
