  "lyrics": [
    {
      "time": 33.25,
      "time_str": "00:33.250",
      "text": "抱抱到了我进睡",
      "translation": null
    },
    {
      "time": 36.43,
      "time_str": "00:36.430",
      "text": "独自坐着没伴随",
      "translation": null
    },
    {
      "time": 39.63,
      "time_str": "00:39.630",
      "text": "背对镜去抹眼泪",
      "translation": null
    },
    {
      "time": 42.09,
      "time_str": "00:42.090",
      "text": "年月逝去",
      "translation": null
    },
    {
      "time": 46.14,
      "time_str": "00:46.140",
      "text": "惯了说我太安静",
      "translation": null
    },
    {
      "time": 49.35,
      "time_str": "00:49.350",
      "text": "学习着独立过程",
      "translation": null
    },
    {
      "time": 52.58,
      "time_str": "00:52.580",
      "text": "发觉了也太镇定",
      "translation": null
    },
    {
      "time": 55.16,
      "time_str": "00:55.160",
      "text": "未够感性",
      "translation": null
    },
    {
      "time": 58.37,
      "time_str": "00:58.370",
      "text": "这近照已不再新",
      "translation": null
    },
    {
      "time": 61.94,
      "time_str": "01:01.940",
      "text": "面容共我相近",
      "translation": null
    },
    {
      "time": 65.14,
      "time_str": "01:05.140",
      "text": "还傻着要给你苦等",
      "translation": null
    },
    {
      "time": 71.71,
      "time_str": "01:11.710",
      "text": "扮作开心天真知不多",
      "translation": null
    },
    {
      "time": 74.97,
      "time_str": "01:14.970",
      "text": "未够两岁你竟抛弃我",
      "translation": null
    },
    {
      "time": 78.16,
      "time_str": "01:18.160",
      "text": "时日远去也需要负荷",
      "translation": null
    },
    {
      "time": 81.46,
      "time_str": "01:21.460",
      "text": "就算他每天振作静坐",
      "translation": null
    },
    {
      "time": 84.69,
      "time_str": "01:24.690",
      "text": "没你关心紧张的当初",
      "translation": null
    },
    {
      "time": 87.89,
      "time_str": "01:27.890",
      "text": "习惯等某天失去宝座",
      "translation": null
    },
    {
      "time": 91.24,
      "time_str": "01:31.240",
      "text": "唯独这合照看你清楚",
      "translation": null
    },
    {
      "time": 94.38,
      "time_str": "01:34.380",
      "text": "证实你曾是家中那个",
      "translation": null
    },
    {
      "time": 101.25,
      "time_str": "01:41.250",
      "text": "笑笑说这个宿命",
      "translation": null
    },
    {
      "time": 104.49,
      "time_str": "01:44.490",
      "text": "自幸运便没法停",
      "translation": null
    },
    {
      "time": 107.7,
      "time_str": "01:47.700",
      "text": "这次故意更冷静",
      "translation": null
    },
    {
      "time": 110.26,
      "time_str": "01:50.260",
      "text": "没有反应",
      "translation": null
    },
    {
      "time": 113.41,
      "time_str": "01:53.410",
      "text": "看着你我等再等",
      "translation": null
    },
    {
      "time": 117.08,
      "time_str": "01:57.080",
      "text": "面容让我拉近",
      "translation": null
