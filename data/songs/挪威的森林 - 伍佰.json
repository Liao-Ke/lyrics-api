  "lyrics": [
    {
      "time": 34.65,
      "time_str": "00:34.650",
      "text": "让我将你心儿摘下",
      "translation": null
    },
    {
      "time": 38.06,
      "time_str": "00:38.060",
      "text": "试着将它慢慢溶化",
      "translation": null
    },
    {
      "time": 41.65,
      "time_str": "00:41.650",
      "text": "看我在你心中是否仍完美无瑕",
      "translation": null
    },
    {
      "time": 48.23,
      "time_str": "00:48.230",
      "text": "是否依然为我丝丝牵挂",
      "translation": null
    },
    {
      "time": 52.14,
      "time_str": "00:52.140",
      "text": "依然爱我无法自拔",
      "translation": null
    },
    {
      "time": 55.67,
      "time_str": "00:55.670",
      "text": "心中是否有我未曾到过的地方啊",
      "translation": null
    },
    {
      "time": 62.3,
      "time_str": "01:02.300",
      "text": "那里湖面总是澄清",
      "translation": null
    },
    {
      "time": 65.82,
      "time_str": "01:05.820",
      "text": "那里空气充满宁静",
      "translation": null
    },
    {
      "time": 69.32,
      "time_str": "01:09.320",
      "text": "雪白明月照在大地",
      "translation": null
    },
    {
      "time": 72.82,
      "time_str": "01:12.820",
      "text": "藏着你不愿提起的回忆",
      "translation": null
    },
    {
      "time": 78.22,
      "time_str": "01:18.220",
      "text": "你说真心总是可以从头",
      "translation": null
    },
    {
      "time": 82.04,
      "time_str": "01:22.040",
      "text": "真爱总是可以长久",
      "translation": null
    },
    {
      "time": 85.7,
      "time_str": "01:25.700",
      "text": "为何你的眼神还有孤独时的落寞",
      "translation": null
    },
    {
      "time": 92.16,
      "time_str": "01:32.160",
      "text": "是否我只是你一种寄托",
      "translation": null
    },
    {
      "time": 96.12,
      "time_str": "01:36.120",
      "text": "填满你感情的缺口",
      "translation": null
    },
    {
      "time": 99.64,
      "time_str": "01:39.640",
      "text": "心中那片森林何时能让我停留",
      "translation": null
    },
    {
      "time": 106.23,
      "time_str": "01:46.230",
      "text": "那里湖面总是澄清",
      "translation": null
    },
    {
      "time": 109.71,
      "time_str": "01:49.710",
      "text": "那里空气充满宁静",
      "translation": null
    },
    {
      "time": 113.23,
      "time_str": "01:53.230",
      "text": "雪白明月照在大地",
      "translation": null
    },
    {
      "time": 116.78,
      "time_str": "01:56.780",
      "text": "藏着你最深处的秘密",
      "translation": null
    },
    {
      "time": 121.68,
      "time_str": "02:01.680",
      "text": "或许我",
      "translation": null
    },
    {
      "time": 123.4,
      "time_str": "02:03.400",
      "text": "不该问",
      "translation": null
    },
    {
      "time": 125.14,
      "time_str": "02:05.140",
      "text": "让你平静的心再起涟漪",
      "translation": null
    },
    {
      "time": 129.09,
      "time_str": "02:09.090",
      "text": "只是爱你的心超出了界线",
      "translation": null
    },
    {
      "time": 132.64,
      "time_str": "02:12.640",
      "text": "我想拥有你所有一切",
      "translation": null
    },
    {
      "time": 135.69,
      "time_str": "02:15.690",
      "text": "应该是",
      "translation": null
    },
    {
      "time": 137.25,
      "time_str": "02:17.250",
      "text": "我不该问",
      "translation": null
    },
    {
      "time": 139.2,
      "time_str": "02:19.200",
      "text": "不该让你再将往事重提",
      "translation": null
    },
    {
      "time": 143.58,
      "time_str": "02:23.580",
      "text": "只是心中枷锁",
      "translation": null
    },
    {
      "time": 145.09,
      "time_str": "02:25.090",
      "text": "该如何才能解脱",
      "translation": null
    },
