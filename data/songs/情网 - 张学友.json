  "lyrics": [
    {
      "time": 3.0,
      "time_str": "00:03.000",
      "text": "Publisher : Codan (In-Co) / PolyGram Taiwan (PolyGram)",
      "translation": null
    },
    {
      "time": 15.935,
      "time_str": "00:15.935",
      "text": "请你再为我点上一盏烛光",
      "translation": null
    },
    {
      "time": 23.845,
      "time_str": "00:23.845",
      "text": "因为我早已迷失了方向",
      "translation": null
    },
    {
      "time": 31.673,
      "time_str": "00:31.673",
      "text": "我掩饰不住的慌张",
      "translation": null
    },
    {
      "time": 35.654,
      "time_str": "00:35.654",
      "text": "在迫不及待地张望",
      "translation": null
    },
    {
      "time": 39.581,
      "time_str": "00:39.581",
      "text": "深怕这一路是好梦一场",
      "translation": null
    },
    {
      "time": 47.512,
      "time_str": "00:47.512",
      "text": "而你是一张无边无际的网",
      "translation": null
    },
    {
      "time": 55.314,
      "time_str": "00:55.314",
      "text": "轻易就把我困在网中央",
      "translation": null
    },
    {
      "time": 63.156,
      "time_str": "01:03.156",
      "text": "我越陷越深越迷惘",
      "translation": null
    },
    {
      "time": 67.082,
      "time_str": "01:07.082",
      "text": "路越走越远越漫长",
      "translation": null
    },
    {
      "time": 71.06,
      "time_str": "01:11.060",
      "text": "如何我才能捉住你眼光",
      "translation": null
    },
    {
      "time": 78.655,
      "time_str": "01:18.655",
      "text": "情愿就这样守在你身旁",
      "translation": null
    },
    {
      "time": 86.768,
      "time_str": "01:26.768",
      "text": "情愿就这样一辈子不忘",
      "translation": null
    },
    {
      "time": 94.687,
      "time_str": "01:34.687",
      "text": "我打开爱情这扇窗",
      "translation": null
    },
    {
      "time": 98.586,
      "time_str": "01:38.586",
      "text": "却看见长夜里凄凉",
      "translation": null
    },
    {
      "time": 102.486,
      "time_str": "01:42.486",
      "text": "问你是否会舍得我心伤",
      "translation": null
    },
    {
