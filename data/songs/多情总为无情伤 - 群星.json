    {
      "time": 53.87,
      "time_str": "00:53.870",
      "text": "我的眼里有漫天风沙",
      "translation": null
    },
    {
      "time": 58.16,
      "time_str": "00:58.160",
      "text": "我的心不为谁溶化",
      "translation": null
    },
    {
      "time": 62.41,
      "time_str": "01:02.410",
      "text": "我的泪洒遍沙漠不开花",
      "translation": null
    },
    {
      "time": 67.6,
      "time_str": "01:07.600",
      "text": "不愿为你牵挂",
      "translation": null
    },
    {
      "time": 75.25,
      "time_str": "01:15.250",
      "text": "给爱流浪的人一个家",
      "translation": null
    },
    {
      "time": 79.35,
      "time_str": "01:19.350",
      "text": "送给孤独的人真心话",
      "translation": null
    },
    {
      "time": 83.65,
      "time_str": "01:23.650",
      "text": "经过这些年你还想我吗",
      "translation": null
    },
    {
      "time": 88.95,
      "time_str": "01:28.950",
      "text": "其实也不必回答",
      "translation": null
    },
    {
      "time": 96.28,
      "time_str": "01:36.280",
      "text": "多情的人总因为无情伤心",
      "translation": null
    },
    {
      "time": 100.72,
      "time_str": "01:40.720",
      "text": "又何苦执着谁对谁最真心",
      "translation": null
    },
    {
      "time": 105.12,
      "time_str": "01:45.120",
      "text": "风沙千年都吹不停",
      "translation": null
    },
    {
      "time": 109.24,
      "time_str": "01:49.240",
      "text": "掩住我滴滴泪的眼睛",
      "translation": null
    },
    {
      "time": 113.57,
      "time_str": "01:53.570",
      "text": "多情的人总因为无情伤心",
      "translation": null
    },
    {
      "time": 117.72,
      "time_str": "01:57.720",
      "text": "别问我今生何时才会梦醒",
