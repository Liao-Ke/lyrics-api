  "lyrics": [
    {
      "time": 35.27,
      "time_str": "00:35.270",
      "text": "下一整夜的暴雨",
      "translation": null
    },
    {
      "time": 37.47,
      "time_str": "00:37.470",
      "text": "让我只想静静抱着你",
      "translation": null
    },
    {
      "time": 41.31,
      "time_str": "00:41.310",
      "text": "Baby",
      "translation": null
    },
    {
      "time": 43.53,
      "time_str": "00:43.530",
      "text": "谈谈我们的过去",
      "translation": null
    },
    {
      "time": 45.43,
      "time_str": "00:45.430",
      "text": "看看漫步半生的轨迹",
      "translation": null
    },
    {
      "time": 49.69,
      "time_str": "00:49.690",
      "text": "Baby",
      "translation": null
    },
    {
      "time": 51.29,
      "time_str": "00:51.290",
      "text": "亲爱的 如果时光倒退一回",
      "translation": null
    },
    {
      "time": 55.84,
      "time_str": "00:55.840",
      "text": "你最想和谁 喝两杯不醉不归",
      "translation": null
    },
    {
      "time": 61.0,
      "time_str": "01:01.000",
      "text": "那一个人还会是我吗",
      "translation": null
    },
    {
      "time": 64.39,
      "time_str": "01:04.390",
      "text": "我们还会不会 把野草当作玫瑰",
      "translation": null
    },
    {
      "time": 68.89,
      "time_str": "01:08.890",
      "text": "下一整夜的暴雨",
      "translation": null
    },
    {
      "time": 70.59,
      "time_str": "01:10.590",
      "text": "让我只想静静抱着你",
      "translation": null
    },
    {
      "time": 74.96,
      "time_str": "01:14.960",
      "text": "Baby",
      "translation": null
    },
    {
      "time": 76.43,
      "time_str": "01:16.430",
      "text": "谈谈我们的过去",
      "translation": null
    },
    {
      "time": 78.78,
      "time_str": "01:18.780",
      "text": "看看漫步半生的轨迹",
      "translation": null
    },
    {
      "time": 83.03,
      "time_str": "01:23.030",
      "text": "Baby",
      "translation": null
    },
    {
      "time": 84.82,
      "time_str": "01:24.820",
      "text": "亲爱的 谢谢你陪伴安慰",
      "translation": null
    },
    {
      "time": 89.59,
      "time_str": "01:29.590",
      "text": "不管是春风得意 或绝望颓废",
      "translation": null
    },
    {
      "time": 94.1,
      "time_str": "01:34.100",
      "text": "晓得了人言可畏",
      "translation": null
    },
    {
      "time": 97.95,
      "time_str": "01:37.950",
      "text": "好像才三十岁 却聪明了三十倍",
      "translation": null
    },
    {
      "time": 101.75,
      "time_str": "01:41.750",
      "text": "我不知会遇见你",
      "translation": null
    },
    {
      "time": 103.75,
      "time_str": "01:43.750",
      "text": "那年1987",
      "translation": null
    },
    {
      "time": 106.4,
      "time_str": "01:46.400",
      "text": "夜空有好多 闪烁星星",
      "translation": null
    },
    {
      "time": 110.66,
      "time_str": "01:50.660",
      "text": "爱是纯白的愿意",
      "translation": null
    },
    {
      "time": 112.26,
      "time_str": "01:52.260",
      "text": "我是我 你也只是你",
      "translation": null
    },
    {
      "time": 118.51,
      "time_str": "01:58.510",
      "text": "我不知会遇见你",
      "translation": null
    },
    {
      "time": 120.46,
      "time_str": "02:00.460",
      "text": "那年1987",
      "translation": null
    },
    {
      "time": 123.17,
      "time_str": "02:03.170",
      "text": "感动会来得 轻而易举",
      "translation": null
    },
    {
      "time": 127.71,
      "time_str": "02:07.710",
      "text": "浪漫也还很便宜",
      "translation": null
    },
    {
      "time": 128.92,
      "time_str": "02:08.920",
      "text": "情是情 趣也只是趣",
      "translation": null
    },
    {
      "time": 135.42,
      "time_str": "02:15.420",
      "text": "摔过跤的石板路",
      "translation": null
    },
    {
      "time": 137.53,
      "time_str": "02:17.530",
      "text": "早就被需求无情拆除",
      "translation": null
    },
    {
      "time": 141.3,
      "time_str": "02:21.300",
      "text": "不复",
      "translation": null
    },
    {
      "time": 143.83,
      "time_str": "02:23.830",
      "text": "最火热的流行歌",
      "translation": null
    },
    {
      "time": 145.58,
      "time_str": "02:25.580",
      "text": "也已经随岁月改名叫复古",
      "translation": null
    },
    {
      "time": 150.0,
      "time_str": "02:30.000",
      "text": "记住",
      "translation": null
    },
    {
      "time": 151.63,
      "time_str": "02:31.630",
      "text": "亲爱的 看看那些物是人非",
      "translation": null
    },
    {
      "time": 156.33,
      "time_str": "02:36.330",
      "text": "别忘记我们 萌芽时多么珍贵",
      "translation": null
    },
    {
      "time": 160.99,
      "time_str": "02:40.990",
      "text": "现实最拿手 不动声色的潜规",
      "translation": null
    },
    {
      "time": 165.74,
      "time_str": "02:45.740",
      "text": "把最初的信念 步步拖溃",
      "translation": null
    },
    {
      "time": 168.49,
      "time_str": "02:48.490",
      "text": "我不知会遇见你",
      "translation": null
