  "lyrics": [
    {
      "time": 16.65,
      "time_str": "00:16.650",
      "text": "一九九五年 我们在机场的车站",
      "translation": null
    },
    {
      "time": 23.58,
      "time_str": "00:23.580",
      "text": "你借我 而我不想归还",
      "translation": null
    },
    {
      "time": 30.42,
      "time_str": "00:30.420",
      "text": "那个背包 都载满纪念品和患难",
      "translation": null
    },
    {
      "time": 38.75,
      "time_str": "00:38.750",
      "text": "还有摩擦留下的图 案",
      "translation": null
    },
    {
      "time": 45.73,
      "time_str": "00:45.730",
      "text": "你的背包 背到现在还没烂",
      "translation": null
    },
    {
      "time": 54.7,
      "time_str": "00:54.700",
      "text": "却 成为我身体另一半",
      "translation": null
    },
    {
      "time": 60.83,
      "time_str": "01:00.830",
      "text": "千金不换 它已熟悉我的汗",
      "translation": null
    },
    {
      "time": 69.28,
      "time_str": "01:09.280",
      "text": "它 是我肩膀上的指环",
      "translation": null
    },
    {
      "time": 77.55,
      "time_str": "01:17.550",
      "text": "背了六年半 我每一天陪它上班",
      "translation": null
    },
    {
      "time": 84.53,
      "time_str": "01:24.530",
      "text": "你借我 我就为你保管",
      "translation": null
    },
    {
      "time": 91.35,
      "time_str": "01:31.350",
      "text": "我的朋友 不都说它旧的很好看",
      "translation": null
    },
    {
      "time": 99.75,
      "time_str": "01:39.750",
      "text": "遗憾是它已与你无 关",
      "translation": null
    },
    {
      "time": 106.67,
      "time_str": "01:46.670",
      "text": "你的背包 让我走的好缓慢",
      "translation": null
    },
    {
      "time": 114.979,
      "time_str": "01:54.979",
      "text": "总 有一天陪着我腐烂",
      "translation": null
    },
    {
      "time": 121.89,
      "time_str": "02:01.890",
      "text": "你的背包 对我沉重的审判",
      "translation": null
    },
    {
      "time": 130.228,
      "time_str": "02:10.228",
      "text": "借了东西为什么不还",
      "translation": null
    },
