    {
      "time": 227.39,
      "time_str": "03:47.390",
      "text": "寓言藏在我心中",
      "translation": null
    },
    {
      "time": 230.65,
      "time_str": "03:50.650",
      "text": "相信它吧 往前冲",
      "translation": null
    },
    {
      "time": 234.01,
      "time_str": "03:54.010",
      "text": "我的路 我就一定让它走成幸福",
      "translation": null
    },
    {
      "time": 240.54,
      "time_str": "04:00.540",
      "text": "那些作了的梦忘了吗",
      "translation": null
    },
    {
      "time": 243.84,
      "time_str": "04:03.840",
      "text": "那些万分之一的也许",
      "translation": null
    },
    {
      "time": 247.1,
      "time_str": "04:07.100",
      "text": "不用说 我还是我",
      "translation": null
    },
    {
      "time": 250.06,
      "time_str": "04:10.060",
      "text": "约定怎样寂寞也不能哭",
      "translation": null
    },
    {
      "time": 256.52,
