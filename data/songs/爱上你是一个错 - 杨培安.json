  "lyrics": [
    {
      "time": 16.83,
      "time_str": "00:16.830",
      "text": "人生有许多难关要过",
      "translation": null
    },
    {
      "time": 20.53,
      "time_str": "00:20.530",
      "text": "自古是情关最让人难受",
      "translation": null
    },
    {
      "time": 24.79,
      "time_str": "00:24.790",
      "text": "也许我命中注定情海中颠簸",
      "translation": null
    },
    {
      "time": 32.3,
      "time_str": "00:32.300",
      "text": "为你我付出这么的多",
      "translation": null
    },
    {
      "time": 36.67,
      "time_str": "00:36.670",
      "text": "却让我痛到有苦不能说",
      "translation": null
    },
    {
      "time": 40.88,
      "time_str": "00:40.880",
      "text": "因为我爱你就像那飞蛾扑向火",
      "translation": null
    },
    {
      "time": 47.81,
      "time_str": "00:47.810",
      "text": "请你告诉我爱上你是一个错",
      "translation": null
    },
    {
      "time": 52.83,
      "time_str": "00:52.830",
      "text": "别让我失魂落魄着了魔",
      "translation": null
    },
    {
      "time": 57.84,
      "time_str": "00:57.840",
      "text": "解开我的迷惑",
      "translation": null
    },
    {
      "time": 59.55,
      "time_str": "00:59.550",
      "text": "收起你的冷漠",
      "translation": null
    },
    {
      "time": 61.54,
      "time_str": "01:01.540",
      "text": "你怎忍心这样做",
      "translation": null
    },
    {
      "time": 64.51,
      "time_str": "01:04.510",
      "text": "请你告诉我爱上你是一个错",
      "translation": null
    },
    {
      "time": 69.48,
      "time_str": "01:09.480",
      "text": "别让我漫漫长夜守寂寞",
      "translation": null
    },
    {
      "time": 73.44,
      "time_str": "01:13.440",
      "text": "伤痛已经太多",
      "translation": null
    },
    {
      "time": 75.74,
      "time_str": "01:15.740",
      "text": "心也早已伤透",
      "translation": null
    },
    {
      "time": 78.0,
      "time_str": "01:18.000",
      "text": "我已不想再为谁去等候",
      "translation": null
