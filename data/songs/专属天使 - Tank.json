  "lyrics": [
    {
      "time": 15.75,
      "time_str": "00:15.750",
      "text": "我不会怪你 对我的伪装",
      "translation": null
    },
    {
      "time": 23.14,
      "time_str": "00:23.140",
      "text": "天使在人间是该藏好翅膀",
      "translation": null
    },
    {
      "time": 29.35,
      "time_str": "00:29.350",
      "text": "人们愚蠢鲁莽 而你纤细善良",
      "translation": null
    },
    {
      "time": 36.79,
      "time_str": "00:36.790",
      "text": "怎能让你为了我被碰伤",
      "translation": null
    },
    {
      "time": 45.32,
      "time_str": "00:45.320",
      "text": "小小的手掌 厚厚的温暖",
      "translation": null
    },
    {
      "time": 52.71,
      "time_str": "00:52.710",
      "text": "你总能平复我不安的夜晚",
      "translation": null
    },
    {
      "time": 59.01,
      "time_str": "00:59.010",
      "text": "不敢想的梦想 透过你的眼光",
      "translation": null
    },
    {
      "time": 66.33,
      "time_str": "01:06.330",
      "text": "我才看见 它原来在前方",
      "translation": null
    },
    {
      "time": 74.43,
      "time_str": "01:14.430",
      "text": "没有谁能把你抢离我身旁",
      "translation": null
    },
    {
      "time": 81.1,
      "time_str": "01:21.100",
      "text": "你是我的专属天使 唯我能独占",
      "translation": null
    },
    {
      "time": 89.16,
      "time_str": "01:29.160",
      "text": "没有谁能取代你在我心上",
      "translation": null
    },
    {
      "time": 95.82,
      "time_str": "01:35.820",
      "text": "拥有一个专属天使 我哪里还需要别的愿望",
      "translation": null
    },
    {
      "time": 108.05,
      "time_str": "01:48.050",
      "text": "小小的手掌 大大的力量",
      "translation": null
    },
    {
      "time": 115.41,
      "time_str": "01:55.410",
      "text": "我一定也会像你一样飞翔",
      "translation": null
    },
    {
      "time": 121.65,
      "time_str": "02:01.650",
      "text": "你想去的地方 就是我的方向",
      "translation": null
    },
    {
      "time": 129.11,
      "time_str": "02:09.110",
      "text": "有我保护 笑容尽管灿烂",
      "translation": null
    },
    {
