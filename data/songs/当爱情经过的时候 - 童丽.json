  "lyrics": [
    {
      "time": 64.415,
      "time_str": "01:04.415",
      "text": "借着星光的温柔",
      "translation": null
    },
    {
      "time": 68.601,
      "time_str": "01:08.601",
      "text": "我自己一个人走",
      "translation": null
    },
    {
      "time": 72.802,
      "time_str": "01:12.802",
      "text": "挥动蓝色的衣袖",
      "translation": null
    },
    {
      "time": 76.995,
      "time_str": "01:16.995",
      "text": "任寂寞喋喋不休",
      "translation": null
    },
    {
      "time": 81.249,
      "time_str": "01:21.249",
      "text": "缘分可遇不可求",
      "translation": null
    },
    {
      "time": 85.45,
      "time_str": "01:25.450",
      "text": "他会在第几层楼",
      "translation": null
    },
    {
      "time": 89.655,
      "time_str": "01:29.655",
      "text": "每当想见你一面",
      "translation": null
    },
    {
      "time": 93.907,
      "time_str": "01:33.907",
      "text": "我就向记忆开口",
      "translation": null
    },
    {
      "time": 97.859,
      "time_str": "01:37.859",
      "text": "你若回头就用眼神和我交流",
      "translation": null
    },
    {
      "time": 105.992,
      "time_str": "01:45.992",
      "text": "无需太多的语言",
      "translation": null
    },
    {
      "time": 110.244,
      "time_str": "01:50.244",
      "text": "用瞬间替代永久",
      "translation": null
    },
    {
      "time": 114.799,
      "time_str": "01:54.799",
      "text": "当爱情经过的时候",
      "translation": null
    },
    {
      "time": 118.9,
      "time_str": "01:58.900",
      "text": "我没有牵到他的手",
      "translation": null
    },
    {
      "time": 123.151,
      "time_str": "02:03.151",
      "text": "梦在九霄云外的另一个宇宙",
      "translation": null
    },
    {
      "time": 127.502,
      "time_str": "02:07.502",
      "text": "就仿佛美丽的石榴",
      "translation": null
    },
    {
      "time": 131.602,
      "time_str": "02:11.602",
      "text": "当爱情经过的时候",
      "translation": null
    },
    {
      "time": 135.804,
      "time_str": "02:15.804",
      "text": "我不知自己在梦游",
      "translation": null
    },
    {
      "time": 139.854,
      "time_str": "02:19.854",
      "text": "到下一个路口",
      "translation": null
    },
    {
      "time": 142.56,
      "time_str": "02:22.560",
      "text": "是向左还是右",
      "translation": null
    },
    {
      "time": 144.444,
      "time_str": "02:24.444",
      "text": "有谁来为我参谋",
      "translation": null
    },
