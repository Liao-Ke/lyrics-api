  "lyrics": [
    {
      "time": 20.11,
      "time_str": "00:20.110",
      "text": "（马雪阳）回忆着初次相遇坐在你身旁",
      "translation": null
    },
    {
      "time": 24.55,
      "time_str": "00:24.550",
      "text": "是谁曾经说 太幸福会缺氧",
      "translation": null
    },
    {
      "time": 29.74,
      "time_str": "00:29.740",
      "text": "爱情已种在心里 自由的生长",
      "translation": null
    },
    {
      "time": 34.64,
      "time_str": "00:34.640",
      "text": "童话里的浪漫 需要用心去培养",
      "translation": null
    },
    {
      "time": 39.98,
      "time_str": "00:39.980",
      "text": "（刘洲成）想带你一起流浪 沐浴阳光",
      "translation": null
    },
    {
      "time": 44.51,
      "time_str": "00:44.510",
      "text": "去完成温暖的想象",
      "translation": null
    },
    {
      "time": 49.6,
      "time_str": "00:49.600",
      "text": "喜欢你任性时候 可爱模样",
      "translation": null
    },
    {
      "time": 53.98,
      "time_str": "00:53.980",
      "text": "好像失意时投下的阳光",
      "translation": null
    },
    {
      "time": 57.8,
      "time_str": "00:57.800",
      "text": "（金恩圣）你就是我心中的棉花糖 甜蜜的梦想",
      "translation": null
    },
    {
      "time": 63.94,
      "time_str": "01:03.940",
      "text": "彼此牵起的双手 谁都不要放",
      "translation": null
    },
    {
      "time": 68.89,
      "time_str": "01:08.890",
      "text": "去眺望 在远方 悉数快乐和希望",
      "translation": null
    },
    {
      "time": 73.84,
      "time_str": "01:13.840",
      "text": "展开翅膀 我们自由飞翔",
      "translation": null
    },
    {
      "time": 78.15,
      "time_str": "01:18.150",
      "text": "（张远）你就是我心中的棉花糖 甜蜜的梦想",
      "translation": null
    },
    {
      "time": 84.17,
      "time_str": "01:24.170",
      "text": "有你世界都变了 就算天快亮",
      "translation": null
    },
    {
      "time": 89.7,
      "time_str": "01:29.700",
      "text": "能不能 就这样 自由的去游荡",
      "translation": null
    },
    {
      "time": 93.85,
      "time_str": "01:33.850",
      "text": "爱在我们心间 悄悄绽放 许下愿望",
      "translation": null
    },
    {
      "time": 99.75,
      "time_str": "01:39.750",
      "text": "（李茂）在寒冷时候 我们难免会彷徨",
      "translation": null
    },
    {
      "time": 101.71,
      "time_str": "01:41.710",
      "text": "爱总会守在某个地方 建造起围墙",
      "translation": null
    },
    {
      "time": 104.01,
      "time_str": "01:44.010",
      "text": "心需要更坚强 不退让不绝望",
      "translation": null
    },
    {
      "time": 106.62,
      "time_str": "01:46.620",
      "text": "有时候等待 慢慢代替了感伤",
      "translation": null
    },
    {
      "time": 108.9,
      "time_str": "01:48.900",
      "text": "需要去付出 多一些互相体谅",
      "translation": null
    },
    {
      "time": 111.12,
      "time_str": "01:51.120",
      "text": "想一起去等待着 那道曙光",
      "translation": null
    },
    {
      "time": 113.6,
      "time_str": "01:53.600",
      "text": "将风雨之中那盏烛火 慢慢点亮",
      "translation": null
    },
    {
      "time": 116.05,
      "time_str": "01:56.050",
      "text": "未来的时光 有我的肩膀",
      "translation": null
    },
