  "lyrics": [
    {
      "time": 24.08,
      "time_str": "00:24.080",
      "text": "曾看着同星空 闲聊吹风 看日出多心动",
      "translation": null
    },
    {
      "time": 29.62,
      "time_str": "00:29.620",
      "text": "曾每日缠一起 傻傻讲起 能爱到下世纪",
      "translation": null
    },
    {
      "time": 35.35,
      "time_str": "00:35.350",
      "text": "怎么你俘虏这个心 却抽身退隐 不再亲近",
      "translation": null
    },
    {
      "time": 41.33,
      "time_str": "00:41.330",
      "text": "独自苦等 仍然空等 难藏泪印",
      "translation": null
    },
    {
      "time": 47.04,
      "time_str": "00:47.040",
      "text": "看着 电话中短讯",
      "translation": null
    },
    {
      "time": 50.59,
      "time_str": "00:50.590",
      "text": "听着 录音的口讯",
      "translation": null
    },
    {
      "time": 53.38,
      "time_str": "00:53.380",
      "text": "昨天的你哪天再接近",
      "translation": null
    },
    {
      "time": 58.95,
      "time_str": "00:58.950",
      "text": "Tell me where did u go?",
      "translation": null
    },
    {
      "time": 64.019,
      "time_str": "01:04.019",
      "text": "心声都不可细诉 Oh tell me baby where did u hide?",
      "translation": null
    },
    {
      "time": 70.44,
      "time_str": "01:10.440",
      "text": "辛苦都未被谅解 Where did u go?",
      "translation": null
    },
    {
      "time": 75.74,
      "time_str": "01:15.740",
      "text": "数数多久不碰到 我在每夜 彻夜狂想 Where did u go?",
      "translation": null
    },
    {
      "time": 88.08,
      "time_str": "01:28.080",
      "text": "而这夜月光中 再见影纵 再献花多感动",
      "translation": null
    },
    {
      "time": 93.73,
      "time_str": "01:33.730",
      "text": "而似蜜甜的心 明明开心 为何又骤降温",
      "translation": null
    },
    {
      "time": 99.65,
      "time_str": "01:39.650",
      "text": "怎么你一下子抱紧 却一下子转身 不再亲近",
      "translation": null
