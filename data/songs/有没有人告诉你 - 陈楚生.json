  "lyrics": [
    {
      "time": 14.94,
      "time_str": "00:14.940",
      "text": "当火车开入这座陌生的城市",
      "translation": null
    },
    {
      "time": 22.74,
      "time_str": "00:22.740",
      "text": "那是从来就没有见过的霓虹",
      "translation": null
    },
    {
      "time": 30.42,
      "time_str": "00:30.420",
      "text": "我打开离别时你送我的信件",
      "translation": null
    },
    {
      "time": 38.82,
      "time_str": "00:38.820",
      "text": "忽然感到无比的思念",
      "translation": null
    },
    {
      "time": 45.9,
      "time_str": "00:45.900",
      "text": "看不见雪的冬天不夜的城市",
      "translation": null
    },
    {
      "time": 53.64,
      "time_str": "00:53.640",
      "text": "我听见有人欢呼有人在哭泣",
      "translation": null
    },
    {
      "time": 61.38,
      "time_str": "01:01.380",
      "text": "早习惯穿梭充满诱惑的黑夜",
      "translation": null
    },
    {
      "time": 69.81,
      "time_str": "01:09.810",
      "text": "但却无法忘记你的脸",
      "translation": null
    },
    {
      "time": 76.86,
      "time_str": "01:16.860",
      "text": "有没有人曾告诉你我很爱你",
      "translation": null
    },
    {
      "time": 84.629,
      "time_str": "01:24.629",
      "text": "有没有人曾在你日记里哭泣",
      "translation": null
    },
    {
      "time": 92.37,
      "time_str": "01:32.370",
      "text": "有没有人曾告诉你我很在意",
      "translation": null
    },
    {
      "time": 100.739,
      "time_str": "01:40.739",
      "text": "在意这座城市的距离",
      "translation": null
    },
