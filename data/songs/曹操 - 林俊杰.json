    {
      "time": 26.847,
      "time_str": "00:26.847",
      "text": "不是英雄 不读三国",
      "translation": null
    },
    {
      "time": 33.491,
      "time_str": "00:33.491",
      "text": "若是英雄 怎么能不懂寂寞",
      "translation": null
    },
    {
      "time": 39.701,
      "time_str": "00:39.701",
      "text": "独自走下长坂坡 月光太温柔",
      "translation": null
    },
    {
      "time": 43.195,
      "time_str": "00:43.195",
      "text": "曹操不啰嗦 一心要拿荆州",
      "translation": null
    },
    {
      "time": 46.795,
      "time_str": "00:46.795",
      "text": "用阴谋 阳谋 明说 暗夺的摸",
      "translation": null
    },
    {
      "time": 53.461,
      "time_str": "00:53.461",
      "text": "东汉末年分三国",
      "translation": null
    },
    {
      "time": 56.535,
      "time_str": "00:56.535",
      "text": "烽火连天不休",
      "translation": null
    },
    {
      "time": 60.125,
      "time_str": "01:00.125",
      "text": "儿女情长 被乱世左右",
      "translation": null
    },
    {
      "time": 65.132,
      "time_str": "01:05.132",
      "text": "谁来煮酒",
      "translation": null
    },
    {
      "time": 66.777,
      "time_str": "01:06.777",
      "text": "尔虞我诈是三国",
      "translation": null
    },
    {
      "time": 69.854,
      "time_str": "01:09.854",
      "text": "说不清对与错",
      "translation": null
    },
    {
      "time": 73.444,
      "time_str": "01:13.444",
      "text": "纷纷扰扰 千百年以后",
      "translation": null
    },
    {
      "time": 78.47,
      "time_str": "01:18.470",
      "text": "一切又从头",
      "translation": null
