  "lyrics": [
    {
      "time": 35.0,
      "time_str": "00:35.000",
      "text": "她熄掉晚灯 幽幽掩两肩",
      "translation": null
    },
    {
      "time": 39.0,
      "time_str": "00:39.000",
      "text": "交织了火花 拘禁在沉淀",
      "translation": null
    },
    {
      "time": 43.0,
      "time_str": "00:43.000",
      "text": "心刚被割损 经不起变迁",
      "translation": null
    },
    {
      "time": 47.0,
      "time_str": "00:47.000",
      "text": "她偏以指尖 牵引着磁电",
      "translation": null
    },
    {
      "time": 51.0,
      "time_str": "00:51.000",
      "text": "汹涌的爱",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "扑着我尽力乱吻乱缠",
      "translation": null
    },
    {
      "time": 59.0,
      "time_str": "00:59.000",
      "text": "偏偏知道爱令我无明天",
      "translation": null
    },
    {
      "time": 66.0,
      "time_str": "01:06.000",
      "text": "她倚着我肩 呼吸响耳边",
      "translation": null
    },
    {
      "time": 70.0,
      "time_str": "01:10.000",
      "text": "高温已产生 色相令人乱",
      "translation": null
    },
    {
      "time": 74.0,
      "time_str": "01:14.000",
      "text": "君子在扑火 吹不走暖烟",
      "translation": null
    },
    {
      "time": 78.0,
      "time_str": "01:18.000",
      "text": "她加上嘴巴 给我做磨练",
      "translation": null
    },
    {
      "time": 82.0,
      "time_str": "01:22.000",
      "text": "汹涌的爱",
      "translation": null
    },
    {
      "time": 84.0,
      "time_str": "01:24.000",
      "text": "扑着我尽力乱吻乱缠",
      "translation": null
    },
    {
      "time": 89.0,
      "time_str": "01:29.000",
      "text": "偏偏知道爱令我无明天",
      "translation": null
    },
    {
      "time": 97.0,
      "time_str": "01:37.000",
      "text": "爱会像头饿狼",
      "translation": null
    },
    {
      "time": 99.0,
      "time_str": "01:39.000",
      "text": "嘴巴似极甜",
      "translation": null
    },
    {
      "time": 101.0,
      "time_str": "01:41.000",
      "text": "假使走近玩玩它凶相便呈现",
      "translation": null
    },
    {
      "time": 105.0,
      "time_str": "01:45.000",
      "text": "爱会像头饿狼",
      "translation": null
    },
    {
      "time": 107.0,
      "time_str": "01:47.000",
      "text": "岂可抱着眠",
      "translation": null
    },
    {
      "time": 108.0,
      "time_str": "01:48.000",
      "text": "它必给我狠狠的伤势做留念",
      "translation": null
    },
