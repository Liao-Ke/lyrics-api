  "lyrics": [
    {
      "time": 14.12,
      "time_str": "00:14.120",
      "text": "把太细的神经割掉",
      "translation": null
    },
    {
      "time": 17.57,
      "time_str": "00:17.570",
      "text": "会不会比较睡得着",
      "translation": null
    },
    {
      "time": 20.84,
      "time_str": "00:20.840",
      "text": "我的心有座灰色的监牢",
      "translation": null
    },
    {
      "time": 26.74,
      "time_str": "00:26.740",
      "text": "关着一票黑色念头在吼叫",
      "translation": null
    },
    {
      "time": 35.82,
      "time_str": "00:35.820",
      "text": "把太硬的脾气抽掉",
      "translation": null
    },
    {
      "time": 39.32,
      "time_str": "00:39.320",
      "text": "会不会比较被明了",
      "translation": null
    },
    {
      "time": 43.12,
      "time_str": "00:43.120",
      "text": "你可以重重把我给打倒",
      "translation": null
    },
    {
      "time": 50.6,
      "time_str": "00:50.600",
      "text": "但是想都别想我求饶",
      "translation": null
    },
    {
      "time": 58.04,
      "time_str": "00:58.040",
      "text": "你是魔鬼中的天使",
      "translation": null
    },
    {
      "time": 61.5,
      "time_str": "01:01.500",
      "text": "所以送我心碎的方式",
      "translation": null
    },
    {
      "time": 65.59,
      "time_str": "01:05.590",
      "text": "是让我笑到最后一秒为止",
      "translation": null
    },
    {
      "time": 69.42,
      "time_str": "01:09.420",
      "text": "才发现自己胸口插了一把刀子",
      "translation": null
    },
    {
      "time": 72.85,
      "time_str": "01:12.850",
      "text": "你是魔鬼中的天使",
      "translation": null
    },
    {
      "time": 76.12,
      "time_str": "01:16.120",
      "text": "让恨变成太俗气的事",
      "translation": null
    },
    {
      "time": 79.88,
      "time_str": "01:19.880",
      "text": "从眼里流下谢谢两个字",
      "translation": null
    },
    {
      "time": 83.65,
      "time_str": "01:23.650",
      "text": "尽管叫我疯子 不准叫我傻子",
      "translation": null
    },
