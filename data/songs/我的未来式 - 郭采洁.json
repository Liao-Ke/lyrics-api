  "lyrics": [
    {
      "time": 11.86,
      "time_str": "00:11.860",
      "text": "脱下鞋子跳舞 赤着脚太空漫步",
      "translation": null
    },
    {
      "time": 15.8,
      "time_str": "00:15.800",
      "text": "我笑了 你还装酷",
      "translation": null
    },
    {
      "time": 17.72,
      "time_str": "00:17.720",
      "text": "阳光晒过的路 正好是年轻的温度",
      "translation": null
    },
    {
      "time": 21.86,
      "time_str": "00:21.860",
      "text": "温暖舒服",
      "translation": null
    },
    {
      "time": 23.74,
      "time_str": "00:23.740",
      "text": "吵醒了闹区 的树木",
      "translation": null
    },
    {
      "time": 27.04,
      "time_str": "00:27.040",
      "text": "吸一口纯氧 就漂浮",
      "translation": null
    },
    {
      "time": 29.78,
      "time_str": "00:29.780",
      "text": "蓝色背景下 我练习 飞行的角度",
      "translation": null
    },
    {
      "time": 33.94,
      "time_str": "00:33.940",
      "text": "保持我的态度",
      "translation": null
    },
    {
      "time": 35.83,
      "time_str": "00:35.830",
      "text": "我的未来式 由我作主",
      "translation": null
    },
    {
      "time": 39.16,
      "time_str": "00:39.160",
      "text": "跳整天的舞 玩耍整片荧幕",
      "translation": null
    },
    {
      "time": 42.14,
      "time_str": "00:42.140",
      "text": "不断电的梦 直线加速",
      "translation": null
    },
    {
      "time": 45.15,
      "time_str": "00:45.150",
      "text": "奔跑在我画的地图",
      "translation": null
    },
    {
      "time": 60.348,
      "time_str": "01:00.348",
      "text": "翻开了五线谱 是我涂鸦的音符",
      "translation": null
    },
    {
      "time": 64.319,
      "time_str": "01:04.319",
      "text": "我找到 我的幸福",
      "translation": null
    },
    {
      "time": 66.269,
      "time_str": "01:06.269",
      "text": "自由平等博爱 我复古 创新演出",
      "translation": null
    },
    {
      "time": 70.498,
      "time_str": "01:10.498",
      "text": "我的天赋",
      "translation": null
    },
    {
