{
  "title": "少年的等待诗",
  "title_raw": "少年的等待诗",
  "version": null,
  "artist": "卷毛TuT",
  "group_key": "少年的等待诗|卷毛tut",
  "writers": {
    "lyricist": "倾故",
    "composer": "梓杰",
    "arranger": "梓杰"
  },
  "lyrics": [
    {
      "time": 31.42,
      "time_str": "00:31.420",
      "text": "似早霞坠入老巷后 秋色上膛",
      "translation": null
    },
    {
      "time": 34.58,
      "time_str": "00:34.580",
      "text": "少年心事怦然 见他越过虹光",
      "translation": null
    },
    {
      "time": 38.54,
      "time_str": "00:38.540",
      "text": "才将十八岁脊梁 贴近三十胸膛",
      "translation": null
    },
    {
      "time": 42.03,
      "time_str": "00:42.030",
      "text": "忘记所谓枷锁 于燎原后滚烫",
      "translation": null
    },
    {
      "time": 45.68,
      "time_str": "00:45.680",
      "text": "山野里不知何处 宝藏正逃匿流浪",
      "translation": null
    },
    {
      "time": 49.77,
      "time_str": "00:49.770",
      "text": "忽而 黑夜翻涌 白日惊天又动荡",
      "translation": null
    },
    {
      "time": 53.62,
      "time_str": "00:53.620",
      "text": "他雀跃摘下一枚 潜伏已久的月亮",
      "translation": null
    },
    {
      "time": 57.3,
      "time_str": "00:57.300",
      "text": "献上爱意 惊艳时光",
      "translation": null
    },
    {
      "time": 60.96,
      "time_str": "01:00.960",
      "text": "水渠流淌 嬉闹摇晃",
      "translation": null
    },
    {
      "time": 64.64,
      "time_str": "01:04.640",
      "text": "说喜欢模样 心跳追不上",
      "translation": null
    },
    {
      "time": 71.92,
      "time_str": "01:11.920",
      "text": "怪夏日单调 等待太长",
      "translation": null
    },
    {
      "time": 75.64,
      "time_str": "01:15.640",
      "text": "少年却笑着 吻颗奶糖",
      "translation": null
    },
    {
      "time": 79.32,
      "time_str": "01:19.320",
      "text": "他赤忱和怀想 拥抱中昂扬 任性疯长",
      "translation": null
    },
    {
      "time": 120.05,
      "time_str": "02:00.050",
      "text": "窑火映照期待脸庞 固执不放手 多坦荡",
      "translation": null
    },
    {
      "time": 127.28,
      "time_str": "02:07.280",
      "text": "做真实的模样 赋予自我力量",
      "translation": null
    },
    {
      "time": 131.14,
      "time_str": "02:11.140",
      "text": "在人潮里跌撞 偏要飞起寻觅光",
      "translation": null
    },
    {
      "time": 134.76,
      "time_str": "02:14.760",
      "text": "山野里竹林路旁 追随着宝藏流浪",
      "translation": null
    },
    {
      "time": 138.44,
      "time_str": "02:18.440",
      "text": "忽而 掀起狂潮 平添千万种风光",
      "translation": null
    },
    {
      "time": 142.19,
      "time_str": "02:22.190",
      "text": "他亲手栽种一杯 花园溢满的芬芳",
      "translation": null
    },
    {
      "time": 145.91,
      "time_str": "02:25.910",
      "text": "静待生长 不慌不忙",
      "translation": null
    },
    {
      "time": 149.65,
      "time_str": "02:29.650",
      "text": "水渠流淌 嬉闹摇晃",
      "translation": null
    },
    {
      "time": 153.17,
      "time_str": "02:33.170",
      "text": "说喜欢模样 心跳追不上",
      "translation": null
    },
    {
      "time": 160.53,
      "time_str": "02:40.530",
      "text": "怪夏日单调 等待太长",
      "translation": null
    },
    {
      "time": 164.2,
      "time_str": "02:44.200",
      "text": "少年却笑着 吻颗奶糖",
      "translation": null
    },
    {
      "time": 167.96,
      "time_str": "02:47.960",
      "text": "他赤忱和怀想 拥抱中昂扬 任性疯长",
      "translation": null
    },
    {
      "time": 179.28,
      "time_str": "02:59.280",
      "text": "就站立在 人潮中央",
      "translation": null
    },
    {
      "time": 182.73,
      "time_str": "03:02.730",
      "text": "等越过星海 等邂逅一场",
      "translation": null
    },
    {
      "time": 190.1,
      "time_str": "03:10.100",
      "text": "等秋千晃荡 并看夕阳",
      "translation": null
    },
    {
      "time": 193.8,
      "time_str": "03:13.800",
      "text": "有山风渐起 又过弄巷",
      "translation": null
    },
    {
      "time": 197.47,
      "time_str": "03:17.470",
      "text": "说迟来的少年 飞落到手掌 是他的光",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "少年的等待诗 - 卷毛TuT.lrc"
}