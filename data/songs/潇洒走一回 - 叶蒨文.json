  "lyrics": [
    {
      "time": 16.36,
      "time_str": "00:16.360",
      "text": "嘿哈嘿哈嘿哈嘿哈嘿哈",
      "translation": null
    },
    {
      "time": 39.38,
      "time_str": "00:39.380",
      "text": "天地悠悠过客匆匆",
      "translation": null
    },
    {
      "time": 46.12,
      "time_str": "00:46.120",
      "text": "潮起又潮落",
      "translation": null
    },
    {
      "time": 50.55,
      "time_str": "00:50.550",
      "text": "恩恩怨怨生死白头",
      "translation": null
    },
    {
      "time": 54.55,
      "time_str": "00:54.550",
      "text": "几人能看透",
      "translation": null
    },
    {
      "time": 58.01,
      "time_str": "00:58.010",
      "text": "红尘呀滚滚痴痴呀情深",
      "translation": null
    },
    {
      "time": 62.54,
      "time_str": "01:02.540",
      "text": "聚散终有时",
      "translation": null
    },
    {
      "time": 66.57,
      "time_str": "01:06.570",
      "text": "留一半清醒留一半醉",
      "translation": null
    },
    {
      "time": 69.36,
      "time_str": "01:09.360",
      "text": "至少梦里有你追随",
      "translation": null
    },
    {
      "time": 75.52,
      "time_str": "01:15.520",
      "text": "我拿青春赌明天",
      "translation": null
    },
    {
      "time": 78.44,
      "time_str": "01:18.440",
      "text": "你用真情换此生",
      "translation": null
    },
    {
      "time": 82.47,
      "time_str": "01:22.470",
      "text": "岁月不知人间多少的忧伤",
      "translation": null
    },
    {
      "time": 86.36,
      "time_str": "01:26.360",
      "text": "何不潇洒走一回",
      "translation": null
    },
