  "lyrics": [
    {
      "time": 49.11,
      "time_str": "00:49.110",
      "text": "是谁导演这场戏",
      "translation": null
    },
    {
      "time": 53.29,
      "time_str": "00:53.290",
      "text": "在这孤单角色里",
      "translation": null
    },
    {
      "time": 56.78,
      "time_str": "00:56.780",
      "text": "对白总是自言自语",
      "translation": null
    },
    {
      "time": 59.37,
      "time_str": "00:59.370",
      "text": "对手都是回忆 看不出什么结局",
      "translation": null
    },
    {
      "time": 65.83,
      "time_str": "01:05.830",
      "text": "自始至终全是你",
      "translation": null
    },
    {
      "time": 70.0,
      "time_str": "01:10.000",
      "text": "让我投入太彻底",
      "translation": null
    },
    {
      "time": 73.31,
      "time_str": "01:13.310",
      "text": "故事如果注定悲剧",
      "translation": null
    },
    {
      "time": 76.03,
      "time_str": "01:16.030",
      "text": "何苦给我美丽 演出相聚和别离",
      "translation": null
    },
    {
      "time": 82.54,
      "time_str": "01:22.540",
      "text": "没有星星的夜里",
      "translation": null
    },
    {
      "time": 86.51,
      "time_str": "01:26.510",
      "text": "我用泪光吸引你",
      "translation": null
    },
    {
      "time": 90.22,
      "time_str": "01:30.220",
      "text": "既然爱你不能言语",
      "translation": null
    },
    {
      "time": 92.83,
      "time_str": "01:32.830",
      "text": "只能微笑哭泣 让我从此忘了你",
      "translation": null
    },
    {
      "time": 99.2,
      "time_str": "01:39.200",
      "text": "没有星星的夜里",
      "translation": null
    },
    {
      "time": 103.37,
      "time_str": "01:43.370",
      "text": "我把往事留给你",
      "translation": null
    },
    {
      "time": 107.01,
      "time_str": "01:47.010",
      "text": "如果一切只是演戏",
      "translation": null
    },
    {
      "time": 109.52,
      "time_str": "01:49.520",
      "text": "要你好好看戏 心碎只是我自己",
      "translation": null
