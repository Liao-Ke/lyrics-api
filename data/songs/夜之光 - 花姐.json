    {
      "time": 0.27,
      "time_str": "00:00.270",
      "text": "花姐 - 夜之光",
      "translation": null
    },
    {
      "time": 19.52,
      "time_str": "00:19.520",
      "text": "黑黑黑的夜",
      "translation": null
    },
    {
      "time": 21.19,
      "time_str": "00:21.190",
      "text": "城市被孤单照亮",
      "translation": null
    },
    {
      "time": 24.02,
      "time_str": "00:24.020",
      "text": "不回家的人",
      "translation": null
    },
    {
      "time": 25.63,
      "time_str": "00:25.630",
      "text": "心事散落在街上",
      "translation": null
    },
    {
      "time": 28.49,
      "time_str": "00:28.490",
      "text": "忙忙忙到晚",
      "translation": null
    },
    {
      "time": 30.15,
      "time_str": "00:30.150",
      "text": "不如出去走一趟",
      "translation": null
    },
    {
      "time": 33.04,
      "time_str": "00:33.040",
      "text": "大好时光等你去闯",
      "translation": null
    },
    {
      "time": 36.74,
      "time_str": "00:36.740",
      "text": "我走过夜夜夜的黑",
      "translation": null
    },
    {
      "time": 39.12,
      "time_str": "00:39.120",
      "text": "做的梦梦梦最真",
      "translation": null
    },
    {
      "time": 41.4,
      "time_str": "00:41.400",
      "text": "唱着火辣辣的情歌",
      "translation": null
    },
    {
      "time": 43.57,
      "time_str": "00:43.570",
      "text": "对你爱爱到底",
      "translation": null
    },
    {
      "time": 45.85,
      "time_str": "00:45.850",
      "text": "我穿过夜夜夜的街",
      "translation": null
    },
    {
      "time": 48.07,
      "time_str": "00:48.070",
      "text": "只为闪亮亮的心",
      "translation": null
    },
    {
      "time": 50.3,
      "time_str": "00:50.300",
      "text": "遇见最好的自己",
      "translation": null
    },
    {
      "time": 52.62,
      "time_str": "00:52.620",
      "text": "然后狠狠拥抱你",
      "translation": null
    },
