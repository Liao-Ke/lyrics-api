    {
      "time": 12.0,
      "time_str": "00:12.000",
      "text": "混音工程师 : 林世龙",
      "translation": null
    },
    {
      "time": 17.18,
      "time_str": "00:17.180",
      "text": "每次我总 一个人走",
      "translation": null
    },
    {
      "time": 22.63,
      "time_str": "00:22.630",
      "text": "交叉路口 自己生活",
      "translation": null
    },
    {
      "time": 30.96,
      "time_str": "00:30.960",
      "text": "这次你却 说带我走",
      "translation": null
    },
    {
      "time": 36.13,
      "time_str": "00:36.130",
      "text": "某个角落 就你和我",
      "translation": null
    },
    {
      "time": 44.23,
      "time_str": "00:44.230",
      "text": "像土壤抓紧花的迷惑",
      "translation": null
    },
    {
      "time": 50.77,
      "time_str": "00:50.770",
      "text": "像天空缠绵雨的汹涌",
      "translation": null
    },
    {
      "time": 56.08,
      "time_str": "00:56.080",
      "text": "在你的身后 计算的步伐",
      "translation": null
    },
    {
      "time": 60.15,
      "time_str": "01:00.150",
      "text": "每个背影 每个场景",
      "translation": null
    },
    {
      "time": 63.7,
      "time_str": "01:03.700",
      "text": "都有发过的梦",
      "translation": null
    },
    {
      "time": 70.81,
      "time_str": "01:10.810",
      "text": "带我走 到遥远的以后",
      "translation": null
    },
    {
      "time": 77.04,
      "time_str": "01:17.040",
      "text": "带走我 一个人自转的寂寞",
      "translation": null
    },
    {
      "time": 84.01,
      "time_str": "01:24.010",
      "text": "带我走 就算我的爱 你的自由 都将成为泡沫",
      "translation": null
    },
    {
      "time": 92.65,
      "time_str": "01:32.650",
      "text": "我不怕 带我走",
      "translation": null
    },
    {
      "time": 109.44,
      "time_str": "01:49.440",
      "text": "每次我总 独自远走",
      "translation": null
    },
    {
      "time": 114.17,
      "time_str": "01:54.170",
      "text": "保持缄默 不皱眉头",
      "translation": null
    },
    {
      "time": 121.69,
      "time_str": "02:01.690",
      "text": "这次你却 说一起走",
