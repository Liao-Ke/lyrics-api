  "lyrics": [
    {
      "time": 31.37,
      "time_str": "00:31.370",
      "text": "孤独的我在梦里寻觅",
      "translation": null
    },
    {
      "time": 39.91,
      "time_str": "00:39.910",
      "text": "不知道寂寞的你是否愿意",
      "translation": null
    },
    {
      "time": 44.0,
      "time_str": "00:44.000",
      "text": "牵着我的手",
      "translation": null
    },
    {
      "time": 48.17,
      "time_str": "00:48.170",
      "text": "那多情的阳光",
      "translation": null
    },
    {
      "time": 51.03,
      "time_str": "00:51.030",
      "text": "温暖了我和你",
      "translation": null
    },
    {
      "time": 55.4,
      "time_str": "00:55.400",
      "text": "在你的耳畔",
      "translation": null
    },
    {
      "time": 59.34,
      "time_str": "00:59.340",
      "text": "我要悄悄地对你说",
      "translation": null
    },
    {
      "time": 63.03,
      "time_str": "01:03.030",
      "text": "你是我过河的一叶扁舟",
      "translation": null
    },
    {
      "time": 66.74,
      "time_str": "01:06.740",
      "text": "你是我登高的一把扶梯",
      "translation": null
    },
    {
      "time": 70.85,
      "time_str": "01:10.850",
      "text": "我把生命深埋在你的怀里",
      "translation": null
    },
    {
      "time": 75.17,
      "time_str": "01:15.170",
      "text": "落下了滚烫的泪",
      "translation": null
    },
    {
      "time": 78.86,
      "time_str": "01:18.860",
      "text": "一点一滴是我是你",
      "translation": null
    },
    {
      "time": 86.39,
      "time_str": "01:26.390",
      "text": "我要把心底的一句话告诉你",
      "translation": null
    },
    {
      "time": 94.1,
      "time_str": "01:34.100",
      "text": "我一无所有只有我自己",
      "translation": null
    },
    {
      "time": 97.68,
      "time_str": "01:37.680",
      "text": "不给别人不给别人",
      "translation": null
    },
    {
      "time": 103.2,
      "time_str": "01:43.200",
      "text": "一生都给你",
      "translation": null
    },
