    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "二胡 : 陆二胡",
      "translation": null
    },
    {
      "time": 5.0,
      "time_str": "00:05.000",
      "text": "调教 : 坐标P",
      "translation": null
    },
    {
      "time": 7.0,
      "time_str": "00:07.000",
      "text": "后期 : Mr_曾经",
      "translation": null
    },
    {
      "time": 25.991,
      "time_str": "00:25.991",
      "text": "光 是谁燃烛照亮 时间设下的迷藏",
      "translation": null
    },
    {
      "time": 32.116,
      "time_str": "00:32.116",
      "text": "光 置换明暗立场 肆意流淌",
      "translation": null
    },
    {
      "time": 38.611,
      "time_str": "00:38.611",
      "text": "看 谁站过的地方 棋局已百孔千疮",
      "translation": null
    },
    {
      "time": 44.877,
      "time_str": "00:44.877",
      "text": "看 眼前最真假相 假又何妨",
      "translation": null
    },
    {
      "time": 50.872,
      "time_str": "00:50.872",
      "text": "怀揣着炽烈顽心走向 最宽容刑场",
      "translation": null
    },
    {
      "time": 57.089,
      "time_str": "00:57.089",
      "text": "裂过碎过 都空洞地回响",
      "translation": null
    },
    {
      "time": 63.719,
      "time_str": "01:03.719",
      "text": "到最后竟庆幸于夕阳 仍留在身上",
      "translation": null
    },
    {
      "time": 69.833,
      "time_str": "01:09.833",
      "text": "来不及讲 故事多跌宕",
      "translation": null
    },
    {
      "time": 76.088,
      "time_str": "01:16.088",
      "text": "有最奇崛的峰峦 成全过你我张狂",
      "translation": null
    },
    {
      "time": 82.29,
      "time_str": "01:22.290",
      "text": "海上清辉与圆月 盛进杯光",
      "translation": null
    },
    {
      "time": 88.686,
      "time_str": "01:28.686",
      "text": "有最孤傲的雪山 静听过你我诵章",
      "translation": null
    },
    {
      "time": 95.08,
      "time_str": "01:35.080",
      "text": "世人惊羡的桥段 不过寻常",
      "translation": null
    },
    {
      "time": 115.268,
      "time_str": "01:55.268",
      "text": "光 可寻来路艰险 也可照前路坦荡",
      "translation": null
    },
    {
      "time": 121.257,
      "time_str": "02:01.257",
      "text": "光 补填残陋世相 无须度量",
      "translation": null
    },
    {
      "time": 127.661,
      "time_str": "02:07.661",
      "text": "看 你计算的无常 和你来时的彷徨",
      "translation": null
    },
    {
      "time": 133.969,
      "time_str": "02:13.969",
      "text": "看 终有勇气独挡 人世荒唐",
      "translation": null
    },
    {
      "time": 139.954,
      "time_str": "02:19.954",
      "text": "怀揣着炽烈顽心走向 最宽容刑场",
      "translation": null
    },
    {
