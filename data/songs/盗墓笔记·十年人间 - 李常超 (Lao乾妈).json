    {
      "time": 209.466,
      "time_str": "03:29.466",
      "text": "海上清辉与圆月 盛进杯光",
      "translation": null
    },
    {
      "time": 215.873,
      "time_str": "03:35.873",
      "text": "有最残破的书简 记载过光阴漫长",
      "translation": null
    },
    {
      "time": 222.207,
      "time_str": "03:42.207",
      "text": "无意拾过的片瓦 历数寒凉",
      "translation": null
    },
    {
      "time": 228.875,
      "time_str": "03:48.875",
      "text": "有最孤傲的雪山 静听过你我诵章",
      "translation": null
    },
    {
      "time": 234.953,
      "time_str": "03:54.953",
      "text": "世人惊羡的桥段 不过寻常",
      "translation": null
    },
    {
      "time": 241.24,
      "time_str": "04:01.240",
      "text": "有最清瘦的字迹 都已随记忆泛黄",
      "translation": null
    },
    {
      "time": 247.718,
      "time_str": "04:07.718",
      "text": "而我再度铺垫起 下个篇章",
      "translation": null
