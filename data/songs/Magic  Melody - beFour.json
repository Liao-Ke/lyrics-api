    {
      "time": 7.37,
      "time_str": "00:07.370",
      "text": "I’m walking through a land",
      "translation": "我走过一片土地"
    },
    {
      "time": 9.22,
      "time_str": "00:09.220",
      "text": "Of peace and harmony",
      "translation": "和平与和谐"
    },
    {
      "time": 10.94,
      "time_str": "00:10.940",
      "text": "Come take me by the hand",
      "translation": "来，抓住我的手"
    },
    {
      "time": 12.85,
      "time_str": "00:12.850",
      "text": "And join my fantasy",
      "translation": "加入我的幻想"
    },
    {
      "time": 14.46,
      "time_str": "00:14.460",
      "text": "This dream has just begun",
      "translation": "这个梦想才刚刚开始"
    },
    {
      "time": 16.52,
      "time_str": "00:16.520",
      "text": "Come on and sing with me",
      "translation": "来和我一起歌唱"
    },
    {
      "time": 18.52,
      "time_str": "00:18.520",
      "text": "I know a certain song",
      "translation": "我知道某一首歌"
    },
    {
      "time": 20.38,
      "time_str": "00:20.380",
      "text": "A certain melody goes",
