    },
    {
      "time": 22.18,
      "time_str": "00:22.180",
      "text": "La la la la la",
      "translation": "啦啦啦啦啦"
    },
    {
      "time": 24.28,
      "time_str": "00:24.280",
      "text": "The magic melody goes",
      "translation": "魔术旋律去"
    },
    {
      "time": 25.97,
