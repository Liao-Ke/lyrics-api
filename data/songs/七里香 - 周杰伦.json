  "lyrics": [
    {
      "time": 27.702,
      "time_str": "00:27.702",
      "text": "窗外的麻雀 在电线杆上多嘴",
      "translation": null
    },
    {
      "time": 34.49,
      "time_str": "00:34.490",
      "text": "你说这一句 很有夏天的感觉",
      "translation": null
    },
    {
      "time": 41.19,
      "time_str": "00:41.190",
      "text": "手中的铅笔 在纸上来来回回",
      "translation": null
    },
    {
      "time": 47.582,
      "time_str": "00:47.582",
      "text": "我用几行字形容你是我的谁",
      "translation": null
    },
    {
      "time": 54.329,
      "time_str": "00:54.329",
      "text": "秋刀鱼的滋味 猫跟你都想了解",
      "translation": null
    },
    {
      "time": 61.447,
      "time_str": "01:01.447",
      "text": "初恋的香味就这样被我们寻回",
      "translation": null
    },
    {
      "time": 67.811,
      "time_str": "01:07.811",
      "text": "那温暖的阳光 像刚摘的鲜艳草莓",
      "translation": null
    },
    {
      "time": 74.138,
      "time_str": "01:14.138",
      "text": "你说你舍不得吃掉这一种感觉",
      "translation": null
    },
    {
      "time": 80.907,
      "time_str": "01:20.907",
      "text": "雨下整夜 我的爱溢出就像雨水",
      "translation": null
    },
    {
      "time": 87.608,
      "time_str": "01:27.608",
      "text": "院子落叶 跟我的思念厚厚一叠",
      "translation": null
    },
    {
      "time": 94.345,
      "time_str": "01:34.345",
      "text": "几句是非 也无法将我的热情冷却",
      "translation": null
    },
    {
      "time": 101.945,
      "time_str": "01:41.945",
      "text": "你出现在我诗的每一页",
      "translation": null
    },
    {
      "time": 107.9,
      "time_str": "01:47.900",
      "text": "雨下整夜 我的爱溢出就像雨水",
      "translation": null
    },
    {
      "time": 114.623,
      "time_str": "01:54.623",
      "text": "窗台蝴蝶 像诗里纷飞的美丽章节",
      "translation": null
    },
    {
      "time": 121.359,
      "time_str": "02:01.359",
      "text": "我接着写 把永远爱你写进诗的结尾",
      "translation": null
    },
    {
      "time": 128.972,
      "time_str": "02:08.972",
      "text": "你是我唯一想要的了解",
      "translation": null
    },
    {
      "time": 161.846,
      "time_str": "02:41.846",
      "text": "雨下整夜 我的爱溢出就像雨水",
      "translation": null
