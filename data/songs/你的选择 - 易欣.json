  "lyrics": [
    {
      "time": 14.74,
      "time_str": "00:14.740",
      "text": "看着你慢慢离开我的视线",
      "translation": null
    },
    {
      "time": 17.784,
      "time_str": "00:17.784",
      "text": "才明白原来这份爱情已走远",
      "translation": null
    },
    {
      "time": 21.765,
      "time_str": "00:21.765",
      "text": "而我还相信有永恒的诺言",
      "translation": null
    },
    {
      "time": 28.736,
      "time_str": "00:28.736",
      "text": "既然爱已到了痛的边缘",
      "translation": null
    },
    {
      "time": 31.742,
      "time_str": "00:31.742",
      "text": "就算为我们留住时间",
      "translation": null
    },
    {
      "time": 35.708,
      "time_str": "00:35.708",
      "text": "也换不回相爱的那一天",
      "translation": null
    },
    {
      "time": 41.767,
      "time_str": "00:41.767",
      "text": "沧海桑田谁为谁而改变",
      "translation": null
    },
    {
      "time": 47.792,
      "time_str": "00:47.792",
      "text": "心甘情愿却不见我们的永远",
      "translation": null
    },
    {
      "time": 55.768,
      "time_str": "00:55.768",
      "text": "爱与被爱同样是受伤害",
      "translation": null
    },
    {
      "time": 58.786,
      "time_str": "00:58.786",
      "text": "谁先不爱谁先离开",
      "translation": null
    },
    {
      "time": 62.719,
      "time_str": "01:02.719",
      "text": "留下的人满身伤痕",
      "translation": null
    },
    {
      "time": 68.771,
      "time_str": "01:08.771",
      "text": "你的选择没有错",
      "translation": null
    },
    {
      "time": 72.7,
      "time_str": "01:12.700",
      "text": "我欠你的太多",
      "translation": null
    },
    {
      "time": 75.736,
      "time_str": "01:15.736",
      "text": "受伤的心找不到解药",
      "translation": null
    },
    {
      "time": 78.774,
      "time_str": "01:18.774",
      "text": "怎么愈合",
      "translation": null
    },
    {
      "time": 82.718,
      "time_str": "01:22.718",
      "text": "你的选择躲不过",
      "translation": null
    },
    {
      "time": 85.741,
      "time_str": "01:25.741",
      "text": "泪水的折磨",
      "translation": null
    },
    {
      "time": 89.724,
      "time_str": "01:29.724",
      "text": "宁愿解脱一个人",
      "translation": null
    },
    {
      "time": 92.759,
      "time_str": "01:32.759",
      "text": "独自漂泊",
