  "lyrics": [
    {
      "time": 15.183,
      "time_str": "00:15.183",
      "text": "余音袅袅我看了太多热闹",
      "translation": null
    },
    {
      "time": 18.144,
      "time_str": "00:18.144",
      "text": "看一尘不染的白纸都变得浮躁",
      "translation": null
    },
    {
      "time": 21.454,
      "time_str": "00:21.454",
      "text": "善者寥寥在泥沼之中煎熬",
      "translation": null
    },
    {
      "time": 24.592,
      "time_str": "00:24.592",
      "text": "而置身事外的君子在一旁冷笑",
      "translation": null
    },
    {
      "time": 27.992,
      "time_str": "00:27.992",
      "text": "没完没了的暗箭持续叫嚣",
      "translation": null
    },
    {
      "time": 31.124,
      "time_str": "00:31.124",
      "text": "怕没人注意到他们得意着作妖",
      "translation": null
    },
    {
      "time": 34.384,
      "time_str": "00:34.384",
      "text": "纷纷扰扰这人间缺个公道",
      "translation": null
    },
    {
      "time": 37.58,
      "time_str": "00:37.580",
      "text": "我辞三界 别五行自顾去逍遥",
      "translation": null
    },
    {
      "time": 41.077,
      "time_str": "00:41.077",
      "text": "此去必经年 荒野寒暑换红颜",
      "translation": null
    },
    {
      "time": 47.326,
      "time_str": "00:47.326",
      "text": "往事散云烟 十寸光阴换一钱",
      "translation": null
    },
    {
      "time": 53.805,
      "time_str": "00:53.805",
      "text": "只身山水间 耳不闻恶语闲言",
      "translation": null
    },
    {
      "time": 60.262,
      "time_str": "01:00.262",
      "text": "举头问苍天 何时得以赴黄泉",
      "translation": null
    },
    {
      "time": 93.2,
      "time_str": "01:33.200",
      "text": "走走停停又逛了几个世纪",
      "translation": null
    },
    {
      "time": 96.021,
      "time_str": "01:36.021",
      "text": "看川流不息灯红酒绿变成孤寂",
      "translation": null
    },
    {
      "time": 99.362,
      "time_str": "01:39.362",
      "text": "战战兢兢的人们未曾怀疑",
      "translation": null
    },
    {
      "time": 102.437,
      "time_str": "01:42.437",
      "text": "在此地荣华富贵是唯一的真理",
      "translation": null
    },
    {
      "time": 105.784,
      "time_str": "01:45.784",
      "text": "机关算尽后徒留一地黄金",
      "translation": null
    },
    {
      "time": 108.972,
      "time_str": "01:48.972",
      "text": "那冢里枯骨不得安息无人在意",
      "translation": null
    },
    {
      "time": 112.288,
      "time_str": "01:52.288",
      "text": "夜色降临时落下一声叹息",
      "translation": null
    },
    {
      "time": 115.393,
      "time_str": "01:55.393",
      "text": "我乘兴来 败兴去也乐得随意",
      "translation": null
    },
    {
      "time": 131.916,
      "time_str": "02:11.916",
