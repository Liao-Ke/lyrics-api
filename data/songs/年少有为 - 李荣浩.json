      "time": 29.799,
      "time_str": "00:29.799",
      "text": "电视一直闪",
      "translation": null
    },
    {
      "time": 33.441,
      "time_str": "00:33.441",
      "text": "联络方式都还没删",
      "translation": null
    },
    {
      "time": 37.146,
      "time_str": "00:37.146",
      "text": "你待我的好",
      "translation": null
    },
    {
      "time": 40.752,
      "time_str": "00:40.752",
      "text": "我却错手毁掉",
      "translation": null
    },
    {
      "time": 44.392,
      "time_str": "00:44.392",
      "text": "也曾一起想",
      "translation": null
    },
    {
      "time": 48.023,
      "time_str": "00:48.023",
      "text": "有个地方睡觉吃饭",
      "translation": null
    },
    {
      "time": 51.674,
      "time_str": "00:51.674",
      "text": "可怎么去熬 日夜颠倒",
      "translation": null
    },
    {
      "time": 55.063,
      "time_str": "00:55.063",
      "text": "连头款也凑不到",
      "translation": null
    },
    {
      "time": 59.193,
      "time_str": "00:59.193",
      "text": "墙板 被我砸烂",
      "translation": null
    },
    {
      "time": 62.573,
      "time_str": "01:02.573",
      "text": "到现在还没修",
      "translation": null
    },
    {
      "time": 65.936,
      "time_str": "01:05.936",
      "text": "一碗热的粥",
