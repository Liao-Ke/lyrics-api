  "lyrics": [
    {
      "time": 14.98,
      "time_str": "00:14.980",
      "text": "再渡与她寻觅自由",
      "translation": null
    },
    {
      "time": 18.77,
      "time_str": "00:18.770",
      "text": "发现我心新的伤口",
      "translation": null
    },
    {
      "time": 22.61,
      "time_str": "00:22.610",
      "text": "怕你仍内疚 我忠心的祷告",
      "translation": null
    },
    {
      "time": 26.53,
      "time_str": "00:26.530",
      "text": "苦恋的一生 偏要自渡下半生",
      "translation": null
    },
    {
      "time": 30.64,
      "time_str": "00:30.640",
      "text": "是我未够好总渗不透",
      "translation": null
    },
    {
      "time": 33.9,
      "time_str": "00:33.900",
      "text": "换转别个他你怎舍得他走",
      "translation": null
    },
    {
      "time": 37.7,
      "time_str": "00:37.700",
      "text": "错又犯错 竟可将他拥抱",
      "translation": null
    },
    {
      "time": 41.75,
      "time_str": "00:41.750",
      "text": "不想懂太多 偏爱你无法拖",
      "translation": null
    },
    {
      "time": 45.39,
      "time_str": "00:45.390",
      "text": "对不起 我又叫座",
      "translation": null
    },
    {
      "time": 49.11,
      "time_str": "00:49.110",
      "text": "请原谅我这次冲动",
      "translation": null
    },
    {
      "time": 52.84,
      "time_str": "00:52.840",
      "text": "这颗心 最後爱过",
      "translation": null
    },
    {
      "time": 56.67,
      "time_str": "00:56.670",
      "text": "即使得不到你 唯有忠心的说句",
      "translation": null
    },
    {
      "time": 61.48,
      "time_str": "01:01.480",
      "text": "我唔识拍拖 分开好过",
      "translation": null
    },
    {
      "time": 66.06,
      "time_str": "01:06.060",
      "text": "来来回回怎么只得一个我",
      "translation": null
    },
    {
      "time": 69.86,
      "time_str": "01:09.860",
      "text": "回望过去你背着我与他相爱",
      "translation": null
    },
    {
      "time": 73.9,
      "time_str": "01:13.900",
      "text": "即使粉身碎骨 亦要爱你没法躲",
      "translation": null
    },
    {
      "time": 77.87,
      "time_str": "01:17.870",
      "text": "拍拖 不知怎过",
      "translation": null
    },
    {
      "time": 81.42,
      "time_str": "01:21.420",
      "text": "沉沉迷迷怎么分不清哪个是我",
      "translation": null
    },
    {
      "time": 85.55,
      "time_str": "01:25.550",
      "text": "踏破了双脚 始终得不到你",
      "translation": null
    },
    {
      "time": 89.14,
      "time_str": "01:29.140",
      "text": "直到最後至清楚 原来是我错",
