  "lyrics": [
    {
      "time": 29.84,
      "time_str": "00:29.840",
      "text": "楚河流沙几聚散 日月沧桑尽变换",
      "translation": null
    },
    {
      "time": 35.08,
      "time_str": "00:35.080",
      "text": "乱世多少红颜换一声长叹",
      "translation": null
    },
    {
      "time": 40.38,
      "time_str": "00:40.380",
      "text": "谁曾巨鹿踏破了秦关 千里兵戈血染",
      "translation": null
    },
    {
      "time": 46.45,
      "time_str": "00:46.450",
      "text": "终究也不过是风轻云淡",
      "translation": null
    },
    {
      "time": 51.51,
      "time_str": "00:51.510",
      "text": "长枪策马平天下 此番诀别却为难",
      "translation": null
    },
    {
      "time": 57.72,
      "time_str": "00:57.720",
      "text": "一声虞兮虞兮泪眼已潸然",
      "translation": null
    },
    {
      "time": 63.07,
      "time_str": "01:03.070",
      "text": "与君共饮这杯中冷暖 西风彻夜回忆吹不断",
      "translation": null
    },
    {
      "time": 69.38,
      "time_str": "01:09.380",
      "text": "醉里挑灯看剑 妾舞阑珊",
      "translation": null
    },
    {
      "time": 74.91,
      "time_str": "01:14.910",
      "text": "垓下一曲离乱 楚歌声四方",
      "translation": null
    },
    {
      "time": 80.31,
      "time_str": "01:20.310",
      "text": "含悲 辞君 饮剑 血落凝寒霜",
      "translation": null
    },
    {
      "time": 85.87,
      "time_str": "01:25.870",
      "text": "难舍一段过往 缘尽又何妨",
      "translation": null
    },
    {
      "time": 91.77,
      "time_str": "01:31.770",
      "text": "与你魂归之处便是苍茫",
      "translation": null
    },
    {
      "time": 120.25,
      "time_str": "02:00.250",
      "text": "长枪策马平天下 此番诀别却为难",
