    {
      "time": 166.39,
      "time_str": "02:46.390",
      "text": "汉兵刀剑纷乱 折断了月光",
      "translation": null
    },
    {
      "time": 171.55,
      "time_str": "02:51.550",
      "text": "江畔 只身 孤舟 余生不思量",
      "translation": null
    },
    {
