    {
      "time": 18.178,
      "time_str": "00:18.178",
      "text": "也许还能在网上看到你的消息",
      "translation": null
    },
    {
      "time": 21.988,
      "time_str": "00:21.988",
      "text": "也许我唱的歌还存在你的手机",
      "translation": null
    },
    {
      "time": 25.528,
      "time_str": "00:25.528",
      "text": "也许我爱你埋在心底变成秘密",
      "translation": null
    },
    {
      "time": 29.128,
      "time_str": "00:29.128",
      "text": "也许你想我的时候我也在想你",
      "translation": null
    },
    {
      "time": 35.598,
      "time_str": "00:35.598",
      "text": "多少次我告诉自己",
      "translation": null
    },
    {
      "time": 38.198,
      "time_str": "00:38.198",
      "text": "此情可待已成追忆",
      "translation": null
    },
    {
      "time": 43.189,
      "time_str": "00:43.189",
      "text": "多少次我告诫自己",
      "translation": null
    },
    {
      "time": 46.178,
      "time_str": "00:46.178",
      "text": "不再为你流泪到一败涂地",
      "translation": null
    },
    {
      "time": 49.968,
      "time_str": "00:49.968",
      "text": "我和你不再联系",
      "translation": null
    },
    {
      "time": 52.499,
      "time_str": "00:52.499",
      "text": "希望你不要介意",
      "translation": null
    },
    {
      "time": 53.998,
      "time_str": "00:53.998",
      "text": "要怪就怪当初没在一起",
      "translation": null
    },
    {
      "time": 57.18,
      "time_str": "00:57.180",
      "text": "而你对现在也比较满意",
      "translation": null
    },
    {
      "time": 60.518,
      "time_str": "01:00.518",
      "text": "所以我留下来也没有道理",
      "translation": null
    },
    {
      "time": 65.78,
      "time_str": "01:05.780",
      "text": "我和你断了联系",
      "translation": null
    },
    {
      "time": 67.089,
      "time_str": "01:07.089",
      "text": "不代表我不想你",
      "translation": null
    },
    {
      "time": 69.229,
      "time_str": "01:09.229",
      "text": "走到哪里还是会有惦记",
      "translation": null
    },
    {
      "time": 72.8,
      "time_str": "01:12.800",
      "text": "而我也开始试着去忘记",
      "translation": null
    },
    {
      "time": 76.498,
      "time_str": "01:16.498",
      "text": "抹去我们过去的放弃的所有交集",
