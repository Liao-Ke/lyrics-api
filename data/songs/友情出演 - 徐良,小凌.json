  "lyrics": [
    {
      "time": 1.53,
      "time_str": "00:01.530",
      "text": "那时候  我们两个人",
      "translation": null
    },
    {
      "time": 5.05,
      "time_str": "00:05.050",
      "text": "不知道明天会有多远",
      "translation": null
    },
    {
      "time": 8.33,
      "time_str": "00:08.330",
      "text": "但是  绑在一起的手",
      "translation": null
    },
    {
      "time": 12.18,
      "time_str": "00:12.180",
      "text": "从来就没有分开过",
      "translation": null
    },
    {
      "time": 15.08,
      "time_str": "00:15.080",
      "text": "你笑我眼泪太少 伪装的很好",
      "translation": null
    },
    {
      "time": 18.32,
      "time_str": "00:18.320",
      "text": "我像傻瓜般在笑 眼泪却在掉",
      "translation": null
    },
    {
      "time": 21.95,
      "time_str": "00:21.950",
      "text": "你的爱并不知道 我早就想要",
      "translation": null
    },
    {
      "time": 25.71,
      "time_str": "00:25.710",
      "text": "闻你的味道 要你的拥抱",
      "translation": null
    },
    {
      "time": 29.7,
      "time_str": "00:29.700",
      "text": "你笑我演技不好 戏入得太少",
      "translation": null
    },
    {
      "time": 32.86,
      "time_str": "00:32.860",
      "text": "在你的身旁紧靠 只剩下心跳",
      "translation": null
    },
    {
      "time": 37.5,
      "time_str": "00:37.500",
      "text": "我什么都不想要 就在下一秒",
      "translation": null
    },
    {
      "time": 40.35,
      "time_str": "00:40.350",
      "text": "也许会疯掉 也许会死掉",
      "translation": null
    },
    {
      "time": 45.28,
      "time_str": "00:45.280",
      "text": "每一个季节 回忆总是会很跳跃",
      "translation": null
    },
    {
      "time": 51.31,
      "time_str": "00:51.310",
      "text": "现在我一个人体贴",
      "translation": null
    },
    {
      "time": 54.97,
      "time_str": "00:54.970",
      "text": "故事都来的太直接",
      "translation": null
    },
    {
      "time": 58.789,
      "time_str": "00:58.789",
      "text": "我没说",
      "translation": null
    },
    {
      "time": 60.755,
      "time_str": "01:00.755",
      "text": "你用过的咖啡杯 余温还多一些",
      "translation": null
    },
    {
      "time": 63.886,
      "time_str": "01:03.886",
      "text": "我轻轻再吻一遍 变态的有点甜",
      "translation": null
    },
    {
      "time": 67.495,
      "time_str": "01:07.495",
      "text": "就快要没有时间 散场的电影院",
