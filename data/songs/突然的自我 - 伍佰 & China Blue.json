  "lyrics": [
    {
      "time": 31.16,
      "time_str": "00:31.160",
      "text": "听见你说 朝阳起又落",
      "translation": null
    },
    {
      "time": 37.24,
      "time_str": "00:37.240",
      "text": "晴雨难测 道路是脚步多",
      "translation": null
    },
    {
      "time": 43.38,
      "time_str": "00:43.380",
      "text": "我已习惯 你突然间的自我",
      "translation": null
    },
    {
      "time": 49.57,
      "time_str": "00:49.570",
      "text": "挥挥洒洒 将自然看通透",
      "translation": null
    },
    {
      "time": 58.16,
      "time_str": "00:58.160",
      "text": "那就不要留 时光一过不再有",
      "translation": null
    },
    {
      "time": 64.9,
      "time_str": "01:04.900",
      "text": "你远眺的天空 挂更多的彩虹",
      "translation": null
    },
    {
      "time": 70.32,
      "time_str": "01:10.320",
      "text": "我会紧紧的 将你豪情放在心头",
      "translation": null
    },
    {
      "time": 77.04,
      "time_str": "01:17.040",
      "text": "在寒冬时候 就回忆你温柔",
      "translation": null
    },
    {
      "time": 82.7,
      "time_str": "01:22.700",
      "text": "把开怀填进我的心扉",
      "translation": null
    },
    {
      "time": 88.8,
      "time_str": "01:28.800",
      "text": "伤心也是带着微笑的眼泪",
      "translation": null
    },
    {
      "time": 95.62,
      "time_str": "01:35.620",
      "text": "数不尽相逢",
      "translation": null
    },
    {
      "time": 98.7,
      "time_str": "01:38.700",
      "text": "等不完守候",
      "translation": null
    },
    {
      "time": 102.02,
      "time_str": "01:42.020",
      "text": "如果仅有此生 又何用待从头",
      "translation": null
    },
    {
      "time": 117.29,
      "time_str": "01:57.290",
      "text": "来来来 喝完这一杯，还有一杯",
      "translation": null
    },
    {
      "time": 126.3,
      "time_str": "02:06.300",
      "text": "再喝完这一杯，还有三杯",
