  "lyrics": [
    {
      "time": 18.72,
      "time_str": "00:18.720",
      "text": "Although loneliness has always been a friend of mine",
      "translation": "虽然孤独一直是我的朋友"
    },
    {
      "time": 24.08,
      "time_str": "00:24.080",
      "text": "I'm leaving my life in your hands",
      "translation": "但我正将我的一切交给你"
    },
    {
      "time": 29.19,
      "time_str": "00:29.190",
      "text": "People say I'm crazy and that I am blind",
      "translation": "人们说我被感情冲昏了脑袋"
    },
    {
      "time": 34.0,
      "time_str": "00:34.000",
      "text": "Risking it all in a glance",
      "translation": "竟转眼间赌上未来"
    },
    {
      "time": 38.87,
      "time_str": "00:38.870",
      "text": "How you got me blind is still a mystery",
      "translation": "你怎会让我不顾一切还是个谜"
    },
    {
      "time": 43.56,
      "time_str": "00:43.560",
      "text": "I can't get you out of my head",
      "translation": "我就是无法忘了你"
    },
    {
      "time": 48.63,
      "time_str": "00:48.630",
      "text": "Don't care what is written in your history",
      "translation": "我不在乎你过去的种种"
    },
    {
      "time": 53.63,
      "time_str": "00:53.630",
      "text": "As long as you're here with me",
      "translation": "只要你陪在我身边"
    },
    {
      "time": 57.0,
      "time_str": "00:57.000",
      "text": "I don't care who you are",
      "translation": "我不在乎你是怎样的人"
    },
    {
      "time": 60.44,
      "time_str": "01:00.440",
      "text": "Where you're from",
      "translation": "你从哪里来"
    },
    {
      "time": 62.88,
      "time_str": "01:02.880",
      "text": "What you did",
      "translation": "你做过什么"
    },
    {
