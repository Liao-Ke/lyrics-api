      "time": 22.15,
      "time_str": "00:22.150",
      "text": "不知道等待多少夜晚",
      "translation": null
    },
    {
      "time": 29.2,
      "time_str": "00:29.200",
      "text": "任思念无边无际蔓延",
      "translation": null
    },
    {
      "time": 36.51,
      "time_str": "00:36.510",
      "text": "流星是天亮时出发的讯号",
      "translation": null
    },
    {
      "time": 43.62,
      "time_str": "00:43.620",
      "text": "我翻山越岭来到你身边",
      "translation": null
    },
    {
      "time": 53.66,
      "time_str": "00:53.660",
      "text": "这是怎样的前世今生",
      "translation": null
    },
    {
      "time": 60.34,
      "time_str": "01:00.340",
      "text": "落花像泪水滴在心间",
      "translation": null
    },
    {
      "time": 67.85,
      "time_str": "01:07.850",
      "text": "前世的梦缠绵悱恻",
      "translation": null
    },
    {
      "time": 74.58,
      "time_str": "01:14.580",
      "text": "今生的歌空灵如烟",
      "translation": null
    },
    {
      "time": 115.02,
      "time_str": "01:55.020",
      "text": "传说中明天爱情重演",
      "translation": null
    },
    {
      "time": 121.51,
      "time_str": "02:01.510",
      "text": "想你不过是最后的孤单",
      "translation": null
    },
    {
      "time": 128.81,
      "time_str": "02:08.810",
      "text": "我把写完的情书装订成册",
      "translation": null
    },
    {
      "time": 136.49,
      "time_str": "02:16.490",
      "text": "会永远爱你是最好的诗篇",
      "translation": null
    },
    {
