{
  "title": "불꽃",
  "title_raw": "불꽃",
  "version": null,
  "artist": "高耀太",
  "group_key": "불꽃|高耀太",
  "writers": {
    "lyricist": "이용민",
    "composer": "이용민",
    "arranger": "이용민"
  },
  "lyrics": [
    {
      "time": 1.06,
      "time_str": "00:01.060",
      "text": "미안하다는 그런 말들로",
      "translation": "仅用对不起那些话"
    },
    {
      "time": 7.62,
      "time_str": "00:07.620",
      "text": "모든거 다 잊을 수 없는거잖아",
      "translation": "全部都忘掉是不可能的"
    },
    {
      "time": 40.99,
      "time_str": "00:40.990",
      "text": "모든게 잘못된거 이제야 난 알아버렸어",
      "translation": "所有的都不对 我现在才知道"
    },
    {
      "time": 47.45,
      "time_str": "00:47.450",
      "text": "그동안 너와 사랑해 정신없어 아무것도 몰랐어",
      "translation": "那期间陷入你的爱情里 昏了头脑 什么也不知道"
    },
    {
      "time": 54.82,
      "time_str": "00:54.820",
      "text": "내 친구의 연인이라는",
      "translation": "和朋友一般的你"
    },
    {
      "time": 57.49,
      "time_str": "00:57.490",
      "text": "너와 사랑한다는게",
      "translation": "和你相爱"
    },
    {
      "time": 61.32,
      "time_str": "01:01.320",
      "text": "너무나 힘들어 너를 정리해도",
      "translation": "真的太累了 想忘记你"
    },
    {
      "time": 64.77,
      "time_str": "01:04.770",
      "text": "끝이 보이질 않아",
      "translation": "但看不到尽头"
    },
    {
      "time": 69.91,
      "time_str": "01:09.910",
      "text": "그러지만 난 너와 행복해",
      "translation": "不要这样  和你在一起好幸福"
    },
    {
      "time": 73.21,
      "time_str": "01:13.210",
      "text": "날 버리고 가지마",
      "translation": "不要抛弃我"
    },
    {
      "time": 76.79,
      "time_str": "01:16.790",
      "text": "오랜 시간 만난건 아니지만",
      "translation": "虽然相遇不久"
    },
    {
      "time": 80.19,
      "time_str": "01:20.190",
      "text": "너 하나면 행복해",
      "translation": "但有你就很幸福"
    },
    {
      "time": 83.26,
      "time_str": "01:23.260",
      "text": "작지만 내 모든걸 주었고",
      "translation": "虽然时间很短 但我把所有都给了你"
    },
    {
      "time": 86.9,
      "time_str": "01:26.900",
      "text": "널 위해 희생했어",
      "translation": "为你做了牺牲"
    },
    {
      "time": 90.08,
      "time_str": "01:30.080",
      "text": "그러지마 이제와서 떠나면",
      "translation": "不要这样 现在离开我"
    },
    {
      "time": 93.66,
      "time_str": "01:33.660",
      "text": "난 어떻하란 말야",
      "translation": "我该怎么办"
    },
    {
      "time": 97.35,
      "time_str": "01:37.350",
      "text": "자 이제 모두 이곳에 일어나",
      "translation": "来 现在从这里站起来"
    },
    {
      "time": 100.53,
      "time_str": "01:40.530",
      "text": "더 크게 소리를 질러봐봐",
      "translation": "更大声的呼喊看看"
    },
    {
      "time": 103.89,
      "time_str": "01:43.890",
      "text": "걱정따윈 하지마 자 내 손을 잡아",
      "translation": "别担心 来 抓住我的手"
    },
    {
      "time": 107.39,
      "time_str": "01:47.390",
      "text": "시간이 다가와서 자 목소릴 높여봐 나",
      "translation": "时间已经到了 来 提高嗓音"
    },
    {
      "time": 127.11,
      "time_str": "02:07.110",
      "text": "잊지마 내 곁에 온 사랑을",
      "translation": "不要忘记 我点燃的爱情"
    },
    {
      "time": 130.16,
      "time_str": "02:10.160",
      "text": "널 위해 태웠던",
      "translation": "为你燃烧着"
    },
    {
      "time": 133.73,
      "time_str": "02:13.730",
      "text": "까맣게 타버린 나를",
      "translation": "已经焦黑的我"
    },
    {
      "time": 136.46,
      "time_str": "02:16.460",
      "text": "어떤 이유로도 잊어선 안돼",
      "translation": "任何理由都不可以忘记"
    },
    {
      "time": 140.98,
      "time_str": "02:20.980",
      "text": "나 지금은 너 떠나지만",
      "translation": "虽然现在离开你"
    },
    {
      "time": 144.08,
      "time_str": "02:24.080",
      "text": "기다려 달라 말할게",
      "translation": "我还是会说请你等我"
    },
    {
      "time": 147.27,
      "time_str": "02:27.270",
      "text": "우 이 사랑 하기엔 넌 내것이기에",
      "translation": "因为我们相爱 因为你是我的"
    },
    {
      "time": 151.29,
      "time_str": "02:31.290",
      "text": "꼭 네가 주러올께",
      "translation": "我一定会回到你身边"
    },
    {
      "time": 156.11,
      "time_str": "02:36.110",
      "text": "그러지만 난 너와 행복해",
      "translation": "不要这样  和你在一起好幸福"
    },
    {
      "time": 159.48,
      "time_str": "02:39.480",
      "text": "날 버리고 가지마",
      "translation": "不要抛弃我"
    },
    {
      "time": 162.88,
      "time_str": "02:42.880",
      "text": "오랜 시간 만난건 아니지만",
      "translation": "相遇虽然不久"
    },
    {
      "time": 166.37,
      "time_str": "02:46.370",
      "text": "너 하나면 행복해",
      "translation": "有你就很幸福"
    },
    {
      "time": 169.69,
      "time_str": "02:49.690",
      "text": "작지만 내 모든걸 주었고",
      "translation": "时间虽然很短暂 但我把一切都给了你"
    },
    {
      "time": 173.06,
      "time_str": "02:53.060",
      "text": "널 위해 희생했어",
      "translation": "为你做了牺牲"
    },
    {
      "time": 176.29,
      "time_str": "02:56.290",
      "text": "그러지마 이제와서 떠나면",
      "translation": "不要这样 现在离开我"
    },
    {
      "time": 179.89,
      "time_str": "02:59.890",
      "text": "난 어떻하란말야",
      "translation": "我该怎么办"
    },
    {
      "time": 182.85,
      "time_str": "03:02.850",
      "text": "하늘이 잠시 갈라 놓아도",
      "translation": "就算老天把我们暂时分开"
    },
    {
      "time": 186.22,
      "time_str": "03:06.220",
      "text": "우리 운명일 거라고",
      "translation": "我相信我们是命中注定"
    },
    {
      "time": 189.93,
      "time_str": "03:09.930",
      "text": "널 향한 내 사랑은",
      "translation": "我对你的爱"
    },
    {
      "time": 193.08,
      "time_str": "03:13.080",
      "text": "절대 변하지는 않아",
      "translation": "绝不会变"
    },
    {
      "time": 198.33,
      "time_str": "03:18.330",
      "text": "그래 걱정마 언제든지 돌아와",
      "translation": "所以不要担心 不论何时 都会回来"
    },
    {
      "time": 201.81,
      "time_str": "03:21.810",
      "text": "내 걱정은 하지마",
      "translation": "不要担心我"
    },
    {
      "time": 205.17,
      "time_str": "03:25.170",
      "text": "영원히 너만을 기다린다고",
      "translation": "永远只等你"
    },
    {
      "time": 208.6,
      "time_str": "03:28.600",
      "text": "내 사랑은 너라고",
      "translation": "我的爱是你"
    },
    {
      "time": 211.98,
      "time_str": "03:31.980",
      "text": "내 사랑은 너라고",
      "translation": "我的爱是你"
    }
  ],
  "has_translation": true,
