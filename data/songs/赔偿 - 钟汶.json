    {
      "time": 21.28,
      "time_str": "00:21.280",
      "text": "剩下嘴巴逞强",
      "translation": null
    },
    {
      "time": 25.44,
      "time_str": "00:25.440",
      "text": "眼睛无力支撑",
      "translation": null
    },
    {
      "time": 29.96,
      "time_str": "00:29.960",
      "text": "就连说一个谎",
      "translation": null
    },
    {
      "time": 32.49,
      "time_str": "00:32.490",
      "text": "瞒一瞒你都不想",
      "translation": null
    },
    {
      "time": 36.54,
      "time_str": "00:36.540",
      "text": "受尽委屈能怎样",
      "translation": null
    },
    {
      "time": 40.86,
      "time_str": "00:40.860",
      "text": "哭过又怎样",
      "translation": null
    },
    {
      "time": 44.87,
      "time_str": "00:44.870",
      "text": "结果都一样",
      "translation": null
    },
    {
      "time": 48.33,
      "time_str": "00:48.330",
      "text": "被你所伤",
      "translation": null
    },
    {
      "time": 53.11,
      "time_str": "00:53.110",
      "text": "你从不曾把我放在心上",
      "translation": null
    },
    {
      "time": 57.33,
      "time_str": "00:57.330",
      "text": "你从不曾在意我所想",
      "translation": null
    },
    {
      "time": 61.12,
      "time_str": "01:01.120",
      "text": "如果爱你从来只是妄想",
      "translation": null
    },
    {
      "time": 65.59,
      "time_str": "01:05.590",
      "text": "承认早已疯狂",
      "translation": null
    },
    {
      "time": 68.44,
      "time_str": "01:08.440",
      "text": "原谅我已无力再坚强",
      "translation": null
    },
    {
