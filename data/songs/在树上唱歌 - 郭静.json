  "lyrics": [
    {
      "time": 0.37,
      "time_str": "00:00.370",
      "text": "想要光着脚丫 在树上唱歌",
      "translation": null
    },
    {
      "time": 24.58,
      "time_str": "00:24.580",
      "text": "你说的每个笑话我都笑了",
      "translation": null
    },
    {
      "time": 27.21,
      "time_str": "00:27.210",
      "text": "是你变幽默还是我变快乐",
      "translation": null
    },
    {
      "time": 31.98,
      "time_str": "00:31.980",
      "text": "好久不见你说我大不相同",
      "translation": null
    },
    {
      "time": 34.68,
      "time_str": "00:34.680",
      "text": "偷偷告诉你 我的心去整型了",
      "translation": null
    },
    {
      "time": 42.91,
      "time_str": "00:42.910",
      "text": "不想对每件事都那么严格",
      "translation": null
    },
    {
      "time": 45.66,
      "time_str": "00:45.660",
      "text": "弄得全世界好像只剩挫折",
      "translation": null
    },
    {
      "time": 50.29,
      "time_str": "00:50.290",
      "text": "爱一朵花不猜它能开多久",
      "translation": null
    },
    {
      "time": 53.4,
      "time_str": "00:53.400",
      "text": "放宽了心情 把什么都变美了",
      "translation": null
    },
    {
      "time": 60.15,
      "time_str": "01:00.150",
      "text": "想要光着脚丫 在树上唱歌",
      "translation": null
    },
    {
      "time": 64.16,
      "time_str": "01:04.160",
      "text": "好多事物全被缩小了",
      "translation": null
    },
    {
      "time": 67.73,
      "time_str": "01:07.730",
      "text": "心里不想放的就去了 算了",
      "translation": null
    },
    {
      "time": 71.39,
      "time_str": "01:11.390",
      "text": "让太阳把脸庞给晒得红彤彤",
      "translation": null
    },
    {
      "time": 74.789,
      "time_str": "01:14.789",
      "text": "想要吹着口哨 在树上唱歌",
      "translation": null
    },
    {
      "time": 78.88,
      "time_str": "01:18.880",
      "text": "要像开往远方的火车",
      "translation": null
    },
    {
      "time": 82.53,
      "time_str": "01:22.530",
      "text": "可以那么轻快地穿过山洞",
      "translation": null
    },
    {
      "time": 86.16,
      "time_str": "01:26.160",
      "text": "大树上还很空 你要不要陪我",
      "translation": null
