    {
      "time": 21.17,
      "time_str": "00:21.170",
      "text": "不要哭了吗 该哭的人是我吧",
      "translation": null
    },
    {
      "time": 26.33,
      "time_str": "00:26.330",
      "text": "你都坦白爱上了他 我有什么办法",
      "translation": null
    },
    {
      "time": 31.39,
      "time_str": "00:31.390",
      "text": "我也同意啦 既然你提出想法",
      "translation": null
    },
    {
      "time": 36.56,
      "time_str": "00:36.560",
      "text": "我们不要拖拖拉拉 就从明天开始吧",
      "translation": null
    },
    {
      "time": 44.06,
      "time_str": "00:44.060",
      "text": "那就这样吧 再爱都曲终人散啦",
      "translation": null
    },
    {
      "time": 49.95,
      "time_str": "00:49.950",
      "text": "那就分手吧 再爱都无需挣扎",
      "translation": null
    },
    {
      "time": 54.79,
      "time_str": "00:54.790",
      "text": "不要再问我 怎舍得拱手让他",
      "translation": null
    },
    {
      "time": 59.74,
      "time_str": "00:59.740",
      "text": "你走吧 到了记得要给我通电话",
      "translation": null
    },
    {
      "time": 65.18,
      "time_str": "01:05.180",
      "text": "那就这样吧 再爱都要Sayonara",
      "translation": null
    },
    {
      "time": 70.71,
      "time_str": "01:10.710",
      "text": "再给抱一下 闻一闻你的长发",
      "translation": null
    },
    {
      "time": 75.79,
      "time_str": "01:15.790",
      "text": "不要再哭啦 快把眼泪擦一擦",
      "translation": null
    },
    {
      "time": 80.39,
      "time_str": "01:20.390",
      "text": "这样吧 再爱我有缘的话",
