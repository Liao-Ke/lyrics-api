  "lyrics": [
    {
      "time": 21.32,
      "time_str": "00:21.320",
      "text": "离开你不是我选择",
      "translation": null
    },
    {
      "time": 25.64,
      "time_str": "00:25.640",
      "text": "丢下你我怎么舍得",
      "translation": null
    },
    {
      "time": 29.8,
      "time_str": "00:29.800",
      "text": "那些爱情的话我说过",
      "translation": null
    },
    {
      "time": 33.619,
      "time_str": "00:33.619",
      "text": "可是却注定要分手",
      "translation": null
    },
    {
      "time": 37.989,
      "time_str": "00:37.989",
      "text": "离开是逼不得已的",
      "translation": null
    },
    {
      "time": 43.79,
      "time_str": "00:43.790",
      "text": "我还欠你一世温柔",
      "translation": null
    },
    {
      "time": 46.729,
      "time_str": "00:46.729",
      "text": "亲爱的能不能别难过",
      "translation": null
    },
    {
      "time": 51.139,
      "time_str": "00:51.139",
      "text": "就这样安静的忘记我",
      "translation": null
    },
    {
      "time": 57.949,
      "time_str": "00:57.949",
      "text": "当你知道时间不多的时候",
      "translation": null
    },
    {
      "time": 62.009,
      "time_str": "01:02.009",
      "text": "就计划着如何让我离开你",
      "translation": null
    },
    {
      "time": 66.479,
      "time_str": "01:06.479",
      "text": "明白你和其他女孩不一样",
      "translation": null
    },
    {
      "time": 70.749,
      "time_str": "01:10.749",
      "text": "不想你的回忆因我而悲伤",
      "translation": null
    },
    {
      "time": 75.169,
      "time_str": "01:15.169",
      "text": "看你忍着剧痛说句不爱我",
      "translation": null
    },
    {
      "time": 79.489,
      "time_str": "01:19.489",
      "text": "忍住眼泪尽力装作不在意",
      "translation": null
    },
    {
      "time": 84.79,
      "time_str": "01:24.790",
      "text": "离别的那天外面下的大雪",
      "translation": null
    },
    {
      "time": 88.999,
      "time_str": "01:28.999",
      "text": "我对天祈祷着希望它可以掩埋一切",
      "translation": null
    },
    {
