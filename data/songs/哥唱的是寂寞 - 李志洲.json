  "lyrics": [
    {
      "time": 1.87,
      "time_str": "00:01.870",
      "text": "哥唱的是寂寞",
      "translation": null
    },
    {
      "time": 20.8,
      "time_str": "00:20.800",
      "text": "老大不小了 还是没老婆",
      "translation": null
    },
    {
      "time": 25.48,
      "time_str": "00:25.480",
      "text": "就连最小的 阿妹都要嫁人了",
      "translation": null
    },
    {
      "time": 30.32,
      "time_str": "00:30.320",
      "text": "我的那个她 你在哪儿呀",
      "translation": null
    },
    {
      "time": 35.03,
      "time_str": "00:35.030",
      "text": "是不是被那有钱人给忽悠你走了",
      "translation": null
    },
    {
      "time": 40.02,
      "time_str": "00:40.020",
      "text": "我想有个家 家里有个她",
      "translation": null
    },
    {
      "time": 44.66,
      "time_str": "00:44.660",
      "text": "就算做点热面汤吃着比啥都香",
      "translation": null
    },
    {
      "time": 49.52,
      "time_str": "00:49.520",
      "text": "可是哥没有房啊 房价它天天涨",
      "translation": null
    },
    {
      "time": 54.2,
      "time_str": "00:54.200",
      "text": "省吃俭用好几年首期还是凑不上",
      "translation": null
    },
    {
      "time": 60.39,
      "time_str": "01:00.390",
      "text": "哥唱的不是歌 哥唱的是寂寞",
      "translation": null
    },
    {
      "time": 65.0,
      "time_str": "01:05.000",
      "text": "没有人关心哥 快乐不快乐",
      "translation": null
    },
    {
      "time": 70.01,
      "time_str": "01:10.010",
      "text": "不要迷恋哥 哥只是个传说",
      "translation": null
    },
    {
      "time": 74.65,
      "time_str": "01:14.650",
      "text": "只是迫于无奈现实的生活",
      "translation": null
    },
    {
      "time": 79.59,
      "time_str": "01:19.590",
      "text": "哥唱的不是歌 哥唱的是寂寞",
      "translation": null
    },
    {
      "time": 84.31,
      "time_str": "01:24.310",
      "text": "没有人知道哥 哥有多难过",
      "translation": null
    },
    {
      "time": 89.09,
      "time_str": "01:29.090",
      "text": "不埋怨坎坷 哥只想有个窝",
      "translation": null
    },
    {
      "time": 93.82,
      "time_str": "01:33.820",
      "text": "难道注定这一辈子在外漂泊",
      "translation": null
    },
