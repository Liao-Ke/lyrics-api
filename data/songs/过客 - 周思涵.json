    },
    {
      "time": 88.67,
      "time_str": "01:28.670",
      "text": "寂寞它每天数着",
      "translation": null
    },
    {
      "time": 90.89,
      "time_str": "01:30.890",
      "text": "你那么多的失落",
      "translation": null
    },
    {
      "time": 93.3,
      "time_str": "01:33.300",
      "text": "你想要什么你说",
      "translation": null
    },
    {
      "time": 95.64,
      "time_str": "01:35.640",
      "text": "只要我现在有的",
      "translation": null
    },
    {
      "time": 97.96,
      "time_str": "01:37.960",
      "text": "我们之间的点点滴滴",
      "translation": null
    },
    {
      "time": 101.3,
