    {
      "time": 11.79,
      "time_str": "00:11.790",
      "text": "没有谁能够想到",
      "translation": null
    },
    {
      "time": 16.45,
      "time_str": "00:16.450",
      "text": "你会 出现我身旁",
      "translation": null
    },
    {
      "time": 20.95,
      "time_str": "00:20.950",
      "text": "也许是命运开的玩笑",
      "translation": null
    },
    {
      "time": 30.07,
      "time_str": "00:30.070",
      "text": "不敢 太靠近你的身边",
      "translation": null
    },
    {
      "time": 37.44,
      "time_str": "00:37.440",
      "text": "怕你会嫌烦",
      "translation": null
    },
    {
      "time": 39.42,
      "time_str": "00:39.420",
      "text": "只有 一个人默默孤单",
      "translation": null
    },
    {
      "time": 47.46,
      "time_str": "00:47.460",
      "text": "是什么让我们遇见的",
      "translation": null
    },
    {
      "time": 52.05,
      "time_str": "00:52.050",
      "text": "是什么让距离更近了",
      "translation": null
    },
    {
      "time": 56.54,
      "time_str": "00:56.540",
      "text": "不奢求你多好",
      "translation": null
    },
    {
      "time": 58.71,
      "time_str": "00:58.710",
      "text": "给我多一点微笑",
      "translation": null
    },
    {
      "time": 65.54,
      "time_str": "01:05.540",
      "text": "你只是一个过客",
      "translation": null
    },
    {
      "time": 68.03,
      "time_str": "01:08.030",
      "text": "从我的世界路过",
      "translation": null
    },
    {
      "time": 70.29,
      "time_str": "01:10.290",
      "text": "我不敢太多不舍",
      "translation": null
    },
    {
      "time": 72.6,
      "time_str": "01:12.600",
      "text": "怕你看出我难过",
      "translation": null
    },
    {
      "time": 74.96,
      "time_str": "01:14.960",
      "text": "也许我想的太多",
      "translation": null
    },
    {
      "time": 77.15,
      "time_str": "01:17.150",
      "text": "却不能给你什么",
      "translation": null
    },
    {
      "time": 79.66,
      "time_str": "01:19.660",
      "text": "努力把伤心变少",
      "translation": null
