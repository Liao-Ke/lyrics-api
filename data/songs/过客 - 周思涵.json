      "text": "笑容变多就好了",
      "translation": null
    },
    {
      "time": 83.98,
      "time_str": "01:23.980",
      "text": "我只是个陪伴者",
      "translation": null
    },
    {
      "time": 86.4,
      "time_str": "01:26.400",
      "text": "陪着你伤心难过",
