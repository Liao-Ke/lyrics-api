    {
      "time": 22.124,
      "time_str": "00:22.124",
      "text": "都是你的错 轻易爱上我",
      "translation": null
    },
    {
      "time": 25.813,
      "time_str": "00:25.813",
      "text": "让我不知不觉满足被爱的虚荣",
      "translation": null
    },
    {
      "time": 29.632,
      "time_str": "00:29.632",
      "text": "都是你的错 你对人的宠",
      "translation": null
    },
    {
      "time": 33.294,
      "time_str": "00:33.294",
      "text": "是一种诱惑",
      "translation": null
    },
    {
      "time": 37.136,
      "time_str": "00:37.136",
      "text": "都是你的错 在你的眼中",
      "translation": null
    },
    {
      "time": 40.854,
      "time_str": "00:40.854",
      "text": "总是藏着让人又爱又怜的朦胧",
      "translation": null
    },
    {
      "time": 44.575,
      "time_str": "00:44.575",
      "text": "都是你的错 你的痴情梦",
      "translation": null
    },
    {
      "time": 48.33,
      "time_str": "00:48.330",
      "text": "像一个魔咒",
      "translation": null
    },
    {
      "time": 51.46,
      "time_str": "00:51.460",
      "text": "被你爱过还能为谁蠢动",
      "translation": null
    },
    {
      "time": 59.92,
      "time_str": "00:59.920",
      "text": "我承认都是月亮惹的祸",
      "translation": null
    },
    {
      "time": 63.771,
      "time_str": "01:03.771",
      "text": "那样的夜色太美你太温柔",
      "translation": null
    },
    {
      "time": 67.533,
      "time_str": "01:07.533",
      "text": "才会在刹那之间只想和你一起到白头",
      "translation": null
    },
    {
      "time": 75.063,
      "time_str": "01:15.063",
      "text": "我承认都是誓言惹的祸",
      "translation": null
    },
    {
      "time": 78.719,
      "time_str": "01:18.719",
      "text": "偏偏似糖如蜜说来最动人",
