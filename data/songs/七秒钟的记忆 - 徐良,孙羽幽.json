      "time": 25.63,
      "time_str": "00:25.630",
      "text": "Hello没关系",
      "translation": null
    },
    {
      "time": 27.8,
      "time_str": "00:27.800",
      "text": "只是会掉眼泪而已",
      "translation": null
    },
    {
      "time": 31.56,
      "time_str": "00:31.560",
      "text": "思念在躲避",
      "translation": null
    },
    {
      "time": 33.88,
      "time_str": "00:33.880",
      "text": "却依然逃不过回忆",
      "translation": null
    },
    {
      "time": 37.71,
      "time_str": "00:37.710",
      "text": "晚风的声音",
      "translation": null
    },
    {
      "time": 40.5,
      "time_str": "00:40.500",
      "text": "带走你曾经的曾经",
      "translation": null
    },
    {
      "time": 43.88,
      "time_str": "00:43.880",
      "text": "我化作人鱼",
      "translation": null
    },
    {
      "time": 46.3,
      "time_str": "00:46.300",
      "text": "只有七秒钟的记忆",
      "translation": null
    },
    {
      "time": 48.71,
      "time_str": "00:48.710",
      "text": "不经意的思念是那么痛",
      "translation": null
    },
    {
      "time": 52.29,
      "time_str": "00:52.290",
      "text": "痛到回忆根本不敢触碰",
      "translation": null
    },
    {
      "time": 55.21,
      "time_str": "00:55.210",
      "text": "岁月带不走痛 是习惯了痛",
      "translation": null
    },
    {
      "time": 58.58,
      "time_str": "00:58.580",
      "text": "你有恃无恐",
      "translation": null
    },
    {
      "time": 60.96,
      "time_str": "01:00.960",
      "text": "时光不停地在转动",
      "translation": null
    },
    {
      "time": 64.15,
      "time_str": "01:04.150",
      "text": "现在你是谁的英雄",
      "translation": null
    },
    {
      "time": 67.24,
      "time_str": "01:07.240",
      "text": "回到你和我的时空",
      "translation": null
    },
    {
      "time": 70.289,
      "time_str": "01:10.289",
      "text": "抱紧了我让我心痛",
      "translation": null
    },
    {
      "time": 73.46,
      "time_str": "01:13.460",
      "text": "眼泪划过我的面容",
      "translation": null
    },
    {
      "time": 76.43,
      "time_str": "01:16.430",
      "text": "闭上眼睛会是好梦",
      "translation": null
    },
    {
