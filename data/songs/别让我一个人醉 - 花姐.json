  "lyrics": [
    {
      "time": 52.2,
      "time_str": "00:52.200",
      "text": "把我的伤悲 我的痛 轻轻注入你的眼中",
      "translation": null
    },
    {
      "time": 54.69,
      "time_str": "00:54.690",
      "text": "将我的快乐 我的苦 斟进你手中酒",
      "translation": null
    },
    {
      "time": 61.14,
      "time_str": "01:01.140",
      "text": "把你的希望 你的梦 慢慢靠在我的怀中",
      "translation": null
    },
    {
      "time": 68.39,
      "time_str": "01:08.390",
      "text": "将我的快乐 我的苦 一杯一杯敬我",
      "translation": null
    },
    {
      "time": 77.92,
      "time_str": "01:17.920",
      "text": "人生像醇酒 有时浓烈有时薄",
      "translation": null
    },
    {
      "time": 82.93,
      "time_str": "01:22.930",
      "text": "多情岁月滴滴在心头 别让我一个人醉",
      "translation": null
    },
    {
      "time": 90.81,
      "time_str": "01:30.810",
      "text": "别让我一个人走 寂寞的路上有你相陪",
      "translation": null
    },
    {
      "time": 102.93,
      "time_str": "01:42.930",
      "text": "醒来还有梦 别让我一个人醉",
      "translation": null
    },
    {
      "time": 109.69,
      "time_str": "01:49.690",
      "text": "别让我一个人守 漫长的午夜有你相随",
      "translation": null
    },
    {
