    {
      "time": 14.58,
      "time_str": "00:14.580",
      "text": "终于我明白 你的感受",
      "translation": null
    },
    {
      "time": 21.05,
      "time_str": "00:21.050",
      "text": "看深爱的人远走",
      "translation": null
    },
    {
      "time": 27.56,
      "time_str": "00:27.560",
      "text": "比全面失去 好过一些",
      "translation": null
    },
    {
      "time": 34.1,
      "time_str": "00:34.100",
      "text": "记忆永远会留着",
      "translation": null
    },
    {
      "time": 39.41,
      "time_str": "00:39.410",
      "text": "我能做的 事情一件也没有了",
      "translation": null
    },
    {
      "time": 45.79,
      "time_str": "00:45.790",
      "text": "请别说破 最后一道沉默",
      "translation": null
    },
    {
      "time": 52.23,
      "time_str": "00:52.230",
      "text": "无法接受 夏天一放手就坠落",
      "translation": null
    },
    {
      "time": 57.98,
      "time_str": "00:57.980",
      "text": "破碎的冰河",
      "translation": null
    },
    {
      "time": 60.91,
      "time_str": "01:00.910",
      "text": "往悲伤缓慢的飘流",
      "translation": null
    },
    {
      "time": 64.46,
      "time_str": "01:04.460",
      "text": "说分手 就分手",
      "translation": null
    },
    {
      "time": 67.72,
      "time_str": "01:07.720",
      "text": "你一定是在骗我",
      "translation": null
    },
    {
      "time": 70.93,
      "time_str": "01:10.930",
      "text": "好让我 一夜看透",
      "translation": null
    },
    {
      "time": 74.21,
      "time_str": "01:14.210",
      "text": "失去你我算什么",
      "translation": null
    },
    {
      "time": 77.36,
      "time_str": "01:17.360",
      "text": "好难过 别作弄",
      "translation": null
    },
    {
      "time": 80.64,
      "time_str": "01:20.640",
      "text": "还想陪你到尽头",
      "translation": null
    },
    {
      "time": 83.92,
      "time_str": "01:23.920",
      "text": "谁需要 什么自由",
      "translation": null
    },
    {
      "time": 87.19,
      "time_str": "01:27.190",
      "text": "我的世界早被你垄断占有",
      "translation": null
