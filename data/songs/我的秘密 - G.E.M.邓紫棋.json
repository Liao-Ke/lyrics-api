    {
      "time": 10.17,
      "time_str": "00:10.170",
      "text": "最近一直很好心情 不知道什么原因",
      "translation": null
    },
    {
      "time": 19.36,
      "time_str": "00:19.360",
      "text": "我现在这一种心情 我想要唱给你听",
      "translation": null
    },
    {
      "time": 37.82,
      "time_str": "00:37.820",
      "text": "看着窗外的小星星 心里想着我的秘密",
      "translation": null
    },
    {
      "time": 47.03,
      "time_str": "00:47.030",
      "text": "算不算爱我不太确定 我只知道我在想你",
      "translation": null
    },
    {
      "time": 64.959,
      "time_str": "01:04.959",
      "text": "我们之间的距离好像忽远又忽近",
      "translation": null
    },
    {
      "time": 69.579,
      "time_str": "01:09.579",
      "text": "你明明不在我身边我却觉得很亲",
      "translation": null
    },
    {
      "time": 73.989,
      "time_str": "01:13.989",
      "text": "Ha~ 有一种感觉我想说明",
      "translation": null
    },
    {
      "time": 78.4,
      "time_str": "01:18.400",
      "text": "我心里的秘密 是你给的甜蜜",
      "translation": null
    },
    {
      "time": 83.409,
      "time_str": "01:23.409",
      "text": "我们之间的距离好像一点点靠近",
      "translation": null
    },
    {
      "time": 87.9,
      "time_str": "01:27.900",
      "text": "是不是你对我也有一种特殊感情",
      "translation": null
    },
    {
      "time": 92.22,
      "time_str": "01:32.220",
      "text": "Ha~ 我犹豫要不要告诉你",
      "translation": null
    },
    {
