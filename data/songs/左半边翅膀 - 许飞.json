  "lyrics": [
    {
      "time": 25.89,
      "time_str": "00:25.890",
      "text": "多一秒停在这里就好",
      "translation": null
    },
    {
      "time": 31.73,
      "time_str": "00:31.730",
      "text": "才发现习惯了这味道",
      "translation": null
    },
    {
      "time": 39.07,
      "time_str": "00:39.070",
      "text": "甜甜的思念涩涩的埋怨",
      "translation": null
    },
    {
      "time": 48.55,
      "time_str": "00:48.550",
      "text": "回忆的画面跟时间赛跑 总赢不了",
      "translation": null
    },
    {
      "time": 55.85,
      "time_str": "00:55.850",
      "text": "再一秒再多一秒就好",
      "translation": null
    },
    {
      "time": 64.42,
      "time_str": "01:04.420",
      "text": "才开始怀念和你争吵",
      "translation": null
    },
    {
      "time": 72.11,
      "time_str": "01:12.110",
      "text": "但你不知道吧 在我心里面",
      "translation": null
    },
    {
      "time": 80.9,
      "time_str": "01:20.900",
      "text": "你的肩膀是我最坚强的依靠",
      "translation": null
    },
    {
      "time": 88.44,
      "time_str": "01:28.440",
      "text": "梦是远远飞翔 你就是我左半边翅膀",
      "translation": null
    },
    {
      "time": 96.65,
      "time_str": "01:36.650",
      "text": "天空再大再远和你并肩 我也勇敢闯",
      "translation": null
    },
    {
      "time": 104.43,
      "time_str": "01:44.430",
      "text": "梦是远远飞翔 你就是我左半边翅膀",
      "translation": null
    },
    {
      "time": 112.95,
      "time_str": "01:52.950",
      "text": "感觉不到你的呼吸的心跳和我一起",
      "translation": null
    },
    {
      "time": 119.08,
      "time_str": "01:59.080",
      "text": "我宁愿不要飞翔",
      "translation": null
