  "lyrics": [
    {
      "time": 23.69,
      "time_str": "00:23.690",
      "text": "突然离开的人都让我很胆怯",
      "translation": null
    },
    {
      "time": 32.97,
      "time_str": "00:32.970",
      "text": "我也学会矫揉造作的去妥协",
      "translation": null
    },
    {
      "time": 43.62,
      "time_str": "00:43.620",
      "text": "等你轻描淡写告了别",
      "translation": null
    },
    {
      "time": 47.87,
      "time_str": "00:47.870",
      "text": "看你头也不回绕过街",
      "translation": null
    },
    {
      "time": 52.99,
      "time_str": "00:52.990",
      "text": "我要是个孩子那该多撕裂",
      "translation": null
    },
    {
      "time": 62.97,
      "time_str": "01:02.970",
      "text": "其实那晚足足喝够了一整夜",
      "translation": null
    },
    {
      "time": 72.97,
      "time_str": "01:12.970",
      "text": "打了几通电话都提示没人接",
      "translation": null
    },
    {
      "time": 83.5,
      "time_str": "01:23.500",
      "text": "然后故作常态的轻蔑",
      "translation": null
    },
    {
      "time": 87.97,
      "time_str": "01:27.970",
      "text": "然而那是最后的通牒",
      "translation": null
    },
    {
      "time": 93.13,
      "time_str": "01:33.130",
      "text": "我要是个罪犯那该多分裂",
      "translation": null
    },
    {
      "time": 100.88,
      "time_str": "01:40.880",
      "text": "我还要装作若无其事的样子",
      "translation": null
    },
    {
      "time": 105.74,
      "time_str": "01:45.740",
      "text": "我感到话语之间冷漠和讽刺",
      "translation": null
    },
    {
      "time": 110.81,
      "time_str": "01:50.810",
      "text": "与其说爱你这件事",
      "translation": null
    },
    {
      "time": 114.67,
      "time_str": "01:54.670",
      "text": "倒不如痛快的告辞",
      "translation": null
    },
    {
      "time": 120.83,
      "time_str": "02:00.830",
      "text": "就算我像个自命清高的疯子",
      "translation": null
    },
    {
      "time": 125.73,
      "time_str": "02:05.730",
      "text": "绝不会颠沛流离地沦落于此",
      "translation": null
    },
    {
      "time": 130.95,
      "time_str": "02:10.950",
      "text": "感情里谁说谁自私",
      "translation": null
    },
    {
      "time": 134.55,
      "time_str": "02:14.550",
      "text": "到后来都语无伦次",
      "translation": null
    },
