  "lyrics": [
    {
      "time": 4.2,
      "time_str": "00:04.200",
      "text": "红日升在东方 其大道满霞光",
      "translation": null
    },
    {
      "time": 11.22,
      "time_str": "00:11.220",
      "text": "我何其幸 生于你怀 承一脉血流淌",
      "translation": null
    },
    {
      "time": 18.49,
      "time_str": "00:18.490",
      "text": "难同当 福共享 挺立起了脊梁",
      "translation": null
    },
    {
      "time": 26.01,
      "time_str": "00:26.010",
      "text": "吾国万疆 以仁爱 千年不灭的信仰",
      "translation": null
    },
    {
      "time": 43.8,
      "time_str": "00:43.800",
      "text": "写苍天只写一角日与月悠长",
      "translation": null
    },
    {
      "time": 50.82,
      "time_str": "00:50.820",
      "text": "画大地只画一隅山与河无恙",
      "translation": null
    },
    {
      "time": 58.09,
      "time_str": "00:58.090",
      "text": "观万古上下五千年天地共仰",
      "translation": null
    },
    {
      "time": 65.11,
      "time_str": "01:05.110",
      "text": "唯炎黄 心坦荡 一身到四方",
      "translation": null
    },
    {
      "time": 74.13,
      "time_str": "01:14.130",
      "text": "抚流光一砖一瓦岁月浸红墙",
      "translation": null
    },
    {
      "time": 81.15,
      "time_str": "01:21.150",
      "text": "叹枯荣一花一木悲喜经沧桑",
      "translation": null
    },
    {
      "time": 88.41,
      "time_str": "01:28.410",
      "text": "横八荒九州一色心中的故乡",
      "translation": null
    },
    {
      "time": 95.68,
      "time_str": "01:35.680",
      "text": "唯华夏 崭锋芒 道路在盛放",
      "translation": null
    },
