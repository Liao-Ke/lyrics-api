  "lyrics": [
    {
      "time": 15.734,
      "time_str": "00:15.734",
      "text": "我间中饮醉酒 很喜欢自由",
      "translation": null
    },
    {
      "time": 19.716,
      "time_str": "00:19.716",
      "text": "常犯错爱说谎 但总会内疚",
      "translation": null
    },
    {
      "time": 24.056,
      "time_str": "00:24.056",
      "text": "遇过很多的损友 学到贪新厌旧",
      "translation": null
    },
    {
      "time": 28.654,
      "time_str": "00:28.654",
      "text": "亦欠过很多女人",
      "translation": null
    },
    {
      "time": 32.614,
      "time_str": "00:32.614",
      "text": "怕结婚只会守 三分钟诺言",
      "translation": null
    },
    {
      "time": 37.013,
      "time_str": "00:37.013",
      "text": "曾话过要戒烟 但讲了就算",
      "translation": null
    },
    {
      "time": 41.359,
      "time_str": "00:41.359",
      "text": "梦与想丢低很远 但对返工厌倦",
      "translation": null
    },
    {
      "time": 45.949,
      "time_str": "00:45.949",
      "text": "自小不会打算",
      "translation": null
    },
    {
      "time": 50.268,
      "time_str": "00:50.268",
      "text": "但是仍 唯独你爱我这废人",
      "translation": null
    },
    {
      "time": 54.478,
      "time_str": "00:54.478",
      "text": "出错你都肯去忍",
      "translation": null
    },
    {
      "time": 58.932,
      "time_str": "00:58.932",
      "text": "然而谁亦早知不会合衬",
      "translation": null
    },
    {
      "time": 63.151,
      "time_str": "01:03.151",
      "text": "偏偏你愿意等",
      "translation": null
    },
    {
      "time": 66.89,
      "time_str": "01:06.890",
      "text": "为何还喜欢我 我这种无赖",
      "translation": null
    },
    {
      "time": 71.31,
      "time_str": "01:11.310",
      "text": "是话你蠢还是很伟大",
      "translation": null
    },
    {
      "time": 75.56,
      "time_str": "01:15.560",
      "text": "在座每位都将我踩 口碑有多坏",
      "translation": null
    },
    {
      "time": 80.512,
      "time_str": "01:20.512",
      "text": "但你亦永远不见怪",
      "translation": null
    },
    {
      "time": 84.369,
      "time_str": "01:24.369",
      "text": "何必跟我 我这种无赖",
      "translation": null
    },
    {
      "time": 88.402,
      "time_str": "01:28.402",
      "text": "活大半生还是很失败",
      "translation": null
    },
    {
      "time": 92.747,
      "time_str": "01:32.747",
      "text": "但是你死都不变心 跟我笑着捱",
      "translation": null
    },
    {
      "time": 97.816,
      "time_str": "01:37.816",
      "text": "就算坏 我也不忍心 偷偷作怪",
      "translation": null
    },
    {
      "time": 123.68,
      "time_str": "02:03.680",
      "text": "没有根的野草 飘忽的命途",
      "translation": null
    },
    {
      "time": 127.813,
      "time_str": "02:07.813",
      "text": "谁像你当我宝 什么也做到",
      "translation": null
    },
    {
      "time": 132.125,
      "time_str": "02:12.125",
      "text": "旧爱数足一匹布 在这刻写句号",
      "translation": null
    },
    {
      "time": 136.723,
      "time_str": "02:16.723",
      "text": "只想跟你终老",
      "translation": null
    },
    {
