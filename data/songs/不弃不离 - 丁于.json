    {
      "time": 16.81,
      "time_str": "00:16.810",
      "text": "还记得我们共同约定",
      "translation": null
    },
    {
      "time": 21.37,
      "time_str": "00:21.370",
      "text": "还记得我们共同呼吸",
      "translation": null
    },
    {
      "time": 26.18,
      "time_str": "00:26.180",
      "text": "那么的温柔 那么近的距离",
      "translation": null
    },
    {
      "time": 32.229,
      "time_str": "00:32.229",
      "text": "我们的心连的很紧",
      "translation": null
    },
    {
      "time": 35.92,
      "time_str": "00:35.920",
      "text": "说好永远都不会放弃",
      "translation": null
    },
    {
      "time": 40.6,
      "time_str": "00:40.600",
      "text": "还记得我们一起散步淋着雨",
      "translation": null
    },
    {
      "time": 45.67,
      "time_str": "00:45.670",
      "text": "就算有冷空气 我会把你抱紧",
      "translation": null
    },
    {
      "time": 52.4,
      "time_str": "00:52.400",
      "text": "不想让你受一点委屈",
      "translation": null
    },
    {
      "time": 60.23,
      "time_str": "01:00.230",
      "text": "不弃不离 永远在一起",
      "translation": null
    },
    {
      "time": 69.17,
      "time_str": "01:09.170",
      "text": "简单的话 还是那一句我爱你",
