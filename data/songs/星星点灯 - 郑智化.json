  "lyrics": [
    {
      "time": 59.52,
      "time_str": "00:59.520",
      "text": "抬头的一片天 是男儿的一片天",
      "translation": null
    },
    {
      "time": 64.08,
      "time_str": "01:04.080",
      "text": "曾经在满天的星光下做梦的少年",
      "translation": null
    },
    {
      "time": 68.8,
      "time_str": "01:08.800",
      "text": "不知道天多高 不知道海多远",
      "translation": null
    },
    {
      "time": 73.36,
      "time_str": "01:13.360",
      "text": "却发誓要带着你远走到海角天边",
      "translation": null
    },
    {
      "time": 78.14,
      "time_str": "01:18.140",
      "text": "不负责任的誓言 年少轻狂的我",
      "translation": null
    },
    {
      "time": 82.66,
      "time_str": "01:22.660",
      "text": "在黑暗中迷失才发现自己的脆弱",
      "translation": null
    },
    {
      "time": 87.37,
      "time_str": "01:27.370",
      "text": "看着你哭红的眼睛 想着远离的家门",
      "translation": null
    },
    {
      "time": 92.1,
      "time_str": "01:32.100",
      "text": "满天的星星请为我点盏希望的灯火",
      "translation": null
    },
    {
      "time": 96.69,
      "time_str": "01:36.690",
      "text": "星星点灯 照亮我的家门",
      "translation": null
    },
    {
      "time": 101.16,
      "time_str": "01:41.160",
      "text": "让迷失的孩子找到来时的路",
      "translation": null
    },
    {
      "time": 105.97,
      "time_str": "01:45.970",
      "text": "星星点灯 照亮我的前程",
      "translation": null
    },
    {
      "time": 110.45,
      "time_str": "01:50.450",
      "text": "用一点光 温暖孩子的心",
      "translation": null
    },
    {
      "time": 131.74,
      "time_str": "02:11.740",
      "text": "现在的一片天 是肮脏的一片天",
      "translation": null
    },
    {
      "time": 136.37,
      "time_str": "02:16.370",
      "text": "星星在文明的天空里再也看不见",
      "translation": null
    },
    {
      "time": 140.96,
      "time_str": "02:20.960",
      "text": "天其实并不高 海其实也不远",
      "translation": null
    },
    {
      "time": 145.67,
      "time_str": "02:25.670",
      "text": "人心其实比天高 比海更遥远",
      "translation": null
    },
    {
      "time": 150.09,
      "time_str": "02:30.090",
      "text": "学会骗人的谎言 追逐名利的我",
      "translation": null
    },
    {
      "time": 154.96,
      "time_str": "02:34.960",
      "text": "在现实中迷失才发现自己的脆弱",
      "translation": null
    },
    {
      "time": 159.65,
      "time_str": "02:39.650",
      "text": "看着你含泪地离去 想着茫茫的前程",
      "translation": null
    },
    {
      "time": 164.32,
      "time_str": "02:44.320",
      "text": "远方的星星请为我点盏希望的灯火",
      "translation": null
    },
    {
      "time": 168.91,
      "time_str": "02:48.910",
      "text": "星星点灯 照亮我的家门",
      "translation": null
    },
    {
      "time": 173.38,
      "time_str": "02:53.380",
      "text": "让迷失的孩子找到来时的路",
      "translation": null
    },
    {
      "time": 178.19,
      "time_str": "02:58.190",
      "text": "星星点灯 照亮我的前程",
      "translation": null
    },
    {
      "time": 183.13,
      "time_str": "03:03.130",
      "text": "用一点光 温暖孩子的心",
      "translation": null
    },
    {
      "time": 213.38,
      "time_str": "03:33.380",
      "text": "多年以后一场大雨惊醒沉睡的我",
      "translation": null
    },
    {
      "time": 218.15,
      "time_str": "03:38.150",
      "text": "突然之间都市的霓虹都不再闪烁",
      "translation": null
    },
    {
      "time": 222.48,
      "time_str": "03:42.480",
      "text": "天边有颗模糊的星光偷偷探出了头",
      "translation": null
    },
    {
      "time": 227.13,
      "time_str": "03:47.130",
      "text": "是你的眼神依旧在远方为我在等候",
      "translation": null
    },
    {
      "time": 232.07,
      "time_str": "03:52.070",
      "text": "星星点灯 照亮我的家门",
      "translation": null
    },
    {
      "time": 236.28,
      "time_str": "03:56.280",
      "text": "让迷失的孩子找到来时的路",
      "translation": null
    },
    {
