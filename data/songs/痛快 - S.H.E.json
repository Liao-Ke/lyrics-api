    {
      "time": 29.62,
      "time_str": "00:29.620",
      "text": "每件事 都发生来丰富我的记忆",
      "translation": null
    },
    {
      "time": 34.41,
      "time_str": "00:34.410",
      "text": "很好奇 还有谁等着闯进我日记",
      "translation": null
    },
    {
