  "lyrics": [
    {
      "time": 22.379,
      "time_str": "00:22.379",
      "text": "你让他用戒指把你套上的时候",
      "translation": null
    },
    {
      "time": 27.999,
      "time_str": "00:27.999",
      "text": "我察觉到你脸上复杂的笑容",
      "translation": null
    },
    {
      "time": 32.988,
      "time_str": "00:32.988",
      "text": "那原本该是我 付予你的承诺",
      "translation": null
    },
    {
      "time": 37.388,
      "time_str": "00:37.388",
      "text": "现在我只能隐身热闹中",
      "translation": null
    },
    {
      "time": 43.997,
      "time_str": "00:43.997",
      "text": "我跟着所有人向你祝贺的时候",
      "translation": null
    },
    {
      "time": 49.8,
      "time_str": "00:49.800",
      "text": "只有你知道我多喝了几杯酒",
      "translation": null
    },
    {
      "time": 53.57,
      "time_str": "00:53.570",
      "text": "我不能再看你 多一眼都是痛",
      "translation": null
    },
    {
      "time": 58.567,
      "time_str": "00:58.567",
      "text": "即使知道暗地里你又回头",
      "translation": null
    },
    {
      "time": 65.68,
      "time_str": "01:05.680",
      "text": "我终于知道曲终人散的寂寞",
      "translation": null
    },
    {
      "time": 69.957,
      "time_str": "01:09.957",
      "text": "只有伤心人才有",
      "translation": null
    },
    {
      "time": 74.638,
      "time_str": "01:14.638",
      "text": "你最后一身红 残留在我眼中",
      "translation": null
    },
    {
      "time": 79.867,
      "time_str": "01:19.867",
      "text": "我没有再依恋的借口",
      "translation": null
    },
    {
      "time": 85.647,
      "time_str": "01:25.647",
      "text": "原来这就是曲终人散的寂寞",
      "translation": null
    },
    {
      "time": 91.326,
      "time_str": "01:31.326",
      "text": "我还想等你什么",
      "translation": null
    },
    {
      "time": 95.368,
      "time_str": "01:35.368",
      "text": "你紧紧拉住我衣袖",
      "translation": null
    },
    {
      "time": 98.618,
      "time_str": "01:38.618",
      "text": "又放开让我走",
      "translation": null
    },
    {
      "time": 100.969,
      "time_str": "01:40.969",
      "text": "这一次跟我彻底分手",
      "translation": null
    },
