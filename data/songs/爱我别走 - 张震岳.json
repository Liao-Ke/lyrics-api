    {
      "time": 23.999,
      "time_str": "00:23.999",
      "text": "我到了这个时候还是一样",
      "translation": null
    },
    {
      "time": 28.998,
      "time_str": "00:28.998",
      "text": "夜里的寂寞容易叫人悲伤",
      "translation": null
    },
    {
      "time": 33.29,
      "time_str": "00:33.290",
      "text": "我不敢想的太多",
      "translation": null
    },
    {
      "time": 38.098,
      "time_str": "00:38.098",
      "text": "因为我一个人",
      "translation": null
    },
    {
      "time": 44.098,
      "time_str": "00:44.098",
      "text": "迎面而来的月光拉长身影",
      "translation": null
    },
    {
      "time": 50.098,
      "time_str": "00:50.098",
      "text": "漫无目的地走在冷冷的街",
      "translation": null
    },
    {
      "time": 55.098,
      "time_str": "00:55.098",
      "text": "我没有你的消息",
      "translation": null
    },
    {
      "time": 59.098,
      "time_str": "00:59.098",
      "text": "因为我在想你",
      "translation": null
    },
    {
      "time": 66.098,
      "time_str": "01:06.098",
      "text": "爱我别走",
      "translation": null
    },
    {
      "time": 69.098,
      "time_str": "01:09.098",
      "text": "如果你说 你不爱我",
      "translation": null
    },
    {
      "time": 76.798,
      "time_str": "01:16.798",
      "text": "不要听见你真的说出口",
      "translation": null
    },
    {
      "time": 80.398,
      "time_str": "01:20.398",
      "text": "再给我一点温柔",
