  },
  "lyrics": [
    {
      "time": 35.51,
      "time_str": "00:35.510",
      "text": "孤单听雨的猫往时间裂缝里看到了我",
      "translation": null
    },
    {
      "time": 42.785,
      "time_str": "00:42.785",
      "text": "雷电交加之外的另一些我",
      "translation": null
    },
    {
      "time": 49.967,
      "time_str": "00:49.967",
      "text": "乌云静止以后 跳进平行时空",
      "translation": null
    },
    {
      "time": 56.381,
      "time_str": "00:56.381",
      "text": "那些我 旅行中的你我",
      "translation": null
    },
    {
      "time": 60.518,
      "time_str": "01:00.518",
      "text": "回忆胡乱穿梭 坠落",
      "translation": null
    },
    {
      "time": 68.82,
      "time_str": "01:08.820",
      "text": "交换余生 是我 非我 苦与乐",
      "translation": null
    },
    {
      "time": 76.629,
      "time_str": "01:16.629",
      "text": "阴天之后总有续命的晴空",
      "translation": null
    },
    {
      "time": 83.885,
      "time_str": "01:23.885",
      "text": "如果我们几经转折 结局一样不动",
      "translation": null
    },
    {
      "time": 91.67,
      "time_str": "01:31.670",
      "text": "也才算无愧这分合",
      "translation": null
    },
    {
      "time": 126.053,
      "time_str": "02:06.053",
      "text": "定位心海的锚让时间停顿的像慢动作",
      "translation": null
    },
    {
      "time": 132.818,
      "time_str": "02:12.818",
      "text": "你说命运很坏吧 幸好有我",
      "translation": null
    },
    {
      "time": 140.443,
      "time_str": "02:20.443",
      "text": "如果没有以后 如果平行失控",
      "translation": null
    },
    {
      "time": 146.747,
      "time_str": "02:26.747",
      "text": "那些我 不同人生的我",
      "translation": null
    },
    {
      "time": 150.691,
      "time_str": "02:30.691",
      "text": "会以什么方式哭过",
      "translation": null
    },
    {
      "time": 157.861,
      "time_str": "02:37.861",
      "text": "交换余生 是我 非我 苦与乐",
      "translation": null
    },
    {
      "time": 165.313,
      "time_str": "02:45.313",
      "text": "阴天之后总有续命的晴空",
      "translation": null
    },
    {
      "time": 172.54,
      "time_str": "02:52.540",
      "text": "如果我们几经转折 结局一样不动",
      "translation": null
    },
    {
      "time": 180.539,
      "time_str": "03:00.539",
      "text": "也才算无愧这分合",
      "translation": null
    },
    {
      "time": 187.946,
      "time_str": "03:07.946",
      "text": "云等风 人等梦 爱辗过时光等什么",
      "translation": null
    },
    {
      "time": 195.072,
      "time_str": "03:15.072",
      "text": "记不住 认不出 泪眼中谁一样脸红",
      "translation": null
    },
    {
      "time": 202.938,
      "time_str": "03:22.938",
      "text": "等你说 等我说 一等就是一个宇宙",
      "translation": null
    },
    {
      "time": 209.459,
      "time_str": "03:29.459",
      "text": "日升换月落 真爱换寂寞",
      "translation": null
    },
    {
      "time": 217.364,
      "time_str": "03:37.364",
      "text": "交换余生 也许忘了第几梦",
      "translation": null
    },
    {
      "time": 224.459,
      "time_str": "03:44.459",
      "text": "那时我们身处第几号时空",
      "translation": null
    },
    {
      "time": 231.395,
      "time_str": "03:51.395",
      "text": "因为我们手心紧握 记忆也能紧扣",
      "translation": null
    },
    {
      "time": 239.438,
      "time_str": "03:59.438",
      "text": "可不怕前方的虫洞",
      "translation": null
    },
    {
      "time": 247.015,
      "time_str": "04:07.015",
      "text": "爱是时间的古董",
      "translation": null
    },
    {
      "time": 257.022,
      "time_str": "04:17.022",
      "text": "-------------",
      "translation": null
