{
  "title": "交换余生",
  "title_raw": "交换余生",
  "version": null,
  "artist": "林俊杰",
  "group_key": "交换余生|林俊杰",
  "writers": {
    "lyricist": "易家扬",
    "composer": "林俊杰",
