    {
      "time": 36.53,
      "time_str": "00:36.530",
      "text": "小时候的我 做着美的梦",
      "translation": null
    },
    {
      "time": 44.17,
      "time_str": "00:44.170",
      "text": "梦想中 那片天空 好像挂满笑容",
      "translation": null
    },
    {
      "time": 50.93,
      "time_str": "00:50.930",
      "text": "长大后的我 坚定着美梦",
      "translation": null
    },
    {
      "time": 58.91,
      "time_str": "00:58.910",
      "text": "因为我 已慢慢懂 努力就能成功",
      "translation": null
    },
    {
      "time": 67.1,
      "time_str": "01:07.100",
      "text": "我一个人的力量",
      "translation": null
    },
    {
      "time": 70.85,
      "time_str": "01:10.850",
      "text": "能去闯 就算要飞越海洋",
      "translation": null
    },
    {
      "time": 76.47,
      "time_str": "01:16.470",
      "text": "也不能 阻挡我对梦的渴望",
      "translation": null
    },
    {
      "time": 81.96,
      "time_str": "01:21.960",
      "text": "我一个人的信仰",
      "translation": null
    },
    {
      "time": 85.6,
      "time_str": "01:25.600",
      "text": "像太阳 散发着炽热的光",
      "translation": null
    },
    {
      "time": 91.18,
      "time_str": "01:31.180",
      "text": "能照亮 所有内心 灰暗的地方",
      "translation": null
    },
    {
      "time": 119.37,
      "time_str": "01:59.370",
      "text": "天边的彩虹 倒映我的梦",
      "translation": null
    },
    {
      "time": 126.89,
      "time_str": "02:06.890",
      "text": "路边的 彩色霓虹 流淌着感动",
      "translation": null
    },
    {
      "time": 134.3,
      "time_str": "02:14.300",
      "text": "风吹的温柔 带走了沉重",
      "translation": null
    },
