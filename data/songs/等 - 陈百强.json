  "lyrics": [
    {
      "time": 16.979,
      "time_str": "00:16.979",
      "text": "等 寂寞到夜深",
      "translation": null
    },
    {
      "time": 22.979,
      "time_str": "00:22.979",
      "text": "夜已渐荒凉",
      "translation": null
    },
    {
      "time": 26.299,
      "time_str": "00:26.299",
      "text": "夜已渐昏暗",
      "translation": null
    },
    {
      "time": 29.699,
      "time_str": "00:29.699",
      "text": "莫道你在选择人",
      "translation": null
    },
    {
      "time": 32.5,
      "time_str": "00:32.500",
      "text": "人亦能选择你",
      "translation": null
    },
    {
      "time": 35.959,
      "time_str": "00:35.959",
      "text": "公平原没半点偏心",
      "translation": null
    },
    {
      "time": 44.99,
      "time_str": "00:44.990",
      "text": "苦涩 慢慢向着心里渗",
      "translation": null
    },
    {
      "time": 50.589,
      "time_str": "00:50.589",
      "text": "何必抱怨",
      "translation": null
    },
    {
      "time": 53.959,
      "time_str": "00:53.959",
      "text": "曾令醉心是谁人",
      "translation": null
    },
    {
      "time": 58.19,
      "time_str": "00:58.190",
      "text": "自愿吻别心上人",
      "translation": null
    },
    {
      "time": 60.729,
      "time_str": "01:00.729",
      "text": "糊涂换来一生泪印",
      "translation": null
    },
    {
      "time": 64.538,
      "time_str": "01:04.538",
      "text": "何故明是痛苦伤心",
      "translation": null
    },
    {
      "time": 71.979,
      "time_str": "01:11.979",
      "text": "还含着笑装开心",
      "translation": null
    },
    {
      "time": 75.789,
      "time_str": "01:15.789",
      "text": "今宵的你可怜还可悯",
      "translation": null
    },
    {
      "time": 79.599,
      "time_str": "01:19.599",
      "text": "目睹她远去",
      "translation": null
    },
    {
      "time": 82.099,
      "time_str": "01:22.099",
      "text": "她的脚印心中永印",
      "translation": null
    },
    {
      "time": 85.609,
      "time_str": "01:25.609",
      "text": "糊涂是你的一颗心",
      "translation": null
    },
    {
      "time": 90.0,
      "time_str": "01:30.000",
      "text": "他朝你将无穷的后悔",
      "translation": null
    },
    {
      "time": 94.3,
      "time_str": "01:34.300",
      "text": "这一生你的心里满哀困",
      "translation": null
    },
