    {
      "time": 100.94,
      "time_str": "01:40.940",
      "text": "听不到那崇高的誓言",
      "translation": null
    },
    {
      "time": 104.31,
      "time_str": "01:44.310",
      "text": "谁还会为理想而战斗",
      "translation": null
    },
    {
      "time": 107.74,
      "time_str": "01:47.740",
      "text": "谁还会为爱情而牺牲",
