    {
      "time": 29.05,
      "time_str": "00:29.050",
      "text": "北京开往莫斯科的快车",
      "translation": null
    },
    {
      "time": 32.41,
      "time_str": "00:32.410",
      "text": "越过西伯利亚伏尔加河",
      "translation": null
    },
    {
      "time": 35.8,
      "time_str": "00:35.800",
      "text": "穿过施华洛奇的森林",
      "translation": null
    },
    {
      "time": 39.18,
      "time_str": "00:39.180",
      "text": "来到迷幻的克里姆林宫",
      "translation": null
    },
    {
      "time": 42.68,
      "time_str": "00:42.680",
      "text": "来自列宁格勒的牛仔",
      "translation": null
    },
    {
      "time": 46.07,
      "time_str": "00:46.070",
      "text": "我有一把托尼卡吉他",
      "translation": null
    },
    {
      "time": 49.51,
      "time_str": "00:49.510",
      "text": "加加林的火箭还在太空",
      "translation": null
    },
    {
      "time": 52.94,
      "time_str": "00:52.940",
      "text": "托尔斯泰的安娜卡特琳娜",
      "translation": null
    },
    {
      "time": 56.37,
      "time_str": "00:56.370",
      "text": "卡宾斯基 柴可夫斯基 卡车司机 出租司机 拖拉机司机",
      "translation": null
    },
    {
      "time": 63.22,
      "time_str": "01:03.220",
      "text": "伊万诺夫 巴普诺夫 巴巴诺夫 他是懦夫 罗里罗索夫",
      "translation": null
    },
    {
      "time": 70.04,
      "time_str": "01:10.040",
      "text": "莎拉波娃 达波波娃 人参娃娃 葫芦娃娃 库尔尼科娃",
      "translation": null
    },
    {
      "time": 76.85,
      "time_str": "01:16.850",
      "text": "鲁舍夫维奇 德约科维奇 尼古拉维奇 费多罗维奇 RUSSIA DISCO",
      "translation": null
    },
    {
      "time": 87.24,
      "time_str": "01:27.240",
      "text": "RUSSIA DISCO DANCE",
      "translation": null
    },
    {
      "time": 94.06,
      "time_str": "01:34.060",
      "text": "RUSSIA DISCO DANCE",
      "translation": null
    },
    {
      "time": 97.62,
      "time_str": "01:37.620",
      "text": "在这莫斯科郊外的夜晚",
      "translation": null
