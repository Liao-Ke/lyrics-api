  "lyrics": [
    {
      "time": 22.51,
      "time_str": "00:22.510",
      "text": "사랑을 잘 모르겠어",
      "translation": "不太懂爱情是什么"
    },
    {
      "time": 26.4,
      "time_str": "00:26.400",
      "text": "이렇게 다가올 줄 난 몰랐어",
      "translation": "万万没想到就这样接近我"
    },
    {
      "time": 31.38,
      "time_str": "00:31.380",
      "text": "내 마음조차도 사랑 앞에서는 내 뜻대로 안돼",
      "translation": "连我的心在爱情面前无法按照我的意愿来"
    },
    {
      "time": 40.7,
      "time_str": "00:40.700",
      "text": "이럴 줄 알았더라면",
      "translation": "早知道这样"
    },
    {
      "time": 44.68,
      "time_str": "00:44.680",
      "text": "첨부터 시작하지도 않았어",
      "translation": "我当初就不会开始的"
    },
    {
      "time": 49.56,
      "time_str": "00:49.560",
      "text": "바보처럼 이제와서야 난 이 늦은 후회를 하고 있어",
      "translation": "像傻瓜一样到现在我才后悔着"
    },
    {
      "time": 58.82,
      "time_str": "00:58.820",
      "text": "니가 사랑이 되지 않기를 빌었어",
      "translation": "我祈祷着不要爱上你"
    },
    {
      "time": 63.72,
      "time_str": "01:03.720",
      "text": "너만은 절대로 아니기를 빌었어",
      "translation": "祈祷着绝对不是你"
    },
    {
      "time": 68.55,
      "time_str": "01:08.550",
      "text": "넌 사랑이 아닐걸라고 수도 없이 나를 속여왔어",
      "translation": "你说这不是爱情，无数次骗我"
    },
    {
      "time": 76.98,
      "time_str": "01:16.980",
      "text": "잠시 스쳐가는 인연이길 바랬어",
      "translation": "希望只是短暂的擦肩而过的缘分"
    },
    {
      "time": 82.12,
      "time_str": "01:22.120",
      "text": "아픈 상처만 내게 남겨질테니까",
      "translation": "不然只会给我留下伤口"
    },
    {
      "time": 86.83,
      "time_str": "01:26.830",
      "text": "하지만 알면서도 너의 모든 것이 욕심이나",
      "translation": "但是明明知道结果，还是我还是想得到你的一切"
    },
    {
      "time": 97.89,
      "time_str": "01:37.890",
      "text": "자꾸 슬퍼져",
      "translation": "所以会经常感到伤心"
    },
    {
      "time": 116.64,
      "time_str": "01:56.640",
      "text": "잘못된 시작이라고",
      "translation": "这是错误的开始"
    },
    {
      "time": 120.19,
      "time_str": "02:00.190",
      "text": "그렇게 쉽게 생각 했었는데",
      "translation": "像这样简单的想着"
    },
    {
      "time": 125.16,
      "time_str": "02:05.160",
      "text": "언제든 부를 수 있을꺼라고 난 믿었었는데",
      "translation": "我以为可以随时叫你"
    },
    {
      "time": 133.57,
      "time_str": "02:13.570",
      "text": "어떻게 난 해야 할지 어디서 부터가 잘못된 건지",
      "translation": "我不知道该怎么办不知道从哪里开始错了"
    },
    {
      "time": 143.43,
      "time_str": "02:23.430",
      "text": "이사랑을 피해야 하는데",
      "translation": "想着应该要避开这段感情"
    },
    {
      "time": 147.93,
      "time_str": "02:27.930",
      "text": "니 모든게 너무 그리워져",
      "translation": "但是你的一切又那么讨人喜欢"
    },
    {
