  "lyrics": [
    {
      "time": 1.16,
      "time_str": "00:01.160",
      "text": "La la la la la la…",
      "translation": "啦……"
    },
    {
      "time": 8.68,
      "time_str": "00:08.680",
      "text": "Mhmm...",
      "translation": "嗯……"
    },
    {
      "time": 10.36,
      "time_str": "00:10.360",
      "text": "You’re the la love of my life",
      "translation": "你是我一生所爱"
    },
    {
      "time": 31.58,
      "time_str": "00:31.580",
      "text": "One way ticket and of life to live",
      "translation": "体验生命的单程票"
    },
    {
      "time": 35.18,
      "time_str": "00:35.180",
      "text": "Pockets full of sunshine",
      "translation": "装满阳光的口袋"
    },
    {
      "time": 36.81,
      "time_str": "00:36.810",
      "text": "Lots of love to give",
      "translation": "可以奉献许许多多的爱"
    },
    {
      "time": 39.17,
      "time_str": "00:39.170",
      "text": "Longing for your kisses",
      "translation": "向往你的吻"
    },
    {
      "time": 40.98,
      "time_str": "00:40.980",
      "text": "Longing for your arms to be holding me.",
      "translation": "期待你用双臂将我环抱"
    },
    {
      "time": 46.44,
      "time_str": "00:46.440",
      "text": "I took the Friday night flight",
      "translation": "乘周五的夜机"
    },
    {
      "time": 48.53,
      "time_str": "00:48.530",
      "text": "Paris here I come",
      "translation": "来到巴黎"
    },
    {
      "time": 50.56,
      "time_str": "00:50.560",
      "text": "Couldn’t live without you",
      "translation": "生活不能没有你相伴"
    },
    {
      "time": 52.33,
      "time_str": "00:52.330",
      "text": "You're the only one",
      "translation": "你是唯一"
    },
    {
      "time": 54.39,
      "time_str": "00:54.390",
      "text": "Got the note you wrote me – know it all by heart",
      "translation": "收到你写给我的留言，明白句句情真意切"
    },
    {
      "time": 58.06,
      "time_str": "00:58.060",
      "text": "Oh nothing’s gonna keep us apart.",
      "translation": "哦，什么也不能把我们分开"
    },
    {
      "time": 61.6,
      "time_str": "01:01.600",
      "text": "There is only...",
      "translation": "只有……"
    },
    {
      "time": 62.34,
      "time_str": "01:02.340",
      "text": "La la love on my mind,",
      "translation": "爱在我心中"
    },
    {
      "time": 65.15,
      "time_str": "01:05.150",
      "text": "Gonna leave my la la love on the line,",
      "translation": "将要离开我的爱人，登上飞机"
    },
    {
      "time": 68.83,
      "time_str": "01:08.830",
      "text": "Baby just surrender, you’ll be la lucky tonight.",
      "translation": "宝贝，放纵一下，今夜你会走运的"
    },
    {
      "time": 76.8,
      "time_str": "01:16.800",
      "text": "Looking out for ooh la la la l’amour",
      "translation": "寻找真爱"
    },
    {
      "time": 80.46,
      "time_str": "01:20.460",
      "text": "And I’m gonna la la love you toujours.",
      "translation": "我将永远爱你"
    },
    {
      "time": 84.31,
      "time_str": "01:24.310",
      "text": "There’s no doubt about it,",
      "translation": "这毫无疑问"
    },
    {
      "time": 87.04,
      "time_str": "01:27.040",
      "text": "You’re the la love of my life.",
      "translation": "你是我一生所爱"
    },
    {
      "time": 92.94,
      "time_str": "01:32.940",
      "text": "Don’t care about my suitcase,",
      "translation": "别管我的旅行箱"
    },
    {
      "time": 94.65,
      "time_str": "01:34.650",
      "text": "Gonna grab a cab,",
      "translation": "去叫辆计程车"
    },
    {
      "time": 96.62,
      "time_str": "01:36.620",
      "text": "Let your arms unfold me",
      "translation": "向我展开你的双臂"
    },
    {
      "time": 98.5,
      "time_str": "01:38.500",
      "text": "Give you all I have",
      "translation": "给你我的全部"
    },
    {
      "time": 100.56,
      "time_str": "01:40.560",
      "text": "Boy you got me dreamin’",
      "translation": "小子，你让我朝思暮想"
    },
    {
      "time": 102.28,
      "time_str": "01:42.280",
      "text": "You’re a kiss away",
      "translation": "你是离别的一吻"
    },
    {
      "time": 104.3,
      "time_str": "01:44.300",
      "text": "In your arms I’m going to stay",
      "translation": "在你怀里我不想离开"
    },
