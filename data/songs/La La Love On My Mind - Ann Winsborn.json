{
  "title": "La La Love On My Mind",
  "title_raw": "La La Love On My Mind",
  "version": null,
  "artist": "Ann Winsborn",
  "group_key": "la la love on my mind|ann winsborn",
  "writers": {
    "lyricist": "Ingela Forsman/Bobby Ljunggren",
