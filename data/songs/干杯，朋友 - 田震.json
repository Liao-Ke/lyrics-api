  "lyrics": [
    {
      "time": 20.999,
      "time_str": "00:20.999",
      "text": "朋友你今天就要远走，干了这杯酒",
      "translation": null
    },
    {
      "time": 29.999,
      "time_str": "00:29.999",
      "text": "忘掉那天涯孤旅的愁，一醉到天尽头",
      "translation": null
    },
    {
      "time": 39.999,
      "time_str": "00:39.999",
      "text": "也许你从今开始的漂流再没有停下的时候",
      "translation": null
    },
    {
      "time": 49.999,
      "time_str": "00:49.999",
      "text": "让我们一起举起这杯酒，干杯啊朋友",
      "translation": null
    },
    {
      "time": 79.999,
      "time_str": "01:19.999",
      "text": "朋友你今天就要远走，干了这杯酒",
      "translation": null
    },
    {
      "time": 89.999,
      "time_str": "01:29.999",
      "text": "天空是蔚蓝的自由，你渴望着拥有",
      "translation": null
    },
    {
      "time": 99.999,
      "time_str": "01:39.999",
      "text": "但愿那无拘无束的日子将不再是一种奢求",
      "translation": null
    },
    {
      "time": 109.999,
      "time_str": "01:49.999",
      "text": "让我们再次举起这杯酒，干杯啊朋友",
      "translation": null
    },
    {
      "time": 139.999,
      "time_str": "02:19.999",
      "text": "朋友你今天就要远走，干了这杯酒",
      "translation": null
    },
    {
      "time": 149.999,
      "time_str": "02:29.999",
      "text": "绿绿的原野没有尽头，像儿时的眼眸",
      "translation": null
    },
    {
      "time": 159.999,
      "time_str": "02:39.999",
      "text": "想着你还要四处去漂流只为能被自己左右",
      "translation": null
    },
    {
      "time": 169.999,
      "time_str": "02:49.999",
      "text": "忽然间再也忍不住泪流，干杯啊朋友",
      "translation": null
    },
    {
      "time": 179.999,
      "time_str": "02:59.999",
      "text": "干杯，朋友",
      "translation": null
    },
    {
      "time": 185.999,
      "time_str": "03:05.999",
      "text": "干杯，朋友",
      "translation": null
    }
  ],
