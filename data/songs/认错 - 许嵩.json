  "lyrics": [
    {
      "time": 23.11,
      "time_str": "00:23.110",
      "text": "那天午后 我站在你家门口",
      "translation": null
    },
    {
      "time": 28.83,
      "time_str": "00:28.830",
      "text": "你咬咬嘴唇还是说出了分手",
      "translation": null
    },
    {
      "time": 34.84,
      "time_str": "00:34.840",
      "text": "我的挽留和眼泪全都没有用",
      "translation": null
    },
    {
      "time": 40.87,
      "time_str": "00:40.870",
      "text": "或许我应该自食这苦果",
      "translation": null
    },
    {
      "time": 46.38,
      "time_str": "00:46.380",
      "text": "你的迁就 我一直领悟不够",
      "translation": null
    },
    {
      "time": 51.44,
      "time_str": "00:51.440",
      "text": "以为爱已强大的不要理由",
      "translation": null
    },
    {
      "time": 57.15,
      "time_str": "00:57.150",
      "text": "心开始颤抖 明白了你的难受",
      "translation": null
    },
    {
      "time": 63.41,
      "time_str": "01:03.410",
      "text": "但你的表情已经冷漠",
      "translation": null
    },
    {
      "time": 68.32,
      "time_str": "01:08.320",
      "text": "全是我的错",
      "translation": null
    },
    {
      "time": 71.16,
      "time_str": "01:11.160",
      "text": "现在认错有没有用",
      "translation": null
    },
    {
      "time": 74.74,
      "time_str": "01:14.740",
      "text": "你说你已经不再爱我",
      "translation": null
    },
    {
      "time": 79.6,
      "time_str": "01:19.600",
      "text": "我带你回忆曾经快乐的时空",
      "translation": null
    },
    {
      "time": 86.02,
      "time_str": "01:26.020",
      "text": "你只是劝我别再执着",
      "translation": null
    },
    {
      "time": 90.8,
      "time_str": "01:30.800",
      "text": "全是我的错",
      "translation": null
    },
    {
      "time": 93.76,
      "time_str": "01:33.760",
      "text": "现在认错有没有用",
      "translation": null
    },
    {
      "time": 97.21,
      "time_str": "01:37.210",
      "text": "你说你喜欢如今的生活",
      "translation": null
    },
    {
      "time": 102.21,
      "time_str": "01:42.210",
      "text": "你带我回忆爱里互相的折磨",
      "translation": null
    },
    {
      "time": 108.65,
      "time_str": "01:48.650",
      "text": "还告诉了我 别再来认错 认结果",
