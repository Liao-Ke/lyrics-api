  "lyrics": [
    {
      "time": 59.06,
      "time_str": "00:59.060",
      "text": "In my dreams",
      "translation": "我的梦里"
    },
    {
      "time": 61.01,
      "time_str": "01:01.010",
      "text": "I feel your light",
      "translation": "有你的光芒"
    },
    {
      "time": 62.85,
      "time_str": "01:02.850",
      "text": "I feel love is born again",
      "translation": "爱再次绽放"
    },
    {
      "time": 66.67,
      "time_str": "01:06.670",
      "text": "Fireflies",
      "translation": "萤火虫"
    },
    {
      "time": 68.56,
      "time_str": "01:08.560",
      "text": "In the moonlight",
      "translation": "在月光里"
    },
    {
      "time": 70.73,
      "time_str": "01:10.730",
      "text": "Rising stars",
      "translation": "如闪烁的繁星"
    },
    {
      "time": 73.92,
      "time_str": "01:13.920",
      "text": "Remember",
      "translation": "还记得吗"
    },
    {
      "time": 76.48,
      "time_str": "01:16.480",
      "text": "The day",
      "translation": "在那一天"
    },
    {
      "time": 78.36,
      "time_str": "01:18.360",
      "text": "I fell in love with you",
      "translation": "我迷恋上了你"
    },
    {
      "time": 81.53,
      "time_str": "01:21.530",
      "text": "Darling won't you break",
      "translation": "亲爱的，请不要伤害"
    },
    {
      "time": 85.46,
      "time_str": "01:25.460",
      "text": "My heart",
      "translation": "我的心"
    },
    {
      "time": 89.47,
      "time_str": "01:29.470",
      "text": "Take my hand now",
      "translation": "抓紧我的手"
    },
    {
      "time": 91.35,
      "time_str": "01:31.350",
      "text": "Stay close to me",
      "translation": "靠近我的心"
    },
    {
      "time": 93.12,
      "time_str": "01:33.120",
      "text": "be my lover",
      "translation": "成为我爱人"
    },
    {
      "time": 95.15,
      "time_str": "01:35.150",
      "text": "Won't you let me go",
      "translation": "不要放开我的手"
    },
    {
      "time": 96.89,
      "time_str": "01:36.890",
      "text": "close your eyes now",
      "translation": "闭上你的眼睛"
    },
    {
      "time": 98.78,
      "time_str": "01:38.780",
      "text": "And you will see",
      "translation": "你将会看到"
    },
    {
      "time": 101.12,
      "time_str": "01:41.120",
      "text": "There's a rainbow",
      "translation": "有道彩虹"
    },
    {
      "time": 102.56,
      "time_str": "01:42.560",
      "text": "For you and me",
      "translation": "连接你我的心"
    },
    {
      "time": 119.22,
      "time_str": "01:59.220",
      "text": "As I wake up",
      "translation": "当我醒来"
    },
    {
      "time": 120.85,
      "time_str": "02:00.850",
      "text": "I see your face",
      "translation": "看到你的脸"
    },
    {
