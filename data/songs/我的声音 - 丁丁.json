  "lyrics": [
    {
      "time": 11.2,
      "time_str": "00:11.200",
      "text": "几人听得懂",
      "translation": null
    },
    {
      "time": 12.4,
      "time_str": "00:12.400",
      "text": "几人跟着起哄",
      "translation": null
    },
    {
      "time": 13.76,
      "time_str": "00:13.760",
      "text": "几人漫不经意地做着观众",
      "translation": null
    },
    {
      "time": 16.62,
      "time_str": "00:16.620",
      "text": "几人看得通",
      "translation": null
    },
    {
      "time": 17.8,
      "time_str": "00:17.800",
      "text": "几人怕梦一醒就落空",
      "translation": null
    },
    {
      "time": 22.34,
      "time_str": "00:22.340",
      "text": "谁（此刻）在想",
      "translation": null
    },
    {
      "time": 23.32,
      "time_str": "00:23.320",
      "text": "谁止不住疯狂",
      "translation": null
    },
    {
      "time": 24.61,
      "time_str": "00:24.610",
      "text": "谁每一句话都能说得漂亮",
      "translation": null
    },
    {
      "time": 27.41,
      "time_str": "00:27.410",
      "text": "谁不会隐藏",
      "translation": null
    },
    {
      "time": 28.68,
      "time_str": "00:28.680",
      "text": "谁又不小心丢了梦想",
      "translation": null
    },
    {
      "time": 33.24,
      "time_str": "00:33.240",
      "text": "我只有我的声音",
      "translation": null
    },
    {
      "time": 38.36,
      "time_str": "00:38.360",
      "text": "随你听没有听",
      "translation": null
    },
    {
      "time": 40.99,
      "time_str": "00:40.990",
      "text": "随你闭上眼睛",
      "translation": null
    },
    {
      "time": 45.54,
      "time_str": "00:45.540",
      "text": "Marvelous Song",
      "translation": null
    },
    {
      "time": 46.52,
      "time_str": "00:46.520",
      "text": "站在世界中央",
      "translation": null
    },
    {
      "time": 47.85,
      "time_str": "00:47.850",
      "text": "听见传来呼喊的声音正在不停地响",
      "translation": null
    },
    {
      "time": 50.93,
      "time_str": "00:50.930",
      "text": "Marvelous Song",
      "translation": null
    },
    {
      "time": 51.9,
      "time_str": "00:51.900",
      "text": "那心中澎湃起的浪",
      "translation": null
    },
    {
      "time": 56.42,
      "time_str": "00:56.420",
      "text": "Marvelous Song",
      "translation": null
    },
    {
      "time": 57.42,
      "time_str": "00:57.420",
      "text": "沉在其中狂想",
      "translation": null
    },
    {
      "time": 58.74,
      "time_str": "00:58.740",
      "text": "让你看到我最爱不停大声唱的模样",
      "translation": null
    },
    {
      "time": 61.78,
      "time_str": "01:01.780",
      "text": "Marvelous Song",
