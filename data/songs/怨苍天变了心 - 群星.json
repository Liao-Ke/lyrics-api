  "lyrics": [
    {
      "time": 24.29,
      "time_str": "00:24.290",
      "text": "如果让我遇见你而你正当年轻",
      "translation": null
    },
    {
      "time": 29.2,
      "time_str": "00:29.200",
      "text": "用最真的心换你最深的情",
      "translation": null
    },
    {
      "time": 36.85,
      "time_str": "00:36.850",
      "text": "如果让我遇见你而我依然年轻",
      "translation": null
    },
    {
      "time": 41.67,
      "time_str": "00:41.670",
      "text": "也相信永恒是不变的曾经",
      "translation": null
    },
    {
      "time": 48.47,
      "time_str": "00:48.470",
      "text": "如果让我离开你而你已能平静",
      "translation": null
    },
    {
      "time": 53.42,
      "time_str": "00:53.420",
      "text": "只愿你放心也不要你担心",
      "translation": null
    },
    {
      "time": 60.18,
      "time_str": "01:00.180",
      "text": "如果让你离开我假装我也平静",
      "translation": null
    },
    {
      "time": 65.06,
      "time_str": "01:05.060",
      "text": "就算是伤心也当作是无心",
      "translation": null
    },
    {
      "time": 73.17,
      "time_str": "01:13.170",
      "text": "时空阻隔岂止长路迢迢",
      "translation": null
    },
    {
      "time": 77.69,
      "time_str": "01:17.690",
      "text": "情丝缠绕岂是长发飘飘",
      "translation": null
    },
    {
      "time": 82.32,
      "time_str": "01:22.320",
      "text": "那红尘俗世的人为什么总是多情惹烦恼",
      "translation": null
    },
    {
      "time": 94.58,
      "time_str": "01:34.580",
      "text": "本是云该化作雨投入海的胸襟",
      "translation": null
    },
    {
      "time": 99.54,
      "time_str": "01:39.540",
      "text": "却含着泪水任孤独的飘零",
      "translation": null
    },
    {
      "time": 106.3,
      "time_str": "01:46.300",
      "text": "本是属于我的你同把人生看尽",
      "translation": null
    },
    {
      "time": 111.1,
      "time_str": "01:51.100",
      "text": "却无缘再聚怨苍天变了心",
