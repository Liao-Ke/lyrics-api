  "lyrics": [
    {
      "time": 36.58,
      "time_str": "00:36.580",
      "text": "雨后落下一地的忧伤",
      "translation": null
    },
    {
      "time": 40.25,
      "time_str": "00:40.250",
      "text": "溶化偷偷想你的伪装",
      "translation": null
    },
    {
      "time": 44.23,
      "time_str": "00:44.230",
      "text": "落叶排成思念的形状",
      "translation": null
    },
    {
      "time": 48.06,
      "time_str": "00:48.060",
      "text": "我撑着伞 不去看",
      "translation": null
    },
    {
      "time": 52.28,
      "time_str": "00:52.280",
      "text": "樱花飘落背后的优雅",
      "translation": null
    },
    {
      "time": 56.27,
      "time_str": "00:56.270",
      "text": "藏着一句说不出的话",
      "translation": null
    },
    {
      "time": 60.23,
      "time_str": "01:00.230",
      "text": "窗外吹着无语的牵挂",
      "translation": null
    },
    {
      "time": 64.06,
      "time_str": "01:04.060",
      "text": "轻轻吹动 我头发",
      "translation": null
    },
    {
      "time": 68.26,
      "time_str": "01:08.260",
      "text": "如此的爱你 花刺痛的伤",
      "translation": null
    },
    {
      "time": 73.77,
      "time_str": "01:13.770",
      "text": "我不想抵抗 该要如何学会隐藏",
      "translation": null
    },
    {
      "time": 79.81,
      "time_str": "01:19.810",
      "text": "傻傻的 微笑表情却无法言语",
      "translation": null
    },
    {
      "time": 83.72,
      "time_str": "01:23.720",
      "text": "偷偷的 像是记忆里幸福的相机",
      "translation": null
    },
    {
      "time": 87.67,
      "time_str": "01:27.670",
      "text": "轻轻的 呼吸身边有你的空气",
      "translation": null
    },
    {
      "time": 91.72,
      "time_str": "01:31.720",
      "text": "我还记得你 说樱花很美丽",
      "translation": null
    },
    {
      "time": 95.74,
      "time_str": "01:35.740",
      "text": "不愿意 再轻易从你身边离去",
      "translation": null
    },
    {
      "time": 99.67,
      "time_str": "01:39.670",
      "text": "不忘记 写下樱花飘落的那场雨",
      "translation": null
    },
    {
      "time": 103.67,
      "time_str": "01:43.670",
      "text": "不放弃 心中刻下了永远爱你",
      "translation": null
    },
    {
      "time": 107.64,
      "time_str": "01:47.640",
      "text": "你说我和你 都为了此刻 着迷",
      "translation": null
    },
