  "lyrics": [
    {
      "time": 26.97,
      "time_str": "00:26.970",
      "text": "谁在乎我的心里有多苦",
      "translation": null
    },
    {
      "time": 34.9,
      "time_str": "00:34.900",
      "text": "谁在意我的明天去何处",
      "translation": null
    },
    {
      "time": 40.96,
      "time_str": "00:40.960",
      "text": "这条路究竟多少崎岖多少坎坷途",
      "translation": null
    },
    {
      "time": 48.43,
      "time_str": "00:48.430",
      "text": "我和你早已没有回头路",
      "translation": null
    },
    {
      "time": 55.58,
      "time_str": "00:55.580",
      "text": "我的爱藏不住",
      "translation": null
    },
    {
      "time": 59.8,
      "time_str": "00:59.800",
      "text": "任凭世界无情的摆布",
      "translation": null
    },
    {
      "time": 62.55,
      "time_str": "01:02.550",
      "text": "我不怕痛不怕输",
      "translation": null
    },
    {
      "time": 65.97,
      "time_str": "01:05.970",
      "text": "只怕是再多努力也无助",
      "translation": null
    },
    {
      "time": 71.67,
      "time_str": "01:11.670",
      "text": "如果说一切都是天意一切都是命运",
      "translation": null
    },
    {
      "time": 76.15,
      "time_str": "01:16.150",
      "text": "终究已注定",
      "translation": null
    },
    {
      "time": 79.2,
      "time_str": "01:19.200",
      "text": "是否能再多爱一天能再多看一眼",
      "translation": null
    },
    {
      "time": 82.989,
      "time_str": "01:22.989",
      "text": "伤会少一点",
      "translation": null
    },
    {
      "time": 85.42,
      "time_str": "01:25.420",
      "text": "如果说一切都是天意一切都是命运",
      "translation": null
    },
    {
      "time": 90.27,
      "time_str": "01:30.270",
      "text": "谁也逃不离",
      "translation": null
    },
    {
      "time": 93.85,
      "time_str": "01:33.850",
      "text": "无情无爱此生又何必",
      "translation": null
