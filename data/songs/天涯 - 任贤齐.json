  "lyrics": [
    {
      "time": 43.01,
      "time_str": "00:43.010",
      "text": "昏天又暗地 忍不住的流星",
      "translation": null
    },
    {
      "time": 46.25,
      "time_str": "00:46.250",
      "text": "烫不伤被冷藏一颗死心",
      "translation": null
    },
    {
      "time": 49.81,
      "time_str": "00:49.810",
      "text": "苦苦的追寻 茫茫然失去",
      "translation": null
    },
    {
      "time": 53.38,
      "time_str": "00:53.380",
      "text": "可爱的 可恨的 多可惜",
      "translation": null
    },
    {
      "time": 56.88,
      "time_str": "00:56.880",
      "text": "梦中的梦中 梦中人的梦中",
      "translation": null
    },
    {
      "time": 60.52,
      "time_str": "01:00.520",
      "text": "梦不到被吹散往事如风",
      "translation": null
    },
    {
      "time": 63.99,
      "time_str": "01:03.990",
      "text": "空空的天空 容不下笑容",
      "translation": null
    },
    {
      "time": 67.54,
      "time_str": "01:07.540",
      "text": "伤神的 伤人的 太伤心",
      "translation": null
    },
    {
      "time": 71.07,
      "time_str": "01:11.070",
      "text": "何必想 何必问 何处是我家",
      "translation": null
    },
    {
      "time": 74.7,
      "time_str": "01:14.700",
      "text": "爱也罢 恨也罢 算了吧",
      "translation": null
    },
    {
      "time": 78.25,
      "time_str": "01:18.250",
      "text": "问天涯 望断了天涯",
      "translation": null
    },
    {
      "time": 81.75,
      "time_str": "01:21.750",
      "text": "赢得了天下 输了她",
      "translation": null
    },
    {
      "time": 85.25,
      "time_str": "01:25.250",
      "text": "挥别的种种 挥不去的种种",
      "translation": null
    },
    {
      "time": 88.88,
      "time_str": "01:28.880",
      "text": "毁不了被掩没一往情深",
      "translation": null
    },
    {
      "time": 92.36,
      "time_str": "01:32.360",
      "text": "忍已无可忍 恨不得别人",
      "translation": null
    },
    {
      "time": 95.93,
      "time_str": "01:35.930",
      "text": "害人的 迷人的 痴情人",
      "translation": null
    },
    {
      "time": 99.54,
      "time_str": "01:39.540",
      "text": "也挣扎 也牵挂 也不是办法",
      "translation": null
    },
    {
      "time": 103.12,
      "time_str": "01:43.120",
      "text": "走也罢 留也罢 错了吗",
      "translation": null
    },
    {
      "time": 106.58,
      "time_str": "01:46.580",
      "text": "今天涯 明天又天涯",
      "translation": null
    },
    {
      "time": 110.27,
      "time_str": "01:50.270",
      "text": "狠狠一巴掌忘了吧",
      "translation": null
    },
    {
