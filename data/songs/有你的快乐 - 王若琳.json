    {
      "time": 9.44,
      "time_str": "00:09.440",
      "text": "我怎么都不想睡",
      "translation": null
    },
    {
      "time": 13.42,
      "time_str": "00:13.420",
      "text": "天特别亮 夜特别的黑",
      "translation": null
    },
    {
      "time": 17.63,
      "time_str": "00:17.630",
      "text": "当我深深的呼吸",
      "translation": null
    },
    {
      "time": 21.96,
      "time_str": "00:21.960",
      "text": "心中充满想你的甜蜜",
      "translation": null
    },
    {
      "time": 28.53,
      "time_str": "00:28.530",
      "text": "想和你走在雨中",
      "translation": null
    },
    {
      "time": 30.95,
      "time_str": "00:30.950",
      "text": "想要你牵我的手",
      "translation": null
    },
    {
      "time": 33.07,
      "time_str": "00:33.070",
      "text": "傻傻的你不敢说爱",
      "translation": null
    },
    {
      "time": 37.64,
      "time_str": "00:37.640",
      "text": "而我也故意要你为我等待",
      "translation": null
    },
    {
      "time": 45.79,
      "time_str": "00:45.790",
      "text": "说不出有多么快乐",
      "translation": null
    },
    {
      "time": 48.86,
      "time_str": "00:48.860",
      "text": "还是不够 这感觉这一切",
      "translation": null
    },
    {
      "time": 54.07,
      "time_str": "00:54.070",
      "text": "就好像飘在外太空",
      "translation": null
    },
    {
      "time": 57.28,
      "time_str": "00:57.280",
      "text": "别的星球 只有我们存在",
      "translation": null
    },
    {
      "time": 64.89,
      "time_str": "01:04.890",
      "text": "喜欢和你在一起",
      "translation": null
    },
    {
      "time": 69.1,
      "time_str": "01:09.100",
      "text": "无聊的生命也变有趣",
      "translation": null
    },
    {
      "time": 73.27,
      "time_str": "01:13.270",
      "text": "让你听我的音乐",
      "translation": null
    },
    {
      "time": 77.67,
      "time_str": "01:17.670",
      "text": "分享在每一刻的心情",
      "translation": null
