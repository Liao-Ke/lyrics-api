  "lyrics": [
    {
      "time": 26.67,
      "time_str": "00:26.670",
      "text": "总是向你索取",
      "translation": null
    },
    {
      "time": 28.94,
      "time_str": "00:28.940",
      "text": "却不曾说谢谢你",
      "translation": null
    },
    {
      "time": 33.08,
      "time_str": "00:33.080",
      "text": "直到长大以后",
      "translation": null
    },
    {
      "time": 35.5,
      "time_str": "00:35.500",
      "text": "才懂得你不容易",
      "translation": null
    },
    {
      "time": 39.87,
      "time_str": "00:39.870",
      "text": "每次离开总是",
      "translation": null
    },
    {
      "time": 42.09,
      "time_str": "00:42.090",
      "text": "装做轻松的样子",
      "translation": null
    },
    {
      "time": 45.92,
      "time_str": "00:45.920",
      "text": "微笑着说回去吧",
      "translation": null
    },
    {
      "time": 49.3,
      "time_str": "00:49.300",
      "text": "转身泪湿眼底",
      "translation": null
    },
    {
      "time": 52.38,
      "time_str": "00:52.380",
      "text": "多想和从前一样",
      "translation": null
    },
    {
      "time": 55.87,
      "time_str": "00:55.870",
      "text": "牵你温暖手掌",
      "translation": null
    },
    {
      "time": 58.55,
      "time_str": "00:58.550",
      "text": "可是你不在我身旁",
      "translation": null
    },
    {
      "time": 62.44,
      "time_str": "01:02.440",
      "text": "托清风捎去安康",
      "translation": null
    },
    {
      "time": 68.67,
      "time_str": "01:08.670",
      "text": "时光时光慢些吧",
      "translation": null
    },
    {
      "time": 71.95,
      "time_str": "01:11.950",
      "text": "不要再让你变老了",
      "translation": null
    },
    {
      "time": 75.33,
      "time_str": "01:15.330",
      "text": "我愿用我一切",
      "translation": null
    },
    {
      "time": 77.35,
      "time_str": "01:17.350",
      "text": "换你岁月长留",
      "translation": null
    },
    {
      "time": 82.01,
      "time_str": "01:22.010",
      "text": "一生要强的爸爸",
      "translation": null
    },
    {
      "time": 85.24,
      "time_str": "01:25.240",
      "text": "我能为你做些什么",
      "translation": null
    },
    {
      "time": 88.52,
      "time_str": "01:28.520",
      "text": "微不足道的关心收下吧",
      "translation": null
    },
    {
      "time": 94.98,
      "time_str": "01:34.980",
      "text": "谢谢你做的一切",
      "translation": null
    },
    {
      "time": 98.37,
      "time_str": "01:38.370",
      "text": "双手撑起我们的家",
      "translation": null
    },
    {
      "time": 101.65,
      "time_str": "01:41.650",
      "text": "总是竭尽所有",
      "translation": null
    },
    {
      "time": 103.72,
      "time_str": "01:43.720",
      "text": "把最好的给我",
      "translation": null
    },
    {
      "time": 107.96,
      "time_str": "01:47.960",
      "text": "我是你的骄傲吗",
      "translation": null
    },
    {
      "time": 111.45,
      "time_str": "01:51.450",
      "text": "还在为我而担心吗",
      "translation": null
    },
    {
      "time": 114.79,
      "time_str": "01:54.790",
      "text": "你牵挂的孩子啊",
      "translation": null
