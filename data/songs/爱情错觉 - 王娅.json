    {
      "time": 19.4,
      "time_str": "00:19.400",
      "text": "看窗外的世界 繁华喧闹的夜",
      "translation": null
    },
    {
      "time": 23.5,
      "time_str": "00:23.500",
      "text": "孤单身影随风在空中摇摇坠跌",
      "translation": null
    },
    {
      "time": 28.37,
      "time_str": "00:28.370",
      "text": "秋风萧瑟凛冽 满天飞舞风雪",
      "translation": null
    },
    {
      "time": 34.4,
      "time_str": "00:34.400",
      "text": "因为你的出现打破所有的一切",
      "translation": null
    },
    {
      "time": 38.198,
      "time_str": "00:38.198",
      "text": "月儿阴晴圆缺照着疲惫黑夜",
      "translation": null
    },
    {
      "time": 42.778,
      "time_str": "00:42.778",
      "text": "人来人往拼命追逐未知的一切",
      "translation": null
    },
    {
      "time": 47.558,
      "time_str": "00:47.558",
      "text": "穿梭从前的街 感觉如此强烈",
      "translation": null
    },
    {
      "time": 52.308,
      "time_str": "00:52.308",
      "text": "你会和我回到那个记忆的年月",
      "translation": null
    },
    {
      "time": 57.007,
      "time_str": "00:57.007",
      "text": "我的爱没了解 你在哪一个世界",
      "translation": null
    },
    {
      "time": 61.534,
      "time_str": "01:01.534",
      "text": "如果当初没拒绝何苦不辞而别",
      "translation": null
    },
    {
      "time": 66.361,
      "time_str": "01:06.361",
      "text": "我若坚定一些不曾将你忽略",
      "translation": null
    },
    {
      "time": 71.489,
      "time_str": "01:11.489",
