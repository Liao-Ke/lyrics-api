{
  "title": "不分手的恋爱",
  "title_raw": "不分手的恋爱",
  "version": null,
  "artist": "汪苏泷",
  "group_key": "不分手的恋爱|汪苏泷",
  "writers": {
    "lyricist": "汪苏泷",
    "composer": "汪苏泷",
    "arranger": "汪苏泷"
  },
  "lyrics": [
    {
      "time": 25.9,
      "time_str": "00:25.900",
      "text": "不知不觉不问 不痛不痒",
      "translation": null
    },
    {
      "time": 29.16,
      "time_str": "00:29.160",
      "text": "多少的时光",
      "translation": null
    },
    {
      "time": 31.6,
      "time_str": "00:31.600",
      "text": "不确定的某个 夜晚小巷",
      "translation": null
    },
    {
      "time": 34.68,
      "time_str": "00:34.680",
      "text": "泪悄悄流淌",
      "translation": null
    },
    {
      "time": 37.16,
      "time_str": "00:37.160",
      "text": "街边天气微凉 淡淡月光",
      "translation": null
    },
    {
      "time": 40.5,
      "time_str": "00:40.500",
      "text": "我沿路哼唱",
      "translation": null
    },
    {
      "time": 42.85,
      "time_str": "00:42.850",
      "text": "找寻我们一直 找不到的",
      "translation": null
    },
    {
      "time": 46.0,
      "time_str": "00:46.000",
      "text": "缘分被捆绑",
      "translation": null
    },
    {
      "time": 48.15,
      "time_str": "00:48.150",
      "text": "感觉不到你为我坚强",
      "translation": null
    },
    {
      "time": 50.84,
      "time_str": "00:50.840",
      "text": "感觉得到你对我说谎",
      "translation": null
    },
    {
      "time": 53.99,
      "time_str": "00:53.990",
      "text": "我安静听着肖邦",
      "translation": null
    },
    {
      "time": 55.78,
      "time_str": "00:55.780",
      "text": "用维也纳忧伤",
      "translation": null
    },
    {
      "time": 59.33,
      "time_str": "00:59.330",
      "text": "你的爱被埋葬 恨被收藏",
      "translation": null
    },
    {
      "time": 63.03,
      "time_str": "01:03.030",
      "text": "痛应该原谅",
      "translation": null
    },
    {
      "time": 64.87,
      "time_str": "01:04.870",
      "text": "我的爱不用讲 恨不用想",
      "translation": null
    },
    {
      "time": 68.41,
      "time_str": "01:08.410",
      "text": "思念在发烫",
      "translation": null
    },
    {
      "time": 70.5,
      "time_str": "01:10.500",
      "text": "看着你的脸庞 背着行囊",
      "translation": null
    },
    {
      "time": 74.05,
      "time_str": "01:14.050",
      "text": "说要去远方",
      "translation": null
    },
    {
      "time": 76.25,
      "time_str": "01:16.250",
      "text": "谁还记得那年我拉着你说",
      "translation": null
    },
    {
      "time": 81.16,
      "time_str": "01:21.160",
      "text": "爱永远一样",
      "translation": null
    },
    {
      "time": 82.53,
      "time_str": "01:22.530",
      "text": "我也搞不懂为什么那么多真心相爱",
      "translation": null
    },
    {
      "time": 85.03,
      "time_str": "01:25.030",
      "text": "到最后 都会变成两个人分开的无奈",
      "translation": null
    },
    {
      "time": 87.78,
      "time_str": "01:27.780",
      "text": "当初我们说过要谈一场永远不分手的恋爱",
      "translation": null
    },
    {
      "time": 91.22,
      "time_str": "01:31.220",
      "text": "是否今天这句话竟变成我们之间的阻碍",
      "translation": null
    },
    {
      "time": 93.82,
      "time_str": "01:33.820",
      "text": "不想太多 不想太多 也许会明白的更多",
      "translation": null
    },
    {
      "time": 96.62,
      "time_str": "01:36.620",
      "text": "不想再说 不想再说 就让我们彼此沉默",
      "translation": null
    },
    {
      "time": 99.41,
      "time_str": "01:39.410",
      "text": "现在我们终于明白 结局却也无法更改",
      "translation": null
    },
    {
      "time": 102.26,
      "time_str": "01:42.260",
      "text": "这场不分手的恋爱 我想结局注定失败",
      "translation": null
    },
    {
