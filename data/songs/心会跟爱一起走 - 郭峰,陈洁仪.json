    {
      "time": 28.63,
      "time_str": "00:28.630",
      "text": "（女）从来没有人如此贴近我的心",
      "translation": null
    },
    {
      "time": 36.11,
      "time_str": "00:36.110",
      "text": "总有许多许多话想说给你听",
      "translation": null
    },
    {
      "time": 43.09,
      "time_str": "00:43.090",
      "text": "（男）从来没有人如此打动我的心",
      "translation": null
    },
    {
      "time": 50.08,
      "time_str": "00:50.080",
      "text": "偶尔无心的伤害全都为了爱",
      "translation": null
    },
    {
      "time": 58.75,
      "time_str": "00:58.750",
      "text": "（合）心会跟爱一起走 说好不回头",
      "translation": null
    },
    {
      "time": 65.8,
      "time_str": "01:05.800",
      "text": "桑田都变成沧海 谁来成全爱",
      "translation": null
    },
    {
      "time": 72.78,
      "time_str": "01:12.780",
      "text": "心会跟爱一起走 说好不分手",
      "translation": null
    },
    {
      "time": 79.8,
      "time_str": "01:19.800",
      "text": "春风都化成秋雨 爱就爱到底",
      "translation": null
    },
    {
      "time": 88.57,
      "time_str": "01:28.570",
      "text": "（女）也许一切太完美 感觉像在飞",
      "translation": null
    },
    {
      "time": 95.55,
      "time_str": "01:35.550",
      "text": "原来快乐的感觉 也可以有泪",
      "translation": null
    },
    {
      "time": 102.58,
      "time_str": "01:42.580",
      "text": "（男）所有的人都沉默 除了你和我",
      "translation": null
    },
    {
      "time": 109.51,
      "time_str": "01:49.510",
      "text": "只要星星会出现 我的爱不变",
      "translation": null
    },
    {
