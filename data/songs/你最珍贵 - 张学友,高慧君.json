    {
      "time": 34.422,
      "time_str": "00:34.422",
      "text": "(男) 明年这个时间",
      "translation": null
    },
    {
      "time": 39.524,
      "time_str": "00:39.524",
      "text": "约在这个地点",
      "translation": null
    },
    {
      "time": 44.615,
      "time_str": "00:44.615",
      "text": "(女) 记得带着玫瑰",
      "translation": null
    },
    {
      "time": 49.077,
      "time_str": "00:49.077",
      "text": "打上领带系上思念",
      "translation": null
    },
    {
      "time": 54.846,
      "time_str": "00:54.846",
      "text": "(男) 动情时刻最美",
      "translation": null
    },
    {
      "time": 59.907,
      "time_str": "00:59.907",
      "text": "真心的给不累",
      "translation": null
    },
    {
      "time": 65.018,
      "time_str": "01:05.018",
      "text": "(女) 太多的爱怕醉",
      "translation": null
    },
    {
      "time": 68.842,
      "time_str": "01:08.842",
      "text": "没人疼爱",
      "translation": null
    },
    {
      "time": 70.597,
      "time_str": "01:10.597",
      "text": "再美的人也会憔悴",
      "translation": null
    },
    {
      "time": 79.101,
      "time_str": "01:19.101",
      "text": "(男) 我会送你红色玫瑰",
      "translation": null
    },
    {
      "time": 79.101,
      "time_str": "01:19.101",
      "text": "(女) 你知道我爱流泪",
      "translation": null
    },
    {
      "time": 84.429,
      "time_str": "01:24.429",
      "text": "(男) 你别拿一生眼泪相对",
      "translation": null
    },
    {
      "time": 89.524,
      "time_str": "01:29.524",
      "text": "(男) 未来的日子有你才美",
      "translation": null
    },
    {
      "time": 89.524,
      "time_str": "01:29.524",
      "text": "(女) 未来的日子是否很美",
      "translation": null
    },
    {
      "time": 92.783,
      "time_str": "01:32.783",
      "text": "(合) 梦才会真一点",
      "translation": null
    },
    {
      "time": 99.772,
      "time_str": "01:39.772",
      "text": "(女) 我学着在你爱里沉醉",
      "translation": null
    },
    {
      "time": 99.772,
      "time_str": "01:39.772",
      "text": "(男) 我不撤退",
      "translation": null
    },
    {
      "time": 104.844,
      "time_str": "01:44.844",
      "text": "(女) 你守护着我穿过黑夜",
      "translation": null
    },
    {
