  "lyrics": [
    {
      "time": 17.07,
      "time_str": "00:17.070",
      "text": "远方煽风点火，雨夜敬清秋",
      "translation": null
    },
    {
      "time": 25.04,
      "time_str": "00:25.040",
      "text": "树蔓枯竭凋落，微风洒悲奏",
      "translation": null
    },
    {
      "time": 41.38,
      "time_str": "00:41.380",
      "text": "洗净风沙月瘦，慰我心间抬头",
      "translation": null
    },
    {
      "time": 48.75,
      "time_str": "00:48.750",
      "text": "一盏烛火灭愁，清香满面嗅",
      "translation": null
    },
    {
      "time": 57.49,
      "time_str": "00:57.490",
      "text": "萧萧雨中流水漏，雾迷止惑淡去留",
      "translation": null
    },
    {
      "time": 64.629,
      "time_str": "01:04.629",
      "text": "江边冷舟无人舵，失得任魔观焦灼",
      "translation": null
    },
    {
      "time": 81.739,
      "time_str": "01:21.739",
      "text": "中伤不是你的强项",
      "translation": null
    },
    {
      "time": 84.76,
      "time_str": "01:24.760",
      "text": "黑夜看不见你的坚强",
      "translation": null
    },
    {
      "time": 89.049,
      "time_str": "01:29.049",
      "text": "流放变成我的苍凉",
      "translation": null
    },
    {
      "time": 94.459,
      "time_str": "01:34.459",
      "text": "鼓声牵引着谁的心脏",
      "translation": null
    },
    {
      "time": 97.36,
      "time_str": "01:37.360",
      "text": "山高只愿任水流长",
      "translation": null
    },
    {
      "time": 102.688,
      "time_str": "01:42.688",
      "text": "虎面担心自己的内向",
      "translation": null
    },
    {
      "time": 105.65,
      "time_str": "01:45.650",
      "text": "西苑屠宰场的冷汤",
      "translation": null
    },
    {
      "time": 109.328,
      "time_str": "01:49.328",
      "text": "微笑不露声色的张扬",
      "translation": null
    },
    {
      "time": 119.65,
      "time_str": "01:59.650",
      "text": "吻我还吃我，爱我还难过",
      "translation": null
    },
    {
      "time": 127.909,
      "time_str": "02:07.909",
      "text": "痛过也笑过，失落也复活",
      "translation": null
    },
    {
      "time": 135.699,
      "time_str": "02:15.699",
      "text": "或淡薄或贪得，愚钝是沉默",
      "translation": null
    },
    {
      "time": 143.899,
      "time_str": "02:23.899",
      "text": "悔过又呵责，放下去成佛",
      "translation": null
    },
    {
