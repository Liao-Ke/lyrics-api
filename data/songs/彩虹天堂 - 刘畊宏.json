  "lyrics": [
    {
      "time": 28.598,
      "time_str": "00:28.598",
      "text": "我不知不觉 又徘徊在从前",
      "translation": null
    },
    {
      "time": 33.338,
      "time_str": "00:33.338",
      "text": "秋风悄悄的呼唤 听来尽是孤单",
      "translation": null
    },
    {
      "time": 40.229,
      "time_str": "00:40.229",
      "text": "落叶的期盼 片片左右为难",
      "translation": null
    },
    {
      "time": 47.17,
      "time_str": "00:47.170",
      "text": "心走寂寞攀 跟着飘进灰暗",
      "translation": null
    },
    {
      "time": 55.449,
      "time_str": "00:55.449",
      "text": "我不闻不问 也许好过一点",
      "translation": null
    },
    {
      "time": 60.299,
      "time_str": "01:00.299",
      "text": "被遗憾关在房间 挣扎只是拖延",
      "translation": null
    },
    {
      "time": 67.6,
      "time_str": "01:07.600",
      "text": "无望的空谈 一声声的轻叹",
      "translation": null
    },
    {
      "time": 74.9,
      "time_str": "01:14.900",
      "text": "回忆扯不断 怎么摆脱纠缠",
      "translation": null
    },
    {
      "time": 80.93,
      "time_str": "01:20.930",
      "text": "找不到方向 往彩虹天堂",
      "translation": null
    },
    {
      "time": 87.42,
      "time_str": "01:27.420",
      "text": "有你说的爱 在用幸福触摸忧伤",
      "translation": null
    },
    {
      "time": 94.069,
      "time_str": "01:34.069",
      "text": "两个人 相守直到白发苍苍",
      "translation": null
    },
    {
      "time": 100.779,
      "time_str": "01:40.779",
      "text": "自由地飞翔在灿烂的星光",
      "translation": null
    },
    {
