    {
      "time": 16.51,
      "time_str": "00:16.510",
      "text": "I am tied by truth like an anchor",
      "translation": "我被像锚一样沉重的真相困住"
    },
    {
      "time": 25.44,
      "time_str": "00:25.440",
      "text": "Anchored to a bottomless sea",
      "translation": "牢牢地钉在无底的深渊"
    },
    {
      "time": 32.34,
      "time_str": "00:32.340",
      "text": "I am floating freely in the heavens",
      "translation": "我自由自在地游走在天上"
    },
    {
      "time": 41.44,
      "time_str": "00:41.440",
      "text": "Held in by your heart's gravity",
      "translation": "被你深深吸引着"
    },
    {
      "time": 48.92,
      "time_str": "00:48.920",
      "text": "All because of love",
      "translation": "这都是因为爱"
    },
    {
      "time": 53.04,
      "time_str": "00:53.040",
      "text": "All because of love",
      "translation": "这都是因为爱"
    },
    {
      "time": 57.41,
      "time_str": "00:57.410",
      "text": "Even though sometimes",
      "translation": "尽管有时候"
    },
    {
      "time": 59.999,
      "time_str": "00:59.999",
      "text": "You don't know who I am",
      "translation": "你并不知道我是谁"
    },
    {
      "time": 65.239,
      "time_str": "01:05.239",
      "text": "I am you..",
      "translation": "我就是你"
    },
    {
      "time": 69.29,
      "time_str": "01:09.290",
      "text": "Everything you do",
      "translation": "你做的一切"
    },
    {
      "time": 73.168,
      "time_str": "01:13.168",
      "text": "Anything you say,",
      "translation": "你说的任何话语"
    },
    {
      "time": 77.319,
      "time_str": "01:17.319",
      "text": "You want me to be",
      "translation": "你想我成为什么样的人"
    },
    {
      "time": 81.328,
      "time_str": "01:21.328",
      "text": "You and me..",
      "translation": "你和我"
    },
    {
      "time": 85.29,
      "time_str": "01:25.290",
      "text": "We're charms on a chain",
