  "lyrics": [
    {
      "time": 0.33,
      "time_str": "00:00.330",
      "text": "愿晚风心里吹 吹散我的泪",
      "translation": null
    },
    {
      "time": 4.54,
      "time_str": "00:04.540",
      "text": "似风筝把你追",
      "translation": null
    },
    {
      "time": 7.83,
      "time_str": "00:07.830",
      "text": "愿等你一辈子 真情留住你",
      "translation": null
    },
    {
      "time": 11.71,
      "time_str": "00:11.710",
      "text": "梦里归家那一扇灯",
      "translation": null
    },
    {
      "time": 23.31,
      "time_str": "00:23.310",
      "text": "心中所属唯独你",
      "translation": null
    },
    {
      "time": 26.1,
      "time_str": "00:26.100",
      "text": "不管天似海深",
      "translation": null
    },
    {
      "time": 27.81,
      "time_str": "00:27.810",
      "text": "今生再没遗憾",
      "translation": null
    },
    {
      "time": 30.5,
      "time_str": "00:30.500",
      "text": "即使分开仍念记",
      "translation": null
    },
    {
      "time": 33.4,
      "time_str": "00:33.400",
      "text": "伤心得你恻隐",
      "translation": null
    },
    {
      "time": 35.3,
      "time_str": "00:35.300",
      "text": "温馨我这半生",
      "translation": null
    },
    {
      "time": 38.11,
      "time_str": "00:38.110",
      "text": "若某天 风花雪月似金",
      "translation": null
    },
    {
      "time": 41.16,
      "time_str": "00:41.160",
      "text": "我倾心 只等你回来时贴近",
      "translation": null
    },
    {
      "time": 45.21,
      "time_str": "00:45.210",
      "text": "俗世间 江山雨落无尽放任",
      "translation": null
    },
    {
      "time": 48.94,
      "time_str": "00:48.940",
      "text": "与沧海 未尽缘分",
      "translation": null
    },
    {
      "time": 54.9,
      "time_str": "00:54.900",
      "text": "愿晚风将我吹 吹进你心内",
      "translation": null
    },
    {
      "time": 58.67,
      "time_str": "00:58.670",
      "text": "晚灯映花正开",
      "translation": null
    },
    {
      "time": 62.26,
      "time_str": "01:02.260",
      "text": "月映照伤我心 痴情难自禁",
      "translation": null
    },
    {
      "time": 66.15,
      "time_str": "01:06.150",
      "text": "夜半莺歌叹息我孤身",
      "translation": null
    },
    {
      "time": 69.72,
      "time_str": "01:09.720",
      "text": "愿晚风心里吹 吹散我的泪",
      "translation": null
    },
    {
