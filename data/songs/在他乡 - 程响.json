    {
      "time": 0.61,
      "time_str": "00:00.610",
      "text": "出品人 : 潘鸿业",
      "translation": null
    },
    {
      "time": 0.77,
      "time_str": "00:00.770",
      "text": "我多想回到家乡",
      "translation": null
    },
    {
      "time": 3.18,
      "time_str": "00:03.180",
      "text": "再回到她的身旁",
      "translation": null
    },
    {
      "time": 5.87,
      "time_str": "00:05.870",
      "text": "看她的温柔善良",
      "translation": null
    },
    {
      "time": 8.59,
      "time_str": "00:08.590",
      "text": "来抚慰我的心伤",
      "translation": null
    },
    {
      "time": 12.21,
      "time_str": "00:12.210",
      "text": "那一夜",
      "translation": null
    },
    {
      "time": 24.07,
      "time_str": "00:24.070",
      "text": "那年你踏上暮色他乡",
      "translation": null
    },
    {
      "time": 29.18,
      "time_str": "00:29.180",
      "text": "你以为那里有你的理想",
      "translation": null
    },
    {
      "time": 34.89,
      "time_str": "00:34.890",
      "text": "你看着周围陌生目光",
      "translation": null
    },
    {
      "time": 40.53,
      "time_str": "00:40.530",
      "text": "清晨醒来却没人在身旁",
      "translation": null
    },
    {
      "time": 46.37,
      "time_str": "00:46.370",
      "text": "人静的雨夜想起了她",
      "translation": null
    },
    {
      "time": 51.89,
      "time_str": "00:51.890",
      "text": "她的挽留还萦绕耳旁",
      "translation": null
    },
    {
      "time": 57.52,
      "time_str": "00:57.520",
      "text": "想起离别她带泪的脸庞",
      "translation": null
    },
    {
      "time": 63.36,
      "time_str": "01:03.360",
      "text": "你忍不住的哭出声响",
      "translation": null
    },
