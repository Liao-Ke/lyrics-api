  "lyrics": [
    {
      "time": 0.315,
      "time_str": "00:00.315",
      "text": "你在南方的艳阳里大雪纷飞",
      "translation": null
    },
    {
      "time": 8.1,
      "time_str": "00:08.100",
      "text": "我在北方的寒夜里四季如春",
      "translation": null
    },
    {
      "time": 14.61,
      "time_str": "00:14.610",
      "text": "如果天黑之前来得及",
      "translation": null
    },
    {
      "time": 18.24,
      "time_str": "00:18.240",
      "text": "我要忘了你的眼睛",
      "translation": null
    },
    {
      "time": 21.97,
      "time_str": "00:21.970",
      "text": "穷极一生做不完一场梦",
      "translation": null
    },
    {
      "time": 30.0,
      "time_str": "00:30.000",
      "text": "他不再和谁谈论相逢的孤岛",
      "translation": null
    },
    {
      "time": 36.73,
      "time_str": "00:36.730",
      "text": "因为心里早已荒芜人烟",
      "translation": null
    },
    {
      "time": 44.1,
      "time_str": "00:44.100",
      "text": "他的心里再装不下一个家",
      "translation": null
    },
    {
      "time": 51.57,
      "time_str": "00:51.570",
      "text": "做一个只对自己说谎的哑巴",
      "translation": null
    },
    {
      "time": 58.7,
      "time_str": "00:58.700",
      "text": "他说你任何为人称道的美丽",
      "translation": null
    },
    {
      "time": 62.54,
      "time_str": "01:02.540",
      "text": "不及他第一次遇见你",
      "translation": null
    },
    {
      "time": 67.24,
      "time_str": "01:07.240",
      "text": "时光苟延残喘无可奈何",
      "translation": null
    },
    {
      "time": 74.07,
      "time_str": "01:14.070",
      "text": "如果所有土地连在一起",
      "translation": null
    },
    {
      "time": 77.14,
      "time_str": "01:17.140",
      "text": "走上一生只为拥抱你",
      "translation": null
    },
    {
      "time": 81.09,
      "time_str": "01:21.090",
      "text": "喝醉了他的梦 晚安",
      "translation": null
    },
    {
      "time": 133.31,
      "time_str": "02:13.310",
      "text": "他听见有人唱着古老的歌",
      "translation": null
    },
    {
      "time": 140.29,
      "time_str": "02:20.290",
      "text": "唱着今天还在远方发生的",
      "translation": null
    },
    {
      "time": 147.87,
      "time_str": "02:27.870",
      "text": "像在她眼睛里看到的孤岛",
      "translation": null
    },
    {
      "time": 155.25,
      "time_str": "02:35.250",
      "text": "没有悲伤但也没有花朵",
      "translation": null
    },
    {
