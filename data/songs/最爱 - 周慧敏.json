  "lyrics": [
    {
      "time": 15.22,
      "time_str": "00:15.220",
      "text": "天空一片蔚蓝 清风添上了浪漫",
      "translation": null
    },
    {
      "time": 19.1,
      "time_str": "00:19.100",
      "text": "心里那份柔情蜜意似海无限",
      "translation": null
    },
    {
      "time": 33.05,
      "time_str": "00:33.050",
      "text": "在那遥远有意无意遇上",
      "translation": null
    },
    {
      "time": 36.57,
      "time_str": "00:36.570",
      "text": "共你初次邂逅谁没有遐想",
      "translation": null
    },
    {
      "time": 40.93,
      "time_str": "00:40.930",
      "text": "诗一般的落霞 酒一般的夕阳",
      "translation": null
    },
    {
      "time": 45.25,
      "time_str": "00:45.250",
      "text": "似是月老给你我留印象",
      "translation": null
    },
    {
      "time": 50.07,
      "time_str": "00:50.070",
      "text": "斜阳离去朗月已换上",
      "translation": null
    },
    {
      "time": 53.58,
      "time_str": "00:53.580",
      "text": "没法掩盖这份情欲盖弥彰",
      "translation": null
    },
    {
      "time": 57.93,
      "time_str": "00:57.930",
      "text": "这一刹情一缕 影一对人一双",
      "translation": null
    },
    {
      "time": 62.29,
      "time_str": "01:02.290",
      "text": "那怕热炽爱一场",
      "translation": null
    },
    {
      "time": 66.27,
      "time_str": "01:06.270",
      "text": "潮汐退和涨 月冷风和霜",
      "translation": null
    },
    {
      "time": 70.39,
      "time_str": "01:10.390",
      "text": "夜雨的狂想 野花的微香",
      "translation": null
    },
    {
      "time": 74.49,
      "time_str": "01:14.490",
      "text": "伴我星夜里幻想 方知不用太紧张",
      "translation": null
    },
    {
      "time": 85.41,
      "time_str": "01:25.410",
      "text": "没法隐藏这份爱 是我深情深似海",
      "translation": null
    },
    {
      "time": 93.64,
      "time_str": "01:33.640",
      "text": "一生一世难分开 难改变也难再",
      "translation": null
    },
    {
      "time": 97.86,
      "time_str": "01:37.860",
      "text": "让你的爱满心内",
      "translation": null
    },
