    {
      "time": 8.04,
      "time_str": "00:08.040",
      "text": "我不要将你多绑住一秒",
      "translation": null
    },
    {
      "time": 20.12,
      "time_str": "00:20.120",
      "text": "我也知道天空多美妙",
      "translation": null
    },
    {
      "time": 33.25,
      "time_str": "00:33.250",
      "text": "请你替我瞧一瞧",
      "translation": null
    },
    {
      "time": 51.32,
      "time_str": "00:51.320",
      "text": "天上的风筝哪儿去了",
      "translation": null
    },
    {
      "time": 56.19,
      "time_str": "00:56.190",
      "text": "一眨眼不见了",
      "translation": null
    },
    {
      "time": 60.87,
      "time_str": "01:00.870",
      "text": "谁把它的线剪断了",
      "translation": null
