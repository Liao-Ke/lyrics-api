  "lyrics": [
    {
      "time": 14.62,
      "time_str": "00:14.620",
      "text": "突然间袭来生命的危险",
      "translation": null
    },
    {
      "time": 21.88,
      "time_str": "00:21.880",
      "text": "还来不及完成春天的心愿",
      "translation": null
    },
    {
      "time": 29.4,
      "time_str": "00:29.400",
      "text": "突然间牵挂在聚散之间",
      "translation": null
    },
    {
      "time": 36.41,
      "time_str": "00:36.410",
      "text": "只有爱的乐章告慰着思念",
      "translation": null
    },
    {
      "time": 44.5,
      "time_str": "00:44.500",
      "text": "别害怕我就站在你身边",
      "translation": null
    },
    {
      "time": 51.17,
      "time_str": "00:51.170",
      "text": "心在一起爱会让我们勇敢",
      "translation": null
    },
    {
      "time": 58.85,
      "time_str": "00:58.850",
      "text": "别害怕我就站在你身边",
      "translation": null
    },
    {
      "time": 66.2,
      "time_str": "01:06.200",
      "text": "看黑夜无法吞没黎明的天",
      "translation": null
    },
    {
      "time": 73.4,
      "time_str": "01:13.400",
      "text": "我坚定的不让泪水涌上双眼",
      "translation": null
    },
    {
      "time": 81.5,
      "time_str": "01:21.500",
      "text": "付出一切只为生命的宣言",
      "translation": null
    },
    {
      "time": 88.16,
      "time_str": "01:28.160",
      "text": "我微笑着矗立在生死之间",
      "translation": null
    },
    {
      "time": 96.399,
      "time_str": "01:36.399",
      "text": "爱的火焰燃烧心中直到永远",
      "translation": null
    },
