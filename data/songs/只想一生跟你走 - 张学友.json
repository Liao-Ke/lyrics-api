    {
      "time": 37.09,
      "time_str": "00:37.090",
      "text": "共你有过最美的邂逅",
      "translation": null
    },
    {
      "time": 44.9,
      "time_str": "00:44.900",
      "text": "共你有过一些风雨忧愁",
      "translation": null
    },
    {
      "time": 52.0,
      "time_str": "00:52.000",
      "text": "共你醉过痛过的最后",
      "translation": null
    },
    {
      "time": 59.9,
      "time_str": "00:59.900",
      "text": "但我发觉想你不能没有",
      "translation": null
    },
    {
      "time": 66.9,
      "time_str": "01:06.900",
      "text": "在你每次抱怨的眼眸",
      "translation": null
    },
    {
      "time": 74.05,
      "time_str": "01:14.050",
      "text": "像我永远不懂给你温柔",
      "translation": null
    },
    {
      "time": 81.9,
      "time_str": "01:21.900",
      "text": "别再诉说我俩早已分手",
      "translation": null
    },
    {
      "time": 89.0,
      "time_str": "01:29.000",
      "text": "像你教我伤心依然未够",
      "translation": null
    },
    {
      "time": 94.9,
      "time_str": "01:34.900",
      "text": "但你没带走 梦里的所有",
      "translation": null
    },
    {
      "time": 102.8,
      "time_str": "01:42.800",
      "text": "让你走 为何让你看不透",
      "translation": null
    },
    {
      "time": 109.5,
      "time_str": "01:49.500",
      "text": "但求你未淡忘往日旧情",
      "translation": null
    },
    {
      "time": 112.0,
      "time_str": "01:52.000",
      "text": "我愿默然带着泪流",
      "translation": null
    },
    {
      "time": 113.9,
      "time_str": "01:53.900",
      "text": "很想一生跟你走",
      "translation": null
    },
    {
      "time": 116.9,
      "time_str": "01:56.900",
      "text": "就算天边海角 多少改变",
      "translation": null
    },
    {
      "time": 119.87,
      "time_str": "01:59.870",
      "text": "一生只有 风中追究",
      "translation": null
    },
    {
      "time": 121.2,
      "time_str": "02:01.200",
      "text": "不想孤单的逗留",
      "translation": null
    },
