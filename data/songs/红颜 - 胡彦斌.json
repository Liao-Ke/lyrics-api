    {
      "time": 2.5,
      "time_str": "00:02.500",
      "text": "剑煮酒无味",
      "translation": null
    },
    {
      "time": 6.52,
      "time_str": "00:06.520",
      "text": "饮一杯为谁",
      "translation": null
    },
    {
      "time": 10.86,
      "time_str": "00:10.860",
      "text": "你为我送别",
      "translation": null
    },
    {
      "time": 14.79,
      "time_str": "00:14.790",
      "text": "你为我送别",
      "translation": null
    },
    {
      "time": 19.07,
      "time_str": "00:19.070",
      "text": "胭脂香味",
      "translation": null
    },
    {
      "time": 22.54,
      "time_str": "00:22.540",
      "text": "能爱不能给",
      "translation": null
    },
    {
      "time": 26.83,
      "time_str": "00:26.830",
      "text": "天有多长",
      "translation": null
    },
    {
      "time": 30.89,
      "time_str": "00:30.890",
      "text": "地有多远",
      "translation": null
    },
    {
      "time": 36.64,
      "time_str": "00:36.640",
      "text": "你是英雄就注定无泪无悔",
      "translation": null
    },
    {
      "time": 44.58,
      "time_str": "00:44.580",
      "text": "这笑有多危险 是穿肠毒药",
      "translation": null
    },
    {
      "time": 52.5,
      "time_str": "00:52.500",
      "text": "这泪有多么美 只有你知道",
      "translation": null
    },
    {
      "time": 60.56,
      "time_str": "01:00.560",
      "text": "这心没有你活着可笑",
      "translation": null
    },
    {
      "time": 68.58,
      "time_str": "01:08.580",
      "text": "这一世英名我不要",
      "translation": null
    },
    {
      "time": 76.53,
      "time_str": "01:16.530",
      "text": "只求换来红颜一笑",
      "translation": null
    },
    {
      "time": 84.75,
      "time_str": "01:24.750",
      "text": "这一去如果还能轮回",
      "translation": null
    },
    {
      "time": 92.78,
      "time_str": "01:32.780",
      "text": "我愿意来生做牛马",
      "translation": null
    },
    {
      "time": 96.6,
      "time_str": "01:36.600",
      "text": "也要与你天涯相随",
