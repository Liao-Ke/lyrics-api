  "lyrics": [
    {
      "time": 16.75,
      "time_str": "00:16.750",
      "text": "曾踏过艰辛的每一步",
      "translation": null
    },
    {
      "time": 21.52,
      "time_str": "00:21.520",
      "text": "仍然前去 仍然闯不理几高",
      "translation": null
    },
    {
      "time": 26.89,
      "time_str": "00:26.890",
      "text": "耳边的风声响 像似歌声鼓舞",
      "translation": null
    },
    {
      "time": 31.83,
      "time_str": "00:31.830",
      "text": "努力为要走好我每步",
      "translation": null
    },
    {
      "time": 37.55,
      "time_str": "00:37.550",
      "text": "行尽了许多的崎岖路",
      "translation": null
    },
    {
      "time": 42.2,
      "time_str": "00:42.200",
      "text": "还前去 才能知境界更高",
      "translation": null
    },
    {
      "time": 47.43,
      "time_str": "00:47.430",
      "text": "名利似有还无 要想捉 捉不到",
      "translation": null
    },
    {
      "time": 52.61,
      "time_str": "00:52.610",
      "text": "岁月在我身边笑着逃",
      "translation": null
    },
    {
      "time": 59.17,
      "time_str": "00:59.170",
      "text": "道路段段美好总是血与汗营造",
      "translation": null
    },
    {
      "time": 64.98,
      "time_str": "01:04.980",
      "text": "感激心中主宰每段道路为我铺",
      "translation": null
    },
    {
      "time": 70.1,
      "time_str": "01:10.100",
      "text": "但愿日后更好 我愿永远莫停步",
      "translation": null
    },
    {
      "time": 75.26,
      "time_str": "01:15.260",
      "text": "我要闯出新绩 要用实力做旗号",
      "translation": null
    },
    {
      "time": 86.74,
      "time_str": "01:26.740",
      "text": "明日再要走几多路",
      "translation": null
    },
    {
      "time": 91.06,
      "time_str": "01:31.060",
      "text": "谁人能计 谁能知天有几高",
      "translation": null
    },
    {
      "time": 96.56,
      "time_str": "01:36.560",
      "text": "凭自信努力做 要得到的终得到",
      "translation": null
    },
    {
      "time": 101.56,
      "time_str": "01:41.560",
      "text": "以后就算追忆也自豪",
      "translation": null
    },
    {
