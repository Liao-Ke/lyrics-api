  "lyrics": [
    {
      "time": 5.0,
      "time_str": "00:05.000",
      "text": "弦乐编写 : 林迈可(Michael Lin)",
      "translation": null
    },
    {
      "time": 29.36,
      "time_str": "00:29.360",
      "text": "小学篱笆旁的蒲公英",
      "translation": null
    },
    {
      "time": 35.92,
      "time_str": "00:35.920",
      "text": "是记忆里有味道的风景",
      "translation": null
    },
    {
      "time": 43.04,
      "time_str": "00:43.040",
      "text": "午睡操场传来蝉的声音",
      "translation": null
    },
    {
      "time": 50.07,
      "time_str": "00:50.070",
      "text": "多少年后也还是很好听",
      "translation": null
    },
    {
      "time": 57.61,
      "time_str": "00:57.610",
      "text": "将愿望折纸飞机寄成信",
      "translation": null
    },
    {
      "time": 64.25,
      "time_str": "01:04.250",
      "text": "因为我们等不到那流星",
      "translation": null
    },
    {
      "time": 71.32,
      "time_str": "01:11.320",
      "text": "认真投决定命运的硬币",
      "translation": null
    },
    {
      "time": 78.29,
      "time_str": "01:18.290",
      "text": "却不知道到底能去哪里",
      "translation": null
    },
    {
      "time": 85.61,
      "time_str": "01:25.610",
      "text": "一起长大的约定",
      "translation": null
    },
    {
      "time": 90.54,
      "time_str": "01:30.540",
      "text": "那样清晰 拉过勾的我相信",
      "translation": null
    },
    {
      "time": 99.45,
      "time_str": "01:39.450",
      "text": "说好要一起旅行",
      "translation": null
    },
    {
      "time": 104.68,
      "time_str": "01:44.680",
      "text": "是你如今 唯一坚持的任性",
      "translation": null
    },
    {
      "time": 142.36,
      "time_str": "02:22.360",
      "text": "在走廊上罚站打手心",
      "translation": null
    },
    {
      "time": 148.94,
      "time_str": "02:28.940",
      "text": "我们却注意窗边的蜻蜓",
      "translation": null
    },
    {
      "time": 156.04,
      "time_str": "02:36.040",
      "text": "我去到哪里你都跟很紧",
      "translation": null
    },
    {
      "time": 163.13,
      "time_str": "02:43.130",
      "text": "很多的梦在等待着进行",
      "translation": null
    },
    {
      "time": 170.13,
      "time_str": "02:50.130",
      "text": "一起长大的约定",
      "translation": null
    },
    {
      "time": 175.21,
      "time_str": "02:55.210",
      "text": "那样清晰 打过勾的我相信",
      "translation": null
    },
    {
      "time": 184.13,
      "time_str": "03:04.130",
      "text": "说好要一起旅行",
      "translation": null
    },
    {
      "time": 189.31,
      "time_str": "03:09.310",
      "text": "是你如今 唯一坚持的任性",
      "translation": null
    },
    {
      "time": 198.31,
      "time_str": "03:18.310",
      "text": "一起长大的约定",
      "translation": null
    },
    {
      "time": 203.4,
      "time_str": "03:23.400",
      "text": "那样真心",
      "translation": null
    },
    {
      "time": 206.84,
      "time_str": "03:26.840",
      "text": "与你聊不完的曾经",
      "translation": null
    },
    {
      "time": 212.39,
      "time_str": "03:32.390",
      "text": "而我已经分不清",
      "translation": null
    },
    {
      "time": 217.58,
      "time_str": "03:37.580",
      "text": "你是友情还是错过的爱情",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "蒲公英的约定 - 周杰伦.lrc"
}