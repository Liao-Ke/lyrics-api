    {
      "time": 0.97,
      "time_str": "00:00.970",
      "text": "赵鹏――爱的箴言",
      "translation": null
    },
    {
      "time": 31.81,
      "time_str": "00:31.810",
      "text": "我将真心付给了你",
      "translation": null
    },
    {
      "time": 37.93,
      "time_str": "00:37.930",
      "text": "将悲伤留给我自己",
      "translation": null
    },
    {
      "time": 43.98,
      "time_str": "00:43.980",
      "text": "我将青春付给了你",
      "translation": null
    },
    {
      "time": 51.47,
      "time_str": "00:51.470",
      "text": "将岁月留给我自己",
      "translation": null
    },
    {
      "time": 57.91,
      "time_str": "00:57.910",
      "text": "我将生命付给了你",
      "translation": null
    },
    {
      "time": 64.9,
      "time_str": "01:04.900",
      "text": "将孤独留给我自己",
      "translation": null
    },
    {
      "time": 70.83,
      "time_str": "01:10.830",
      "text": "我将春天付给了你",
      "translation": null
    },
    {
      "time": 78.25,
      "time_str": "01:18.250",
      "text": "将冬天留给我自己",
      "translation": null
    },
    {
      "time": 81.99,
      "time_str": "01:21.990",
      "text": "爱是没有人能了解的东西",
      "translation": null
    },
    {
      "time": 91.93,
      "time_str": "01:31.930",
      "text": "爱是永恒的旋律",
      "translation": null
    },
    {
      "time": 98.54,
      "time_str": "01:38.540",
      "text": "爱是欢笑泪珠飘落的过程",
      "translation": null
    },
    {
      "time": 105.35,
      "time_str": "01:45.350",
      "text": "爱曾经是我也是你",
      "translation": null
    },
    {
      "time": 111.71,
      "time_str": "01:51.710",
      "text": "我将春天付给了你",
      "translation": null
    },
    {
      "time": 118.14,
      "time_str": "01:58.140",
      "text": "将冬天留给我自己",
      "translation": null
    },
    {
      "time": 124.45,
      "time_str": "02:04.450",
      "text": "我将你的背影留给我自己",
      "translation": null
    },
    {
      "time": 131.49,
      "time_str": "02:11.490",
      "text": "却将自己给了你",
