    {
      "time": 23.03,
      "time_str": "00:23.030",
      "text": "刚下的地铁还不算拥挤",
      "translation": null
    },
    {
      "time": 27.85,
      "time_str": "00:27.850",
      "text": "你那边飞机碰巧也落地",
      "translation": null
    },
    {
      "time": 32.53,
      "time_str": "00:32.530",
      "text": "东京下雨 淋湿巴黎",
      "translation": null
    },
    {
      "time": 34.92,
      "time_str": "00:34.920",
      "text": "收音机 你听几点几",
      "translation": null
    },
    {
      "time": 42.51,
      "time_str": "00:42.510",
      "text": "当半个地球外还有个你",
      "translation": null
    },
    {
      "time": 47.2,
      "time_str": "00:47.200",
      "text": "当相遇还没到对的时机",
      "translation": null
    },
    {
      "time": 52.01,
      "time_str": "00:52.010",
      "text": "夏天一去 又是冬季",
      "translation": null
    },
    {
      "time": 54.58,
      "time_str": "00:54.580",
      "text": "7-11 暖杯巧克力",
      "translation": null
    },
    {
