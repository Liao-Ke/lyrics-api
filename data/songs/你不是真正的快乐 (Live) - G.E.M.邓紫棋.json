  "lyrics": [
    {
      "time": 27.72,
      "time_str": "00:27.720",
      "text": "人群中哭着",
      "translation": null
    },
    {
      "time": 31.85,
      "time_str": "00:31.850",
      "text": "你只想变成透明的 颜色",
      "translation": null
    },
    {
      "time": 37.56,
      "time_str": "00:37.560",
      "text": "你再也不会梦或痛或心动了",
      "translation": null
    },
    {
      "time": 44.82,
      "time_str": "00:44.820",
      "text": "你已经决定了",
      "translation": null
    },
    {
      "time": 47.75,
      "time_str": "00:47.750",
      "text": "你已经决定了",
      "translation": null
    },
    {
      "time": 54.15,
      "time_str": "00:54.150",
      "text": "你静静忍着",
      "translation": null
    },
    {
      "time": 58.01,
      "time_str": "00:58.010",
      "text": "紧紧把昨天在拳心握着",
      "translation": null
    },
    {
      "time": 64.19,
      "time_str": "01:04.190",
      "text": "而回忆越是甜就是越伤人的",
      "translation": null
    },
    {
      "time": 71.19,
      "time_str": "01:11.190",
      "text": "越是在手心留下",
      "translation": null
    },
    {
      "time": 72.89,
      "time_str": "01:12.890",
      "text": "密密麻麻深深浅浅的刀割",
      "translation": null
    },
    {
      "time": 81.43,
      "time_str": "01:21.430",
      "text": "你不是真正的快乐",
      "translation": null
    },
    {
      "time": 87.12,
      "time_str": "01:27.120",
      "text": "你的笑只是你穿的保护色",
      "translation": null
    },
    {
      "time": 93.46,
      "time_str": "01:33.460",
      "text": "你决定不恨了 也决定不爱了",
      "translation": null
    },
    {
      "time": 99.2,
      "time_str": "01:39.200",
      "text": "把你的灵魂",
      "translation": null
    },
    {
      "time": 100.82,
      "time_str": "01:40.820",
      "text": "关在永远锁上的躯壳",
      "translation": null
    },
    {
      "time": 106.6,
      "time_str": "01:46.600",
      "text": "这世界笑了",
      "translation": null
    },
    {
      "time": 110.6,
      "time_str": "01:50.600",
      "text": "于是你合群地一起笑了",
      "translation": null
    },
    {
      "time": 116.53,
      "time_str": "01:56.530",
      "text": "当生存是规则",
      "translation": null
    },
    {
      "time": 119.41,
      "time_str": "01:59.410",
      "text": "不是你的选择",
      "translation": null
    },
    {
      "time": 123.82,
      "time_str": "02:03.820",
      "text": "于是你含着眼泪",
      "translation": null
    },
    {
      "time": 125.7,
      "time_str": "02:05.700",
      "text": "飘飘荡荡跌跌撞撞地走着",
      "translation": null
    },
    {
      "time": 131.17,
      "time_str": "02:11.170",
      "text": "你不是真正的快乐",
      "translation": null
    },
    {
      "time": 136.81,
      "time_str": "02:16.810",
      "text": "你的伤从不肯完全的愈合",
      "translation": null
    },
    {
      "time": 142.69,
      "time_str": "02:22.690",
      "text": "我站在你左侧",
      "translation": null
    },
    {
      "time": 145.83,
      "time_str": "02:25.830",
      "text": "却像隔着银河",
      "translation": null
    },
    {
      "time": 148.65,
      "time_str": "02:28.650",
      "text": "难道就真的抱着遗憾一直到老了",
      "translation": null
    },
    {
      "time": 154.54,
      "time_str": "02:34.540",
      "text": "然后才后悔着",
      "translation": null
