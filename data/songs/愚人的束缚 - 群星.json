    },
    {
      "time": 37.14,
      "time_str": "00:37.140",
      "text": "For five long years",
      "translation": "整整五年时光"
    },
    {
      "time": 40.77,
      "time_str": "00:40.770",
      "text": "I thought you were my man",
      "translation": "我以为你是我的归宿"
    },
    {
      "time": 45.49,
      "time_str": "00:45.490",
      "text": "But I found out, I’m just a link in your chain",
      "translation": "却发现只是你锁链的一环"
    },
    {
      "time": 54.15,
      "time_str": "00:54.150",
      "text": "Oh, you got me where you want me",
      "translation": "你已将我掌控在手"
    },
    {
      "time": 57.68,
      "time_str": "00:57.680",
      "text": "I ain’t nothin but your fool",
      "translation": "我不过是你掌中愚人"
    },
    {
