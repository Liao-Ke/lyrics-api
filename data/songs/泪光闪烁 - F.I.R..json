  "lyrics": [
    {
      "time": 31.42,
      "time_str": "00:31.420",
      "text": "夜 从天空悄悄滑落",
      "translation": null
    },
    {
      "time": 37.27,
      "time_str": "00:37.270",
      "text": "任性地划着伤口",
      "translation": null
    },
    {
      "time": 40.99,
      "time_str": "00:40.990",
      "text": "是谁呢 痛得那么沉默",
      "translation": null
    },
    {
      "time": 47.0,
      "time_str": "00:47.000",
      "text": "我 以为把幸福上锁",
      "translation": null
    },
    {
      "time": 51.76,
      "time_str": "00:51.760",
      "text": "能紧紧守护承诺",
      "translation": null
    },
    {
      "time": 55.53,
      "time_str": "00:55.530",
      "text": "是谁呢 把窗推开 风卷走了爱",
      "translation": null
    },
    {
      "time": 64.47,
      "time_str": "01:04.470",
      "text": "为你哭的泪 每一颗闪烁",
      "translation": null
    },
    {
      "time": 68.05,
      "time_str": "01:08.050",
      "text": "坚定的路途也走得颠簸",
      "translation": null
    },
    {
      "time": 71.76,
      "time_str": "01:11.760",
      "text": "头也不回 义无反顾 从不后悔深爱过",
      "translation": null
    },
    {
      "time": 78.87,
      "time_str": "01:18.870",
      "text": "为你笑的泪 每一颗闪烁",
      "translation": null
    },
    {
      "time": 83.8,
      "time_str": "01:23.800",
      "text": "Cause I love you so",
      "translation": "都是因为我爱你至深"
    },
    {
      "time": 87.23,
      "time_str": "01:27.230",
      "text": "最美的爱 不是紧握 我们曾拥有",
      "translation": null
