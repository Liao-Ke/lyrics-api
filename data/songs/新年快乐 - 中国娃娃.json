      "time": 15.0,
      "time_str": "00:15.000",
      "text": "萨瓦迪卡～财神来敲我家门",
      "translation": null
    },
    {
      "time": 18.3,
      "time_str": "00:18.300",
      "text": "娃娃来点灯",
      "translation": null
    },
    {
      "time": 21.7,
      "time_str": "00:21.700",
      "text": "新夜红包加鞭炮声",
      "translation": null
    },
    {
      "time": 25.1,
      "time_str": "00:25.100",
      "text": "多财又多福",
      "translation": null
    },
    {
      "time": 55.97,
      "time_str": "00:55.970",
      "text": "恭喜啦 中国娃娃",
      "translation": null
    },
    {
      "time": 62.6,
      "time_str": "01:02.600",
      "text": "发财啦 中国娃娃",
      "translation": null
    },
    {
      "time": 69.46,
      "time_str": "01:09.460",
      "text": "开市啦",
      "translation": null
    },
    {
      "time": 70.03,
      "time_str": "01:10.030",
      "text": "祝大家新年恭喜恭喜发财",
      "translation": null
    },
    {
      "time": 71.91,
      "time_str": "01:11.910",
      "text": "中国娃娃",
      "translation": null
    },
    {
      "time": 73.06,
      "time_str": "01:13.060",
      "text": "祝大家快快乐乐见财有福",
      "translation": null
    },
    {
      "time": 75.46,
      "time_str": "01:15.460",
      "text": "福气啦（台语）",
      "translation": null
    },
    {
      "time": 76.82,
      "time_str": "01:16.820",
      "text": "祝大家新年 恭喜恭喜发财",
      "translation": null
    },
    {
      "time": 79.27,
      "time_str": "01:19.270",
      "text": "中国娃娃祝大家",
      "translation": null
    },
    {
      "time": 80.77,
      "time_str": "01:20.770",
      "text": "happy happy new year",
      "translation": null
    },
    {
      "time": 82.65,
      "time_str": "01:22.650",
      "text": "一天一天的过去",
      "translation": null
    },
    {
      "time": 85.3,
      "time_str": "01:25.300",
      "text": "新年又来临",
      "translation": null
    },
    {
      "time": 86.7,
      "time_str": "01:26.700",
      "text": "你我不分离",
      "translation": null
    },
    {
      "time": 89.15,
      "time_str": "01:29.150",
      "text": "不管到世界各地",
      "translation": null
    },
    {
      "time": 92.06,
      "time_str": "01:32.060",
      "text": "同样的气息",
      "translation": null
    },
    {
      "time": 93.57,
      "time_str": "01:33.570",
      "text": "家家都欢喜",
      "translation": null
    },
    {
      "time": 95.77,
