    {
      "time": 23.53,
      "time_str": "00:23.530",
      "text": "多少个秋 多少个冬",
      "translation": null
    },
    {
      "time": 27.07,
      "time_str": "00:27.070",
      "text": "我几乎快要被治愈好",
      "translation": null
    },
    {
      "time": 32.03,
      "time_str": "00:32.030",
      "text": "但还是会只因为一个重复的话题",
      "translation": null
    },
    {
      "time": 37.87,
      "time_str": "00:37.870",
      "text": "就无心自扰",
      "translation": null
    },
    {
      "time": 43.59,
      "time_str": "00:43.590",
      "text": "也曾想过",
      "translation": null
    },
    {
      "time": 45.09,
      "time_str": "00:45.090",
      "text": "若真遇见 我们应该如何是好",
      "translation": null
    },
    {
      "time": 51.86,
      "time_str": "00:51.860",
      "text": "我想我还是会还站在某一个街角",
      "translation": null
    },
    {
      "time": 57.43,
      "time_str": "00:57.430",
      "text": "不让你看到",
      "translation": null
    },
    {
      "time": 62.48,
      "time_str": "01:02.480",
      "text": "只因为我不想打扰",
      "translation": null
    },
    {
      "time": 67.41,
      "time_str": "01:07.410",
      "text": "只因为怕你解释不了",
      "translation": null
    },
    {
      "time": 72.08,
      "time_str": "01:12.080",
      "text": "只因为现在你的眼睛里",
      "translation": null
    },
    {
      "time": 77.38,
      "time_str": "01:17.380",
      "text": "她比我还重要",
      "translation": null
    },
    {
      "time": 84.47,
      "time_str": "01:24.470",
      "text": "我只好假装我看不到",
      "translation": null
    },
    {
      "time": 89.15,
      "time_str": "01:29.150",
      "text": "看不到你和她在对街拥抱",
      "translation": null
    },
    {
      "time": 94.27,
      "time_str": "01:34.270",
      "text": "你的快乐 我可以感受得到",
      "translation": null
    },
    {
      "time": 99.209,
      "time_str": "01:39.209",
      "text": "这样的见面方式对谁都好",
      "translation": null
    },
    {
      "time": 104.2,
      "time_str": "01:44.200",
      "text": "我只好假装我听不到",
      "translation": null
    },
    {
      "time": 108.959,
      "time_str": "01:48.959",
      "text": "听不到别人口中的她好不好",
      "translation": null
    },
    {
      "time": 114.71,
      "time_str": "01:54.710",
      "text": "再不想问 也不想被通知到",
      "translation": null
    },
    {
      "time": 120.32,
      "time_str": "02:00.320",
      "text": "反正你的世界我管不了",
