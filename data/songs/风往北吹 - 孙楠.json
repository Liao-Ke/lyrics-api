  },
  "lyrics": [
    {
      "time": 31.33,
      "time_str": "00:31.330",
      "text": "你的手一挥 说要往北飞",
      "translation": null
    },
    {
      "time": 37.93,
      "time_str": "00:37.930",
      "text": "爱情被一刀剪碎 我的心一片黑",
      "translation": null
    },
    {
      "time": 46.26,
      "time_str": "00:46.260",
      "text": "你讲的很对 说永远多累",
      "translation": null
    },
    {
      "time": 53.3,
      "time_str": "00:53.300",
      "text": "但是这一声再会 以后谁记得谁",
      "translation": null
    },
    {
      "time": 62.38,
      "time_str": "01:02.380",
      "text": "我以为我的爱情",
      "translation": null
    },
    {
      "time": 65.85,
      "time_str": "01:05.850",
      "text": "可以满足你想买的醉",
      "translation": null
    },
    {
      "time": 70.94,
      "time_str": "01:10.940",
      "text": "风一吹 我才知道自己早已崩溃",
      "translation": null
    },
    {
      "time": 79.39,
      "time_str": "01:19.390",
      "text": "风往北吹 你走的好干脆",
      "translation": null
    },
    {
      "time": 86.33,
      "time_str": "01:26.330",
      "text": "我的眼睁不开 流着泪",
      "translation": null
    },
    {
      "time": 90.13,
      "time_str": "01:30.130",
      "text": "你用一句话把一切收回",
      "translation": null
    },
    {
      "time": 92.96,
      "time_str": "01:32.960",
      "text": "我往北追 用迷了路的腿",
      "translation": null
    },
    {
      "time": 100.13,
      "time_str": "01:40.130",
      "text": "我只有往前飞 退不回",
      "translation": null
    },
    {
      "time": 103.34,
      "time_str": "01:43.340",
      "text": "北方没有你",
      "translation": null
    },
    {
      "time": 106.789,
      "time_str": "01:46.789",
      "text": "要我如何收拾你给我的美",
      "translation": null
    },
