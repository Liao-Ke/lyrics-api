  "lyrics": [
    {
      "time": 35.19,
      "time_str": "00:35.190",
      "text": "过完整个夏天忧伤并没有好一些",
      "translation": null
    },
    {
      "time": 41.29,
      "time_str": "00:41.290",
      "text": "开车行驶在公路无际无边",
      "translation": null
    },
    {
      "time": 47.38,
      "time_str": "00:47.380",
      "text": "有离开自己的感觉",
      "translation": null
    },
    {
      "time": 53.64,
      "time_str": "00:53.640",
      "text": "唱不完一首歌",
      "translation": null
    },
    {
      "time": 59.75,
      "time_str": "00:59.750",
      "text": "疲倦还剩下黑眼圈",
      "translation": null
    },
    {
      "time": 65.92,
      "time_str": "01:05.920",
      "text": "感情的世界伤害在所难免",
      "translation": null
    },
    {
      "time": 72.03,
      "time_str": "01:12.030",
      "text": "黄昏再美终要黑夜",
      "translation": null
    },
    {
      "time": 78.64,
      "time_str": "01:18.640",
      "text": "依然记得从你口中",
      "translation": null
    },
    {
      "time": 81.69,
      "time_str": "01:21.690",
      "text": "说出再见坚决如铁",
      "translation": null
    },
    {
      "time": 85.16,
      "time_str": "01:25.160",
      "text": "昏暗中有种烈日灼身的错觉",
      "translation": null
    },
    {
      "time": 90.48,
      "time_str": "01:30.480",
      "text": "黄昏的地平线",
      "translation": null
    },
    {
      "time": 93.53,
      "time_str": "01:33.530",
      "text": "划出一句离别",
      "translation": null
    },
    {
      "time": 96.65,
      "time_str": "01:36.650",
      "text": "爱情进入永夜",
      "translation": null
    },
    {
      "time": 103.23,
      "time_str": "01:43.230",
      "text": "依然记得从你眼中",
      "translation": null
    },
    {
      "time": 106.22,
      "time_str": "01:46.220",
      "text": "滑落的泪伤心欲绝",
      "translation": null
    },
    {
      "time": 109.67,
      "time_str": "01:49.670",
      "text": "混乱中有种热泪烧伤的错觉",
      "translation": null
    },
    {
      "time": 115.1,
      "time_str": "01:55.100",
      "text": "黄昏的地平线",
      "translation": null
    },
    {
      "time": 118.17,
      "time_str": "01:58.170",
      "text": "割断幸福喜悦",
      "translation": null
    },
    {
      "time": 121.34,
      "time_str": "02:01.340",
      "text": "相爱已经幻灭",
      "translation": null
    },
