    {
      "time": 23.879,
      "time_str": "00:23.879",
      "text": "别说 我年少轻狂",
      "translation": null
    },
    {
      "time": 28.879,
      "time_str": "00:28.879",
      "text": "我本善良骄傲倔强",
      "translation": null
    },
    {
      "time": 34.13,
      "time_str": "00:34.130",
      "text": "相信 我无法阻挡",
      "translation": null
    },
    {
      "time": 39.63,
      "time_str": "00:39.630",
      "text": "我会成为那道光",
      "translation": null
    },
    {
      "time": 43.13,
      "time_str": "00:43.130",
      "text": "不犹豫 不彷徨",
      "translation": null
    },
    {
      "time": 45.879,
      "time_str": "00:45.879",
      "text": "从未有过绝望",
      "translation": null
    },
    {
      "time": 48.63,
      "time_str": "00:48.630",
      "text": "我的心 像海洋",
      "translation": null
    },
    {
      "time": 53.631,
      "time_str": "00:53.631",
      "text": "未来的路还漫长",
      "translation": null
    },
    {
      "time": 56.38,
      "time_str": "00:56.380",
      "text": "刺破永夜碎星光",
      "translation": null
    },
    {
      "time": 59.13,
      "time_str": "00:59.130",
      "text": "我有我的信仰",
      "translation": null
    },
    {
      "time": 64.131,
      "time_str": "01:04.131",
      "text": "无畏向前 哪怕风雨霜",
      "translation": null
    },
    {
      "time": 69.131,
      "time_str": "01:09.131",
      "text": "我的梦 有乐章 编织方向",
      "translation": null
    },
    {
      "time": 74.381,
      "time_str": "01:14.381",
      "text": "无畏向前哪怕逆着光",
      "translation": null
    },
    {
      "time": 79.382,
