  "lyrics": [
    {
      "time": 4.79,
      "time_str": "00:04.790",
      "text": "也许很远或是昨天",
      "translation": null
    },
    {
      "time": 8.75,
      "time_str": "00:08.750",
      "text": "在这里或在对岸",
      "translation": null
    },
    {
      "time": 12.91,
      "time_str": "00:12.910",
      "text": "长路辗转离合悲欢",
      "translation": null
    },
    {
      "time": 16.96,
      "time_str": "00:16.960",
      "text": "人聚又人散",
      "translation": null
    },
    {
      "time": 21.13,
      "time_str": "00:21.130",
      "text": "放过对错才知答案",
      "translation": null
    },
    {
      "time": 25.3,
      "time_str": "00:25.300",
      "text": "活着的勇敢",
      "translation": null
    },
    {
      "time": 29.45,
      "time_str": "00:29.450",
      "text": "没有神的光环",
      "translation": null
    },
    {
      "time": 33.53,
      "time_str": "00:33.530",
      "text": "你我生而平凡",
      "translation": null
    },
    {
      "time": 37.82,
      "time_str": "00:37.820",
      "text": "在心碎中认清遗憾",
      "translation": null
    },
    {
      "time": 41.88,
      "time_str": "00:41.880",
      "text": "生命漫长也短暂",
      "translation": null
    },
    {
      "time": 45.96,
      "time_str": "00:45.960",
      "text": "跳动心脏长出藤蔓",
      "translation": null
    },
    {
      "time": 50.09,
      "time_str": "00:50.090",
      "text": "愿为险而战",
      "translation": null
    },
    {
      "time": 54.26,
      "time_str": "00:54.260",
      "text": "跌入灰暗坠入深渊",
      "translation": null
    },
    {
      "time": 58.39,
      "time_str": "00:58.390",
      "text": "沾满泥土的脸",
      "translation": null
    },
    {
      "time": 62.41,
      "time_str": "01:02.410",
      "text": "没有神的光环",
      "translation": null
    },
    {
      "time": 66.37,
      "time_str": "01:06.370",
      "text": "握紧手中的平凡",
      "translation": null
    },
    {
      "time": 70.75,
      "time_str": "01:10.750",
      "text": "此心此生无憾",
      "translation": null
    },
    {
      "time": 74.64,
      "time_str": "01:14.640",
      "text": "生命的火已点燃",
      "translation": null
    },
    {
      "time": 81.52,
      "time_str": "01:21.520",
      "text": "有一天也许会走远",
      "translation": null
    },
    {
      "time": 85.21,
      "time_str": "01:25.210",
      "text": "也许还能再相见",
      "translation": null
    },
    {
      "time": 89.4,
      "time_str": "01:29.400",
      "text": "无论在人群在天边",
      "translation": null
    },
    {
      "time": 93.47,
      "time_str": "01:33.470",
      "text": "让我再看清你的脸",
      "translation": null
    },
    {
      "time": 97.67,
      "time_str": "01:37.670",
      "text": "任泪水铺满了双眼",
      "translation": null
    },
    {
      "time": 101.67,
      "time_str": "01:41.670",
      "text": "虽无言泪满面",
