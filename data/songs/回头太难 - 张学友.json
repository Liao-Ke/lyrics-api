    {
      "time": 3.0,
      "time_str": "00:03.000",
      "text": "Publisher : PolyGram Taiwan (PolyGram)",
      "translation": null
    },
    {
      "time": 23.363,
      "time_str": "00:23.363",
      "text": "过了这一夜",
      "translation": null
    },
    {
      "time": 25.924,
      "time_str": "00:25.924",
      "text": "你的爱也不会多一些",
      "translation": null
    },
    {
      "time": 33.773,
      "time_str": "00:33.773",
      "text": "你又何必流泪",
      "translation": null
    },
    {
      "time": 36.389,
      "time_str": "00:36.389",
      "text": "管我明天心里又爱谁",
      "translation": null
    },
    {
      "time": 44.22,
      "time_str": "00:44.220",
      "text": "我的爱情有个缺",
      "translation": null
    },
    {
      "time": 48.37,
      "time_str": "00:48.370",
      "text": "谁能让我停歇",
      "translation": null
    },
    {
      "time": 54.3,
      "time_str": "00:54.300",
      "text": "痴心若有罪 情愿自己背",
      "translation": null
    },
    {
      "time": 65.082,
      "time_str": "01:05.082",
      "text": "不让我挽回",
      "translation": null
    },
    {
      "time": 67.632,
      "time_str": "01:07.632",
      "text": "是你的另一种不妥协",
      "translation": null
    },
    {
      "time": 75.535,
      "time_str": "01:15.535",
      "text": "你的永不后悔",
      "translation": null
    },
    {
      "time": 78.123,
      "time_str": "01:18.123",
      "text": "深深刻刻痛彻我心扉",
      "translation": null
    },
    {
      "time": 85.943,
      "time_str": "01:25.943",
      "text": "可知心痛的感觉",
      "translation": null
    },
    {
      "time": 90.143,
      "time_str": "01:30.143",
      "text": "总是我在体会",
      "translation": null
    },
    {
      "time": 96.357,
      "time_str": "01:36.357",
      "text": "看我心碎 你远走高飞",
      "translation": null
    },
    {
      "time": 106.848,
      "time_str": "01:46.848",
      "text": "一生热爱 回头太难",
      "translation": null
    },
    {
      "time": 111.977,
      "time_str": "01:51.977",
      "text": "苦往心里藏",
      "translation": null
    },
    {
      "time": 117.213,
      "time_str": "01:57.213",
      "text": "情若不断 谁能帮我将你忘",
      "translation": null
    },
    {
      "time": 127.691,
      "time_str": "02:07.691",
      "text": "一生热爱 回头太难",
