  },
  "lyrics": [
    {
      "time": 21.198,
      "time_str": "00:21.198",
      "text": "曾在我背包小小夹层里的那个人",
      "translation": null
    },
    {
      "time": 26.68,
      "time_str": "00:26.680",
      "text": "陪伴我漂洋过海经过每一段旅程",
      "translation": null
    },
    {
      "time": 31.498,
      "time_str": "00:31.498",
      "text": "隐形的稻草人 守护我的天真",
      "translation": null
    },
    {
      "time": 37.588,
      "time_str": "00:37.588",
      "text": "曾以为爱情能让未来只为一个人",
      "translation": null
    },
    {
      "time": 41.99,
      "time_str": "00:41.990",
      "text": "关了灯依旧在书桌角落的那个人",
      "translation": null
    },
    {
      "time": 46.888,
      "time_str": "00:46.888",
      "text": "变成我许多年来纪念爱情的标本",
      "translation": null
    },
    {
      "time": 51.888,
      "time_str": "00:51.888",
      "text": "消失的那个人 回不去的青春",
      "translation": null
    },
    {
      "time": 57.388,
      "time_str": "00:57.388",
      "text": "忘不了爱过的人才会对过往认真",
      "translation": null
    },
    {
      "time": 63.829,
      "time_str": "01:03.829",
      "text": "只愿得一人心 白首不分离",
      "translation": null
    },
    {
      "time": 69.199,
      "time_str": "01:09.199",
      "text": "这简单的话语 需要巨大的勇气",
      "translation": null
    },
    {
      "time": 74.139,
      "time_str": "01:14.139",
      "text": "没想过失去你 却是在骗自己",
      "translation": null
    },
    {
      "time": 79.548,
      "time_str": "01:19.548",
      "text": "最后你深深藏在我的歌声里",
      "translation": null
    },
    {
      "time": 84.219,
      "time_str": "01:24.219",
      "text": "只愿得一人心 白首不分离",
      "translation": null
    },
    {
      "time": 89.338,
      "time_str": "01:29.338",
      "text": "这清晰的话语 嘲笑孤单的自己",
      "translation": null
    },
    {
      "time": 94.338,
      "time_str": "01:34.338",
      "text": "盼望能见到你 却一直骗自己",
      "translation": null
    },
    {
      "time": 99.897,
      "time_str": "01:39.897",
      "text": "遗憾你听不到我唱的这首歌",
      "translation": null
    },
    {
      "time": 104.158,
      "time_str": "01:44.158",
      "text": "多想唱给你",
      "translation": null
    },
