  "lyrics": [
    {
      "time": 0.28,
      "time_str": "00:00.280",
      "text": "你说爱我就跟我走 风雨也跟我走",
      "translation": null
    },
    {
      "time": 6.32,
      "time_str": "00:06.320",
      "text": "海角也跟我走 决定就不回头",
      "translation": null
    },
    {
      "time": 11.2,
      "time_str": "00:11.200",
      "text": "你说爱我就跟我走 勇敢牵我的手",
      "translation": null
    },
    {
      "time": 17.64,
      "time_str": "00:17.640",
      "text": "让爱带我们到 尽头",
      "translation": null
    },
    {
      "time": 26.39,
      "time_str": "00:26.390",
      "text": "清晨的眼泪 淋湿手里的玫瑰",
      "translation": null
    },
    {
      "time": 32.07,
      "time_str": "00:32.070",
      "text": "昨夜点的火 早就悄悄化成灰",
      "translation": null
    },
    {
      "time": 37.76,
      "time_str": "00:37.760",
      "text": "我不用太久 听我最后的要求",
      "translation": null
    },
    {
      "time": 43.37,
      "time_str": "00:43.370",
      "text": "如果爱我你就轻轻点点头",
