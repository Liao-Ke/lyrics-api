  "lyrics": [
    {
      "time": 15.38,
      "time_str": "00:15.380",
      "text": "这是一封离别信",
      "translation": null
    },
    {
      "time": 18.68,
      "time_str": "00:18.680",
      "text": "写下我该离开的原因",
      "translation": null
    },
    {
      "time": 22.27,
      "time_str": "00:22.270",
      "text": "我在你生命中扮演的角色太模糊了",
      "translation": null
    },
    {
      "time": 29.28,
      "time_str": "00:29.280",
      "text": "你对我常忽冷忽热",
      "translation": null
    },
    {
      "time": 32.73,
      "time_str": "00:32.730",
      "text": "我到底是情人还是朋友",
      "translation": null
    },
    {
      "time": 36.5,
      "time_str": "00:36.500",
      "text": "爱你是否不该太认真",
      "translation": null
    },
    {
      "time": 40.81,
      "time_str": "00:40.810",
      "text": "That’s why",
      "translation": null
    },
    {
      "time": 42.6,
      "time_str": "00:42.600",
      "text": "I’m letting go",
      "translation": null
    },
    {
      "time": 45.16,
      "time_str": "00:45.160",
      "text": "我终于舍得为你放开手",
      "translation": null
    },
    {
      "time": 49.09,
      "time_str": "00:49.090",
      "text": "因为爱你爱到我心痛",
      "translation": null
    },
    {
      "time": 54.52,
      "time_str": "00:54.520",
      "text": "但你却不懂",
      "translation": null
    },
    {
      "time": 56.94,
      "time_str": "00:56.940",
      "text": "I’m letting go",
      "translation": null
    },
    {
      "time": 59.19,
      "time_str": "00:59.190",
      "text": "你对一切的软弱与怠惰",
      "translation": null
    },
    {
      "time": 63.1,
      "time_str": "01:03.100",
      "text": "让人怀疑你是否爱过我 真的爱过我",
      "translation": null
    },
    {
      "time": 72.21,
      "time_str": "01:12.210",
      "text": "为你再也找不到借口",
      "translation": null
    },
    {
      "time": 75.63,
      "time_str": "01:15.630",
      "text": "That’s when we should let it go",
      "translation": null
    },
    {
      "time": 93.26,
      "time_str": "01:33.260",
      "text": "你是呼吸的空气",
      "translation": null
    },
    {
      "time": 96.53,
      "time_str": "01:36.530",
      "text": "脱离不了的地心引力",
      "translation": null
    },
    {
      "time": 99.84,
      "time_str": "01:39.840",
      "text": "你在我生命中 曾经是我存在的原因",
      "translation": null
    },
    {
      "time": 107.07,
      "time_str": "01:47.070",
      "text": "或许就像他们说",
      "translation": null
    },
    {
      "time": 110.57,
      "time_str": "01:50.570",
      "text": "爱情只会让人变愚蠢",
      "translation": null
    },
    {
      "time": 114.24,
      "time_str": "01:54.240",
      "text": "自作多情 爱得太天真",
      "translation": null
