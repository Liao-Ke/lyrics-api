  "lyrics": [
    {
      "time": 25.991,
      "time_str": "00:25.991",
      "text": "你总是心太软 心太软",
      "translation": null
    },
    {
      "time": 31.917,
      "time_str": "00:31.917",
      "text": "独自一个人流泪到天亮",
      "translation": null
    },
    {
      "time": 37.107,
      "time_str": "00:37.107",
      "text": "你无怨无悔的爱着那个人",
      "translation": null
    },
    {
      "time": 42.293,
      "time_str": "00:42.293",
      "text": "我知道你根本没那么坚强",
      "translation": null
    },
    {
      "time": 46.847,
      "time_str": "00:46.847",
      "text": "你总是心太软 心太软",
      "translation": null
    },
    {
      "time": 52.633,
      "time_str": "00:52.633",
      "text": "把所有问题都自己扛",
      "translation": null
    },
    {
      "time": 57.546,
      "time_str": "00:57.546",
      "text": "相爱总是简单 相处太难",
      "translation": null
    },
    {
      "time": 62.792,
      "time_str": "01:02.792",
      "text": "不是你的就别再勉强",
      "translation": null
    },
    {
      "time": 71.553,
      "time_str": "01:11.553",
      "text": "夜深了你还不想睡",
      "translation": null
    },
    {
      "time": 76.758,
      "time_str": "01:16.758",
      "text": "你还在想着他吗",
      "translation": null
    },
    {
      "time": 81.936,
      "time_str": "01:21.936",
      "text": "你这样痴情到底累不累",
      "translation": null
    },
    {
      "time": 87.132,
      "time_str": "01:27.132",
      "text": "明知他不会回来安慰",
      "translation": null
    },
    {
      "time": 92.357,
      "time_str": "01:32.357",
      "text": "只不过想好好爱一个人",
      "translation": null
    },
    {
      "time": 97.557,
      "time_str": "01:37.557",
      "text": "可惜他无法给你满分",
      "translation": null
    },
    {
      "time": 102.77,
      "time_str": "01:42.770",
      "text": "多余的牺牲 他不懂心疼",
      "translation": null
    },
    {
      "time": 107.938,
      "time_str": "01:47.938",
      "text": "你应该不会只想做个好人",
      "translation": null
    },
    {
      "time": 111.864,
      "time_str": "01:51.864",
      "text": "喔 算了吧",
      "translation": null
    },
    {
      "time": 115.045,
      "time_str": "01:55.045",
      "text": "就这样忘了吧 该放就放",
      "translation": null
    },
    {
      "time": 120.278,
      "time_str": "02:00.278",
      "text": "再想也没有用",
      "translation": null
    },
    {
      "time": 122.638,
      "time_str": "02:02.638",
      "text": "傻傻等待 他也不会回来",
      "translation": null
    },
    {
      "time": 128.124,
      "time_str": "02:08.124",
      "text": "你总该为自己想想未来",
      "translation": null
    },
    {
