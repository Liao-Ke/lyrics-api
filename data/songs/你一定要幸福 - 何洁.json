  "lyrics": [
    {
      "time": 31.23,
      "time_str": "00:31.230",
      "text": "沿着路灯一个人走回家",
      "translation": null
    },
    {
      "time": 37.9,
      "time_str": "00:37.900",
      "text": "和老朋友打电话",
      "translation": null
    },
    {
      "time": 44.04,
      "time_str": "00:44.040",
      "text": "你那里天气好吗",
      "translation": null
    },
    {
      "time": 49.68,
      "time_str": "00:49.680",
      "text": "有什么新闻可以当作笑话",
      "translation": null
    },
    {
      "time": 57.93,
      "time_str": "00:57.930",
      "text": "回忆与我都不爱说话",
      "translation": null
    },
    {
      "time": 64.7,
      "time_str": "01:04.700",
      "text": "偶尔我会想起他",
      "translation": null
    },
    {
      "time": 71.0,
      "time_str": "01:11.000",
      "text": "心里有一些牵挂",
      "translation": null
    },
    {
      "time": 76.15,
      "time_str": "01:16.150",
      "text": "有些爱却不得不",
      "translation": null
    },
    {
      "time": 79.33,
      "time_str": "01:19.330",
      "text": "各安天涯",
      "translation": null
    },
    {
      "time": 85.67,
      "time_str": "01:25.670",
      "text": "在夜深人静的时候想起他",
      "translation": null
    },
    {
      "time": 92.08,
      "time_str": "01:32.080",
      "text": "送的那些花",
      "translation": null
    },
    {
      "time": 94.55,
      "time_str": "01:34.550",
      "text": "还说过一些撕心裂肺的情话",
      "translation": null
    },
    {
      "time": 101.64,
      "time_str": "01:41.640",
      "text": "赌一把幸福的筹码",
      "translation": null
    },
    {
      "time": 105.69,
      "time_str": "01:45.690",
      "text": "在人来人往的街头",
      "translation": null
    },
    {
      "time": 109.4,
      "time_str": "01:49.400",
      "text": "想起他他现在好吗",
      "translation": null
    },
    {
      "time": 114.44,
      "time_str": "01:54.440",
      "text": "可我没有能给你想要的回答",
      "translation": null
    },
    {
      "time": 121.57,
      "time_str": "02:01.570",
      "text": "可是你一定要",
      "translation": null
    },
    {
      "time": 126.24,
      "time_str": "02:06.240",
      "text": "幸福啊",
      "translation": null
    },
