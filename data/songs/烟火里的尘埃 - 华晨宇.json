  "lyrics": [
    {
      "time": 2.643,
      "time_str": "00:02.643",
      "text": "SP: Warner/Chappell Music Publishing Agency(Beijing)Ltd.",
      "translation": null
    },
    {
      "time": 3.343,
      "time_str": "00:03.343",
      "text": "SP: 百代音乐版权代理(北京)有限公司(EMI Music Publishing China)",
      "translation": null
    },
    {
      "time": 4.543,
      "time_str": "00:04.543",
      "text": "看着飞舞的尘埃掉下来",
      "translation": null
    },
    {
      "time": 14.81,
      "time_str": "00:14.810",
      "text": "没人发现它存在",
      "translation": null
    },
    {
      "time": 18.061,
      "time_str": "00:18.061",
      "text": "多自由自在",
      "translation": null
    },
    {
      "time": 23.245,
      "time_str": "00:23.245",
      "text": "可世界都爱热热闹闹",
      "translation": null
    },
    {
      "time": 27.057,
      "time_str": "00:27.057",
      "text": "容不下我百无聊赖",
      "translation": null
    },
    {
      "time": 34.131,
      "time_str": "00:34.131",
      "text": "不应该一个人发呆",
      "translation": null
    },
    {
      "time": 44.628,
      "time_str": "00:44.628",
      "text": "只有我守着安静的沙漠",
      "translation": null
    },
    {
      "time": 49.286,
      "time_str": "00:49.286",
      "text": "等待着花开",
      "translation": null
    },
    {
      "time": 55.046,
      "time_str": "00:55.046",
      "text": "只有我看着别人的快乐",
      "translation": null
    },
    {
      "time": 59.874,
      "time_str": "00:59.874",
      "text": "竟然会感慨",
      "translation": null
    },
    {
      "time": 65.448,
      "time_str": "01:05.448",
      "text": "就让我听着天大的道理",
      "translation": null
    },
    {
      "time": 70.019,
      "time_str": "01:10.019",
      "text": "不愿意明白",
      "translation": null
    },
    {
      "time": 75.426,
      "time_str": "01:15.426",
      "text": "有什么是应该不应该",
      "translation": null
    },
    {
      "time": 107.209,
      "time_str": "01:47.209",
      "text": "我的心里住着一个",
      "translation": null
    },
    {
      "time": 110.068,
      "time_str": "01:50.068",
      "text": "苍老的小孩",
      "translation": null
    },
    {
      "time": 116.878,
      "time_str": "01:56.878",
      "text": "如果世界听不明白",
      "translation": null
    },
    {
      "time": 120.524,
      "time_str": "02:00.524",
      "text": "对影子表白",
      "translation": null
    },
    {
      "time": 125.305,
      "time_str": "02:05.305",
      "text": "是不是只有我还在问",
      "translation": null
    },
    {
      "time": 128.857,
      "time_str": "02:08.857",
      "text": "为什么明天更精彩",
      "translation": null
    },
    {
      "time": 136.251,
      "time_str": "02:16.251",
      "text": "烟火里找不到童真的残骸",
      "translation": null
    },
    {
      "time": 146.411,
      "time_str": "02:26.411",
      "text": "只有我守着安静的沙漠",
      "translation": null
    },
    {
      "time": 150.871,
      "time_str": "02:30.871",
      "text": "等待着花开",
      "translation": null
    },
    {
      "time": 156.229,
