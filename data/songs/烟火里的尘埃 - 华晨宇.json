      "text": "只有我看着别人的快乐",
      "translation": null
    },
    {
      "time": 160.853,
      "time_str": "02:40.853",
      "text": "竟然会感慨",
      "translation": null
    },
    {
      "time": 166.388,
      "time_str": "02:46.388",
      "text": "就让我听着天大的道理",
      "translation": null
    },
    {
      "time": 170.95,
      "time_str": "02:50.950",
      "text": "不愿意明白",
      "translation": null
    },
    {
      "time": 176.628,
      "time_str": "02:56.628",
      "text": "只有我就是我好奇怪",
      "translation": null
    },
    {
      "time": 181.407,
      "time_str": "03:01.407",
      "text": "我还在感慨",
      "translation": null
    },
    {
      "time": 193.162,
      "time_str": "03:13.162",
      "text": "风阵阵吹过来为何不回来",
      "translation": null
    },
    {
      "time": 203.155,
      "time_str": "03:23.155",
      "text": "风一去不回来悲不悲哀",
      "translation": null
    },
    {
      "time": 213.337,
      "time_str": "03:33.337",
      "text": "麻木得那么快应不应该",
      "translation": null
    },
    {
      "time": 223.43,
      "time_str": "03:43.430",
      "text": "能不能慢下来",
      "translation": null
    },
    {
      "time": 228.789,
      "time_str": "03:48.789",
      "text": "笑得开怀哭得坦率",
      "translation": null
    },
    {
      "time": 233.937,
      "time_str": "03:53.937",
      "text": "为何表情要让这世界安排",
      "translation": null
    },
    {
      "time": 239.08,
      "time_str": "03:59.080",
      "text": "我就是我我只是我",
      "translation": null
    },
    {
      "time": 243.528,
      "time_str": "04:03.528",
      "text": "只是一场烟火散落的尘埃",
      "translation": null
    },
    {
      "time": 261.173,
      "time_str": "04:21.173",
      "text": "风阵阵吹过来",
      "translation": null
    },
    {
      "time": 271.502,
