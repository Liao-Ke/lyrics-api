    {
      "time": 30.91,
      "time_str": "00:30.910",
      "text": "把犹豫 把回忆 从手机里删去",
      "translation": null
    },
    {
      "time": 34.49,
      "time_str": "00:34.490",
      "text": "没信任 的感情 像夜没有星星",
      "translation": null
    },
    {
      "time": 38.05,
      "time_str": "00:38.050",
      "text": "第一次 第二次 已经够了",
      "translation": null
    },
    {
      "time": 41.0,
      "time_str": "00:41.000",
      "text": "别再敲痛我的心",
      "translation": null
    },
    {
      "time": 45.11,
      "time_str": "00:45.110",
      "text": "不联系 不回应 现在适合安静",
      "translation": null
    },
    {
      "time": 48.61,
      "time_str": "00:48.610",
      "text": "怕失控 怕泄密 部落格不更新",
      "translation": null
    },
    {
      "time": 52.14,
      "time_str": "00:52.140",
      "text": "难过并 不需要 公开演出来博取关心",
      "translation": null
    },
    {
      "time": 57.09,
      "time_str": "00:57.090",
      "text": "只想喝着音乐 大口吞下情绪",
      "translation": null
    },
    {
      "time": 65.95,
      "time_str": "01:05.950",
      "text": "一整夜",
      "translation": null
    },
    {
      "time": 66.69,
      "time_str": "01:06.690",
      "text": "La La La 在矛盾里面",
      "translation": null
    },
    {
      "time": 70.18,
      "time_str": "01:10.180",
      "text": "La La La 看离线留言",
      "translation": null
    },
    {
      "time": 73.74,
      "time_str": "01:13.740",
      "text": "La La La 我并没有哭 却滴下眼泪",
      "translation": null
    },
    {
      "time": 80.16,
      "time_str": "01:20.160",
      "text": "一整天",
      "translation": null
    },
    {
      "time": 80.84,
      "time_str": "01:20.840",
      "text": "La La La 你翻遍世界",
      "translation": null
    },
    {
      "time": 84.31,
      "time_str": "01:24.310",
      "text": "La La La 狂Call 狂留言",
