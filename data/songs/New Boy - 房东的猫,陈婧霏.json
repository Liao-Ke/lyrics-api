    {
      "time": 25.189,
      "time_str": "00:25.189",
      "text": "是的我看见到处是阳光",
      "translation": null
    },
    {
      "time": 29.156,
      "time_str": "00:29.156",
      "text": "快乐在城市上空飘扬",
      "translation": null
    },
    {
      "time": 32.773,
      "time_str": "00:32.773",
      "text": "新世界来得像梦一样",
      "translation": null
    },
    {
      "time": 36.689,
      "time_str": "00:36.689",
      "text": "让我暖洋洋",
      "translation": null
    },
    {
      "time": 40.122,
      "time_str": "00:40.122",
      "text": "你的老怀表还在转吗",
      "translation": null
    },
    {
      "time": 43.822,
      "time_str": "00:43.822",
      "text": "你的旧皮鞋还能穿吗",
      "translation": null
    },
    {
      "time": 47.506,
      "time_str": "00:47.506",
      "text": "这儿有一支未来牌香烟",
      "translation": null
    },
    {
      "time": 51.479,
      "time_str": "00:51.479",
      "text": "你不想尝尝吗",
      "translation": null
    },
    {
      "time": 54.512,
      "time_str": "00:54.512",
      "text": "明天一早 我猜阳光会好",
      "translation": null
    },
    {
      "time": 62.679,
      "time_str": "01:02.679",
      "text": "我要把自己打扫",
      "translation": null
    },
    {
      "time": 65.896,
      "time_str": "01:05.896",
      "text": "把破旧的全部卖掉",
      "translation": null
    },
    {
      "time": 69.212,
      "time_str": "01:09.212",
      "text": "哦这样多好 快来吧奔腾电脑",
      "translation": null
    },
    {
      "time": 77.329,
      "time_str": "01:17.329",
      "text": "就让它们代替我来思考",
      "translation": null
    },
    {
      "time": 87.229,
      "time_str": "01:27.229",
      "text": "穿新衣吧 剪新发型呀",
      "translation": null
    },
    {
      "time": 91.347,
      "time_str": "01:31.347",
      "text": "轻松一下Windows98",
      "translation": null
    },
    {
      "time": 95.048,
      "time_str": "01:35.048",
      "text": "打扮漂亮 18岁是天堂",
      "translation": null
    },
    {
