  "lyrics": [
    {
      "time": 1.912,
      "time_str": "00:01.912",
      "text": "原唱：孙楠&韩红",
      "translation": null
    },
    {
      "time": 15.646,
      "time_str": "00:15.646",
      "text": "梦中人 熟悉的脸孔",
      "translation": null
    },
    {
      "time": 22.389,
      "time_str": "00:22.389",
      "text": "你是我守候的温柔",
      "translation": null
    },
    {
      "time": 28.077,
      "time_str": "00:28.077",
      "text": "就算泪水淹没天地",
      "translation": null
    },
    {
      "time": 37.15,
      "time_str": "00:37.150",
      "text": "我不会放手",
      "translation": null
    },
    {
      "time": 44.665,
      "time_str": "00:44.665",
      "text": "每一刻 孤独的承受",
      "translation": null
    },
    {
      "time": 51.96,
      "time_str": "00:51.960",
      "text": "只因我曾许下承诺",
      "translation": null
    },
    {
      "time": 58.874,
      "time_str": "00:58.874",
      "text": "你我之间熟悉的感动",
      "translation": null
    },
    {
      "time": 65.848,
      "time_str": "01:05.848",
      "text": "爱就要苏醒",
      "translation": null
    },
    {
      "time": 74.119,
      "time_str": "01:14.119",
      "text": "万世沧桑 唯有爱是永远的神话",
      "translation": null
    },
    {
      "time": 80.567,
      "time_str": "01:20.567",
      "text": "潮起潮落 始终不悔真爱的相约",
      "translation": null
    },
    {
      "time": 88.087,
      "time_str": "01:28.087",
      "text": "几番苦痛的纠缠 多少黑夜挣扎",
      "translation": null
    },
    {
      "time": 95.585,
      "time_str": "01:35.585",
      "text": "紧握双手 让我和你再也不离分",
      "translation": null
    },
    {
      "time": 118.62,
      "time_str": "01:58.620",
      "text": "枕上雪 冰封的爱恋",
      "translation": null
    },
    {
      "time": 125.789,
      "time_str": "02:05.789",
      "text": "真心相拥才能融解",
      "translation": null
    },
    {
      "time": 132.978,
      "time_str": "02:12.978",
      "text": "风中摇曳炉上的火",
      "translation": null
    },
    {
      "time": 140.467,
      "time_str": "02:20.467",
      "text": "不灭亦不休",
      "translation": null
    },
    {
      "time": 147.736,
      "time_str": "02:27.736",
      "text": "等待花开 春去春又来",
      "translation": null
    },
    {
      "time": 154.486,
      "time_str": "02:34.486",
      "text": "（等待花 春去春又来）",
      "translation": null
    },
    {
      "time": 155.529,
      "time_str": "02:35.529",
      "text": "无情岁月笑我痴狂",
      "translation": null
    },
    {
      "time": 162.248,
      "time_str": "02:42.248",
      "text": "心如钢铁 任世界荒芜",
      "translation": null
    },
    {
      "time": 170.694,
      "time_str": "02:50.694",
      "text": "思念永相随",
      "translation": null
    },
    {
      "time": 177.174,
      "time_str": "02:57.174",
      "text": "万世沧桑 唯有爱是永远的神话",
      "translation": null
    },
    {
      "time": 184.097,
      "time_str": "03:04.097",
      "text": "潮起潮落 始终不悔真爱的相约",
      "translation": null
    },
    {
      "time": 191.374,
      "time_str": "03:11.374",
      "text": "几番苦痛的纠缠 多少黑夜挣扎",
      "translation": null
    },
    {
      "time": 198.92,
      "time_str": "03:18.920",
      "text": "紧握双手 让我和你再也不离分",
      "translation": null
    },
    {
      "time": 206.975,
      "time_str": "03:26.975",
      "text": "你是我心中唯一 美丽的神话",
      "translation": null
    }
  ],
