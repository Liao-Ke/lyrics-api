    {
      "time": 114.373,
      "time_str": "01:54.373",
      "text": "潘：",
      "translation": null
    },
    {
      "time": 114.53,
      "time_str": "01:54.530",
      "text": "In this life our love is in our hearts to see",
      "translation": null
    },
    {
      "time": 117.087,
      "time_str": "01:57.087",
      "text": "Though people change the future's still inside of me",
      "translation": null
    },
    {
      "time": 119.794,
      "time_str": "01:59.794",
      "text": "We must remember that tomorrow  comes after the dark",
      "translation": null
    },
    {
      "time": 122.454,
      "time_str": "02:02.454",
      "text": "But I got something trapped in my heart",
      "translation": null
