    {
      "time": 0.28,
      "time_str": "00:00.280",
      "text": "rap作词人：潘玮柏",
      "translation": null
    },
    {
      "time": 0.348,
      "time_str": "00:00.348",
      "text": "Where you going?",
      "translation": null
    },
    {
      "time": 1.193,
      "time_str": "00:01.193",
      "text": "Going out",
      "translation": null
    },
    {
      "time": 2.518,
      "time_str": "00:02.518",
      "text": "With who?",
      "translation": null
    },
    {
      "time": 3.814,
      "time_str": "00:03.814",
      "text": "It's none of your business, OK?",
      "translation": null
    },
    {
      "time": 5.956,
      "time_str": "00:05.956",
      "text": "Would you gonna do it later?",
      "translation": null
    },
    {
      "time": 7.482,
      "time_str": "00:07.482",
      "text": "Stop acting like you care about me",
      "translation": null
    },
    {
      "time": 9.308,
      "time_str": "00:09.308",
      "text": "Stop acting like you wanna know something about me",
      "translation": null
    },
    {
      "time": 11.1,
      "time_str": "00:11.100",
      "text": "You don't know nothings, you don't care!",
      "translation": null
    },
    {
      "time": 13.175,
      "time_str": "00:13.175",
      "text": "Stop asking!",
      "translation": null
    },
    {
      "time": 15.62,
      "time_str": "00:15.620",
      "text": "I care...",
      "translation": null
    },
    {
      "time": 28.028,
      "time_str": "00:28.028",
      "text": "苏：",
      "translation": null
    },
    {
      "time": 28.52,
      "time_str": "00:28.520",
      "text": "每次我想更懂你",
      "translation": null
    },
    {
      "time": 30.889,
      "time_str": "00:30.889",
      "text": "我们却更有距离",
      "translation": null
    },
    {
      "time": 33.285,
      "time_str": "00:33.285",
      "text": "是不是都用错言语",
      "translation": null
    },
    {
      "time": 36.499,
      "time_str": "00:36.499",
      "text": "也用错了表情",
      "translation": null
    },
    {
      "time": 39.297,
      "time_str": "00:39.297",
      "text": "其实我想更懂你",
      "translation": null
    },
    {
      "time": 41.662,
      "time_str": "00:41.662",
      "text": "不是为了抓紧你",
      "translation": null
    },
    {
      "time": 44.104,
      "time_str": "00:44.104",
      "text": "我只是怕你会忘记",
      "translation": null
    },
    {
      "time": 47.004,
      "time_str": "00:47.004",
      "text": "有人永远爱着你",
      "translation": null
    },
    {
      "time": 51.907,
      "time_str": "00:51.907",
      "text": "爱你 woo...",
      "translation": null
    },
    {
      "time": 60.336,
      "time_str": "01:00.336",
      "text": "潘：",
      "translation": null
    },
    {
      "time": 60.546,
      "time_str": "01:00.546",
      "text": "请你听听我的真心话",
      "translation": null
    },
    {
      "time": 62.41,
      "time_str": "01:02.410",
      "text": "你每天看着我长大",
      "translation": null
    },
    {
      "time": 63.868,
      "time_str": "01:03.868",
      "text": "但你是否了解我内心矛盾的对话",
      "translation": null
    },
    {
      "time": 66.436,
      "time_str": "01:06.436",
      "text": "你板着脸孔不屑的对着我看",
      "translation": null
    },
    {
      "time": 68.746,
      "time_str": "01:08.746",
      "text": "我的视线没有勇气",
      "translation": null
    },
    {
      "time": 69.976,
      "time_str": "01:09.976",
      "text": "只好面对冷冰冰的地板",
      "translation": null
    },
    {
      "time": 71.775,
      "time_str": "01:11.775",
      "text": "这就是你这就是我",
      "translation": null
    },
    {
      "time": 73.147,
      "time_str": "01:13.147",
      "text": "我们之间的互动",
      "translation": null
    },
    {
      "time": 74.66,
      "time_str": "01:14.660",
      "text": "何时开始慢慢加以冷藏加以冷冻",
      "translation": null
    },
    {
      "time": 77.113,
      "time_str": "01:17.113",
      "text": "我好想逃我好想躲进一个洞",
      "translation": null
    },
    {
      "time": 79.139,
      "time_str": "01:19.139",
      "text": "我需要真正了解我的人",
      "translation": null
    },
    {
      "time": 80.681,
      "time_str": "01:20.681",
      "text": "为我进行解救",
      "translation": null
    },
    {
      "time": 81.729,
      "time_str": "01:21.729",
      "text": "这就是我的内心请你仔细的剖 (苏：放弃一点自己)",
      "translation": null
    },
    {
      "time": 84.452,
      "time_str": "01:24.452",
      "text": "我试过好多次的机会想要触碰你手",
      "translation": null
    },
    {
      "time": 87.355,
      "time_str": "01:27.355",
      "text": "课本写说你们应是我最好的朋友 (苏：开始慢慢懂你)",
      "translation": null
    },
    {
      "time": 90.145,
      "time_str": "01:30.145",
      "text": "但是显然不是我叙述我的故事",
      "translation": null
    },
    {
      "time": 93.029,
      "time_str": "01:33.029",
      "text": "苏：",
      "translation": null
    },
    {
      "time": 93.247,
      "time_str": "01:33.247",
      "text": "每次我想更懂你",
      "translation": null
    },
    {
      "time": 95.586,
      "time_str": "01:35.586",
      "text": "我们却更有距离",
      "translation": null
    },
    {
      "time": 97.87,
      "time_str": "01:37.870",
      "text": "是不是都用错言语",
      "translation": null
    },
    {
      "time": 101.178,
      "time_str": "01:41.178",
      "text": "也用错了表情",
      "translation": null
    },
    {
      "time": 103.969,
      "time_str": "01:43.969",
      "text": "其实我想更懂你",
      "translation": null
    },
    {
      "time": 106.344,
      "time_str": "01:46.344",
      "text": "不是为了抓紧你",
      "translation": null
    },
    {
      "time": 108.758,
      "time_str": "01:48.758",
      "text": "我只是怕你会忘记",
      "translation": null
