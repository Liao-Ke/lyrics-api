  "lyrics": [
    {
      "time": 29.35,
      "time_str": "00:29.350",
      "text": "人间 宝刀出鞘 一出手高低揭晓",
      "translation": null
    },
    {
      "time": 36.03,
      "time_str": "00:36.030",
      "text": "情天 爱中有恨 真心跟假意难料",
      "translation": null
    },
    {
      "time": 43.4,
      "time_str": "00:43.400",
      "text": "人海 可泣可笑 斩不开恩多怨少",
      "translation": null
    },
    {
      "time": 50.5,
      "time_str": "00:50.500",
      "text": "情关 似非似是 想不出一式半招",
      "translation": null
    },
    {
      "time": 57.63,
      "time_str": "00:57.630",
      "text": ".",
      "translation": null
    },
    {
      "time": 58.65,
      "time_str": "00:58.650",
      "text": "刀剑若梦 恩怨似风有没有轻重",
      "translation": null
    },
    {
      "time": 62.67,
      "time_str": "01:02.670",
      "text": "只要情浓 不要武功爱恨两难容",
      "translation": null
    },
    {
      "time": 66.5,
      "time_str": "01:06.500",
      "text": "只怕热泪 不怕刀锋 手中有剑 眼前有你",
      "translation": null
    },
    {
      "time": 69.96,
      "time_str": "01:09.960",
      "text": "偏偏都一一扑空",
