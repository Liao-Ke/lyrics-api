  "lyrics": [
    {
      "time": 33.1,
      "time_str": "00:33.100",
      "text": "深海中 那点光 昏暗的诱惑",
      "translation": null
    },
    {
      "time": 40.94,
      "time_str": "00:40.940",
      "text": "她以为 抓得住 名为爱的泡沫",
      "translation": null
    },
    {
      "time": 48.71,
      "time_str": "00:48.710",
      "text": "人心 扑朔 晦涩 幽蓝如墨",
      "translation": null
    },
    {
      "time": 56.52,
      "time_str": "00:56.520",
      "text": "怎么 猜透 看透 故事的结果",
      "translation": null
    },
    {
      "time": 80.06,
      "time_str": "01:20.060",
      "text": "为何绚烂 叫人扑空",
      "translation": null
    },
    {
      "time": 84.04,
      "time_str": "01:24.040",
      "text": "为何爱我者予我牢笼",
      "translation": null
    },
    {
      "time": 88.07,
      "time_str": "01:28.070",
      "text": "为何等待 都徒劳无功",
      "translation": null
    },
    {
      "time": 91.95,
      "time_str": "01:31.950",
      "text": "为何囚人者也像困兽（为什么）",
      "translation": null
    },
    {
      "time": 96.79,
      "time_str": "01:36.790",
      "text": "越珍贵 越浪费",
      "translation": null
    },
    {
      "time": 100.77,
      "time_str": "01:40.770",
      "text": "致命的伤 诞生于亲密",
      "translation": null
    },
    {
      "time": 105.03,
      "time_str": "01:45.030",
      "text": "越追问 越无解",
      "translation": null
    },
    {
      "time": 108.85,
      "time_str": "01:48.850",
      "text": "哪有答案 不过是咒语",
      "translation": null
    },
    {
      "time": 114.39,
      "time_str": "01:54.390",
      "text": "都在笼中",
      "translation": null
    },
    {
      "time": 131.93,
      "time_str": "02:11.930",
      "text": "出口就 在身后 只需要回头",
      "translation": null
    },
    {
      "time": 140.03,
      "time_str": "02:20.030",
      "text": "为什么 人们却 亲手上一把锁",
      "translation": null
    },
    {
      "time": 147.71,
      "time_str": "02:27.710",
      "text": "不甘 不得 不休 囚人自囚",
      "translation": null
