  "lyrics": [
    {
      "time": 20.887,
      "time_str": "00:20.887",
      "text": "Jcool：",
      "translation": null
    },
    {
      "time": 21.043,
      "time_str": "00:21.043",
      "text": "有个女仔令我思想变得大个",
      "translation": null
    },
    {
      "time": 23.551,
      "time_str": "00:23.551",
      "text": "当初",
      "translation": null
    },
    {
      "time": 24.469,
      "time_str": "00:24.469",
      "text": "我幼稚行为对你犯下大错",
      "translation": null
    },
    {
      "time": 26.432,
      "time_str": "00:26.432",
      "text": "你话我唔识谂 用钱买无用饰品",
      "translation": null
    },
    {
      "time": 28.896,
      "time_str": "00:28.896",
      "text": "你慢慢心淡觉得我对感情唔认真",
      "translation": null
    },
    {
      "time": 31.597,
      "time_str": "00:31.597",
      "text": "要知道男人系天生嘅小朋友",
      "translation": null
    },
    {
      "time": 34.198,
      "time_str": "00:34.198",
      "text": "小朋友弱点会忽略另一半感受",
      "translation": null
    },
    {
      "time": 36.806,
      "time_str": "00:36.806",
      "text": "要改正好简单我只系欠调教",
      "translation": null
    },
    {
      "time": 39.407,
      "time_str": "00:39.407",
      "text": "经历得多反而可以令到爱意浓厚",
      "translation": null
    },
    {
      "time": 41.972,
      "time_str": "00:41.972",
      "text": "Vai：",
      "translation": null
    },
    {
      "time": 42.107,
      "time_str": "00:42.107",
      "text": "志明慨世界永远好动带着可爱",
      "translation": null
    },
    {
      "time": 44.365,
      "time_str": "00:44.365",
      "text": "佢冇时间迷茫 爱情错过却唔可再",
      "translation": null
    },
    {
      "time": 46.922,
      "time_str": "00:46.922",
      "text": "从开始走到结尾哪个不会变大个",
      "translation": null
    },
    {
      "time": 49.434,
      "time_str": "00:49.434",
      "text": "但春娇想要那个你又有谁可以劝阻",
      "translation": null
    },
    {
      "time": 52.278,
      "time_str": "00:52.278",
      "text": "等待 UFO 纵有变数",
      "translation": null
    },
    {
      "time": 54.422,
      "time_str": "00:54.422",
      "text": "最普通嘅佢哋世上遍布",
      "translation": null
    },
    {
      "time": 57.078,
      "time_str": "00:57.078",
      "text": "爱漫春天散落每个季节慨消耗",
      "translation": null
    },
    {
      "time": 59.794,
      "time_str": "00:59.794",
      "text": "看着花瓣跌落过程撑得过衰老",
      "translation": null
    },
    {
      "time": 62.712,
      "time_str": "01:02.712",
      "text": "欧：",
      "translation": null
    },
    {
      "time": 63.665,
      "time_str": "01:03.665",
      "text": "重新出发吗 huh 更渴望未来",
      "translation": null
    },
    {
      "time": 68.127,
      "time_str": "01:08.127",
      "text": "以往这少年懂爱吗",
      "translation": null
    },
    {
      "time": 71.385,
      "time_str": "01:11.385",
      "text": "仿佛不够",
      "translation": null
    },
    {
      "time": 74.148,
      "time_str": "01:14.148",
      "text": "成长会进化吗 也信念自由",
      "translation": null
    },
    {
      "time": 78.583,
      "time_str": "01:18.583",
      "text": "我爱这少年讽刺吗",
      "translation": null
    },
    {
      "time": 81.869,
      "time_str": "01:21.869",
      "text": "这花开吗",
      "translation": null
    },
    {
      "time": 83.56,
      "time_str": "01:23.560",
      "text": "留：",
      "translation": null
    },
    {
      "time": 83.749,
      "time_str": "01:23.749",
      "text": "我爱你 你是唱将我做配合",
      "translation": null
    },
    {
      "time": 86.34,
      "time_str": "01:26.340",
      "text": "但你予我这过程细致给我培训",
      "translation": null
    },
    {
      "time": 88.941,
      "time_str": "01:28.941",
      "text": "情与爱 太过复杂 我要太多喘息",
      "translation": null
    },
    {
      "time": 91.578,
      "time_str": "01:31.578",
      "text": "但你爱我嘅以后不会太过忐忑",
      "translation": null
    },
    {
      "time": 94.186,
      "time_str": "01:34.186",
      "text": "当拥有慨时候 又接近放手",
      "translation": null
    },
    {
      "time": 96.795,
      "time_str": "01:36.795",
      "text": "循环播放剧情有多少个然后",
      "translation": null
    },
    {
      "time": 99.288,
      "time_str": "01:39.288",
      "text": "如果系现实我会选择打破现实",
      "translation": null
    },
    {
      "time": 101.431,
      "time_str": "01:41.431",
      "text": "喺你嘅世界里面我会选择慢慢渐入",
      "translation": null
    },
    {
