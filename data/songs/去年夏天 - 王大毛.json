  "lyrics": [
    {
      "time": 17.92,
      "time_str": "00:17.920",
      "text": "还有什么等待",
      "translation": null
    },
    {
      "time": 20.24,
      "time_str": "00:20.240",
      "text": "还有什么悲哀",
      "translation": null
    },
    {
      "time": 22.2,
      "time_str": "00:22.200",
      "text": "这故事中的人不太精彩",
      "translation": null
    },
    {
      "time": 25.8,
      "time_str": "00:25.800",
      "text": "夏去了又回来",
      "translation": null
    },
    {
      "time": 27.74,
      "time_str": "00:27.740",
      "text": "而人却已不在",
      "translation": null
    },
    {
      "time": 29.62,
      "time_str": "00:29.620",
      "text": "它重复着我汹涌的忍耐",
      "translation": null
    },
    {
      "time": 33.69,
      "time_str": "00:33.690",
      "text": "今年兰花又开",
      "translation": null
    },
    {
      "time": 35.52,
      "time_str": "00:35.520",
      "text": "开了它也会败",
      "translation": null
    },
    {
      "time": 37.65,
      "time_str": "00:37.650",
      "text": "我想要一个人活得精彩",
      "translation": null
    },
    {
      "time": 41.27,
      "time_str": "00:41.270",
      "text": "有些人总会来",
      "translation": null
    },
    {
      "time": 43.37,
      "time_str": "00:43.370",
      "text": "有些人在我心中在徘徊",
      "translation": null
    },
    {
      "time": 49.22,
      "time_str": "00:49.220",
      "text": "我拿了总会还",
      "translation": null
    },
    {
      "time": 51.0,
      "time_str": "00:51.000",
      "text": "你拿了就逃开",
      "translation": null
    },
    {
      "time": 53.08,
      "time_str": "00:53.080",
      "text": "在失去中我慢慢的变呆",
      "translation": null
    },
    {
      "time": 57.04,
      "time_str": "00:57.040",
      "text": "是不同步的未来",
      "translation": null
    },
    {
      "time": 60.92,
      "time_str": "01:00.920",
      "text": "却把书包中的日记更改",
      "translation": null
    },
    {
      "time": 64.72,
      "time_str": "01:04.720",
      "text": "把虚伪的尘埃",
      "translation": null
    },
    {
      "time": 66.36,
      "time_str": "01:06.360",
      "text": "也全部都掩盖",
      "translation": null
    },
    {
      "time": 68.51,
      "time_str": "01:08.510",
      "text": "把每次心痛都当成活该",
      "translation": null
    },
    {
      "time": 72.52,
      "time_str": "01:12.520",
      "text": "把心慢慢的释怀",
      "translation": null
    },
    {
      "time": 76.28,
      "time_str": "01:16.280",
      "text": "我相信总有一天你会明白",
      "translation": null
    },
    {
      "time": 80.13,
      "time_str": "01:20.130",
      "text": "我给你的爱",
      "translation": null
    },
    {
      "time": 82.1,
      "time_str": "01:22.100",
      "text": "我给你的爱",
      "translation": null
