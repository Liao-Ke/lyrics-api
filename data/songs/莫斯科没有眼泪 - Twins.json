    {
      "time": 17.19,
      "time_str": "00:17.190",
      "text": "冬天的离别",
      "translation": null
    },
    {
      "time": 19.25,
      "time_str": "00:19.250",
      "text": "在莫斯科的深夜",
      "translation": null
    },
    {
      "time": 23.67,
      "time_str": "00:23.670",
      "text": "一列列军队",
      "translation": null
    },
    {
      "time": 25.84,
      "time_str": "00:25.840",
      "text": "在街上森严戒备",
      "translation": null
    },
    {
      "time": 29.87,
      "time_str": "00:29.870",
      "text": "这里没人察觉",
      "translation": null
    },
    {
      "time": 32.42,
      "time_str": "00:32.420",
      "text": "谁又爱上了谁",
      "translation": null
    },
    {
      "time": 36.28,
      "time_str": "00:36.280",
      "text": "因为苦难不许人崩溃",
      "translation": null
    },
    {
      "time": 42.13,
      "time_str": "00:42.130",
      "text": "感情上若习惯防备",
      "translation": null
    },
    {
      "time": 45.0,
      "time_str": "00:45.000",
      "text": "寂寞就多一道墙围",
      "translation": null
    },
    {
      "time": 48.29,
      "time_str": "00:48.290",
      "text": "爱情隐隐约约",
      "translation": null
    },
    {
      "time": 50.29,
      "time_str": "00:50.290",
      "text": "提醒我这一回",
      "translation": null
    },
    {
      "time": 53.48,
      "time_str": "00:53.480",
      "text": "再不拥抱就是罪",
      "translation": null
    },
    {
      "time": 57.92,
      "time_str": "00:57.920",
      "text": "莫斯科没有眼泪",
      "translation": null
    },
    {
      "time": 60.04,
      "time_str": "01:00.040",
      "text": "大雪纷飞",
      "translation": null
    },
    {
      "time": 61.86,
      "time_str": "01:01.860",
      "text": "你冷的好憔悴",
      "translation": null
    },
    {
      "time": 64.24,
      "time_str": "01:04.240",
      "text": "单身的我",
      "translation": null
    },
    {
      "time": 65.83,
      "time_str": "01:05.830",
      "text": "原本以为",
      "translation": null
    },
    {
      "time": 67.77,
      "time_str": "01:07.770",
      "text": "可以一辈子不跟谁",
      "translation": null
    },
    {
      "time": 70.73,
      "time_str": "01:10.730",
      "text": "莫斯科没有眼泪",
      "translation": null
    },
    {
      "time": 72.59,
      "time_str": "01:12.590",
      "text": "我却流泪",
      "translation": null
    },
    {
      "time": 74.51,
      "time_str": "01:14.510",
      "text": "不住哭的赞美",
      "translation": null
    },
    {
      "time": 76.83,
      "time_str": "01:16.830",
      "text": "让我付出不怕心碎",
      "translation": null
    },
    {
      "time": 80.48,
      "time_str": "01:20.480",
      "text": "是你最好的美",
      "translation": null
