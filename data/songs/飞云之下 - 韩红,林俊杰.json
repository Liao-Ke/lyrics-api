  "lyrics": [
    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "人声录音 : 林俊杰/瞿然/Leonard Fong/李岳松/黄冠龙",
      "translation": null
    },
    {
      "time": 6.0,
      "time_str": "00:06.000",
      "text": "封面设计 : 方亮",
      "translation": null
    },
    {
      "time": 20.51,
      "time_str": "00:20.510",
      "text": "韩红：风 让云长出花 漫天的花",
      "translation": null
    },
    {
      "time": 27.1,
      "time_str": "00:27.100",
      "text": "无声开在乌云之下 然后 又飘到哪里呀",
      "translation": null
    },
    {
      "time": 36.6,
      "time_str": "00:36.600",
      "text": "喔",
      "translation": null
    },
    {
      "time": 37.98,
      "time_str": "00:37.980",
      "text": "林俊杰：漫步在人海的人 你过得好吗",
      "translation": null
    },
    {
      "time": 44.23,
      "time_str": "00:44.230",
      "text": "是不是又想念家",
      "translation": null
    },
    {
      "time": 48.75,
      "time_str": "00:48.750",
      "text": "心中那炙热的梦啊",
      "translation": null
    },
    {
      "time": 52.74,
      "time_str": "00:52.740",
      "text": "合：它多久没说话",
      "translation": null
    },
    {
      "time": 58.34,
      "time_str": "00:58.340",
      "text": "韩红：在飞云之下 以为忘了的家",
      "translation": null
    },
    {
      "time": 62.45,
      "time_str": "01:02.450",
      "text": "在耳里说话 叫我别烦心那些痛与怕",
      "translation": null
    },
    {
      "time": 69.14,
      "time_str": "01:09.140",
      "text": "林俊杰：喔 半路上的我 穿上回忆和风沙",
      "translation": null
    },
    {
      "time": 75.81,
      "time_str": "01:15.810",
      "text": "合：在飞云之下",
      "translation": null
    },
    {
      "time": 77.7,
      "time_str": "01:17.700",
      "text": "韩红：我看着海峡",
      "translation": null
    },
    {
      "time": 79.93,
      "time_str": "01:19.930",
      "text": "走月光沙滩 我也承认我还是会想他",
      "translation": null
    },
    {
      "time": 86.88,
      "time_str": "01:26.880",
      "text": "喔 且慢 前面听说风很大",
      "translation": null
    },
    {
      "time": 105.36,
      "time_str": "01:45.360",
      "text": "林俊杰：心 在云里摩擦 又酸又麻",
      "translation": null
    },
    {
      "time": 111.93,
      "time_str": "01:51.930",
      "text": "但是思念在梦里爬 以后 还有谁值得等吗",
      "translation": null
    },
    {
      "time": 122.11,
      "time_str": "02:02.110",
      "text": "喔",
      "translation": null
    },
    {
      "time": 123.07,
      "time_str": "02:03.070",
      "text": "韩红：孤单是件风衣 它裹起了怕",
      "translation": null
    },
    {
      "time": 129.39,
      "time_str": "02:09.390",
      "text": "然而我很勇敢啊",
      "translation": null
    },
    {
      "time": 133.68,
      "time_str": "02:13.680",
      "text": "没人记得我也没差",
      "translation": null
    },
    {
      "time": 137.89,
      "time_str": "02:17.890",
      "text": "合：未来在等我去拿",
      "translation": null
    },
    {
