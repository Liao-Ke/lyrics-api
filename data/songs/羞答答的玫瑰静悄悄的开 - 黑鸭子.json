  "lyrics": [
    {
      "time": 32.4,
      "time_str": "00:32.400",
      "text": "羞答答的玫瑰静悄悄的开",
      "translation": null
    },
    {
      "time": 37.71,
      "time_str": "00:37.710",
      "text": "慢慢的绽开她留给我的情怀",
      "translation": null
    },
    {
      "time": 42.93,
      "time_str": "00:42.930",
      "text": "春天的手呀翻阅她的等待",
      "translation": null
    },
    {
      "time": 47.49,
      "time_str": "00:47.490",
      "text": "我在暗暗思量该不该将她轻轻的摘",
      "translation": null
    },
    {
      "time": 53.28,
      "time_str": "00:53.280",
      "text": "羞答答的玫瑰静悄悄的开",
      "translation": null
    },
    {
      "time": 58.59,
      "time_str": "00:58.590",
      "text": "慢慢的燃烧她不承认的情怀",
      "translation": null
    },
    {
      "time": 63.75,
      "time_str": "01:03.750",
      "text": "春风的手呀试探她的等待",
      "translation": null
    },
    {
      "time": 68.34,
      "time_str": "01:08.340",
      "text": "我在暗暗犹豫该不该将她轻轻的摘",
      "translation": null
    },
    {
      "time": 76.8,
      "time_str": "01:16.800",
      "text": "怎么舍得如此接受你的爱",
      "translation": null
    },
    {
      "time": 82.02,
      "time_str": "01:22.020",
      "text": "从来喜欢都会被爱成悲哀",
      "translation": null
    },
    {
      "time": 87.24,
      "time_str": "01:27.240",
      "text": "怎么舍得如此揽你入胸怀",
      "translation": null
    },
    {
      "time": 92.49,
      "time_str": "01:32.490",
      "text": "当我越是深爱脾气就会越坏",
      "translation": null
    },
    {
      "time": 97.59,
      "time_str": "01:37.590",
      "text": "羞答答的玫瑰静悄悄的开",
      "translation": null
    },
    {
      "time": 102.93,
      "time_str": "01:42.930",
      "text": "慢慢的同时凋零同时盛开",
      "translation": null
    },
    {
      "time": 108.18,
      "time_str": "01:48.180",
      "text": "爱情的手呀抚过她的等待",
      "translation": null
    },
    {
      "time": 112.65,
      "time_str": "01:52.650",
      "text": "我在暗暗惆怅竟不曾将她轻轻的摘",
      "translation": null
    },
    {
