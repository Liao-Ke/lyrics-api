    },
    {
      "time": 155.7,
      "time_str": "02:35.700",
      "text": "在我和某某之前",
      "translation": null
    },
    {
      "time": 157.53,
      "time_str": "02:37.530",
      "text": "这里是谁的窝",
      "translation": null
    },
    {
      "time": 159.37,
      "time_str": "02:39.370",
      "text": "有谁比谁快活",
      "translation": null
    },
    {
      "time": 161.01,
      "time_str": "02:41.010",
      "text": "谁为谁而难过",
      "translation": null
    },
    {
      "time": 163.03,
      "time_str": "02:43.030",
      "text": "留下多少指纹",
      "translation": null
