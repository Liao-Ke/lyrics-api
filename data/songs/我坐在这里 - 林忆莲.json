  "lyrics": [
    {
      "time": 2.57,
      "time_str": "00:02.570",
      "text": "我坐在这里 看着时间溜过",
      "translation": null
    },
    {
      "time": 23.97,
      "time_str": "00:23.970",
      "text": "我怕我会爱上了 这个角落",
      "translation": null
    },
    {
      "time": 27.81,
      "time_str": "00:27.810",
      "text": "是它看着我日子 到底怎么样过",
      "translation": null
    },
    {
      "time": 31.67,
      "time_str": "00:31.670",
      "text": "人来人往地出没 有什么样的轮廓",
      "translation": null
    },
    {
      "time": 35.5,
      "time_str": "00:35.500",
      "text": "老房子若有话说 它会说什么",
      "translation": null
    },
    {
      "time": 39.44,
      "time_str": "00:39.440",
      "text": "有谁和谁的身影 影响我过什么",
      "translation": null
    },
    {
      "time": 43.27,
      "time_str": "00:43.270",
      "text": "有谁含情脉脉 让我惊心动魄",
      "translation": null
    },
    {
      "time": 47.04,
      "time_str": "00:47.040",
      "text": "窗口长了眼睛",
      "translation": null
    },
    {
      "time": 49.04,
      "time_str": "00:49.040",
      "text": "说不定拍下来 拿去广播",
      "translation": null
    },
    {
      "time": 54.82,
      "time_str": "00:54.820",
      "text": "我坐在这里 看着时间溜过",
      "translation": null
    },
    {
      "time": 58.98,
      "time_str": "00:58.980",
      "text": "我的心 会不会在这里停泊",
      "translation": null
    },
    {
      "time": 62.83,
      "time_str": "01:02.830",
      "text": "站在这里 会不会立地成佛",
      "translation": null
    },
    {
      "time": 66.65,
      "time_str": "01:06.650",
      "text": "躺在这里 会否夜长梦多",
      "translation": null
    },
    {
      "time": 70.28,
      "time_str": "01:10.280",
      "text": "我坐在这里 会否开花结果",
      "translation": null
    },
    {
      "time": 77.94,
      "time_str": "01:17.940",
      "text": "其实我讨厌 水龙头的回音",
      "translation": null
    },
    {
      "time": 81.83,
      "time_str": "01:21.830",
      "text": "滴滴答答地挑拨",
      "translation": null
    },
    {
      "time": 83.73,
      "time_str": "01:23.730",
      "text": "告诉我有多寂寞",
      "translation": null
    },
    {
      "time": 85.84,
      "time_str": "01:25.840",
      "text": "有谁和谁走过",
      "translation": null
    },
    {
      "time": 87.51,
      "time_str": "01:27.510",
      "text": "灯火一下下闪烁",
      "translation": null
    },
    {
      "time": 89.66,
      "time_str": "01:29.660",
      "text": "只有老房子记得 这些人的承诺",
      "translation": null
    },
    {
      "time": 93.58,
      "time_str": "01:33.580",
      "text": "听过谁的呼吸 像潮起潮落",
      "translation": null
    },
    {
      "time": 97.39,
      "time_str": "01:37.390",
      "text": "有某某的声音",
      "translation": null
    },
    {
      "time": 99.05,
      "time_str": "01:39.050",
      "text": "一句句地隐没",
      "translation": null
    },
    {
      "time": 101.17,
      "time_str": "01:41.170",
      "text": "窗帘长了耳朵",
      "translation": null
    },
    {
      "time": 103.21,
      "time_str": "01:43.210",
      "text": "说不定录下来 拿去广播",
      "translation": null
    },
    {
