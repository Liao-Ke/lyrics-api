    "arranger": null
  },
  "lyrics": [
    {
      "time": 22.75,
      "time_str": "00:22.750",
      "text": "谁能告诉我",
      "translation": null
    },
    {
      "time": 25.06,
      "time_str": "00:25.060",
      "text": "有没有这样的笔",
      "translation": null
    },
    {
      "time": 27.95,
      "time_str": "00:27.950",
      "text": "能画出一双双不流泪的眼睛",
      "translation": null
    },
    {
      "time": 34.15,
      "time_str": "00:34.150",
      "text": "留得住世上一纵即逝的光阴",
      "translation": null
    },
    {
      "time": 39.89,
      "time_str": "00:39.890",
      "text": "能让所有美丽从此也不再凋零",
      "translation": null
    },
    {
      "time": 45.57,
      "time_str": "00:45.570",
      "text": "如果是这样",
      "translation": null
    },
    {
      "time": 47.87,
      "time_str": "00:47.870",
      "text": "我可以安慰自己",
      "translation": null
    },
    {
      "time": 50.85,
      "time_str": "00:50.850",
      "text": "在没有你的夜里",
      "translation": null
    },
    {
      "time": 53.66,
      "time_str": "00:53.660",
      "text": "能画出一线光明",
      "translation": null
    },
    {
      "time": 56.91,
      "time_str": "00:56.910",
      "text": "留得住快乐",
      "translation": null
    },
    {
      "time": 59.37,
      "time_str": "00:59.370",
      "text": "全部都送去给你",
      "translation": null
    },
    {
      "time": 62.23,
      "time_str": "01:02.230",
      "text": "苦涩的味道变了甜蜜",
      "translation": null
    },
    {
      "time": 67.84,
      "time_str": "01:07.840",
      "text": "从此也不用分开相爱的天和地",
      "translation": null
    },
    {
      "time": 73.57,
      "time_str": "01:13.570",
      "text": "还能在同一天空月亮太阳再相遇",
      "translation": null
    },
    {
      "time": 79.2,
      "time_str": "01:19.200",
      "text": "生命中只要有你",
      "translation": null
    },
    {
      "time": 82.09,
      "time_str": "01:22.090",
      "text": "什么都变了可以",
      "translation": null
    },
    {
      "time": 84.95,
      "time_str": "01:24.950",
      "text": "让所有流星随时都相遇",
      "translation": null
    },
    {
      "time": 90.66,
      "time_str": "01:30.660",
      "text": "从此在人世上也没有无奈的分离",
      "translation": null
    },
    {
      "time": 96.3,
      "time_str": "01:36.300",
      "text": "我不用睁着眼睛看你远走的背影",
      "translation": null
    },
    {
      "time": 102.01,
      "time_str": "01:42.010",
      "text": "没有变坏的青春",
      "translation": null
    },
    {
      "time": 104.92,
      "time_str": "01:44.920",
      "text": "没有失落的爱情",
      "translation": null
    },
    {
      "time": 108.73,
      "time_str": "01:48.730",
      "text": "所有承诺永恒得像星星",
      "translation": null
    },
    {
