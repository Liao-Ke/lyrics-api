  "lyrics": [
    {
      "time": 0.5,
      "time_str": "00:00.500",
      "text": "扛住了 柴米油盐的麻烦",
      "translation": null
    },
    {
      "time": 4.167,
      "time_str": "00:04.167",
      "text": "扛住了 朋友聚会的调侃",
      "translation": null
    },
    {
      "time": 7.584,
      "time_str": "00:07.584",
      "text": "扛住了 世俗生活的刁难",
      "translation": null
    },
    {
      "time": 11.001,
      "time_str": "00:11.001",
      "text": "却扛不住",
      "translation": null
    },
    {
      "time": 12.735,
      "time_str": "00:12.735",
      "text": "对你的喜欢",
      "translation": null
    },
    {
      "time": 15.547,
      "time_str": "00:15.547",
      "text": "亦步亦趋 随你至深不可测",
      "translation": null
    },
    {
      "time": 18.897,
      "time_str": "00:18.897",
      "text": "患得患失 唯恐你遥不可得",
      "translation": null
    },
    {
      "time": 24.87,
      "time_str": "00:24.870",
      "text": "却只面不改色",
      "translation": null
    },
    {
      "time": 26.905,
      "time_str": "00:26.905",
      "text": "为你我认了",
      "translation": null
    },
    {
      "time": 29.304,
      "time_str": "00:29.304",
      "text": "一朝一夕 使我已固不可彻",
      "translation": null
    },
    {
      "time": 32.604,
      "time_str": "00:32.604",
      "text": "若即若离 本应是罪不可赦",
      "translation": null
    },
    {
      "time": 38.671,
      "time_str": "00:38.671",
      "text": "怎不忍心怪你",
      "translation": null
    },
    {
      "time": 40.687,
      "time_str": "00:40.687",
      "text": "对我太独特",
      "translation": null
    },
    {
      "time": 45.155,
      "time_str": "00:45.155",
      "text": "无时无刻",
      "translation": null
    },
    {
      "time": 48.504,
      "time_str": "00:48.504",
      "text": "像是一首",
      "translation": null
    },
    {
      "time": 49.352,
      "time_str": "00:49.352",
      "text": "无法停止单曲循环的无名歌",
      "translation": null
    },
