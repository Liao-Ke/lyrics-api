  "lyrics": [
    {
      "time": 18.39,
      "time_str": "00:18.390",
      "text": "今夜特别漫长",
      "translation": null
    },
    {
      "time": 21.46,
      "time_str": "00:21.460",
      "text": "有个号码一直被存放",
      "translation": null
    },
    {
      "time": 25.68,
      "time_str": "00:25.680",
      "text": "源自某种倔强",
      "translation": null
    },
    {
      "time": 30.07,
      "time_str": "00:30.070",
      "text": "不舍删去又不敢想",
      "translation": null
    },
    {
      "time": 33.26,
      "time_str": "00:33.260",
      "text": "明明对你念念不忘",
      "translation": null
    },
    {
      "time": 37.41,
      "time_str": "00:37.410",
      "text": "思前想后越发紧张",
      "translation": null
    },
    {
      "time": 41.38,
      "time_str": "00:41.380",
      "text": "无法深藏",
      "translation": null
    },
    {
      "time": 43.75,
      "time_str": "00:43.750",
      "text": "爱没爱过想听你讲",
      "translation": null
    },
    {
      "time": 48.61,
      "time_str": "00:48.610",
      "text": "讲真的",
      "translation": null
    },
    {
      "time": 51.38,
      "time_str": "00:51.380",
      "text": "会不会是我 被鬼迷心窍了",
      "translation": null
    },
    {
      "time": 54.96,
      "time_str": "00:54.960",
      "text": "敷衍了太多 我怎么不难过",
      "translation": null
    },
    {
      "time": 58.95,
      "time_str": "00:58.950",
      "text": "要你亲口说 别只剩沉默",
      "translation": null
    },
    {
      "time": 63.23,
      "time_str": "01:03.230",
      "text": "或许你早就回答了我",
      "translation": null
    },
    {
      "time": 66.89,
      "time_str": "01:06.890",
      "text": "讲真的",
      "translation": null
    },
    {
      "time": 68.24,
      "time_str": "01:08.240",
      "text": "想得不可得 是最难割舍的",
      "translation": null
    },
    {
      "time": 71.84,
      "time_str": "01:11.840",
      "text": "各自好好过 也好过一直拖",
      "translation": null
    },
    {
      "time": 75.9,
      "time_str": "01:15.900",
      "text": "自作多情了 好吧我认了",
      "translation": null
    },
    {
      "time": 79.81,
      "time_str": "01:19.810",
      "text": "至少能换来释怀洒脱",
      "translation": null
    },
    {
      "time": 83.25,
      "time_str": "01:23.250",
      "text": "没丢失掉自我",
      "translation": null
    },
