  "lyrics": [
    {
      "time": 23.19,
      "time_str": "00:23.190",
      "text": "一份爱能承受多少的误解",
      "translation": null
    },
    {
      "time": 30.25,
      "time_str": "00:30.250",
      "text": "熬过飘雪的冬天",
      "translation": null
    },
    {
      "time": 34.54,
      "time_str": "00:34.540",
      "text": "一句话能撕裂多深的牵连",
      "translation": null
    },
    {
      "time": 41.38,
      "time_str": "00:41.380",
      "text": "变的比陌生人还遥远",
      "translation": null
    },
    {
      "time": 45.98,
      "time_str": "00:45.980",
      "text": "最初的爱越像火焰",
      "translation": null
    },
    {
      "time": 50.26,
      "time_str": "00:50.260",
      "text": "最后越会被风熄灭",
      "translation": null
    },
    {
      "time": 57.04,
      "time_str": "00:57.040",
      "text": "有时候真话太尖锐",
      "translation": null
    },
    {
      "time": 61.4,
      "time_str": "01:01.400",
      "text": "有人只好说着谎言",
      "translation": null
    },
    {
      "time": 65.54,
      "time_str": "01:05.540",
      "text": "假如时光倒流 我能做什么",
      "translation": null
    },
    {
      "time": 71.79,
      "time_str": "01:11.790",
      "text": "找你没说的 却想要的",
      "translation": null
    },
    {
      "time": 77.22,
      "time_str": "01:17.220",
      "text": "假如我不放手 你多年以后",
      "translation": null
    },
    {
      "time": 82.96,
      "time_str": "01:22.960",
      "text": "会怪我恨我 或感动",
      "translation": null
    },
    {
      "time": 88.16,
      "time_str": "01:28.160",
      "text": "想假如 是最空虚的痛",
      "translation": null
    },
    {
      "time": 106.68,
      "time_str": "01:46.680",
      "text": "一个人要看过 几次爱凋谢",
      "translation": null
    },
    {
      "time": 113.7,
      "time_str": "01:53.700",
      "text": "才甘心在孤独里冬眠",
      "translation": null
    },
