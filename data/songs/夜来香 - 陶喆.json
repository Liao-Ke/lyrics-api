  "lyrics": [
    {
      "time": 9.762,
      "time_str": "00:09.762",
      "text": "那南风吹来清凉",
      "translation": null
    },
    {
      "time": 13.651,
      "time_str": "00:13.651",
      "text": "那夜莺啼声齐唱",
      "translation": null
    },
    {
      "time": 17.834,
      "time_str": "00:17.834",
      "text": "月下的花儿入梦",
      "translation": null
    },
    {
      "time": 20.582,
      "time_str": "00:20.582",
      "text": "只有那夜来香",
      "translation": null
    },
    {
      "time": 23.525,
      "time_str": "00:23.525",
      "text": "吐露着芬芳",
      "translation": null
    },
    {
      "time": 28.38,
      "time_str": "00:28.380",
      "text": "我爱这夜色茫茫",
      "translation": null
    },
    {
      "time": 32.333,
      "time_str": "00:32.333",
      "text": "也爱那夜莺歌唱",
      "translation": null
    },
    {
      "time": 36.376,
      "time_str": "00:36.376",
      "text": "更爱那花一般的梦",
      "translation": null
    },
    {
      "time": 39.48,
      "time_str": "00:39.480",
      "text": "拥抱着夜来香",
      "translation": null
    },
    {
      "time": 42.27,
      "time_str": "00:42.270",
      "text": "吻着夜来香",
      "translation": null
    },
    {
      "time": 47.344,
      "time_str": "00:47.344",
      "text": "夜来香",
      "translation": null
    },
    {
      "time": 50.923,
      "time_str": "00:50.923",
      "text": "我为你歌唱",
      "translation": null
    },
    {
      "time": 55.532,
      "time_str": "00:55.532",
      "text": "夜来香",
      "translation": null
    },
