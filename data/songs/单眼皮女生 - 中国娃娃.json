    {
      "time": 23.64,
      "time_str": "00:23.640",
      "text": "大错特错不要来 侮辱我的美",
      "translation": null
    },
    {
      "time": 27.6,
      "time_str": "00:27.600",
      "text": "我不是你的Style 为何天天缠着我",
      "translation": null
    },
    {
      "time": 31.01,
      "time_str": "00:31.010",
      "text": "特错不要来 侮辱我的美",
      "translation": null
    },
    {
      "time": 34.57,
      "time_str": "00:34.570",
      "text": "但要是你喜欢我 就快点大声说出来 Yeah！",
      "translation": null
    },
    {
      "time": 38.08,
      "time_str": "00:38.080",
      "text": "姐妹拿起电话 喂喂靠过来",
      "translation": null
    },
    {
      "time": 41.52,
      "time_str": "00:41.520",
      "text": "对面那桌男孩 今天又来 哼",
      "translation": null
    },
    {
      "time": 45.07,
      "time_str": "00:45.070",
      "text": "瞧瞧他的眼睛 超级有自信",
      "translation": null
    },
    {
      "time": 48.56,
      "time_str": "00:48.560",
      "text": "好像每个女生 都会上钩",
      "translation": null
    },
    {
      "time": 59.1,
      "time_str": "00:59.100",
      "text": "听说他爱的女生 只挑双眼皮",
      "translation": null
    },
    {
      "time": 62.53,
      "time_str": "01:02.530",
      "text": "但我的单眼皮 不能挑剔",
      "translation": null
    },
    {
      "time": 66.04,
      "time_str": "01:06.040",
      "text": "要爱就爱所有 包括妹妹头",
      "translation": null
    },
    {
      "time": 69.54,
      "time_str": "01:09.540",
      "text": "流行整个地球 Pretty China Doll",
      "translation": null
    },
    {
      "time": 73.23,
      "time_str": "01:13.230",
      "text": "我承认我已爱上他",
      "translation": null
    },
    {
      "time": 76.72,
      "time_str": "01:16.720",
      "text": "但是我的自尊不能随便卸下",
      "translation": null
    },
    {
