  "lyrics": [
    {
      "time": 16.02,
      "time_str": "00:16.020",
      "text": "梦里梦到醒不来的梦",
      "translation": null
    },
    {
      "time": 18.62,
      "time_str": "00:18.620",
      "text": "红线里被软禁的红",
      "translation": null
    },
    {
      "time": 23.32,
      "time_str": "00:23.320",
      "text": "所有刺激剩下疲乏的痛",
      "translation": null
    },
    {
      "time": 26.52,
      "time_str": "00:26.520",
      "text": "再无动于衷",
      "translation": null
    },
    {
      "time": 29.82,
      "time_str": "00:29.820",
      "text": "从背后抱你的时候",
      "translation": null
    },
    {
      "time": 33.72,
      "time_str": "00:33.720",
      "text": "期待的却是她的面容",
      "translation": null
    },
    {
      "time": 37.45,
      "time_str": "00:37.450",
      "text": "说来实在嘲讽我不太懂",
      "translation": null
    },
    {
      "time": 41.05,
      "time_str": "00:41.050",
      "text": "偏渴望你懂",
      "translation": null
    },
    {
      "time": 44.45,
      "time_str": "00:44.450",
      "text": "是否幸福轻得太沉重",
      "translation": null
    },
    {
      "time": 48.2,
      "time_str": "00:48.200",
      "text": "过度使用不痒不痛",
      "translation": null
    },
    {
      "time": 52.01,
      "time_str": "00:52.010",
      "text": "烂熟透红空洞了的瞳孔",
      "translation": null
    },
    {
      "time": 56.26,
      "time_str": "00:56.260",
      "text": "终于掏空终于有始无终",
      "translation": null
    },
    {
      "time": 59.51,
      "time_str": "00:59.510",
      "text": "得不到的永远在骚动",
      "translation": null
    },
    {
      "time": 63.109,
      "time_str": "01:03.109",
      "text": "被偏爱的都有恃无恐",
      "translation": null
    },
    {
      "time": 66.81,
      "time_str": "01:06.810",
      "text": "玫瑰的红容易受伤的梦",
      "translation": null
    },
    {
      "time": 71.159,
      "time_str": "01:11.159",
      "text": "握在手中却流失于指缝",
      "translation": null
    },
    {
      "time": 74.659,
      "time_str": "01:14.659",
      "text": "又落空",
      "translation": null
    },
    {
      "time": 90.72,
      "time_str": "01:30.720",
      "text": "红是朱砂痣烙印心口",
      "translation": null
    },
    {
      "time": 93.519,
      "time_str": "01:33.519",
      "text": "红是蚊子血般平庸",
      "translation": null
    },
    {
      "time": 98.43,
      "time_str": "01:38.430",
      "text": "时间美化那仅有的悸动",
      "translation": null
    },
    {
      "time": 101.519,
      "time_str": "01:41.519",
      "text": "也磨平激动",
      "translation": null
