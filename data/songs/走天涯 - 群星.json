  "lyrics": [
    {
      "time": 20.4,
      "time_str": "00:20.400",
      "text": "月亮依旧停在旷野上",
      "translation": null
    },
    {
      "time": 24.67,
      "time_str": "00:24.670",
      "text": "你的身影被越拉越长",
      "translation": null
    },
    {
      "time": 29.42,
      "time_str": "00:29.420",
      "text": "直到远去的马蹄声响",
      "translation": null
    },
    {
      "time": 34.05,
      "time_str": "00:34.050",
      "text": "呼唤你的歌声传四方",
      "translation": null
    },
    {
      "time": 38.43,
      "time_str": "00:38.430",
      "text": "举头望天只见雁两行",
      "translation": null
    },
    {
      "time": 42.81,
      "time_str": "00:42.810",
      "text": "低头泪水为我卸了妆",
      "translation": null
    },
    {
      "time": 47.4,
      "time_str": "00:47.400",
      "text": "伤心凭栏相思涂满墙",
      "translation": null
    },
    {
      "time": 51.88,
      "time_str": "00:51.880",
      "text": "彻夜无眠爱的路太长",
      "translation": null
    },
    {
      "time": 56.76,
      "time_str": "00:56.760",
      "text": "你的脚步流浪在天涯",
      "translation": null
    },
    {
      "time": 61.1,
      "time_str": "01:01.100",
      "text": "我的思念随你到远方",
      "translation": null
    },
    {
      "time": 65.49,
      "time_str": "01:05.490",
      "text": "谁的眼泪在月光中凝聚成了霜",
      "translation": null
    },
    {
      "time": 70.11,
      "time_str": "01:10.110",
      "text": "是你让我想你想断肠",
      "translation": null
    },
    {
      "time": 74.71,
      "time_str": "01:14.710",
      "text": "你的脚步流浪在天涯",
      "translation": null
    },
    {
      "time": 79.32,
      "time_str": "01:19.320",
      "text": "我的思念随你到远方",
      "translation": null
    },
    {
      "time": 83.74,
      "time_str": "01:23.740",
      "text": "如果今生不能与你结呀结成双",
      "translation": null
    },
    {
      "time": 88.17,
      "time_str": "01:28.170",
      "text": "来世化蝶依偎你身旁",
      "translation": null
    },
    {
      "time": 110.93,
      "time_str": "01:50.930",
      "text": "弹断琴弦诉不够离伤",
      "translation": null
    },
    {
      "time": 115.28,
      "time_str": "01:55.280",
      "text": "望穿秋水看不破情网",
      "translation": null
    },
    {
      "time": 119.88,
      "time_str": "01:59.880",
      "text": "岁月轮回带不走忧伤",
      "translation": null
    },
    {
      "time": 124.48,
      "time_str": "02:04.480",
      "text": "白雪苍茫盖不住惆怅",
      "translation": null
    },
    {
      "time": 129.21,
      "time_str": "02:09.210",
      "text": "原上枯荣飞逝的时光",
      "translation": null
    },
    {
      "time": 133.44,
      "time_str": "02:13.440",
      "text": "无奈岁月画鬓已如霜",
      "translation": null
    },
    {
      "time": 138.04,
      "time_str": "02:18.040",
      "text": "但求千里与你共婵娟",
      "translation": null
    },
    {
      "time": 142.55,
      "time_str": "02:22.550",
      "text": "天涯海角我都不能忘",
