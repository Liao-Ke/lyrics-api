    {
      "time": 23.92,
      "time_str": "00:23.920",
      "text": "曾看着同星空 闲聊吹风",
      "translation": null
    },
    {
      "time": 27.13,
      "time_str": "00:27.130",
      "text": "看日出多心动",
      "translation": null
    },
    {
      "time": 29.73,
      "time_str": "00:29.730",
      "text": "曾每日缠一起 傻傻讲起",
      "translation": null
    },
    {
      "time": 32.89,
      "time_str": "00:32.890",
      "text": "能爱到下世纪",
      "translation": null
    },
    {
      "time": 35.55,
      "time_str": "00:35.550",
      "text": "怎么你俘虏这个心",
      "translation": null
    },
    {
      "time": 37.08,
      "time_str": "00:37.080",
      "text": "却抽身退隐 不再亲近",
      "translation": null
    },
    {
      "time": 41.91,
      "time_str": "00:41.910",
      "text": "独自苦等 仍然空等",
      "translation": null
    },
    {
      "time": 44.47,
      "time_str": "00:44.470",
      "text": "难藏泪印",
      "translation": null
    },
    {
      "time": 47.86,
      "time_str": "00:47.860",
      "text": "看着 电话中短讯",
      "translation": null
    },
    {
      "time": 50.79,
      "time_str": "00:50.790",
      "text": "听着 录音的口讯",
      "translation": null
    },
    {
      "time": 53.64,
      "time_str": "00:53.640",
      "text": "昨天的你哪天再接近",
      "translation": null
    },
    {
      "time": 59.17,
      "time_str": "00:59.170",
      "text": "Tell me where did you go",
      "translation": null
    },
