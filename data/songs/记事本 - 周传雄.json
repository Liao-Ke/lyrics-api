  "lyrics": [
    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "原唱 : 陈慧琳",
      "translation": null
    },
    {
      "time": 24.17,
      "time_str": "00:24.170",
      "text": "翻开随身携带的记事本",
      "translation": null
    },
    {
      "time": 28.31,
      "time_str": "00:28.310",
      "text": "写着许多事都是关于你",
      "translation": null
    },
    {
      "time": 33.56,
      "time_str": "00:33.560",
      "text": "你讨厌被冷落",
      "translation": null
    },
    {
      "time": 36.72,
      "time_str": "00:36.720",
      "text": "习惯被守候",
      "translation": null
    },
    {
      "time": 39.66,
      "time_str": "00:39.660",
      "text": "寂寞才找我",
      "translation": null
    },
    {
      "time": 47.31,
      "time_str": "00:47.310",
      "text": "我看见自己写下的心情",
      "translation": null
    },
    {
      "time": 51.68,
      "time_str": "00:51.680",
      "text": "把自己放在卑微的后头",
      "translation": null
    },
    {
      "time": 57.28,
      "time_str": "00:57.280",
      "text": "等你等太久",
      "translation": null
    },
    {
      "time": 60.14,
      "time_str": "01:00.140",
      "text": "想你泪会流",
      "translation": null
    },
    {
      "time": 62.75,
      "time_str": "01:02.750",
      "text": "而幸福快乐是什么",
      "translation": null
    },
    {
      "time": 69.28,
      "time_str": "01:09.280",
      "text": "爱的痛了",
      "translation": null
    },
    {
      "time": 71.83,
      "time_str": "01:11.830",
      "text": "痛的哭了",
      "translation": null
    },
    {
      "time": 74.82,
      "time_str": "01:14.820",
      "text": "哭的累了",
      "translation": null
    },
    {
      "time": 76.07,
      "time_str": "01:16.070",
      "text": "日记本里页页执着",
      "translation": null
    },
    {
      "time": 80.31,
      "time_str": "01:20.310",
      "text": "记载着你的好",
      "translation": null
    },
    {
      "time": 83.25,
      "time_str": "01:23.250",
      "text": "像上瘾的毒药",
      "translation": null
    },
    {
      "time": 86.17,
      "time_str": "01:26.170",
      "text": "它反复骗着我",
      "translation": null
    },
    {
      "time": 92.12,
      "time_str": "01:32.120",
      "text": "爱的痛了",
      "translation": null
    },
    {
      "time": 95.27,
      "time_str": "01:35.270",
      "text": "痛的哭了",
      "translation": null
    },
    {
      "time": 98.23,
      "time_str": "01:38.230",
      "text": "哭的累了",
      "translation": null
    },
    {
      "time": 99.47,
      "time_str": "01:39.470",
      "text": "矛盾心里总是强求",
      "translation": null
    },
    {
      "time": 103.61,
      "time_str": "01:43.610",
      "text": "劝自己要放手",
      "translation": null
    },
    {
      "time": 106.66,
      "time_str": "01:46.660",
      "text": "闭上眼让你走",
      "translation": null
    },
    {
      "time": 109.59,
      "time_str": "01:49.590",
      "text": "烧掉日记重新来过",
      "translation": null
