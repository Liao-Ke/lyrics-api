    },
    {
      "time": 103.59,
      "time_str": "01:43.590",
      "text": "看到我的全心全意",
      "translation": null
    },
    {
      "time": 120.77,
      "time_str": "02:00.770",
      "text": "听你说你和你的他们",
      "translation": null
    },
    {
      "time": 124.44,
      "time_str": "02:04.440",
      "text": "暧昧的空气",
      "translation": null
    },
    {
      "time": 129.85,
      "time_str": "02:09.850",
      "text": "我和我的绝望",
      "translation": null
    },
    {
      "time": 131.82,
      "time_str": "02:11.820",
      "text": "装得很风趣",
      "translation": null
    },
    {
