  "lyrics": [
    {
      "time": 15.52,
      "time_str": "00:15.520",
      "text": "如果你眼神能够为我",
      "translation": null
    },
    {
      "time": 19.33,
      "time_str": "00:19.330",
      "text": "片刻的降临",
      "translation": null
    },
    {
      "time": 24.69,
      "time_str": "00:24.690",
      "text": "如果你能听到",
      "translation": null
    },
    {
      "time": 26.71,
      "time_str": "00:26.710",
      "text": "心碎的声音",
      "translation": null
    },
    {
      "time": 31.14,
      "time_str": "00:31.140",
      "text": "沉默的守护着你",
      "translation": null
    },
    {
      "time": 34.8,
      "time_str": "00:34.800",
      "text": "沉默的等奇迹",
      "translation": null
    },
    {
      "time": 37.53,
      "time_str": "00:37.530",
      "text": "沉默的让自己",
      "translation": null
    },
    {
      "time": 40.31,
      "time_str": "00:40.310",
      "text": "像是空气",
      "translation": null
    },
    {
      "time": 44.87,
      "time_str": "00:44.870",
      "text": "大家都吃着聊着笑着",
      "translation": null
    },
    {
      "time": 48.54,
      "time_str": "00:48.540",
      "text": "今晚多开心",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "最角落里的我",
      "translation": null
    },
    {
      "time": 56.07,
      "time_str": "00:56.070",
      "text": "笑得多合群",
      "translation": null
    },
    {
      "time": 60.53,
      "time_str": "01:00.530",
      "text": "盘底的洋葱像我",
      "translation": null
    },
    {
      "time": 64.2,
      "time_str": "01:04.200",
      "text": "永远是调味品",
      "translation": null
    },
    {
      "time": 66.98,
      "time_str": "01:06.980",
      "text": "偷偷的看着你",
      "translation": null
    },
    {
      "time": 69.94,
      "time_str": "01:09.940",
      "text": "偷偷的隐藏着自己",
      "translation": null
    },
    {
      "time": 75.78,
      "time_str": "01:15.780",
      "text": "如果你愿意一层一层",
      "translation": null
    },
    {
      "time": 79.12,
      "time_str": "01:19.120",
      "text": "一层地剥开我的心",
      "translation": null
    },
    {
      "time": 83.16,
      "time_str": "01:23.160",
      "text": "你会发现",
      "translation": null
    },
    {
      "time": 85.0,
      "time_str": "01:25.000",
      "text": "你会讶异",
      "translation": null
    },
    {
      "time": 86.76,
      "time_str": "01:26.760",
      "text": "你是我",
      "translation": null
    },
    {
      "time": 87.47,
      "time_str": "01:27.470",
      "text": "最压抑",
      "translation": null
    },
    {
      "time": 88.36,
      "time_str": "01:28.360",
      "text": "最深处的秘密",
      "translation": null
    },
    {
      "time": 90.63,
      "time_str": "01:30.630",
      "text": "如果你愿意一层一层",
      "translation": null
    },
    {
      "time": 93.82,
      "time_str": "01:33.820",
      "text": "一层地剥开我的心",
      "translation": null
