  "lyrics": [
    {
      "time": 18.0,
      "time_str": "00:18.000",
      "text": "说好了 不回头",
      "translation": null
    },
    {
      "time": 20.0,
      "time_str": "00:20.000",
      "text": "不想承诺 缘分尽了",
      "translation": null
    },
    {
      "time": 23.0,
      "time_str": "00:23.000",
      "text": "你别过头 如果还有什么",
      "translation": null
    },
    {
      "time": 28.0,
      "time_str": "00:28.000",
      "text": "值得我逗留 我想是你爱过我",
      "translation": null
    },
    {
      "time": 34.0,
      "time_str": "00:34.000",
      "text": "只是路无尽头",
      "translation": null
    },
    {
      "time": 36.0,
      "time_str": "00:36.000",
      "text": "都是路过 什么感受我能带走",
      "translation": null
    },
    {
      "time": 42.0,
      "time_str": "00:42.000",
      "text": "眼泪可以不流",
      "translation": null
    },
    {
      "time": 44.0,
      "time_str": "00:44.000",
      "text": "心碎不能救",
      "translation": null
    },
    {
      "time": 46.0,
      "time_str": "00:46.000",
      "text": "看我能否得自由",
      "translation": null
    },
    {
      "time": 50.0,
      "time_str": "00:50.000",
      "text": "当我松开你的手",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "一些风沙哽住眼眸",
      "translation": null
    },
    {
      "time": 58.0,
      "time_str": "00:58.000",
      "text": "爱你最后一幕却模糊带过",
      "translation": null
    },
    {
      "time": 62.0,
      "time_str": "01:02.000",
      "text": "不让疼痛有路追究",
      "translation": null
    },
    {
      "time": 66.0,
      "time_str": "01:06.000",
      "text": "我不后悔我曾爱过",
      "translation": null
    },
    {
      "time": 69.5,
      "time_str": "01:09.500",
      "text": "只是天涯从此寂寞",
      "translation": null
    },
    {
      "time": 74.0,
      "time_str": "01:14.000",
      "text": "远去的渡口 彼岸的灯火",
      "translation": null
    },
    {
      "time": 78.0,
      "time_str": "01:18.000",
      "text": "人在河流只需漂泊",
      "translation": null
    },
    {
      "time": 82.0,
      "time_str": "01:22.000",
      "text": "我不后悔被你爱过",
      "translation": null
    },
    {
      "time": 85.5,
      "time_str": "01:25.500",
      "text": "只是不能爱到最后",
      "translation": null
    },
    {
      "time": 90.0,
      "time_str": "01:30.000",
      "text": "短暂的幸福拥有就足够",
      "translation": null
    },
    {
      "time": 94.39,
      "time_str": "01:34.390",
      "text": "只要舍得就会快乐 会快乐",
      "translation": null
    },
    {
