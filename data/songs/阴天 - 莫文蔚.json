  "lyrics": [
    {
      "time": 20.51,
      "time_str": "00:20.510",
      "text": "阴天 在不开灯的房间",
      "translation": null
    },
    {
      "time": 23.5,
      "time_str": "00:23.500",
      "text": "当所有思绪都一点一点沉淀",
      "translation": null
    },
    {
      "time": 27.12,
      "time_str": "00:27.120",
      "text": "爱情究竟是精神鸦片",
      "translation": null
    },
    {
      "time": 30.17,
      "time_str": "00:30.170",
      "text": "还是世纪末的无聊消遣",
      "translation": null
    },
    {
      "time": 34.79,
      "time_str": "00:34.790",
      "text": "香烟 氤成一滩光圈",
      "translation": null
    },
    {
      "time": 37.78,
      "time_str": "00:37.780",
      "text": "和他的照片就摆在手边",
      "translation": null
    },
    {
      "time": 41.5,
      "time_str": "00:41.500",
      "text": "傻傻两个人 笑的多甜",
      "translation": null
    },
    {
      "time": 47.68,
      "time_str": "00:47.680",
      "text": "开始总是分分钟都妙不可言",
      "translation": null
    },
    {
      "time": 51.68,
      "time_str": "00:51.680",
      "text": "谁都以为热情它永不会减",
      "translation": null
    },
    {
      "time": 55.21,
      "time_str": "00:55.210",
      "text": "除了激情褪去后的那一点点倦",
      "translation": null
    },
    {
      "time": 62.07,
      "time_str": "01:02.070",
      "text": "也许像谁说过的贪得无厌",
      "translation": null
    },
    {
      "time": 65.94,
      "time_str": "01:05.940",
      "text": "活该应了谁说过的不知检点",
      "translation": null
    },
    {
      "time": 69.6,
      "time_str": "01:09.600",
      "text": "总之那几年 感性赢了理性那一面",
      "translation": null
    },
    {
      "time": 92.24,
      "time_str": "01:32.240",
      "text": "阴天 在不开灯的房间",
      "translation": null
    },
    {
      "time": 95.2,
      "time_str": "01:35.200",
      "text": "当所有思绪都一点一点沉淀",
      "translation": null
    },
    {
      "time": 98.76,
      "time_str": "01:38.760",
      "text": "爱恨情欲里的疑点 盲点",
      "translation": null
    },
    {
      "time": 102.34,
      "time_str": "01:42.340",
      "text": "呼之欲出 那么明显",
      "translation": null
    },
    {
      "time": 106.43,
      "time_str": "01:46.430",
      "text": "女孩 通通让到一边",
      "translation": null
    },
    {
      "time": 109.26,
      "time_str": "01:49.260",
      "text": "这歌里的细微末节就算都体验",
      "translation": null
    },
    {
      "time": 113.04,
      "time_str": "01:53.040",
      "text": "若想真明白 真要好几年",
      "translation": null
    },
    {
      "time": 148.75,
      "time_str": "02:28.750",
      "text": "回想那一天 喧闹的喜宴",
      "translation": null
    },
    {
      "time": 155.94,
      "time_str": "02:35.940",
      "text": "耳边响起的究竟是序曲或完结篇",
      "translation": null
    },
    {
      "time": 163.37,
      "time_str": "02:43.370",
      "text": "感情不就是你情我愿",
      "translation": null
    },
    {
      "time": 166.33,
      "time_str": "02:46.330",
      "text": "最好爱恨扯平两不相欠",
      "translation": null
    },
    {
      "time": 169.87,
      "time_str": "02:49.870",
      "text": "感情说穿了",
      "translation": null
    },
    {
      "time": 171.56,
      "time_str": "02:51.560",
      "text": "一人挣脱的 一人去捡",
      "translation": null
    },
    {
      "time": 176.74,
      "time_str": "02:56.740",
      "text": "男人大可不必百口莫辩",
      "translation": null
    },
    {
      "time": 180.56,
      "time_str": "03:00.560",
      "text": "女人实在无须楚楚可怜",
      "translation": null
    },
    {
      "time": 184.18,
      "time_str": "03:04.180",
      "text": "总之那几年 你们两个没有缘",
      "translation": null
    },
    {
