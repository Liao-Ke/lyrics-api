  "lyrics": [
    {
      "time": 16.05,
      "time_str": "00:16.050",
      "text": "每次走过这间咖啡屋",
      "translation": null
    },
    {
      "time": 19.23,
      "time_str": "00:19.230",
      "text": "忍不住慢下了脚步",
      "translation": null
    },
    {
      "time": 23.91,
      "time_str": "00:23.910",
      "text": "你我初次相识在这里",
      "translation": null
    },
    {
      "time": 27.15,
      "time_str": "00:27.150",
      "text": "揭开了相约的序幕",
      "translation": null
    },
    {
      "time": 31.83,
      "time_str": "00:31.830",
      "text": "今天你不再是座上客",
      "translation": null
    },
    {
      "time": 35.04,
      "time_str": "00:35.040",
      "text": "我也就恢复了孤独",
      "translation": null
    },
    {
      "time": 39.78,
      "time_str": "00:39.780",
      "text": "不知什么缘故使我俩",
      "translation": null
    },
    {
      "time": 42.96,
      "time_str": "00:42.960",
      "text": "由情侣变成了陌路",
      "translation": null
    },
    {
      "time": 46.92,
      "time_str": "00:46.920",
      "text": "芳香的咖啡飘满小屋",
      "translation": null
    },
    {
      "time": 50.85,
      "time_str": "00:50.850",
      "text": "对你的情感依然如故",
      "translation": null
    },
    {
      "time": 54.87,
      "time_str": "00:54.870",
      "text": "不知道何时再续前缘",
      "translation": null
    },
    {
      "time": 58.74,
      "time_str": "00:58.740",
      "text": "让我把思念向你倾诉",
      "translation": null
    },
    {
      "time": 65.46,
      "time_str": "01:05.460",
      "text": "我又走过这间咖啡屋",
      "translation": null
    },
    {
      "time": 68.64,
      "time_str": "01:08.640",
      "text": "忍不住慢下了脚步",
      "translation": null
    },
    {
      "time": 73.41,
      "time_str": "01:13.410",
      "text": "屋里再也不见你和我",
      "translation": null
    },
    {
      "time": 76.59,
      "time_str": "01:16.590",
      "text": "美丽的往事已模糊",
      "translation": null
