  "lyrics": [
    {
      "time": 0.36,
      "time_str": "00:00.360",
      "text": "It's my first night out with you",
      "translation": "这是我第一次和你在晚上约会"
    },
    {
      "time": 5.71,
      "time_str": "00:05.710",
      "text": "treat me right and buy me shoes",
      "translation": "好好待我 给我买鞋子"
    },
    {
      "time": 11.09,
      "time_str": "00:11.090",
      "text": "Let me be your fantasy play with me",
      "translation": "让我做你的梦中情人 和我在一起吧"
    },
    {
      "time": 17.75,
      "time_str": "00:17.750",
      "text": "I wanna be your girl",
      "translation": "我想成为你的女孩"
    },
    {
      "time": 22.27,
      "time_str": "00:22.270",
      "text": "Just give me some time",
      "translation": "给我一点时间"
    },
    {
      "time": 23.37,
      "time_str": "00:23.370",
      "text": "I will be ready",
      "translation": "我很快就准备好"
    },
    {
      "time": 24.75,
      "time_str": "00:24.750",
      "text": "Do my make-up",
      "translation": "要化妆"
    },
    {
      "time": 25.77,
      "time_str": "00:25.770",
      "text": "Bathe in my perfume",
      "translation": "喷香水"
    },
    {
      "time": 27.35,
      "time_str": "00:27.350",
      "text": "Quick shower won't take too long",
      "translation": "冲个澡 要不了多久"
    },
    {
      "time": 29.81,
      "time_str": "00:29.810",
      "text": "I'll be done just sing this song so",
      "translation": "唱完这首歌我就可以"
    },
    {
      "time": 32.41,
      "time_str": "00:32.410",
      "text": "Wrap me in plastic and make me shine",
      "translation": "让我好好打扮 让我光芒四射"
    },
    {
      "time": 35.08,
      "time_str": "00:35.080",
      "text": "We can make a dollhouse follow your design",
      "translation": "我们可以做个玩具小屋 由你来设计"
    },
    {
      "time": 37.69,
      "time_str": "00:37.690",
      "text": "Let's build a dog out of sticks and twine",
      "translation": "让我们先用木棍和绳子制作一只狗"
    },
    {
      "time": 40.31,
      "time_str": "00:40.310",
      "text": "I can call you master",
      "translation": "我可以叫你主人"
