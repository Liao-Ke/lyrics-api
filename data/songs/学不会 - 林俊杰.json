  "lyrics": [
    {
      "time": 16.43,
      "time_str": "00:16.430",
      "text": "你的痛苦我都心疼",
      "translation": null
    },
    {
      "time": 18.47,
      "time_str": "00:18.470",
      "text": "想为你解决",
      "translation": null
    },
    {
      "time": 23.85,
      "time_str": "00:23.850",
      "text": "挡开流言 紧握你手",
      "translation": null
    },
    {
      "time": 26.24,
      "time_str": "00:26.240",
      "text": "想飞奔往前",
      "translation": null
    },
    {
      "time": 31.04,
      "time_str": "00:31.040",
      "text": "我相信爱能证明一切",
      "translation": null
    },
    {
      "time": 34.67,
      "time_str": "00:34.670",
      "text": "够真心会超越时间",
      "translation": null
    },
    {
      "time": 38.62,
      "time_str": "00:38.620",
      "text": "多付出也多了喜悦",
      "translation": null
    },
    {
      "time": 42.55,
      "time_str": "00:42.550",
      "text": "让幸福蔓延",
      "translation": null
    },
    {
      "time": 48.45,
      "time_str": "00:48.450",
      "text": "总是学不会再聪明一点",
      "translation": null
    },
    {
      "time": 56.08,
      "time_str": "00:56.080",
      "text": "记得自我保护 必要时候讲些",
      "translation": null
    },
    {
      "time": 60.719,
      "time_str": "01:00.719",
      "text": "善意谎言",
      "translation": null
    },
    {
      "time": 63.609,
      "time_str": "01:03.609",
      "text": "总是学不会",
      "translation": null
    },
    {
      "time": 67.558,
      "time_str": "01:07.558",
      "text": "真爱也有现实面",
      "translation": null
    },
    {
      "time": 73.438,
      "time_str": "01:13.438",
      "text": "不是谁情愿",
      "translation": null
    },
    {
      "time": 77.43,
      "time_str": "01:17.430",
      "text": "就能够解决",
      "translation": null
    },
    {
      "time": 90.138,
      "time_str": "01:30.138",
      "text": "一次争吵 一个心结",
      "translation": null
    },
    {
      "time": 91.989,
      "time_str": "01:31.989",
      "text": "累积着改变 Yeah",
      "translation": null
    },
    {
      "time": 97.78,
      "time_str": "01:37.780",
      "text": "内心疏远足够秒杀",
      "translation": null
    },
    {
      "time": 99.688,
      "time_str": "01:39.688",
      "text": "外表多浓烈",
      "translation": null
    },
    {
      "time": 104.42,
      "time_str": "01:44.420",
      "text": "才发现爱不代表一切",
      "translation": null
    },
    {
      "time": 108.218,
      "time_str": "01:48.218",
      "text": "再真心也会被阻绝",
      "translation": null
    },
    {
      "time": 112.049,
      "time_str": "01:52.049",
      "text": "这世界天天有诡雷",
      "translation": null
    },
    {
      "time": 115.688,
      "time_str": "01:55.688",
      "text": "随时会爆裂",
      "translation": null
    },
    {
      "time": 120.078,
      "time_str": "02:00.078",
      "text": "还是学不会少浪漫一点",
      "translation": null
    },
    {
      "time": 127.62,
      "time_str": "02:07.620",
      "text": "拼命着想的事未必带来感动",
