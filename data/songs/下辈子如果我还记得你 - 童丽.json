    {
      "time": 24.478,
      "time_str": "00:24.478",
      "text": "信箱出现一张美丽的明信片",
      "translation": null
    },
    {
      "time": 28.478,
      "time_str": "00:28.478",
      "text": "翠绿的山脚木屋袅袅的烟",
      "translation": null
    },
    {
      "time": 31.81,
      "time_str": "00:31.810",
      "text": "但我惊讶的却是背面",
      "translation": null
    },
    {
      "time": 35.289,
      "time_str": "00:35.289",
      "text": "你熟悉的字迹竟已相隔多年",
      "translation": null
    },
    {
      "time": 40.593,
      "time_str": "00:40.593",
      "text": "那一句话是你离开的玩笑话",
      "translation": null
    },
    {
      "time": 44.443,
      "time_str": "00:44.443",
      "text": "搁在我心里灰尘堆成了塔",
      "translation": null
    },
    {
      "time": 47.695,
      "time_str": "00:47.695",
      "text": "你就这样的拨开了它",
      "translation": null
    },
    {
      "time": 51.48,
      "time_str": "00:51.480",
      "text": "在信箱前我依旧是那个木偶",
      "translation": null
    },
    {
      "time": 56.1,
      "time_str": "00:56.100",
      "text": "线等着你来拉",
      "translation": null
    },
    {
      "time": 61.62,
      "time_str": "01:01.620",
      "text": "你说下辈子如果我还记得你",
      "translation": null
    },
    {
      "time": 65.727,
      "time_str": "01:05.727",
      "text": "我们死也要在一起",
      "translation": null
    },
    {
      "time": 69.661,
      "time_str": "01:09.661",
      "text": "像是陷入催眠的指令",
      "translation": null
    },
    {
      "time": 73.811,
      "time_str": "01:13.811",
      "text": "我已开始昏迷不醒",
      "translation": null
    },
    {
      "time": 77.716,
      "time_str": "01:17.716",
      "text": "好吧",
      "translation": null
