  "lyrics": [
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "原唱 : 雷智皓(大能人)",
      "translation": null
    },
    {
      "time": 11.57,
      "time_str": "00:11.570",
      "text": "我的山楂树之恋",
      "translation": null
    },
    {
      "time": 14.59,
      "time_str": "00:14.590",
      "text": "只有是和你才会纯洁",
      "translation": null
    },
    {
      "time": 17.54,
      "time_str": "00:17.540",
      "text": "可以丢弃",
      "translation": null
    },
    {
      "time": 18.73,
      "time_str": "00:18.730",
      "text": "我的底线",
      "translation": null
    },
    {
      "time": 20.65,
      "time_str": "00:20.650",
      "text": "锁定与你的是我视线",
      "translation": null
    },
    {
      "time": 23.69,
      "time_str": "00:23.690",
      "text": "我的山楂树之恋",
      "translation": null
    },
    {
      "time": 26.8,
      "time_str": "00:26.800",
      "text": "永远站在你的身边",
      "translation": null
    },
    {
      "time": 29.67,
      "time_str": "00:29.670",
      "text": "我保证我的爱不会变",
      "translation": null
    },
    {
      "time": 32.11,
      "time_str": "00:32.110",
      "text": "共享永恒时间",
      "translation": null
    },
    {
      "time": 33.12,
      "time_str": "00:33.120",
      "text": "像蝴蝶起舞翩翩",
      "translation": null
    },
    {
      "time": 36.05,
      "time_str": "00:36.050",
      "text": "每次懊恼在于相见恨晚",
      "translation": null
    },
    {
      "time": 38.96,
      "time_str": "00:38.960",
      "text": "不管相隔的距离是长",
      "translation": null
    },
    {
      "time": 41.12,
      "time_str": "00:41.120",
      "text": "或是短",
      "translation": null
    },
    {
      "time": 42.09,
      "time_str": "00:42.090",
      "text": "能在一起的时候不要快只想慢",
      "translation": null
    },
    {
      "time": 45.32,
      "time_str": "00:45.320",
      "text": "想和你有个孩子",
      "translation": null
    },
    {
      "time": 46.76,
      "time_str": "00:46.760",
      "text": "围着你团团转",
      "translation": null
    },
    {
      "time": 48.27,
      "time_str": "00:48.270",
      "text": "世界变化不停",
      "translation": null
    },
    {
      "time": 49.73,
      "time_str": "00:49.730",
      "text": "人潮川流不息",
      "translation": null
    },
    {
      "time": 51.25,
      "time_str": "00:51.250",
      "text": "不在乎沉淀你肩膀上的经历",
      "translation": null
    },
    {
      "time": 54.2,
      "time_str": "00:54.200",
      "text": "让你少份畏惧",
      "translation": null
    },
    {
      "time": 55.87,
      "time_str": "00:55.870",
      "text": "还你一颗少女心",
      "translation": null
    },
    {
      "time": 57.44,
      "time_str": "00:57.440",
      "text": "有一种超凡动力是为你而打拼",
      "translation": null
    },
    {
      "time": 60.712,
      "time_str": "01:00.712",
      "text": "爱你的坦诚",
      "translation": null
    },
    {
      "time": 61.781,
      "time_str": "01:01.781",
      "text": "像一面清澈的湖水",
      "translation": null
    },
    {
      "time": 63.621,
      "time_str": "01:03.621",
      "text": "就算眼睛肿了我也觉得世上你最美",
      "translation": null
    },
    {
      "time": 66.632,
      "time_str": "01:06.632",
      "text": "许愿十年之后你在我的枕边睡",
      "translation": null
    },
    {
      "time": 69.546,
      "time_str": "01:09.546",
      "text": "我用我的嘴巴抚平你一天的疲惫",
      "translation": null
    },
    {
      "time": 72.644,
      "time_str": "01:12.644",
      "text": "心里总有期待所以过的度日如年",
      "translation": null
    },
    {
      "time": 75.885,
      "time_str": "01:15.885",
      "text": "每天会关注你生活的片片面面",
      "translation": null
    },
    {
      "time": 78.766,
      "time_str": "01:18.766",
      "text": "你说心里话的时候我像在充电",
      "translation": null
    },
    {
      "time": 81.736,
      "time_str": "01:21.736",
      "text": "不理睬的时候我只能自己去找空间",
      "translation": null
    },
    {
      "time": 84.846,
      "time_str": "01:24.846",
      "text": "我的山楂树之恋",
      "translation": null
    },
    {
      "time": 87.944,
      "time_str": "01:27.944",
      "text": "只有是和你才会纯洁",
      "translation": null
    },
    {
      "time": 90.864,
      "time_str": "01:30.864",
      "text": "可以丢弃",
      "translation": null
    },
    {
      "time": 92.057,
      "time_str": "01:32.057",
      "text": "我的底线",
      "translation": null
    },
    {
      "time": 93.959,
      "time_str": "01:33.959",
      "text": "锁定与你的是我视线",
      "translation": null
    },
    {
      "time": 97.057,
      "time_str": "01:37.057",
      "text": "我的山楂树之恋",
      "translation": null
    },
    {
      "time": 100.137,
      "time_str": "01:40.137",
      "text": "永远站在你的身边",
      "translation": null
    },
    {
      "time": 103.048,
      "time_str": "01:43.048",
      "text": "我保证我的爱不会变",
      "translation": null
    },
    {
      "time": 105.447,
      "time_str": "01:45.447",
      "text": "共享永恒时间",
      "translation": null
    },
    {
      "time": 106.447,
      "time_str": "01:46.447",
      "text": "像蝴蝶起舞翩翩",
      "translation": null
    },
    {
      "time": 109.349,
      "time_str": "01:49.349",
      "text": "你的喜好你的习惯",
      "translation": null
    },
    {
      "time": 110.887,
      "time_str": "01:50.887",
      "text": "你爱吃的我都记着",
      "translation": null
    },
    {
      "time": 112.399,
      "time_str": "01:52.399",
      "text": "你爱的高冷我做不来",
      "translation": null
    },
    {
      "time": 113.768,
      "time_str": "01:53.768",
      "text": "可以逐渐适应着",
      "translation": null
    },
    {
      "time": 115.768,
      "time_str": "01:55.768",
      "text": "我不会",
      "translation": null
    },
    {
      "time": 116.387,
      "time_str": "01:56.387",
      "text": "你没睡我不睡",
      "translation": null
    },
    {
      "time": 118.459,
      "time_str": "01:58.459",
      "text": "即使第二天和你在一起会很疲惫",
      "translation": null
    },
    {
      "time": 121.584,
      "time_str": "02:01.584",
      "text": "过的自由自在",
      "translation": null
    },
    {
      "time": 122.992,
      "time_str": "02:02.992",
      "text": "美丽置身事外",
      "translation": null
    },
    {
      "time": 124.525,
      "time_str": "02:04.525",
      "text": "陪你走路回家在每个",
      "translation": null
    },
    {
      "time": 126.465,
      "time_str": "02:06.465",
      "text": "All day all night",
      "translation": null
    },
    {
      "time": 127.647,
      "time_str": "02:07.647",
      "text": "也不能深陷情海",
      "translation": null
    },
    {
      "time": 129.092,
      "time_str": "02:09.092",
      "text": "为了你的那一半",
      "translation": null
    },
    {
      "time": 130.644,
      "time_str": "02:10.644",
      "text": "用太多的精力",
      "translation": null
    },
    {
      "time": 131.774,
      "time_str": "02:11.774",
      "text": "因为上天自有安排",
      "translation": null
    },
    {
      "time": 134.073,
      "time_str": "02:14.073",
      "text": "你是一只飞鸟",
      "translation": null
    },
    {
      "time": 135.832,
      "time_str": "02:15.832",
      "text": "飞上我的树梢",
      "translation": null
    },
    {
      "time": 137.174,
      "time_str": "02:17.174",
      "text": "从此我乏味的生活",
      "translation": null
    },
    {
      "time": 139.353,
      "time_str": "02:19.353",
      "text": "变得热闹",
      "translation": null
    },
    {
      "time": 140.323,
      "time_str": "02:20.323",
      "text": "我知道",
      "translation": null
    },
    {
      "time": 141.313,
      "time_str": "02:21.313",
      "text": "你会为我停留",
      "translation": null
    },
    {
      "time": 143.503,
      "time_str": "02:23.503",
      "text": "时间也会随之",
      "translation": null
    },
    {
      "time": 144.872,
      "time_str": "02:24.872",
      "text": "而过的很久",
      "translation": null
    },
    {
      "time": 146.313,
      "time_str": "02:26.313",
      "text": "说什么好",
      "translation": null
    },
    {
      "time": 147.842,
      "time_str": "02:27.842",
      "text": "念什么糟",
      "translation": null
    },
    {
      "time": 149.372,
      "time_str": "02:29.372",
      "text": "行如此情",
      "translation": null
    },
    {
      "time": 150.533,
      "time_str": "02:30.533",
      "text": "却无从知晓",
      "translation": null
    },
    {
      "time": 152.835,
      "time_str": "02:32.835",
      "text": "我怕来不及",
      "translation": null
    },
    {
      "time": 154.353,
      "time_str": "02:34.353",
      "text": "我怕保不齐",
      "translation": null
    },
    {
      "time": 155.946,
      "time_str": "02:35.946",
      "text": "山楂树下站的我和你",
      "translation": null
    },
