    {
      "time": 3.4,
      "time_str": "00:03.400",
      "text": "豆浆油条",
      "translation": null
    },
    {
      "time": 6.26,
      "time_str": "00:06.260",
      "text": "演唱：林俊杰",
      "translation": null
    },
    {
      "time": 15.39,
      "time_str": "00:15.390",
      "text": "喝纯白的豆浆 是纯白的浪漫",
      "translation": null
    },
    {
      "time": 26.17,
      "time_str": "00:26.170",
      "text": "望着你可爱脸庞 和你纯真的模样",
      "translation": null
    },
    {
      "time": 37.12,
      "time_str": "00:37.120",
      "text": "我傻傻对你笑 是你忧愁解药",
      "translation": null
    },
    {
      "time": 47.91,
      "time_str": "00:47.910",
      "text": "你说我就像油条 很简单却很美好",
      "translation": null
    },
    {
      "time": 58.21,
      "time_str": "00:58.210",
      "text": "我知道你和我就像是豆浆油条",
      "translation": null
    },
    {
      "time": 63.68,
      "time_str": "01:03.680",
      "text": "要一起吃下去味道才会是最好",
      "translation": null
    },
    {
      "time": 68.76,
      "time_str": "01:08.760",
      "text": "你需要我的傻笑 我需要你的拥抱",
      "translation": null
    },
    {
      "time": 74.51,
      "time_str": "01:14.510",
      "text": "爱情就需要这样 它才不会单调",
      "translation": null
    },
    {
      "time": 79.91,
      "time_str": "01:19.910",
      "text": "我知道有时候也需要吵吵闹闹",
      "translation": null
    },
    {
      "time": 85.38,
      "time_str": "01:25.380",
      "text": "但始终也知道只有你对我最好",
      "translation": null
    },
    {
      "time": 90.5,
      "time_str": "01:30.500",
      "text": "豆浆离不开油条 让我爱你爱到老",
      "translation": null
    },
    {
      "time": 96.23,
      "time_str": "01:36.230",
      "text": "爱情就需要这样 它才幸福美好",
      "translation": null
    },
    {
      "time": 101.73,
      "time_str": "01:41.730",
      "text": "我知道 都知道 你知道 你都知道",
      "translation": null
    },
    {
      "time": 106.69,
      "time_str": "01:46.690",
      "text": "好不好 别偷笑 让我知道",
      "translation": null
    },
    {
      "time": 129.6,
      "time_str": "02:09.600",
      "text": "我喝完热豆浆 眷恋着还想要",
      "translation": null
    },
    {
      "time": 140.67,
      "time_str": "02:20.670",
      "text": "你吃完金黄油条 爱情又要再发酵",
