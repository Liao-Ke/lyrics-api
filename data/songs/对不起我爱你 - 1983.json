    {
      "time": 35.48,
      "time_str": "00:35.480",
      "text": "这熟悉的天气",
      "translation": null
    },
    {
      "time": 38.98,
      "time_str": "00:38.980",
      "text": "留在深处的记忆",
      "translation": null
    },
    {
      "time": 42.3,
      "time_str": "00:42.300",
      "text": "似乎那次我们相遇",
      "translation": null
    },
    {
      "time": 45.64,
      "time_str": "00:45.640",
      "text": "是缘分前世的累积",
      "translation": null
    },
    {
      "time": 49.0,
      "time_str": "00:49.000",
      "text": "那曾经的旋律",
      "translation": null
    },
    {
      "time": 52.43,
      "time_str": "00:52.430",
      "text": "却不能再次响起",
      "translation": null
    },
    {
      "time": 55.68,
      "time_str": "00:55.680",
      "text": "是否我们无法逃避",
      "translation": null
    },
    {
      "time": 59.0,
      "time_str": "00:59.000",
      "text": "早已注定的结局",
      "translation": null
    },
    {
      "time": 63.61,
      "time_str": "01:03.610",
      "text": "而距离",
      "translation": null
    },
    {
      "time": 66.37,
      "time_str": "01:06.370",
      "text": "我们在不同轨迹",
      "translation": null
    },
    {
      "time": 70.11,
      "time_str": "01:10.110",
      "text": "再多的努力也是悲戚",
      "translation": null
    },
    {
      "time": 76.76,
      "time_str": "01:16.760",
      "text": "在心底千万次地练习",
      "translation": null
    },
    {
      "time": 81.97,
      "time_str": "01:21.970",
      "text": "千万次不停地温习",
      "translation": null
    },
    {
      "time": 86.74,
      "time_str": "01:26.740",
      "text": "只怕已来不及",
      "translation": null
    },
    {
      "time": 90.1,
      "time_str": "01:30.100",
      "text": "只是还没告诉你",
      "translation": null
    },
    {
