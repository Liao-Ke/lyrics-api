  "lyrics": [
    {
      "time": 2.12,
      "time_str": "00:02.120",
      "text": "编曲 Arrangement：钟成虎 Tiger Chung",
      "translation": null
    },
    {
      "time": 27.73,
      "time_str": "00:27.730",
      "text": "你看过了许多美景",
      "translation": null
    },
    {
      "time": 31.17,
      "time_str": "00:31.170",
      "text": "你看过了许多美女",
      "translation": null
    },
    {
      "time": 34.66,
      "time_str": "00:34.660",
      "text": "你迷失在地图上 每一道短暂的光阴",
      "translation": null
    },
    {
      "time": 41.64,
      "time_str": "00:41.640",
      "text": "你品尝了夜的巴黎",
      "translation": null
    },
    {
      "time": 45.08,
      "time_str": "00:45.080",
      "text": "你踏过下雪的北京",
      "translation": null
    },
    {
      "time": 48.53,
      "time_str": "00:48.530",
      "text": "你熟记书本里 每一句你最爱的真理",
      "translation": null
    },
    {
      "time": 54.85,
      "time_str": "00:54.850",
      "text": "却说不出你爱我的原因",
      "translation": null
    },
    {
      "time": 61.8,
      "time_str": "01:01.800",
      "text": "却说不出你欣赏我哪一种表情",
      "translation": null
    },
    {
      "time": 68.71,
      "time_str": "01:08.710",
      "text": "却说不出在什么场合我曾让你动心",
      "translation": null
    },
    {
      "time": 75.69,
      "time_str": "01:15.690",
      "text": "说不出离开的原因",
      "translation": null
    },
    {
      "time": 86.8,
      "time_str": "01:26.800",
      "text": "你累积了许多飞行",
      "translation": null
    },
    {
      "time": 90.36,
      "time_str": "01:30.360",
      "text": "你用心挑选纪念品",
      "translation": null
    },
    {
      "time": 93.85,
      "time_str": "01:33.850",
      "text": "你搜集了地图上 每一次的风和日丽",
      "translation": null
    },
    {
      "time": 100.78,
      "time_str": "01:40.780",
      "text": "你拥抱热情的岛屿",
      "translation": null
    },
    {
      "time": 104.21,
      "time_str": "01:44.210",
      "text": "你埋葬记忆的土耳其",
      "translation": null
    },
    {
      "time": 107.52,
      "time_str": "01:47.520",
      "text": "你流连电影里美丽的不真实的场景",
      "translation": null
    },
    {
      "time": 113.95,
      "time_str": "01:53.950",
      "text": "却说不出你爱我的原因",
      "translation": null
    },
    {
      "time": 120.92,
      "time_str": "02:00.920",
      "text": "却说不出你欣赏我哪一种表情",
      "translation": null
    },
    {
      "time": 127.53,
      "time_str": "02:07.530",
      "text": "你却说不出在什么场合我曾让你分心",
      "translation": null
    },
    {
      "time": 134.71,
      "time_str": "02:14.710",
      "text": "说不出旅行的意义",
      "translation": null
    },
    {
      "time": 173.04,
      "time_str": "02:53.040",
      "text": "你勉强说出你爱我的原因",
      "translation": null
    },
    {
      "time": 180.03,
      "time_str": "03:00.030",
      "text": "却说不出你欣赏我哪一种表情",
      "translation": null
    },
    {
      "time": 186.83,
      "time_str": "03:06.830",
      "text": "却说不出在什么场合我曾让你动心",
      "translation": null
    },
    {
      "time": 194.01,
      "time_str": "03:14.010",
      "text": "说不出旅行的意义",
      "translation": null
    },
    {
      "time": 200.99,
      "time_str": "03:20.990",
      "text": "勉强说出你为我寄出的每一封信",
      "translation": null
    },
    {
      "time": 207.98,
      "time_str": "03:27.980",
      "text": "都是你离开的原因 你离开我",
      "translation": null
    },
    {
      "time": 215.78,
      "time_str": "03:35.780",
      "text": "就是旅行的意义",
      "translation": null
    },
    {
