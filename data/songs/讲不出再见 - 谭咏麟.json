    {
      "time": 30.32,
      "time_str": "00:30.320",
      "text": "是对是错也好不必说了",
      "translation": null
    },
    {
      "time": 36.89,
      "time_str": "00:36.890",
      "text": "是怨是爱也好不须揭晓",
      "translation": null
    },
    {
      "time": 43.47,
      "time_str": "00:43.470",
      "text": "何事更重要 比两心的需要",
      "translation": null
    },
    {
      "time": 49.96,
      "time_str": "00:49.960",
      "text": "柔情蜜意怎么可缺少",
      "translation": null
    },
    {
      "time": 56.58,
      "time_str": "00:56.580",
      "text": "是进是退也好有若狂潮",
      "translation": null
    },
    {
      "time": 63.207,
      "time_str": "01:03.207",
      "text": "是痛是爱也好不须发表",
      "translation": null
    },
    {
      "time": 69.738,
      "time_str": "01:09.738",
      "text": "曾为你愿意 我梦想都不要",
      "translation": null
    },
    {
      "time": 76.268,
      "time_str": "01:16.268",
      "text": "流言自此心知不会少",
      "translation": null
    },
    {
      "time": 82.929,
      "time_str": "01:22.929",
      "text": "这段情 越是浪漫越美妙",
      "translation": null
    },
    {
      "time": 90.247,
      "time_str": "01:30.247",
      "text": "离别最是吃不消",
      "translation": null
    },
    {
      "time": 95.188,
      "time_str": "01:35.188",
      "text": "我最不忍看你 背向我转面",
      "translation": null
    },
    {
      "time": 102.2,
      "time_str": "01:42.200",
      "text": "要走一刻请不必诸多眷恋",
      "translation": null
    },
    {
      "time": 108.209,
      "time_str": "01:48.209",
      "text": "浮沉浪似人潮 哪会没有思念",
      "translation": null
    },
    {
      "time": 115.429,
      "time_str": "01:55.429",
      "text": "你我伤心到讲不出再见",
