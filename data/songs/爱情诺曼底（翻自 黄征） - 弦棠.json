  "lyrics": [
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "六月六日六时 六分刚过六十秒",
      "translation": null
    },
    {
      "time": 38.82,
      "time_str": "00:38.820",
      "text": "脆弱的堡垒远眺如风化的沙雕",
      "translation": null
    },
    {
      "time": 45.11,
      "time_str": "00:45.110",
      "text": "轻抚着断裂的皱纹 沧桑一条条",
      "translation": null
    },
    {
      "time": 51.65,
      "time_str": "00:51.650",
      "text": "谁的心 早已 死掉",
      "translation": null
    },
    {
      "time": 58.9,
      "time_str": "00:58.900",
      "text": "曾和你相爱如天命难违的 凑巧",
      "translation": null
    },
    {
      "time": 65.5,
      "time_str": "01:05.500",
      "text": "为何与你对决 变成轮回的纷扰",
      "translation": null
    },
    {
      "time": 71.76,
      "time_str": "01:11.760",
      "text": "爱如那常消的 海潮 退去时飘渺",
      "translation": null
    },
    {
      "time": 78.4,
      "time_str": "01:18.400",
      "text": "我 的心 不再 计较",
      "translation": null
    },
    {
      "time": 84.99,
      "time_str": "01:24.990",
      "text": "情爱它 似毒药  你我早就应该知道",
      "translation": null
    },
    {
      "time": 91.75,
      "time_str": "01:31.750",
      "text": "为何却 不停的要",
      "translation": null
    },
    {
      "time": 98.71,
      "time_str": "01:38.710",
      "text": "我怎么才能登上你的爱情诺曼底",
      "translation": null
    },
    {
      "time": 105.01,
      "time_str": "01:45.010",
      "text": "别让天与海的距离  衡量爱与恨的对立",
      "translation": null
    },
    {
      "time": 111.77,
      "time_str": "01:51.770",
      "text": "怎么才能让我登上你的爱情诺曼底",
      "translation": null
    },
    {
      "time": 118.48,
      "time_str": "01:58.480",
      "text": "狂奔在破晓的大地  拼了命 也要找到你",
