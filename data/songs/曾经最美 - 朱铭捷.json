  "lyrics": [
    {
      "time": 20.568,
      "time_str": "00:20.568",
      "text": "看不穿你的眼睛",
      "translation": null
    },
    {
      "time": 24.528,
      "time_str": "00:24.528",
      "text": "藏有多少悲和喜",
      "translation": null
    },
    {
      "time": 27.947,
      "time_str": "00:27.947",
      "text": "像冰雪细腻",
      "translation": null
    },
    {
      "time": 29.951,
      "time_str": "00:29.951",
      "text": "又如此透明",
      "translation": null
    },
    {
      "time": 32.31,
      "time_str": "00:32.310",
      "text": "仿佛片刻就要老去",
      "translation": null
    },
    {
      "time": 36.545,
      "time_str": "00:36.545",
      "text": "整个城市的孤寂",
      "translation": null
    },
    {
      "time": 39.962,
      "time_str": "00:39.962",
      "text": "不止一个你",
      "translation": null
    },
    {
      "time": 43.352,
      "time_str": "00:43.352",
      "text": "只能远远的",
      "translation": null
    },
    {
      "time": 45.578,
      "time_str": "00:45.578",
      "text": "想像慰藉",
      "translation": null
    },
    {
      "time": 47.746,
      "time_str": "00:47.746",
      "text": "我们之间的距离",
      "translation": null
    },
    {
      "time": 51.722,
      "time_str": "00:51.722",
      "text": "我又不是你的谁",
      "translation": null
    },
    {
      "time": 55.654,
      "time_str": "00:55.654",
      "text": "不能带给你安慰",
      "translation": null
    },
    {
      "time": 59.74,
      "time_str": "00:59.740",
      "text": "忍心你枯萎",
      "translation": null
    },
    {
      "time": 61.82,
      "time_str": "01:01.820",
      "text": "凋零的玫瑰",
      "translation": null
    },
    {
      "time": 63.48,
      "time_str": "01:03.480",
      "text": "仿佛希望化成灰",
      "translation": null
    },
    {
      "time": 68.26,
      "time_str": "01:08.260",
      "text": "要不是痛彻心扉",
      "translation": null
    },
    {
      "time": 71.376,
      "time_str": "01:11.376",
      "text": "谁又记得谁",
      "translation": null
    },
    {
      "time": 74.846,
      "time_str": "01:14.846",
      "text": "只是云和月相互以为",
      "translation": null
    },
    {
      "time": 78.528,
      "time_str": "01:18.528",
      "text": "是彼此的盈缺",
      "translation": null
    },
    {
      "time": 82.226,
      "time_str": "01:22.226",
      "text": "不能哭喊已破碎",
      "translation": null
    },
    {
      "time": 87.9,
      "time_str": "01:27.900",
      "text": "曾经的最美",
      "translation": null
    },
    {
      "time": 90.602,
      "time_str": "01:30.602",
      "text": "独自一个人熟悉的街",
      "translation": null
    },
    {
      "time": 94.998,
      "time_str": "01:34.998",
      "text": "别问你在想谁",
      "translation": null
    },
    {
      "time": 97.922,
      "time_str": "01:37.922",
      "text": "不去追悔已憔悴",
      "translation": null
    },
    {
      "time": 102.874,
      "time_str": "01:42.874",
      "text": "爱过的机会",
      "translation": null
    },
    {
      "time": 106.298,
      "time_str": "01:46.298",
      "text": "真实已粉碎人事已非",
      "translation": null
