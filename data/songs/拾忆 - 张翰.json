  "lyrics": [
    {
      "time": 30.92,
      "time_str": "00:30.920",
      "text": "翻开日记 整理破碎的心情",
      "translation": null
    },
    {
      "time": 38.3,
      "time_str": "00:38.300",
      "text": "不知怎么 你什么都已记不清",
      "translation": null
    },
    {
      "time": 45.95,
      "time_str": "00:45.950",
      "text": "但我相信 只要相爱就有魔力",
      "translation": null
    },
    {
      "time": 53.26,
      "time_str": "00:53.260",
      "text": "但是换来 一次又一次失意",
      "translation": null
    },
    {
      "time": 60.7,
      "time_str": "01:00.700",
      "text": "你我的爱 像融化的冰淇凌",
      "translation": null
    },
    {
      "time": 67.67,
      "time_str": "01:07.670",
      "text": "虽然很甜 却没有了那种晶莹",
      "translation": null
    },
    {
      "time": 74.94,
      "time_str": "01:14.940",
      "text": "我会每天 反反复复给你温习",
      "translation": null
    },
    {
      "time": 82.61,
      "time_str": "01:22.610",
      "text": "找回那份 遗失的专属甜蜜",
      "translation": null
    },
    {
      "time": 89.92,
      "time_str": "01:29.920",
      "text": "怎么会忘了情",
      "translation": null
    },
    {
      "time": 93.31,
      "time_str": "01:33.310",
      "text": "让我丢了你",
      "translation": null
    },
    {
      "time": 97.33,
      "time_str": "01:37.330",
      "text": "傻傻的 还以为能够在一起",
      "translation": null
    },
    {
      "time": 104.82,
      "time_str": "01:44.820",
      "text": "划过了 流星",
      "translation": null
    },
    {
      "time": 108.53,
      "time_str": "01:48.530",
      "text": "身边没有你",
      "translation": null
    },
    {
      "time": 112.33,
      "time_str": "01:52.330",
      "text": "就算梦实现也没意义",
