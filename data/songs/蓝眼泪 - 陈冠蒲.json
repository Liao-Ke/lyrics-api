  "lyrics": [
    {
      "time": 40.61,
      "time_str": "00:40.610",
      "text": "我已经好几天深夜不能眠",
      "translation": null
    },
    {
      "time": 46.01,
      "time_str": "00:46.010",
      "text": "都为了谁",
      "translation": null
    },
    {
      "time": 50.26,
      "time_str": "00:50.260",
      "text": "我只是心疼你哭肿的双眼",
      "translation": null
    },
    {
      "time": 55.53,
      "time_str": "00:55.530",
      "text": "多可怜",
      "translation": null
    },
    {
      "time": 59.53,
      "time_str": "00:59.530",
      "text": "如果情已决裂",
      "translation": null
    },
    {
      "time": 62.79,
      "time_str": "01:02.790",
      "text": "你伤心欲绝 他没感觉",
      "translation": null
    },
    {
      "time": 69.37,
      "time_str": "01:09.370",
      "text": "他早已空了心",
      "translation": null
    },
    {
      "time": 72.36,
      "time_str": "01:12.360",
      "text": "对你的深情都看不见",
      "translation": null
    },
    {
      "time": 78.42,
      "time_str": "01:18.420",
      "text": "取一瓢深蓝色苦苦的湖水",
      "translation": null
    },
    {
      "time": 83.81,
      "time_str": "01:23.810",
      "text": "化成一滴蓝色的眼泪",
      "translation": null
    },
    {
      "time": 88.01,
      "time_str": "01:28.010",
      "text": "滴落在你眉间能解开情结",
      "translation": null
    },
    {
      "time": 93.41,
      "time_str": "01:33.410",
      "text": "还会让你心如止水",
      "translation": null
    },
    {
      "time": 97.89,
      "time_str": "01:37.890",
      "text": "你不再对他痴恋",
      "translation": null
    },
    {
      "time": 101.25,
      "time_str": "01:41.250",
      "text": "苦守整个夜 魂萦梦牵",
      "translation": null
    },
    {
      "time": 107.81,
      "time_str": "01:47.810",
      "text": "深蓝色的眼泪",
      "translation": null
    },
    {
      "time": 110.83,
      "time_str": "01:50.830",
      "text": "也让你失去爱的感觉",
      "translation": null
    },
