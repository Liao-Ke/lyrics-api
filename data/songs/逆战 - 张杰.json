    {
      "time": 16.473,
      "time_str": "00:16.473",
      "text": "在这个风起云涌的战场上",
      "translation": null
    },
    {
      "time": 20.402,
      "time_str": "00:20.402",
      "text": "暴风少年登场",
      "translation": null
    },
    {
      "time": 24.506,
      "time_str": "00:24.506",
      "text": "在战胜烈火重重的咆哮声",
      "translation": null
    },
    {
      "time": 28.459,
      "time_str": "00:28.459",
      "text": "喧闹整个世界",
      "translation": null
    },
    {
      "time": 32.464,
      "time_str": "00:32.464",
      "text": "硝烟狂飞的讯号",
      "translation": null
    },
    {
      "time": 34.475,
      "time_str": "00:34.475",
      "text": "机甲时代正来到",
      "translation": null
    },
    {
      "time": 36.579,
      "time_str": "00:36.579",
      "text": "热血逆流而上",
      "translation": null
    },
    {
      "time": 40.531,
      "time_str": "00:40.531",
      "text": "战车在发烫",
      "translation": null
    },
    {
      "time": 41.935,
      "time_str": "00:41.935",
      "text": "勇士也势不可挡",
      "translation": null
    },
    {
      "time": 46.756,
      "time_str": "00:46.756",
      "text": "Come On!逆战逆战来也",
      "translation": null
    },
    {
      "time": 49.458,
      "time_str": "00:49.458",
      "text": "王牌要狂野",
      "translation": null
    },
    {
      "time": 51.47,
      "time_str": "00:51.470",
      "text": "闯荡宇宙摆平世界",
      "translation": null
    },
    {
      "time": 54.924,
      "time_str": "00:54.924",
      "text": "Oooh!逆战逆战狂野",
      "translation": null
    },
    {
      "time": 57.431,
      "time_str": "00:57.431",
      "text": "王牌要发泄",
      "translation": null
    },
    {
      "time": 59.432,
      "time_str": "00:59.432",
      "text": "战斗是我们倔强起点",
      "translation": null
    },
    {
      "time": 63.737,
      "time_str": "01:03.737",
      "text": "我要操控我的权势",
      "translation": null
    },
    {
      "time": 66.43,
      "time_str": "01:06.430",
      "text": "张扬我的声势",
      "translation": null
    },
    {
      "time": 68.253,
      "time_str": "01:08.253",
      "text": "看这场龙战在野",
      "translation": null
    },
    {
      "time": 70.908,
      "time_str": "01:10.908",
      "text": "这战场千百热血战士",
