  "lyrics": [
    {
      "time": 14.7,
      "time_str": "00:14.700",
      "text": "远处蔚蓝天空下",
      "translation": null
    },
    {
      "time": 16.79,
      "time_str": "00:16.790",
      "text": "涌动着金色的麦浪",
      "translation": null
    },
    {
      "time": 21.65,
      "time_str": "00:21.650",
      "text": "就在那里曾是你和我",
      "translation": null
    },
    {
      "time": 25.29,
      "time_str": "00:25.290",
      "text": "爱过的地方",
      "translation": null
    },
    {
      "time": 28.38,
      "time_str": "00:28.380",
      "text": "当微风带着收获的味道",
      "translation": null
    },
    {
      "time": 32.27,
      "time_str": "00:32.270",
      "text": "吹向我脸庞",
      "translation": null
    },
    {
      "time": 35.5,
      "time_str": "00:35.500",
      "text": "想起你轻柔的话语",
      "translation": null
    },
    {
      "time": 39.0,
      "time_str": "00:39.000",
      "text": "曾打湿我眼眶",
      "translation": null
    },
    {
      "time": 42.01,
      "time_str": "00:42.010",
      "text": "嗯…啦…嗯…啦…",
      "translation": null
    },
    {
      "time": 73.86,
      "time_str": "01:13.860",
      "text": "我们曾在田野里歌唱",
      "translation": null
    },
    {
      "time": 77.56,
      "time_str": "01:17.560",
      "text": "在冬季盼望",
      "translation": null
    },
    {
      "time": 80.88,
      "time_str": "01:20.880",
      "text": "却没能等到这阳光下",
      "translation": null
    },
    {
      "time": 84.48,
      "time_str": "01:24.480",
      "text": "秋天的景象",
      "translation": null
    },
    {
      "time": 87.57,
      "time_str": "01:27.570",
      "text": "就让曾经的誓言飞舞吧",
      "translation": null
    },
    {
      "time": 91.42,
      "time_str": "01:31.420",
      "text": "随西风飘荡",
      "translation": null
    },
    {
      "time": 94.86,
      "time_str": "01:34.860",
      "text": "就像你柔软的长发",
      "translation": null
    },
    {
      "time": 98.25,
      "time_str": "01:38.250",
      "text": "曾芬芳我梦乡",
      "translation": null
