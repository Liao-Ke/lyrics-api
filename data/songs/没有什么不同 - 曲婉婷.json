      "time": 21.23,
      "time_str": "00:21.230",
      "text": "又是你的面孔 带给我是笑容",
      "translation": null
    },
    {
      "time": 25.71,
      "time_str": "00:25.710",
      "text": "在我哭泣的时候",
      "translation": null
    },
    {
      "time": 30.25,
      "time_str": "00:30.250",
      "text": "又是你的问候 带给我是感动",
      "translation": null
    },
    {
      "time": 34.95,
      "time_str": "00:34.950",
      "text": "在我孤寂的时候",
      "translation": null
    },
    {
      "time": 38.92,
      "time_str": "00:38.920",
      "text": "虽然没有天生一样的",
      "translation": null
    },
    {
      "time": 43.43,
      "time_str": "00:43.430",
      "text": "但在地球上我们是一样的",
      "translation": null
    },
    {
      "time": 48.52,
      "time_str": "00:48.520",
      "text": "尽管痛的苦的没说的",
      "translation": null
    },
    {
      "time": 52.54,
      "time_str": "00:52.540",
      "text": "但哪有一路走来都是顺风的",
      "translation": null
    },
    {
      "time": 56.93,
      "time_str": "00:56.930",
      "text": "因为我们没有什么不同",
      "translation": null
    },
    {
      "time": 61.32,
      "time_str": "01:01.320",
      "text": "天黑时我们仰望同一片星空",
      "translation": null
    },
    {
      "time": 66.55,
