  "lyrics": [
    {
      "time": 35.71,
      "time_str": "00:35.710",
      "text": "碧池剑 华山之巅",
      "translation": null
    },
    {
      "time": 37.769,
      "time_str": "00:37.769",
      "text": "风云再起 有没有银两赚",
      "translation": null
    },
    {
      "time": 40.12,
      "time_str": "00:40.120",
      "text": "上上签 你签不签",
      "translation": null
    },
    {
      "time": 42.633,
      "time_str": "00:42.633",
      "text": "得罪了他 把你压在五指山",
      "translation": null
    },
    {
      "time": 45.183,
      "time_str": "00:45.183",
      "text": "血红染 乌云满天",
      "translation": null
    },
    {
      "time": 47.683,
      "time_str": "00:47.683",
      "text": "过美人关 过不去利益关",
      "translation": null
    },
    {
      "time": 50.234,
      "time_str": "00:50.234",
      "text": "上上签 你签不签",
      "translation": null
    },
    {
      "time": 52.775,
      "time_str": "00:52.775",
      "text": "谁最爱骗 不谙世事的少年",
      "translation": null
    },
    {
      "time": 55.361,
      "time_str": "00:55.361",
      "text": "Joe是我的名字",
      "translation": null
    },
    {
      "time": 56.532,
      "time_str": "00:56.532",
      "text": "屌丝成了BOSS",
      "translation": null
    },
    {
      "time": 57.916,
      "time_str": "00:57.916",
      "text": "这一切多亏拜谁所赐",
      "translation": null
    },
    {
      "time": 59.516,
      "time_str": "00:59.516",
      "text": "匿在歌词",
      "translation": null
    },
    {
      "time": 60.566,
      "time_str": "01:00.566",
      "text": "我没掉链子",
      "translation": null
    },
    {
      "time": 61.716,
      "time_str": "01:01.716",
      "text": "你在纠结面子",
      "translation": null
    },
    {
      "time": 62.917,
      "time_str": "01:02.917",
      "text": "Sorry你这辈子",
      "translation": null
    },
    {
      "time": 63.867,
      "time_str": "01:03.867",
      "text": "摊上我这么个疯子",
      "translation": null
    },
    {
      "time": 67.741,
      "time_str": "01:07.741",
      "text": "他有盖世武功",
      "translation": null
    },
    {
      "time": 70.493,
      "time_str": "01:10.493",
      "text": "所以万分神勇",
      "translation": null
    },
    {
      "time": 72.745,
      "time_str": "01:12.745",
      "text": "什么大侠英雄",
      "translation": null
    },
    {
      "time": 75.596,
      "time_str": "01:15.596",
      "text": "他看都是狗熊",
      "translation": null
    },
    {
      "time": 77.746,
      "time_str": "01:17.746",
      "text": "他有盖世武功",
      "translation": null
    },
    {
      "time": 80.55,
      "time_str": "01:20.550",
      "text": "江湖人称神勇",
      "translation": null
    },
    {
      "time": 82.89,
      "time_str": "01:22.890",
      "text": "不敢打抱不平",
      "translation": null
    },
    {
      "time": 85.861,
      "time_str": "01:25.861",
      "text": "专欺黎民百姓",
      "translation": null
    },
    {
      "time": 98.331,
      "time_str": "01:38.331",
      "text": "山连绵 轻啼的猿",
      "translation": null
    },
    {
      "time": 100.72,
      "time_str": "01:40.720",
      "text": "问卦一盘 小人心好可怜",
      "translation": null
    },
    {
      "time": 103.27,
      "time_str": "01:43.270",
      "text": "雨涟涟 把酒窗前",
      "translation": null
    },
    {
      "time": 105.87,
      "time_str": "01:45.870",
      "text": "可笑眼前 猪读书满眼不堪",
      "translation": null
    },
    {
      "time": 108.371,
      "time_str": "01:48.371",
      "text": "纯归还 花香满园",
      "translation": null
    },
    {
      "time": 110.921,
      "time_str": "01:50.921",
      "text": "他轻轻叹 弹一曲声声慢",
      "translation": null
    },
    {
      "time": 113.433,
      "time_str": "01:53.433",
      "text": "声声慢 乍暖还寒",
      "translation": null
    },
    {
