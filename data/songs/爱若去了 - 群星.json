  "lyrics": [
    {
      "time": 27.87,
      "time_str": "00:27.870",
      "text": "北风呼啸着吹过",
      "translation": null
    },
    {
      "time": 31.54,
      "time_str": "00:31.540",
      "text": "吹来他乡的冬季",
      "translation": null
    },
    {
      "time": 35.39,
      "time_str": "00:35.390",
      "text": "冰冻着当初爱情开始的城市",
      "translation": null
    },
    {
      "time": 42.52,
      "time_str": "00:42.520",
      "text": "此刻谁的怀抱感动着你",
      "translation": null
    },
    {
      "time": 46.11,
      "time_str": "00:46.110",
      "text": "此刻谁在唇边温馨着你",
      "translation": null
    },
    {
      "time": 49.27,
      "time_str": "00:49.270",
      "text": "现在的他是否比我懂你",
      "translation": null
    },
    {
      "time": 57.24,
      "time_str": "00:57.240",
      "text": "无意中再次路过",
      "translation": null
    },
    {
      "time": 60.71,
      "time_str": "01:00.710",
      "text": "这片寒冷的故地",
      "translation": null
    },
    {
      "time": 64.53,
      "time_str": "01:04.530",
      "text": "仿佛空气的味道都那么熟悉",
      "translation": null
    },
    {
      "time": 71.58,
      "time_str": "01:11.580",
      "text": "此刻已不想用太多力气",
      "translation": null
    },
    {
      "time": 75.2,
      "time_str": "01:15.200",
      "text": "将过去一点点片段记起",
      "translation": null
    },
    {
      "time": 78.35,
      "time_str": "01:18.350",
      "text": "只有重复事过境迁提醒自己",
      "translation": null
    },
    {
      "time": 86.13,
      "time_str": "01:26.130",
      "text": "爱若去了 就由它吧",
      "translation": null
    },
    {
      "time": 89.71,
      "time_str": "01:29.710",
      "text": "谁不是在爱情起起落落中浮沉",
      "translation": null
    },
    {
      "time": 93.41,
      "time_str": "01:33.410",
      "text": "那些去而复返的情节",
      "translation": null
    },
    {
      "time": 96.51,
      "time_str": "01:36.510",
      "text": "总有人重温",
      "translation": null
    },
    {
      "time": 100.63,
      "time_str": "01:40.630",
      "text": "爱若去了 就由它吧",
      "translation": null
