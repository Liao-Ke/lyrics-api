      "time": 13.833,
      "time_str": "00:13.833",
      "text": "从未怕我会失礼",
      "translation": null
    },
    {
      "time": 17.0,
      "time_str": "00:17.000",
      "text": "为我劳苦都不计",
      "translation": null
    },
    {
      "time": 20.024,
      "time_str": "00:20.024",
      "text": "还在说我如上天",
      "translation": null
    },
    {
      "time": 23.237,
      "time_str": "00:23.237",
      "text": "赏给你的奖励",
      "translation": null
    },
    {
      "time": 26.107,
      "time_str": "00:26.107",
      "text": "其实我那算宝贵",
      "translation": null
    },
    {
      "time": 29.134,
      "time_str": "00:29.134",
      "text": "尚有你宠先珍贵",
      "translation": null
    },
    {
      "time": 32.4,
      "time_str": "00:32.400",
      "text": "眼看今天一切统统",
      "translation": null
    },
    {
      "time": 35.398,
      "time_str": "00:35.398",
      "text": "都靠你先可发挥",
      "translation": null
