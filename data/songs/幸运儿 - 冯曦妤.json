    },
    {
      "time": 51.253,
      "time_str": "00:51.253",
      "text": "未见得位位都会爱我",
      "translation": null
    },
    {
      "time": 54.381,
      "time_str": "00:54.381",
      "text": "在这个世界 伪装的很多",
