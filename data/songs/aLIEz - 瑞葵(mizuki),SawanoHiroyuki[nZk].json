  "lyrics": [
    {
      "time": 20.6,
      "time_str": "00:20.600",
      "text": "決めつけばかり 自惚れを着た チープなhokoriで 音荒げても",
      "translation": "一味的固执己见，充满着傲慢，就算是声色俱厉也无法掩盖这可笑的自尊"
    },
    {
      "time": 30.3,
      "time_str": "00:30.300",
      "text": "棚に隠した 哀れな 恥に濡れた鏡の中",
      "translation": "但有时也会躲藏在那被悲哀所羞辱的镜子里"
    },
    {
      "time": 39.17,
      "time_str": "00:39.170",
      "text": "都合の傷だけひけらかして 手軽な強さで勝取る術を",
      "translation": "可以炫耀的只剩显露的伤痕，只想赢取轻而易举就能得到的胜利"
    },
    {
      "time": 48.88,
      "time_str": "00:48.880",
      "text": "どれだけ磨いでも気はやつれる ふらついた思想通りだ",
      "translation": "不管经历多少次的磨练依然还是这么脆弱，正如自己摇摆不定的思想"
    },
    {
      "time": 57.6,
      "time_str": "00:57.600",
      "text": "愛-same-CRIER 愛撫-save-LIAR",
      "translation": null
    },
    {
      "time": 57.6,
      "time_str": "00:57.600",
      "text": "内心一直在哭泣着，用谎言来安抚受伤的内心",
      "translation": null
    },
    {
      "time": 62.4,
      "time_str": "01:02.400",
      "text": "Eid-聖-Rising HELL",
      "translation": null
    },
    {
      "time": 62.4,
      "time_str": "01:02.400",
      "text": "就算是神圣誓言也能创造出地狱",
      "translation": null
    },
    {
      "time": 64.89,
      "time_str": "01:04.890",
      "text": "愛してる Game世界のDay",
      "translation": "我所深爱着的世界却犹如游戏般地荒谬"
    },
    {
      "time": 67.4,
      "time_str": "01:07.400",
      "text": "Don't-生-War Lie-兵士-War-World",
      "translation": null
    },
    {
      "time": 67.4,
      "time_str": "01:07.400",
      "text": "请不要再制造战争，然后回过头来欺骗士兵，说我们都生存在战争之中",
      "translation": null
    },
    {
      "time": 72.2,
      "time_str": "01:12.200",
      "text": "Eyes-Hate-War",
      "translation": "仇恨着眼前的战争"
    },
    {
      "time": 74.59,
      "time_str": "01:14.590",
      "text": "A-Z Looser-Krankheit-Was IS das?",
      "translation": "从开始到结束，什么才是败者的病痛？"
    },
    {
      "time": 88.5,
      "time_str": "01:28.500",
      "text": "受け売り盾に 見下してても そこには地面しかない事さえ",
      "translation": "凭借着人云亦云，就想装腔作势，这也仅能俯视到地面"
    },
    {
      "time": 98.2,
      "time_str": "01:38.200",
      "text": "気付かぬままに 壊れた 過去に負けた鏡の奥",
      "translation": "假装没有察觉到那残破的过去，而这是过去背负过的命运在镜中所映射的影子"
    },
    {
      "time": 107.0,
      "time_str": "01:47.000",
      "text": "どこまで叫べば位置を知れる とどめもないまま息が切れる",
      "translation": "要如何嘶喊才会拥有自知之明，未承受最后一击却停止了呼吸"
    },
    {
      "time": 116.67,
      "time_str": "01:56.670",
      "text": "堂々さらした罪の群れと 後ろ向きにあらがう",
      "translation": "面对这些恬不知耻的无数罪孽，消极地做着抵抗"
    },
    {
      "time": 125.58,
      "time_str": "02:05.580",
      "text": "愛-same-CRIER 愛撫-save-LIAR",
      "translation": null
    },
    {
      "time": 125.58,
      "time_str": "02:05.580",
      "text": "内心一直在哭泣着，用谎言来安抚受伤的内心",
      "translation": null
    },
    {
      "time": 130.29,
