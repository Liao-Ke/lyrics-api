    {
      "time": 25.19,
      "time_str": "00:25.190",
      "text": "暗想 从前阴雨天",
      "translation": null
    },
    {
      "time": 31.4,
      "time_str": "00:31.400",
      "text": "你的伞 留下了思念",
      "translation": null
    },
    {
      "time": 37.91,
      "time_str": "00:37.910",
      "text": "今夜 你不在我身边",
      "translation": null
    },
    {
      "time": 44.1,
      "time_str": "00:44.100",
      "text": "爱在 断桥边也无法了断",
      "translation": null
    },
    {
      "time": 49.93,
      "time_str": "00:49.930",
      "text": "不管多波折 多磨难",
      "translation": null
    },
    {
      "time": 53.9,
      "time_str": "00:53.900",
      "text": "我心依然",
      "translation": null
    },
    {
      "time": 56.2,
      "time_str": "00:56.200",
      "text": "爱瞬间 痛了一千年",
      "translation": null
    },
    {
      "time": 62.41,
      "time_str": "01:02.410",
      "text": "说声再见心盘起",
      "translation": null
    },
    {
      "time": 65.66,
      "time_str": "01:05.660",
      "text": "缠绵眷恋千百般",
      "translation": null
    },
    {
      "time": 68.79,
      "time_str": "01:08.790",
      "text": "变得温暖",
      "translation": null
    },
    {
      "time": 71.11,
      "time_str": "01:11.110",
      "text": "谁还叹 人一生短暂",
      "translation": null
    },
    {
      "time": 75.14,
      "time_str": "01:15.140",
      "text": "守着那知己",
      "translation": null
    },
    {
      "time": 78.09,
      "time_str": "01:18.090",
      "text": "看不见人世间纷繁",
      "translation": null
    },
    {
      "time": 81.46,
      "time_str": "01:21.460",
      "text": "今生和你并肩 就要你作伴",
      "translation": null
    },
