  "lyrics": [
    {
      "time": 12.24,
      "time_str": "00:12.240",
      "text": "还没到的樱花季  还没用的照相机",
      "translation": null
    },
    {
      "time": 17.48,
      "time_str": "00:17.480",
      "text": "还没光临的餐厅  还在期待  有着你的旅行",
      "translation": null
    },
    {
      "time": 23.24,
      "time_str": "00:23.240",
      "text": "等待日落的巴黎  铁塔之下牵着你",
      "translation": null
    },
    {
      "time": 29.58,
      "time_str": "00:29.580",
      "text": "等待说着我愿意  等待未来  每天身边有你",
      "translation": null
    },
    {
      "time": 35.1,
      "time_str": "00:35.100",
      "text": "一点一滴每一天珍惜",
      "translation": null
    },
    {
      "time": 39.22,
      "time_str": "00:39.220",
      "text": "怕突然来不及  好好的爱你",
      "translation": null
    },
    {
      "time": 45.15,
      "time_str": "00:45.150",
      "text": "时针一直倒数着  我们剩下的快乐",
      "translation": null
    },
    {
      "time": 50.7,
      "time_str": "00:50.700",
      "text": "此刻相拥的狂热  却永远都深刻",
      "translation": null
    },
    {
      "time": 56.7,
      "time_str": "00:56.700",
      "text": "心跳一直倒数着  生命剩下的温热",
      "translation": null
    },
    {
      "time": 62.44,
      "time_str": "01:02.440",
      "text": "至少用力地爱着  还乌黑的头发  有你就不怕白了",
      "translation": null
    },
    {
      "time": 70.69,
      "time_str": "01:10.690",
      "text": "漆黑过后是旭日  泪流以后是坚持",
      "translation": null
    },
    {
      "time": 76.32,
      "time_str": "01:16.320",
      "text": "真的爱是日复日  从不放弃  重复说你愿意",
      "translation": null
    },
    {
      "time": 81.75,
      "time_str": "01:21.750",
      "text": "还没退化的眼睛  抓紧时间看看你",
      "translation": null
    },
    {
      "time": 88.09,
      "time_str": "01:28.090",
      "text": "爱是从来不止息  一个风景  每天新的生命",
      "translation": null
    },
    {
      "time": 93.81,
      "time_str": "01:33.810",
      "text": "一点一滴每一天珍惜",
      "translation": null
    },
    {
      "time": 97.72,
      "time_str": "01:37.720",
      "text": "用尽每一口气  好好的爱你",
      "translation": null
    },
    {
      "time": 103.69,
      "time_str": "01:43.690",
      "text": "时针一直倒数着  我们剩下的快乐",
      "translation": null
    },
    {
      "time": 109.42,
      "time_str": "01:49.420",
      "text": "此刻相拥的狂热  却永远都深刻",
      "translation": null
    },
    {
      "time": 115.06,
      "time_str": "01:55.060",
      "text": "心跳一直倒数着  生命剩下的温热",
      "translation": null
    },
    {
      "time": 121.1,
      "time_str": "02:01.100",
      "text": "至少用力地爱着  还乌黑的头发  有你就不怕白了",
      "translation": null
    },
    {
      "time": 129.76,
      "time_str": "02:09.760",
      "text": "咖啡再不喝就酸了  晚餐再不吃就冷了",
      "translation": null
    },
    {
      "time": 135.44,
      "time_str": "02:15.440",
      "text": "爱着为什么不说呢  难道错过了才来后悔着",
      "translation": null
    },
    {
      "time": 141.02,
      "time_str": "02:21.020",
      "text": "谁梦未实现就醒了  谁心没开过就灰了",
      "translation": null
    },
    {
      "time": 147.18,
      "time_str": "02:27.180",
      "text": "追逐爱的旅途曲折  就算再曲折为你都值得",
      "translation": null
    },
    {
      "time": 152.35,
      "time_str": "02:32.350",
      "text": "一点一滴每一天珍惜",
      "translation": null
    },
    {
      "time": 156.17,
      "time_str": "02:36.170",
      "text": "用尽每一口气  好好的爱你",
      "translation": null
    },
    {
      "time": 162.26,
      "time_str": "02:42.260",
      "text": "时针一直倒数着  我们剩下的快乐",
      "translation": null
    },
    {
      "time": 167.84,
      "time_str": "02:47.840",
      "text": "此刻相拥的狂热  却永远都深刻",
      "translation": null
    },
    {
      "time": 173.73,
      "time_str": "02:53.730",
      "text": "心跳一直倒数着  生命剩下的温热",
      "translation": null
    },
    {
      "time": 179.85,
      "time_str": "02:59.850",
      "text": "至少痛并快乐着  爱过才算活着  有你别无所求了",
      "translation": null
    },
    {
      "time": 191.12,
      "time_str": "03:11.120",
      "text": "有你别无所求了  有你别无所求了",
      "translation": null
    },
    {
      "time": 202.41,
      "time_str": "03:22.410",
      "text": "有你别无所求了  有你别无所求了",
      "translation": null
    },
    {
      "time": 214.02,
