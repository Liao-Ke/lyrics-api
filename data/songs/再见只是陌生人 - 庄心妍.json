  "lyrics": [
    {
      "time": 25.486,
      "time_str": "00:25.486",
      "text": "爱过你 就当你是错的人",
      "translation": null
    },
    {
      "time": 31.239,
      "time_str": "00:31.239",
      "text": "有些错 我们都要负责任",
      "translation": null
    },
    {
      "time": 37.04,
      "time_str": "00:37.040",
      "text": "是否我爱了 不该爱的人",
      "translation": null
    },
    {
      "time": 42.895,
      "time_str": "00:42.895",
      "text": "其实我 想要的并不过分",
      "translation": null
    },
    {
      "time": 48.753,
      "time_str": "00:48.753",
      "text": "爱过你 至少我坦诚承认",
      "translation": null
    },
    {
      "time": 54.503,
      "time_str": "00:54.503",
      "text": "有些错 我们不用去争论",
      "translation": null
    },
    {
      "time": 60.417,
      "time_str": "01:00.417",
      "text": "也许我错过 幸福的时分",
      "translation": null
    },
    {
      "time": 66.567,
      "time_str": "01:06.567",
      "text": "这座城 多了个伤心的人",
      "translation": null
    },
    {
      "time": 72.174,
      "time_str": "01:12.174",
      "text": "我们爱的难舍难分 爱的奋不顾身",
      "translation": null
    },
    {
      "time": 78.147,
      "time_str": "01:18.147",
      "text": "为何再见只是陌生人",
      "translation": null
    },
    {
      "time": 83.85,
      "time_str": "01:23.850",
      "text": "夜来得无声 我的心好冷",
      "translation": null
    },
    {
      "time": 89.752,
      "time_str": "01:29.752",
      "text": "那绝望比分手更伤人",
      "translation": null
    },
    {
      "time": 95.61,
      "time_str": "01:35.610",
      "text": "我们爱的难舍难分 爱的奋不顾身",
      "translation": null
    },
    {
      "time": 101.611,
      "time_str": "01:41.611",
      "text": "爱到最后同样不可能",
      "translation": null
    },
    {
      "time": 107.312,
      "time_str": "01:47.312",
      "text": "你走得无痕 我的心好疼",
      "translation": null
    },
    {
      "time": 113.118,
      "time_str": "01:53.118",
      "text": "该拿什么与眼泪抗衡",
      "translation": null
