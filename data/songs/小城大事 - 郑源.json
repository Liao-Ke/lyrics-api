{
  "title": "小城大事",
  "title_raw": "小城大事",
  "version": null,
  "artist": "郑源",
  "group_key": "小城大事|郑源",
  "writers": {
    "lyricist": "林夕",
    "composer": "雷颂德",
    "arranger": "雷颂德"
  },
  "lyrics": [
    {
      "time": 18.35,
      "time_str": "00:18.350",
      "text": "青春仿佛因我爱你开始",
      "translation": null
    },
    {
      "time": 21.65,
      "time_str": "00:21.650",
      "text": "但却令我看破爱这个字",
      "translation": null
    },
    {
      "time": 25.66,
      "time_str": "00:25.660",
      "text": "自你患上失忆",
      "translation": null
    },
    {
      "time": 28.85,
      "time_str": "00:28.850",
      "text": "便是我扭转命数的事",
      "translation": null
    },
    {
      "time": 34.459,
      "time_str": "00:34.459",
      "text": "只因当失忆症发作加深",
      "translation": null
    },
    {
      "time": 37.509,
      "time_str": "00:37.509",
      "text": "没记住我但却另有更新蜜运",
      "translation": null
    },
    {
      "time": 41.709,
      "time_str": "00:41.709",
      "text": "像狐狸精般",
      "translation": null
    },
    {
      "time": 44.859,
      "time_str": "00:44.859",
      "text": "并未允许我步近",
      "translation": null
    },
    {
      "time": 49.759,
      "time_str": "00:49.759",
      "text": "无回忆的余生",
      "translation": null
    },
    {
      "time": 51.66,
      "time_str": "00:51.660",
      "text": "忘掉往日情人",
      "translation": null
    },
    {
      "time": 53.709,
      "time_str": "00:53.709",
      "text": "却又记住移情别爱的命运",
      "translation": null
    },
    {
      "time": 57.66,
      "time_str": "00:57.660",
      "text": "无回忆的男人",
      "translation": null
    },
    {
      "time": 59.459,
      "time_str": "00:59.459",
      "text": "就当偷厄与瞒骗",
      "translation": null
    },
    {
      "time": 62.559,
      "time_str": "01:02.559",
      "text": "抱抱我不过份",
      "translation": null
    },
    {
      "time": 64.66,
      "time_str": "01:04.660",
      "text": "吻下来 豁出去",
      "translation": null
    },
    {
      "time": 69.21,
      "time_str": "01:09.210",
      "text": "这吻别似覆水",
      "translation": null
    },
    {
      "time": 73.36,
      "time_str": "01:13.360",
      "text": "再来也许要天上团聚",
      "translation": null
    },
    {
      "time": 80.31,
      "time_str": "01:20.310",
      "text": "再回头 你不许",
      "translation": null
    },
    {
      "time": 84.81,
      "time_str": "01:24.810",
      "text": "如曾经不登对",
      "translation": null
    },
    {
      "time": 89.11,
      "time_str": "01:29.110",
      "text": "你何以双眼好像流泪",
      "translation": null
    },
    {
      "time": 113.52,
      "time_str": "01:53.520",
      "text": "彼此追忆不怕爱要终止",
      "translation": null
    },
    {
      "time": 116.57,
      "time_str": "01:56.570",
      "text": "但我大概上世做过太多坏事",
      "translation": null
    },
    {
      "time": 120.669,
      "time_str": "02:00.669",
      "text": "能从头开始",
      "translation": null
    },
    {
      "time": 123.869,
      "time_str": "02:03.869",
      "text": "跪在教堂说愿意",
      "translation": null
    },
    {
      "time": 128.83,
      "time_str": "02:08.830",
      "text": "娱乐行的人影",
      "translation": null
    },
    {
      "time": 130.58,
      "time_str": "02:10.580",
      "text": "还在继续繁荣",
      "translation": null
    },
    {
      "time": 132.98,
      "time_str": "02:12.980",
      "text": "我在算着甜言蜜语的寿命",
      "translation": null
    },
    {
      "time": 136.63,
      "time_str": "02:16.630",
      "text": "人造的蠢卫星",
      "translation": null
    },
    {
      "time": 138.329,
      "time_str": "02:18.329",
      "text": "没探测出我们已",
      "translation": null
    },
    {
      "time": 140.63,
      "time_str": "02:20.630",
      "text": "已再见不再认",
      "translation": null
    },
    {
      "time": 141.93,
      "time_str": "02:21.930",
      "text": "吻下来 豁出去",
      "translation": null
    },
    {
      "time": 150.68,
      "time_str": "02:30.680",
      "text": "这吻别似覆水",
      "translation": null
    },
    {
      "time": 155.23,
      "time_str": "02:35.230",
      "text": "再来也许要天上团聚",
      "translation": null
    },
    {
      "time": 162.23,
      "time_str": "02:42.230",
      "text": "我下来 你出去",
      "translation": null
    },
    {
      "time": 166.48,
      "time_str": "02:46.480",
      "text": "讲再会也心虚",
      "translation": null
    },
    {
      "time": 171.8,
      "time_str": "02:51.800",
      "text": "我还记得到天上团聚",
      "translation": null
    },
    {
      "time": 177.829,
      "time_str": "02:57.829",
      "text": "吻下来 豁出去",
      "translation": null
    },
    {
      "time": 182.14,
      "time_str": "03:02.140",
      "text": "从前多么登对",
      "translation": null
    },
    {
      "time": 183.98,
      "time_str": "03:03.980",
      "text": "你何以双眼好像流泪",
      "translation": null
    },
    {
      "time": 194.94,
      "time_str": "03:14.940",
      "text": "每年这天记得再流泪",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "小城大事 - 郑源.lrc"
}