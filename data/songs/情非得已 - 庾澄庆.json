    {
      "time": 13.63,
      "time_str": "00:13.630",
      "text": "难以忘记初次见你",
      "translation": null
    },
    {
      "time": 17.47,
      "time_str": "00:17.470",
      "text": "一双迷人的眼睛",
      "translation": null
    },
    {
      "time": 22.45,
      "time_str": "00:22.450",
      "text": "在我脑海里 你的身影 挥散不去",
      "translation": null
    },
    {
      "time": 31.21,
      "time_str": "00:31.210",
      "text": "握你的双手感觉你的温柔",
      "translation": null
    },
    {
      "time": 35.92,
      "time_str": "00:35.920",
      "text": "真的有点透不过气",
      "translation": null
    },
    {
      "time": 40.63,
      "time_str": "00:40.630",
      "text": "你的天真我想珍惜",
      "translation": null
    },
    {
      "time": 44.84,
      "time_str": "00:44.840",
      "text": "看到你受委屈我会伤心",
      "translation": null
    },
    {
      "time": 51.31,
      "time_str": "00:51.310",
      "text": "只怕我自己会爱上你",
      "translation": null
    },
    {
      "time": 56.02,
      "time_str": "00:56.020",
      "text": "不敢让自己靠的太近",
      "translation": null
    },
    {
      "time": 60.45,
      "time_str": "01:00.450",
      "text": "怕我没什么能够给你",
      "translation": null
    },
    {
