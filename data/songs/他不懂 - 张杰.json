  "lyrics": [
    {
      "time": 19.41,
      "time_str": "00:19.410",
      "text": "他留给你是背影",
      "translation": null
    },
    {
      "time": 25.06,
      "time_str": "00:25.060",
      "text": "关于爱情只字不提",
      "translation": null
    },
    {
      "time": 29.85,
      "time_str": "00:29.850",
      "text": "害你哭红了眼睛",
      "translation": null
    },
    {
      "time": 34.78,
      "time_str": "00:34.780",
      "text": "他把谎言说的竟然那么动听",
      "translation": null
    },
    {
      "time": 40.75,
      "time_str": "00:40.750",
      "text": "他不止一次骗了你",
      "translation": null
    },
    {
      "time": 44.71,
      "time_str": "00:44.710",
      "text": "不值得你再为他伤心",
      "translation": null
    },
    {
      "time": 48.38,
      "time_str": "00:48.380",
      "text": "他不懂你的心假装冷静",
      "translation": null
    },
    {
      "time": 53.18,
      "time_str": "00:53.180",
      "text": "他不懂爱情把它当游戏",
      "translation": null
    },
    {
      "time": 56.17,
      "time_str": "00:56.170",
      "text": "他不懂表明相爱这件事",
      "translation": null
    },
    {
      "time": 60.06,
      "time_str": "01:00.060",
      "text": "除了对不起就只剩叹息",
      "translation": null
    },
    {
      "time": 64.06,
      "time_str": "01:04.060",
      "text": "他不懂你的心为何哭泣",
      "translation": null
    },
    {
      "time": 68.95,
      "time_str": "01:08.950",
      "text": "窒息到快要不能呼吸",
      "translation": null
    },
    {
      "time": 76.7,
      "time_str": "01:16.700",
      "text": "喔喔",
      "translation": null
    },
    {
      "time": 78.88,
      "time_str": "01:18.880",
      "text": "他不懂你的心",
      "translation": null
    },
    {
      "time": 96.55,
      "time_str": "01:36.550",
      "text": "他把回忆留给你",
      "translation": null
    },
    {
      "time": 103.64,
      "time_str": "01:43.640",
      "text": "连同忧伤强加给你",
      "translation": null
    },
    {
      "time": 108.3,
      "time_str": "01:48.300",
      "text": "对你说来不公平",
      "translation": null
    },
    {
