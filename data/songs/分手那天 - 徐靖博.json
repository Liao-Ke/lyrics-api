  "lyrics": [
    {
      "time": 21.55,
      "time_str": "00:21.550",
      "text": "这么快就走到了尽头",
      "translation": null
    },
    {
      "time": 24.9,
      "time_str": "00:24.900",
      "text": "还以为彼此仍然拥有",
      "translation": null
    },
    {
      "time": 29.06,
      "time_str": "00:29.060",
      "text": "看着那熟悉的脸",
      "translation": null
    },
    {
      "time": 32.23,
      "time_str": "00:32.230",
      "text": "还有双舍不得放开的手",
      "translation": null
    },
    {
      "time": 35.79,
      "time_str": "00:35.790",
      "text": "许多话还没有说出口",
      "translation": null
    },
    {
      "time": 39.47,
      "time_str": "00:39.470",
      "text": "回头看看来时的路",
      "translation": null
    },
    {
      "time": 43.05,
      "time_str": "00:43.050",
      "text": "虽然充满坎坷",
      "translation": null
    },
    {
      "time": 46.38,
      "time_str": "00:46.380",
      "text": "我们也肩并肩的渡过",
      "translation": null
    },
    {
      "time": 50.4,
      "time_str": "00:50.400",
      "text": "爱不是一封情书",
      "translation": null
    },
    {
      "time": 53.93,
      "time_str": "00:53.930",
      "text": "爱是无悔的付出",
      "translation": null
    },
    {
      "time": 57.36,
      "time_str": "00:57.360",
      "text": "爱不是相互约束",
      "translation": null
    },
    {
      "time": 61.04,
      "time_str": "01:01.040",
      "text": "爱是衷心的",
      "translation": null
    },
    {
      "time": 63.13,
      "time_str": "01:03.130",
      "text": "一生的祝福",
      "translation": null
    },
    {
      "time": 68.03,
      "time_str": "01:08.030",
      "text": "如果真有再见那天",
      "translation": null
    },
    {
      "time": 71.52,
      "time_str": "01:11.520",
      "text": "求求你不要泪流满面",
      "translation": null
    },
    {
      "time": 75.12,
      "time_str": "01:15.120",
      "text": "你知道我会哭",
      "translation": null
    },
    {
      "time": 77.18,
      "time_str": "01:17.180",
      "text": "我会忍不住",
      "translation": null
    },
    {
      "time": 78.92,
      "time_str": "01:18.920",
      "text": "我会紧紧的把你抱住",
      "translation": null
    },
    {
      "time": 82.37,
      "time_str": "01:22.370",
      "text": "如果也有寂寞那天",
      "translation": null
    },
    {
      "time": 85.75,
      "time_str": "01:25.750",
      "text": "就一起想想我们从前",
      "translation": null
    },
    {
      "time": 89.45,
      "time_str": "01:29.450",
      "text": "不管再多天",
      "translation": null
    },
    {
      "time": 91.39,
      "time_str": "01:31.390",
      "text": "不管再多年",
      "translation": null
    },
    {
      "time": 93.21,
      "time_str": "01:33.210",
      "text": "回忆永远是",
      "translation": null
    },
    {
      "time": 95.05,
      "time_str": "01:35.050",
      "text": "我给你最真的礼物",
      "translation": null
    },
    {
