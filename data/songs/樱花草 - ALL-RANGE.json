    {
      "time": 28.0,
      "time_str": "00:28.000",
      "text": "晚风吹动着竹林 月光拉长的身影",
      "translation": null
    },
    {
      "time": 34.56,
      "time_str": "00:34.560",
      "text": "萤火虫 一闪闪 满山飞舞的钱币",
      "translation": null
    },
    {
      "time": 40.97,
      "time_str": "00:40.970",
      "text": "天上银河在发光 地上风铃来歌唱",
      "translation": null
    },
    {
      "time": 47.48,
      "time_str": "00:47.480",
      "text": "织女星 在远方 古老浪漫的神话",
      "translation": null
    },
    {
      "time": 54.36,
      "time_str": "00:54.360",
      "text": "流水走过 春夏四季的变换",
      "translation": null
    },
    {
      "time": 60.83,
      "time_str": "01:00.830",
      "text": "幸福 在蔓延 爱你永恒不孤单",
      "translation": null
    },
    {
      "time": 66.89,
      "time_str": "01:06.890",
      "text": "恋人手中樱花草 春彩满布的微笑",
      "translation": null
    },
    {
      "time": 73.45,
      "time_str": "01:13.450",
      "text": "种下了 一朵朵 青春璀璨的年少",
      "translation": null
    },
    {
      "time": 79.86,
      "time_str": "01:19.860",
      "text": "恋人怀中樱花草 听见胸膛心在跳",
      "translation": null
    },
    {
      "time": 86.41,
      "time_str": "01:26.410",
      "text": "偷偷的 在思念 那是我们相爱的记号",
      "translation": null
    },
    {
      "time": 108.24,
      "time_str": "01:48.240",
      "text": "啦啦啦",
      "translation": null
    },
    {
      "time": 120.5,
      "time_str": "02:00.500",
      "text": "远方钟声再响起 蛙鸣唱起了摇篮曲",
      "translation": null
    },
    {
