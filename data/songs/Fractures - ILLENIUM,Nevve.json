  "lyrics": [
    {
      "time": 25.0,
      "time_str": "00:25.000",
      "text": "Burning everything I know",
      "translation": "熊熊烈焰燃尽目所能及的一切"
    },
    {
      "time": 30.59,
      "time_str": "00:30.590",
      "text": "Desperate for a change",
      "translation": "绝望的火焰中寻觅着涅槃重生的蜕变"
    },
    {
      "time": 37.16,
      "time_str": "00:37.160",
      "text": "Crashing down the ancient roads",
      "translation": "一路疾驰过苍老的路"
    },
    {
      "time": 42.65,
      "time_str": "00:42.650",
      "text": "Past our yesterday",
      "translation": "挥别昨天"
    },
    {
      "time": 49.36,
      "time_str": "00:49.360",
      "text": "Maybe there is hunger in my blood",
      "translation": "也许那贪婪在我血液中流淌"
    },
    {
      "time": 55.39,
      "time_str": "00:55.390",
      "text": "Screaming out loud for what I want",
      "translation": "嘶吼出我欲求渴想的一切"
    },
    {
      "time": 59.17,
      "time_str": "00:59.170",
      "text": "See me running full speed at it",
      "translation": "且看我全速奔跑追逐着那些"
    },
    {
      "time": 63.95,
      "time_str": "01:03.950",
      "text": "Shattering, collide",
      "translation": "即便是粉身碎骨 亦能复而重生"
    },
    {
      "time": 65.8,
      "time_str": "01:05.800",
      "text": "Call it post-traumatic",
      "translation": "你大可随意唾弃伤痕累累的我"
    },
    {
      "time": 69.93,
      "time_str": "01:09.930",
      "text": "Now it's do or die",
      "translation": "我只准备孤注一掷"
    },
    {
      "time": 72.6,
      "time_str": "01:12.600",
      "text": "Coming after tiny fractures",
      "translation": "哪怕我只是那渺小的裂纹随其漂泊"
    },
    {
