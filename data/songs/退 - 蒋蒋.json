    {
      "time": 31.11,
      "time_str": "00:31.110",
      "text": "我们乐此不疲",
      "translation": null
    },
    {
      "time": 34.56,
      "time_str": "00:34.560",
      "text": "沉迷情感游戏",
      "translation": null
    },
    {
      "time": 38.23,
      "time_str": "00:38.230",
      "text": "大雨总在纷纷扰扰中断句",
      "translation": null
    },
    {
      "time": 45.6,
      "time_str": "00:45.600",
      "text": "往事今非昔比",
      "translation": null
    },
    {
      "time": 49.1,
      "time_str": "00:49.100",
      "text": "回忆如一滩泥",
      "translation": null
    },
    {
      "time": 52.79,
      "time_str": "00:52.790",
      "text": "陷入沼泽的你遇到了天敌",
      "translation": null
    },
    {
      "time": 58.39,
      "time_str": "00:58.390",
      "text": "谎言变本加厉的说客",
      "translation": null
    },
    {
      "time": 66.15,
      "time_str": "01:06.150",
      "text": "好多委屈无法平复的过客",
      "translation": null
    },
    {
      "time": 72.73,
      "time_str": "01:12.730",
      "text": "后退 退到没了绝路我好狼狈",
      "translation": null
    },
    {
      "time": 78.07,
      "time_str": "01:18.070",
      "text": "撑到最后我不敢再奉陪",
      "translation": null
    },
    {
      "time": 81.82,
      "time_str": "01:21.820",
      "text": "流着眼泪装什么大无畏",
      "translation": null
    },
    {
      "time": 85.4,
      "time_str": "01:25.400",
      "text": "现在尝到无路可退孤独的滋味",
      "translation": null
    },
    {
      "time": 90.94,
      "time_str": "01:30.940",
      "text": "后退 退到悬崖绝壁我好心碎",
      "translation": null
    },
    {
      "time": 96.33,
      "time_str": "01:36.330",
      "text": "粉身碎骨我不怕成野鬼",
      "translation": null
    },
    {
      "time": 100.08,
      "time_str": "01:40.080",
      "text": "你的眼角为什么还有泪",
      "translation": null
    },
    {
      "time": 103.61,
      "time_str": "01:43.610",
      "text": "终于明白我们都在黑夜里沉醉 沉醉",
      "translation": null
    },
