{
  "title": "讲不出的告别-2002年的第一场雪",
  "title_raw": "讲不出的告别-2002年的第一场雪",
  "version": null,
  "artist": "谭咏麟,刀郎",
  "group_key": "讲不出的告别-2002年的第一场雪|谭咏麟,刀郎",
  "writers": {
    "lyricist": "刀郎/潘源良",
    "composer": "刀郎",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 30.49,
      "time_str": "00:30.490",
      "text": "２００２年的第一场雪",
      "translation": null
    },
    {
      "time": 34.39,
      "time_str": "00:34.390",
      "text": "比以往时候来得更晚一些",
      "translation": null
    },
    {
      "time": 39.66,
      "time_str": "00:39.660",
      "text": "停靠在八楼的二路汽车",
      "translation": null
    },
    {
      "time": 44.47,
      "time_str": "00:44.470",
      "text": "带走了最后一片飘落的黄叶",
      "translation": null
    },
    {
      "time": 49.54,
      "time_str": "00:49.540",
      "text": "漆黑天空好比一声叹息",
      "translation": null
    },
    {
      "time": 53.96,
      "time_str": "00:53.960",
      "text": "只可惜必须上路创建我价值",
      "translation": null
    },
    {
      "time": 59.17,
      "time_str": "00:59.170",
      "text": "不想解释我要担当的压力",
      "translation": null
    },
    {
      "time": 63.58,
      "time_str": "01:03.580",
      "text": "祝福你 祝福你 讲不出告别",
      "translation": null
    },
    {
      "time": 68.37,
      "time_str": "01:08.370",
      "text": "忘不了把你搂在怀里的感觉",
      "translation": null
    },
    {
      "time": 73.11,
      "time_str": "01:13.110",
      "text": "比藏在心中那份火热更暖一些",
      "translation": null
    },
    {
      "time": 77.93,
      "time_str": "01:17.930",
      "text": "可惜一生不止风花雪月",
      "translation": null
    },
    {
      "time": 79.95,
      "time_str": "01:19.950",
      "text": "不可以栖息于你芬芳的暖热",
      "translation": null
    },
    {
      "time": 116.82,
      "time_str": "01:56.820",
      "text": "是你的红唇粘住我的一切",
      "translation": null
    },
    {
      "time": 121.56,
      "time_str": "02:01.560",
      "text": "分开的天空各自染出彩色",
      "translation": null
    },
    {
      "time": 126.8,
      "time_str": "02:06.800",
      "text": "是你的万种柔情融化冰雪",
      "translation": null
    },
    {
      "time": 131.14,
      "time_str": "02:11.140",
      "text": "他朝凑巧的再会也许不必",
      "translation": null
    },
    {
      "time": 136.22,
      "time_str": "02:16.220",
      "text": "口中讲不出的一声告别",
      "translation": null
    },
    {
      "time": 140.13,
      "time_str": "02:20.130",
      "text": "在眼里告诉你叫我更珍惜",
      "translation": null
    },
    {
      "time": 145.45,
      "time_str": "02:25.450",
      "text": "追忆将必种种关于你的",
      "translation": null
    },
    {
      "time": 150.15,
      "time_str": "02:30.150",
      "text": "收起跟抛开也无非耗费气力",
      "translation": null
    },
    {
      "time": 155.5,
      "time_str": "02:35.500",
      "text": "２００２年的第一场雪",
      "translation": null
    },
    {
      "time": 159.71,
      "time_str": "02:39.710",
      "text": "是留在乌鲁木齐难舍的情结",
      "translation": null
    },
    {
      "time": 164.89,
      "time_str": "02:44.890",
      "text": "你像一只飞来飞去的蝴蝶",
      "translation": null
    },
    {
      "time": 169.5,
      "time_str": "02:49.500",
      "text": "在白雪飘飞的季节里摇曳",
      "translation": null
    },
    {
      "time": 204.18,
      "time_str": "03:24.180",
      "text": "是你的红唇粘住我的一切",
      "translation": null
    },
    {
      "time": 208.95,
      "time_str": "03:28.950",
      "text": "分开的天空各自染出彩色",
      "translation": null
    },
    {
      "time": 213.74,
      "time_str": "03:33.740",
      "text": "是你的万种柔情融化冰雪",
      "translation": null
    },
    {
      "time": 218.52,
      "time_str": "03:38.520",
      "text": "是你的甜言蜜语改变季节",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "讲不出的告别-2002年的第一场雪 - 谭咏麟,刀郎.lrc"
}