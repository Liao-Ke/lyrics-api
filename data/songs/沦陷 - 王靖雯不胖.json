  "lyrics": [
    {
      "time": 16.28,
      "time_str": "00:16.280",
      "text": "你走之后整个世界",
      "translation": null
    },
    {
      "time": 20.32,
      "time_str": "00:20.320",
      "text": "像是期待黎明的黑夜",
      "translation": null
    },
    {
      "time": 23.5,
      "time_str": "00:23.500",
      "text": "我被自己封锁",
      "translation": null
    },
    {
      "time": 25.97,
      "time_str": "00:25.970",
      "text": "在第五个不存在的季节",
      "translation": null
    },
    {
      "time": 30.37,
      "time_str": "00:30.370",
      "text": "剪下了翅膀的蝴蝶",
      "translation": null
    },
    {
      "time": 34.86,
      "time_str": "00:34.860",
      "text": "只能选择和玫瑰告别",
      "translation": null
    },
    {
      "time": 38.3,
      "time_str": "00:38.300",
      "text": "我没想过后果",
      "translation": null
    },
    {
      "time": 39.97,
      "time_str": "00:39.970",
      "text": "以为你就是我爱的一切",
      "translation": null
    },
    {
      "time": 44.41,
      "time_str": "00:44.410",
      "text": "出现在 小说电影的桥段",
      "translation": null
    },
    {
      "time": 49.51,
      "time_str": "00:49.510",
      "text": "镜头下拥抱 分开的画面",
      "translation": null
    },
    {
      "time": 53.0,
      "time_str": "00:53.000",
      "text": "回忆情节 重合明显",
      "translation": null
    },
    {
      "time": 56.38,
      "time_str": "00:56.380",
      "text": "模糊了从前",
      "translation": null
    },
    {
      "time": 61.139,
      "time_str": "01:01.139",
      "text": "我的爱 滴滴点点",
      "translation": null
    },
    {
      "time": 63.569,
      "time_str": "01:03.569",
      "text": "圆圆圈圈 像断了线",
      "translation": null
    },
    {
      "time": 65.84,
      "time_str": "01:05.840",
      "text": "你曾经 心心念念 信誓旦旦",
      "translation": null
    },
    {
      "time": 69.48,
      "time_str": "01:09.480",
      "text": "时间 改变 昨天 所以",
      "translation": null
    },
    {
      "time": 73.37,
      "time_str": "01:13.370",
      "text": "爱会消失不见",
      "translation": null
    },
    {
      "time": 76.099,
      "time_str": "01:16.099",
      "text": "我的心 明明暗暗",
      "translation": null
    },
    {
      "time": 78.17,
      "time_str": "01:18.170",
      "text": "零零散散 缺氧搁浅",
      "translation": null
    },
    {
      "time": 80.59,
      "time_str": "01:20.590",
      "text": "你带走 我的呼吸 不顾不管",
      "translation": null
    },
    {
      "time": 84.23,
      "time_str": "01:24.230",
      "text": "爱沦陷在边缘 等待救援",
