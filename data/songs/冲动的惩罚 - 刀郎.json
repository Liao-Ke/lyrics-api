  },
  "lyrics": [
    {
      "time": 25.295,
      "time_str": "00:25.295",
      "text": "那夜我喝醉了拉着你的手",
      "translation": null
    },
    {
      "time": 29.929,
      "time_str": "00:29.929",
      "text": "胡乱地说话",
      "translation": null
    },
    {
      "time": 34.852,
      "time_str": "00:34.852",
      "text": "只顾着自己心中压抑的想法",
      "translation": null
    },
    {
      "time": 39.721,
      "time_str": "00:39.721",
      "text": "狂乱地表达",
      "translation": null
    },
    {
      "time": 44.345,
      "time_str": "00:44.345",
      "text": "我迷醉的眼睛",
      "translation": null
    },
    {
      "time": 46.678,
      "time_str": "00:46.678",
      "text": "已看不清你表情",
      "translation": null
    },
    {
      "time": 49.226,
      "time_str": "00:49.226",
      "text": "忘记了你当时会有怎样的反应",
      "translation": null
    },
    {
      "time": 53.893,
      "time_str": "00:53.893",
      "text": "我拉着你的手",
      "translation": null
    },
    {
      "time": 56.46,
      "time_str": "00:56.460",
      "text": "放在我手心",
      "translation": null
    },
    {
      "time": 58.792,
      "time_str": "00:58.792",
      "text": "我错误地感觉到你也没有生气",
      "translation": null
    },
    {
      "time": 62.906,
      "time_str": "01:02.906",
      "text": "所以我以为",
      "translation": null
    },
    {
      "time": 67.819,
      "time_str": "01:07.819",
      "text": "你会明白我的良苦用心",
      "translation": null
    },
    {
      "time": 78.133,
      "time_str": "01:18.133",
      "text": "直到你转身离去那一刻起",
      "translation": null
    },
    {
      "time": 82.773,
      "time_str": "01:22.773",
      "text": "逐渐地清醒",
      "translation": null
    },
    {
      "time": 87.652,
      "time_str": "01:27.652",
      "text": "才知道把我世界强加给你",
      "translation": null
    },
    {
      "time": 92.547,
      "time_str": "01:32.547",
      "text": "还需要勇气",
      "translation": null
    },
    {
      "time": 97.169,
      "time_str": "01:37.169",
      "text": "在你的内心里",
      "translation": null
    },
    {
      "time": 99.474,
      "time_str": "01:39.474",
      "text": "是怎样对待感情",
      "translation": null
    },
    {
      "time": 102.068,
      "time_str": "01:42.068",
      "text": "直到现在你都没有对我提起",
      "translation": null
    },
    {
      "time": 106.692,
      "time_str": "01:46.692",
      "text": "我自说自话",
      "translation": null
    },
    {
      "time": 109.281,
      "time_str": "01:49.281",
      "text": "简单的想法",
      "translation": null
    },
    {
      "time": 111.321,
      "time_str": "01:51.321",
      "text": "在你看来这根本就是一个笑话",
      "translation": null
    },
    {
      "time": 115.438,
      "time_str": "01:55.438",
      "text": "所以我伤悲",
      "translation": null
    },
    {
      "time": 120.848,
      "time_str": "02:00.848",
      "text": "尽管手中还残留着你的香味",
      "translation": null
    },
    {
      "time": 129.865,
      "time_str": "02:09.865",
      "text": "如果那天你不知道我喝了多少杯",
      "translation": null
    },
    {
      "time": 135.499,
      "time_str": "02:15.499",
      "text": "你就不会明白你究竟有多美",
      "translation": null
    },
    {
      "time": 139.873,
      "time_str": "02:19.873",
      "text": "我也不会相信第一次看见你",
      "translation": null
    },
    {
      "time": 144.738,
      "time_str": "02:24.738",
      "text": "就爱你爱得那么干脆",
      "translation": null
    },
    {
      "time": 149.135,
      "time_str": "02:29.135",
      "text": "可是我相信我心中的感觉",
      "translation": null
    },
    {
      "time": 154.283,
      "time_str": "02:34.283",
      "text": "它来得那么快来得那么直接",
      "translation": null
    },
    {
      "time": 159.157,
      "time_str": "02:39.157",
      "text": "就算我心狂野",
      "translation": null
    },
    {
      "time": 161.696,
      "time_str": "02:41.696",
      "text": "无法将火熄灭",
      "translation": null
    },
    {
      "time": 164.013,
      "time_str": "02:44.013",
      "text": "我依然相信是老天让你我相约",
      "translation": null
    },
    {
      "time": 168.425,
      "time_str": "02:48.425",
      "text": "如果说没有闻到残留",
      "translation": null
    },
    {
      "time": 171.027,
      "time_str": "02:51.027",
      "text": "手中你的香水",
      "translation": null
    },
    {
      "time": 173.864,
      "time_str": "02:53.864",
      "text": "我绝对不会辗转反侧难以入睡",
      "translation": null
    },
    {
      "time": 178.483,
      "time_str": "02:58.483",
      "text": "就想着你的美",
      "translation": null
    },
    {
      "time": 180.807,
      "time_str": "03:00.807",
      "text": "闻着你的香味",
      "translation": null
    },
    {
      "time": 183.133,
      "time_str": "03:03.133",
      "text": "在冰与火的情欲中挣扎徘徊",
      "translation": null
    },
    {
      "time": 187.481,
      "time_str": "03:07.481",
      "text": "如果说不是老天让缘分把我捉弄",
      "translation": null
    },
    {
      "time": 193.148,
      "time_str": "03:13.148",
      "text": "想到你我就不会那么心痛",
      "translation": null
    },
    {
      "time": 197.777,
      "time_str": "03:17.777",
      "text": "就把你忘记吧",
      "translation": null
    },
    {
      "time": 200.097,
      "time_str": "03:20.097",
      "text": "应该把你忘了",
      "translation": null
    },
    {
      "time": 203.191,
      "time_str": "03:23.191",
      "text": "这是对冲动",
      "translation": null
    },
    {
      "time": 206.55,
      "time_str": "03:26.550",
      "text": "最好的惩罚",
      "translation": null
    },
    {
