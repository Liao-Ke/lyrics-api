  "lyrics": [
    {
      "time": 12.512,
      "time_str": "00:12.512",
      "text": "感受停在我发端的指尖",
      "translation": null
    },
    {
      "time": 16.573,
      "time_str": "00:16.573",
      "text": "如何瞬间冻结时间",
      "translation": null
    },
    {
      "time": 23.365,
      "time_str": "00:23.365",
      "text": "记住望着我坚定的双眼",
      "translation": null
    },
    {
      "time": 27.308,
      "time_str": "00:27.308",
      "text": "也许已经没有明天",
      "translation": null
    },
    {
      "time": 33.597,
      "time_str": "00:33.597",
      "text": "面对浩瀚的星海",
      "translation": null
    },
    {
      "time": 36.394,
      "time_str": "00:36.394",
      "text": "我们微小得像尘埃",
      "translation": null
    },
    {
      "time": 38.906,
      "time_str": "00:38.906",
      "text": "漂浮在一片无奈",
      "translation": null
    },
    {
      "time": 44.684,
      "time_str": "00:44.684",
      "text": "缘分让我们相遇乱世以外",
      "translation": null
    },
    {
      "time": 50.126,
      "time_str": "00:50.126",
      "text": "命运却要我们危难中相爱",
      "translation": null
    },
    {
      "time": 55.544,
      "time_str": "00:55.544",
      "text": "也许未来遥远在光年之外",
      "translation": null
    },
    {
      "time": 60.989,
      "time_str": "01:00.989",
      "text": "我愿守候未知里",
      "translation": null
    },
    {
      "time": 63.643,
      "time_str": "01:03.643",
      "text": "为你等待",
      "translation": null
    },
    {
      "time": 65.109,
      "time_str": "01:05.109",
      "text": "我没想到",
      "translation": null
    },
    {
      "time": 66.396,
      "time_str": "01:06.396",
      "text": "为了你我能疯狂到",
      "translation": null
    },
    {
      "time": 70.571,
      "time_str": "01:10.571",
      "text": "山崩海啸",
      "translation": null
    },
    {
      "time": 71.786,
      "time_str": "01:11.786",
      "text": "没有你根本不想逃",
      "translation": null
    },
    {
      "time": 76.058,
      "time_str": "01:16.058",
      "text": "我的大脑",
      "translation": null
    },
    {
      "time": 77.327,
      "time_str": "01:17.327",
      "text": "为了你已经疯狂到",
      "translation": null
    },
    {
      "time": 81.477,
      "time_str": "01:21.477",
      "text": "脉搏心跳",
      "translation": null
    },
    {
      "time": 82.718,
      "time_str": "01:22.718",
      "text": "没有你根本不重要",
      "translation": null
    },
    {
      "time": 88.891,
      "time_str": "01:28.891",
      "text": "一双围在我胸口的臂弯",
      "translation": null
    },
    {
      "time": 92.768,
      "time_str": "01:32.768",
      "text": "足够抵挡 天旋地转",
      "translation": null
    },
    {
      "time": 99.6,
      "time_str": "01:39.600",
      "text": "一种执迷不放手的倔强",
      "translation": null
    },
    {
      "time": 103.655,
      "time_str": "01:43.655",
      "text": "足以点燃 所有希望",
      "translation": null
    },
    {
      "time": 110.029,
      "time_str": "01:50.029",
      "text": "宇宙磅礴而冷漠",
      "translation": null
    },
    {
      "time": 112.707,
      "time_str": "01:52.707",
      "text": "我们的爱微小却闪烁",
      "translation": null
    },
    {
      "time": 115.211,
      "time_str": "01:55.211",
      "text": "颠簸却如此忘我",
