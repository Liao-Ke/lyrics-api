{
  "title": "机器铃 砍菜刀",
  "title_raw": "机器铃 砍菜刀",
  "version": null,
  "artist": "张卫",
  "group_key": "机器铃 砍菜刀|张卫",
  "writers": {
    "lyricist": null,
    "composer": null,
    "arranger": null
  },
  "lyrics": [
    {
      "time": 14.377,
      "time_str": "00:14.377",
      "text": "是不是一个人太久了 总觉得时间在翻倍的过",
      "translation": null
    },
    {
      "time": 21.57,
      "time_str": "00:21.570",
      "text": "我不知道自己在找什么 只觉得丢了很多",
      "translation": null
    },
    {
      "time": 28.938,
      "time_str": "00:28.938",
      "text": "星星还是那颗星星 但被霾遮住了光明",
      "translation": null
    },
    {
      "time": 36.259,
      "time_str": "00:36.259",
      "text": "我怀念狗屁不通的光阴 最初的节奏你听",
      "translation": null
    },
    {
      "time": 43.584,
      "time_str": "00:43.584",
      "text": "（二八二五六 二八二五七 二八二九三十一",
      "translation": null
    },
    {
      "time": 51.0,
      "time_str": "00:51.000",
      "text": "三八三五六 三八三五七 三八三九四十一）",
      "translation": null
    },
    {
      "time": 58.65,
      "time_str": "00:58.650",
      "text": "你知道我有多想回到老家和泥巴",
      "translation": null
    },
    {
      "time": 61.936,
      "time_str": "01:01.936",
      "text": "再邀子那些光腚伙家去坑里逮青蛙",
      "translation": null
    },
    {
      "time": 65.653,
      "time_str": "01:05.653",
      "text": "给俺爷爷卷袋烟叶 听俺奶奶拉拉呱",
      "translation": null
    },
    {
      "time": 70.049,
      "time_str": "01:10.049",
      "text": "他们这一代人没有文化但是很伟大",
      "translation": null
    },
    {
      "time": 73.183,
      "time_str": "01:13.183",
      "text": "我想不起来那台黑白电视演哩啥",
      "translation": null
    },
    {
      "time": 76.751,
      "time_str": "01:16.751",
      "text": "也想不起来鞠萍姐姐当年说哩话",
      "translation": null
    },
    {
      "time": 80.516,
      "time_str": "01:20.516",
      "text": "我找不到我跳房子踢哩那片瓦",
      "translation": null
    },
    {
      "time": 84.248,
      "time_str": "01:24.248",
      "text": "谁知道我哩弹球和票夹都放哪里啦",
      "translation": null
    },
    {
      "time": 88.058,
      "time_str": "01:28.058",
      "text": "一个沙坑一个秋千俺就能玩上一天",
      "translation": null
    },
    {
      "time": 91.819,
      "time_str": "01:31.819",
      "text": "饿了爬到树上摘点槐花吃点榆钱",
      "translation": null
    },
    {
      "time": 96.26,
      "time_str": "01:36.260",
      "text": "马泡有多香 桑葚有多甜",
      "translation": null
    },
    {
      "time": 99.141,
      "time_str": "01:39.141",
      "text": "溜溜菶菶架戏台 再抓把黑添添",
      "translation": null
    },
    {
      "time": 102.801,
      "time_str": "01:42.801",
      "text": "谁捅了马蜂窝谁被蛰哩疙瘩多",
      "translation": null
    },
    {
      "time": 106.36,
      "time_str": "01:46.360",
      "text": "谁晚上尿了床白天就得少玩火",
      "translation": null
    },
    {
      "time": 110.069,
      "time_str": "01:50.069",
      "text": "谁骑着大梁自行车 扎过麦秸垛",
      "translation": null
    },
    {
      "time": 114.218,
      "time_str": "01:54.218",
      "text": "谁哩作业最多谁就捞不着一起唱儿歌",
      "translation": null
    },
    {
      "time": 117.548,
      "time_str": "01:57.548",
      "text": "机器铃 砍菜刀 恁那边哩紧俺挑",
      "translation": null
    },
    {
      "time": 124.769,
      "time_str": "02:04.769",
      "text": "挑谁吧 挑 挑的那个人已经回家了",
      "translation": null
    },
    {
      "time": 132.187,
      "time_str": "02:12.187",
      "text": "机器铃 砍菜刀 恁那边哩紧俺挑",
      "translation": null
    },
    {
      "time": 139.601,
      "time_str": "02:19.601",
      "text": "挑谁吧 挑 挑的那个人已经回家了",
      "translation": null
    },
    {
      "time": 147.229,
      "time_str": "02:27.229",
      "text": "我想俺姐姐分给我哩那块糖疙瘩",
      "translation": null
    },
    {
      "time": 150.688,
      "time_str": "02:30.688",
      "text": "我很后悔当年为啥老是欺负她",
      "translation": null
    },
    {
      "time": 154.047,
      "time_str": "02:34.047",
      "text": "现在我有了小外甥还在欺负她",
      "translation": null
    },
    {
      "time": 157.655,
      "time_str": "02:37.655",
      "text": "我说老姐啊老姐 你真的辛苦啦",
      "translation": null
    },
    {
      "time": 161.519,
      "time_str": "02:41.519",
      "text": "每天放学俺爸爸都会骑车接我回家",
      "translation": null
    },
    {
      "time": 165.277,
      "time_str": "02:45.277",
      "text": "他说谁吃饭吃哩多他就给谁买贴画",
      "translation": null
    },
    {
      "time": 168.837,
      "time_str": "02:48.837",
      "text": "偶尔老师也会叫他去学校谈谈话",
      "translation": null
    },
    {
      "time": 172.706,
      "time_str": "02:52.706",
      "text": "他回来打了我一巴掌他自己也哭啦",
      "translation": null
    },
    {
      "time": 176.67,
      "time_str": "02:56.670",
      "text": "俺妈妈给我打哩毛衣总是有点大",
      "translation": null
    },
    {
      "time": 180.026,
      "time_str": "03:00.026",
      "text": "直到长大以后我才明白那是因为啥",
      "translation": null
    },
    {
      "time": 183.887,
      "time_str": "03:03.887",
      "text": "她哩委屈都在心里从不善于表达",
      "translation": null
    },
    {
      "time": 187.393,
      "time_str": "03:07.393",
      "text": "但我知道她最牵挂哩就是俺姐弟俩",
      "translation": null
    },
    {
      "time": 191.0,
      "time_str": "03:11.000",
      "text": "其实我很想看俺爸爸妈妈再吵一次架",
      "translation": null
    },
    {
      "time": 194.662,
      "time_str": "03:14.662",
      "text": "但是94年哩全家福往后不再有啦",
      "translation": null
    },
    {
      "time": 198.781,
      "time_str": "03:18.781",
      "text": "爸爸 妈妈 姐姐 你们都还好嘛",
      "translation": null
    },
    {
      "time": 202.3,
      "time_str": "03:22.300",
      "text": "我很想你们 更想回咱以前那个家",
      "translation": null
    },
    {
      "time": 206.318,
      "time_str": "03:26.318",
      "text": "机器铃 砍菜刀 恁哪边哩紧俺挑",
      "translation": null
    },
    {
      "time": 213.381,
      "time_str": "03:33.381",
      "text": "挑谁吧 挑 挑的那个人回不去家了",
      "translation": null
    },
    {
      "time": 220.801,
      "time_str": "03:40.801",
      "text": "机器铃 砍菜刀 恁哪边哩紧俺挑",
      "translation": null
    },
    {
      "time": 228.077,
      "time_str": "03:48.077",
      "text": "挑谁吧 挑 挑的那个人回不去家了",
      "translation": null
    },
    {
      "time": 235.899,
      "time_str": "03:55.899",
      "text": "我多想和俺老表再一起逃节课",
      "translation": null
    },
    {
      "time": 239.2,
      "time_str": "03:59.200",
      "text": "去蒙山商场打游戏机一直打到饿",
      "translation": null
    },
    {
      "time": 242.058,
      "time_str": "04:02.058",
      "text": "抽哩第一口烟应该是两毛钱哩飞鸽",
      "translation": null
    },
    {
      "time": 246.789,
      "time_str": "04:06.789",
      "text": "喝哩第一口酒是不是兰陵我不记得",
      "translation": null
    },
    {
      "time": 250.294,
      "time_str": "04:10.294",
      "text": "我踩在张家斌哩肩膀爬过几次墙头",
      "translation": null
    },
    {
      "time": 254.004,
      "time_str": "04:14.004",
      "text": "和赵顺去工地上偷过几个卡口",
      "translation": null
    },
    {
      "time": 257.661,
      "time_str": "04:17.661",
      "text": "在体育场拜把子磕过几个响头",
      "translation": null
    },
    {
      "time": 261.223,
      "time_str": "04:21.223",
      "text": "看看以前哩合影 造型 儿哩也 全是非主流",
      "translation": null
    },
    {
      "time": 265.043,
      "time_str": "04:25.043",
      "text": "在路边听我和君耀唱歌哩人成群结队",
      "translation": null
    },
    {
      "time": 268.697,
      "time_str": "04:28.697",
      "text": "他们说俺俩玩音乐 其实俺俩是为了漏味",
      "translation": null
    },
    {
      "time": 272.509,
      "time_str": "04:32.509",
      "text": "有人看俺不愤儿  是为了争小闺女",
      "translation": null
    },
    {
      "time": 276.274,
      "time_str": "04:36.274",
      "text": "想想那些屁事 哎呦 真是味儿",
      "translation": null
    },
    {
      "time": 279.928,
      "time_str": "04:39.928",
      "text": "能弥补失去哩童年也莫过于咱们哩初恋",
      "translation": null
    },
    {
      "time": 283.589,
      "time_str": "04:43.589",
      "text": "那时候什么都不图只是一味的想和她见面",
      "translation": null
    },
    {
      "time": 287.502,
      "time_str": "04:47.502",
      "text": "看着她哩照片 感觉每天都是晴天",
      "translation": null
    },
    {
      "time": 290.805,
      "time_str": "04:50.805",
      "text": "那些上课传过哩纸条现在只能在心里默念",
      "translation": null
    },
    {
      "time": 294.721,
      "time_str": "04:54.721",
      "text": "机器铃 砍菜刀 恁那边哩紧俺挑",
      "translation": null
    },
    {
      "time": 302.038,
      "time_str": "05:02.038",
      "text": "挑谁吧 挑 挑的那个人已经长大了",
      "translation": null
    },
    {
      "time": 309.36,
      "time_str": "05:09.360",
      "text": "机器铃 砍菜刀 恁那边哩紧俺挑",
      "translation": null
    },
    {
      "time": 316.692,
      "time_str": "05:16.692",
      "text": "挑谁吧 挑 挑的那个人已经长大了",
      "translation": null
    },
    {
      "time": 339.072,
      "time_str": "05:39.072",
      "text": "我写了这么多不是想歌颂我哩童年",
      "translation": null
    },
    {
      "time": 342.329,
      "time_str": "05:42.329",
      "text": "只是想把80后的回忆翻出来做个意见",
      "translation": null
    },
    {
      "time": 346.245,
      "time_str": "05:46.245",
      "text": "给亲情留个纪念 还爱情一次记惦",
      "translation": null
    },
    {
      "time": 350.009,
      "time_str": "05:50.009",
      "text": "对弟兄们说声抱歉 一起挥手向青春告别",
      "translation": null
    },
    {
      "time": 353.67,
      "time_str": "05:53.670",
      "text": "在传统教育和独立之间迷惘着寻找出路",
      "translation": null
    },
    {
      "time": 357.387,
      "time_str": "05:57.387",
      "text": "我们扮演了改革开放哩宠儿尴尬哩幸福",
      "translation": null
    },
    {
      "time": 360.992,
      "time_str": "06:00.992",
      "text": "你有多久没对着自己哩眼睛好好哩认个错",
      "translation": null
    },
    {
      "time": 364.908,
      "time_str": "06:04.908",
      "text": "那么接下来让咱们一起对号入座",
      "translation": null
    },
    {
      "time": 368.165,
      "time_str": "06:08.165",
      "text": "有多少人为了眼前放弃自己的明天",
      "translation": null
    },
    {
      "time": 371.983,
      "time_str": "06:11.983",
      "text": "有多少人为了明天又在扼杀今天",
      "translation": null
    },
    {
      "time": 375.79,
      "time_str": "06:15.790",
      "text": "有多少人为了今天寄生给了欺骗",
      "translation": null
    },
    {
      "time": 379.305,
      "time_str": "06:19.305",
      "text": "又有多少人欺骗只为换取一丝尊严",
      "translation": null
    },
    {
      "time": 383.127,
      "time_str": "06:23.127",
      "text": "有多少人为了尊严却活在别人胯下",
      "translation": null
    },
    {
      "time": 386.788,
      "time_str": "06:26.788",
      "text": "有多少人活在胯下只为养活他一家",
      "translation": null
    },
    {
      "time": 390.545,
      "time_str": "06:30.545",
      "text": "有多少人为了一家老小四海为家",
      "translation": null
    },
    {
      "time": 393.949,
      "time_str": "06:33.949",
      "text": "有多少人漂泊日夜思念朋友和爸妈",
      "translation": null
    },
    {
      "time": 397.865,
      "time_str": "06:37.865",
      "text": "有多少人指手画脚的给别人讲着道理",
      "translation": null
    },
    {
      "time": 402.149,
      "time_str": "06:42.149",
      "text": "有多少人讲完道理自己却不讲道义",
      "translation": null
    },
    {
      "time": 404.589,
      "time_str": "06:44.589",
      "text": "有多少人纹着道义却出卖自己的兄弟",
      "translation": null
    },
    {
      "time": 408.918,
      "time_str": "06:48.918",
      "text": "有多少人从你的兄弟变成了你的凶器",
      "translation": null
    },
    {
      "time": 412.644,
      "time_str": "06:52.644",
      "text": "有多少人付出总是很难得到回报",
      "translation": null
    },
    {
      "time": 416.153,
      "time_str": "06:56.153",
      "text": "有多少人面对镜子流着眼泪微笑",
      "translation": null
    },
    {
      "time": 420.062,
      "time_str": "07:00.062",
      "text": "有多少人笑着在暴雨中疯狂奔跑",
      "translation": null
    },
    {
      "time": 423.564,
      "time_str": "07:03.564",
      "text": "有多少人为了名利戴上了冰凉哩手铐",
      "translation": null
    },
    {
      "time": 427.278,
      "time_str": "07:07.278",
      "text": "有多少人为了苟活背叛了最初的理想",
      "translation": null
    },
    {
      "time": 431.139,
      "time_str": "07:11.139",
      "text": "但坚持了理想的却又混不到车房",
      "translation": null
    },
    {
      "time": 434.716,
      "time_str": "07:14.716",
      "text": "有多少人为了车房要还一辈子外账",
      "translation": null
    },
    {
      "time": 438.394,
      "time_str": "07:18.394",
      "text": "他还了外账也是拆了东墙补上了西墙",
      "translation": null
    },
    {
      "time": 442.158,
      "time_str": "07:22.158",
      "text": "有多少人的婚姻没有出现过裂缝",
      "translation": null
    },
    {
      "time": 445.774,
      "time_str": "07:25.774",
      "text": "嘴上骂着小三自己却破坏别人的家庭",
      "translation": null
    },
    {
      "time": 449.759,
      "time_str": "07:29.759",
      "text": "有多少人的亲朋好友被钱给逼疯",
      "translation": null
    },
    {
      "time": 453.05,
      "time_str": "07:33.050",
      "text": "他却无动于衷的在夜总会里摇晃着筛盅",
      "translation": null
    },
    {
      "time": 456.807,
      "time_str": "07:36.807",
      "text": "有多少的通讯设备安装了无数的功能",
      "translation": null
    },
    {
      "time": 460.519,
      "time_str": "07:40.519",
      "text": "但总是和最亲最近的人无法沟通",
      "translation": null
    },
    {
      "time": 464.242,
      "time_str": "07:44.242",
      "text": "有多少人多少事其实我们都懂",
      "translation": null
    },
    {
      "time": 467.848,
      "time_str": "07:47.848",
      "text": "但懂的太多最后智商变成了狗熊",
      "translation": null
    },
    {
      "time": 471.711,
      "time_str": "07:51.711",
      "text": "有多少人听到这里听着听着累了",
      "translation": null
    },
    {
      "time": 474.565,
      "time_str": "07:54.565",
      "text": "有多少人听到这里听着听着哭了",
      "translation": null
    },
    {
      "time": 479.05,
      "time_str": "07:59.050",
      "text": "有多少的故事我们永远回不去了",
      "translation": null
    },
    {
      "time": 482.713,
      "time_str": "08:02.713",
      "text": "有多少我们思念的人在天堂里听着",
      "translation": null
    },
    {
      "time": 486.521,
      "time_str": "08:06.521",
      "text": "机器铃 砍菜刀 恁那边哩紧俺挑",
      "translation": null
    },
    {
      "time": 494.521,
      "time_str": "08:14.521",
      "text": "挑谁吧 挑 挑的那个人已经不见了",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "机器铃 砍菜刀 - 张卫.lrc"
}