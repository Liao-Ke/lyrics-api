  "lyrics": [
    {
      "time": 15.78,
      "time_str": "00:15.780",
      "text": "I ain't like no one you met before",
      "translation": "我不像你以前认识的任何人"
    },
    {
      "time": 19.62,
      "time_str": "00:19.620",
      "text": "I'm running for the front",
      "translation": "我直面挑战"
    },
    {
      "time": 21.02,
      "time_str": "00:21.020",
      "text": "When they're all running for the door",
      "translation": "而他们只会一味退缩"
    },
    {
      "time": 23.35,
      "time_str": "00:23.350",
      "text": "And I won't sit down won't back out",
      "translation": "我不会停歇 不会逃避"
    },
    {
      "time": 25.69,
      "time_str": "00:25.690",
      "text": "You can't ever shut me up",
      "translation": "没有人能阻止我"
    },
    {
      "time": 27.69,
      "time_str": "00:27.690",
      "text": "Cause I'm on a mission",
      "translation": "因为我在完成一个使命"
    },
    {
      "time": 29.71,
      "time_str": "00:29.710",
      "text": "And I won't quit now",
      "translation": "并且我永不言弃"
    },
    {
      "time": 31.49,
      "time_str": "00:31.490",
      "text": "In a world full of followers",
      "translation": "在一个满是追随者的世界里"
    },
    {
      "time": 33.19,
      "time_str": "00:33.190",
      "text": "I'll be a leader",
      "translation": "我将是一个领导者"
    },
    {
      "time": 35.23,
      "time_str": "00:35.230",
      "text": "In a world full of doubters",
      "translation": "在一个满是怀疑者的世界里"
    },
    {
      "time": 37.12,
      "time_str": "00:37.120",
      "text": "I'll be a believer",
      "translation": "我将是一个信仰者"
    },
    {
      "time": 40.23,
      "time_str": "00:40.230",
      "text": "I'm stepping out without a hesitation",
      "translation": "我会毫不犹豫的离开"
    },
    {
      "time": 43.73,
      "time_str": "00:43.730",
      "text": "Because the battle's already been won",
      "translation": "因为战役已经取得了胜利"
    },
    {
      "time": 47.34,
      "time_str": "00:47.340",
      "text": "I'm sold out",
      "translation": "我无畏向前"
    },
    {
      "time": 49.52,
      "time_str": "00:49.520",
      "text": "I'm no longer living",
      "translation": "我再也不会"
    },
    {
      "time": 51.62,
      "time_str": "00:51.620",
      "text": "Just for myself",
      "translation": "只为我自己活着"
    },
    {
      "time": 53.61,
      "time_str": "00:53.610",
      "text": "Running after Jesus",
      "translation": "我追随着耶稣的脚步"
    },
    {
      "time": 55.24,
      "time_str": "00:55.240",
      "text": "With my whole heart",
      "translation": "全心全意地付出"
    },
    {
      "time": 57.74,
      "time_str": "00:57.740",
      "text": "And now I'm ready to show",
      "translation": "我已经准备好出演了"
    },
    {
      "time": 60.688,
      "time_str": "01:00.688",
      "text": "I am sold out",
      "translation": "我无畏向前"
    },
