  "lyrics": [
    {
      "time": 29.44,
      "time_str": "00:29.440",
      "text": "人群中哭着 你只想变成透明的颜色",
      "translation": null
    },
    {
      "time": 40.02,
      "time_str": "00:40.020",
      "text": "你再也不会梦或痛或心动了",
      "translation": null
    },
    {
      "time": 46.84,
      "time_str": "00:46.840",
      "text": "你已经决定了 你已经决定了",
      "translation": null
    },
    {
      "time": 53.33,
      "time_str": "00:53.330",
      "text": "你静静忍着 紧紧把昨天在拳心握着",
      "translation": null
    },
    {
      "time": 63.15,
      "time_str": "01:03.150",
      "text": "而回忆越是甜就是越伤人",
      "translation": null
    },
    {
      "time": 70.42,
      "time_str": "01:10.420",
      "text": "越是在手心留下密密麻麻深深浅浅的刀割",
      "translation": null
    },
    {
      "time": 80.16,
      "time_str": "01:20.160",
      "text": "你不是真正的快乐",
      "translation": null
    },
    {
      "time": 85.92,
      "time_str": "01:25.920",
      "text": "你的笑只是你穿的保护色",
      "translation": null
    },
    {
      "time": 92.64,
      "time_str": "01:32.640",
      "text": "你决定不恨了 也决定不爱了",
      "translation": null
    },
    {
      "time": 98.12,
      "time_str": "01:38.120",
      "text": "把你的灵魂关在永远锁上的躯壳",
      "translation": null
    },
    {
      "time": 105.84,
      "time_str": "01:45.840",
      "text": "这世界笑了 于是你合群的一起笑了",
      "translation": null
    },
    {
      "time": 116.42,
      "time_str": "01:56.420",
      "text": "当生存是规则 不是你的选择",
      "translation": null
    },
    {
      "time": 123.18,
      "time_str": "02:03.180",
      "text": "于是你含着眼泪飘飘荡荡跌跌撞撞地走着",
      "translation": null
    },
    {
