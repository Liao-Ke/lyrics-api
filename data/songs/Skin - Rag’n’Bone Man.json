  "lyrics": [
    {
      "time": 1.7,
      "time_str": "00:01.700",
      "text": "When I heard that sound",
      "translation": "当我听见那句话"
    },
    {
      "time": 3.6,
      "time_str": "00:03.600",
      "text": "When the walls came down",
      "translation": "当我的心墙崩塌"
    },
    {
      "time": 6.33,
      "time_str": "00:06.330",
      "text": "I was thinking about you",
      "translation": "我无时不在思念你"
    },
    {
      "time": 9.46,
      "time_str": "00:09.460",
      "text": "About you",
      "translation": "思念你"
    },
    {
      "time": 12.23,
      "time_str": "00:12.230",
      "text": "When my skin grows old",
      "translation": "当我皮肤起皱褶"
    },
    {
      "time": 14.94,
      "time_str": "00:14.940",
      "text": "When my breath runs cold",
      "translation": "当我的呼吸冻结"
    },
    {
      "time": 17.46,
      "time_str": "00:17.460",
      "text": "I'll be thinking about you",
      "translation": "我在思念你"
    },
    {
      "time": 21.11,
      "time_str": "00:21.110",
      "text": "About you",
      "translation": "思念你"
    },
    {
      "time": 22.74,
      "time_str": "00:22.740",
      "text": "Seconds from my heart",
      "translation": "那一刹，我的心"
    },
    {
      "time": 25.43,
      "time_str": "00:25.430",
      "text": "A bullet from the dark",
      "translation": "被漆黑中的子弹击穿"
    },
    {
      "time": 28.31,
      "time_str": "00:28.310",
      "text": "Helpless, I surrender",
      "translation": "无助，举降"
    },
    {
      "time": 30.99,
      "time_str": "00:30.990",
      "text": "Shackled by your love",
      "translation": "被你的爱桎梏"
    },
    {
      "time": 33.95,
      "time_str": "00:33.950",
      "text": "Holding me like this",
      "translation": "你这样抱住我"
    },
    {
      "time": 36.59,
      "time_str": "00:36.590",
      "text": "With poison on your lips",
      "translation": "迷幻的毒唇"
    },
    {
      "time": 39.45,
      "time_str": "00:39.450",
      "text": "Only when it's over",
      "translation": "但一切都结束了"
    },
    {
      "time": 42.27,
      "time_str": "00:42.270",
      "text": "The silence hits so hard",
      "translation": "寂静得如此冰冷"
    },
    {
      "time": 46.25,
      "time_str": "00:46.250",
      "text": "'Cause it was almost love, it was almost love",
      "translation": "差一点就是爱了，差一点"
    },
    {
