  "lyrics": [
    {
      "time": 2.069,
      "time_str": "00:02.069",
      "text": "今天我 终于站在这年轻的战场",
      "translation": null
    },
    {
      "time": 10.409,
      "time_str": "00:10.409",
      "text": "请你给我 一束爱的光芒",
      "translation": null
    },
    {
      "time": 17.339,
      "time_str": "00:17.339",
      "text": "今天我 将要走向这胜利的远方",
      "translation": null
    },
    {
      "time": 26.33,
      "time_str": "00:26.330",
      "text": "我要把这世界为你点亮",
      "translation": null
    },
    {
      "time": 49.64,
      "time_str": "00:49.640",
      "text": "我的梦想 在每个醒来的早晨 敲打我的心房",
      "translation": null
    },
    {
      "time": 58.34,
      "time_str": "00:58.340",
      "text": "告诉自己成功的道路 还很漫长",
      "translation": null
    },
    {
      "time": 64.78,
      "time_str": "01:04.780",
      "text": "我的梦想 在每次把握机会 表达自我主张",
      "translation": null
    },
    {
      "time": 73.47,
      "time_str": "01:13.470",
      "text": "展现给你年轻但一样宽阔的胸膛",
      "translation": null
    },
    {
      "time": 81.02,
      "time_str": "01:21.020",
      "text": "所有经历风雨的温柔与坚强",
      "translation": null
    },
    {
      "time": 87.08,
      "time_str": "01:27.080",
      "text": "所有青春无悔 烦恼与成长",
      "translation": null
    },
    {
      "time": 96.109,
      "time_str": "01:36.109",
      "text": "所有奔向未来的理想与张扬",
      "translation": null
    },
    {
      "time": 102.43,
      "time_str": "01:42.430",
      "text": "所有冲破捆绑的热爱与癫狂",
      "translation": null
    },
    {
      "time": 108.9,
      "time_str": "01:48.900",
      "text": "今天我 终于站在这年轻的战场",
      "translation": null
    },
    {
      "time": 117.07,
      "time_str": "01:57.070",
      "text": "请你为我 骄傲鼓掌",
      "translation": null
    },
    {
      "time": 124.05,
      "time_str": "02:04.050",
      "text": "今天我 将要走向这胜利的远方",
      "translation": null
    },
    {
      "time": 132.769,
      "time_str": "02:12.769",
      "text": "我要让这世界为我激荡",
      "translation": null
    },
    {
      "time": 152.52,
      "time_str": "02:32.520",
      "text": "我的梦想 在每个失败的时候 迎来祝福目光",
      "translation": null
    },
    {
      "time": 162.09,
      "time_str": "02:42.090",
      "text": "懂得幸福就是彼此 依靠的肩膀",
      "translation": null
    },
    {
      "time": 167.739,
      "time_str": "02:47.739",
      "text": "我的梦想 在每次付出汗水 创造生命绽放",
      "translation": null
    },
    {
      "time": 176.69,
      "time_str": "02:56.690",
