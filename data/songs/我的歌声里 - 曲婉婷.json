    {
      "time": 13.599,
      "time_str": "00:13.599",
      "text": "没有一点点防备",
      "translation": null
    },
    {
      "time": 16.0,
      "time_str": "00:16.000",
      "text": "也没有一丝顾虑",
      "translation": null
    },
    {
      "time": 17.619,
      "time_str": "00:17.619",
      "text": "你就这样出现在我的世界里",
      "translation": null
    },
    {
      "time": 22.089,
      "time_str": "00:22.089",
      "text": "带给我惊喜 情不自已",
      "translation": null
    },
    {
      "time": 27.56,
      "time_str": "00:27.560",
      "text": "可是你偏又这样",
      "translation": null
    },
    {
      "time": 29.969,
      "time_str": "00:29.969",
      "text": "在我不知不觉中 悄悄的消失",
      "translation": null
    },
    {
      "time": 34.089,
      "time_str": "00:34.089",
      "text": "从我的世界里 没有音讯",
      "translation": null
    },
    {
      "time": 37.408,
      "time_str": "00:37.408",
      "text": "剩下的只是回忆",
      "translation": null
    },
    {
      "time": 41.438,
      "time_str": "00:41.438",
      "text": "你存在 我深深的脑海里",
      "translation": null
    },
    {
      "time": 47.989,
      "time_str": "00:47.989",
      "text": "我的梦里 我的心里 我的歌声里",
      "translation": null
    },
