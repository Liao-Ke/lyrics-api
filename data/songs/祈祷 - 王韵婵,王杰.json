    },
    {
      "time": 135.67,
      "time_str": "02:15.670",
      "text": "王韵婵：让时光懂得去倒流",
      "translation": null
    },
    {
      "time": 142.59,
      "time_str": "02:22.590",
      "text": "叫青春不开溜",
      "translation": null
    },
    {
      "time": 148.65,
      "time_str": "02:28.650",
      "text": "王杰：让贫穷开始去逃亡啊",
      "translation": null
    },
    {
      "time": 155.54,
      "time_str": "02:35.540",
      "text": "快乐健康留四方",
