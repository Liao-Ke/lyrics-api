    },
    {
      "time": 52.82,
      "time_str": "00:52.820",
      "text": "叫成功永远在",
      "translation": null
    },
    {
      "time": 58.06,
      "time_str": "00:58.060",
      "text": "王韵婵：让地球忘记了转动啊",
      "translation": null
    },
    {
      "time": 65.77,
      "time_str": "01:05.770",
      "text": "四季少了夏秋冬",
      "translation": null
    },
    {
      "time": 72.33,
      "time_str": "01:12.330",
      "text": "王杰：让宇宙关不了天窗",
      "translation": null
    },
    {
      "time": 78.8,
      "time_str": "01:18.800",
      "text": "叫太阳不西沉",
      "translation": null
    },
    {
      "time": 123.26,
      "time_str": "02:03.260",
      "text": "王杰：让欢喜代替了哀愁啊",
      "translation": null
    },
    {
      "time": 128.51,
      "time_str": "02:08.510",
      "text": "微笑不会再害羞",
