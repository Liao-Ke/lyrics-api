    },
    {
      "time": 31.0,
      "time_str": "00:31.000",
      "text": "（女）想走进你的港湾",
      "translation": null
    },
    {
      "time": 37.0,
      "time_str": "00:37.000",
      "text": "（女）把美梦连成一片",
      "translation": null
    },
    {
      "time": 42.0,
      "time_str": "00:42.000",
      "text": "（女）不需要太多的誓言",
      "translation": null
    },
    {
      "time": 47.0,
      "time_str": "00:47.000",
      "text": "（女）你的目光是我追逐的彼岸 啊 ～",
      "translation": null
    },
    {
      "time": 57.0,
      "time_str": "00:57.000",
      "text": "（男）在梦中见你容颜",
      "translation": null
    },
    {
      "time": 62.0,
      "time_str": "01:02.000",
      "text": "（男）那寂寞涌在心间",
      "translation": null
    },
    {
      "time": 68.0,
      "time_str": "01:08.000",
      "text": "（男）忍不住太多的思念",
      "translation": null
    },
    {
      "time": 73.0,
      "time_str": "01:13.000",
      "text": "（男）你的祝福伴我直到永远",
      "translation": null
    },
    {
      "time": 81.0,
      "time_str": "01:21.000",
      "text": "（合）如果再给我一点时间",
      "translation": null
    },
    {
      "time": 86.0,
