    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "出品人 : 靖成@爱粉扑",
      "translation": null
    },
    {
      "time": 19.1,
      "time_str": "00:19.100",
      "text": "晕开的笔墨难落下",
      "translation": null
    },
    {
      "time": 22.8,
      "time_str": "00:22.800",
      "text": "明月穿云过离人各天涯",
      "translation": null
    },
    {
      "time": 27.56,
      "time_str": "00:27.560",
      "text": "梦一刹繁华已落下",
      "translation": null
    },
    {
      "time": 31.28,
      "time_str": "00:31.280",
      "text": "旧事里打捞不起一个他",
      "translation": null
    },
    {
      "time": 35.96,
      "time_str": "00:35.960",
      "text": "酌一杯孤独敬月光",
      "translation": null
    },
    {
      "time": 39.63,
      "time_str": "00:39.630",
      "text": "饮下我一干二净的牵挂",
      "translation": null
    },
    {
      "time": 43.87,
      "time_str": "00:43.870",
      "text": "大梦催白发",
      "translation": null
    },
    {
      "time": 45.99,
      "time_str": "00:45.990",
      "text": "昨夜又见他窈窈的风华",
      "translation": null
    },
    {
      "time": 52.74,
      "time_str": "00:52.740",
      "text": "听西厢月落乌啼声声唱罢",
      "translation": null
    },
    {
      "time": 56.87,
      "time_str": "00:56.870",
      "text": "在长亭苦等却等不来他",
      "translation": null
    },
    {
      "time": 61.02,
      "time_str": "01:01.020",
      "text": "竹林外的酒家",
      "translation": null
    },
    {
      "time": 62.84,
      "time_str": "01:02.840",
      "text": "传来边关外 的生杀",
      "translation": null
    },
    {
      "time": 67.99,
      "time_str": "01:07.990",
      "text": "天地大 爱恨能落墨 几斗",
      "translation": null
    },
    {
      "time": 72.37,
      "time_str": "01:12.370",
      "text": "千万里 山河不为我 迁就",
      "translation": null
    },
    {
      "time": 72.4,
      "time_str": "01:12.400",
      "text": "世间纸短 情难相留 这份离愁",
      "translation": null
    },
    {
      "time": 84.86,
      "time_str": "01:24.860",
      "text": "道不尽 红尘巍巍高 几楼",
      "translation": null
    },
    {
      "time": 89.05,
      "time_str": "01:29.050",
      "text": "心无怨 等闲一场梦 难留",
      "translation": null
    },
    {
      "time": 93.52,
      "time_str": "01:33.520",
      "text": "落了眼眸 上了心头 他的温柔",
      "translation": null
    },
    {
      "time": 120.16,
      "time_str": "02:00.160",
      "text": "他孤身纵马一去相思放下",
      "translation": null
    },
    {
      "time": 124.05,
      "time_str": "02:04.050",
      "text": "满头青丝敌不过空牵挂",
      "translation": null
    },
    {
