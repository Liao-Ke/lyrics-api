  "lyrics": [
    {
      "time": 20.34,
      "time_str": "00:20.340",
      "text": "你我皆凡人 生在人世间",
      "translation": null
    },
    {
      "time": 27.59,
      "time_str": "00:27.590",
      "text": "终日奔波苦 一刻不得闲",
      "translation": null
    },
    {
      "time": 35.119,
      "time_str": "00:35.119",
      "text": "既然不是仙 难免有杂念",
      "translation": null
    },
    {
      "time": 42.67,
      "time_str": "00:42.670",
      "text": "道义放两旁 把利字摆中间",
      "translation": null
    },
    {
      "time": 49.773,
      "time_str": "00:49.773",
      "text": "多少男子汉 一怒为红颜",
      "translation": null
    },
    {
      "time": 57.224,
      "time_str": "00:57.224",
      "text": "多少同林鸟 已成了分飞燕",
      "translation": null
    },
    {
      "time": 64.375,
      "time_str": "01:04.375",
      "text": "人生何其短 何必苦苦恋",
      "translation": null
    },
    {
      "time": 71.928,
      "time_str": "01:11.928",
      "text": "爱人不见了 向谁去喊冤",
      "translation": null
    },
    {
      "time": 79.328,
      "time_str": "01:19.328",
      "text": "问你 何时曾看见",
      "translation": null
    },
    {
      "time": 82.578,
      "time_str": "01:22.578",
      "text": "这世界为了人们改变",
      "translation": null
    },
    {
      "time": 87.081,
      "time_str": "01:27.081",
      "text": "有了梦寐以求的容颜",
      "translation": null
    },
    {
      "time": 90.209,
      "time_str": "01:30.209",
      "text": "是否就算是拥有春天",
      "translation": null
    },
    {
