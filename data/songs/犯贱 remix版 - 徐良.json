  "lyrics": [
    {
      "time": 9.31,
      "time_str": "00:09.310",
      "text": "男：",
      "translation": null
    },
    {
      "time": 9.66,
      "time_str": "00:09.660",
      "text": "我结婚的时候一定要来喔",
      "translation": null
    },
    {
      "time": 13.58,
      "time_str": "00:13.580",
      "text": "因为看见你我会有安全感",
      "translation": null
    },
    {
      "time": 37.74,
      "time_str": "00:37.740",
      "text": "点燃你总抽的香烟",
      "translation": null
    },
    {
      "time": 40.09,
      "time_str": "00:40.090",
      "text": "欺骗我无法满足的嗅觉",
      "translation": null
    },
    {
      "time": 42.64,
      "time_str": "00:42.640",
      "text": "那夜弄懂你嘴唇甘甜",
      "translation": null
    },
    {
      "time": 45.3,
      "time_str": "00:45.300",
      "text": "但却感觉距离还是很远",
      "translation": null
    },
    {
      "time": 47.9,
      "time_str": "00:47.900",
      "text": "点燃你潇洒的拒绝",
      "translation": null
    },
    {
      "time": 50.17,
      "time_str": "00:50.170",
      "text": "要知道只是一厢的情愿",
      "translation": null
    },
    {
      "time": 52.88,
      "time_str": "00:52.880",
      "text": "你已不再允许我犯贱",
      "translation": null
    },
    {
      "time": 55.43,
      "time_str": "00:55.430",
      "text": "没办法让我再次回到你的身边",
      "translation": null
    },
    {
      "time": 58.1,
      "time_str": "00:58.100",
      "text": "女：",
      "translation": null
    },
    {
      "time": 58.55,
      "time_str": "00:58.550",
      "text": "我习惯你走在我的身后",
      "translation": null
    },
    {
      "time": 62.96,
      "time_str": "01:02.960",
      "text": "无论什么要求你全都接受",
      "translation": null
    },
    {
      "time": 68.13,
      "time_str": "01:08.130",
      "text": "我如果能够让时光倒流",
      "translation": null
    },
    {
