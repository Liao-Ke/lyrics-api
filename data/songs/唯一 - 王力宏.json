    {
      "time": 17.298,
      "time_str": "00:17.298",
      "text": "我的天空多么的清晰",
      "translation": null
    },
    {
      "time": 24.298,
      "time_str": "00:24.298",
      "text": "透明的承诺是过去的空气",
      "translation": null
    },
    {
      "time": 33.299,
      "time_str": "00:33.299",
      "text": "牵着我的手是你",
      "translation": null
    },
    {
      "time": 38.299,
      "time_str": "00:38.299",
      "text": "但你的笑容 却看不清",
      "translation": null
    },
    {
      "time": 48.299,
      "time_str": "00:48.299",
      "text": "是否一颗星星变了心",
      "translation": null
    },
    {
      "time": 54.299,
      "time_str": "00:54.299",
      "text": "从前的愿望 已全都被抛弃",
      "translation": null
    },
    {
      "time": 64.299,
      "time_str": "01:04.299",
      "text": "最近我无法呼吸",
      "translation": null
    },
    {
      "time": 68.299,
      "time_str": "01:08.299",
      "text": "连自己的影子",
      "translation": null
    },
    {
      "time": 73.299,
      "time_str": "01:13.299",
      "text": "都想逃避",
      "translation": null
    },
    {
      "time": 76.299,
      "time_str": "01:16.299",
      "text": "BABY 你就是我的唯一",
      "translation": null
    },
    {
      "time": 82.299,
      "time_str": "01:22.299",
      "text": "两个世界都变形",
      "translation": null
    },
    {
      "time": 86.299,
      "time_str": "01:26.299",
      "text": "回去谈何容易",
      "translation": null
    },
    {
      "time": 91.299,
      "time_str": "01:31.299",
      "text": "确定 你就是我的唯一",
      "translation": null
    },
    {
      "time": 97.299,
      "time_str": "01:37.299",
      "text": "独自对着电话说我爱你",
      "translation": null
    },
    {
