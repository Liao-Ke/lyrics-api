    {
      "time": 18.754,
      "time_str": "00:18.754",
      "text": "这世界有那么多人",
      "translation": null
    },
    {
      "time": 25.191,
      "time_str": "00:25.191",
      "text": "人群里 敞着一扇门",
      "translation": null
    },
    {
      "time": 31.197,
      "time_str": "00:31.197",
      "text": "我迷朦的眼睛里长存",
      "translation": null
    },
    {
      "time": 38.007,
      "time_str": "00:38.007",
      "text": "初见你  蓝色清晨",
      "translation": null
    },
    {
      "time": 45.179,
      "time_str": "00:45.179",
      "text": "这世界有那么多人",
      "translation": null
    },
    {
      "time": 50.98,
      "time_str": "00:50.980",
      "text": "多幸运 我有个我们",
      "translation": null
    },
    {
      "time": 57.976,
      "time_str": "00:57.976",
      "text": "这悠长命运中的晨昏",
      "translation": null
    },
    {
      "time": 64.591,
      "time_str": "01:04.591",
      "text": "常让我 望远方出神",
      "translation": null
    },
    {
      "time": 72.251,
      "time_str": "01:12.251",
      "text": "灰树叶飘转在池塘",
      "translation": null
    },
    {
      "time": 78.179,
      "time_str": "01:18.179",
      "text": "看飞机轰的一声去远乡",
      "translation": null
    },
    {
      "time": 84.683,
      "time_str": "01:24.683",
      "text": "光阴的长廊 脚步声叫嚷",
      "translation": null
    },
    {
      "time": 91.23,
      "time_str": "01:31.230",
      "text": "灯一亮 无人的空荡",
      "translation": null
    },
    {
      "time": 99.027,
      "time_str": "01:39.027",
      "text": "晚风中闪过 几帧从前啊",
      "translation": null
    },
    {
      "time": 105.061,
      "time_str": "01:45.061",
      "text": "飞驰中旋转 已不见了吗",
      "translation": null
    },
    {
      "time": 112.099,
      "time_str": "01:52.099",
      "text": "远光中走来 你一身晴朗",
      "translation": null
    },
    {
      "time": 119.084,
      "time_str": "01:59.084",
      "text": "身旁那么多人 可世界不声 不响",
      "translation": null
