    },
    {
      "time": 23.63,
      "time_str": "00:23.630",
      "text": "他不爱我",
      "translation": null
    },
    {
      "time": 28.6,
      "time_str": "00:28.600",
      "text": "说话的时候 不认真",
      "translation": null
    },
    {
      "time": 31.78,
      "time_str": "00:31.780",
      "text": "沉默的时候 又太用心",
      "translation": null
    },
    {
      "time": 39.57,
      "time_str": "00:39.570",
      "text": "我知道 他不爱我",
      "translation": null
    },
    {
      "time": 47.9,
      "time_str": "00:47.900",
      "text": "他的眼神 说出他的心",
      "translation": null
    },
    {
      "time": 56.37,
      "time_str": "00:56.370",
      "text": "我看透了他的心",
      "translation": null
    },
    {
      "time": 60.05,
      "time_str": "01:00.050",
      "text": "还有别人逗留的背影",
      "translation": null
    },
    {
      "time": 64.04,
      "time_str": "01:04.040",
      "text": "他的回忆 清除得不够干净",
      "translation": null
    },
    {
      "time": 72.29,
      "time_str": "01:12.290",
      "text": "我看到了他的心",
      "translation": null
    },
    {
      "time": 76.02,
