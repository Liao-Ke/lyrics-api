    },
    {
      "time": 12.66,
      "time_str": "00:12.660",
      "text": "牵手的时候 太冷清",
      "translation": null
    },
    {
      "time": 15.75,
      "time_str": "00:15.750",
      "text": "拥抱的时候 不够靠近",
