  "lyrics": [
    {
      "time": 17.32,
      "time_str": "00:17.320",
      "text": "这夜我又再独对夜半无人的空气",
      "translation": null
    },
    {
      "time": 24.38,
      "time_str": "00:24.380",
      "text": "穿起你的毛衣 重演某天的好戏",
      "translation": null
    },
    {
      "time": 32.3,
      "time_str": "00:32.300",
      "text": "让毛造长袖不经意地 抱着我静看天地",
      "translation": null
    },
    {
      "time": 39.54,
      "time_str": "00:39.540",
      "text": "让唇在无味的衣领上 笑说最爱你的气味",
      "translation": null
    },
    {
      "time": 47.19,
      "time_str": "00:47.190",
      "text": "我恨我共你是套现已完场的好戏",
      "translation": null
    },
    {
      "time": 54.68,
      "time_str": "00:54.680",
      "text": "只有请你的毛衣 从此每天饰演你",
      "translation": null
    },
    {
      "time": 62.28,
      "time_str": "01:02.280",
      "text": "夜来便来伴我坐 默然但仍默许我",
      "translation": null
    },
    {
      "time": 69.16,
      "time_str": "01:09.160",
      "text": "将肌肤紧贴你 将身躯交予你",
      "translation": null
    },
    {
      "time": 73.43,
      "time_str": "01:13.430",
      "text": "准许我这夜做旧角色",
      "translation": null
    },
    {
      "time": 75.58,
      "time_str": "01:15.580",
      "text": "准我快乐地重饰演某段美丽故事主人",
      "translation": null
    },
    {
      "time": 80.45,
      "time_str": "01:20.450",
      "text": "饰演你旧年共寻梦的恋人",
      "translation": null
    },
    {
      "time": 84.19,
      "time_str": "01:24.190",
      "text": "再去做没流着情泪的伊人",
      "translation": null
    },
    {
      "time": 87.89,
      "time_str": "01:27.890",
      "text": "假装再有从前演过的戏份",
      "translation": null
    },
    {
      "time": 91.76,
      "time_str": "01:31.760",
      "text": "重饰演某段美丽故事主人",
      "translation": null
    },
    {
      "time": 95.46,
      "time_str": "01:35.460",
      "text": "饰演你旧年共寻梦的恋人",
      "translation": null
    },
    {
      "time": 99.3,
      "time_str": "01:39.300",
      "text": "你纵是未明白仍夜深一人",
      "translation": null
    },
    {
      "time": 103.6,
      "time_str": "01:43.600",
      "text": "穿起你那无言毛衣当跟你贴近",
