  "lyrics": [
    {
      "time": 24.88,
      "time_str": "00:24.880",
      "text": "忘记分开后的第几天起",
      "translation": null
    },
    {
      "time": 30.03,
      "time_str": "00:30.030",
      "text": "喜欢一个人 看下大雨",
      "translation": null
    },
    {
      "time": 35.68,
      "time_str": "00:35.680",
      "text": "没联络 孤单就像连锁反应",
      "translation": null
    },
    {
      "time": 41.6,
      "time_str": "00:41.600",
      "text": "想要快乐都没力气",
      "translation": null
    },
    {
      "time": 49.53,
      "time_str": "00:49.530",
      "text": "雷雨世界像场灾难电影",
      "translation": null
    },
    {
      "time": 54.68,
      "time_str": "00:54.680",
      "text": "让现在的我 可怜到底",
      "translation": null
    },
    {
      "time": 60.16,
      "time_str": "01:00.160",
      "text": "对不起 谁也没有时光机器",
      "translation": null
    },
    {
      "time": 66.11,
      "time_str": "01:06.110",
      "text": "已经结束的 没有商量的余地",
      "translation": null
    },
    {
      "time": 75.28,
      "time_str": "01:15.280",
      "text": "我希望你 是我独家的记忆",
      "translation": null
    },
    {
      "time": 81.11,
      "time_str": "01:21.110",
      "text": "摆在心底",
      "translation": null
    },
    {
      "time": 83.56,
      "time_str": "01:23.560",
      "text": "不管别人说的多么难听",
      "translation": null
    },
    {
      "time": 89.13,
      "time_str": "01:29.130",
      "text": "现在我拥有的事情",
      "translation": null
    },
    {
      "time": 92.9,
      "time_str": "01:32.900",
      "text": "是你 是给我一半的爱情",
      "translation": null
    },
    {
      "time": 98.49,
      "time_str": "01:38.490",
      "text": "我喜欢你 是我独家的记忆",
      "translation": null
    },
    {
      "time": 104.5,
      "time_str": "01:44.500",
      "text": "谁也不行",
      "translation": null
    },
    {
      "time": 107.02,
      "time_str": "01:47.020",
      "text": "从我这个身体中拿走你",
      "translation": null
    },
    {
      "time": 112.59,
      "time_str": "01:52.590",
      "text": "在我感情的封锁区",
      "translation": null
    },
    {
      "time": 116.39,
      "time_str": "01:56.390",
      "text": "有关于你 绝口不提 没问题",
      "translation": null
    },
    {
