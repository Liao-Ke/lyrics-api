    {
      "time": 0.548,
      "time_str": "00:00.548",
      "text": "还记得多年前跟你手牵手",
      "translation": null
    },
    {
      "time": 7.169,
      "time_str": "00:07.169",
      "text": "还记得多年前跟你手牵手",
      "translation": null
    },
    {
      "time": 10.508,
      "time_str": "00:10.508",
      "text": "你都害羞的不敢抬头",
      "translation": null
    },
    {
      "time": 13.847,
      "time_str": "00:13.847",
      "text": "只会傻傻的看着天上的星星",
      "translation": null
    },
    {
      "time": 17.37,
      "time_str": "00:17.370",
      "text": "你就是那么的纯净",
      "translation": null
    },
    {
      "time": 20.269,
      "time_str": "00:20.269",
      "text": "知道你收到上榜的通知单",
      "translation": null
    },
    {
      "time": 23.892,
      "time_str": "00:23.892",
      "text": "我的心里就变得很乱",
      "translation": null
    },
    {
      "time": 27.132,
      "time_str": "00:27.132",
      "text": "不知为你而高兴还为自己忧愁",
      "translation": null
    },
    {
      "time": 30.897,
      "time_str": "00:30.897",
      "text": "只好就放你走",
      "translation": null
    },
    {
      "time": 33.326,
      "time_str": "00:33.326",
      "text": "不明白",
      "translation": null
    },
    {
      "time": 36.367,
      "time_str": "00:36.367",
      "text": "不明白",
      "translation": null
    },
    {
      "time": 36.893,
      "time_str": "00:36.893",
      "text": "为什么我不能放得开",
      "translation": null
    },
    {
      "time": 40.033,
      "time_str": "00:40.033",
      "text": "舍不得",
      "translation": null
    },
    {
      "time": 42.462,
      "time_str": "00:42.462",
      "text": "这个爱",
      "translation": null
    },
    {
      "time": 43.372,
      "time_str": "00:43.372",
      "text": "你是一生一世不会了解",
      "translation": null
    },
    {
      "time": 46.654,
      "time_str": "00:46.654",
      "text": "我明白",
      "translation": null
    },
    {
      "time": 48.316,
      "time_str": "00:48.316",
      "text": "我明白",
      "translation": null
    },
    {
      "time": 49.851,
      "time_str": "00:49.851",
      "text": "在我心中你永远存在",
      "translation": null
    },
    {
      "time": 54.227,
      "time_str": "00:54.227",
      "text": "或许你会有一天怀念",
      "translation": null
    },
    {
      "time": 57.324,
      "time_str": "00:57.324",
      "text": "可是我已不在",
      "translation": null
    },
    {
      "time": 73.564,
      "time_str": "01:13.564",
      "text": "还记得一开始你不能适应",
      "translation": null
    },
    {
      "time": 77.131,
      "time_str": "01:17.131",
      "text": "那个忙乱又吵的环境",
      "translation": null
    },
    {
      "time": 80.512,
      "time_str": "01:20.512",
      "text": "一个小镇的姑娘到了大城市",
      "translation": null
