{
  "title": "葡萄成熟时",
  "title_raw": "葡萄成熟时",
  "version": null,
  "artist": "陈奕迅",
  "group_key": "葡萄成熟时|陈奕迅",
  "writers": {
    "lyricist": "黄伟文",
    "composer": "Vincent Chow",
    "arranger": "Adrian Chan"
  },
  "lyrics": [
    {
      "time": 15.982,
      "time_str": "00:15.982",
      "text": "差不多冬至一早一晚还是有雨",
      "translation": null
    },
    {
      "time": 19.952,
      "time_str": "00:19.952",
      "text": "当初的坚持现已令你很怀疑",
      "translation": null
    },
    {
      "time": 25.625,
      "time_str": "00:25.625",
      "text": "很怀疑 你最尾等到 只有这枯枝",
      "translation": null
    },
    {
      "time": 31.776,
      "time_str": "00:31.776",
      "text": "苦恋几多次悉心栽种 全力灌注",
      "translation": null
    },
    {
      "time": 35.547,
      "time_str": "00:35.547",
      "text": "所得竟不如别个后辈 收成时",
      "translation": null
    },
    {
      "time": 41.153,
      "time_str": "00:41.153",
      "text": "这一次 你真的很介意",
      "translation": null
    },
    {
      "time": 46.008,
      "time_str": "00:46.008",
      "text": "但见旁人谈情何引诱",
      "translation": null
    },
    {
      "time": 50.368,
      "time_str": "00:50.368",
      "text": "问到何时葡萄先熟透",
      "translation": null
    },
    {
      "time": 54.491,
      "time_str": "00:54.491",
      "text": "你要静候 再静候",
      "translation": null
    },
    {
      "time": 58.103,
      "time_str": "00:58.103",
      "text": "就算失收始终要守",
      "translation": null
    },
    {
      "time": 63.41,
      "time_str": "01:03.410",
      "text": "日后 尽量别教今天的泪白流",
      "translation": null
    },
    {
      "time": 70.354,
      "time_str": "01:10.354",
      "text": "留低 击伤你的石头",
      "translation": null
    },
    {
      "time": 74.11,
      "time_str": "01:14.110",
      "text": "从错误里吸收",
      "translation": null
    },
    {
      "time": 77.763,
      "time_str": "01:17.763",
      "text": "也许 丰收月份尚未到你也得接受",
      "translation": null
    },
    {
      "time": 85.027,
      "time_str": "01:25.027",
      "text": "或者要到你将爱酿成醇酒",
      "translation": null
    },
    {
      "time": 91.443,
      "time_str": "01:31.443",
      "text": "时机先至熟透",
      "translation": null
    },
    {
      "time": 109.098,
      "time_str": "01:49.098",
      "text": "应该怎么爱可惜书里从没记载",
      "translation": null
    },
    {
      "time": 112.94,
      "time_str": "01:52.940",
      "text": "终于摸出来但岁月却不回来",
      "translation": null
    },
    {
      "time": 118.434,
      "time_str": "01:58.434",
      "text": "不回来 错过了春天可会再花开",
      "translation": null
    },
    {
      "time": 124.402,
      "time_str": "02:04.402",
      "text": "一千种恋爱一些需要情泪灌溉",
      "translation": null
    },
    {
      "time": 128.266,
      "time_str": "02:08.266",
      "text": "枯萎的温柔在最后会长回来",
      "translation": null
    },
    {
      "time": 133.733,
      "time_str": "02:13.733",
      "text": "错的爱乃必经的配菜",
      "translation": null
    },
    {
      "time": 138.555,
      "time_str": "02:18.555",
      "text": "但见旁人谈情何引诱",
      "translation": null
    },
    {
      "time": 142.827,
      "time_str": "02:22.827",
      "text": "问到何时葡萄先熟透",
      "translation": null
    },
    {
      "time": 146.921,
      "time_str": "02:26.921",
      "text": "你要静候 再静候",
      "translation": null
    },
    {
      "time": 150.476,
      "time_str": "02:30.476",
      "text": "就算失收始终要守",
      "translation": null
    },
    {
      "time": 155.284,
      "time_str": "02:35.284",
      "text": "日后 尽量别教今天的泪白流",
      "translation": null
    },
    {
      "time": 162.173,
      "time_str": "02:42.173",
      "text": "留低 击伤你的石头",
      "translation": null
    },
    {
      "time": 165.95,
      "time_str": "02:45.950",
      "text": "从错误里吸收",
      "translation": null
    },
    {
      "time": 169.529,
      "time_str": "02:49.529",
      "text": "也许 丰收月份尚未到你也得接受",
      "translation": null
    },
    {
      "time": 176.687,
      "time_str": "02:56.687",
      "text": "或者要到你将爱酿成醇酒",
      "translation": null
    },
    {
      "time": 183.087,
      "time_str": "03:03.087",
      "text": "时机先至熟透",
      "translation": null
    },
    {
      "time": 189.528,
      "time_str": "03:09.528",
      "text": "想想天的一边",
      "translation": null
    },
    {
      "time": 192.305,
      "time_str": "03:12.305",
      "text": "亦有个某某 在等候",
      "translation": null
    },
    {
      "time": 204.564,
      "time_str": "03:24.564",
      "text": "一心只等葡萄熟透 尝杯酒",
      "translation": null
    },
    {
      "time": 219.555,
      "time_str": "03:39.555",
      "text": "别让 寂寞害你想得一夜白头",
      "translation": null
    },
    {
      "time": 226.441,
      "time_str": "03:46.441",
      "text": "赢得不需要的自由",
      "translation": null
    },
    {
      "time": 230.215,
      "time_str": "03:50.215",
      "text": "和最耀眼伤口",
      "translation": null
    },
    {
      "time": 233.77,
      "time_str": "03:53.770",
      "text": "我知 日后路上或没有更美的邂逅",
      "translation": null
    },
    {
      "time": 240.954,
      "time_str": "04:00.954",
      "text": "但当你智慧都酝酿成红酒",
      "translation": null
    },
    {
      "time": 247.306,
      "time_str": "04:07.306",
      "text": "仍可一醉自救",
      "translation": null
    },
    {
      "time": 253.043,
      "time_str": "04:13.043",
      "text": "谁都辛酸过哪个没有",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "葡萄成熟时 - 陈奕迅.lrc"
}