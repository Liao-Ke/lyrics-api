  "lyrics": [
    {
      "time": 1.77,
      "time_str": "00:01.770",
      "text": "雨一直下",
      "translation": null
    },
    {
      "time": 25.44,
      "time_str": "00:25.440",
      "text": "气氛不算融洽",
      "translation": null
    },
    {
      "time": 41.01,
      "time_str": "00:41.010",
      "text": "在同个屋檐下",
      "translation": null
    },
    {
      "time": 42.66,
      "time_str": "00:42.660",
      "text": "你渐渐感到心在变化",
      "translation": null
    },
    {
      "time": 46.59,
      "time_str": "00:46.590",
      "text": "你爱着他",
      "translation": null
    },
    {
      "time": 49.74,
      "time_str": "00:49.740",
      "text": "也许也带着恨吧",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "青春耗了一大半",
      "translation": null
    },
    {
      "time": 55.98,
      "time_str": "00:55.980",
      "text": "原来只是陪他玩耍",
      "translation": null
    },
    {
      "time": 59.61,
      "time_str": "00:59.610",
      "text": "正想离开他他却拿着鲜花",
      "translation": null
    },
    {
      "time": 67.41,
      "time_str": "01:07.410",
      "text": "说不着边的话",
      "translation": null
    },
    {
      "time": 69.09,
      "time_str": "01:09.090",
      "text": "让整个场面更加尴尬",
      "translation": null
    },
    {
      "time": 73.05,
      "time_str": "01:13.050",
      "text": "不可思议吧梦在瞬间崩塌",
      "translation": null
    },
    {
      "time": 80.52,
      "time_str": "01:20.520",
      "text": "为何当初那么傻",
      "translation": null
    },
    {
      "time": 82.29,
      "time_str": "01:22.290",
      "text": "还一心想要嫁给他",
      "translation": null
    },
    {
      "time": 88.35,
      "time_str": "01:28.350",
      "text": "就是爱到深处才怨他",
      "translation": null
    },
    {
      "time": 92.13,
      "time_str": "01:32.130",
      "text": "舍不舍得都断了吧",
      "translation": null
    },
    {
      "time": 95.37,
      "time_str": "01:35.370",
      "text": "那是从来都没有后路的悬崖",
      "translation": null
    },
    {
      "time": 101.58,
      "time_str": "01:41.580",
      "text": "就是爱到深处才由他",
      "translation": null
    },
    {
      "time": 105.39,
      "time_str": "01:45.390",
      "text": "碎了心也要放得下",
      "translation": null
    },
    {
      "time": 108.63,
      "time_str": "01:48.630",
      "text": "难道忘了那爱他的伤",
      "translation": null
    },
    {
      "time": 111.3,
      "time_str": "01:51.300",
      "text": "已密密麻麻",
      "translation": null
    },
    {
