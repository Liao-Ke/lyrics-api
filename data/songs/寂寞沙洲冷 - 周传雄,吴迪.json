  "lyrics": [
    {
      "time": 13.35,
      "time_str": "00:13.350",
      "text": "自你走后心憔悴",
      "translation": null
    },
    {
      "time": 16.92,
      "time_str": "00:16.920",
      "text": "白色油桐风中纷飞",
      "translation": null
    },
    {
      "time": 21.42,
      "time_str": "00:21.420",
      "text": "落花似人有情这个季节",
      "translation": null
    },
    {
      "time": 29.25,
      "time_str": "00:29.250",
      "text": "河畔的风放肆拼命的吹",
      "translation": null
    },
    {
      "time": 32.76,
      "time_str": "00:32.760",
      "text": "无端拨弄离人的眼泪",
      "translation": null
    },
    {
      "time": 36.78,
      "time_str": "00:36.780",
      "text": "那样浓烈的爱再也无法给",
      "translation": null
    },
    {
      "time": 41.01,
      "time_str": "00:41.010",
      "text": "伤感一夜一夜",
      "translation": null
    },
    {
      "time": 48.72,
      "time_str": "00:48.720",
      "text": "当记忆的线缠绕过往支离破碎",
      "translation": null
    },
    {
      "time": 52.56,
      "time_str": "00:52.560",
      "text": "是慌乱占据了心扉",
      "translation": null
    },
    {
      "time": 56.88,
      "time_str": "00:56.880",
      "text": "有花儿伴着蝴碟孤燕可以双飞",
      "translation": null
    },
    {
      "time": 61.11,
      "time_str": "01:01.110",
      "text": "夜深人静独徘徊",
      "translation": null
    },
    {
      "time": 64.59,
      "time_str": "01:04.590",
      "text": "当幸福恋人寄来红色分享喜悦",
      "translation": null
    },
    {
      "time": 68.55,
      "time_str": "01:08.550",
      "text": "闭上双眼难过头也不敢回",
      "translation": null
    },
    {
      "time": 72.57,
      "time_str": "01:12.570",
      "text": "仍然捡尽寒枝不肯安歇",
      "translation": null
    },
    {
      "time": 75.09,
      "time_str": "01:15.090",
      "text": "微带着后悔",
      "translation": null
    },
    {
      "time": 76.98,
      "time_str": "01:16.980",
      "text": "寂寞沙洲我该思念谁",
      "translation": null
    },
