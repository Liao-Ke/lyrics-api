    {
      "time": 25.4,
      "time_str": "00:25.400",
      "text": "那年你踏上暮色他乡",
      "translation": null
    },
    {
      "time": 30.27,
      "time_str": "00:30.270",
      "text": "你以为那里有你的理想",
