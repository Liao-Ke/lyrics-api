    {
      "time": 35.5,
      "time_str": "00:35.500",
      "text": "你看着周围陌生目光",
      "translation": null
    },
    {
      "time": 40.55,
      "time_str": "00:40.550",
      "text": "清晨醒来却没人在身旁",
      "translation": null
    },
    {
      "time": 46.15,
      "time_str": "00:46.150",
      "text": "人静的雨夜想起了她",
      "translation": null
    },
    {
      "time": 51.29,
      "time_str": "00:51.290",
      "text": "她的挽留还萦绕耳旁",
      "translation": null
    },
    {
      "time": 56.37,
      "time_str": "00:56.370",
