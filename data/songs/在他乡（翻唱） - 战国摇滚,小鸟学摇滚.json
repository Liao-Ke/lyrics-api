      "text": "再回到她的身旁",
      "translation": null
    },
    {
      "time": 6.17,
      "time_str": "00:06.170",
      "text": "看她的温柔善良",
      "translation": null
    },
    {
      "time": 8.76,
      "time_str": "00:08.760",
      "text": "来抚慰我的心伤",
      "translation": null
    },
    {
      "time": 11.32,
      "time_str": "00:11.320",
      "text": "就让我回到家乡",
