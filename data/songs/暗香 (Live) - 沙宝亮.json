  "lyrics": [
    {
      "time": 14.83,
      "time_str": "00:14.830",
      "text": "当花瓣离开花朵 暗香残留",
      "translation": null
    },
    {
      "time": 28.33,
      "time_str": "00:28.330",
      "text": "香消在风起雨后 无人来嗅",
      "translation": null
    },
    {
      "time": 42.33,
      "time_str": "00:42.330",
      "text": "如果爱告诉我走下去",
      "translation": null
    },
    {
      "time": 49.33,
      "time_str": "00:49.330",
      "text": "我会拼到爱尽头",
      "translation": null
    },
    {
      "time": 55.33,
      "time_str": "00:55.330",
      "text": "心若在灿烂中死去",
      "translation": null
    },
    {
      "time": 62.33,
      "time_str": "01:02.330",
      "text": "爱会在灰烬里重生",
      "translation": null
    },
    {
      "time": 69.33,
      "time_str": "01:09.330",
      "text": "难忘缠绵细语时",
      "translation": null
    },
    {
      "time": 74.33,
      "time_str": "01:14.330",
      "text": "用你笑容为我祭奠",
      "translation": null
    },
    {
      "time": 82.33,
      "time_str": "01:22.330",
      "text": "让心在灿烂中死去",
      "translation": null
    },
    {
      "time": 89.33,
      "time_str": "01:29.330",
      "text": "让爱在灰烬里重生",
      "translation": null
    },
    {
      "time": 97.33,
      "time_str": "01:37.330",
      "text": "烈火烧过青草痕",
      "translation": null
    },
    {
      "time": 101.33,
      "time_str": "01:41.330",
      "text": "看看又是一年春风",
      "translation": null
    },
    {
