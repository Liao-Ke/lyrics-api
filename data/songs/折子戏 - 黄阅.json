  "lyrics": [
    {
      "time": 34.61,
      "time_str": "00:34.610",
      "text": "你穿上凤冠霞衣",
      "translation": null
    },
    {
      "time": 39.09,
      "time_str": "00:39.090",
      "text": "我将眉目掩去",
      "translation": null
    },
    {
      "time": 43.54,
      "time_str": "00:43.540",
      "text": "大红的幔布扯开了一出折子戏",
      "translation": null
    },
    {
      "time": 52.56,
      "time_str": "00:52.560",
      "text": "你演的不是自己",
      "translation": null
    },
    {
      "time": 57.25,
      "time_str": "00:57.250",
      "text": "我却投入情绪",
      "translation": null
    },
    {
      "time": 61.22,
      "time_str": "01:01.220",
      "text": "弦索胡琴不能免俗的是死别生离",
      "translation": null
    },
    {
      "time": 70.08,
      "time_str": "01:10.080",
      "text": "折子戏不过是全剧的几分之一",
      "translation": null
    },
    {
      "time": 74.57,
      "time_str": "01:14.570",
      "text": "通常不会上演开始和结局",
      "translation": null
    },
    {
      "time": 79.08,
      "time_str": "01:19.080",
      "text": "正是多了一种残缺不全的魅力",
      "translation": null
    },
    {
      "time": 83.29,
      "time_str": "01:23.290",
      "text": "才没有那么多含恨不如意",
      "translation": null
    },
    {
      "time": 90.3,
      "time_str": "01:30.300",
      "text": "如果人人都是一出折子戏",
      "translation": null
    },
    {
      "time": 94.57,
      "time_str": "01:34.570",
      "text": "把最璀璨的部分留在别人生命里",
      "translation": null
    },
    {
      "time": 99.36,
      "time_str": "01:39.360",
      "text": "如果人间拭去脂粉的艳丽",
      "translation": null
    },
    {
      "time": 103.64,
      "time_str": "01:43.640",
      "text": "还会不会有动情的演绎",
      "translation": null
    },
    {
      "time": 108.39,
      "time_str": "01:48.390",
      "text": "如果人人都是一出折子戏",
      "translation": null
    },
    {
      "time": 112.58,
      "time_str": "01:52.580",
      "text": "在剧中尽情释放自己的欢乐悲喜",
      "translation": null
