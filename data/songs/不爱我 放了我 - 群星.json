    {
      "time": 108.09,
      "time_str": "01:48.090",
      "text": "何必非得让我",
      "translation": null
    },
    {
      "time": 110.4,
      "time_str": "01:50.400",
      "text": "在你面前疯了",
      "translation": null
    },
    {
