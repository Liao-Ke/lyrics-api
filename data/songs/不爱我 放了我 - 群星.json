    {
      "time": 53.97,
      "time_str": "00:53.970",
      "text": "我是这样僵着",
      "translation": null
    },
    {
      "time": 56.25,
      "time_str": "00:56.250",
      "text": "忍着苦着等着",
      "translation": null
    },
    {
      "time": 61.77,
      "time_str": "01:01.770",
      "text": "被你那样摆着",
      "translation": null
    },
    {
      "time": 63.9,
      "time_str": "01:03.900",
      "text": "晾着冻着空着",
      "translation": null
    },
    {
      "time": 67.17,
      "time_str": "01:07.170",
      "text": "泪乾了 就让眼枯了",
      "translation": null
    },
    {
      "time": 73.35,
      "time_str": "01:13.350",
      "text": "人走了 就让心死了",
      "translation": null
    },
    {
      "time": 77.25,
      "time_str": "01:17.250",
      "text": "你从来不管我",
      "translation": null
    },
    {
      "time": 79.32,
      "time_str": "01:19.320",
      "text": "是笑的还是哭的",
      "translation": null
    },
    {
      "time": 84.99,
      "time_str": "01:24.990",
      "text": "被你那样 搁着",
      "translation": null
    },
    {
      "time": 87.03,
      "time_str": "01:27.030",
      "text": "放着悬着藏着",
      "translation": null
    },
    {
      "time": 92.7,
      "time_str": "01:32.700",
      "text": "我是这样 熬着",
      "translation": null
    },
    {
      "time": 94.92,
      "time_str": "01:34.920",
      "text": "病着疼着蔓延着",
      "translation": null
    },
    {
      "time": 100.44,
      "time_str": "01:40.440",
      "text": "天黑了别让灯亮着",
      "translation": null
    },
    {
      "time": 104.34,
      "time_str": "01:44.340",
      "text": "你走了就让门关着",
      "translation": null
