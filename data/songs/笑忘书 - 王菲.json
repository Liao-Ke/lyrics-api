    {
      "time": 12.61,
      "time_str": "00:12.610",
      "text": "没 没有蜡烛",
      "translation": null
    },
    {
      "time": 15.28,
      "time_str": "00:15.280",
      "text": "就不用勉强庆祝",
      "translation": null
    },
    {
      "time": 18.12,
      "time_str": "00:18.120",
      "text": "没 没想到答案",
      "translation": null
    },
    {
      "time": 21.02,
      "time_str": "00:21.020",
      "text": "就不要寻找题目",
      "translation": null
    },
    {
      "time": 23.92,
      "time_str": "00:23.920",
      "text": "没 没有退路",
      "translation": null
    },
    {
      "time": 26.77,
      "time_str": "00:26.770",
      "text": "那我也不要散步",
      "translation": null
    },
    {
      "time": 29.48,
      "time_str": "00:29.480",
      "text": "没 没人去仰慕",
      "translation": null
    },
    {
      "time": 32.43,
      "time_str": "00:32.430",
      "text": "那我就继续忙碌",
      "translation": null
    },
    {
      "time": 35.17,
      "time_str": "00:35.170",
      "text": "来 来 思前想后",
      "translation": null
    },
    {
      "time": 38.12,
      "time_str": "00:38.120",
      "text": "差一点忘记了怎么投诉",
      "translation": null
    },
    {
      "time": 41.33,
      "time_str": "00:41.330",
      "text": "来 来 从此以后",
      "translation": null
    },
    {
      "time": 43.83,
      "time_str": "00:43.830",
      "text": "不要犯同一个错误",
      "translation": null
    },
    {
      "time": 46.68,
      "time_str": "00:46.680",
      "text": "将这样的感触",
      "translation": null
    },
    {
      "time": 48.69,
      "time_str": "00:48.690",
      "text": "写一封情书送给我自己",
      "translation": null
    },
    {
      "time": 51.75,
      "time_str": "00:51.750",
      "text": "感动得要哭 很久没哭",
      "translation": null
    },
    {
      "time": 55.26,
      "time_str": "00:55.260",
      "text": "不失为天大的幸福",
      "translation": null
    },
    {
      "time": 58.2,
      "time_str": "00:58.200",
      "text": "将这一份礼物 这一封情书",
      "translation": null
    },
    {
