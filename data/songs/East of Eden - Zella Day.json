    },
    {
      "time": 0.78,
      "time_str": "00:00.780",
      "text": "Pink toes pressed against the carpet",
      "translation": "粉红脚趾头压住地毯"
    },
    {
      "time": 4.38,
      "time_str": "00:04.380",
      "text": "Show your face and finish",
      "translation": "显露你的表情"
    },
    {
      "time": 6.59,
      "time_str": "00:06.590",
      "text": "what you started",
      "translation": "在你开始的地方结束"
    },
    {
      "time": 8.13,
      "time_str": "00:08.130",
      "text": "The record spins down",
      "translation": "唱片不停播放着"
    },
    {
      "time": 9.96,
      "time_str": "00:09.960",
      "text": "the alley late night",
      "translation": "在深夜的小巷回荡着"
    },
    {
      "time": 12.12,
      "time_str": "00:12.120",
      "text": "Be my friend,",
      "translation": "做我的朋友吧"
    },
    {
      "time": 13.42,
      "time_str": "00:13.420",
      "text": "surround me like a satellite",
      "translation": "像一颗卫星般包围我"
    },
    {
      "time": 15.67,
      "time_str": "00:15.670",
      "text": "Tiger on the prowl",
      "translation": "老虎潜行徘徊"
    },
    {
      "time": 18.15,
      "time_str": "00:18.150",
      "text": "East of Eden",
      "translation": "伊甸之东"
    },
    {
      "time": 19.61,
      "time_str": "00:19.610",
      "text": "Coming for you now",
      "translation": "为你而来"
    },
    {
      "time": 22.62,
