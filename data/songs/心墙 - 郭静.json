  "lyrics": [
    {
      "time": 0.4,
      "time_str": "00:00.400",
      "text": "一个人 眺望碧海和蓝天",
      "translation": null
    },
    {
      "time": 8.46,
      "time_str": "00:08.460",
      "text": "在心里面 那抹灰就淡一些",
      "translation": null
    },
    {
      "time": 15.19,
      "time_str": "00:15.190",
      "text": "海豚从眼前 飞越",
      "translation": null
    },
    {
      "time": 19.2,
      "time_str": "00:19.200",
      "text": "我看见了最阳光的笑脸",
      "translation": null
    },
    {
      "time": 23.38,
      "time_str": "00:23.380",
      "text": "好时光都该被宝贝 因为有限",
      "translation": null
    },
    {
      "time": 32.119,
      "time_str": "00:32.119",
      "text": "我学着不去担心得太远",
      "translation": null
    },
    {
      "time": 35.87,
      "time_str": "00:35.870",
      "text": "不计划太多 反而能勇敢冒险",
      "translation": null
    },
    {
      "time": 39.58,
      "time_str": "00:39.580",
      "text": "丰富地过每一天 快乐地看每一天",
      "translation": null
    },
    {
      "time": 47.35,
      "time_str": "00:47.350",
      "text": "第一次遇见阴天 遮住你侧脸",
      "translation": null
    },
    {
      "time": 51.8,
      "time_str": "00:51.800",
      "text": "有什么故事好想了解",
      "translation": null
    },
    {
      "time": 54.71,
      "time_str": "00:54.710",
      "text": "我感觉我懂 你的特别",
      "translation": null
    },
    {
      "time": 61.13,
      "time_str": "01:01.130",
      "text": "你的心有一道墙 但我发现一扇窗",
      "translation": null
    },
    {
      "time": 70.19,
      "time_str": "01:10.190",
      "text": "偶尔透出 一丝暖暖的微光",
      "translation": null
    },
    {
      "time": 77.3,
      "time_str": "01:17.300",
      "text": "就算你有一道墙 我的爱会攀上窗台盛放",
      "translation": null
    },
    {
      "time": 84.88,
      "time_str": "01:24.880",
      "text": "打开窗你会看到 悲伤融化",
      "translation": null
    },
