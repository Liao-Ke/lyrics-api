  "lyrics": [
    {
      "time": 18.85,
      "time_str": "00:18.850",
      "text": "我听着你最后的要求",
      "translation": null
    },
    {
      "time": 26.55,
      "time_str": "00:26.550",
      "text": "分手后彼此要好好过",
      "translation": null
    },
    {
      "time": 34.45,
      "time_str": "00:34.45",
      "text": "我知道你跌坐在门口",
      "translation": null
    },
    {
      "time": 41.9,
      "time_str": "00:41.90",
      "text": "收拾着你自己的难过",
      "translation": null
    },
    {
      "time": 50.4,
      "time_str": "00:50.40",
      "text": "因为爱情",
      "translation": null
    },
    {
      "time": 54.41,
      "time_str": "00:54.41",
      "text": "我们都努力过",
      "translation": null
    },
    {
      "time": 58.32,
      "time_str": "00:58.32",
      "text": "只是到最后",
      "translation": null
    },
    {
      "time": 62.22,
      "time_str": "01:02.22",
      "text": "分开对你是解脱",
      "translation": null
    },
    {
      "time": 67.09,
      "time_str": "01:07.09",
      "text": "就让你走",
      "translation": null
    },
    {
      "time": 70.96,
      "time_str": "01:10.96",
      "text": "不留什么",
      "translation": null
    },
    {
      "time": 73.03,
      "time_str": "01:13.03",
      "text": "我手中的香烟",
      "translation": null
    },
    {
      "time": 76.68,
      "time_str": "01:16.68",
      "text": "也只剩一口",
      "translation": null
    },
    {
      "time": 82.1,
      "time_str": "01:22.10",
      "text": "再没有理由",
      "translation": null
    },
    {
      "time": 86.39,
      "time_str": "01:26.39",
      "text": "叫你再回一次头",
      "translation": null
    },
    {
      "time": 89.04,
      "time_str": "01:29.04",
      "text": "爱像水在你手中遗漏",
      "translation": null
    },
    {
      "time": 92.87,
      "time_str": "01:32.87",
      "text": "回到最深的海洋之中",
      "translation": null
    },
    {
      "time": 98.03,
      "time_str": "01:38.03",
      "text": "就让你走",
      "translation": null
    },
    {
      "time": 101.91,
      "time_str": "01:41.91",
      "text": "没说什么",
      "translation": null
    },
    {
      "time": 104.01,
      "time_str": "01:44.01",
      "text": "只因为我知道",
      "translation": null
    },
    {
      "time": 107.66,
      "time_str": "01:47.66",
      "text": "你仍在我心中",
      "translation": null
    },
    {
      "time": 112.9,
      "time_str": "01:52.90",
      "text": "心隐隐作痛",
      "translation": null
    },
    {
      "time": 116.89,
      "time_str": "01:56.89",
      "text": "不想你看到我难过",
      "translation": null
    },
    {
      "time": 120.12,
      "time_str": "02:00.12",
      "text": "只要你能够从此快乐",
      "translation": null
    },
    {
      "time": 123.87,
      "time_str": "02:03.87",
      "text": "就别想我该怎么生活",
      "translation": null
    },
    {
      "time": 128.85,
      "time_str": "02:08.85",
      "text": "怎么过",
      "translation": null
    },
