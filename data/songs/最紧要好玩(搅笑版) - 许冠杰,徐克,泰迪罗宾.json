    {
      "time": 21.0,
      "time_str": "00:21.000",
      "text": "許：其實我天生奔放貪玩，",
      "translation": null
    },
    {
      "time": 23.92,
      "time_str": "00:23.920",
      "text": "唔愿有獎品只要笑顏，",
      "translation": null
    },
    {
      "time": 27.38,
      "time_str": "00:27.380",
      "text": "關：翻工我唔慣，鄉下有田我不耕。",
      "translation": null
    },
    {
      "time": 33.79,
      "time_str": "00:33.790",
      "text": "許：人其實天生奔放貪玩，",
      "translation": null
    },
    {
      "time": 37.26,
      "time_str": "00:37.260",
      "text": "原沒有拘束只有笑顏，",
      "translation": null
    },
    {
      "time": 40.64,
      "time_str": "00:40.640",
      "text": "徐：點到我唔信，屋企各人困青山。",
      "translation": null
    },
    {
      "time": 47.76,
      "time_str": "00:47.760",
      "text": "關：我想嘥粒子彈捉只鱷魚用嚟送飯，",
      "translation": null
    },
    {
      "time": 54.2,
      "time_str": "00:54.200",
      "text": "許：其實開心好簡單，最緊要好玩。n！",
      "translation": null
    },
    {
      "time": 62.48,
      "time_str": "01:02.480",
      "text": "徐：我愿抬著炸藥成磅對你單眼，",
      "translation": null
    },
    {
      "time": 65.82,
      "time_str": "01:05.820",
      "text": "星光之上扯起鼻寒你要避難，",
      "translation": null
    },
    {
      "time": 69.4,
      "time_str": "01:09.400",
      "text": "我用雷電放射融掉你那雙眼，",
      "translation": null
    },
    {
      "time": 72.61,
      "time_str": "01:12.610",
      "text": "合：使你無從忘掉這暴力先生。",
      "translation": null
    },
    {
      "time": 78.82,
      "time_str": "01:18.820",
      "text": "許：乘坐穿梭機飛到沙灘，",
      "translation": null
    },
    {
      "time": 82.07,
      "time_str": "01:22.070",
      "text": "陳立品叉腰通處吐痰，",
      "translation": null
    },
    {
