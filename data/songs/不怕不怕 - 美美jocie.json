      "text": "MAI-A-HO MAI-A-HA-HA",
      "translation": null
    },
    {
      "time": 33.07,
      "time_str": "00:33.070",
      "text": "HELLO！看我！",
      "translation": null
    },
    {
      "time": 37.05,
      "time_str": "00:37.050",
      "text": "你在害怕什么？",
      "translation": null
    },
    {
      "time": 40.52,
      "time_str": "00:40.520",
      "text": "是我错，",
      "translation": null
    },
    {
      "time": 42.4,
      "time_str": "00:42.400",
      "text": "没能够啊 把自己变得成熟",
      "translation": null
    },
    {
      "time": 48.09,
      "time_str": "00:48.090",
      "text": "伤口 那么多",
      "translation": null
    },
    {
      "time": 51.56,
      "time_str": "00:51.560",
      "text": "已经不怕再痛",
      "translation": null
    },
    {
      "time": 55.35,
      "time_str": "00:55.350",
      "text": "没什么 转身以后",
      "translation": null
    },
    {
      "time": 58.57,
      "time_str": "00:58.570",
      "text": "我会练成无敌神功!",
      "translation": null
    },
    {
      "time": 62.47,
      "time_str": "01:02.470",
      "text": "看见蟑螂",
      "translation": null
    },
    {
      "time": 64.12,
      "time_str": "01:04.120",
      "text": "我不怕不怕啦",
      "translation": null
    },
    {
      "time": 65.97,
      "time_str": "01:05.970",
      "text": "我神经比较大",
      "translation": null
    },
    {
      "time": 67.77,
      "time_str": "01:07.770",
      "text": "不怕不怕不怕啦",
      "translation": null
    },
    {
      "time": 69.74,
      "time_str": "01:09.740",
      "text": "胆怯只会让自己更憔悴",
      "translation": null
    },
    {
      "time": 73.36,
      "time_str": "01:13.360",
      "text": "麻痹也是勇敢表现",
      "translation": null
    },
    {
      "time": 77.18,
      "time_str": "01:17.180",
      "text": "一个人睡也不怕不怕啦",
      "translation": null
    },
    {
      "time": 80.75,
      "time_str": "01:20.750",
      "text": "勇气当棉被",
