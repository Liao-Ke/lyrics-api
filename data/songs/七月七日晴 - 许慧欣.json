  "lyrics": [
    {
      "time": 22.65,
      "time_str": "00:22.650",
      "text": "说了再见",
      "translation": null
    },
    {
      "time": 24.38,
      "time_str": "00:24.380",
      "text": "是否就能不再想念",
      "translation": null
    },
    {
      "time": 31.07,
      "time_str": "00:31.070",
      "text": "说了抱歉",
      "translation": null
    },
    {
      "time": 33.63,
      "time_str": "00:33.630",
      "text": "是否就能理解了一切",
      "translation": null
    },
    {
      "time": 39.82,
      "time_str": "00:39.820",
      "text": "眼泪代替你亲吻我的脸",
      "translation": null
    },
    {
      "time": 47.7,
      "time_str": "00:47.700",
      "text": "我的世界忽然冰天白雪",
      "translation": null
    },
    {
      "time": 54.45,
      "time_str": "00:54.450",
      "text": "五指之间",
      "translation": null
    },
    {
      "time": 57.44,
      "time_str": "00:57.440",
      "text": "还残留你的昨天",
      "translation": null
    },
    {
      "time": 63.94,
      "time_str": "01:03.940",
      "text": "一片一片",
      "translation": null
    },
    {
      "time": 65.88,
      "time_str": "01:05.880",
      "text": "怎么拼贴完全",
      "translation": null
    },
    {
      "time": 71.38,
      "time_str": "01:11.380",
      "text": "七月七日晴",
      "translation": null
    },
    {
      "time": 73.0,
      "time_str": "01:13.000",
      "text": "忽然下起了大雪",
      "translation": null
    },
    {
      "time": 75.32,
      "time_str": "01:15.320",
      "text": "不敢睁开眼",
      "translation": null
    },
    {
      "time": 77.26,
      "time_str": "01:17.260",
      "text": "希望是我的幻觉",
      "translation": null
    },
    {
      "time": 79.57,
      "time_str": "01:19.570",
      "text": "我站在地球边",
      "translation": null
    },
    {
      "time": 81.57,
      "time_str": "01:21.570",
      "text": "眼睁睁看着雪",
      "translation": null
    },
    {
      "time": 83.63,
      "time_str": "01:23.630",
      "text": "覆盖你来的那条街",
      "translation": null
    },
    {
      "time": 88.01,
      "time_str": "01:28.010",
      "text": "七月七日晴",
      "translation": null
    },
    {
      "time": 89.63,
      "time_str": "01:29.630",
      "text": "黑夜忽然变白天",
      "translation": null
    },
    {
      "time": 91.88,
      "time_str": "01:31.880",
      "text": "我失去知觉",
      "translation": null
    },
    {
      "time": 93.94,
      "time_str": "01:33.940",
      "text": "看见相爱的极限",
      "translation": null
    },
    {
      "time": 96.13,
      "time_str": "01:36.130",
      "text": "我望着地平线",
      "translation": null
    },
    {
      "time": 98.07,
      "time_str": "01:38.070",
      "text": "天空无际无边",
      "translation": null
    },
    {
      "time": 100.19,
      "time_str": "01:40.190",
      "text": "听不见你道别",
