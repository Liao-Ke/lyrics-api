{
  "title": "可惜我是水瓶座",
  "title_raw": "可惜我是水瓶座",
  "version": null,
  "artist": "杨千嬅",
  "group_key": "可惜我是水瓶座|杨千嬅",
  "writers": {
    "lyricist": "黄伟文",
    "composer": "雷颂德",
