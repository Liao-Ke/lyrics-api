  },
  "lyrics": [
    {
      "time": 11.91,
      "time_str": "00:11.910",
      "text": "原来你这样珍惜我",
      "translation": null
    },
    {
      "time": 17.51,
      "time_str": "00:17.510",
      "text": "从前在热恋中都未听讲过",
      "translation": null
    },
    {
      "time": 22.86,
      "time_str": "00:22.860",
      "text": "别说这种行货 哪里留得住我",
      "translation": null
    },
    {
      "time": 28.88,
      "time_str": "00:28.880",
      "text": "到底是为什么分手你很清楚",
      "translation": null
    },
    {
      "time": 34.48,
      "time_str": "00:34.480",
      "text": "如何笨到底 但到底还是我",
      "translation": null
    },
    {
      "time": 39.89,
      "time_str": "00:39.890",
      "text": "谁人待我好 待我差 太清楚",
      "translation": null
    },
    {
      "time": 45.8,
      "time_str": "00:45.800",
      "text": "想继续装傻 却又无力受折磨",
      "translation": null
    },
    {
      "time": 51.4,
      "time_str": "00:51.400",
      "text": "心里羡慕那些人 盲目到不计后果",
      "translation": null
    },
    {
      "time": 57.81,
      "time_str": "00:57.810",
      "text": "我就回去 别引出我泪水",
      "translation": null
    },
    {
      "time": 63.51,
      "time_str": "01:03.510",
      "text": "尤其明知水瓶座最爱是流泪",
      "translation": null
    },
    {
      "time": 68.47,
      "time_str": "01:08.470",
      "text": "若然道别是下一句 可以闭上了你的嘴",
      "translation": null
    },
    {
      "time": 74.12,
      "time_str": "01:14.120",
      "text": "无谓再会要是再会更加心碎",
      "translation": null
    },
    {
      "time": 80.57,
      "time_str": "01:20.570",
      "text": "要是回去没有止痛药水",
      "translation": null
    },
    {
      "time": 86.28,
      "time_str": "01:26.280",
      "text": "拿来长岛冰茶换我半晚安睡",
      "translation": null
    },
    {
      "time": 91.18,
      "time_str": "01:31.180",
      "text": "十年后或现在失去 反正到最尾也唏嘘",
      "translation": null
    },
    {
      "time": 96.89,
      "time_str": "01:36.890",
      "text": "够绝情我都赶我自己出去",
      "translation": null
    },
    {
      "time": 113.98,
      "time_str": "01:53.980",
      "text": "犹如最结实的堡垒",
      "translation": null
    },
    {
      "time": 119.49,
      "time_str": "01:59.490",
      "text": "原来在逐点崩溃逐点粉碎",
      "translation": null
    },
    {
      "time": 124.85,
      "time_str": "02:04.850",
      "text": "极固执的如我 也会捱不下去",
      "translation": null
    },
    {
      "time": 130.82,
      "time_str": "02:10.820",
      "text": "每天扮着幸福始终有些心虚",
      "translation": null
    },
    {
      "time": 136.38,
      "time_str": "02:16.380",
      "text": "如何笨到底 但到底还是我",
      "translation": null
    },
    {
