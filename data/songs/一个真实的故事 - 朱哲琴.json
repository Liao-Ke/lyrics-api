  "lyrics": [
    {
      "time": 2.5,
      "time_str": "00:02.500",
      "text": "有一个女孩她从小就爱养丹顶鹤",
      "translation": null
    },
    {
      "time": 6.31,
      "time_str": "00:06.310",
      "text": "在她大学毕业以后",
      "translation": null
    },
    {
      "time": 8.87,
      "time_str": "00:08.870",
      "text": "她仍回到她养鹤的地方",
      "translation": null
    },
    {
      "time": 13.05,
      "time_str": "00:13.050",
      "text": "可是有一天",
      "translation": null
    },
    {
      "time": 15.9,
      "time_str": "00:15.900",
      "text": "她为了救一只受伤的丹顶鹤",
      "translation": null
    },
    {
      "time": 19.77,
      "time_str": "00:19.770",
      "text": "滑进了沼泽地里",
      "translation": null
    },
    {
      "time": 22.33,
      "time_str": "00:22.330",
      "text": "就再也没有上来",
      "translation": null
    },
    {
      "time": 26.2,
      "time_str": "00:26.200",
      "text": "走过那条小河",
      "translation": null
    },
    {
      "time": 29.32,
      "time_str": "00:29.320",
      "text": "你可曾听说",
      "translation": null
    },
    {
      "time": 33.0,
      "time_str": "00:33.000",
      "text": "有一位女孩她曾经来过",
      "translation": null
    },
    {
      "time": 41.9,
      "time_str": "00:41.900",
      "text": "走过这片芦苇坡",
      "translation": null
    },
    {
      "time": 45.14,
      "time_str": "00:45.140",
      "text": "你可曾听说",
      "translation": null
    },
    {
      "time": 48.7,
      "time_str": "00:48.700",
      "text": "有一位女孩",
      "translation": null
    },
    {
      "time": 52.07,
      "time_str": "00:52.070",
      "text": "她留下一首歌",
      "translation": null
    },
    {
      "time": 57.62,
      "time_str": "00:57.620",
      "text": "为何片片白云悄悄落泪",
      "translation": null
    },
    {
      "time": 64.55,
      "time_str": "01:04.550",
      "text": "为何阵阵风儿轻声诉说",
      "translation": null
    },
    {
      "time": 71.35,
      "time_str": "01:11.350",
      "text": "呜呜呜呜呜",
      "translation": null
    },
    {
      "time": 73.78,
      "time_str": "01:13.780",
      "text": "喔噢噢噢噢",
      "translation": null
    },
    {
      "time": 78.46,
      "time_str": "01:18.460",
      "text": "还有一群丹顶鹤轻轻地",
      "translation": null
    },
    {
      "time": 84.7,
      "time_str": "01:24.700",
      "text": "轻轻地飞过",
      "translation": null
    },
    {
