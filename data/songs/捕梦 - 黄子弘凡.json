    {
      "time": 16.86,
      "time_str": "00:16.860",
      "text": "Verse1",
      "translation": null
    },
    {
      "time": 17.6,
      "time_str": "00:17.600",
      "text": "被月光遗忘的窗边",
      "translation": null
    },
    {
      "time": 23.56,
      "time_str": "00:23.560",
      "text": "一盏不眠光线",
      "translation": null
    },
    {
      "time": 26.93,
      "time_str": "00:26.930",
      "text": "像人造太阳般耀眼",
      "translation": null
    },
    {
      "time": 34.75,
      "time_str": "00:34.750",
      "text": "Verse2",
      "translation": null
    },
    {
      "time": 35.31,
      "time_str": "00:35.310",
      "text": "用时间和心血堆叠",
      "translation": null
    },
    {
      "time": 38.93,
      "time_str": "00:38.930",
      "text": "用指尖温度溶解",
      "translation": null
    },
    {
      "time": 42.75,
      "time_str": "00:42.750",
      "text": "把想念织进梦里面",
      "translation": null
    },
    {
      "time": 50.12,
      "time_str": "00:50.120",
      "text": "Pre-Chorus1",
      "translation": null
    },
    {
      "time": 50.36,
      "time_str": "00:50.360",
      "text": "一勾一捻",
      "translation": null
    },
    {
      "time": 53.46,
      "time_str": "00:53.460",
      "text": "心意都缠绕成圈",
      "translation": null
    },
    {
      "time": 57.19,
      "time_str": "00:57.190",
      "text": "牵挂着羽毛装点",
      "translation": null
    },
    {
      "time": 61.45,
      "time_str": "01:01.450",
      "text": "让风送到你身边",
      "translation": null
    },
    {
      "time": 71.01,
      "time_str": "01:11.010",
      "text": "Chorus",
      "translation": null
    },
    {
      "time": 71.42,
      "time_str": "01:11.420",
      "text": "让我 亲手 捕梦 送你",
      "translation": null
    },
    {
      "time": 79.04,
      "time_str": "01:19.040",
      "text": "今夜 不会 再失眠或哭泣",
      "translation": null
    },
    {
      "time": 87.35,
      "time_str": "01:27.350",
      "text": "像星河轨迹 短暂分离",
      "translation": null
    },
    {
      "time": 91.35,
      "time_str": "01:31.350",
      "text": "还会相遇",
      "translation": null
    },
    {
      "time": 94.8,
      "time_str": "01:34.800",
      "text": "纯白色的心意",
      "translation": null
    },
    {
      "time": 97.87,
      "time_str": "01:37.870",
      "text": "咫尺间的距离",
      "translation": null
    },
    {
      "time": 99.55,
      "time_str": "01:39.550",
      "text": "代替我守护着你",
      "translation": null
    },
    {
      "time": 105.16,
      "time_str": "01:45.160",
      "text": "Verse3",
      "translation": null
    },
    {
      "time": 121.62,
      "time_str": "02:01.620",
      "text": "无论明天晴天雨天",
      "translation": null
    },
    {
      "time": 128.09,
      "time_str": "02:08.090",
      "text": "当风经过窗前",
