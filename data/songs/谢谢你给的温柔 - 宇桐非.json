  "lyrics": [
    {
      "time": 17.67,
      "time_str": "00:17.670",
      "text": "每当夜深人静的时候",
      "translation": null
    },
    {
      "time": 21.57,
      "time_str": "00:21.570",
      "text": "总会想起你的温柔",
      "translation": null
    },
    {
      "time": 25.52,
      "time_str": "00:25.520",
      "text": "也许我的脆弱 只有你能猜透",
      "translation": null
    },
    {
      "time": 32.22,
      "time_str": "00:32.220",
      "text": "每当我需要你的时候",
      "translation": null
    },
    {
      "time": 36.17,
      "time_str": "00:36.170",
      "text": "就会给我想要的温柔",
      "translation": null
    },
    {
      "time": 40.22,
      "time_str": "00:40.220",
      "text": "已找不到借口 不爱你的理由",
      "translation": null
    },
    {
      "time": 46.98,
      "time_str": "00:46.980",
      "text": "终于发现牵了手的手",
      "translation": null
    },
    {
      "time": 50.98,
      "time_str": "00:50.980",
      "text": "不会再有其他的奢求",
      "translation": null
    },
    {
      "time": 54.88,
      "time_str": "00:54.880",
      "text": "也许命中注定",
      "translation": null
    },
    {
      "time": 57.03,
      "time_str": "00:57.030",
      "text": "你就是我 永远的港口",
      "translation": null
    },
    {
      "time": 65.75,
      "time_str": "01:05.750",
      "text": "谢谢你给的温柔",
      "translation": null
    },
    {
      "time": 69.4,
      "time_str": "01:09.400",
      "text": "在我最需要你的时候",
      "translation": null
    },
    {
      "time": 73.65,
      "time_str": "01:13.650",
      "text": "都会有你在身边抚平我的伤口",
      "translation": null
    },
    {
      "time": 80.5,
      "time_str": "01:20.500",
      "text": "谢谢你给的温柔",
      "translation": null
    },
    {
      "time": 84.16,
      "time_str": "01:24.160",
      "text": "在我特别特别想你的时候",
      "translation": null
    },
    {
      "time": 88.63,
      "time_str": "01:28.630",
      "text": "从此后 我再没有 悲伤的理由",
      "translation": null
    },
