  "lyrics": [
    {
      "time": 13.85,
      "time_str": "00:13.850",
      "text": "弯成一弯的桥梁倒映在这湖面上",
      "translation": null
    },
    {
      "time": 20.39,
      "time_str": "00:20.390",
      "text": "你从那头瞧这看月光下一轮美满",
      "translation": null
    },
    {
      "time": 27.3,
      "time_str": "00:27.300",
      "text": "青石板的老街上你我走过的地方",
      "translation": null
    },
    {
      "time": 34.1,
      "time_str": "00:34.100",
      "text": "那段斑驳的砖墙如今到底啥模样",
      "translation": null
    },
    {
      "time": 40.95,
      "time_str": "00:40.950",
      "text": "到不了的都叫做远方",
      "translation": null
    },
    {
      "time": 47.85,
      "time_str": "00:47.850",
      "text": "回不去的名字叫家乡",
      "translation": null
    },
    {
      "time": 53.75,
      "time_str": "00:53.750",
      "text": "呜~",
      "translation": null
    },
    {
      "time": 54.8,
      "time_str": "00:54.800",
      "text": "谁在门外唱那首牡丹江",
      "translation": null
    },
    {
      "time": 58.3,
      "time_str": "00:58.300",
      "text": "我聆听感伤你声音悠扬",
      "translation": null
    },
    {
      "time": 61.5,
      "time_str": "01:01.500",
      "text": "风铃摇晃清脆响",
      "translation": null
    },
    {
      "time": 64.75,
      "time_str": "01:04.750",
      "text": "江边的小村庄午睡般安祥",
      "translation": null
    },
    {
      "time": 68.26,
      "time_str": "01:08.260",
      "text": "谁在门外唱那首牡丹江",
      "translation": null
    },
    {
      "time": 71.86,
      "time_str": "01:11.860",
      "text": "我脚步轻响走向你身旁",
      "translation": null
    },
    {
