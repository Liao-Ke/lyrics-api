    {
      "time": 14.263,
      "time_str": "00:14.263",
      "text": "外面下着雨",
      "translation": null
    },
    {
      "time": 17.301,
      "time_str": "00:17.301",
      "text": "犹如我心血在滴",
      "translation": null
    },
    {
      "time": 21.236,
      "time_str": "00:21.236",
      "text": "爱你那么久",
      "translation": null
    },
    {
      "time": 24.398,
      "time_str": "00:24.398",
      "text": "其实算算不容易",
      "translation": null
    },
    {
      "time": 28.315,
      "time_str": "00:28.315",
      "text": "就要分东西",
      "translation": null
    },
    {
      "time": 31.576,
      "time_str": "00:31.576",
      "text": "明天不再有关系",
      "translation": null
    },
    {
      "time": 35.312,
      "time_str": "00:35.312",
      "text": "留在家里的衣服",
      "translation": null
    },
    {
      "time": 38.39,
      "time_str": "00:38.390",
      "text": "有空再来拿回去",
      "translation": null
    },
    {
      "time": 42.997,
      "time_str": "00:42.997",
      "text": "不去想爱都结了果",
      "translation": null
    },
    {
      "time": 47.12,
      "time_str": "00:47.120",
      "text": "舍不得拼命找借口",
      "translation": null
    },
    {
      "time": 49.972,
      "time_str": "00:49.972",
      "text": "不勉强你再为了我",
      "translation": null
    },
    {
      "time": 54.216,
      "time_str": "00:54.216",
      "text": "心不在留不留都是痛",
      "translation": null
    },
    {
      "time": 60.96,
      "time_str": "01:00.960",
      "text": "我可以抱你吗 爱人",
      "translation": null
    },
    {
      "time": 63.663,
      "time_str": "01:03.663",
      "text": "让我在你肩膀哭泣",
      "translation": null
    },
    {
      "time": 66.81,
      "time_str": "01:06.810",
      "text": "如果今天我们就要分离",
      "translation": null
    },
    {
      "time": 69.871,
      "time_str": "01:09.871",
      "text": "让我痛快地哭出声音",
      "translation": null
    },
    {
      "time": 74.368,
      "time_str": "01:14.368",
      "text": "我可以抱你吗 宝贝",
      "translation": null
    },
    {
      "time": 77.861,
      "time_str": "01:17.861",
      "text": "容我最后一次这样叫你",
      "translation": null
    },
    {
      "time": 80.913,
      "time_str": "01:20.913",
      "text": "你也不得已",
      "translation": null
    },
    {
      "time": 82.681,
      "time_str": "01:22.681",
      "text": "我会笑笑的离去",
      "translation": null
    },
