  "lyrics": [
    {
      "time": 9.96,
      "time_str": "00:09.960",
      "text": "给你我的心作纪念",
      "translation": null
    },
    {
      "time": 15.58,
      "time_str": "00:15.580",
      "text": "这份爱 任何时刻你打开都新鲜",
      "translation": null
    },
    {
      "time": 20.19,
      "time_str": "00:20.190",
      "text": "有我陪伴 多苦都变成甜",
      "translation": null
    },
    {
      "time": 23.69,
      "time_str": "00:23.690",
      "text": "睁开眼就看见永远",
      "translation": null
    },
    {
      "time": 27.74,
      "time_str": "00:27.740",
      "text": "给我你的心作纪念 我的梦",
      "translation": null
    },
    {
      "time": 32.81,
      "time_str": "00:32.810",
      "text": "有你的祝福才能够完全",
      "translation": null
    },
    {
      "time": 36.3,
      "time_str": "00:36.300",
      "text": "风浪再大 我也会勇往直前",
      "translation": null
    },
    {
      "time": 39.8,
      "time_str": "00:39.800",
      "text": "我们的爱 镶在青春的纪念册",
      "translation": null
    },
    {
      "time": 60.09,
      "time_str": "01:00.090",
      "text": "去年夏天",
      "translation": null
    },
    {
      "time": 64.09,
      "time_str": "01:04.090",
      "text": "数着贝壳和浪花的海边",
      "translation": null
    },
    {
      "time": 67.65,
      "time_str": "01:07.650",
      "text": "我们祈祷着明年的今天",
      "translation": null
    },
    {
      "time": 72.14,
      "time_str": "01:12.140",
      "text": "还能够保持这样无忧笑脸",
      "translation": null
    },
    {
      "time": 76.01,
      "time_str": "01:16.010",
      "text": "你是夏天",
      "translation": null
    },
    {
      "time": 80.31,
      "time_str": "01:20.310",
      "text": "有海风吹过棕榈的蓝天",
      "translation": null
    },
    {
      "time": 83.68,
      "time_str": "01:23.680",
      "text": "让我忘记了眼泪有多咸",
      "translation": null
    },
    {
      "time": 88.05,
      "time_str": "01:28.050",
      "text": "你一出现就是晴天",
      "translation": null
    },
    {
      "time": 91.36,
      "time_str": "01:31.360",
      "text": "还想听你任性的说",
      "translation": null
    },
    {
      "time": 95.16,
      "time_str": "01:35.160",
      "text": "要带我去环游世界",
      "translation": null
    },
    {
      "time": 100.28,
      "time_str": "01:40.280",
      "text": "就算整个世界都改变",
      "translation": null
    },
    {
      "time": 103.71,
      "time_str": "01:43.710",
      "text": "也不改变 为你勇敢的自己",
      "translation": null
    },
    {
