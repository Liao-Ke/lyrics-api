    {
      "time": 161.49,
      "time_str": "02:41.490",
      "text": "一年以后",
      "translation": null
    },
    {
      "time": 165.04,
      "time_str": "02:45.040",
      "text": "我们踏上了各自的旅途",
      "translation": null
    },
    {
      "time": 168.73,
      "time_str": "02:48.730",
      "text": "虽然经历过不同的故事",
