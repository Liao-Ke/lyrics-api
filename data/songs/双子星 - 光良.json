      "time_str": "00:48.960",
      "text": "我都能感应",
      "translation": null
    },
    {
      "time": 51.11,
      "time_str": "00:51.110",
      "text": "我们就像双子星",
      "translation": null
    },
    {
      "time": 55.87,
      "time_str": "00:55.870",
      "text": "我们面对面 挂在天边",
      "translation": null
    },
    {
      "time": 60.52,
      "time_str": "01:00.520",
      "text": "在黑夜里 连成一条线",
      "translation": null
    },
    {
      "time": 65.69,
      "time_str": "01:05.690",
      "text": "你和我之间 只能相连",
      "translation": null
    },
    {
