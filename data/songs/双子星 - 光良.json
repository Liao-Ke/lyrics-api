    {
      "time": 19.41,
      "time_str": "00:19.410",
      "text": "天上的星星数不清",
      "translation": null
    },
    {
      "time": 23.61,
      "time_str": "00:23.610",
      "text": "最亮的是你",
      "translation": null
    },
    {
      "time": 28.31,
      "time_str": "00:28.310",
      "text": "不管有多远我愿意",
      "translation": null
    },
    {
      "time": 32.86,
      "time_str": "00:32.860",
      "text": "放弃一切寻找你",
      "translation": null
    },
    {
      "time": 37.21,
      "time_str": "00:37.210",
      "text": "我不需要用时间为我证明",
      "translation": null
    },
    {
      "time": 41.66,
      "time_str": "00:41.660",
      "text": "就可以肯定",
      "translation": null
    },
    {
      "time": 46.71,
      "time_str": "00:46.710",
      "text": "你的快乐、伤心",
      "translation": null
    },
    {
