  "lyrics": [
    {
      "time": 14.19,
      "time_str": "00:14.190",
      "text": "发现我们的想法渐渐不同了",
      "translation": null
    },
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "发现我们越来越爱争吵了",
      "translation": null
    },
    {
      "time": 28.15,
      "time_str": "00:28.150",
      "text": "发现你的冷漠渐渐变得多了",
      "translation": null
    },
    {
      "time": 34.81,
      "time_str": "00:34.810",
      "text": "发现你都不听我的解释了",
      "translation": null
    },
    {
      "time": 41.56,
      "time_str": "00:41.560",
      "text": "发现你还喜欢那一种颜色",
      "translation": null
    },
    {
      "time": 48.15,
      "time_str": "00:48.150",
      "text": "发现你还听着那首可爱的歌",
      "translation": null
    },
    {
      "time": 54.78,
      "time_str": "00:54.780",
      "text": "发现我的脆弱渐渐变得大了",
      "translation": null
    },
    {
      "time": 61.42,
      "time_str": "01:01.420",
      "text": "发现我终于找到寂寞了",
      "translation": null
    },
    {
      "time": 68.13,
      "time_str": "01:08.130",
      "text": "亲爱的 我们究竟怎么了",
      "translation": null
    },
    {
      "time": 75.97,
      "time_str": "01:15.970",
      "text": "疲倦了 就想放手了",
      "translation": null
    },
    {
      "time": 82.18,
      "time_str": "01:22.180",
      "text": "爱不是想来就来 想走就走",
      "translation": null
    },
    {
      "time": 86.16,
      "time_str": "01:26.160",
      "text": "这么简单的",
      "translation": null
    },
    {
      "time": 88.59,
      "time_str": "01:28.590",
      "text": "如果真这样 你觉得值不值得",
      "translation": null
    },
    {
      "time": 95.48,
      "time_str": "01:35.480",
      "text": "告诉我 我们究竟哪儿错了",
      "translation": null
    },
    {
      "time": 101.99,
      "time_str": "01:41.990",
      "text": "这一刻 我们沉默了",
      "translation": null
    },
    {
      "time": 109.07,
      "time_str": "01:49.070",
      "text": "我们开心的时刻 却不记得",
      "translation": null
    },
    {
      "time": 113.95,
      "time_str": "01:53.950",
      "text": "那些悲伤的",
      "translation": null
    },
    {
      "time": 115.01,
      "time_str": "01:55.010",
      "text": "偏偏要记得如此深刻",
