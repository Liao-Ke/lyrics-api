  "lyrics": [
    {
      "time": 24.49,
      "time_str": "00:24.490",
      "text": "如果让我遇见你 而你正当年轻",
      "translation": null
    },
    {
      "time": 29.68,
      "time_str": "00:29.680",
      "text": "用最真的心 换你最深的情",
      "translation": null
    },
    {
      "time": 36.65,
      "time_str": "00:36.650",
      "text": "如果让我遇见你 而我依然年轻",
      "translation": null
    },
    {
      "time": 41.7,
      "time_str": "00:41.700",
      "text": "也相信永恒 是不变的曾经",
      "translation": null
    },
    {
      "time": 47.83,
      "time_str": "00:47.830",
      "text": "如果让我离开你 而你亦能平静",
      "translation": null
    },
    {
      "time": 53.01,
      "time_str": "00:53.010",
      "text": "只愿你放心 也不要你担心",
      "translation": null
    },
    {
      "time": 59.85,
      "time_str": "00:59.850",
      "text": "如果让你离开我 假装我也平静",
      "translation": null
    },
    {
      "time": 65.0,
      "time_str": "01:05.000",
      "text": "就算是伤心 也当作是无心",
      "translation": null
    },
    {
      "time": 72.45,
      "time_str": "01:12.450",
      "text": "时空阻隔岂止长路迢迢",
      "translation": null
    },
    {
      "time": 77.23,
      "time_str": "01:17.230",
      "text": "情丝缠绕岂是长发飘飘",
      "translation": null
    },
    {
      "time": 81.94,
      "time_str": "01:21.940",
      "text": "那红尘俗世的人为什么",
      "translation": null
    },
    {
      "time": 87.76,
      "time_str": "01:27.760",
      "text": "总是多情惹烦恼",
      "translation": null
    },
    {
      "time": 94.99,
      "time_str": "01:34.990",
      "text": "本是云该化作雨 投入海的胸襟",
      "translation": null
    },
    {
      "time": 100.1,
      "time_str": "01:40.100",
      "text": "却含著泪水 任孤独的飘零",
      "translation": null
    },
    {
      "time": 106.91,
      "time_str": "01:46.910",
      "text": "本是属于我的你 同把人生看尽",
      "translation": null
    },
    {
      "time": 112.04,
      "time_str": "01:52.040",
      "text": "却无缘再聚 怨苍天变了心",
      "translation": null
