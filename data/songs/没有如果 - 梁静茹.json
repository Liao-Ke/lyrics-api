    {
      "time": 12.83,
      "time_str": "00:12.830",
      "text": "如果我说 爱我没有如果",
      "translation": null
    },
    {
      "time": 15.86,
      "time_str": "00:15.860",
      "text": "错过就过 你是不是会难过",
      "translation": null
    },
    {
      "time": 19.47,
      "time_str": "00:19.470",
      "text": "若“如果”拿来当借口",
      "translation": null
    },
    {
      "time": 22.04,
      "time_str": "00:22.040",
      "text": "那是不是有一点弱",
      "translation": null
    },
    {
      "time": 25.88,
      "time_str": "00:25.880",
      "text": "如果我说 爱我没有如果",
      "translation": null
    },
    {
      "time": 28.88,
      "time_str": "00:28.880",
      "text": "真的爱我 就放手一搏",
      "translation": null
    },
    {
      "time": 31.99,
      "time_str": "00:31.990",
      "text": "还想什么 还怕什么",
      "translation": null
    },
    {
      "time": 35.29,
      "time_str": "00:35.290",
      "text": "快牵起我的手",
      "translation": null
    },
    {
      "time": 38.13,
      "time_str": "00:38.130",
      "text": "有人说",
      "translation": null
    },
    {
      "time": 39.39,
      "time_str": "00:39.390",
      "text": "世界上最遥远的距离",
      "translation": null
    },
    {
      "time": 41.48,
      "time_str": "00:41.480",
      "text": "不是生与死",
      "translation": null
    },
    {
      "time": 43.78,
      "time_str": "00:43.780",
      "text": "而是我就站在你面前",
      "translation": null
    },
    {
      "time": 45.48,
      "time_str": "00:45.480",
      "text": "你却不知道我爱你",
      "translation": null
    },
    {
      "time": 50.97,
      "time_str": "00:50.970",
      "text": "我常说",
      "translation": null
    },
    {
      "time": 52.42,
      "time_str": "00:52.420",
      "text": "如果人类连爱一个人",
      "translation": null
    },
    {
      "time": 54.56,
      "time_str": "00:54.560",
      "text": "都被自己绑住",
      "translation": null
    },
    {
      "time": 56.87,
      "time_str": "00:56.870",
      "text": "那世界末日已来到",
      "translation": null
    },
    {
