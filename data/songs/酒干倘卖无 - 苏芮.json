    },
    {
      "time": 26.11,
      "time_str": "00:26.110",
      "text": "酒干倘卖无 酒干倘卖无",
      "translation": null
    },
    {
      "time": 34.41,
      "time_str": "00:34.410",
      "text": "多么熟悉的声音",
      "translation": null
    },
    {
      "time": 38.37,
      "time_str": "00:38.370",
      "text": "陪我多少年风和雨",
      "translation": null
    },
    {
      "time": 43.03,
      "time_str": "00:43.030",
      "text": "从来不需要想起",
      "translation": null
    },
    {
      "time": 47.37,
      "time_str": "00:47.370",
      "text": "永远也不会忘记",
      "translation": null
    },
    {
      "time": 52.17,
      "time_str": "00:52.170",
      "text": "没有天哪有地",
      "translation": null
    },
    {
      "time": 56.01,
      "time_str": "00:56.010",
      "text": "没有地哪有家",
      "translation": null
    },
    {
      "time": 60.42,
      "time_str": "01:00.420",
      "text": "没有家哪有你",
      "translation": null
    },
    {
      "time": 64.96,
      "time_str": "01:04.960",
      "text": "没有你哪有我",
      "translation": null
    },
    {
      "time": 69.03,
      "time_str": "01:09.030",
      "text": "假如你不曾养育我",
      "translation": null
    },
    {
      "time": 73.14,
      "time_str": "01:13.140",
      "text": "给我温暖的生活",
      "translation": null
    },
    {
      "time": 77.18,
      "time_str": "01:17.180",
      "text": "假如你不曾保护我",
      "translation": null
    },
    {
      "time": 81.67,
      "time_str": "01:21.670",
      "text": "我的命运将会是什么",
      "translation": null
    },
    {
      "time": 86.34,
      "time_str": "01:26.340",
      "text": "是你抚养我长大",
      "translation": null
    },
    {
      "time": 90.49,
      "time_str": "01:30.490",
      "text": "陪我说第一句话",
      "translation": null
    },
    {
      "time": 95.04,
      "time_str": "01:35.040",
      "text": "是你给我一个家",
      "translation": null
    },
    {
      "time": 99.03,
      "time_str": "01:39.030",
      "text": "让我与你共同拥有它",
      "translation": null
    },
    {
      "time": 118.85,
      "time_str": "01:58.850",
      "text": "虽然你不能开口说一句话",
      "translation": null
    },
    {
      "time": 122.78,
      "time_str": "02:02.780",
      "text": "却更能明白人世间的黑白与真假",
      "translation": null
    },
    {
      "time": 126.23,
      "time_str": "02:06.230",
      "text": "虽然你不会表达你的真情",
      "translation": null
    },
    {
      "time": 129.67,
      "time_str": "02:09.670",
      "text": "却付出了热忱的生命",
      "translation": null
    },
    {
      "time": 133.31,
      "time_str": "02:13.310",
      "text": "远处传来你多么熟悉的声音",
      "translation": null
    },
    {
      "time": 137.19,
      "time_str": "02:17.190",
      "text": "让我想起你多么慈祥的心灵",
      "translation": null
    },
    {
      "time": 140.52,
      "time_str": "02:20.520",
      "text": "什么时候你再回到我身旁",
      "translation": null
    },
    {
      "time": 143.87,
      "time_str": "02:23.870",
      "text": "让我再和你一起唱",
      "translation": null
    },
