    {
      "time": 15.992,
      "time_str": "00:15.992",
      "text": "红豆生南国",
      "translation": null
    },
    {
      "time": 21.541,
      "time_str": "00:21.541",
      "text": "是很遥远的事情",
      "translation": null
    },
    {
      "time": 25.3,
      "time_str": "00:25.300",
      "text": "相思算什么",
      "translation": null
    },
    {
      "time": 28.789,
      "time_str": "00:28.789",
      "text": "早无人在意",
      "translation": null
    },
    {
      "time": 32.749,
      "time_str": "00:32.749",
      "text": "醉卧不夜城",
      "translation": null
    },
    {
      "time": 35.721,
      "time_str": "00:35.721",
      "text": "处处霓虹",
      "translation": null
    },
    {
      "time": 39.974,
      "time_str": "00:39.974",
      "text": "酒杯中好一片滥滥风情",
      "translation": null
    },
    {
      "time": 48.899,
      "time_str": "00:48.899",
      "text": "最肯忘却古人诗",
      "translation": null
    },
    {
      "time": 52.216,
      "time_str": "00:52.216",
      "text": "最不屑一顾是相思",
      "translation": null
    },
    {
      "time": 55.927,
      "time_str": "00:55.927",
      "text": "守着爱怕人笑",
      "translation": null
    },
    {
      "time": 59.414,
      "time_str": "00:59.414",
      "text": "还怕人看清",
      "translation": null
    },
    {
      "time": 63.394,
      "time_str": "01:03.394",
      "text": "春又来看红豆开",
      "translation": null
    },
    {
      "time": 66.713,
      "time_str": "01:06.713",
      "text": "竟不见有情人去采",
