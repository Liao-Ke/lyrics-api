  "lyrics": [
    {
      "time": 31.42,
      "time_str": "00:31.420",
      "text": "听见你说朝阳起又落",
      "translation": null
    },
    {
      "time": 37.67,
      "time_str": "00:37.670",
      "text": "晴雨难测道路是脚步多",
      "translation": null
    },
    {
      "time": 44.7,
      "time_str": "00:44.700",
      "text": "我已习惯你突然间的自我",
      "translation": null
    },
    {
      "time": 50.46,
      "time_str": "00:50.460",
      "text": "挥挥洒洒将自然看通透",
      "translation": null
    },
    {
      "time": 59.37,
      "time_str": "00:59.370",
      "text": "那就不要留",
      "translation": null
    },
    {
      "time": 62.42,
      "time_str": "01:02.420",
      "text": "时光一过不再有",
      "translation": null
    },
    {
      "time": 66.5,
      "time_str": "01:06.500",
      "text": "你远眺的天空",
      "translation": null
    },
    {
      "time": 69.25,
      "time_str": "01:09.250",
      "text": "挂更多的彩虹",
      "translation": null
    },
    {
      "time": 72.9,
      "time_str": "01:12.900",
      "text": "我会紧紧的",
      "translation": null
    },
    {
      "time": 75.23,
      "time_str": "01:15.230",
      "text": "将你豪情放在心头",
      "translation": null
    },
    {
      "time": 78.87,
      "time_str": "01:18.870",
      "text": "在寒冬时候就回忆你温柔",
      "translation": null
    },
    {
      "time": 84.87,
      "time_str": "01:24.870",
      "text": "把开怀填进我的心扉",
      "translation": null
    },
    {
      "time": 91.24,
      "time_str": "01:31.240",
      "text": "伤心也是带着微笑的眼泪",
      "translation": null
    },
    {
      "time": 98.46,
      "time_str": "01:38.460",
      "text": "数不尽相逢等不完守候",
      "translation": null
    },
    {
      "time": 104.83,
      "time_str": "01:44.830",
      "text": "如果仅有此生",
      "translation": null
    },
    {
      "time": 107.64,
      "time_str": "01:47.640",
      "text": "又何用待从头",
      "translation": null
    },
