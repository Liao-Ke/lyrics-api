  "lyrics": [
    {
      "time": 33.728,
      "time_str": "00:33.728",
      "text": "夜 夜得那么美丽",
      "translation": null
    },
    {
      "time": 39.127,
      "time_str": "00:39.127",
      "text": "有人欢笑 有人却在哭泣",
      "translation": null
    },
    {
      "time": 46.18,
      "time_str": "00:46.180",
      "text": "尘封的记忆 残留着邂逅的美丽",
      "translation": null
    },
    {
      "time": 52.198,
      "time_str": "00:52.198",
      "text": "辗转反侧的我 失眠在夜里",
      "translation": null
    },
    {
      "time": 60.989,
      "time_str": "01:00.989",
      "text": "你 你带走的呼吸",
      "translation": null
    },
    {
      "time": 66.137,
      "time_str": "01:06.137",
      "text": "吻不到你 那感觉多委屈",
      "translation": null
    },
    {
      "time": 72.687,
      "time_str": "01:12.687",
      "text": "分岔的爱情 让眼泪隔出银河的距离",
      "translation": null
    },
    {
      "time": 80.98,
      "time_str": "01:20.980",
      "text": "轻轻关上门",
      "translation": null
    },
    {
      "time": 82.98,
      "time_str": "01:22.980",
      "text": "让眼泪不逃避",
      "translation": null
    },
    {
      "time": 89.928,
      "time_str": "01:29.928",
      "text": "何必要在一起",
      "translation": null
    },
    {
      "time": 95.19,
      "time_str": "01:35.190",
      "text": "让我爱上你",
      "translation": null
    },
    {
      "time": 97.598,
      "time_str": "01:37.598",
      "text": "至少自己过得不必太压抑",
      "translation": null
    },
    {
      "time": 103.617,
      "time_str": "01:43.617",
      "text": "何必要在一起",
      "translation": null
    },
    {
      "time": 107.937,
      "time_str": "01:47.937",
      "text": "逃出生命里",
      "translation": null
    },
    {
      "time": 111.187,
      "time_str": "01:51.187",
      "text": "才让这个夜显得那么空虚",
      "translation": null
    },
    {
      "time": 117.988,
      "time_str": "01:57.988",
      "text": "何必要在一起",
      "translation": null
    },
    {
