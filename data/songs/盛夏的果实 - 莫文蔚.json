    "arranger": "张佳添"
  },
  "lyrics": [
    {
      "time": 6.3,
      "time_str": "00:06.300",
      "text": "也许放弃 才能靠近你 不再见你",
      "translation": null
    },
    {
      "time": 12.96,
      "time_str": "00:12.960",
      "text": "你才会把我记起 时间累积",
      "translation": null
    },
    {
      "time": 19.76,
      "time_str": "00:19.760",
      "text": "这盛夏的果实 回忆里寂寞的香气",
      "translation": null
    },
    {
      "time": 28.09,
      "time_str": "00:28.090",
      "text": "我要试着离开你   不要再想你",
      "translation": null
    },
    {
      "time": 33.55,
      "time_str": "00:33.550",
      "text": "虽然这并不是我本意",
      "translation": null
    },
    {
      "time": 39.95,
      "time_str": "00:39.950",
      "text": "你曾说过 会永远爱我",
      "translation": null
    },
    {
      "time": 45.22,
      "time_str": "00:45.220",
      "text": "也许承诺 不过因为没把握 别用沉默",
      "translation": null
    },
    {
      "time": 54.5,
      "time_str": "00:54.500",
      "text": "再去掩饰什么 当结果是那么赤裸裸",
      "translation": null
    },
    {
      "time": 62.6,
      "time_str": "01:02.600",
      "text": "以为你会说什么 才会离开我",
      "translation": null
    },
    {
      "time": 68.35,
      "time_str": "01:08.350",
      "text": "你只是转过头 不看我",
      "translation": null
    },
    {
      "time": 74.38,
      "time_str": "01:14.380",
      "text": "不要刻意说 你还爱我",
      "translation": null
    },
    {
      "time": 86.37,
      "time_str": "01:26.370",
      "text": "当看尽潮起潮落 只要你记得我",
      "translation": null
    },
    {
      "time": 104.81,
      "time_str": "01:44.810",
      "text": "你曾说过 会永远爱我 也许承诺",
      "translation": null
    },
    {
      "time": 110.879,
      "time_str": "01:50.879",
      "text": "不过证明没把握 不用难过",
      "translation": null
    },
    {
      "time": 117.73,
      "time_str": "01:57.730",
      "text": "不用掩饰什么 当结果是那么赤裸裸",
      "translation": null
    },
    {
      "time": 126.9,
      "time_str": "02:06.900",
      "text": "其实不必说什么",
      "translation": null
    },
    {
      "time": 128.89,
      "time_str": "02:08.890",
      "text": "才能离开我 起码那些经过 属于我",
      "translation": null
    },
    {
      "time": 161.57,
      "time_str": "02:41.570",
      "text": "也许放弃 才能靠近你 不再见你",
      "translation": null
    },
    {
      "time": 168.97,
      "time_str": "02:48.970",
      "text": "你才会把我记起 时间累积",
      "translation": null
    },
    {
      "time": 176.329,
      "time_str": "02:56.329",
      "text": "这盛夏的果实 回忆里爱情的香气",
      "translation": null
    },
    {
      "time": 184.69,
      "time_str": "03:04.690",
      "text": "我以为不露痕迹 思念却满溢",
      "translation": null
    },
    {
      "time": 190.28,
      "time_str": "03:10.280",
      "text": "或许这代表了我的心",
      "translation": null
    },
    {
      "time": 196.86,
      "time_str": "03:16.860",
      "text": "不要刻意说 你还爱我",
      "translation": null
    },
    {
      "time": 208.59,
      "time_str": "03:28.590",
      "text": "当看尽潮起潮落 只要你记得我",
      "translation": null
    },
    {
      "time": 220.0,
      "time_str": "03:40.000",
      "text": "如果你会梦见我 请你再抱紧我",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "盛夏的果实 - 莫文蔚.lrc"
}