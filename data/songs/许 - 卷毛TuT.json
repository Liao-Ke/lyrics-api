  "lyrics": [
    {
      "time": 1.95,
      "time_str": "00:01.950",
      "text": "《许》",
      "translation": null
    },
    {
      "time": 3.37,
      "time_str": "00:03.370",
      "text": "星一问水",
      "translation": null
    },
    {
      "time": 8.93,
      "time_str": "00:08.930",
      "text": "后期：Jove",
      "translation": null
    },
    {
      "time": 23.04,
      "time_str": "00:23.040",
      "text": "这一别 未曾见",
      "translation": null
    },
    {
      "time": 25.69,
      "time_str": "00:25.690",
      "text": "满眼山花故人边",
      "translation": null
    },
    {
      "time": 28.65,
      "time_str": "00:28.650",
      "text": "三分泉 七分月",
      "translation": null
    },
    {
      "time": 31.49,
      "time_str": "00:31.490",
      "text": "用尽一生才忘却",
      "translation": null
    },
    {
      "time": 34.89,
      "time_str": "00:34.890",
      "text": "你是否 有在佛前",
      "translation": null
    },
    {
      "time": 37.61,
      "time_str": "00:37.610",
      "text": "许下一盏誓愿",
      "translation": null
    },
    {
      "time": 40.45,
      "time_str": "00:40.450",
      "text": "经一场大梦 今夕何年",
      "translation": null
    },
    {
      "time": 45.9,
      "time_str": "00:45.900",
      "text": "蹄音落 悲欢弦",
      "translation": null
    },
    {
      "time": 48.74,
      "time_str": "00:48.740",
      "text": "衣襟带花立山巅",
      "translation": null
    },
    {
      "time": 51.59,
      "time_str": "00:51.590",
      "text": "北风冽 吹作雪",
      "translation": null
    },
    {
      "time": 54.36,
      "time_str": "00:54.360",
      "text": "眉间月指山河天",
      "translation": null
    },
    {
      "time": 57.7,
      "time_str": "00:57.700",
      "text": "你是否 又在佛前",
      "translation": null
    },
    {
      "time": 60.54,
      "time_str": "01:00.540",
      "text": "许下一盏誓愿",
      "translation": null
    },
    {
      "time": 63.15,
      "time_str": "01:03.150",
      "text": "愿灯火万千 长明不灭",
      "translation": null
    },
    {
      "time": 68.63,
      "time_str": "01:08.630",
      "text": "我愿飞花向天涯",
      "translation": null
    },
    {
      "time": 71.6,
      "time_str": "01:11.600",
      "text": "予她红妆倾天下",
      "translation": null
    },
    {
      "time": 74.39,
      "time_str": "01:14.390",
      "text": "待我踏遍了风沙",
      "translation": null
    },
    {
      "time": 77.23,
      "time_str": "01:17.230",
      "text": "许她盛世中安家",
      "translation": null
    },
    {
      "time": 80.01,
      "time_str": "01:20.010",
      "text": "我愿落日天边撒",
      "translation": null
    },
    {
      "time": 83.09,
      "time_str": "01:23.090",
      "text": "与她照雪月风花",
      "translation": null
    },
    {
      "time": 85.87,
      "time_str": "01:25.870",
      "text": "拈这一朵蒹葭",
      "translation": null
    },
    {
      "time": 87.98,
      "time_str": "01:27.980",
      "text": "许几世繁华",
      "translation": null
    },
    {
