  "lyrics": [
    {
      "time": 16.03,
      "time_str": "00:16.030",
      "text": "没有花 这刹那被破坏吗",
      "translation": null
    },
    {
      "time": 22.97,
      "time_str": "00:22.970",
      "text": "无野火都会温暖吗",
      "translation": null
    },
    {
      "time": 27.86,
      "time_str": "00:27.860",
      "text": "无烟花一起庆祝好吗",
      "translation": null
    },
    {
      "time": 33.35,
      "time_str": "00:33.350",
      "text": "若爱恋 仿似戏剧那样假",
      "translation": null
    },
    {
      "time": 40.42,
      "time_str": "00:40.420",
      "text": "如布景一切都美化",
      "translation": null
    },
    {
      "time": 45.21,
      "time_str": "00:45.210",
      "text": "连相拥都参照主角吗",
      "translation": null
    },
    {
      "time": 51.25,
      "time_str": "00:51.250",
      "text": "你说我未能定时",
      "translation": null
    },
    {
      "time": 54.66,
      "time_str": "00:54.660",
      "text": "令你每天欢笑一次",
      "translation": null
    },
    {
      "time": 58.43,
      "time_str": "00:58.430",
      "text": "我没说出一句美丽台词",
      "translation": null
    },
    {
      "time": 62.35,
      "time_str": "01:02.350",
      "text": "是你心中一种缺陷定义",
      "translation": null
    },
    {
      "time": 66.52,
      "time_str": "01:06.520",
      "text": "流进了眼角里的刺",
      "translation": null
    },
    {
      "time": 69.66,
      "time_str": "01:09.660",
      "text": "为何不浪漫亦是罪名",
      "translation": null
    },
    {
      "time": 73.33,
      "time_str": "01:13.330",
      "text": "为何不轰烈是件坏事情",
      "translation": null
    },
    {
      "time": 77.17,
      "time_str": "01:17.170",
      "text": "从来未察觉我每个动作",
      "translation": null
    },
    {
      "time": 81.04,
      "time_str": "01:21.040",
      "text": "没有声 都有爱你的铁证",
      "translation": null
    },
    {
      "time": 84.96,
      "time_str": "01:24.960",
      "text": "为何苦不浪漫亦是罪名",
      "translation": null
    },
    {
      "time": 88.78,
      "time_str": "01:28.780",
      "text": "为何总等待着特别事情",
      "translation": null
    },
    {
      "time": 92.58,
      "time_str": "01:32.580",
      "text": "从来未察觉我语气动听",
      "translation": null
    },
    {
      "time": 96.48,
      "time_str": "01:36.480",
      "text": "在我呼吸声早已说明",
      "translation": null
    },
    {
      "time": 101.33,
      "time_str": "01:41.330",
      "text": "什么都会用一生保证",
      "translation": null
    },
    {
