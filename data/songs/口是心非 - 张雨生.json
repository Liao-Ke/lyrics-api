  "lyrics": [
    {
      "time": 65.0,
      "time_str": "01:05.000",
      "text": "口是心非 你深情的承诺",
      "translation": null
    },
    {
      "time": 69.5,
      "time_str": "01:09.500",
      "text": "都随着西风飘渺远走",
      "translation": null
    },
    {
      "time": 75.25,
      "time_str": "01:15.250",
      "text": "痴人梦话 我钟情的倚托",
      "translation": null
    },
    {
      "time": 79.07,
      "time_str": "01:19.070",
      "text": "就像枯萎凋零的花朵",
      "translation": null
    },
    {
      "time": 86.75,
      "time_str": "01:26.750",
      "text": "星火燎原 我热情的眼眸",
      "translation": null
    },
    {
      "time": 91.2,
      "time_str": "01:31.200",
      "text": "曾点亮最灿烂的天空",
      "translation": null
    },
    {
      "time": 96.69,
      "time_str": "01:36.690",
      "text": "晴天霹雳 你绝情的放手",
      "translation": null
    },
    {
      "time": 100.69,
      "time_str": "01:40.690",
      "text": "在我最需要你的时候",
      "translation": null
    },
    {
      "time": 105.65,
      "time_str": "01:45.650",
      "text": "于是爱恨交错人消瘦",
      "translation": null
    },
    {
      "time": 110.27,
      "time_str": "01:50.270",
      "text": "怕是怕这些苦没来由",
      "translation": null
    },
    {
      "time": 115.04,
      "time_str": "01:55.040",
      "text": "于是悲欢起落人静默",
      "translation": null
    },
    {
      "time": 119.95,
      "time_str": "01:59.950",
      "text": "等一等这些伤会自由",
      "translation": null
    },
    {
      "time": 124.66,
      "time_str": "02:04.660",
      "text": "于是爱恨交错人消瘦",
      "translation": null
