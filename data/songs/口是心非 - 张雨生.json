      "translation": null
    },
    {
      "time": 168.68,
      "time_str": "02:48.680",
      "text": "口是心非 你矫情的面容",
      "translation": null
    },
    {
      "time": 172.62,
      "time_str": "02:52.620",
      "text": "都烙印在心灵的角落",
      "translation": null
    },
    {
      "time": 178.22,
      "time_str": "02:58.220",
      "text": "无话可说 我纵情的结果",
      "translation": null
    },
    {
      "time": 182.29,
      "time_str": "03:02.290",
      "text": "就像残破光秃的山头",
      "translation": null
    },
    {
      "time": 188.17,
      "time_str": "03:08.170",
      "text": "浑然天成 我纯情的悸动",
      "translation": null
    },
    {
      "time": 191.86,
      "time_str": "03:11.860",
      "text": "曾奔放最滚烫的节奏",
      "translation": null
    },
    {
      "time": 197.73,
      "time_str": "03:17.730",
      "text": "不可收拾 你滥情的抛空",
      "translation": null
    },
    {
      "time": 201.48,
      "time_str": "03:21.480",
      "text": "所有晶莹剔透的感受",
      "translation": null
    },
    {
