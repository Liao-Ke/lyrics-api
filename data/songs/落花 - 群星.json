    {
      "time": 19.79,
      "time_str": "00:19.790",
      "text": "花开的时候最珍贵 花落了就枯萎",
      "translation": null
    },
    {
      "time": 28.51,
      "time_str": "00:28.510",
      "text": "错过了花期花怪谁 花需要人安慰",
      "translation": null
    },
    {
      "time": 42.449,
      "time_str": "00:42.449",
      "text": "一生要哭多少回 才能不流泪",
      "translation": null
    },
    {
      "time": 51.699,
      "time_str": "00:51.699",
      "text": "一生要流多少泪 才能不心碎",
      "translation": null
    },
    {
      "time": 59.759,
      "time_str": "00:59.759",
      "text": "我眼角眉梢的憔悴 没有人看得会",
      "translation": null
    },
    {
      "time": 68.599,
      "time_str": "01:08.599",
      "text": "当初的誓言太完美 像落花满天飞",
      "translation": null
    },
    {
      "time": 77.379,
      "time_str": "01:17.379",
      "text": "冷冷的夜里北风吹 找不到人安慰",
      "translation": null
    },
    {
      "time": 86.369,
      "time_str": "01:26.369",
      "text": "当初的誓言太完美 让相思化成灰",
      "translation": null
    },
    {
