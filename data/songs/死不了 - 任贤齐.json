  "lyrics": [
    {
      "time": 49.093,
      "time_str": "00:49.093",
      "text": "剖开胸膛 我让心在烈日底下烧",
      "translation": null
    },
    {
      "time": 55.41,
      "time_str": "00:55.410",
      "text": "烧成记号 记你的好永远别忘掉",
      "translation": null
    },
    {
      "time": 61.687,
      "time_str": "01:01.687",
      "text": "头破血流 也要护你到天涯海角",
      "translation": null
    },
    {
      "time": 68.05,
      "time_str": "01:08.050",
      "text": "爱一个字 我敢用一辈子来回报",
      "translation": null
    },
    {
      "time": 73.518,
      "time_str": "01:13.518",
      "text": "狂风吹 大海啸",
      "translation": null
    },
    {
      "time": 76.709,
      "time_str": "01:16.709",
      "text": "真心的人死不了",
      "translation": null
    },
    {
      "time": 79.842,
      "time_str": "01:19.842",
      "text": "地多大 天多高",
      "translation": null
    },
    {
      "time": 82.994,
      "time_str": "01:22.994",
      "text": "一生只换一声好",
      "translation": null
    },
    {
      "time": 86.168,
      "time_str": "01:26.168",
      "text": "痛快哭 痛快笑",
      "translation": null
    },
    {
      "time": 89.307,
      "time_str": "01:29.307",
      "text": "痛快的痛死不了",
      "translation": null
    },
    {
      "time": 92.512,
      "time_str": "01:32.512",
      "text": "这一生 这一秒",
      "translation": null
    },
    {
      "time": 95.616,
      "time_str": "01:35.616",
      "text": "我只要求你知道",
      "translation": null
    },
    {
      "time": 110.626,
      "time_str": "01:50.626",
      "text": "冰天雪地 我把冰水全往头上浇",
      "translation": null
    },
    {
      "time": 116.959,
      "time_str": "01:56.959",
      "text": "浇熄思念 最后一处温暖的怀抱",
      "translation": null
    },
    {
      "time": 123.293,
      "time_str": "02:03.293",
      "text": "你为了谁 宁愿让心变成了孤岛",
      "translation": null
