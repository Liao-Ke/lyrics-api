    },
    {
      "time": 47.48,
      "time_str": "00:47.480",
      "text": "哥哥你要把河过，先要对上妹妹的歌妹妹的歌",
      "translation": null
    },
    {
      "time": 62.18,
      "time_str": "01:02.180",
      "text": "不问花儿为谁开，不问蜂儿为谁落",
