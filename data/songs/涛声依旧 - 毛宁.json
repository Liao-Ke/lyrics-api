  "lyrics": [
    {
      "time": 28.489,
      "time_str": "00:28.489",
      "text": "带走一盏渔火 让他温暖我的双眼",
      "translation": null
    },
    {
      "time": 33.78,
      "time_str": "00:33.780",
      "text": "留下一段真情 让它停泊在枫桥边",
      "translation": null
    },
    {
      "time": 42.68,
      "time_str": "00:42.680",
      "text": "无助的我 已经疏远了那份情感",
      "translation": null
    },
    {
      "time": 49.68,
      "time_str": "00:49.680",
      "text": "许多年以后却发觉 又回到你面前",
      "translation": null
    },
    {
      "time": 64.67,
      "time_str": "01:04.670",
      "text": "留连的钟声 还在敲打我的无眠",
      "translation": null
    },
    {
      "time": 72.68,
      "time_str": "01:12.680",
      "text": "尘封的日子 始终不会是一片云烟",
      "translation": null
    },
    {
      "time": 80.68,
      "time_str": "01:20.680",
      "text": "久违的你 一定保存着那张笑脸",
      "translation": null
    },
    {
      "time": 87.68,
      "time_str": "01:27.680",
      "text": "许多年以后 能不能接受彼此的改变",
      "translation": null
    },
    {
      "time": 101.679,
      "time_str": "01:41.679",
      "text": "月落乌啼总是千年的风霜",
      "translation": null
    },
    {
      "time": 107.679,
      "time_str": "01:47.679",
      "text": "涛声依旧不见当初的夜晚",
      "translation": null
    },
    {
      "time": 115.679,
      "time_str": "01:55.679",
      "text": "今天的你我 怎样重复昨天的故事",
      "translation": null
    },
    {
      "time": 122.68,
      "time_str": "02:02.680",
      "text": "这一张旧船票 能否登上你的客船",
      "translation": null
    },
    {
