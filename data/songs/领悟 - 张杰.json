  "lyrics": [
    {
      "time": 6.33,
      "time_str": "00:06.330",
      "text": "我以为我会哭 但是我没有",
      "translation": null
    },
    {
      "time": 14.33,
      "time_str": "00:14.330",
      "text": "我只是怔怔望着你的脚步",
      "translation": null
    },
    {
      "time": 17.41,
      "time_str": "00:17.410",
      "text": "给你我最后的祝福",
      "translation": null
    },
    {
      "time": 23.08,
      "time_str": "00:23.080",
      "text": "这何尝不是一种领悟",
      "translation": null
    },
    {
      "time": 27.8,
      "time_str": "00:27.800",
      "text": "让我把自己看清楚",
      "translation": null
    },
    {
      "time": 30.7,
      "time_str": "00:30.700",
      "text": "虽然那无爱的痛苦",
      "translation": null
    },
    {
      "time": 33.18,
      "time_str": "00:33.180",
      "text": "将日日夜夜 在我灵魂最深处",
      "translation": null
    },
    {
      "time": 42.49,
      "time_str": "00:42.490",
      "text": "我以为我会报复 但是我没有",
      "translation": null
    },
    {
      "time": 49.7,
      "time_str": "00:49.700",
      "text": "当我看到我深爱过的女人",
      "translation": null
    },
    {
      "time": 53.12,
      "time_str": "00:53.120",
      "text": "竟然像孩子一样无助",
      "translation": null
    },
    {
      "time": 59.1,
      "time_str": "00:59.100",
      "text": "这何尝不是一种领悟",
      "translation": null
    },
    {
      "time": 63.09,
      "time_str": "01:03.090",
      "text": "让你把自己看清楚",
      "translation": null
    },
    {
      "time": 66.83,
      "time_str": "01:06.830",
      "text": "被爱是奢侈的幸福",
      "translation": null
    },
    {
      "time": 69.45,
      "time_str": "01:09.450",
      "text": "可惜你从来不在乎",
      "translation": null
    },
    {
      "time": 74.78,
      "time_str": "01:14.780",
      "text": "啊!一段感情就此结束",
      "translation": null
    },
    {
      "time": 83.22,
      "time_str": "01:23.220",
      "text": "啊!一颗心眼看要荒芜",
      "translation": null
    },
    {
      "time": 90.47,
      "time_str": "01:30.470",
      "text": "我们的爱若是错误",
      "translation": null
    },
    {
      "time": 95.2,
      "time_str": "01:35.200",
      "text": "愿你我没有白白受苦",
      "translation": null
    },
    {
      "time": 98.89,
      "time_str": "01:38.890",
      "text": "若曾真心真意付出 就应该满足",
      "translation": null
    },
    {
      "time": 106.34,
      "time_str": "01:46.340",
      "text": "啊!多么痛的领悟 你曾是我的全部",
      "translation": null
    },
    {
      "time": 114.21,
      "time_str": "01:54.210",
      "text": "只是我回首来时路的每一步",
      "translation": null
    },
    {
      "time": 119.31,
      "time_str": "01:59.310",
      "text": "都走的好孤独",
      "translation": null
    },
    {
      "time": 122.25,
      "time_str": "02:02.250",
      "text": "啊!多么痛的领悟 你曾是我的全部",
      "translation": null
    },
    {
      "time": 130.1,
      "time_str": "02:10.100",
      "text": "只愿你挣脱情的枷锁",
      "translation": null
    },
    {
      "time": 133.36,
      "time_str": "02:13.360",
      "text": "爱的束缚 任意追逐",
