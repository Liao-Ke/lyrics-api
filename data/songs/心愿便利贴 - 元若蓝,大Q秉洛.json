    {
      "time": 21.199,
      "time_str": "00:21.199",
      "text": "一天一天贴近你的心 你开心 我关心",
      "translation": null
    },
    {
      "time": 30.789,
      "time_str": "00:30.789",
      "text": "一点一滴我都能感应 你是我 最美的相信",
      "translation": null
    },
    {
      "time": 39.417,
      "time_str": "00:39.417",
      "text": "等不到 双子座 流星雨 洒满天际",
      "translation": null
    },
    {
      "time": 44.277,
      "time_str": "00:44.277",
      "text": "先点燃 九支仙女棒 代替",
      "translation": null
    },
    {
      "time": 49.688,
      "time_str": "00:49.688",
      "text": "最灿烂 不一定 要许多 钻石黄金",
      "translation": null
    },
    {
      "time": 53.887,
      "time_str": "00:53.887",
      "text": "看你眼睛 有幸福的倒影",
      "translation": null
    },
    {
      "time": 58.585,
      "time_str": "00:58.585",
      "text": "把你的讨厌 宅急便 送到天边",
      "translation": null
    },
    {
      "time": 63.887,
      "time_str": "01:03.887",
      "text": "平凡的傻事 用了心 变成经典",
      "translation": null
    },
    {
      "time": 68.608,
      "time_str": "01:08.608",
      "text": "存满满的心愿 便利贴 贴成无限",
      "translation": null
    },
    {
      "time": 73.847,
      "time_str": "01:13.847",
      "text": "就是我们 最富有的宣言",
      "translation": null
    },
    {
      "time": 78.909,
      "time_str": "01:18.909",
      "text": "把你的喜欢 每一天 复习两遍",
      "translation": null
    },
    {
      "time": 85.298,
      "time_str": "01:25.298",
      "text": "惊喜的预言 我的天 通通应验",
      "translation": null
    },
    {
      "time": 90.138,
      "time_str": "01:30.138",
      "text": "你和我的心愿 便利贴 贴心里面",
      "translation": null
