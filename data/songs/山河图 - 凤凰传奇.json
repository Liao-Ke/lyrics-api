  },
  "lyrics": [
    {
      "time": 24.94,
      "time_str": "00:24.940",
      "text": "看这山   万壑千岩  连一川又一川",
      "translation": null
    },
    {
      "time": 27.77,
      "time_str": "00:27.770",
      "text": "让这河   星奔川鹜  结一湾又一湾",
      "translation": null
    },
    {
      "time": 30.91,
      "time_str": "00:30.910",
      "text": "谱这图   鸾回凤舞  重峦高不可攀",
      "translation": null
    },
    {
      "time": 34.09,
      "time_str": "00:34.090",
      "text": "泼了墨   墨饱笔酣  润我锦绣河山",
      "translation": null
    },
    {
      "time": 37.31,
      "time_str": "00:37.310",
      "text": "任他八千里路云和月 男子汉 都往前站",
      "translation": null
    },
    {
      "time": 40.28,
      "time_str": "00:40.280",
      "text": "我们翻过那三山和五岳 也依然要往前看",
      "translation": null
    },
    {
      "time": 43.44,
      "time_str": "00:43.440",
      "text": "我们走遍了五湖四海  从来不言苦和难",
      "translation": null
    },
    {
      "time": 46.57,
      "time_str": "00:46.570",
      "text": "不管披星戴月 大好河山  常与我作伴",
      "translation": null
    },
    {
      "time": 49.81,
      "time_str": "00:49.810",
      "text": "到最高点 日喀则 矗立喜马拉雅巅",
      "translation": null
    },
    {
      "time": 52.97,
      "time_str": "00:52.970",
      "text": "到最东边 下大雪 大雪飘在漠河边",
      "translation": null
    },
    {
      "time": 56.06,
      "time_str": "00:56.060",
      "text": "到最西边 忆狼烟 风在喀什转个圈",
      "translation": null
    },
    {
      "time": 59.21,
      "time_str": "00:59.210",
      "text": "到最南边  碧海天  龙腾出海浪滔天",
      "translation": null
    },
    {
      "time": 63.37,
      "time_str": "01:03.370",
      "text": "挥毫提笔画我山河",
      "translation": null
    },
    {
      "time": 66.16,
      "time_str": "01:06.160",
      "text": "剑锋千轫画这巍峨",
      "translation": null
    },
    {
      "time": 69.36,
      "time_str": "01:09.360",
      "text": "滔滔江水走笔龙蛇",
      "translation": null
    },
    {
      "time": 72.57,
      "time_str": "01:12.570",
      "text": "我丹青不渝画我中国",
      "translation": null
    },
    {
      "time": 75.87,
      "time_str": "01:15.870",
      "text": "让我心中装秦汉  梦回大唐画牡丹",
      "translation": null
    },
    {
      "time": 78.88,
      "time_str": "01:18.880",
      "text": "银钩铁画未抹淡  我勾勒出壮丽河山",
      "translation": null
    },
    {
      "time": 82.0,
      "time_str": "01:22.000",
      "text": "峨眉山 昆仑山   英雄们论剑在华山",
      "translation": null
    },
    {
      "time": 85.26,
      "time_str": "01:25.260",
      "text": "长白山 太行山   泰山端沧海任我观",
      "translation": null
    },
    {
      "time": 88.51,
      "time_str": "01:28.510",
      "text": "松花澜沧珠江 哎！   鄱阳洞庭太湖 哎！",
      "translation": null
    },
    {
      "time": 91.6,
      "time_str": "01:31.600",
      "text": "雅鲁藏布最高位      河奔海聚世世辈",
      "translation": null
    },
    {
      "time": 94.75,
      "time_str": "01:34.750",
      "text": "长江头到长江尾      兄弟共饮长江水",
      "translation": null
    },
    {
      "time": 97.88,
      "time_str": "01:37.880",
      "text": "黄河南到黄河北      华夏儿女那么美",
      "translation": null
    },
    {
      "time": 101.1,
      "time_str": "01:41.100",
      "text": "想飞回草原在那月光下面弹琴",
      "translation": null
    },
    {
      "time": 104.2,
      "time_str": "01:44.200",
      "text": "身藏于大漠敦煌舞动我的金翎",
      "translation": null
    },
    {
      "time": 107.27,
      "time_str": "01:47.270",
      "text": "盘栖在云南大理最神秘的山林",
      "translation": null
    },
    {
      "time": 110.52,
      "time_str": "01:50.520",
      "text": "你看那凤凰终将飞出一个传奇",
      "translation": null
    },
    {
      "time": 113.97,
      "time_str": "01:53.970",
      "text": "挥毫提笔画我山河",
      "translation": null
    },
    {
      "time": 116.93,
      "time_str": "01:56.930",
      "text": "剑锋千轫画这巍峨",
      "translation": null
    },
    {
      "time": 120.13,
      "time_str": "02:00.130",
      "text": "滔滔江水走笔龙蛇",
      "translation": null
    },
    {
      "time": 123.19,
      "time_str": "02:03.190",
      "text": "我丹青不渝画我中国",
      "translation": null
    },
    {
      "time": 133.49,
      "time_str": "02:13.490",
      "text": "唐寅伯驹公望山人希梦   铺长卷",
      "translation": null
    },
    {
      "time": 135.75,
      "time_str": "02:15.750",
      "text": "屈原太白杜甫苏轼陆游   诗百篇",
      "translation": null
    },
    {
      "time": 138.95,
      "time_str": "02:18.950",
      "text": "你看这大江大河生生不息 多少年",
      "translation": null
    },
    {
      "time": 142.17,
      "time_str": "02:22.170",
      "text": "你看这巍巍青山浩然之气 天地间",
      "translation": null
    },
    {
      "time": 145.53,
      "time_str": "02:25.530",
      "text": "打开一副山河图     唐宗宋祖来带路",
      "translation": null
    },
    {
      "time": 148.68,
      "time_str": "02:28.680",
      "text": "打开一副山河图     千年渺沧海一粟",
      "translation": null
    },
    {
      "time": 152.07,
      "time_str": "02:32.070",
      "text": "打开一副山河图     兄弟姐妹跳起舞",
      "translation": null
    },
    {
      "time": 154.94,
      "time_str": "02:34.940",
      "text": "打开一副山河图     百鸟朝凤龙起舞",
      "translation": null
    },
