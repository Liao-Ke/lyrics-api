  "lyrics": [
    {
      "time": 21.98,
      "time_str": "00:21.980",
      "text": "昨晚下过雨后操场的湿气很重",
      "translation": null
    },
    {
      "time": 24.87,
      "time_str": "00:24.870",
      "text": "篮球上的水滴也没有干过",
      "translation": null
    },
    {
      "time": 26.54,
      "time_str": "00:26.540",
      "text": "雨水流过的泥土味道很浓厚",
      "translation": null
    },
    {
      "time": 29.06,
      "time_str": "00:29.060",
      "text": "操场的青草香不时飘到我梦中",
      "translation": null
    },
    {
      "time": 31.17,
      "time_str": "00:31.170",
      "text": "上上上上课的时候稚气的脸孔",
      "translation": null
    },
    {
      "time": 33.59,
      "time_str": "00:33.590",
      "text": "还在想那颗球怎么老是投不中",
      "translation": null
    },
    {
      "time": 36.02,
      "time_str": "00:36.020",
      "text": "最后十分钟大家开始倒数",
      "translation": null
    },
    {
      "time": 38.79,
      "time_str": "00:38.790",
      "text": "比赛谁先冲到福利社",
      "translation": null
    },
    {
      "time": 41.15,
      "time_str": "00:41.150",
      "text": "怎么停留回忆总是出现在",
      "translation": null
    },
    {
      "time": 44.24,
      "time_str": "00:44.240",
      "text": "我想起之后",
      "translation": null
    },
    {
      "time": 45.99,
      "time_str": "00:45.990",
      "text": "这样稚气的面容现在还有没有",
      "translation": null
    },
    {
      "time": 50.77,
      "time_str": "00:50.770",
      "text": "怎么重播如此念旧的镜头",
      "translation": null
    },
    {
      "time": 53.82,
      "time_str": "00:53.820",
      "text": "在离开之后",
      "translation": null
    },
    {
      "time": 55.5,
      "time_str": "00:55.500",
      "text": "场景人物画面时空都还没变过",
      "translation": null
    },
    {
      "time": 69.76,
      "time_str": "01:09.760",
      "text": "校门外卖吧噗的老伯",
      "translation": null
    },
    {
      "time": 71.71,
      "time_str": "01:11.710",
      "text": "那胡须越长越多",
      "translation": null
    },
    {
      "time": 72.95,
      "time_str": "01:12.950",
      "text": "放学后篮球场上",
      "translation": null
    },
    {
      "time": 74.24,
      "time_str": "01:14.240",
      "text": "只剩我留到最后",
      "translation": null
    },
    {
      "time": 75.36,
      "time_str": "01:15.360",
      "text": "苦练再苦练",
      "translation": null
    },
    {
      "time": 76.36,
      "time_str": "01:16.360",
      "text": "经过女生看不见",
      "translation": null
    },
    {
      "time": 77.66,
      "time_str": "01:17.660",
      "text": "先别想那么多",
      "translation": null
    },
    {
      "time": 78.82,
      "time_str": "01:18.820",
      "text": "反正选不上我",
      "translation": null
    },
    {
      "time": 80.16,
      "time_str": "01:20.160",
      "text": "趁手上白色的吧噗",
      "translation": null
    },
    {
      "time": 81.44,
      "time_str": "01:21.440",
      "text": "还没溶化的时候",
      "translation": null
    },
    {
      "time": 82.71,
      "time_str": "01:22.710",
      "text": "悄悄跟在她背后",
      "translation": null
    },
    {
      "time": 84.0,
      "time_str": "01:24.000",
      "text": "希望那上帝保佑",
      "translation": null
    },
    {
      "time": 85.15,
      "time_str": "01:25.150",
      "text": "劝自己别再孬种",
      "translation": null
    },
    {
      "time": 86.31,
      "time_str": "01:26.310",
      "text": "买了三年香草吧噗",
      "translation": null
    },
    {
      "time": 87.45,
      "time_str": "01:27.450",
      "text": "吧吧吧吧吧噗",
      "translation": null
    },
    {
      "time": 88.63,
      "time_str": "01:28.630",
      "text": "也该送到她手中",
      "translation": null
    },
    {
      "time": 89.81,
      "time_str": "01:29.810",
      "text": "刷刷牙 洗脸后",
      "translation": null
    },
    {
      "time": 91.05,
      "time_str": "01:31.050",
      "text": "早餐从来没吃过",
      "translation": null
    },
    {
      "time": 92.24,
      "time_str": "01:32.240",
      "text": "隔壁巷子的女孩已经出发",
      "translation": null
    },
    {
      "time": 94.5,
      "time_str": "01:34.500",
      "text": "再晚点就来不及假装经过",
      "translation": null
    },
    {
      "time": 96.34,
      "time_str": "01:36.340",
      "text": "进教室在升旗过后 打手心",
      "translation": null
    },
    {
      "time": 97.97,
      "time_str": "01:37.970",
      "text": "还好还好",
      "translation": null
    },
    {
      "time": 99.54,
      "time_str": "01:39.540",
      "text": "啦啦啦啦啦",
      "translation": null
    },
