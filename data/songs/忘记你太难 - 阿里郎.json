    {
      "time": 20.54,
      "time_str": "00:20.540",
      "text": "当我转身倔强离开的时候",
      "translation": null
    },
    {
      "time": 24.75,
      "time_str": "00:24.750",
      "text": "没能预见以后多难受",
      "translation": null
    },
    {
      "time": 29.34,
      "time_str": "00:29.340",
      "text": "以为天空海阔可以找回自由",
      "translation": null
    },
    {
      "time": 34.0,
      "time_str": "00:34.000",
      "text": "现实总叫人留下伤口",
      "translation": null
    },
    {
      "time": 38.54,
      "time_str": "00:38.540",
      "text": "就在此刻不经意去想你的夜晚",
      "translation": null
    },
    {
      "time": 43.19,
      "time_str": "00:43.190",
      "text": "失去牵挂的人心好乱",
      "translation": null
    },
    {
      "time": 47.93,
      "time_str": "00:47.930",
      "text": "落入前尘往事眼泪反复纠缠",
      "translation": null
    },
    {
      "time": 52.64,
      "time_str": "00:52.640",
      "text": "我的回忆有你剪不断",
      "translation": null
    },
    {
      "time": 57.01,
      "time_str": "00:57.010",
      "text": "忘记你太难 想爱你太晚",
      "translation": null
    },
    {
      "time": 61.93,
      "time_str": "01:01.930",
      "text": "我的生命留下遗憾",
      "translation": null
    },
    {
