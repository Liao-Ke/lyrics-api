    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "出品人 : 刘健/钱彤",
      "translation": null
    },
    {
      "time": 32.44,
      "time_str": "00:32.440",
      "text": "在 银河流转 岁月沉淀",
      "translation": null
    },
    {
      "time": 36.02,
      "time_str": "00:36.020",
      "text": "有 巍峨山川 屹立千年",
      "translation": null
    },
    {
      "time": 39.61,
      "time_str": "00:39.610",
      "text": "看 峦峰夜幕 星火点点",
      "translation": null
    },
    {
      "time": 43.25,
      "time_str": "00:43.250",
      "text": "轻轻点燃了信念",
      "translation": null
    },
    {
      "time": 46.94,
      "time_str": "00:46.940",
      "text": "沿 无尽黑夜 探索方向",
      "translation": null
    },
    {
      "time": 50.44,
      "time_str": "00:50.440",
      "text": "在 无际荒芜 拥抱希望",
      "translation": null
    },
    {
      "time": 54.05,
      "time_str": "00:54.050",
      "text": "山遥路远 道阻且长",
      "translation": null
    },
    {
      "time": 57.7,
      "time_str": "00:57.700",
      "text": "内心从未彷徨",
      "translation": null
    },
    {
      "time": 62.97,
      "time_str": "01:02.970",
      "text": "采一缕清风携手同往",
      "translation": null
    },
    {
      "time": 66.41,
      "time_str": "01:06.410",
      "text": "寻一道曙光照亮信仰",
      "translation": null
    },
    {
      "time": 70.18,
      "time_str": "01:10.180",
      "text": "无惧风浪逐光飞翔",
      "translation": null
    },
    {
      "time": 73.51,
      "time_str": "01:13.510",
      "text": "举目眺望 远方晴朗",
      "translation": null
    },
    {
      "time": 77.11,
      "time_str": "01:17.110",
      "text": "听风起潮又落勾勒沧海",
      "translation": null
    },
    {
      "time": 80.75,
      "time_str": "01:20.750",
      "text": "目光所至 春潮澎湃",
      "translation": null
    },
    {
      "time": 84.35,
      "time_str": "01:24.350",
      "text": "奔赴山与海 流淌在血脉",
      "translation": null
    },
    {
      "time": 88.43,
      "time_str": "01:28.430",
      "text": "征途向未来",
      "translation": null
    },
