  "lyrics": [
    {
      "time": 27.62,
      "time_str": "00:27.620",
      "text": "泪有点咸有点甜",
      "translation": null
    },
    {
      "time": 31.11,
      "time_str": "00:31.110",
      "text": "你的胸膛吻着我的侧脸",
      "translation": null
    },
    {
      "time": 35.63,
      "time_str": "00:35.630",
      "text": "回头看踏过的雪 慢慢融化成草原",
      "translation": null
    },
    {
      "time": 42.38,
      "time_str": "00:42.380",
      "text": "而我就像你没有一秒曾后悔",
      "translation": null
    },
    {
      "time": 51.68,
      "time_str": "00:51.680",
      "text": "爱那么绵那么粘",
      "translation": null
    },
    {
      "time": 55.29,
      "time_str": "00:55.290",
      "text": "管命运设定要谁离别",
      "translation": null
    },
    {
      "time": 59.37,
      "time_str": "00:59.370",
      "text": "海岸线越让人流连 总是美得越蜿蜒",
      "translation": null
    },
    {
      "time": 66.55,
      "time_str": "01:06.550",
      "text": "我们太倔强 连天都不忍 再反对",
      "translation": null
    },
    {
      "time": 74.78,
      "time_str": "01:14.780",
      "text": "深情一眼挚爱万年 几度轮回恋恋不灭",
      "translation": null
    },
    {
      "time": 82.89,
      "time_str": "01:22.890",
      "text": "把岁月铺成红毯 见证我们的极限",
      "translation": null
    },
    {
      "time": 90.48,
      "time_str": "01:30.480",
      "text": "心疼一句珍藏万年 誓言就该比永远更远",
      "translation": null
    },
    {
      "time": 98.87,
      "time_str": "01:38.870",
      "text": "要不是沧海桑田 真爱怎么会浮现",
      "translation": null
