      "time": 13.271,
      "time_str": "00:13.271",
      "text": "戚琦（念白）：",
      "translation": null
    },
    {
      "time": 13.554,
      "time_str": "00:13.554",
      "text": "绝世舞姬",
      "translation": null
    },
    {
      "time": 15.57,
      "time_str": "00:15.570",
      "text": "天下先",
      "translation": null
    },
    {
      "time": 23.05,
      "time_str": "00:23.050",
      "text": "张晓涵：",
      "translation": null
    },
    {
      "time": 23.284,
      "time_str": "00:23.284",
      "text": "烽烟燃起 乱风华",
      "translation": null
    },
    {
      "time": 26.384,
      "time_str": "00:26.384",
      "text": "胭脂落泪 染红霞",
      "translation": null
    },
    {
      "time": 29.27,
      "time_str": "00:29.270",
      "text": "眉目如画 宜其室家",
      "translation": null
    },
    {
      "time": 31.742,
      "time_str": "00:31.742",
      "text": "说陪我浪迹天涯 都作假",
      "translation": null
    },
    {
      "time": 34.384,
      "time_str": "00:34.384",
      "text": "心死就在 那一刹",
      "translation": null
    },
    {
      "time": 37.004,
      "time_str": "00:37.004",
      "text": "世间安得 双全法",
      "translation": null
    },
    {
      "time": 39.604,
      "time_str": "00:39.604",
      "text": "眸中无他 便无冬夏",
      "translation": null
    },
    {
      "time": 42.411,
      "time_str": "00:42.411",
      "text": "君临天下",
      "translation": null
    },
    {
      "time": 43.119,
      "time_str": "00:43.119",
      "text": "也只能道一声 寡",
      "translation": null
    },
    {
      "time": 44.989,
      "time_str": "00:44.989",
      "text": "若我一舞断杀伐",
      "translation": null
    },
    {
      "time": 47.739,
      "time_str": "00:47.739",
      "text": "兵临城下万箭发",
      "translation": null
    },
    {
      "time": 50.337,
      "time_str": "00:50.337",
      "text": "若我一舞定天下",
      "translation": null
    },
    {
      "time": 52.769,
      "time_str": "00:52.769",
      "text": "在你方寸棋盘倒也罢",
      "translation": null
    },
    {
      "time": 58.9,
      "time_str": "00:58.900",
      "text": "戚琦（戏腔）：",
      "translation": null
    },
    {
      "time": 59.138,
      "time_str": "00:59.138",
      "text": "啊~~~",
      "translation": null
    },
    {
      "time": 60.852,
      "time_str": "01:00.852",
      "text": "美人舞如莲花旋",
      "translation": null
    },
    {
      "time": 63.518,
      "time_str": "01:03.518",
      "text": "世人见之惊且叹",
      "translation": null
