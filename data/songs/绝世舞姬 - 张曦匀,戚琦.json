    {
      "time": 66.183,
      "time_str": "01:06.183",
      "text": "一曲终了与君断",
      "translation": null
    },
    {
      "time": 68.811,
      "time_str": "01:08.811",
      "text": "绝世舞姬天下先",
      "translation": null
    },
    {
