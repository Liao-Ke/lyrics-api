    {
      "time": 2.53,
      "time_str": "00:02.530",
      "text": "制作：瞬心文化",
      "translation": null
    },
    {
      "time": 6.84,
      "time_str": "00:06.840",
      "text": "策划/统筹：子木",
      "translation": null
    },
    {
      "time": 8.99,
      "time_str": "00:08.990",
      "text": "演唱：卷毛TuT",
      "translation": null
    },
    {
      "time": 11.32,
      "time_str": "00:11.320",
      "text": "作曲/编曲：钮丞",
      "translation": null
    },
    {
      "time": 22.34,
      "time_str": "00:22.340",
      "text": "可见过 那个少年",
      "translation": null
    },
    {
      "time": 26.76,
      "time_str": "00:26.760",
      "text": "他拥有 剔透的 一双眼",
      "translation": null
    },
    {
      "time": 31.8,
      "time_str": "00:31.800",
      "text": "望着你 你就有全世界",
      "translation": null
    },
    {
      "time": 59.11,
      "time_str": "00:59.110",
      "text": "某一天 一只蝴蝶",
      "translation": null
    },
    {
      "time": 63.32,
      "time_str": "01:03.320",
      "text": "从窗边 振翅到 谁指尖",
      "translation": null
    },
    {
      "time": 68.42,
      "time_str": "01:08.420",
      "text": "牵动着 不可说的心弦",
      "translation": null
    },
    {
      "time": 75.67,
      "time_str": "01:15.670",
      "text": "就看着他 敢于逐鹿 心如旷野",
      "translation": null
    },
    {
      "time": 80.78,
      "time_str": "01:20.780",
      "text": "埋伏着的 黑色云层 竟会妥协",
      "translation": null
    },
    {
      "time": 86.11,
      "time_str": "01:26.110",
      "text": "少年就算 落泪也是 最热烈",
      "translation": null
    },
    {
      "time": 93.28,
      "time_str": "01:33.280",
      "text": "就要在顶峰相见",
      "translation": null
    },
    {
      "time": 98.53,
      "time_str": "01:38.530",
      "text": "因为天光 会乍现",
      "translation": null
    },
    {
      "time": 103.13,
      "time_str": "01:43.130",
      "text": "我们始终 不负遇见",
      "translation": null
    },
    {
      "time": 108.22,
      "time_str": "01:48.220",
      "text": "就算 失了翼 也要飞 过长夜",
      "translation": null
    },
    {
      "time": 116.96,
      "time_str": "01:56.960",
      "text": "如果如果 有明天",
      "translation": null
    },
    {
      "time": 121.42,
      "time_str": "02:01.420",
      "text": "明天你 一定会出现",
      "translation": null
    },
    {
      "time": 125.99,
      "time_str": "02:05.990",
      "text": "最重要的",
      "translation": null
    },
    {
      "time": 129.48,
      "time_str": "02:09.480",
      "text": "在身边就是永远",
      "translation": null
    },
    {
      "time": 155.36,
      "time_str": "02:35.360",
      "text": "某一天 一只蝴蝶",
      "translation": null
    },
    {
      "time": 159.31,
      "time_str": "02:39.310",
      "text": "从窗边 振翅到 谁指尖",
      "translation": null
    },
    {
      "time": 164.13,
      "time_str": "02:44.130",
      "text": "一瞬间 恍然已经深陷",
      "translation": null
    },
    {
      "time": 171.61,
      "time_str": "02:51.610",
      "text": "就看着他 光芒万千 不惧流言",
      "translation": null
    },
    {
      "time": 176.84,
      "time_str": "02:56.840",
      "text": "从未囿于 某座迷城 无声向前",
      "translation": null
    },
    {
      "time": 182.39,
      "time_str": "03:02.390",
      "text": "凛冽的风 未能席卷 他的眼",
      "translation": null
    },
    {
      "time": 189.2,
      "time_str": "03:09.200",
      "text": "竟只敢为他加冕",
      "translation": null
    },
    {
      "time": 194.5,
      "time_str": "03:14.500",
      "text": "因为天光 会乍现",
      "translation": null
    },
    {
      "time": 199.13,
      "time_str": "03:19.130",
      "text": "我们始终 不负遇见",
      "translation": null
    },
    {
      "time": 204.13,
      "time_str": "03:24.130",
      "text": "就算 失了翼 也要飞 过长夜",
      "translation": null
    },
    {
      "time": 212.82,
      "time_str": "03:32.820",
      "text": "最亮的星 在眼前",
      "translation": null
    },
    {
      "time": 217.36,
      "time_str": "03:37.360",
      "text": "经年后 依旧被惊艳",
      "translation": null
    },
    {
      "time": 222.01,
      "time_str": "03:42.010",
      "text": "你知道的",
      "translation": null
    },
    {
      "time": 225.74,
      "time_str": "03:45.740",
      "text": "爱不会败给时间",
      "translation": null
    },
    {
