  },
  "lyrics": [
    {
      "time": 22.08,
      "time_str": "00:22.080",
      "text": "不知道在那天边可会有尽头",
      "translation": null
    },
    {
      "time": 27.3,
      "time_str": "00:27.300",
      "text": "只知道逝去光阴不会再回头",
      "translation": null
    },
    {
      "time": 33.69,
      "time_str": "00:33.690",
      "text": "每一串泪水伴每一个梦想",
      "translation": null
    },
    {
      "time": 39.26,
      "time_str": "00:39.260",
      "text": "不知不觉全溜走",
      "translation": null
    },
    {
      "time": 44.32,
      "time_str": "00:44.32",
      "text": "不经意在这圈中转到这年头",
      "translation": null
    },
    {
      "time": 50.01,
      "time_str": "00:50.01",
      "text": "只感到在这圈中经过顺逆流",
      "translation": null
    },
    {
      "time": 56.11,
      "time_str": "00:56.11",
      "text": "每颗冷酷眼光 共每声友善笑声",
      "translation": null
    },
    {
      "time": 61.83,
      "time_str": "01:01.83",
      "text": "默然一一尝透",
      "translation": null
    },
    {
      "time": 67.77,
      "time_str": "01:07.77",
      "text": "几多艰苦当天我默默接受",
      "translation": null
    },
    {
      "time": 73.1,
      "time_str": "01:13.10",
      "text": "几多辛酸也未放手",
      "translation": null
    },
    {
      "time": 78.88,
      "time_str": "01:18.88",
      "text": "故意挑剔今天我不在乎",
      "translation": null
    },
    {
      "time": 84.32,
      "time_str": "01:24.32",
      "text": "只跟心中意愿去走",
      "translation": null
    },
    {
      "time": 89.62,
      "time_str": "01:29.62",
      "text": "不信未作牺牲竟先可拥有",
      "translation": null
    },
    {
      "time": 95.15,
      "time_str": "01:35.15",
      "text": "只相信是靠双手找到我欲求",
      "translation": null
    },
    {
      "time": 101.4,
      "time_str": "01:41.40",
      "text": "每一串汗水换每一个成就",
      "translation": null
    },
    {
      "time": 107.21,
      "time_str": "01:47.21",
      "text": "从来得失我睇透",
      "translation": null
    },
    {
