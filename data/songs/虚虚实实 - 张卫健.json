  "lyrics": [
    {
      "time": 23.62,
      "time_str": "00:23.620",
      "text": "假如我可以再生",
      "translation": null
    },
    {
      "time": 26.81,
      "time_str": "00:26.810",
      "text": "像太极为两仪而生",
      "translation": null
    },
    {
      "time": 30.25,
      "time_str": "00:30.250",
      "text": "动静之间如行云流水",
      "translation": null
    },
    {
      "time": 33.78,
      "time_str": "00:33.780",
      "text": "追一个豁达的眼神",
      "translation": null
    },
    {
      "time": 38.19,
      "time_str": "00:38.190",
      "text": "任膨湃巨力来打我",
      "translation": null
    },
    {
      "time": 42.1,
      "time_str": "00:42.100",
      "text": "牵动我四两拨千斤",
      "translation": null
    },
    {
      "time": 44.75,
      "time_str": "00:44.750",
      "text": "以弱可胜强",
      "translation": null
    },
    {
      "time": 47.63,
      "time_str": "00:47.630",
      "text": "后发可先至",
      "translation": null
    },
    {
      "time": 49.39,
      "time_str": "00:49.390",
      "text": "天大地大博大精深",
      "translation": null
    },
    {
      "time": 53.38,
      "time_str": "00:53.380",
      "text": "在虚虚在实实 神会中",
      "translation": null
    },
    {
      "time": 55.95,
      "time_str": "00:55.950",
      "text": "虚守实发掌中穷",
      "translation": null
    },
    {
      "time": 57.89,
      "time_str": "00:57.890",
      "text": "来势凶不为动",
      "translation": null
    },
    {
      "time": 59.78,
      "time_str": "00:59.780",
      "text": "所向无敌真英雄",
      "translation": null
    },
    {
      "time": 62.55,
      "time_str": "01:02.550",
      "text": "随心行动",
      "translation": null
    },
    {
      "time": 65.09,
      "time_str": "01:05.090",
      "text": "心底我是这样的人",
      "translation": null
    },
    {
      "time": 68.06,
      "time_str": "01:08.060",
      "text": "在虚虚在实实 现实中",
      "translation": null
    },
    {
      "time": 70.87,
      "time_str": "01:10.870",
      "text": "爱与不爱都很难",
      "translation": null
    },
    {
      "time": 72.65,
      "time_str": "01:12.650",
      "text": "伤依然那么深",
      "translation": null
    },
    {
      "time": 74.74,
      "time_str": "01:14.740",
      "text": "每一条路的尽头",
      "translation": null
    },
    {
      "time": 78.1,
      "time_str": "01:18.100",
      "text": "是一个人",
      "translation": null
    },
    {
      "time": 79.31,
      "time_str": "01:19.310",
      "text": "看不透世上的真",
      "translation": null
    },
    {
      "time": 83.12,
      "time_str": "01:23.120",
      "text": "你还是这样天真",
      "translation": null
    },
