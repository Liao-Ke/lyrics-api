      "time": 11.18,
      "time_str": "00:11.180",
      "text": "你知道吗",
      "translation": null
    },
    {
      "time": 13.3,
      "time_str": "00:13.300",
      "text": "爱你并不容易",
      "translation": null
    },
    {
      "time": 16.23,
      "time_str": "00:16.230",
      "text": "还需要很多勇气",
      "translation": null
    },
    {
      "time": 21.31,
      "time_str": "00:21.310",
      "text": "是天意吧",
      "translation": null
    },
    {
      "time": 23.74,
      "time_str": "00:23.740",
      "text": "好多话说不出去",
      "translation": null
    },
    {
      "time": 27.14,
      "time_str": "00:27.140",
      "text": "就是怕你负担不起",
      "translation": null
    },
    {
      "time": 31.72,
      "time_str": "00:31.720",
      "text": "你相信吗",
      "translation": null
    },
    {
      "time": 34.02,
      "time_str": "00:34.020",
      "text": "这一生遇见你",
      "translation": null
    },
    {
      "time": 37.25,
      "time_str": "00:37.250",
      "text": "是上辈子我欠你的",
      "translation": null
    },
    {
      "time": 42.37,
      "time_str": "00:42.370",
      "text": "是天意吧",
      "translation": null
    },
    {
      "time": 44.51,
      "time_str": "00:44.510",
      "text": "让我爱上你",
      "translation": null
    },
    {
      "time": 47.61,
      "time_str": "00:47.610",
      "text": "才又让你 离我而去",
      "translation": null
    },
    {
      "time": 53.94,
      "time_str": "00:53.940",
      "text": "也许轮回里 早已注定",
      "translation": null
    },
    {
      "time": 58.52,
      "time_str": "00:58.520",
      "text": "今生就该我还给你",
      "translation": null
    },
    {
