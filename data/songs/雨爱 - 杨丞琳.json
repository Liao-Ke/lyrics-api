    {
      "time": 16.286,
      "time_str": "00:16.286",
      "text": "窗外的天气",
      "translation": null
    },
    {
      "time": 20.706,
      "time_str": "00:20.706",
      "text": "就像是 你多变的表情",
      "translation": null
    },
    {
      "time": 26.454,
      "time_str": "00:26.454",
      "text": "下雨了 雨陪我哭泣",
      "translation": null
    },
    {
      "time": 32.824,
      "time_str": "00:32.824",
      "text": "看不清 我也不想看清",
      "translation": null
    },
    {
      "time": 38.411,
      "time_str": "00:38.411",
      "text": "离开你 我安静的抽离",
      "translation": null
    },
    {
      "time": 42.188,
      "time_str": "00:42.188",
      "text": "不忍揭晓的剧情",
      "translation": null
    },
    {
      "time": 45.138,
      "time_str": "00:45.138",
      "text": "我的泪流在心里",
      "translation": null
    },
    {
      "time": 48.145,
      "time_str": "00:48.145",
      "text": "学会放弃",
      "translation": null
    },
    {
      "time": 50.943,
      "time_str": "00:50.943",
      "text": "听雨的声音 一滴滴清晰",
      "translation": null
    },
    {
      "time": 54.109,
      "time_str": "00:54.109",
      "text": "你的呼吸像雨滴渗入我的爱里",
      "translation": null
    },
    {
      "time": 59.402,
      "time_str": "00:59.402",
      "text": "真希望雨能下不停",
      "translation": null
    },
    {
      "time": 63.21,
      "time_str": "01:03.210",
      "text": "让想念继续 让爱变透明",
      "translation": null
    },
    {
      "time": 69.173,
      "time_str": "01:09.173",
      "text": "我爱上给我勇气的 Rainie Love",
      "translation": null
    },
    {
      "time": 75.006,
      "time_str": "01:15.006",
      "text": "窗外的雨滴 一滴滴累积",
      "translation": null
    },
    {
      "time": 78.144,
      "time_str": "01:18.144",
      "text": "屋内的湿气像储存爱你的记忆",
      "translation": null
    },
    {
      "time": 83.483,
      "time_str": "01:23.483",
      "text": "真希望雨能下不停",
