  },
  "lyrics": [
    {
      "time": 26.293,
      "time_str": "00:26.293",
      "text": "离开真的残酷吗",
      "translation": null
    },
    {
      "time": 28.7,
      "time_str": "00:28.700",
      "text": "或者温柔才是可耻的",
      "translation": null
    },
    {
      "time": 31.881,
      "time_str": "00:31.881",
      "text": "或者孤独的人无所谓",
      "translation": null
    },
    {
      "time": 35.116,
      "time_str": "00:35.116",
      "text": "无日无夜无条件",
      "translation": null
    },
    {
      "time": 39.076,
      "time_str": "00:39.076",
      "text": "前面真的危险吗",
      "translation": null
    },
    {
      "time": 41.509,
      "time_str": "00:41.509",
      "text": "或者背叛才是体贴的",
      "translation": null
    },
    {
      "time": 44.672,
      "time_str": "00:44.672",
      "text": "或者逃避比较容易吧",
      "translation": null
    },
    {
      "time": 47.868,
      "time_str": "00:47.868",
      "text": "风言风语风吹沙",
      "translation": null
    },
    {
      "time": 51.472,
      "time_str": "00:51.472",
      "text": "往前一步是黄昏",
      "translation": null
    },
    {
      "time": 54.716,
      "time_str": "00:54.716",
      "text": "退后一步是人生",
      "translation": null
    },
    {
      "time": 57.86,
      "time_str": "00:57.860",
      "text": "风不平 浪不静",
      "translation": null
    },
    {
      "time": 59.518,
      "time_str": "00:59.518",
      "text": "心还不安稳",
      "translation": null
    },
    {
      "time": 61.134,
      "time_str": "01:01.134",
      "text": "一个岛锁住一个人",
      "translation": null
    },
    {
      "time": 65.961,
      "time_str": "01:05.961",
      "text": "我等的船还不来",
      "translation": null
    },
    {
      "time": 69.095,
      "time_str": "01:09.095",
      "text": "我等的人还不明白",
      "translation": null
    },
    {
      "time": 72.356,
      "time_str": "01:12.356",
      "text": "寂寞默默沉没沉入海",
      "translation": null
    },
    {
      "time": 75.543,
      "time_str": "01:15.543",
      "text": "未来不在我还在",
      "translation": null
    },
    {
      "time": 78.751,
      "time_str": "01:18.751",
      "text": "如果潮去心也去",
      "translation": null
    },
    {
      "time": 81.991,
      "time_str": "01:21.991",
      "text": "如果潮来你还不来",
      "translation": null
    },
    {
      "time": 85.173,
      "time_str": "01:25.173",
      "text": "浮浮沉沉 往事浮上来",
      "translation": null
    },
    {
      "time": 88.326,
      "time_str": "01:28.326",
      "text": "回忆回来 你已不在",
      "translation": null
    },
    {
      "time": 92.775,
      "time_str": "01:32.775",
      "text": "一波还未平息",
      "translation": null
    },
    {
      "time": 94.414,
      "time_str": "01:34.414",
      "text": "一波又来侵袭",
      "translation": null
    },
    {
      "time": 96.353,
      "time_str": "01:36.353",
      "text": "茫茫人海 狂风暴雨",
      "translation": null
    },
    {
      "time": 99.229,
      "time_str": "01:39.229",
      "text": "一波还来不及",
      "translation": null
    },
    {
      "time": 100.831,
      "time_str": "01:40.831",
      "text": "一波早就过去",
      "translation": null
    },
    {
      "time": 102.784,
      "time_str": "01:42.784",
      "text": "一生一世 如梦初醒",
      "translation": null
    },
    {
      "time": 106.019,
      "time_str": "01:46.019",
      "text": "深深太平洋底 深深伤心",
      "translation": null
    },
    {
