      "time": 36.966,
      "time_str": "00:36.966",
      "text": "春风细细诉说秘密",
      "translation": null
    },
    {
      "time": 41.471,
      "time_str": "00:41.471",
      "text": "谁的手握在一起",
      "translation": null
    },
    {
      "time": 48.387,
      "time_str": "00:48.387",
      "text": "若现若隐",
      "translation": null
    },
    {
      "time": 50.632,
      "time_str": "00:50.632",
      "text": "谁是梦中的你",
      "translation": null
    },
    {
      "time": 57.594,
      "time_str": "00:57.594",
      "text": "月光如蜜寻欢人群",
      "translation": null
    },
    {
      "time": 62.147,
      "time_str": "01:02.147",
      "text": "多少爱慕的眼睛",
      "translation": null
    },
    {
      "time": 68.987,
      "time_str": "01:08.987",
      "text": "不远不近",
      "translation": null
    },
    {
      "time": 71.193,
      "time_str": "01:11.193",
      "text": "正好使我动情",
      "translation": null
    },
    {
      "time": 77.753,
      "time_str": "01:17.753",
      "text": "我的心从来不觉得冷",
      "translation": null
    },
    {
      "time": 82.632,
      "time_str": "01:22.632",
      "text": "像盏粉红色的灯",
      "translation": null
    },
    {
      "time": 87.32,
      "time_str": "01:27.320",
      "text": "温柔的燃烧在夜里",
      "translation": null
    },
    {
      "time": 96.508,
      "time_str": "01:36.508",
      "text": "谁想轻轻偷走我的吻",
