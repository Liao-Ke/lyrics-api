  "lyrics": [
    {
      "time": 18.08,
      "time_str": "00:18.080",
      "text": "我站在教室门口的小角落",
      "translation": null
    },
    {
      "time": 23.25,
      "time_str": "00:23.250",
      "text": "偷偷看着你可爱的笑容",
      "translation": null
    },
    {
      "time": 27.91,
      "time_str": "00:27.910",
      "text": "你就像天上的云朵我好想变成彩虹",
      "translation": null
    },
    {
      "time": 36.99,
      "time_str": "00:36.990",
      "text": "橘子汽水的香味飘在空气中",
      "translation": null
    },
    {
      "time": 41.31,
      "time_str": "00:41.310",
      "text": "你嘴角的奶油看得我好心动",
      "translation": null
    },
    {
      "time": 45.71,
      "time_str": "00:45.710",
      "text": "我和你的默契有种节奏",
      "translation": null
    },
    {
      "time": 49.08,
      "time_str": "00:49.080",
      "text": "牵着我的心跳跟你走",
      "translation": null
    },
    {
      "time": 53.88,
      "time_str": "00:53.880",
      "text": "就这样牵着你一直走 （这路没有尽头）",
      "translation": null
    },
    {
      "time": 58.95,
      "time_str": "00:58.950",
      "text": "就是喜欢你偷瞄着我 （的害羞）",
      "translation": null
    },
    {
      "time": 62.9,
      "time_str": "01:02.900",
      "text": "让我紧紧牵着你的手望着星空",
      "translation": null
    },
    {
      "time": 67.6,
      "time_str": "01:07.600",
      "text": "直到我们心灵相通",
      "translation": null
    },
    {
      "time": 72.04,
      "time_str": "01:12.040",
      "text": "就这样牵着你一直走 （这次绝不放手）",
      "translation": null
    },
    {
      "time": 77.19,
      "time_str": "01:17.190",
      "text": "我会努力变成属于你 （的流星）",
      "translation": null
    },
    {
      "time": 81.37,
      "time_str": "01:21.370",
      "text": "帮你实现心底所有期待的愿望",
      "translation": null
    },
    {
      "time": 85.91,
      "time_str": "01:25.910",
      "text": "不管四季变化我的心意不隐藏",
      "translation": null
    },
    {
      "time": 108.97,
      "time_str": "01:48.970",
      "text": "天空突然下起了一场大雨",
      "translation": null
    },
    {
      "time": 114.62,
      "time_str": "01:54.620",
      "text": "我该不该现在送你回去",
      "translation": null
    },
    {
      "time": 119.21,
      "time_str": "01:59.210",
      "text": "不想打断你给的甜蜜",
      "translation": null
    },
    {
      "time": 122.38,
      "time_str": "02:02.380",
      "text": "干脆就让我陪你淋雨",
      "translation": null
    },
