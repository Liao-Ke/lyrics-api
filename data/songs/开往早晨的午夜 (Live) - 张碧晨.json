  "lyrics": [
    {
      "time": 6.58,
      "time_str": "00:06.580",
      "text": "原唱：张碧晨",
      "translation": null
    },
    {
      "time": 13.74,
      "time_str": "00:13.740",
      "text": "夜的星屑 不熄灭的夜",
      "translation": null
    },
    {
      "time": 25.36,
      "time_str": "00:25.360",
      "text": "开往早晨的午夜",
      "translation": null
    },
    {
      "time": 29.43,
      "time_str": "00:29.430",
      "text": "终将拥抱的季节",
      "translation": null
    },
    {
      "time": 33.47,
      "time_str": "00:33.470",
      "text": "让我们变爱人 那么狂野",
      "translation": null
    },
    {
      "time": 42.03,
      "time_str": "00:42.030",
      "text": "不划边界的原野",
      "translation": null
    },
    {
      "time": 46.29,
      "time_str": "00:46.290",
      "text": "愈合抱歉的感谢",
      "translation": null
    },
    {
      "time": 50.27,
      "time_str": "00:50.270",
      "text": "恰好的已足够",
      "translation": null
    },
    {
      "time": 54.62,
      "time_str": "00:54.620",
      "text": "一吻一朵温柔",
      "translation": null
    },
    {
      "time": 58.75,
      "time_str": "00:58.750",
      "text": "曾像夜那么黑 每个清晨",
      "translation": null
    },
    {
      "time": 63.0,
      "time_str": "01:03.000",
      "text": "曾阻挡每个梦 每一道门",
      "translation": null
    },
    {
      "time": 67.35,
      "time_str": "01:07.350",
      "text": "终于也可能 无限可能自由发生",
      "translation": null
    },
    {
      "time": 75.68,
      "time_str": "01:15.680",
      "text": "曾像爱那么真 功败垂成",
      "translation": null
    },
    {
      "time": 79.81,
      "time_str": "01:19.810",
      "text": "曾误认的诚恳 每个猎人",
      "translation": null
    },
    {
      "time": 84.03,
      "time_str": "01:24.030",
      "text": "终于成人 这是青春",
      "translation": null
    },
    {
      "time": 92.56,
      "time_str": "01:32.560",
      "text": "沿着银河 一身星屑",
      "translation": null
    },
    {
      "time": 96.64,
      "time_str": "01:36.640",
      "text": "一身星屑 夜正倾斜",
      "translation": null
    },
    {
      "time": 100.99,
      "time_str": "01:40.990",
      "text": "在倾斜 霓虹荒野",
      "translation": null
    },
    {
      "time": 105.06,
      "time_str": "01:45.060",
      "text": "星的长街",
      "translation": null
    },
    {
      "time": 109.52,
      "time_str": "01:49.520",
      "text": "开往早晨的午夜",
      "translation": null
    },
    {
      "time": 113.66,
      "time_str": "01:53.660",
      "text": "终将花开的花谢",
      "translation": null
