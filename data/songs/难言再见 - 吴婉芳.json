{
  "title": "难言再见",
  "title_raw": "难言再见",
  "version": null,
  "artist": "吴婉芳",
  "group_key": "难言再见|吴婉芳",
  "writers": {
    "lyricist": "刘明瑞",
    "composer": "张国祖",
    "arranger": "杜自持"
  },
  "lyrics": [
    {
      "time": 16.58,
      "time_str": "00:16.580",
      "text": "旧日话别时 共你心中不需多挂念",
      "translation": null
    },
    {
      "time": 23.26,
      "time_str": "00:23.260",
      "text": "悠悠随着那风的变迁",
      "translation": null
    },
    {
      "time": 29.7,
      "time_str": "00:29.700",
      "text": "若是慢慢离别去不再返今生不再依恋",
      "translation": null
    },
    {
      "time": 36.0,
      "time_str": "00:36.000",
      "text": "奈何又思忆数千遍",
      "translation": null
    },
    {
      "time": 42.7,
      "time_str": "00:42.700",
      "text": "你却要记念过往我俩是爱过一遍",
      "translation": null
    },
    {
      "time": 48.9,
      "time_str": "00:48.900",
      "text": "莫堆积心中 再丝丝相牵 你却对我缠绵",
      "translation": null
    },
    {
      "time": 54.85,
      "time_str": "00:54.850",
      "text": "啊 哈 谁能令你改变(谁能令你)",
      "translation": null
    },
    {
      "time": 59.33,
      "time_str": "00:59.330",
      "text": "难言共对相劝(难言共对)",
      "translation": null
    },
    {
      "time": 62.0,
      "time_str": "01:02.000",
      "text": "无边的爱情暂变迁",
      "translation": null
    },
    {
      "time": 68.57,
      "time_str": "01:08.570",
      "text": "滴着泪渐离别去 难堪轻私语",
      "translation": null
    },
    {
      "time": 75.9,
      "time_str": "01:15.900",
      "text": "痴痴的心也轻轻的被流住",
      "translation": null
    },
    {
      "time": 81.13,
      "time_str": "01:21.130",
      "text": "如可会千载不变 或许也可再重遇",
      "translation": null
    },
    {
      "time": 87.64,
      "time_str": "01:27.640",
      "text": "难言 亦说声 再见",
      "translation": null
    },
    {
