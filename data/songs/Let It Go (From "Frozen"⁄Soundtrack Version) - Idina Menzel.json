{
  "title": "Let It Go",
  "title_raw": "Let It Go (From \"Frozen\"⁄Soundtrack Version)",
  "version": "From \"Frozen\"⁄Soundtrack Version",
  "artist": "Idina Menzel",
  "group_key": "let it go|idina menzel",
  "writers": {
