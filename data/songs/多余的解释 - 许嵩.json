    {
      "time": 17.61,
      "time_str": "00:17.610",
      "text": "那阵子我们的感情出了一些问题",
      "translation": null
    },
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "可是我也不太清楚问题出在哪里",
      "translation": null
    },
    {
      "time": 25.41,
      "time_str": "00:25.410",
      "text": "你面无表情的话语不剩多少意义",
      "translation": null
    },
    {
      "time": 29.27,
      "time_str": "00:29.270",
      "text": "就当我求求你 给我一些说明",
      "translation": null
    },
    {
      "time": 33.17,
      "time_str": "00:33.170",
      "text": "ok 我猜你只是暂时的压抑心情",
      "translation": null
    },
    {
      "time": 36.71,
      "time_str": "00:36.710",
      "text": "不再去追问你 多给你一些关心",
      "translation": null
    },
    {
      "time": 40.87,
      "time_str": "00:40.870",
      "text": "打电话请你去看最新的电影",
      "translation": null
    },
    {
      "time": 44.52,
      "time_str": "00:44.520",
      "text": "你说工作很忙要加班到夜里",
      "translation": null
    },
    {
      "time": 48.32,
      "time_str": "00:48.320",
      "text": "ooook 入冬了想给你买一条围巾",
      "translation": null
    },
    {
      "time": 51.1,
      "time_str": "00:51.100",
      "text": "怕眼光不行 所以叫着紧跟潮流的妹妹和我一起",
      "translation": null
    },
    {
      "time": 56.24,
      "time_str": "00:56.240",
      "text": "和妹妹说说笑笑 缓释最近糟糕心绪",
      "translation": null
    },
    {
      "time": 60.21,
      "time_str": "01:00.210",
      "text": "在下一个转角却和你相遇",
      "translation": null
    },
    {
      "time": 64.22,
      "time_str": "01:04.220",
      "text": "她只是我的妹妹 妹妹说紫色很有韵味",
      "translation": null
    },
    {
      "time": 70.82,
      "time_str": "01:10.820",
      "text": "她只是我的妹妹 我在担心你是否误会",
      "translation": null
    },
    {
      "time": 78.87,
      "time_str": "01:18.870",
      "text": "她只是我的妹妹 对这个解释你无所谓",
      "translation": null
    },
    {
      "time": 87.29,
      "time_str": "01:27.290",
      "text": "我没有思想准备 看到你身旁还有一位",
