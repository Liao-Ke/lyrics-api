      "time": 29.761,
      "time_str": "00:29.761",
      "text": "爱过的人 我已不再拥有",
      "translation": null
    },
    {
      "time": 36.956,
      "time_str": "00:36.956",
      "text": "许多故事 有伤心的理由",
      "translation": null
    },
    {
      "time": 43.003,
      "time_str": "00:43.003",
      "text": "这一次我的爱情",
      "translation": null
    },
    {
