  "lyrics": [
    {
      "time": 4.522,
      "time_str": "00:04.522",
      "text": "忘不掉你留给我的话",
      "translation": null
    },
    {
      "time": 11.562,
      "time_str": "00:11.562",
      "text": "在平行时空我回答",
      "translation": null
    },
    {
      "time": 16.313,
      "time_str": "00:16.313",
      "text": "就把过去放下",
      "translation": null
    },
    {
      "time": 20.74,
      "time_str": "00:20.740",
      "text": "要学会遮住伤疤",
      "translation": null
    },
    {
      "time": 25.625,
      "time_str": "00:25.625",
      "text": "是无声的 惩罚",
      "translation": null
    },
    {
      "time": 33.058,
      "time_str": "00:33.058",
      "text": "承诺最害怕不懂表达",
      "translation": null
    },
    {
      "time": 40.745,
      "time_str": "00:40.745",
      "text": "电话那端时钟嘀嗒",
      "translation": null
    },
    {
      "time": 46.594,
      "time_str": "00:46.594",
      "text": "措辞想到沙哑",
      "translation": null
    },
    {
      "time": 49.81,
      "time_str": "00:49.810",
      "text": "眼泪始终不听话",
      "translation": null
    },
    {
      "time": 53.93,
      "time_str": "00:53.930",
      "text": "我应该怎么表达",
      "translation": null
    },
    {
      "time": 61.609,
      "time_str": "01:01.609",
      "text": "眼泪太拥挤当眼里都是你",
      "translation": null
    },
    {
      "time": 67.866,
      "time_str": "01:07.866",
      "text": "却刻意轻描淡写我们的关系",
      "translation": null
    },
    {
      "time": 75.297,
      "time_str": "01:15.297",
      "text": "过往被旁人提起",
      "translation": null
    },
    {
      "time": 79.017,
      "time_str": "01:19.017",
      "text": "心里下起了暴雨",
      "translation": null
    },
    {
      "time": 83.938,
      "time_str": "01:23.938",
      "text": "我该学会自我疗愈",
      "translation": null
    },
    {
      "time": 90.762,
      "time_str": "01:30.762",
      "text": "眼泪太拥挤当眼里都是你",
      "translation": null
    },
    {
      "time": 97.05,
      "time_str": "01:37.050",
      "text": "当初是我太逃避爱情的难题",
      "translation": null
    },
    {
      "time": 105.322,
      "time_str": "01:45.322",
      "text": "还你晚到的歉意",
      "translation": null
    },
    {
      "time": 107.85,
      "time_str": "01:47.850",
      "text": "落得这般的境地",
      "translation": null
    },
    {
      "time": 112.905,
      "time_str": "01:52.905",
      "text": "最后我也只能说句 对不起",
