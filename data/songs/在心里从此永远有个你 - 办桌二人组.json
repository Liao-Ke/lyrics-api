    {
      "time": 25.79,
      "time_str": "00:25.790",
      "text": "为什么 我们相遇网络",
      "translation": null
    },
    {
      "time": 30.04,
      "time_str": "00:30.040",
      "text": "为什么 要拿虚拟对待我",
      "translation": null
    },
    {
      "time": 35.22,
      "time_str": "00:35.220",
      "text": "我和你 在一起",
      "translation": null
    },
    {
      "time": 39.29,
      "time_str": "00:39.290",
      "text": "在一起 的甜蜜",
      "translation": null
    },
    {
      "time": 41.06,
      "time_str": "00:41.060",
      "text": "这份爱 会埋在我心底",
      "translation": null
    },
    {
      "time": 46.09,
      "time_str": "00:46.090",
      "text": "我和你相爱网络里",
      "translation": null
    },
    {
      "time": 52.35,
      "time_str": "00:52.350",
      "text": "爱来爱去 都变成回忆",
      "translation": null
    },
    {
      "time": 57.31,
      "time_str": "00:57.310",
      "text": "你的心 我最懂",
      "translation": null
    },
    {
      "time": 61.08,
      "time_str": "01:01.080",
      "text": "你哭泣 我陪你",
      "translation": null
    },
    {
      "time": 63.78,
      "time_str": "01:03.780",
      "text": "这辈子 注定与你在一起",
      "translation": null
    },
    {
      "time": 69.57,
      "time_str": "01:09.570",
      "text": "大声喊出我爱你",
      "translation": null
    },
    {
      "time": 71.08,
      "time_str": "01:11.080",
      "text": "时刻把你放心底",
      "translation": null
    },
    {
      "time": 74.68,
      "time_str": "01:14.680",
      "text": "不怕网络的虚拟 等着你",
      "translation": null
    },
    {
      "time": 80.05,
      "time_str": "01:20.050",
      "text": "点击鼠标的情意",
      "translation": null
    },
    {
      "time": 82.03,
      "time_str": "01:22.030",
      "text": "传达爱你的蜜语",
      "translation": null
    },
    {
      "time": 85.66,
      "time_str": "01:25.660",
      "text": "在心里从此永远有个你",
      "translation": null
    },
    {
      "time": 90.56,
      "time_str": "01:30.560",
      "text": "谢谢你 让我遇到你",
      "translation": null
    },
    {
      "time": 95.41,
      "time_str": "01:35.410",
      "text": "谢谢你 也让我爱上你",
      "translation": null
    },
    {
      "time": 101.05,
      "time_str": "01:41.050",
      "text": "不管 风风 雨雨",
      "translation": null
    },
    {
      "time": 104.8,
      "time_str": "01:44.800",
      "text": "不问 明天在哪里",
      "translation": null
    },
    {
      "time": 107.44,
      "time_str": "01:47.440",
      "text": "我都会 永远的 陪伴你",
