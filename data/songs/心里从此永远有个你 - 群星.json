  "lyrics": [
    {
      "time": 27.28,
      "time_str": "00:27.280",
      "text": "为什么我们相遇网络",
      "translation": null
    },
    {
      "time": 32.7,
      "time_str": "00:32.700",
      "text": "为什么要拿虚拟对待我",
      "translation": null
    },
    {
      "time": 37.77,
      "time_str": "00:37.770",
      "text": "我和你在一起 在一起的甜蜜",
      "translation": null
    },
    {
      "time": 43.14,
      "time_str": "00:43.140",
      "text": "这份爱会埋在我心里",
      "translation": null
    },
    {
      "time": 48.69,
      "time_str": "00:48.690",
      "text": "我和你相爱网络里",
      "translation": null
    },
    {
      "time": 54.18,
      "time_str": "00:54.180",
      "text": "爱来爱去都变成回忆",
      "translation": null
    },
    {
      "time": 59.49,
      "time_str": "00:59.490",
      "text": "你的心我最懂",
      "translation": null
    },
    {
      "time": 62.17,
      "time_str": "01:02.170",
      "text": "你哭泣我陪你",
      "translation": null
    },
    {
      "time": 65.03,
      "time_str": "01:05.030",
      "text": "这辈子注定与你在一起",
      "translation": null
    },
    {
      "time": 70.53,
      "time_str": "01:10.530",
      "text": "大声喊出我爱你时刻把你放心底",
      "translation": null
    },
    {
      "time": 75.89,
      "time_str": "01:15.890",
      "text": "不怕网络的虚拟等着你",
      "translation": null
    },
    {
      "time": 81.66,
      "time_str": "01:21.660",
      "text": "点击鼠标的情意传达爱你的蜜语",
      "translation": null
    },
    {
      "time": 86.83,
      "time_str": "01:26.830",
      "text": "在心里从此永远有个你",
      "translation": null
    },
    {
      "time": 92.5,
      "time_str": "01:32.500",
      "text": "谢谢你让我遇到你",
      "translation": null
    },
    {
      "time": 97.809,
      "time_str": "01:37.809",
      "text": "谢谢你也让我爱上你",
      "translation": null
    },
    {
      "time": 103.67,
      "time_str": "01:43.670",
      "text": "不管风 风雨雨 不问明天在哪里",
      "translation": null
    },
    {
      "time": 108.67,
      "time_str": "01:48.670",
      "text": "我都会永远地陪伴你",
      "translation": null
