      "text": "羽扇纶巾笑谈间",
      "translation": null
    },
    {
      "time": 26.87,
      "time_str": "00:26.870",
      "text": "千军万马我无懈",
      "translation": null
    },
    {
      "time": 30.729,
      "time_str": "00:30.729",
      "text": "伪面君子三尺剑",
      "translation": null
    },
    {
      "time": 33.679,
      "time_str": "00:33.679",
      "text": "狼火烽烟我敷衍",
      "translation": null
    },
    {
      "time": 37.539,
      "time_str": "00:37.539",
      "text": "生于乱世行不言",
      "translation": null
    },
    {
      "time": 41.19,
      "time_str": "00:41.190",
      "text": "功过不求谁来鉴",
      "translation": null
    },
    {
      "time": 43.499,
      "time_str": "00:43.499",
      "text": "灯为谁点 脂为谁添",
      "translation": null
    },
    {
      "time": 46.499,
      "time_str": "00:46.499",
      "text": "任谁来笑我太疯癫",
      "translation": null
    },
    {
      "time": 49.809,
      "time_str": "00:49.809",
      "text": "雨一直下 风一直刮",
      "translation": null
    },
    {
      "time": 54.2,
      "time_str": "00:54.200",
      "text": "谁与我煮酒论天下",
      "translation": null
    },
    {
      "time": 56.769,
      "time_str": "00:56.769",
      "text": "万箭齐发 杀气如麻",
      "translation": null
    },
    {
      "time": 60.299,
      "time_str": "01:00.299",
      "text": "谁忍我乱世中安家",
      "translation": null
    },
    {
      "time": 63.478,
      "time_str": "01:03.478",
      "text": "三分天下 为谁争霸",
      "translation": null
    },
    {
      "time": 66.839,
      "time_str": "01:06.839",
      "text": "如今我已剑指天涯",
