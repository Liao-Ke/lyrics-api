    {
      "time": 22.319,
      "time_str": "00:22.319",
      "text": "我为什么还在等待",
      "translation": null
    },
    {
      "time": 30.18,
      "time_str": "00:30.180",
      "text": "我不知道为何仍这样痴情",
      "translation": null
    },
    {
      "time": 38.248,
      "time_str": "00:38.248",
      "text": "明知辉煌",
      "translation": null
    },
    {
      "time": 42.088,
      "time_str": "00:42.088",
      "text": "过后是暗淡",
      "translation": null
    },
    {
      "time": 45.738,
      "time_str": "00:45.738",
      "text": "仍期待着把一切从头来过",
      "translation": null
    },
    {
      "time": 57.98,
      "time_str": "00:57.980",
      "text": "我们既然曾经拥有",
      "translation": null
    },
    {
      "time": 65.778,
      "time_str": "01:05.778",
      "text": "我的爱就不想停顿",
      "translation": null
    },
    {
      "time": 74.908,
      "time_str": "01:14.908",
      "text": "每个梦里都有你的梦",
      "translation": null
    },
    {
      "time": 82.918,
      "time_str": "01:22.918",
      "text": "共同期待一个永恒的春天",
      "translation": null
    },
    {
