    {
      "time": 1.29,
      "time_str": "00:01.290",
      "text": "雪下得那么深 下得那么认真",
      "translation": null
    },
    {
      "time": 6.67,
      "time_str": "00:06.670",
      "text": "倒映出我躺在雪中的伤痕",
      "translation": null
    },
    {
      "time": 24.41,
      "time_str": "00:24.410",
      "text": "夜深人静 那是爱情",
      "translation": null
    },
    {
      "time": 33.53,
      "time_str": "00:33.530",
      "text": "偷偷的控制着我的心",
      "translation": null
    },
    {
      "time": 36.39,
      "time_str": "00:36.390",
      "text": "提醒我爱你要随时待命",
      "translation": null
    },
    {
      "time": 42.78,
      "time_str": "00:42.780",
      "text": "音乐安静 还是爱情啊",
      "translation": null
    },
    {
      "time": 51.38,
      "time_str": "00:51.380",
      "text": "一步一步吞噬着我的心",
      "translation": null
    },
    {
      "time": 54.59,
      "time_str": "00:54.590",
      "text": "爱上你我失去了我自己",
      "translation": null
    },
    {
