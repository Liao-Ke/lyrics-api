  "lyrics": [
    {
      "time": 18.042,
      "time_str": "00:18.042",
      "text": "你降落的 太突然了",
      "translation": null
    },
    {
      "time": 24.24,
      "time_str": "00:24.240",
      "text": "我刚好呢 又路过了",
      "translation": null
    },
    {
      "time": 32.325,
      "time_str": "00:32.325",
      "text": "机会难得 又主观觉得",
      "translation": null
    },
    {
      "time": 38.725,
      "time_str": "00:38.725",
      "text": "想明抢 又碰不得",
      "translation": null
    },
    {
      "time": 46.157,
      "time_str": "00:46.157",
      "text": "你带来了 我的快乐",
      "translation": null
    },
    {
      "time": 53.157,
      "time_str": "00:53.157",
      "text": "让这世界 有点颜色",
      "translation": null
    },
    {
      "time": 60.444,
      "time_str": "01:00.444",
      "text": "我好想指责 你太随意了",
      "translation": null
    },
    {
      "time": 66.991,
      "time_str": "01:06.991",
      "text": "宝物该有人捧着  你是不是我的",
      "translation": null
    },
    {
      "time": 77.333,
      "time_str": "01:17.333",
      "text": "你像 天外来物一样 求之不得",
      "translation": null
    },
    {
      "time": 84.269,
      "time_str": "01:24.269",
      "text": "你在世俗里的名字 不重要了",
      "translation": null
    },
    {
      "time": 91.516,
      "time_str": "01:31.516",
      "text": "正好 我隐藏的人格是契而不舍",
      "translation": null
    },
    {
      "time": 98.299,
      "time_str": "01:38.299",
      "text": "直到蜂拥而至的人都透明了",
      "translation": null
    },
    {
      "time": 105.943,
      "time_str": "01:45.943",
      "text": "我在 不近又不远处",
      "translation": null
    },
    {
      "time": 109.925,
      "time_str": "01:49.925",
      "text": "用明天换你 靠近我",
      "translation": null
    },
    {
      "time": 127.554,
      "time_str": "02:07.554",
      "text": "你占领了 我的快乐",
      "translation": null
    },
    {
      "time": 134.406,
      "time_str": "02:14.406",
      "text": "和这世界 已没有瓜葛",
      "translation": null
    },
    {
      "time": 141.639,
      "time_str": "02:21.639",
      "text": "任事物干渴  都褪去颜色",
      "translation": null
    },
    {
      "time": 148.34,
      "time_str": "02:28.340",
      "text": "只有你是天蓝色  我开始找你了",
      "translation": null
    },
    {
      "time": 160.569,
      "time_str": "02:40.569",
      "text": "会像 天外来物一样 失而复得",
      "translation": null
    },
    {
      "time": 167.769,
      "time_str": "02:47.769",
      "text": "你在世俗里的名字  被人用了",
      "translation": null
    },
    {
      "time": 174.662,
      "time_str": "02:54.662",
      "text": "反正 我隐藏的人格是契而不舍",
