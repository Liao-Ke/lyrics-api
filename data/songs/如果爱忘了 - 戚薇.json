  "lyrics": [
    {
      "time": 19.19,
      "time_str": "00:19.190",
      "text": "总有一些话 来不及说了",
      "translation": null
    },
    {
      "time": 25.87,
      "time_str": "00:25.870",
      "text": "总有一个人 是心口的朱砂",
      "translation": null
    },
    {
      "time": 33.169,
      "time_str": "00:33.169",
      "text": "想起那些话 那些傻 眼泪落下",
      "translation": null
    },
    {
      "time": 39.339,
      "time_str": "00:39.339",
      "text": "只留一句 你现在好吗",
      "translation": null
    },
    {
      "time": 46.828,
      "time_str": "00:46.828",
      "text": "如果爱忘了 泪不想落下",
      "translation": null
    },
    {
      "time": 53.779,
      "time_str": "00:53.779",
      "text": "那些幸福啊 让她替我到达",
      "translation": null
    },
    {
      "time": 60.188,
      "time_str": "01:00.188",
      "text": "如果爱懂了 承诺的代价",
      "translation": null
    },
    {
      "time": 66.79,
      "time_str": "01:06.790",
      "text": "不能给我的 请完整给她",
      "translation": null
    },
    {
      "time": 95.789,
      "time_str": "01:35.789",
      "text": "总有些牵挂 旧的像伤疤",
      "translation": null
    },
    {
      "time": 101.89,
      "time_str": "01:41.890",
      "text": "越是不碰它 越隐隐的痛在那",
      "translation": null
    },
    {
      "time": 108.619,
      "time_str": "01:48.619",
      "text": "想你的脸颊 你的发 我不害怕",
      "translation": null
    },
    {
      "time": 116.099,
      "time_str": "01:56.099",
      "text": "就让时间 给我们回答",
      "translation": null
    },
    {
      "time": 121.808,
      "time_str": "02:01.808",
      "text": "如果爱忘了 泪不想落下",
      "translation": null
    },
    {
      "time": 127.789,
      "time_str": "02:07.789",
      "text": "那些幸福啊 让她替我到达",
      "translation": null
    },
    {
      "time": 134.15,
      "time_str": "02:14.150",
      "text": "如果爱懂了 承诺的代价",
      "translation": null
    },
    {
      "time": 141.3,
      "time_str": "02:21.300",
      "text": "不能给我的 请完整给她",
      "translation": null
    },
    {
      "time": 148.59,
      "time_str": "02:28.590",
      "text": "我说我忘了 不痛了",
      "translation": null
    },
    {
      "time": 152.4,
      "time_str": "02:32.400",
      "text": "那是因为太爱太懂了",
      "translation": null
    },
    {
      "time": 155.56,
      "time_str": "02:35.560",
      "text": "笑了 原谅了 为你也值得",
      "translation": null
    },
    {
      "time": 161.74,
      "time_str": "02:41.740",
      "text": "用你的快乐 告诉我",
      "translation": null
    },
    {
      "time": 165.17,
      "time_str": "02:45.170",
      "text": "现在放开双手是对的",
      "translation": null
    },
    {
      "time": 168.4,
      "time_str": "02:48.400",
      "text": "别管我多 舍不得",
      "translation": null
    },
    {
      "time": 173.62,
      "time_str": "02:53.620",
      "text": "如果爱忘了 就放他走吧",
      "translation": null
    },
    {
