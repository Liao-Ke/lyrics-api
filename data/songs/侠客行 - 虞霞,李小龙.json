  "lyrics": [
    {
      "time": 21.4,
      "time_str": "00:21.400",
      "text": "自打盘古开天劈地",
      "translation": null
    },
    {
      "time": 24.11,
      "time_str": "00:24.110",
      "text": "侠行天下路在哪里",
      "translation": null
    },
    {
      "time": 26.82,
      "time_str": "00:26.820",
      "text": "不战而胜最是理想",
      "translation": null
    },
    {
      "time": 29.45,
      "time_str": "00:29.450",
      "text": "一身正气无人能敌",
      "translation": null
    },
    {
      "time": 32.13,
      "time_str": "00:32.130",
      "text": "除暴安良不畏艰险",
      "translation": null
    },
    {
      "time": 34.81,
      "time_str": "00:34.810",
      "text": "心中有爱是礼是义",
      "translation": null
    },
    {
      "time": 37.44,
      "time_str": "00:37.440",
      "text": "哪怕一时失去方向",
      "translation": null
    },
    {
      "time": 40.02,
      "time_str": "00:40.020",
      "text": "坚持下去就是希望",
      "translation": null
    },
    {
      "time": 43.72,
      "time_str": "00:43.720",
      "text": "这世界真的也许有太多的你不如意",
      "translation": null
    },
    {
      "time": 46.3,
      "time_str": "00:46.300",
      "text": "可你的生活虽然坎坎坷坷仍在继续",
      "translation": null
    },
    {
      "time": 48.94,
      "time_str": "00:48.940",
      "text": "希望就住在你的心底",
      "translation": null
    },
    {
      "time": 50.56,
      "time_str": "00:50.560",
      "text": "愿你勤勤恳恳善待别人关心自己",
      "translation": null
    },
    {
      "time": 53.02,
      "time_str": "00:53.020",
      "text": "美好的日子等你",
      "translation": null
    },
    {
      "time": 54.05,
      "time_str": "00:54.050",
      "text": "呛呛嗟 呛呛嗟",
      "translation": null
    },
    {
      "time": 55.53,
      "time_str": "00:55.530",
      "text": "拿出勇气让我看看",
      "translation": null
    },
    {
      "time": 56.84,
      "time_str": "00:56.840",
      "text": "呛呛嗟 呛呛嗟",
      "translation": null
    },
    {
      "time": 58.03,
      "time_str": "00:58.030",
      "text": "要向上看不向下看",
      "translation": null
    },
    {
      "time": 59.45,
      "time_str": "00:59.450",
      "text": "呛呛嗟 呛呛嗟",
      "translation": null
    },
    {
      "time": 60.73,
      "time_str": "01:00.730",
      "text": "要向前看不向后看",
      "translation": null
    },
    {
      "time": 62.08,
      "time_str": "01:02.080",
      "text": "呛呛嗟 呛呛嗟",
      "translation": null
    },
    {
