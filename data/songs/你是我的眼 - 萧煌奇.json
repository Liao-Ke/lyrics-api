  "lyrics": [
    {
      "time": 31.33,
      "time_str": "00:31.330",
      "text": "如果我能看得见",
      "translation": null
    },
    {
      "time": 34.01,
      "time_str": "00:34.010",
      "text": "就能轻易的分辨白天黑夜",
      "translation": null
    },
    {
      "time": 38.97,
      "time_str": "00:38.970",
      "text": "就能准确的在人群中",
      "translation": null
    },
    {
      "time": 42.79,
      "time_str": "00:42.790",
      "text": "牵住你的手",
      "translation": null
    },
    {
      "time": 46.76,
      "time_str": "00:46.760",
      "text": "如果我能看得见",
      "translation": null
    },
    {
      "time": 49.67,
      "time_str": "00:49.670",
      "text": "就能驾车带你到处遨游",
      "translation": null
    },
    {
      "time": 54.35,
      "time_str": "00:54.350",
      "text": "就能惊喜的从背后",
      "translation": null
    },
    {
      "time": 57.92,
      "time_str": "00:57.920",
      "text": "给你一个拥抱",
      "translation": null
    },
    {
      "time": 62.34,
      "time_str": "01:02.340",
      "text": "如果我能看得见",
      "translation": null
    },
    {
      "time": 65.09,
      "time_str": "01:05.090",
      "text": "生命也许完全不同",
      "translation": null
    },
    {
      "time": 70.2,
      "time_str": "01:10.200",
      "text": "可能我想要的我喜欢的我爱的",
      "translation": null
    },
    {
      "time": 74.07,
      "time_str": "01:14.070",
      "text": "都不一样",
      "translation": null
    },
    {
      "time": 81.65,
      "time_str": "01:21.650",
      "text": "眼前的黑不是黑",
      "translation": null
    },
    {
      "time": 85.19,
      "time_str": "01:25.190",
      "text": "你说的白是什么白",
      "translation": null
    },
    {
      "time": 89.39,
      "time_str": "01:29.390",
      "text": "人们说的天空蓝",
      "translation": null
    },
    {
      "time": 93.02,
      "time_str": "01:33.020",
      "text": "是我记忆中那团白云背后的蓝天",
      "translation": null
    },
    {
      "time": 101.15,
      "time_str": "01:41.150",
      "text": "我望向你的脸",
      "translation": null
    },
    {
      "time": 104.8,
      "time_str": "01:44.800",
      "text": "却只能看见一片虚无",
      "translation": null
    },
    {
      "time": 108.75,
      "time_str": "01:48.750",
      "text": "是不是上帝在我眼前遮住了帘",
      "translation": null
    },
    {
      "time": 112.41,
      "time_str": "01:52.410",
      "text": "忘了掀开",
      "translation": null
    },
    {
      "time": 120.69,
      "time_str": "02:00.690",
      "text": "你是我的眼",
      "translation": null
    },
    {
      "time": 124.06,
      "time_str": "02:04.060",
      "text": "带我领略四季的变换",
      "translation": null
    },
    {
      "time": 128.24,
      "time_str": "02:08.240",
      "text": "你是我的眼",
      "translation": null
    },
    {
      "time": 132.13,
      "time_str": "02:12.130",
      "text": "带我穿越拥挤的人潮",
      "translation": null
    },
    {
      "time": 135.97,
      "time_str": "02:15.970",
      "text": "你是我的眼",
      "translation": null
    },
    {
      "time": 139.46,
      "time_str": "02:19.460",
      "text": "带我阅读浩瀚的书海",
      "translation": null
    },
    {
      "time": 143.78,
      "time_str": "02:23.780",
      "text": "因为你是我的眼",
      "translation": null
    },
    {
      "time": 147.66,
      "time_str": "02:27.660",
      "text": "让我看见这世界",
