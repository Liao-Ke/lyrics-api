    {
      "time": 16.98,
      "time_str": "00:16.980",
      "text": "回忆像个说书的人",
      "translation": null
    },
    {
      "time": 20.74,
      "time_str": "00:20.740",
      "text": "用充满乡音的口吻",
      "translation": null
    },
    {
      "time": 24.76,
      "time_str": "00:24.760",
      "text": "跳过水坑 绕过小村",
      "translation": null
    },
    {
      "time": 28.74,
      "time_str": "00:28.740",
      "text": "等相遇的缘份",
      "translation": null
    },
    {
      "time": 32.8,
      "time_str": "00:32.800",
      "text": "你用泥巴捏一座城",
      "translation": null
    },
    {
      "time": 36.62,
      "time_str": "00:36.620",
      "text": "说将来要娶我进门",
      "translation": null
    },
    {
      "time": 40.72,
      "time_str": "00:40.720",
      "text": "转多少身 过几次门 虚掷青春",
      "translation": null
    },
    {
      "time": 48.7,
      "time_str": "00:48.700",
      "text": "小小的誓言还不稳",
      "translation": null
    },
    {
      "time": 52.63,
      "time_str": "00:52.630",
      "text": "小小的泪水还在撑",
      "translation": null
    },
    {
      "time": 56.28,
      "time_str": "00:56.280",
      "text": "稚嫩的唇 在说离分",
      "translation": null
    },
    {
      "time": 63.96,
      "time_str": "01:03.960",
      "text": "我的心里从此住了一个人",
      "translation": null
    },
    {
      "time": 68.26,
      "time_str": "01:08.260",
      "text": "曾经模样小小的我们",
      "translation": null
    },
    {
      "time": 72.36,
      "time_str": "01:12.360",
      "text": "那年你搬小小的板凳",
      "translation": null
    },
    {
      "time": 76.49,
      "time_str": "01:16.490",
      "text": "为戏入迷我也一路跟",
      "translation": null
    },
    {
      "time": 80.11,
      "time_str": "01:20.110",
      "text": "我在找那个故事里的人",
      "translation": null
    },
    {
      "time": 84.38,
      "time_str": "01:24.380",
      "text": "你是不能缺少的部份",
      "translation": null
    },
    {
      "time": 88.42,
      "time_str": "01:28.420",
      "text": "你在树下小小的打盹",
      "translation": null
    },
    {
      "time": 92.27,
      "time_str": "01:32.270",
      "text": "小小的我傻傻等",
