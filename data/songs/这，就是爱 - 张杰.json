  "lyrics": [
    {
      "time": 28.08,
      "time_str": "00:28.080",
      "text": "可能回忆掉进了大海",
      "translation": null
    },
    {
      "time": 31.62,
      "time_str": "00:31.620",
      "text": "可能有些往事回不来",
      "translation": null
    },
    {
      "time": 35.13,
      "time_str": "00:35.130",
      "text": "可能岁月会偷走等待",
      "translation": null
    },
    {
      "time": 38.31,
      "time_str": "00:38.310",
      "text": "爱了很久也许会分开",
      "translation": null
    },
    {
      "time": 42.21,
      "time_str": "00:42.210",
      "text": "我们一同喜欢着现在",
      "translation": null
    },
    {
      "time": 45.72,
      "time_str": "00:45.720",
      "text": "我们曾经被别人取代",
      "translation": null
    },
    {
      "time": 49.2,
      "time_str": "00:49.200",
      "text": "我们都有类似的遗憾",
      "translation": null
    },
    {
      "time": 52.35,
      "time_str": "00:52.350",
      "text": "所以一起漂流在人海",
      "translation": null
    },
    {
      "time": 55.86,
      "time_str": "00:55.860",
      "text": "挥不去的阴霾",
      "translation": null
    },
    {
      "time": 59.4,
      "time_str": "00:59.400",
      "text": "让我为你掩埋",
      "translation": null
    },
    {
      "time": 63.42,
      "time_str": "01:03.420",
      "text": "哭了一晚的你的样子",
      "translation": null
    },
    {
      "time": 66.9,
      "time_str": "01:06.900",
      "text": "从此都种在我的脑海",
      "translation": null
    },
    {
      "time": 70.049,
      "time_str": "01:10.049",
      "text": "月亮下的对白",
      "translation": null
    },
    {
      "time": 73.59,
      "time_str": "01:13.590",
      "text": "单纯得像小孩",
      "translation": null
    },
    {
      "time": 77.489,
      "time_str": "01:17.489",
      "text": "你有好几次问我那是什么",
      "translation": null
    },
    {
      "time": 81.84,
      "time_str": "01:21.840",
      "text": "这就是爱",
      "translation": null
    },
    {
      "time": 88.92,
      "time_str": "01:28.920",
      "text": "这就是爱",
      "translation": null
    },
