  "lyrics": [
    {
      "time": 29.25,
      "time_str": "00:29.250",
      "text": "2002年的第一场雪，",
      "translation": null
    },
    {
      "time": 33.41,
      "time_str": "00:33.410",
      "text": "比以往时候来的更晚一些。",
      "translation": null
    },
    {
      "time": 38.18,
      "time_str": "00:38.180",
      "text": "停靠在八楼的二路汽车，",
      "translation": null
    },
    {
      "time": 43.44,
      "time_str": "00:43.440",
      "text": "带走了最后一片飘落的黄叶。",
      "translation": null
    },
    {
      "time": 48.7,
      "time_str": "00:48.700",
      "text": "2002年的第一场雪，",
      "translation": null
    },
    {
      "time": 53.23,
      "time_str": "00:53.230",
      "text": "是留在乌鲁木齐难舍的情结。",
      "translation": null
    },
    {
      "time": 57.99,
      "time_str": "00:57.990",
      "text": "你像一只飞来飞去的蝴蝶，",
      "translation": null
    },
    {
      "time": 62.61,
      "time_str": "01:02.610",
      "text": "在白雪飘飞的季节里摇曳。",
      "translation": null
    },
    {
      "time": 67.62,
      "time_str": "01:07.620",
      "text": "忘不了把你搂在怀里的感觉，",
      "translation": null
    },
    {
      "time": 72.11,
      "time_str": "01:12.110",
      "text": "比藏在心中那份火热更暖一些。",
      "translation": null
    },
    {
      "time": 77.3,
      "time_str": "01:17.300",
      "text": "忘记了窗外的北风凛冽，",
      "translation": null
    },
    {
      "time": 82.14,
      "time_str": "01:22.140",
      "text": "再一次把温柔和缠绵重叠。",
      "translation": null
    },
    {
      "time": 115.82,
      "time_str": "01:55.820",
      "text": "是你的红唇粘住我的一切，",
      "translation": null
    },
    {
      "time": 120.27,
      "time_str": "02:00.270",
      "text": "是你的体贴让我再次热烈。",
      "translation": null
    },
    {
      "time": 124.78,
      "time_str": "02:04.780",
      "text": "是你的万种柔情融化冰雪，",
      "translation": null
    },
    {
      "time": 130.1,
      "time_str": "02:10.100",
      "text": "是你的甜言蜜语改变季节。",
      "translation": null
    },
