    {
      "time": 38.23,
      "time_str": "00:38.230",
      "text": "没必要回想刚刚下大雨的黄昏",
      "translation": null
    },
    {
      "time": 46.419,
      "time_str": "00:46.419",
      "text": "此刻夜空只有美丽的星辰",
      "translation": null
    },
    {
      "time": 54.019,
      "time_str": "00:54.019",
      "text": "走过了甜酸各一半的旅程",
      "translation": null
    },
    {
      "time": 61.639,
      "time_str": "01:01.639",
      "text": "我单薄的心才能变得丰盛",
      "translation": null
    },
    {
      "time": 68.439,
      "time_str": "01:08.439",
      "text": "心会累爱会冷",
      "translation": null
    },
    {
      "time": 72.118,
      "time_str": "01:12.118",
      "text": "这是感情必经的过程",
      "translation": null
    },
    {
      "time": 76.79,
      "time_str": "01:16.790",
      "text": "只是有人就放弃",
      "translation": null
    },
    {
      "time": 78.739,
      "time_str": "01:18.739",
      "text": "也有人愿意再等 等一个发现",
      "translation": null
    },
    {
      "time": 87.47,
      "time_str": "01:27.470",
      "text": "等一个感动让爱再沸腾",
      "translation": null
    },
    {
      "time": 91.28,
      "time_str": "01:31.280",
      "text": "就算很在乎自尊",
      "translation": null
    },
    {
      "time": 93.709,
      "time_str": "01:33.709",
      "text": "我们依赖彼此 不得不承认",
      "translation": null
    },
    {
      "time": 100.4,
      "time_str": "01:40.400",
      "text": "放弃自由喜欢两个人",
      "translation": null
    },
    {
      "time": 105.439,
      "time_str": "01:45.439",
      "text": "绑住的两个人",
      "translation": null
    },
    {
      "time": 109.439,
      "time_str": "01:49.439",
      "text": "互不相让还是相爱分享一生",
      "translation": null
    },
    {
      "time": 115.179,
      "time_str": "01:55.179",
      "text": "不爱热闹喜欢两个人",
      "translation": null
    },
    {
      "time": 120.67,
      "time_str": "02:00.670",
      "text": "就我们两个人",
