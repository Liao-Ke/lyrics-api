    {
      "time": 9.78,
      "time_str": "00:09.780",
      "text": "原唱：Mango Daddy",
      "translation": null
    },
    {
      "time": 19.81,
      "time_str": "00:19.810",
      "text": "我常常一个人路过",
      "translation": null
    },
    {
      "time": 26.02,
      "time_str": "00:26.020",
      "text": "车水马龙拥挤的路口",
      "translation": null
    },
    {
      "time": 32.26,
      "time_str": "00:32.260",
      "text": "此时的喧嚣",
      "translation": null
    },
    {
      "time": 36.18,
      "time_str": "00:36.180",
      "text": "已与我分割",
      "translation": null
    },
    {
      "time": 39.57,
      "time_str": "00:39.570",
      "text": "我无处可逃",
      "translation": null
    },
    {
      "time": 41.9,
      "time_str": "00:41.900",
      "text": "四处闪躲",
      "translation": null
    },
    {
      "time": 47.94,
      "time_str": "00:47.940",
      "text": "患得患失的世界",
      "translation": null
    },
    {
      "time": 54.21,
      "time_str": "00:54.210",
      "text": "有些画面却无法割舍",
      "translation": null
    },
    {
      "time": 60.32,
      "time_str": "01:00.320",
      "text": "是你永远",
      "translation": null
    },
    {
      "time": 64.088,
      "time_str": "01:04.088",
      "text": "在前方为我闪烁",
      "translation": null
    },
    {
      "time": 67.7,
      "time_str": "01:07.700",
      "text": "所有的光汇成河",
      "translation": null
    },
    {
      "time": 74.018,
      "time_str": "01:14.018",
      "text": "抬头看着星星在唱歌",
      "translation": null
    },
    {
      "time": 77.64,
      "time_str": "01:17.640",
      "text": "她的呼吸好似对我说",
      "translation": null
    },
    {
      "time": 81.33,
      "time_str": "01:21.330",
      "text": "她说你要慢慢长大",
      "translation": null
    },
    {
      "time": 83.619,
      "time_str": "01:23.619",
      "text": "不只为自己活着",
      "translation": null
    },
    {
      "time": 88.149,
      "time_str": "01:28.149",
      "text": "如果你也听见星星的歌",
      "translation": null
    },
    {
      "time": 91.709,
      "time_str": "01:31.709",
      "text": "不要哭泣不要再受折磨",
      "translation": null
    },
    {
      "time": 95.78,
      "time_str": "01:35.780",
      "text": "若你抬起头",
      "translation": null
    },
    {
      "time": 97.86,
      "time_str": "01:37.860",
      "text": "她就在天空",
      "translation": null
