  "lyrics": [
    {
      "time": 25.17,
      "time_str": "00:25.170",
      "text": "当我看见左肩破损的战衣",
      "translation": null
    },
    {
      "time": 28.84,
      "time_str": "00:28.840",
      "text": "盔甲后你的表情带着笑意",
      "translation": null
    },
    {
      "time": 30.86,
      "time_str": "00:30.860",
      "text": "想要对我说",
      "translation": null
    },
    {
      "time": 32.24,
      "time_str": "00:32.240",
      "text": "外来的袭击即将离公主远去",
      "translation": null
    },
    {
      "time": 35.07,
      "time_str": "00:35.070",
      "text": "那些令人刺耳的声音",
      "translation": null
    },
    {
      "time": 36.25,
      "time_str": "00:36.250",
      "text": "我不听我不听",
      "translation": null
    },
    {
      "time": 37.9,
      "time_str": "00:37.900",
      "text": "偏偏我又容易受影响容易伤心",
      "translation": null
    },
    {
      "time": 40.13,
      "time_str": "00:40.130",
      "text": "没有用 微笑的表面不停骗自己",
      "translation": null
    },
    {
      "time": 42.9,
      "time_str": "00:42.900",
      "text": "他们的语气",
      "translation": null
    },
    {
      "time": 43.59,
      "time_str": "00:43.590",
      "text": "好笑的攻击",
      "translation": null
    },
    {
      "time": 43.92,
      "time_str": "00:43.920",
      "text": "自卑的心理",
      "translation": null
    },
    {
      "time": 44.78,
      "time_str": "00:44.780",
      "text": "四年来",
      "translation": null
    },
    {
      "time": 45.44,
      "time_str": "00:45.440",
      "text": "带着各种面具想让你我孤立",
      "translation": null
    },
    {
      "time": 48.62,
      "time_str": "00:48.620",
      "text": "莫名其妙那些话语",
      "translation": null
    },
    {
      "time": 49.83,
      "time_str": "00:49.830",
      "text": "莫名其妙那些话语",
      "translation": null
    },
    {
      "time": 51.03,
      "time_str": "00:51.030",
      "text": "如同沙子掉进眼里",
      "translation": null
    },
    {
      "time": 52.41,
      "time_str": "00:52.410",
      "text": "不用哭泣",
      "translation": null
    },
    {
      "time": 53.78,
      "time_str": "00:53.780",
      "text": "莫名其妙那些话语",
      "translation": null
    },
    {
      "time": 55.16,
      "time_str": "00:55.160",
      "text": "莫名其妙那些话语",
      "translation": null
    },
    {
      "time": 56.29,
      "time_str": "00:56.290",
      "text": "不如下档电影",
      "translation": null
    },
    {
      "time": 57.31,
      "time_str": "00:57.310",
      "text": "值得注意",
      "translation": null
    },
    {
      "time": 58.91,
      "time_str": "00:58.910",
      "text": "我 不要王子",
      "translation": null
    },
    {
      "time": 60.1,
      "time_str": "01:00.100",
      "text": "苦苦守候的故事",
      "translation": null
    },
    {
      "time": 61.82,
      "time_str": "01:01.820",
      "text": "梦幻不实",
      "translation": null
    },
    {
      "time": 62.53,
      "time_str": "01:02.530",
      "text": "我不希望 你是王子",
      "translation": null
    },
    {
      "time": 64.42,
      "time_str": "01:04.420",
      "text": "因为瑰丽童话结局",
      "translation": null
    },
    {
      "time": 65.84,
      "time_str": "01:05.840",
      "text": "为战而死",
      "translation": null
    },
    {
      "time": 67.06,
      "time_str": "01:07.060",
      "text": "故事开端结局会因你而真实",
      "translation": null
    },
    {
      "time": 80.05,
      "time_str": "01:20.050",
      "text": "像骑士的忠贞",
      "translation": null
    },
    {
      "time": 81.24,
      "time_str": "01:21.240",
      "text": "不畏惧邪恶的眼神",
      "translation": null
    },
    {
      "time": 82.97,
      "time_str": "01:22.970",
      "text": "这过程",
      "translation": null
    },
    {
      "time": 84.01,
      "time_str": "01:24.010",
      "text": "一直放在我心底",
      "translation": null
    },
    {
      "time": 85.44,
      "time_str": "01:25.440",
      "text": "就像挡在你胸前的盔甲",
      "translation": null
    },
    {
      "time": 88.36,
      "time_str": "01:28.360",
      "text": "保护着我",
      "translation": null
    },
    {
      "time": 89.65,
      "time_str": "01:29.650",
      "text": "让我心疼",
      "translation": null
    },
    {
      "time": 91.05,
      "time_str": "01:31.050",
      "text": "骑士们发挥出你们的精神",
      "translation": null
    },
    {
      "time": 93.65,
      "time_str": "01:33.650",
      "text": "就这样",
      "translation": null
    },
    {
      "time": 94.67,
      "time_str": "01:34.670",
      "text": "强悍的骑士撑到最后",
      "translation": null
    },
    {
      "time": 96.46,
      "time_str": "01:36.460",
      "text": "骄傲的公主要回家",
      "translation": null
    },
    {
      "time": 98.91,
      "time_str": "01:38.910",
      "text": "整装再出发",
      "translation": null
    },
