      "time": 37.06,
      "time_str": "00:37.060",
      "text": "第一次你陪我坐着",
      "translation": null
    },
    {
      "time": 41.87,
      "time_str": "00:41.870",
      "text": "我的手心是空空的",
      "translation": null
    },
    {
      "time": 45.59,
      "time_str": "00:45.590",
      "text": "我知道那些简讯声你努力藏着",
      "translation": null
    },
    {
      "time": 50.5,
      "time_str": "00:50.500",
      "text": "还怕我难过",
      "translation": null
