      "time_str": "01:10.805",
      "text": "相信总会有一天",
      "translation": null
    },
    {
      "time": 73.85,
      "time_str": "01:13.850",
      "text": "你一定会离去",
      "translation": null
    },
    {
      "time": 77.556,
      "time_str": "01:17.556",
      "text": "但明天你是否依然爱我",
