      "text": "没有什么能够阻挡",
      "translation": null
    },
    {
      "time": 105.128,
      "time_str": "01:45.128",
      "text": "你对自由的向往",
      "translation": null
    },
    {
      "time": 110.189,
      "time_str": "01:50.189",
      "text": "天马行空的生涯",
      "translation": null
    },
    {
      "time": 116.128,
      "time_str": "01:56.128",
      "text": "你的心了无牵挂",
      "translation": null
    },
    {
      "time": 121.55,
