  "lyrics": [
    {
      "time": 29.879,
      "time_str": "00:29.879",
      "text": "讨论一下你为什么不快乐",
      "translation": null
    },
    {
      "time": 32.368,
      "time_str": "00:32.368",
      "text": "我们看看幸福手册上它说些什么",
      "translation": null
    },
    {
      "time": 35.727,
      "time_str": "00:35.727",
      "text": "你照它去做 会也收获很多",
      "translation": null
    },
    {
      "time": 40.08,
      "time_str": "00:40.080",
      "text": "别让快乐走了 噢 吧 吧 吧",
      "translation": null
    },
    {
      "time": 43.489,
      "time_str": "00:43.489",
      "text": "不要守着难题总是很忧郁",
      "translation": null
    },
    {
      "time": 45.789,
      "time_str": "00:45.789",
      "text": "命运安排我们日子都有许多坎坷",
      "translation": null
    },
    {
      "time": 50.208,
      "time_str": "00:50.208",
      "text": "如果发现错了 就马上改过",
      "translation": null
    },
    {
      "time": 54.089,
      "time_str": "00:54.089",
      "text": "别让快乐走了噢 吧 吧 吧",
      "translation": null
    },
    {
      "time": 57.018,
      "time_str": "00:57.018",
      "text": "不贪不占 你会快乐",
      "translation": null
    },
    {
      "time": 59.007,
      "time_str": "00:59.007",
      "text": "不抽少喝 你会快乐",
      "translation": null
    },
    {
      "time": 60.88,
      "time_str": "01:00.880",
      "text": "清清白白 你会快乐",
      "translation": null
    },
    {
      "time": 62.347,
      "time_str": "01:02.347",
      "text": "善待朋友 你会快乐",
      "translation": null
    },
    {
      "time": 64.78,
      "time_str": "01:04.780",
      "text": "孝敬老人 你会快乐",
      "translation": null
    },
    {
      "time": 66.588,
      "time_str": "01:06.588",
      "text": "有了爱情 你会快乐",
      "translation": null
    },
    {
      "time": 68.48,
      "time_str": "01:08.480",
      "text": "好的心情总是让你快快乐乐",
      "translation": null
    },
    {
      "time": 71.668,
      "time_str": "01:11.668",
      "text": "你笑一笑它很容易",
      "translation": null
    },
    {
      "time": 74.68,
      "time_str": "01:14.680",
      "text": "不要忧郁不要灰心和叹息",
      "translation": null
    },
    {
      "time": 78.068,
      "time_str": "01:18.068",
      "text": "用你的真心和你的感激",
      "translation": null
    },
    {
      "time": 81.489,
      "time_str": "01:21.489",
      "text": "有了知已有了幸福和甜蜜",
      "translation": null
    },
    {
      "time": 86.38,
      "time_str": "01:26.380",
      "text": "别让那快乐走了 吧 吧 吧吧吧吧",
