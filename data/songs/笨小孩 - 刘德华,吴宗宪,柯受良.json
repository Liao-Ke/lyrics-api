    "arranger": "江建民"
  },
  "lyrics": [
    {
      "time": 24.124,
      "time_str": "00:24.124",
      "text": "哦哦哦 宁静的小村外 有一个笨小孩",
      "translation": null
    },
    {
      "time": 27.782,
      "time_str": "00:27.782",
      "text": "出生在六零年代",
      "translation": null
    },
    {
      "time": 30.76,
      "time_str": "00:30.760",
      "text": "十来岁到城市 不怕那太阳晒",
      "translation": null
    },
    {
      "time": 33.764,
      "time_str": "00:33.764",
      "text": "努力在七零年代",
      "translation": null
    },
    {
      "time": 36.82,
      "time_str": "00:36.820",
      "text": "发现呀城市里 朋友们不用去灌溉",
      "translation": null
    },
    {
      "time": 42.724,
      "time_str": "00:42.724",
      "text": "花自然会开",
      "translation": null
    },
    {
      "time": 47.922,
      "time_str": "00:47.922",
      "text": "哦哦哦 转眼间那么快 这一个笨小孩",
      "translation": null
    },
    {
      "time": 51.631,
      "time_str": "00:51.631",
      "text": "又到了八零年代",
      "translation": null
    },
    {
      "time": 54.505,
      "time_str": "00:54.505",
      "text": "三十岁到头来 不算好也不坏",
      "translation": null
    },
    {
      "time": 57.561,
      "time_str": "00:57.561",
      "text": "经过了九零年代",
      "translation": null
    },
    {
      "time": 60.539,
      "time_str": "01:00.539",
      "text": "最无奈他自己 总是会慢人家一拍",
      "translation": null
    },
    {
      "time": 66.495,
      "time_str": "01:06.495",
      "text": "没有钱在那口袋",
      "translation": null
    },
    {
      "time": 71.615,
      "time_str": "01:11.615",
      "text": "哎哟 往着胸口拍一拍呀 勇敢站起来",
      "translation": null
    },
    {
      "time": 78.407,
      "time_str": "01:18.407",
      "text": "不用心情太坏",
      "translation": null
    },
    {
      "time": 83.501,
      "time_str": "01:23.501",
      "text": "哎哟 向着天空拜一拜呀 别想不开",
      "translation": null
    },
    {
      "time": 90.371,
      "time_str": "01:30.371",
      "text": "老天自有安排",
      "translation": null
    },
    {
      "time": 102.204,
      "time_str": "01:42.204",
      "text": "笨小孩跟聪明的小孩有没有什么分别",
      "translation": null
    },
    {
      "time": 105.574,
      "time_str": "01:45.574",
      "text": "当然有分别啦，聪明的小孩很厉害的啦",
      "translation": null
    },
    {
      "time": 109.571,
      "time_str": "01:49.571",
      "text": "只是笨小孩也很可爱的",
      "translation": null
    },
    {
      "time": 119.602,
      "time_str": "01:59.602",
      "text": "哦哦哦 他们说城市里 男不坏女不爱",
      "translation": null
    },
    {
      "time": 126.159,
      "time_str": "02:06.159",
      "text": "怎么想也不明白",
      "translation": null
    },
    {
      "time": 129.032,
      "time_str": "02:09.032",
      "text": "妈妈说真心爱 会爱得很精彩",
      "translation": null
    },
    {
      "time": 132.089,
      "time_str": "02:12.089",
      "text": "结果我没有女孩",
      "translation": null
    },
    {
      "time": 135.014,
      "time_str": "02:15.014",
      "text": "笨小孩依然是坚强得像石头一块",
      "translation": null
    },
    {
      "time": 140.657,
      "time_str": "02:20.657",
      "text": "只是晚上寂寞难耐",
      "translation": null
    },
    {
      "time": 146.142,
      "time_str": "02:26.142",
      "text": "哎哟 往着胸口拍一拍呀 勇敢站起来",
      "translation": null
    },
    {
      "time": 152.882,
      "time_str": "02:32.882",
      "text": "不用心情太坏",
      "translation": null
    },
    {
      "time": 158.185,
      "time_str": "02:38.185",
      "text": "哎哟 向着天空拜一拜呀 别想不开",
      "translation": null
    },
    {
      "time": 164.794,
      "time_str": "02:44.794",
      "text": "老天自有安排",
      "translation": null
    },
    {
      "time": 170.123,
      "time_str": "02:50.123",
      "text": "哎哟 往着胸口拍一拍呀 勇敢站起来",
      "translation": null
    },
    {
      "time": 176.758,
      "time_str": "02:56.758",
      "text": "管它上山下海",
      "translation": null
    },
    {
      "time": 181.956,
      "time_str": "03:01.956",
      "text": "哎哟 向着天空拜一拜呀 别想不开",
      "translation": null
    },
    {
      "time": 188.722,
      "time_str": "03:08.722",
      "text": "老天自有安排",
      "translation": null
    },
    {
      "time": 194.6,
      "time_str": "03:14.600",
      "text": "老天爱笨小孩",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "笨小孩 - 刘德华,吴宗宪,柯受良.lrc"
