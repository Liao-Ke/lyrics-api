{
  "title": "笨小孩",
  "title_raw": "笨小孩",
  "version": null,
  "artist": "刘德华,吴宗宪,柯受良",
  "group_key": "笨小孩|刘德华,吴宗宪,柯受良",
  "writers": {
    "lyricist": "刘德华",
