    {
      "time": 3.75,
      "time_str": "00:03.750",
      "text": "每一次想起都让我无法呼吸",
      "translation": null
    },
    {
      "time": 11.25,
      "time_str": "00:11.250",
      "text": "总是会放开七月七里的日记",
      "translation": null
    },
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "那年七月七 你和我的相遇",
      "translation": null
    },
    {
      "time": 28.93,
      "time_str": "00:28.930",
      "text": "我以为是命里注定",
      "translation": null
    },
    {
      "time": 36.25,
      "time_str": "00:36.250",
      "text": "随手写下 属于我们的奇迹",
      "translation": null
    },
    {
      "time": 43.45,
      "time_str": "00:43.450",
      "text": "让牛郎织女来证明",
      "translation": null
    },
    {
      "time": 50.93,
      "time_str": "00:50.930",
      "text": "又是七月七 没有你的消息",
      "translation": null
    },
    {
      "time": 58.44,
      "time_str": "00:58.440",
      "text": "难道也是命里注定",
      "translation": null
    },
    {
      "time": 65.84,
      "time_str": "01:05.840",
      "text": "只有我自己 和手里的日记",
      "translation": null
    },
    {
      "time": 73.1,
      "time_str": "01:13.100",
      "text": "已变成伤心的旋律",
      "translation": null
    },
    {
