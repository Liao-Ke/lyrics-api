    },
    {
      "time": 116.21,
      "time_str": "01:56.210",
      "text": "或是听觉卑微不前",
      "translation": null
    },
    {
      "time": 121.16,
      "time_str": "02:01.160",
      "text": "我自己问自己 退路已在原地",
