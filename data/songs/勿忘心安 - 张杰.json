  "lyrics": [
    {
      "time": 14.26,
      "time_str": "00:14.260",
      "text": "不要再逗留 人心太拥挤",
      "translation": null
    },
    {
      "time": 21.65,
      "time_str": "00:21.650",
      "text": "被混乱的游戏或是真理的命运",
      "translation": null
    },
    {
      "time": 28.8,
      "time_str": "00:28.800",
      "text": "我自己问自己 完成到这里",
      "translation": null
    },
    {
      "time": 36.39,
      "time_str": "00:36.390",
      "text": "到底还剩多少不用挣扎的阴霾",
      "translation": null
    },
    {
      "time": 43.72,
      "time_str": "00:43.720",
      "text": "只是无奈这些问题 无人交流",
      "translation": null
    },
    {
      "time": 52.3,
      "time_str": "00:52.300",
      "text": "只好任凭生命去阻碍",
      "translation": null
    },
    {
      "time": 58.49,
      "time_str": "00:58.490",
      "text": "中途的放纵 才选错了出口",
      "translation": null
    },
    {
      "time": 66.17,
      "time_str": "01:06.170",
      "text": "泛滥的欲望无邪 却沦为成烂醉",
      "translation": null
    },
    {
      "time": 73.16,
      "time_str": "01:13.160",
      "text": "早已该放手 这无休的阴谋",
      "translation": null
    },
    {
      "time": 80.72,
      "time_str": "01:20.720",
      "text": "玩笑已过半 不由不该",
      "translation": null
    },
    {
      "time": 87.96,
      "time_str": "01:27.960",
      "text": "路还有汗流 梦还没腐朽",
      "translation": null
    },
    {
      "time": 95.49,
      "time_str": "01:35.490",
      "text": "命运到最后 勿忘心安",
      "translation": null
    },
    {
      "time": 106.66,
      "time_str": "01:46.660",
      "text": "不要再逗留 人心太闪躲",
      "translation": null
