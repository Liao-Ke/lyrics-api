  "lyrics": [
    {
      "time": 0.4,
      "time_str": "00:00.400",
      "text": "Talking to the moon 悔恨讲不出口",
      "translation": null
    },
    {
      "time": 3.9,
      "time_str": "00:03.900",
      "text": "每夜也在想你 这内心的小偷",
      "translation": null
    },
    {
      "time": 8.2,
      "time_str": "00:08.200",
      "text": "Walking on the roof 困在漆黑山丘",
      "translation": null
    },
    {
      "time": 11.48,
      "time_str": "00:11.480",
      "text": "我或继续心跳 噩梦却在静候",
      "translation": null
    },
    {
      "time": 16.34,
      "time_str": "00:16.340",
      "text": "又看着已是满地酒瓶",
      "translation": null
    },
    {
      "time": 18.9,
      "time_str": "00:18.900",
      "text": "烟里吞吐不停 叫着也未懂回应",
      "translation": null
    },
    {
      "time": 23.96,
      "time_str": "00:23.960",
      "text": "日记上说着那日天晴",
      "translation": null
    },
    {
      "time": 26.5,
      "time_str": "00:26.500",
      "text": "故事里极深情 因我不太清醒",
      "translation": null
    },
    {
      "time": 31.08,
      "time_str": "00:31.080",
      "text": "夜幕国度再没有白昼风景",
      "translation": null
    },
    {
      "time": 35.24,
      "time_str": "00:35.240",
      "text": "像是散聚以后陨落了的星",
      "translation": null
    },
    {
      "time": 39.01,
      "time_str": "00:39.010",
      "text": "尽力了但永未化掉你的冰",
      "translation": null
    },
    {
      "time": 42.76,
      "time_str": "00:42.760",
      "text": "现实面对怕我已置身幽冥",
      "translation": null
    },
    {
      "time": 45.73,
      "time_str": "00:45.730",
      "text": "Talking to the moon 悔恨讲不出口",
      "translation": null
    },
    {
      "time": 48.78,
      "time_str": "00:48.780",
      "text": "每夜也在想你 这内心的小偷",
      "translation": null
    },
    {
      "time": 52.88,
      "time_str": "00:52.880",
      "text": "Walking on the roof 困在漆黑山丘",
      "translation": null
    },
    {
      "time": 56.47,
      "time_str": "00:56.470",
      "text": "我或继续心跳 噩梦却在静候",
      "translation": null
    },
    {
      "time": 60.55,
      "time_str": "01:00.550",
      "text": "Waiting in the cool 枫叶转色初秋",
      "translation": null
    },
    {
      "time": 64.05,
      "time_str": "01:04.050",
      "text": "纵是幼稚当晚 注定争吵不休",
      "translation": null
    },
    {
      "time": 68.35,
      "time_str": "01:08.350",
      "text": "Feeling is so fool 你若牵他的手",
      "translation": null
    },
    {
      "time": 71.65,
      "time_str": "01:11.650",
      "text": "往事化做乌有 放下告别念旧",
      "translation": null
    },
    {
      "time": 75.43,
      "time_str": "01:15.430",
      "text": "如走音的协奏 旧CD生了锈",
      "translation": null
    },
    {
      "time": 79.31,
      "time_str": "01:19.310",
      "text": "未解锁的铁扣 是回忆中的某某",
      "translation": null
    },
    {
      "time": 83.03,
      "time_str": "01:23.030",
      "text": "无止境的占有 像魔鬼的引诱",
      "translation": null
    },
    {
      "time": 86.96,
      "time_str": "01:26.960",
      "text": "人懵懂不看透 然而分开方知不够",
      "translation": null
    },
    {
      "time": 90.92,
      "time_str": "01:30.920",
      "text": "唱悲伤的歌可治愈这伤口",
      "translation": null
    },
    {
      "time": 94.58,
      "time_str": "01:34.580",
      "text": "害怕略带感情而又上心头",
      "translation": null
    },
    {
      "time": 98.33,
      "time_str": "01:38.330",
      "text": "再兜兜转转也是没法出走",
      "translation": null
    },
    {
      "time": 102.03,
      "time_str": "01:42.030",
      "text": "恨我又会想象是爱过的讲有没有",
      "translation": null
    },
