    {
      "time": 0.329,
      "time_str": "00:00.329",
      "text": "张学友-想和你去吹吹风",
      "translation": null
    },
    {
      "time": 5.555,
      "time_str": "00:05.555",
      "text": "想和你再去吹吹风",
      "translation": null
    },
    {
      "time": 8.891,
      "time_str": "00:08.891",
      "text": "虽然已是不同时空",
      "translation": null
    },
    {
      "time": 13.64,
      "time_str": "00:13.640",
      "text": "还是可以迎著风",
      "translation": null
    },
    {
      "time": 16.265,
      "time_str": "00:16.265",
      "text": "随意说说心里的梦",
      "translation": null
    },
    {
      "time": 39.686,
      "time_str": "00:39.686",
      "text": "感情浮浮沈沈",
      "translation": null
    },
    {
      "time": 43.404,
      "time_str": "00:43.404",
      "text": "世事颠颠倒倒",
      "translation": null
    },
    {
      "time": 47.445,
      "time_str": "00:47.445",
      "text": "一颗心硬硬冷冷",
      "translation": null
    },
    {
      "time": 50.823,
      "time_str": "00:50.823",
      "text": "感动愈来愈少",
      "translation": null
    },
    {
      "time": 54.716,
      "time_str": "00:54.716",
      "text": "繁华色彩光影",
      "translation": null
    },
    {
      "time": 58.297,
      "time_str": "00:58.297",
      "text": "谁不为它迷倒",
      "translation": null
    },
    {
      "time": 62.28,
      "time_str": "01:02.280",
      "text": "笑眼泪光看自己",
      "translation": null
    },
    {
      "time": 65.974,
      "time_str": "01:05.974",
      "text": "感觉有些寂寥",
      "translation": null
    },
    {
      "time": 68.905,
      "time_str": "01:08.905",
      "text": "想起你爱恨",
      "translation": null
    },
    {
      "time": 69.99,
      "time_str": "01:09.990",
      "text": "早已不再萦绕",
      "translation": null
    },
    {
      "time": 73.155,
      "time_str": "01:13.155",
      "text": "那情份还有些味道",
      "translation": null
    },
    {
      "time": 76.857,
      "time_str": "01:16.857",
      "text": "喜怒哀乐依然围绕",
      "translation": null
    },
    {
      "time": 80.588,
      "time_str": "01:20.588",
      "text": "能分享的人哪里去寻找",
      "translation": null
    },
    {
      "time": 83.69,
      "time_str": "01:23.690",
      "text": "很想和你再去吹吹风",
      "translation": null
    },
    {
      "time": 87.355,
      "time_str": "01:27.355",
      "text": "去吹吹风",
      "translation": null
    },
    {
      "time": 91.727,
      "time_str": "01:31.727",
      "text": "风会带走一些短暂的轻松",
      "translation": null
    },
    {
      "time": 99.683,
      "time_str": "01:39.683",
      "text": "让我们像从前一样安安静静",
