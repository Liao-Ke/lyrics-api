  "lyrics": [
    {
      "time": 15.99,
      "time_str": "00:15.990",
      "text": "每次走过这间咖啡屋",
      "translation": null
    },
    {
      "time": 18.99,
      "time_str": "00:18.990",
      "text": "忍不住慢下了脚步",
      "translation": null
    },
    {
      "time": 23.37,
      "time_str": "00:23.370",
      "text": "你我初次相识在这里",
      "translation": null
    },
    {
      "time": 26.34,
      "time_str": "00:26.340",
      "text": "揭开了相悦的序幕",
      "translation": null
    },
    {
      "time": 30.72,
      "time_str": "00:30.720",
      "text": "今天你不再是座上客",
      "translation": null
    },
    {
      "time": 33.75,
      "time_str": "00:33.750",
      "text": "我也就恢复了孤独",
      "translation": null
    },
    {
      "time": 38.25,
      "time_str": "00:38.250",
      "text": "不知什么缘故使我俩",
      "translation": null
    },
    {
      "time": 41.13,
      "time_str": "00:41.130",
      "text": "由情侣变成了陌路",
      "translation": null
    },
    {
      "time": 44.85,
      "time_str": "00:44.850",
      "text": "芳香的咖啡飘满小屋",
      "translation": null
    },
    {
      "time": 48.63,
      "time_str": "00:48.630",
      "text": "对你的情感依然如故",
      "translation": null
    },
    {
      "time": 52.38,
      "time_str": "00:52.380",
      "text": "不知道何时再续前缘",
      "translation": null
    },
    {
      "time": 55.98,
      "time_str": "00:55.980",
      "text": "让我把思念向你倾诉",
      "translation": null
    },
    {
