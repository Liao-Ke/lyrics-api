  "lyrics": [
    {
      "time": 19.3,
      "time_str": "00:19.300",
      "text": "煤气灯不禁影照 街里一对蚯蚓",
      "translation": null
    },
    {
      "time": 24.91,
      "time_str": "00:24.910",
      "text": "照过以俩心相亲 一对小情人",
      "translation": null
    },
    {
      "time": 29.94,
      "time_str": "00:29.940",
      "text": "沉默以拥吻抵抗 一切的冰与冷",
      "translation": null
    },
    {
      "time": 34.96,
      "time_str": "00:34.960",
      "text": "晚意借北风 轻轻的飘起长长裙",
      "translation": null
    },
    {
      "time": 40.05,
      "time_str": "00:40.050",
      "text": "多温馨 心里 风中那笑声 淌泪",
      "translation": null
    },
    {
      "time": 50.29,
      "time_str": "00:50.290",
      "text": "尝尽了失意的我 将一切都褪去",
      "translation": null
    },
    {
      "time": 55.17,
      "time_str": "00:55.170",
      "text": "再到这风中心中 竟仿似伤痕累累",
      "translation": null
    },
    {
      "time": 60.58,
      "time_str": "01:00.580",
      "text": "然后再忆记起 当晚跟你在这里",
      "translation": null
    },
    {
      "time": 65.41,
      "time_str": "01:05.410",
      "text": "相依相拥中 交出的心早已失去",
      "translation": null
    },
    {
      "time": 73.53,
      "time_str": "01:13.530",
      "text": "失去 已破碎 不可以再追 洒泪",
      "translation": null
    },
    {
      "time": 79.48,
      "time_str": "01:19.480",
      "text": "Don't worry Don't worry Baby",
      "translation": null
    },
    {
      "time": 83.94,
      "time_str": "01:23.940",
      "text": "今天今天星闪闪",
      "translation": null
    },
    {
      "time": 88.05,
      "time_str": "01:28.050",
      "text": "剩下我北风中 漆黑中带着泪",
      "translation": null
    },
    {
      "time": 93.53,
      "time_str": "01:33.530",
      "text": "念当天当天 跟他一起的每天",
      "translation": null
    },
    {
      "time": 104.11,
      "time_str": "01:44.110",
      "text": "今天今天星闪闪",
      "translation": null
    },
    {
      "time": 108.3,
      "time_str": "01:48.300",
      "text": "剩下我漆黑中 北风中带泪悼念",
      "translation": null
    },
    {
      "time": 113.3,
      "time_str": "01:53.300",
      "text": "当天的心 欢欣 再也再也再也不见",
      "translation": null
    },
    {
      "time": 126.05,
      "time_str": "02:06.050",
      "text": "一切已失去 不可以再追",
      "translation": null
