      "text": "不放开手到永久",
      "translation": null
    },
    {
      "time": 238.56,
      "time_str": "03:58.560",
      "text": "我们要一起生活",
      "translation": null
    },
    {
      "time": 241.15,
      "time_str": "04:01.150",
      "text": "没有办法想象 那画面",
      "translation": null
    },
    {
      "time": 243.75,
      "time_str": "04:03.750",
      "text": "一个孤独的背影走在 小公园",
      "translation": null
    },
    {
      "time": 246.14,
      "time_str": "04:06.140",
      "text": "一颗心 需要暖 一双手 需要牵",
      "translation": null
    },
    {
      "time": 249.14,
      "time_str": "04:09.140",
      "text": "故事要有美好结局 需要两双手来写",
      "translation": null
    },
    {
      "time": 252.35,
      "time_str": "04:12.350",
      "text": "永远 不是只出现在童话里的梦",
      "translation": null
    },
    {
      "time": 255.17,
      "time_str": "04:15.170",
      "text": "在身边 眼泪加了蜜糖甜",
      "translation": null
    },
    {
      "time": 257.169,
      "time_str": "04:17.169",
      "text": "这句点 要完美画在无名指上",
      "translation": null
    },
    {
      "time": 260.4,
      "time_str": "04:20.400",
      "text": "承诺的开始",
      "translation": null
    },
    {
      "time": 261.359,
      "time_str": "04:21.359",
      "text": "恋人们 要一起珍藏",
      "translation": null
    }
