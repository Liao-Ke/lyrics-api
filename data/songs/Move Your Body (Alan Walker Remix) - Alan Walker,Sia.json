    {
      "time": 17.18,
      "time_str": "00:17.180",
      "text": "And can't you see it's you I'm watching?",
      "translation": "你看不见我在注视着你？"
    },
    {
      "time": 19.17,
      "time_str": "00:19.170",
      "text": "I am hot for you in every way",
      "translation": "我为你的一切感到痴迷"
    },
    {
      "time": 24.63,
      "time_str": "00:24.630",
      "text": "And turn around, let me see you",
      "translation": "转过身来，让我仔细看看你"
    },
    {
      "time": 26.69,
      "time_str": "00:26.690",
      "text": "Wanna free you with my rhythm",
      "translation": "想要你跟随着我的节奏嗨翻天"
    },
    {
      "time": 32.2,
      "time_str": "00:32.200",
      "text": "I know you can't get enough",
