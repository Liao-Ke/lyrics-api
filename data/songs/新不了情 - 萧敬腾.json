  "lyrics": [
    {
      "time": 13.15,
      "time_str": "00:13.150",
      "text": "心若倦了泪也干了",
      "translation": null
    },
    {
      "time": 20.77,
      "time_str": "00:20.770",
      "text": "这份深情难舍难了",
      "translation": null
    },
    {
      "time": 27.46,
      "time_str": "00:27.460",
      "text": "曾经拥有天荒地老",
      "translation": null
    },
    {
      "time": 35.0,
      "time_str": "00:35.000",
      "text": "已不见你暮暮与朝朝",
      "translation": null
    },
    {
      "time": 41.7,
      "time_str": "00:41.700",
      "text": "这一份情永远难了",
      "translation": null
    },
    {
      "time": 48.87,
      "time_str": "00:48.870",
      "text": "愿来生还能再度拥抱",
      "translation": null
    },
    {
      "time": 55.52,
      "time_str": "00:55.520",
      "text": "爱一个人如何厮守到老",
      "translation": null
    },
    {
      "time": 62.71,
      "time_str": "01:02.710",
      "text": "怎样面对一切我不知道",
      "translation": null
    },
    {
      "time": 69.65,
      "time_str": "01:09.650",
      "text": "回忆过去痛苦的相思忘不了",
      "translation": null
    },
    {
      "time": 76.99,
      "time_str": "01:16.990",
      "text": "为何你还来拨动我心跳",
      "translation": null
    },
    {
      "time": 82.96,
      "time_str": "01:22.960",
      "text": "爱你怎么能了今夜的你应该明了",
      "translation": null
    },
    {
      "time": 91.18,
      "time_str": "01:31.180",
      "text": "缘难了情难了",
      "translation": null
