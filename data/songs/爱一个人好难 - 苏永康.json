  "lyrics": [
    {
      "time": 19.999,
      "time_str": "00:19.999",
      "text": "你说你还是喜欢孤单",
      "translation": null
    },
    {
      "time": 26.359,
      "time_str": "00:26.359",
      "text": "其实你怕被我看穿",
      "translation": null
    },
    {
      "time": 32.899,
      "time_str": "00:32.899",
      "text": "你怕属于我们的船，飘飘荡荡靠不了岸",
      "translation": null
    },
    {
      "time": 43.999,
      "time_str": "00:43.999",
      "text": "事到如今没有答案",
      "translation": null
    },
    {
      "time": 50.699,
      "time_str": "00:50.699",
      "text": "我的真心为你牵绊",
      "translation": null
    },
    {
      "time": 58.09,
      "time_str": "00:58.090",
      "text": "不管相见的夜多么难堪",
      "translation": null
    },
    {
      "time": 62.999,
      "time_str": "01:02.999",
      "text": "简简单单的说爱是不爱",
      "translation": null
    },
    {
      "time": 69.59,
      "time_str": "01:09.590",
      "text": "想要把你忘记真的好难",
      "translation": null
    },
    {
      "time": 75.59,
      "time_str": "01:15.590",
      "text": "思念的痛在我心里纠缠",
      "translation": null
    },
    {
      "time": 80.999,
      "time_str": "01:20.999",
      "text": "朝朝暮暮的期盼",
      "translation": null
    },
    {
      "time": 84.99,
      "time_str": "01:24.990",
      "text": "永远没有答案",
      "translation": null
    },
    {
      "time": 88.199,
      "time_str": "01:28.199",
      "text": "为何当初你选择一刀两断",
      "translation": null
    },
    {
      "time": 93.799,
      "time_str": "01:33.799",
      "text": "听你说声爱我真的好难",
      "translation": null
    },
    {
      "time": 99.499,
      "time_str": "01:39.499",
      "text": "曾经说过的话风吹云散",
      "translation": null
    },
    {
      "time": 105.899,
      "time_str": "01:45.899",
      "text": "站在天平的两端一样的为难",
      "translation": null
    },
    {
      "time": 112.599,
      "time_str": "01:52.599",
      "text": "唯一的答案",
      "translation": null
    },
    {
