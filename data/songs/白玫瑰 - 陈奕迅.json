    {
      "time": 15.54,
      "time_str": "00:15.540",
      "text": "白如白牙热情被吞噬",
      "translation": null
    },
    {
      "time": 18.19,
      "time_str": "00:18.190",
      "text": "香槟早挥发得彻底",
      "translation": null
    },
    {
      "time": 22.89,
      "time_str": "00:22.890",
      "text": "白如白蛾潜回红尘俗世",
      "translation": null
    },
    {
      "time": 25.9,
      "time_str": "00:25.900",
      "text": "俯瞰过灵位",
      "translation": null
    },
    {
      "time": 29.35,
      "time_str": "00:29.350",
      "text": "但是爱骤变芥蒂后",
      "translation": null
    },
    {
      "time": 33.12,
      "time_str": "00:33.120",
      "text": "如同肮脏污秽不要提",
      "translation": null
    },
    {
      "time": 35.41,
      "time_str": "00:35.410",
      "text": "沉默带笑玫瑰",
      "translation": null
    },
    {
      "time": 38.82,
      "time_str": "00:38.820",
      "text": "带刺回礼 只信任防卫",
      "translation": null
    },
    {
      "time": 43.97,
      "time_str": "00:43.970",
      "text": "怎么冷酷却仍然美丽",
      "translation": null
    },
    {
      "time": 47.63,
      "time_str": "00:47.630",
      "text": "得不到的从来矜贵",
      "translation": null
    },
    {
      "time": 51.4,
      "time_str": "00:51.400",
      "text": "身处劣势如何不攻心计",
      "translation": null
    },
    {
      "time": 55.45,
      "time_str": "00:55.450",
      "text": "流露敬畏试探你的法规",
      "translation": null
    },
    {
      "time": 58.88,
      "time_str": "00:58.880",
      "text": "即使恶梦却仍然绮丽",
      "translation": null
    },
    {
      "time": 62.6,
      "time_str": "01:02.600",
      "text": "甘心垫底衬你的高贵",
      "translation": null
    },
    {
      "time": 66.42,
      "time_str": "01:06.420",
      "text": "一撮玫瑰无疑心的丧礼",
      "translation": null
    },
    {
      "time": 70.59,
      "time_str": "01:10.590",
      "text": "前事作废当爱已经流逝",
      "translation": null
    },
    {
      "time": 73.91,
      "time_str": "01:13.910",
      "text": "下一世",
      "translation": null
    },
    {
