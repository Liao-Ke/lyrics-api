    {
      "time": 18.2,
      "time_str": "00:18.200",
      "text": "分手到底是不是你要的结果",
      "translation": null
    },
    {
      "time": 24.02,
      "time_str": "00:24.020",
      "text": "给不了我太多还不准我难过",
      "translation": null
    },
    {
      "time": 31.64,
      "time_str": "00:31.640",
      "text": "不知道是为了什么",
      "translation": null
    },
    {
      "time": 35.26,
      "time_str": "00:35.260",
      "text": "还要把你无力的爱 记得那么多",
      "translation": null
    },
    {
      "time": 42.07,
      "time_str": "00:42.070",
      "text": "怎么放手",
      "translation": null
    },
    {
      "time": 46.82,
      "time_str": "00:46.820",
      "text": "也许上天安排你我擦身而过",
      "translation": null
    },
    {
      "time": 53.01,
      "time_str": "00:53.010",
      "text": "我明白和你的爱不可能会有结果",
      "translation": null
    },
    {
      "time": 60.74,
      "time_str": "01:00.740",
      "text": "你留下泛黄的承诺",
