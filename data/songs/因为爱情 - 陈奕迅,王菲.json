    {
      "time": 11.739,
      "time_str": "00:11.739",
      "text": "给你一张过去的CD",
      "translation": null
    },
    {
      "time": 16.299,
      "time_str": "00:16.299",
      "text": "听听那时我们的爱情",
      "translation": null
    },
    {
      "time": 21.34,
      "time_str": "00:21.340",
      "text": "有时会突然忘了我还在爱着你",
      "translation": null
    },
    {
      "time": 33.39,
      "time_str": "00:33.390",
      "text": "再唱不出那样的歌曲",
      "translation": null
    },
    {
      "time": 37.69,
      "time_str": "00:37.690",
      "text": "听到都会红着脸躲避",
      "translation": null
    },
    {
      "time": 43.14,
      "time_str": "00:43.140",
      "text": "虽然会经常忘了我依然爱着你",
      "translation": null
    },
    {
      "time": 53.79,
      "time_str": "00:53.790",
      "text": "因为爱情 不会轻易悲伤",
      "translation": null
    },
    {
      "time": 59.54,
      "time_str": "00:59.540",
      "text": "所以一切都是幸福的模样",
      "translation": null
    },
    {
      "time": 65.129,
      "time_str": "01:05.129",
      "text": "因为爱情 简单的生长",
      "translation": null
    },
    {
      "time": 70.73,
      "time_str": "01:10.730",
      "text": "依然随时可以为你疯狂",
      "translation": null
    },
    {
      "time": 76.0,
      "time_str": "01:16.000",
      "text": "因为爱情 怎么会有沧桑",
      "translation": null
    },
    {
      "time": 81.35,
      "time_str": "01:21.350",
      "text": "所以我们还是年轻的模样",
      "translation": null
    },
    {
      "time": 86.89,
      "time_str": "01:26.890",
      "text": "因为爱情 在那个地方",
      "translation": null
