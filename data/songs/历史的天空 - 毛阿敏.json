    {
      "time": 27.8,
      "time_str": "00:27.800",
      "text": "暗淡了刀光剑影",
      "translation": null
    },
    {
      "time": 33.68,
      "time_str": "00:33.680",
      "text": "远去了鼓角铮鸣",
      "translation": null
    },
    {
      "time": 40.05,
      "time_str": "00:40.050",
      "text": "眼前飞扬着一个个",
      "translation": null
    },
    {
      "time": 46.05,
      "time_str": "00:46.050",
      "text": "鲜活的面容",
      "translation": null
    },
    {
      "time": 52.65,
      "time_str": "00:52.650",
      "text": "湮没了黄尘古道",
      "translation": null
    },
    {
      "time": 58.65,
      "time_str": "00:58.650",
      "text": "荒芜了烽火边城",
      "translation": null
    },
    {
      "time": 64.65,
      "time_str": "01:04.650",
      "text": "岁月啊你带不走",
      "translation": null
    },
    {
      "time": 69.67,
      "time_str": "01:09.670",
      "text": "那一串串熟悉的姓名",
      "translation": null
    },
    {
      "time": 77.57,
      "time_str": "01:17.570",
      "text": "兴亡谁人定啊",
      "translation": null
    },
    {
      "time": 83.57,
      "time_str": "01:23.570",
      "text": "盛衰岂无凭啊",
      "translation": null
    },
    {
      "time": 89.57,
      "time_str": "01:29.570",
      "text": "一页风云散啊",
      "translation": null
    },
    {
      "time": 95.57,
      "time_str": "01:35.570",
      "text": "变幻了时空",
      "translation": null
    },
    {
      "time": 102.57,
      "time_str": "01:42.570",
      "text": "聚散皆是缘哪",
      "translation": null
    },
    {
      "time": 108.57,
      "time_str": "01:48.570",
      "text": "离合总关情啊",
      "translation": null
    },
    {
      "time": 114.57,
      "time_str": "01:54.570",
      "text": "担当生前事啊",
      "translation": null
    },
    {
      "time": 120.57,
      "time_str": "02:00.570",
      "text": "何计身后评",
      "translation": null
    },
    {
      "time": 127.47,
      "time_str": "02:07.470",
      "text": "长江有意化作泪",
      "translation": null
    },
    {
      "time": 133.79,
      "time_str": "02:13.790",
      "text": "长江有情起歌声",
      "translation": null
    },
    {
      "time": 140.0,
      "time_str": "02:20.000",
      "text": "历史的天空闪烁几颗星",
      "translation": null
    },
    {
      "time": 147.0,
      "time_str": "02:27.000",
      "text": "人间一股英雄气",
      "translation": null
    },
    {
      "time": 151.8,
      "time_str": "02:31.800",
      "text": "在驰骋纵横",
      "translation": null
    }
  ],
