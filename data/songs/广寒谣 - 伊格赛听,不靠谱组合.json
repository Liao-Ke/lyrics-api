  "lyrics": [
    {
      "time": 13.96,
      "time_str": "00:13.960",
      "text": "​绿柳垂腰轻绕堤岸",
      "translation": null
    },
    {
      "time": 17.03,
      "time_str": "00:17.030",
      "text": "墨客才子画扇   乌篷小调细唤",
      "translation": null
    },
    {
      "time": 20.79,
      "time_str": "00:20.790",
      "text": "​良人桥头碎步温婉",
      "translation": null
    },
    {
      "time": 23.6,
      "time_str": "00:23.600",
      "text": "推开一柄紫竹伞​",
      "translation": null
    },
    {
      "time": 27.54,
      "time_str": "00:27.540",
      "text": "​浅笑淡妆   回阁楼刺绣伴",
      "translation": null
    },
    {
      "time": 30.17,
      "time_str": "00:30.170",
      "text": "春燕赏花呢喃   白衣老叟垂钓江畔",
      "translation": null
    },
    {
      "time": 33.92,
      "time_str": "00:33.920",
      "text": "声声短笛 浸润水雾弥漫   残阳落天欲晚",
      "translation": null
    },
    {
      "time": 40.51,
      "time_str": "00:40.510",
      "text": "她还素手挑盏灯花  月色映她玉脸生霞",
      "translation": null
    },
    {
      "time": 47.01,
      "time_str": "00:47.010",
      "text": "她点天灯漫过柳枝桠飞向广寒化作银玉盘",
      "translation": null
    },
    {
      "time": 53.81,
      "time_str": "00:53.810",
      "text": "她还温润从容烹茶   良人相坐绿柳树下",
      "translation": null
    },
    {
      "time": 60.539,
      "time_str": "01:00.539",
      "text": "她留几阙情诗相赠他抚琴长伴成佳话",
      "translation": null
    },
