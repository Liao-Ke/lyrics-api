  "lyrics": [
    {
      "time": 20.948,
      "time_str": "00:20.948",
      "text": "如果兄妹相称太多",
      "translation": null
    },
    {
      "time": 26.192,
      "time_str": "00:26.192",
      "text": "醒不起喜欢我",
      "translation": null
    },
    {
      "time": 28.957,
      "time_str": "00:28.957",
      "text": "快研究和我这异性拍拖",
      "translation": null
    },
    {
      "time": 35.195,
      "time_str": "00:35.195",
      "text": "讹称知己的真太多",
      "translation": null
    },
    {
      "time": 40.45,
      "time_str": "00:40.450",
      "text": "当女共男未变爱侣",
      "translation": null
    },
    {
      "time": 44.196,
      "time_str": "00:44.196",
      "text": "不吻过自然没结果",
      "translation": null
    },
    {
      "time": 49.19,
      "time_str": "00:49.190",
      "text": "没有好感怎会相亲相爱",
      "translation": null
    },
    {
      "time": 53.698,
      "time_str": "00:53.698",
      "text": "大哥只是掩饰",
      "translation": null
    },
    {
      "time": 56.632,
      "time_str": "00:56.632",
      "text": "能做对爱侣",
      "translation": null
    },
    {
      "time": 58.636,
      "time_str": "00:58.636",
      "text": "堕落成朋友谁心息",
      "translation": null
    },
    {
      "time": 64.631,
      "time_str": "01:04.631",
      "text": "我要爱情不需要登对",
      "translation": null
    },
    {
      "time": 68.135,
      "time_str": "01:08.135",
      "text": "不需得你允许",
      "translation": null
    },
    {
      "time": 71.13,
      "time_str": "01:11.130",
      "text": "兄妹真有趣",
      "translation": null
    },
    {
      "time": 72.885,
      "time_str": "01:12.885",
      "text": "不需要分居",
      "translation": null
    },
    {
      "time": 75.883,
      "time_str": "01:15.883",
      "text": "忘记辈份再追",
      "translation": null
    },
    {
      "time": 79.14,
      "time_str": "01:19.140",
      "text": "我要爱情摧毁世交",
      "translation": null
    },
    {
      "time": 81.886,
      "time_str": "01:21.886",
      "text": "也不失一个壮举",
      "translation": null
    },
    {
      "time": 85.143,
      "time_str": "01:25.143",
      "text": "相恋的证据",
      "translation": null
    },
    {
      "time": 87.129,
      "time_str": "01:27.129",
      "text": "假使要争取",
      "translation": null
    },
    {
      "time": 90.142,
      "time_str": "01:30.142",
      "text": "唯有约定和大哥喝醉",
      "translation": null
    },
    {
      "time": 106.63,
      "time_str": "01:46.630",
      "text": "曾经想手执一柄枪",
      "translation": null
    },
    {
      "time": 112.127,
      "time_str": "01:52.127",
      "text": "想逼供你一趟",
      "translation": null
    },
    {
      "time": 114.632,
      "time_str": "01:54.632",
      "text": "我和你无爱谁没有智商",
      "translation": null
    },
    {
      "time": 120.885,
      "time_str": "02:00.885",
      "text": "如果恋爱必须创伤",
      "translation": null
    },
    {
      "time": 125.889,
      "time_str": "02:05.889",
      "text": "想你亦明白到我俩",
      "translation": null
    },
    {
      "time": 129.633,
      "time_str": "02:09.633",
      "text": "需开心都也受够伤",
      "translation": null
