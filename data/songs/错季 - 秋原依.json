  "lyrics": [
    {
      "time": 35.09,
      "time_str": "00:35.090",
      "text": "话题结束在最炎热的天气",
      "translation": null
    },
    {
      "time": 42.28,
      "time_str": "00:42.280",
      "text": "分手两个字就像一句咒语",
      "translation": null
    },
    {
      "time": 49.87,
      "time_str": "00:49.870",
      "text": "意外打开封印 我误闯入冬季",
      "translation": null
    },
    {
      "time": 55.49,
      "time_str": "00:55.490",
      "text": "眼看着身体 正在快速结冰",
      "translation": null
    },
    {
      "time": 65.07,
      "time_str": "01:05.070",
      "text": "折射的阳光没有一点暖意",
      "translation": null
    },
    {
      "time": 72.25,
      "time_str": "01:12.250",
      "text": "我只能闭上眼睛 任凭绝望侵袭",
      "translation": null
    },
    {
      "time": 79.55,
      "time_str": "01:19.550",
      "text": "最后一次深呼吸 竟然自主记忆",
      "translation": null
    },
    {
      "time": 85.08,
      "time_str": "01:25.080",
      "text": "我可能还是希望留下你",
      "translation": null
    },
    {
      "time": 88.67,
      "time_str": "01:28.670",
      "text": "你的气息",
      "translation": null
    },
    {
      "time": 92.76,
      "time_str": "01:32.760",
      "text": "春的颜色不走进秋季",
      "translation": null
    },
    {
      "time": 95.56,
      "time_str": "01:35.560",
      "text": "有些爱情就经不起季节轮替",
      "translation": null
    },
    {
      "time": 99.36,
      "time_str": "01:39.360",
      "text": "我情愿被世界隔离",
      "translation": null
    },
    {
      "time": 101.76,
      "time_str": "01:41.760",
      "text": "也不愿意去面对着你的善意",
      "translation": null
    },
    {
      "time": 107.75,
      "time_str": "01:47.750",
      "text": "夏的炙热不温暖冬季",
      "translation": null
    },
    {
      "time": 110.47,
      "time_str": "01:50.470",
      "text": "而我只能停在原地无法破冰",
      "translation": null
    },
    {
      "time": 114.34,
      "time_str": "01:54.340",
      "text": "强烈的挣扎以后终于开始脱力",
      "translation": null
    },
    {
      "time": 118.71,
      "time_str": "01:58.710",
      "text": "被迫冷静",
      "translation": null
    },
