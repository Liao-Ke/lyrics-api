    {
      "time": 0.726,
      "time_str": "00:00.726",
      "text": "改编词 : 吴庆康",
      "translation": null
    },
    {
      "time": 0.968,
      "time_str": "00:00.968",
      "text": "每个人都在问我",
      "translation": null
    },
    {
      "time": 2.619,
      "time_str": "00:02.619",
      "text": "到底还在等什么",
      "translation": null
    },
    {
      "time": 7.755,
      "time_str": "00:07.755",
      "text": "等到春夏秋冬",
      "translation": null
    },
    {
      "time": 9.511,
      "time_str": "00:09.511",
      "text": "都过了难道还不够",
      "translation": null
    },
    {
      "time": 14.423,
      "time_str": "00:14.423",
      "text": "其实是因为我",
      "translation": null
    },
    {
      "time": 16.425,
      "time_str": "00:16.425",
      "text": "的心有一个缺口",
      "translation": null
    },
    {
      "time": 20.361,
      "time_str": "00:20.361",
      "text": "等待拿走的人",
      "translation": null
    },
    {
      "time": 21.915,
      "time_str": "00:21.915",
      "text": "把它还给我",
      "translation": null
    },
    {
      "time": 28.182,
      "time_str": "00:28.182",
      "text": "每个人都在说这种",
      "translation": null
    },
    {
      "time": 30.185,
      "time_str": "00:30.185",
      "text": "爱情没有结果",
      "translation": null
    },
    {
      "time": 34.96,
      "time_str": "00:34.960",
      "text": "我也知道你永远",
      "translation": null
    },
    {
      "time": 36.564,
      "time_str": "00:36.564",
      "text": "都不能够爱我",
      "translation": null
    },
    {
      "time": 41.457,
      "time_str": "00:41.457",
      "text": "其实我只是希望",
      "translation": null
    },
    {
      "time": 43.471,
      "time_str": "00:43.471",
      "text": "你有时想一想我",
      "translation": null
    },
    {
      "time": 47.177,
      "time_str": "00:47.177",
      "text": "你却已经渐渐渐渐",
      "translation": null
    },
    {
      "time": 49.28,
      "time_str": "00:49.280",
      "text": "什么都不再说",
      "translation": null
    },
    {
      "time": 54.96,
      "time_str": "00:54.960",
      "text": "我睡不着的时候",
      "translation": null
    },
    {
      "time": 57.199,
      "time_str": "00:57.199",
      "text": "会不会有人陪着我",
      "translation": null
    },
    {
      "time": 60.925,
      "time_str": "01:00.925",
      "text": "我难过的时候",
      "translation": null
    },
    {
      "time": 63.831,
      "time_str": "01:03.831",
      "text": "会不会有人安慰我",
      "translation": null
    },
    {
      "time": 67.763,
      "time_str": "01:07.763",
      "text": "我想说话的时候",
      "translation": null
    },
    {
      "time": 70.418,
      "time_str": "01:10.418",
      "text": "会不会有人了解我",
      "translation": null
