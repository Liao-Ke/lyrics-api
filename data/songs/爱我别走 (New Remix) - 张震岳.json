    {
      "time": 29.17,
      "time_str": "00:29.170",
      "text": "我到了这个时候还是一样",
      "translation": null
    },
    {
      "time": 34.63,
      "time_str": "00:34.630",
      "text": "夜里的寂寞容易叫人悲伤",
      "translation": null
    },
    {
      "time": 41.14,
      "time_str": "00:41.140",
      "text": "我不敢想的太多",
      "translation": null
    },
    {
      "time": 44.94,
      "time_str": "00:44.940",
      "text": "因为我一个人",
      "translation": null
    },
    {
      "time": 51.46,
      "time_str": "00:51.460",
      "text": "迎面而来的月光拉长身影",
      "translation": null
    },
    {
      "time": 57.15,
      "time_str": "00:57.150",
      "text": "漫无目的地走在冷冷的街",
      "translation": null
    },
    {
      "time": 62.56,
      "time_str": "01:02.560",
      "text": "我没有你的消息",
      "translation": null
    },
    {
