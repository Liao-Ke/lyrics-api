      "time_str": "01:06.970",
      "text": "因为我在想你",
      "translation": null
    },
    {
      "time": 73.38,
      "time_str": "01:13.380",
      "text": "爱我别走",
      "translation": null
    },
    {
      "time": 75.98,
      "time_str": "01:15.980",
      "text": "如果你说 你不爱我",
      "translation": null
    },
    {
      "time": 85.38,
      "time_str": "01:25.380",
      "text": "不要听见你真的说出口",
      "translation": null
    },
    {
      "time": 88.29,
      "time_str": "01:28.290",
      "text": "再给我一点温柔",
