  "lyrics": [
    {
      "time": 27.08,
      "time_str": "00:27.080",
      "text": "元夜琴鼓奏 花街灯如昼",
      "translation": null
    },
    {
      "time": 33.3,
      "time_str": "00:33.300",
      "text": "欢歌笑语飘上船头",
      "translation": null
    },
    {
      "time": 39.89,
      "time_str": "00:39.890",
      "text": "被你牵过的手 揽不住永久",
      "translation": null
    },
    {
      "time": 46.51,
      "time_str": "00:46.510",
      "text": "雨过方知绿肥红瘦",
      "translation": null
    },
    {
      "time": 53.73,
      "time_str": "00:53.730",
      "text": "欲除相思垢 泪浣春袖",
      "translation": null
    },
    {
      "time": 59.75,
      "time_str": "00:59.750",
      "text": "船家只道是离人愁",
      "translation": null
    },
    {
      "time": 66.51,
      "time_str": "01:06.510",
      "text": "你送我的红豆 原来会腐朽",
      "translation": null
    },
    {
      "time": 73.19,
      "time_str": "01:13.190",
      "text": "可惜从没人告诉我",
      "translation": null
    },
    {
      "time": 79.4,
      "time_str": "01:19.400",
      "text": "寒江陪烟火 月伴星如昨",
      "translation": null
    },
    {
      "time": 86.16,
      "time_str": "01:26.160",
      "text": "可你怎么独留我一个人过",
      "translation": null
    },
    {
      "time": 92.73,
      "time_str": "01:32.730",
      "text": "若你想起我",
      "translation": null
    },
    {
      "time": 96.12,
      "time_str": "01:36.120",
      "text": "不必抱愧当时承诺太重",
      "translation": null
    },
    {
      "time": 100.3,
      "time_str": "01:40.300",
      "text": "聚散无常 怨谁错",
      "translation": null
    },
