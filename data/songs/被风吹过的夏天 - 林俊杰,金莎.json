{
  "title": "被风吹过的夏天",
  "title_raw": "被风吹过的夏天",
  "version": null,
  "artist": "林俊杰,金莎",
  "group_key": "被风吹过的夏天|林俊杰,金莎",
  "writers": {
    "lyricist": "冯欣慧",
    "composer": "林俊杰",
    "arranger": "蔡政勋"
  },
  "lyrics": [
    {
      "time": 15.69,
      "time_str": "00:15.690",
      "text": "还记得昨天那个夏天 微风吹过的一瞬间",
      "translation": null
    },
    {
      "time": 25.45,
      "time_str": "00:25.450",
      "text": "似乎吹翻一切 只剩寂寞肯沉淀",
      "translation": null
    },
    {
      "time": 31.36,
      "time_str": "00:31.360",
      "text": "如今风依旧在吹 秋天的雨跟随",
      "translation": null
    },
    {
      "time": 36.94,
      "time_str": "00:36.940",
      "text": "心中的热却不退 仿佛继续闭着双眼",
      "translation": null
    },
    {
      "time": 43.46,
      "time_str": "00:43.460",
      "text": "熟悉的脸又会浮现在眼前",
      "translation": null
    },
    {
      "time": 51.01,
      "time_str": "00:51.010",
      "text": "蓝色的思念",
      "translation": null
    },
    {
      "time": 54.01,
      "time_str": "00:54.010",
      "text": "突然演变成了阳光的夏天",
      "translation": null
    },
    {
      "time": 57.85,
      "time_str": "00:57.850",
      "text": "空气中的温暖不会很遥远",
      "translation": null
    },
    {
      "time": 62.48,
      "time_str": "01:02.480",
      "text": "冬天也仿佛不再留恋",
      "translation": null
    },
    {
      "time": 67.0,
      "time_str": "01:07.000",
      "text": "绿色的思念",
      "translation": null
    },
    {
      "time": 69.5,
      "time_str": "01:09.500",
      "text": "挥手对我说一声四季不变",
      "translation": null
    },
    {
      "time": 73.35,
      "time_str": "01:13.350",
      "text": "不过一季的时间",
      "translation": null
    },
    {
      "time": 75.12,
      "time_str": "01:15.120",
      "text": "又再回到从前（我回到那个）",
      "translation": null
    },
    {
      "time": 77.28,
      "time_str": "01:17.280",
      "text": "那个被风吹过的夏天",
      "translation": null
    },
    {
