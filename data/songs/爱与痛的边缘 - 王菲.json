  "lyrics": [
    {
      "time": 19.25,
      "time_str": "00:19.250",
      "text": "徘徊傍徨路前 回望这一段",
      "translation": null
    },
    {
      "time": 26.83,
      "time_str": "00:26.830",
      "text": "你吻过我的脸 曾是百千遍",
      "translation": null
    },
    {
      "time": 34.87,
      "time_str": "00:34.870",
      "text": "没去想 终有一天",
      "translation": null
    },
    {
      "time": 38.93,
      "time_str": "00:38.930",
      "text": "夜雨中 找不到打算",
      "translation": null
    },
    {
      "time": 42.92,
      "time_str": "00:42.920",
      "text": "让我孤单这边 一点钟等到三点",
      "translation": null
    },
    {
      "time": 52.57,
      "time_str": "00:52.570",
      "text": "哪怕与你相见 仍是我心愿",
      "translation": null
    },
    {
      "time": 60.96,
      "time_str": "01:00.960",
      "text": "我也有我感觉 难道要遮掩",
      "translation": null
    },
    {
      "time": 68.36,
      "time_str": "01:08.360",
      "text": "若已经不想跟我相恋",
      "translation": null
    },
    {
      "time": 72.06,
      "time_str": "01:12.060",
      "text": "又却怎麽口口声声的欺骗",
      "translation": null
    },
    {
      "time": 76.2,
      "time_str": "01:16.200",
      "text": "让我一等再等",
      "translation": null
    },
    {
      "time": 79.64,
      "time_str": "01:19.640",
      "text": "再等一天共你拾回温暖",
      "translation": null
    },
    {
      "time": 85.22,
      "time_str": "01:25.220",
      "text": "情像雨点 似断难断",
      "translation": null
    },
    {
      "time": 89.48,
      "time_str": "01:29.480",
      "text": "愈是去想 更是凌乱",
      "translation": null
    },
    {
      "time": 93.49,
      "time_str": "01:33.490",
      "text": "我已经不想跟你痴缠",
      "translation": null
    },
    {
      "time": 95.93,
      "time_str": "01:35.930",
      "text": "我有我的尊严 不想再受损",
      "translation": null
    },
    {
      "time": 101.52,
      "time_str": "01:41.520",
      "text": "无奈我心 要辨难辨",
      "translation": null
    },
    {
      "time": 105.12,
      "time_str": "01:45.120",
      "text": "道别再等 也未如愿",
      "translation": null
    },
    {
      "time": 109.27,
      "time_str": "01:49.270",
      "text": "永远在爱与痛的边缘",
      "translation": null
    },
    {
      "time": 112.15,
      "time_str": "01:52.150",
      "text": "应该怎麽决定挑选",
      "translation": null
    },
    {
