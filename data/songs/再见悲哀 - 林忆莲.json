    {
      "time": 0.47,
      "time_str": "00:00.470",
      "text": "再见悲哀因我不再计较任何结果",
      "translation": null
    },
    {
      "time": 5.67,
      "time_str": "00:05.670",
      "text": "什么都可以坦荡未在乎谁是错",
      "translation": null
    },
    {
      "time": 10.42,
      "time_str": "00:10.420",
      "text": "我两眼合上失去什么",
      "translation": null
    },
    {
      "time": 13.71,
      "time_str": "00:13.710",
      "text": "是与非也掠过",
      "translation": null
    },
    {
      "time": 16.28,
      "time_str": "00:16.280",
      "text": "别固执到问一切为何",
      "translation": null
    },
    {
      "time": 19.62,
      "time_str": "00:19.620",
      "text": "再见伤感因我不易被泪流留住我",
      "translation": null
    },
    {
      "time": 24.78,
      "time_str": "00:24.780",
      "text": "什么的境界都爱自自然地渡过",
      "translation": null
    },
    {
      "time": 29.5,
      "time_str": "00:29.500",
      "text": "去到最尾就如与物忘我",
      "translation": null
    },
    {
      "time": 32.92,
      "time_str": "00:32.920",
      "text": "回复身心最初",
      "translation": null
    },
    {
      "time": 35.48,
      "time_str": "00:35.480",
      "text": "面对心镜内一片平和",
      "translation": null
    },
    {
      "time": 39.31,
      "time_str": "00:39.310",
      "text": "鸟声瞬间闪过",
      "translation": null
    },
    {
      "time": 49.73,
      "time_str": "00:49.730",
      "text": "除了心只有心可以解心锁",
      "translation": null
    },
    {
      "time": 54.46,
      "time_str": "00:54.460",
      "text": "烦恼多因我要得多",
      "translation": null
    },
    {
      "time": 59.16,
      "time_str": "00:59.160",
      "text": "微似砂轻似烟怎会有风波",
      "translation": null
    },
    {
      "time": 64.01,
      "time_str": "01:04.010",
      "text": "有惆怅跌入了恒河",
      "translation": null
    },
    {
