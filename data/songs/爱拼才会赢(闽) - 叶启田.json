      "time_str": "00:28.650",
      "text": "一时失志不免怨叹",
      "translation": null
    },
    {
      "time": 34.02,
      "time_str": "00:34.020",
      "text": "一时落魄不免胆寒",
      "translation": null
    },
    {
      "time": 39.71,
      "time_str": "00:39.710",
      "text": "那通失去希望",
      "translation": null
    },
    {
      "time": 43.01,
      "time_str": "00:43.010",
      "text": "每日醉茫茫",
      "translation": null
    },
    {
      "time": 46.08,
