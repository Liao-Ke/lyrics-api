      "text": "第一天",
      "translation": null
    },
    {
      "time": 35.35,
      "time_str": "00:35.350",
      "text": "在玻璃窗上出现你的笑脸",
      "translation": null
    },
    {
      "time": 40.78,
      "time_str": "00:40.780",
      "text": "突然间",
      "translation": null
    },
    {
      "time": 43.36,
      "time_str": "00:43.360",
      "text": "就点燃",
      "translation": null
    },
    {
      "time": 46.11,
      "time_str": "00:46.110",
      "text": "我的天",
      "translation": null
    },
    {
      "time": 48.4,
      "time_str": "00:48.400",
      "text": "彩虹一片片",
      "translation": null
    },
    {
      "time": 51.24,
      "time_str": "00:51.240",
      "text": "环绕我身边",
      "translation": null
    },
    {
      "time": 54.46,
      "time_str": "00:54.460",
      "text": "这些年",
      "translation": null
    },
    {
      "time": 56.51,
      "time_str": "00:56.510",
      "text": "无论风雨晴天你都在身边",
      "translation": null
    },
    {
