    {
      "time": 80.23,
      "time_str": "01:20.230",
      "text": "我学会勇敢",
      "translation": null
    },
    {
      "time": 84.16,
      "time_str": "01:24.160",
      "text": "流星飞 带我飞",
      "translation": null
