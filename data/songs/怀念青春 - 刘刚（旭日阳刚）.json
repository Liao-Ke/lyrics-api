  "lyrics": [
    {
      "time": 37.76,
      "time_str": "00:37.760",
      "text": "那时的我们拥有",
      "translation": null
    },
    {
      "time": 41.4,
      "time_str": "00:41.400",
      "text": "没有污染过的清晨",
      "translation": null
    },
    {
      "time": 45.72,
      "time_str": "00:45.720",
      "text": "嘀嘀嗒嗒的秒针",
      "translation": null
    },
    {
      "time": 49.4,
      "time_str": "00:49.400",
      "text": "却留不住一个黄昏",
      "translation": null
    },
    {
      "time": 53.75,
      "time_str": "00:53.750",
      "text": "曾经的爱很简单",
      "translation": null
    },
    {
      "time": 57.43,
      "time_str": "00:57.430",
      "text": "不需要费力的眼神",
      "translation": null
    },
    {
      "time": 61.42,
      "time_str": "01:01.420",
      "text": "牵手走过无人山岗",
      "translation": null
    },
    {
      "time": 65.29,
      "time_str": "01:05.290",
      "text": "想时间再慢几分",
      "translation": null
    },
    {
      "time": 70.76,
      "time_str": "01:10.760",
      "text": "怀念啊我们的青春啊",
      "translation": null
    },
    {
      "time": 74.86,
      "time_str": "01:14.860",
      "text": "昨天在记忆里生根发芽",
      "translation": null
    },
    {
      "time": 78.8,
      "time_str": "01:18.800",
      "text": "爱情滋养心中那片土地",
      "translation": null
    },
    {
      "time": 82.81,
      "time_str": "01:22.810",
      "text": "绽放出美丽不舍的泪花",
      "translation": null
    },
    {
      "time": 86.69,
      "time_str": "01:26.690",
      "text": "怀念啊我们的青春啊",
      "translation": null
    },
    {
      "time": 90.75,
      "time_str": "01:30.750",
      "text": "留下的脚印拼成一幅画",
      "translation": null
    },
    {
      "time": 94.68,
      "time_str": "01:34.680",
      "text": "最美的风景是你的笑容",
      "translation": null
    },
    {
      "time": 98.71,
      "time_str": "01:38.710",
      "text": "那一句再见有太多的  放不下",
      "translation": null
    },
