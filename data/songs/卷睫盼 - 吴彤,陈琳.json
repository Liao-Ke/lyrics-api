      "time": 14.73,
      "time_str": "00:14.730",
      "text": "男：美是初见",
      "translation": null
    },
    {
      "time": 17.6,
      "time_str": "00:17.600",
      "text": "燃起爱情火焰",
      "translation": null
    },
    {
      "time": 20.86,
      "time_str": "00:20.860",
      "text": "燃烧在茫茫东海边缘",
      "translation": null
    },
    {
      "time": 23.61,
      "time_str": "00:23.610",
      "text": "随着风飞翻",
      "translation": null
    },
    {
      "time": 26.54,
      "time_str": "00:26.540",
      "text": "卷睫盼",
      "translation": null
    },
    {
      "time": 29.39,
      "time_str": "00:29.390",
      "text": "明眸璀璨我捉不住",
      "translation": null
    },
    {
      "time": 33.91,
      "time_str": "00:33.910",
      "text": "你若即若离的手指尖",
      "translation": null
    },
    {
      "time": 38.31,
      "time_str": "00:38.310",
      "text": "女：爱是因为你 美丽被还原",
      "translation": null
    },
    {
      "time": 44.69,
      "time_str": "00:44.690",
      "text": "我知道有一千种可能",
      "translation": null
    },
    {
      "time": 47.25,
      "time_str": "00:47.250",
      "text": "是与你相恋",
      "translation": null
    },
    {
      "time": 50.28,
      "time_str": "00:50.280",
      "text": "睁开眼",
      "translation": null
    },
    {
      "time": 53.15,
      "time_str": "00:53.150",
      "text": "闭上眼难得难弃的缘",
      "translation": null
    },
    {
      "time": 57.64,
      "time_str": "00:57.640",
      "text": "女：天赐的",
      "translation": null
    },
    {
      "time": 58.45,
      "time_str": "00:58.450",
      "text": "男：地护的",
      "translation": null
    },
    {
      "time": 59.31,
      "time_str": "00:59.310",
      "text": "合：永不变",
      "translation": null
    },
    {
      "time": 62.12,
      "time_str": "01:02.120",
      "text": "望眼欲穿",
