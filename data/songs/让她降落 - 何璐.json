    {
      "time": 22.3,
      "time_str": "00:22.300",
      "text": "她没有焰火绚丽",
      "translation": null
    },
    {
      "time": 32.188,
      "time_str": "00:32.188",
      "text": "也不像鸟儿会迁徙",
      "translation": null
    },
    {
      "time": 39.625,
      "time_str": "00:39.625",
      "text": "不过是 放飞的风筝",
      "translation": null
    },
    {
      "time": 44.812,
      "time_str": "00:44.812",
      "text": "怕你心痛 才自由",
      "translation": null
    },
    {
      "time": 49.225,
      "time_str": "00:49.225",
      "text": "记忆的线索 在你手中",
      "translation": null
    },
    {
      "time": 59.291,
      "time_str": "00:59.291",
      "text": "如果 你能让她降落",
      "translation": null
    },
    {
      "time": 68.727,
      "time_str": "01:08.727",
      "text": "天空 如自由无尽头",
      "translation": null
    },
    {
      "time": 78.479,
      "time_str": "01:18.479",
      "text": "宁愿 是条船 如果你是大海",
      "translation": null
    },
    {
      "time": 87.797,
      "time_str": "01:27.797",
      "text": "就让她能漂流在你 心中",
      "translation": null
    },
    {
      "time": 99.297,
      "time_str": "01:39.297",
      "text": "这世间繁华太多",
      "translation": null
    },
    {
      "time": 108.801,
      "time_str": "01:48.801",
      "text": "人影交错擦肩而过",
      "translation": null
    },
    {
      "time": 116.485,
      "time_str": "01:56.485",
      "text": "她走过 惟独她走过",
      "translation": null
    },
    {
      "time": 121.673,
      "time_str": "02:01.673",
      "text": "让你 停下了脚步",
      "translation": null
    },
    {
      "time": 126.296,
      "time_str": "02:06.296",
      "text": "沉默 两颗心不再沉默",
      "translation": null
    },
    {
      "time": 135.854,
      "time_str": "02:15.854",
      "text": "如果 你能让她降落",
      "translation": null
    },
    {
      "time": 145.609,
      "time_str": "02:25.609",
      "text": "天空 如自由无尽头",
      "translation": null
    },
    {
      "time": 155.205,
      "time_str": "02:35.205",
      "text": "可知 那颗心 在风中太落寞",
      "translation": null
    },
    {
      "time": 164.829,
      "time_str": "02:44.829",
      "text": "就让她停留在你 怀中",
      "translation": null
    },
    {
      "time": 174.583,
      "time_str": "02:54.583",
      "text": "如果 你能让她降落",
      "translation": null
    },
    {
