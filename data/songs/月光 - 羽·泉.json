    {
      "time": 17.16,
      "time_str": "00:17.160",
      "text": "月光洒在每个人心上",
      "translation": null
    },
    {
      "time": 23.46,
      "time_str": "00:23.460",
      "text": "为想家的人照着亮",
      "translation": null
    },
    {
      "time": 30.44,
      "time_str": "00:30.440",
      "text": "哦~离开太久的故乡",
      "translation": null
    },
    {
      "time": 37.18,
      "time_str": "00:37.180",
      "text": "和老去的爹娘",
      "translation": null
    },
    {
      "time": 44.18,
      "time_str": "00:44.180",
      "text": "哦~迎着月色散落的光芒",
      "translation": null
    },
    {
      "time": 50.66,
      "time_str": "00:50.660",
      "text": "把古老的歌谣轻轻唱",
      "translation": null
    },
    {
      "time": 57.88,
      "time_str": "00:57.880",
      "text": "哦~无论走到任何的地方",
