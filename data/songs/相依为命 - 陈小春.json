  "lyrics": [
    {
      "time": 20.55,
      "time_str": "00:20.550",
      "text": "旁人在 淡出 终于只有你共我一起",
      "translation": null
    },
    {
      "time": 28.1,
      "time_str": "00:28.100",
      "text": "仍然自问幸福 虽说有阵时为你生气",
      "translation": null
    },
    {
      "time": 35.22,
      "time_str": "00:35.220",
      "text": "其实以前和你 互相不懂得死心塌地",
      "translation": null
    },
    {
      "time": 42.76,
      "time_str": "00:42.760",
      "text": "直到共你 度过多灾世纪",
      "translation": null
    },
    {
      "time": 48.89,
      "time_str": "00:48.890",
      "text": "即使身边世事再毫无道理",
      "translation": null
    },
    {
      "time": 52.75,
      "time_str": "00:52.750",
      "text": "与你永远亦连在一起",
      "translation": null
    },
    {
      "time": 56.43,
      "time_str": "00:56.430",
      "text": "你不放下我 我不放下你",
      "translation": null
    },
    {
      "time": 59.99,
      "time_str": "00:59.990",
      "text": "我想确定每日挽住同样的手臂",
      "translation": null
    },
    {
      "time": 64.48,
      "time_str": "01:04.480",
      "text": "不敢早死要来陪住你",
      "translation": null
    },
    {
      "time": 68.52,
      "time_str": "01:08.520",
      "text": "我已试够别离并不很凄美",
      "translation": null
    },
    {
      "time": 74.97,
      "time_str": "01:14.970",
      "text": "我还 如何撇下你",
      "translation": null
    },
    {
      "time": 94.71,
      "time_str": "01:34.710",
      "text": "年华像细水 冲走几个爱人与知己",
      "translation": null
    },
    {
      "time": 101.9,
      "time_str": "01:41.900",
      "text": "抬头命运射灯 光柱罩下来剩我跟你",
      "translation": null
    },
    {
      "time": 109.0,
      "time_str": "01:49.000",
      "text": "难道有人离去是想显出好光阴 有限",
      "translation": null
    },
    {
      "time": 116.2,
      "time_str": "01:56.200",
      "text": "让我学会为你 贪生怕死",
      "translation": null
    },
    {
