    {
      "time": 15.5,
      "time_str": "00:15.500",
      "text": "把昨天都作废",
      "translation": null
    },
    {
      "time": 18.91,
      "time_str": "00:18.910",
      "text": "现在你在我眼前",
      "translation": null
    },
    {
      "time": 22.69,
      "time_str": "00:22.690",
      "text": "我想爱 请给我机会",
      "translation": null
    },
    {
      "time": 29.19,
      "time_str": "00:29.190",
      "text": "如果我错了也承担",
      "translation": null
    },
    {
      "time": 33.07,
      "time_str": "00:33.070",
      "text": "认定你就是答案",
      "translation": null
    },
    {
      "time": 37.76,
      "time_str": "00:37.760",
      "text": "我不怕谁嘲笑我极端",
      "translation": null
    },
    {
      "time": 42.92,
      "time_str": "00:42.920",
      "text": "相信自己的直觉",
      "translation": null
    },
    {
      "time": 46.78,
      "time_str": "00:46.780",
      "text": "顽固的人不喊累",
      "translation": null
    },
    {
      "time": 50.27,
      "time_str": "00:50.270",
      "text": "爱上你 我不撤退",
      "translation": null
    },
    {
      "time": 55.7,
      "time_str": "00:55.700",
      "text": "我说过 我不闪躲",
      "translation": null
    },
    {
      "time": 59.12,
      "time_str": "00:59.120",
      "text": "我非要这么做",
      "translation": null
    },
    {
      "time": 61.83,
      "time_str": "01:01.830",
      "text": "讲不听 也偏要爱",
      "translation": null
    },
    {
      "time": 64.27,
      "time_str": "01:04.270",
      "text": "更努力爱 让你明白",
      "translation": null
    },
    {
      "time": 69.37,
      "time_str": "01:09.370",
      "text": "没有别条路能走",
      "translation": null
    },
    {
      "time": 72.58,
      "time_str": "01:12.580",
      "text": "你决定要不要陪我",
      "translation": null
    },
    {
      "time": 75.5,
      "time_str": "01:15.500",
      "text": "讲不听 偏爱",
      "translation": null
    },
    {
      "time": 77.22,
      "time_str": "01:17.220",
      "text": "靠我感觉爱",
      "translation": null
    },
    {
      "time": 78.94,
      "time_str": "01:18.940",
      "text": "等你的依赖",
      "translation": null
    },
