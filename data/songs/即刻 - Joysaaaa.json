    {
      "time": 4.48,
      "time_str": "00:04.480",
      "text": "【未经许可，不得翻唱或使用】",
      "translation": null
    },
    {
      "time": 19.44,
      "time_str": "00:19.440",
      "text": "听见叹息 以后保持距离",
      "translation": null
    },
    {
      "time": 23.75,
      "time_str": "00:23.750",
      "text": "我是我 你是你",
      "translation": null
    },
    {
      "time": 27.99,
      "time_str": "00:27.990",
      "text": "悄无声息 第一时间失去",
      "translation": null
    },
    {
      "time": 31.99,
      "time_str": "00:31.990",
      "text": "你已各自删掉联系",
      "translation": null
    },
    {
      "time": 36.77,
      "time_str": "00:36.770",
      "text": "也不可以 重新回到原地",
      "translation": null
    },
    {
      "time": 40.91,
      "time_str": "00:40.910",
      "text": "你迟疑 我想你",
      "translation": null
    },
    {
      "time": 45.26,
      "time_str": "00:45.260",
      "text": "留在心里",
      "translation": null
    },
    {
      "time": 46.83,
      "time_str": "00:46.830",
      "text": "那一段用来复习的回忆",
      "translation": null
    },
    {
      "time": 53.58,
      "time_str": "00:53.580",
      "text": "所有的关心 明显不合时宜",
      "translation": null
    },
    {
      "time": 58.21,
      "time_str": "00:58.210",
      "text": "分开的瞬息 深刻记忆",
      "translation": null
    },
    {
      "time": 62.47,
      "time_str": "01:02.470",
      "text": "无能为力 不多言语",
      "translation": null
    },
    {
      "time": 66.53,
      "time_str": "01:06.530",
      "text": "我们只配惋惜",
      "translation": null
    },
    {
      "time": 69.63,
      "time_str": "01:09.630",
      "text": "从即刻起说",
      "translation": null
    },
    {
      "time": 71.04,
      "time_str": "01:11.040",
      "text": "对不起谎话没恶意",
      "translation": null
    },
    {
      "time": 73.82,
      "time_str": "01:13.820",
      "text": "明天还 能不能",
      "translation": null
    },
    {
      "time": 75.49,
      "time_str": "01:15.490",
      "text": "和现在一样熟悉",
      "translation": null
    },
    {
      "time": 79.23,
      "time_str": "01:19.230",
      "text": "从开篇起 埋下了伏笔",
      "translation": null
    },
    {
      "time": 82.59,
      "time_str": "01:22.590",
      "text": "骄傲的你 哪里来的底气",
      "translation": null
    },
    {
      "time": 86.8,
      "time_str": "01:26.800",
      "text": "从即刻起",
      "translation": null
    },
    {
      "time": 87.81,
      "time_str": "01:27.810",
      "text": "说对不起谎话没恶意",
      "translation": null
    },
    {
      "time": 91.1,
      "time_str": "01:31.100",
      "text": "一把伞也遮不住吹过来的雨",
