      "time_str": "08:08.320",
      "text": "女 爱不爱都难",
      "translation": null
    },
    {
      "time": 490.04,
      "time_str": "08:10.040",
      "text": "未快乐先有责任给予对方面露欢颜",
      "translation": null
    },
    {
      "time": 494.44,
      "time_str": "08:14.440",
      "text": "合 得到浪漫 又要有空间",
      "translation": null
    },
    {
      "time": 497.23,
      "time_str": "08:17.230",
      "text": "得到定局 却怕去到终站",
      "translation": null
    },
    {
      "time": 500.41,
      "time_str": "08:20.410",
      "text": "然後付出多得到少不介意豁达",
      "translation": null
    },
    {
      "time": 503.67,
      "time_str": "08:23.670",
      "text": "又担心",
      "translation": null
    },
    {
      "time": 507.67,
      "time_str": "08:27.670",
      "text": "合 当真正愿意爱一个人",
      "translation": null
    },
    {
      "time": 510.56,
      "time_str": "08:30.560",
      "text": "没法再爱更需要恨",
      "translation": null
    },
    {
      "time": 513.66,
      "time_str": "08:33.660",
      "text": "要奋不顾身继续遗憾",
      "translation": null
    },
    {
      "time": 517.04,
      "time_str": "08:37.040",
      "text": "谁计较 有没有开过心",
      "translation": null
    },
    {
      "time": 521.35,
      "time_str": "08:41.350",
      "text": "当不计代价爱一个人",
      "translation": null
    },
    {
      "time": 523.89,
      "time_str": "08:43.890",
      "text": "大概我也免不了私心",
      "translation": null
    },
    {
      "time": 526.79,
      "time_str": "08:46.790",
      "text": "痛苦使我兴奋 连错爱都吸引",
      "translation": null
    },
    {
      "time": 530.3,
      "time_str": "08:50.300",
      "text": "亦显得我神圣牺牲作陪衬",
      "translation": null
