  "lyrics": [
    {
      "time": 32.5,
      "time_str": "00:32.500",
      "text": "谢谢你如此温柔",
      "translation": null
    },
    {
      "time": 35.68,
      "time_str": "00:35.680",
      "text": "捧着爱静静等候",
      "translation": null
    },
    {
      "time": 38.85,
      "time_str": "00:38.850",
      "text": "我的双手 其实同样在颤抖",
      "translation": null
    },
    {
      "time": 45.47,
      "time_str": "00:45.470",
      "text": "但我能给你什么",
      "translation": null
    },
    {
      "time": 48.67,
      "time_str": "00:48.670",
      "text": "我只是一个他遗忘的我",
      "translation": null
    },
    {
      "time": 54.04,
      "time_str": "00:54.040",
      "text": "心被一扫而空",
      "translation": null
    },
    {
      "time": 58.44,
      "time_str": "00:58.440",
      "text": "我会把你种在我心中",
      "translation": null
    },
    {
      "time": 64.95,
      "time_str": "01:04.950",
      "text": "也许某天 会终于再次长出一个梦",
      "translation": null
    },
    {
      "time": 73.47,
      "time_str": "01:13.470",
      "text": "不知道 不明了 不想要",
      "translation": null
    },
    {
      "time": 76.29,
      "time_str": "01:16.290",
      "text": "为什么 我的心",
      "translation": null
    },
    {
      "time": 79.99,
      "time_str": "01:19.990",
      "text": "明明是想靠近",
      "translation": null
    },
    {
      "time": 83.48,
      "time_str": "01:23.480",
      "text": "却孤单到黎明",
      "translation": null
    },
    {
      "time": 86.81,
      "time_str": "01:26.810",
      "text": "不知道 不明了 不想要",
      "translation": null
    },
    {
      "time": 89.14,
      "time_str": "01:29.140",
      "text": "为什么 我的心",
      "translation": null
    },
    {
      "time": 93.27,
      "time_str": "01:33.270",
      "text": "那爱情的绮丽",
      "translation": null
    },
    {
      "time": 96.55,
      "time_str": "01:36.550",
      "text": "总是在孤单里",
      "translation": null
    },
    {
      "time": 99.69,
      "time_str": "01:39.690",
      "text": "再把我的最好的爱给你",
      "translation": null
    },
    {
      "time": 107.58,
      "time_str": "01:47.580",
      "text": "谢谢你如此温柔",
      "translation": null
    },
    {
      "time": 110.54,
      "time_str": "01:50.540",
      "text": "点着笑容的灯火",
      "translation": null
    },
    {
      "time": 114.01,
      "time_str": "01:54.010",
      "text": "只温暖而不打扰我的寒冬",
      "translation": null
    },
    {
      "time": 120.49,
      "time_str": "02:00.490",
      "text": "还没决定往哪走",
      "translation": null
    },
    {
      "time": 123.39,
      "time_str": "02:03.390",
      "text": "才所以不能答应你陪我",
      "translation": null
    },
    {
      "time": 128.97,
      "time_str": "02:08.970",
      "text": "怕你会变成我",
      "translation": null
    },
