  "lyrics": [
    {
      "time": 22.488,
      "time_str": "00:22.488",
      "text": "灯光和花火一起闪亮",
      "translation": null
    },
    {
      "time": 26.762,
      "time_str": "00:26.762",
      "text": "也亮不过我的梦想",
      "translation": null
    },
    {
      "time": 30.756,
      "time_str": "00:30.756",
      "text": "我旅途的开场",
      "translation": null
    },
    {
      "time": 33.141,
      "time_str": "00:33.141",
      "text": "我沿路的徽章",
      "translation": null
    },
    {
      "time": 35.785,
      "time_str": "00:35.785",
      "text": "风沙搁浅的希望",
      "translation": null
    },
    {
      "time": 39.349,
      "time_str": "00:39.349",
      "text": "时光让脸庞渐渐发光",
      "translation": null
    },
    {
      "time": 42.814,
      "time_str": "00:42.814",
      "text": "风雪把悲伤轻轻吹亮",
      "translation": null
    },
    {
      "time": 46.675,
      "time_str": "00:46.675",
      "text": "被淋湿的翅膀",
      "translation": null
    },
    {
      "time": 49.133,
      "time_str": "00:49.133",
      "text": "才拥有穿越过",
      "translation": null
    },
    {
      "time": 51.15,
      "time_str": "00:51.150",
      "text": "那暴风雨的力量",
      "translation": null
    },
    {
      "time": 55.429,
      "time_str": "00:55.429",
      "text": "曾经的我想唱就唱我最响亮",
      "translation": null
    },
    {
      "time": 59.369,
      "time_str": "00:59.369",
      "text": "这一年夏天有最感动的阳光",
      "translation": null
    },
    {
      "time": 64.258,
      "time_str": "01:04.258",
      "text": "你给我梦想",
      "translation": null
    },
    {
      "time": 66.13,
      "time_str": "01:06.130",
      "text": "我勇敢往前闯",
      "translation": null
    },
    {
      "time": 68.382,
      "time_str": "01:08.382",
      "text": "风吹雨打拍拍肩膀",
      "translation": null
    },
    {
      "time": 71.385,
      "time_str": "01:11.385",
      "text": "现在的我想唱就唱我最响亮",
      "translation": null
    },
    {
      "time": 75.196,
      "time_str": "01:15.196",
      "text": "这一年夏天有最温暖的目光",
      "translation": null
    },
    {
      "time": 80.16,
      "time_str": "01:20.160",
      "text": "记忆的远方",
      "translation": null
    },
    {
      "time": 82.214,
      "time_str": "01:22.214",
      "text": "我披戴的荣光",
      "translation": null
    },
    {
      "time": 84.32,
      "time_str": "01:24.320",
      "text": "照进天窗擦亮梦想",
      "translation": null
    },
    {
