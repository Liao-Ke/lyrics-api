  "lyrics": [
    {
      "time": 25.02,
      "time_str": "00:25.020",
      "text": "某年某月的某一天",
      "translation": null
    },
    {
      "time": 30.96,
      "time_str": "00:30.960",
      "text": "就像一张破碎的脸",
      "translation": null
    },
    {
      "time": 36.18,
      "time_str": "00:36.180",
      "text": "难以开口道再见",
      "translation": null
    },
    {
      "time": 42.57,
      "time_str": "00:42.570",
      "text": "就让一切走远",
      "translation": null
    },
    {
      "time": 48.56,
      "time_str": "00:48.560",
      "text": "这不是件容易的事",
      "translation": null
    },
    {
      "time": 54.84,
      "time_str": "00:54.840",
      "text": "我们却都没有哭泣",
      "translation": null
    },
    {
      "time": 60.31,
      "time_str": "01:00.310",
      "text": "让它淡淡地来",
      "translation": null
    },
    {
      "time": 66.26,
      "time_str": "01:06.260",
      "text": "让它好好地去",
      "translation": null
    },
    {
      "time": 71.1,
      "time_str": "01:11.100",
      "text": "到如今年复一年",
      "translation": null
    },
    {
      "time": 74.82,
      "time_str": "01:14.820",
      "text": "我不能停止怀念",
      "translation": null
    },
    {
      "time": 78.31,
      "time_str": "01:18.310",
      "text": "怀念你 怀念从前",
      "translation": null
    },
    {
      "time": 82.36,
      "time_str": "01:22.360",
      "text": "但愿那海风再起",
      "translation": null
    },
    {
      "time": 86.94,
      "time_str": "01:26.940",
      "text": "只为那浪花的手",
      "translation": null
    },
    {
      "time": 90.29,
      "time_str": "01:30.290",
      "text": "恰似你的温柔",
      "translation": null
    },
