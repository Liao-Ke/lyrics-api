{
  "title": "冲动的惩罚",
  "title_raw": "冲动的惩罚 (洛克先生Live版)",
  "version": "洛克先生Live版",
  "artist": "萧敬腾",
  "group_key": "冲动的惩罚|萧敬腾",
  "writers": {
    "lyricist": "刀郎",
    "composer": "刀郎",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 11.38,
      "time_str": "00:11.380",
      "text": "直到你转身离去那一刻起逐渐地清醒",
      "translation": null
    },
    {
      "time": 20.64,
      "time_str": "00:20.640",
      "text": "才知道我把世界强加给你还需要勇气",
      "translation": null
    },
    {
      "time": 29.41,
      "time_str": "00:29.410",
      "text": "在你的内心里是怎样对待感情",
      "translation": null
    },
    {
      "time": 34.1,
      "time_str": "00:34.100",
      "text": "直到现在你都没有对我提起",
      "translation": null
    },
    {
      "time": 38.17,
      "time_str": "00:38.170",
      "text": "我自说自话简单的想法",
      "translation": null
    },
    {
      "time": 42.72,
      "time_str": "00:42.720",
      "text": "在你看来这根本就是一个笑话",
      "translation": null
    },
    {
      "time": 46.73,
      "time_str": "00:46.730",
      "text": "所以我伤悲",
      "translation": null
    },
    {
      "time": 51.57,
      "time_str": "00:51.570",
      "text": "尽管手中还残留着你的香味",
      "translation": null
    },
    {
      "time": 59.9,
      "time_str": "00:59.900",
      "text": "如果那天你不知道我喝了多少杯",
      "translation": null
    },
    {
      "time": 65.43,
      "time_str": "01:05.430",
      "text": "你就不会明白你究竟有多美",
      "translation": null
    },
    {
      "time": 69.89,
      "time_str": "01:09.890",
      "text": "我也不会相信第一次看见你",
      "translation": null
    },
    {
      "time": 74.59,
      "time_str": "01:14.590",
      "text": "就爱你爱得那么干脆",
      "translation": null
    },
    {
      "time": 78.33,
      "time_str": "01:18.330",
      "text": "可是我相信我心中的感觉",
      "translation": null
    },
    {
      "time": 83.54,
      "time_str": "01:23.540",
      "text": "它来得那么快来得那么直接",
      "translation": null
    },
    {
      "time": 88.07,
      "time_str": "01:28.070",
      "text": "就算我心狂野",
      "translation": null
    },
    {
      "time": 90.31,
      "time_str": "01:30.310",
      "text": "无法将火熄灭",
      "translation": null
    },
    {
      "time": 92.64,
      "time_str": "01:32.640",
      "text": "我依然相信是老天让你我相约",
      "translation": null
    },
    {
      "time": 96.46,
      "time_str": "01:36.460",
      "text": "如果说没有闻到残留手中你的香水",
      "translation": null
    },
    {
      "time": 101.63,
      "time_str": "01:41.630",
      "text": "我绝对不会辗转反侧难以入睡",
      "translation": null
    },
    {
      "time": 105.98,
      "time_str": "01:45.980",
      "text": "就想着你的美",
      "translation": null
    },
    {
      "time": 108.1,
      "time_str": "01:48.100",
      "text": "闻着你的香味",
      "translation": null
    },
    {
      "time": 110.5,
      "time_str": "01:50.500",
      "text": "在冰与火的情欲中挣扎徘徊",
      "translation": null
    },
    {
      "time": 114.27,
      "time_str": "01:54.270",
      "text": "如果说不是老天让缘分把我捉弄",
      "translation": null
    },
    {
      "time": 119.45,
      "time_str": "01:59.450",
      "text": "想到你我就不会那么心痛",
      "translation": null
    },
    {
      "time": 123.56,
      "time_str": "02:03.560",
      "text": "就把你忘记吧",
      "translation": null
    },
    {
      "time": 125.99,
      "time_str": "02:05.990",
      "text": "应该把你忘了",
      "translation": null
    },
    {
      "time": 129.11,
      "time_str": "02:09.110",
      "text": "这是对冲动最好的惩罚",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "冲动的惩罚 (洛克先生Live版) - 萧敬腾.lrc"
}