  "lyrics": [
    {
      "time": 1.723,
      "time_str": "00:01.723",
      "text": "演唱:叶倩文",
      "translation": null
    },
    {
      "time": 17.109,
      "time_str": "00:17.109",
      "text": "时光飘过回头又见",
      "translation": null
    },
    {
      "time": 21.191,
      "time_str": "00:21.191",
      "text": "长夜细诉别时情",
      "translation": null
    },
    {
      "time": 24.995,
      "time_str": "00:24.995",
      "text": "还幸友爱不减半点",
      "translation": null
    },
    {
      "time": 28.563,
      "time_str": "00:28.563",
      "text": "一声两声总也是心声",
      "translation": null
    },
    {
      "time": 32.491,
      "time_str": "00:32.491",
      "text": "谁可想到谁能预算",
      "translation": null
    },
    {
      "time": 36.561,
      "time_str": "00:36.561",
      "text": "其实你对我痴情",
      "translation": null
    },
    {
      "time": 40.421,
      "time_str": "00:40.421",
      "text": "藏在暗里已多年",
      "translation": null
    },
    {
      "time": 44.15,
      "time_str": "00:44.150",
      "text": "在这天终于要说一遍",
      "translation": null
    },
    {
      "time": 52.49,
      "time_str": "00:52.490",
      "text": "我怎么可狠心的欺骗",
      "translation": null
    },
    {
      "time": 56.212,
      "time_str": "00:56.212",
      "text": "但也不忍跟你绝情",
      "translation": null
    },
    {
      "time": 60.414,
      "time_str": "01:00.414",
      "text": "我匆匆地再喝一杯",
      "translation": null
    },
    {
      "time": 63.388,
      "time_str": "01:03.388",
      "text": "没法清醒作决定WOO",
      "translation": null
    },
    {
      "time": 75.338,
      "time_str": "01:15.338",
      "text": "难怪曾说出不能成为知己的",
      "translation": null
    },
    {
      "time": 79.098,
      "time_str": "01:19.098",
      "text": "怎么可能相恋",
      "translation": null
    },
    {
      "time": 80.922,
      "time_str": "01:20.922",
      "text": "这晚我认真听见",
      "translation": null
    },
    {
      "time": 83.03,
      "time_str": "01:23.030",
      "text": "而我和你已经能成为知己",
      "translation": null
    },
    {
      "time": 86.098,
      "time_str": "01:26.098",
      "text": "终可不可能相恋",
      "translation": null
    },
    {
      "time": 88.142,
      "time_str": "01:28.142",
      "text": "我却怕未可以预见",
      "translation": null
    },
    {
      "time": 93.242,
      "time_str": "01:33.242",
      "text": "友情如仍未变",
      "translation": null
    },
    {
      "time": 97.565,
      "time_str": "01:37.565",
      "text": "最终双方都会醒",
      "translation": null
    },
    {
      "time": 102.29,
      "time_str": "01:42.290",
      "text": "到那一天将必听到",
      "translation": null
    },
    {
      "time": 104.769,
      "time_str": "01:44.769",
      "text": "知己笑声到永远",
      "translation": null
    },
    {
      "time": 128.713,
      "time_str": "02:08.713",
      "text": "如果可以回头避免",
      "translation": null
    },
    {
      "time": 133.029,
      "time_str": "02:13.029",
      "text": "也许彼此好过点",
      "translation": null
    },
    {
      "time": 137.006,
      "time_str": "02:17.006",
      "text": "无奈看你此刻眼睛",
      "translation": null
    },
    {
      "time": 140.785,
      "time_str": "02:20.785",
      "text": "仿佛我不应拒绝邀请",
      "translation": null
    },
    {
      "time": 145.061,
      "time_str": "02:25.061",
      "text": "谁知应要如何辨证",
      "translation": null
    },
    {
      "time": 149.284,
      "time_str": "02:29.284",
      "text": "才是友爱与痴情",
      "translation": null
    },
    {
      "time": 153.164,
      "time_str": "02:33.164",
      "text": "唯害怕爱火烧完",
      "translation": null
    },
    {
      "time": 156.68,
      "time_str": "02:36.680",
      "text": "现有的知己已再不见",
      "translation": null
    },
