{
  "title": "说唱脸谱",
  "title_raw": "说唱脸谱",
  "version": null,
  "artist": "谢津",
  "group_key": "说唱脸谱|谢津",
  "writers": {
    "lyricist": null,
    "composer": null,
    "arranger": null
  },
  "lyrics": [
    {
      "time": 18.305,
      "time_str": "00:18.305",
      "text": "那一天爷爷领我去把京戏看",
      "translation": null
    },
    {
      "time": 23.776,
      "time_str": "00:23.776",
      "text": "看见那舞台上面好多大花脸",
      "translation": null
    },
    {
      "time": 28.748,
      "time_str": "00:28.748",
      "text": "红白黄绿蓝咧嘴又瞪眼",
      "translation": null
    },
    {
      "time": 32.187,
      "time_str": "00:32.187",
      "text": "一边唱一边喊哇呀呀呀",
      "translation": null
    },
    {
      "time": 35.591,
      "time_str": "00:35.591",
      "text": "好像炸雷嘁哧咔喳震响在耳边",
      "translation": null
    },
    {
      "time": 46.373,
      "time_str": "00:46.373",
      "text": "蓝脸的窦尔墩盗御马",
      "translation": null
    },
    {
      "time": 49.541,
      "time_str": "00:49.541",
      "text": "红脸的关公战长沙",
      "translation": null
    },
    {
      "time": 52.96,
      "time_str": "00:52.960",
      "text": "黄脸的典韦白脸的曹操",
      "translation": null
    },
    {
      "time": 56.269,
      "time_str": "00:56.269",
      "text": "黑脸的张飞叫喳喳",
      "translation": null
    },
    {
      "time": 76.313,
      "time_str": "01:16.313",
      "text": "说实话京剧脸谱本来确实挺好看",
      "translation": null
    },
    {
      "time": 79.312,
      "time_str": "01:19.312",
      "text": "可唱的说的全是方言怎么听也不懂",
      "translation": null
    },
    {
      "time": 82.564,
      "time_str": "01:22.564",
      "text": "慢慢腾腾咿咿呀呀哼上老半天",
      "translation": null
    },
    {
      "time": 85.616,
      "time_str": "01:25.616",
      "text": "乐队伴奏一听光是锣鼓家伙",
      "translation": null
    },
    {
      "time": 88.451,
      "time_str": "01:28.451",
      "text": "隆格里格三大件",
      "translation": null
    },
    {
      "time": 90.514,
      "time_str": "01:30.514",
      "text": "这怎么能够跟上时代跟上潮流",
      "translation": null
    },
    {
      "time": 93.144,
      "time_str": "01:33.144",
      "text": "吸引当代小青年",
      "translation": null
    },
    {
      "time": 101.957,
      "time_str": "01:41.957",
      "text": "紫色的天王托宝塔",
      "translation": null
    },
    {
      "time": 105.96,
      "time_str": "01:45.960",
      "text": "绿色的魔鬼斗夜叉",
      "translation": null
    },
    {
      "time": 108.63,
      "time_str": "01:48.630",
      "text": "金色的猴王银色的妖怪",
      "translation": null
    },
    {
      "time": 111.934,
      "time_str": "01:51.934",
      "text": "灰色的精灵笑哈哈",
      "translation": null
    },
    {
      "time": 131.516,
      "time_str": "02:11.516",
      "text": "我爷爷生气说我纯粹这是瞎捣乱",
      "translation": null
    },
    {
      "time": 134.99,
      "time_str": "02:14.990",
      "text": "多美的精彩艺术中华瑰宝",
      "translation": null
    },
    {
      "time": 137.108,
      "time_str": "02:17.108",
      "text": "就连外国人也拍手叫好",
      "translation": null
    },
    {
      "time": 139.312,
      "time_str": "02:19.312",
      "text": "一个劲的来称赞",
      "translation": null
    },
    {
      "time": 141.63,
      "time_str": "02:21.630",
      "text": "生旦净末唱念做打",
      "translation": null
    },
    {
      "time": 143.136,
      "time_str": "02:23.136",
      "text": "手眼身法功夫真是不简单",
      "translation": null
    },
    {
      "time": 146.13,
      "time_str": "02:26.130",
      "text": "你不懂戏曲胡说八道",
      "translation": null
    },
    {
      "time": 148.31,
      "time_str": "02:28.310",
      "text": "气的爷爷胡子直往脸上翻",
      "translation": null
    },
    {
      "time": 152.694,
      "time_str": "02:32.694",
      "text": "老爷爷你别生气允许我申辩",
      "translation": null
    },
    {
      "time": 158.248,
      "time_str": "02:38.248",
      "text": "就算是山珍海味老吃也会烦",
      "translation": null
    },
    {
      "time": 163.198,
      "time_str": "02:43.198",
      "text": "艺术与时代不能离太远",
      "translation": null
    },
    {
      "time": 166.646,
      "time_str": "02:46.646",
      "text": "要创新要发展哇呀呀呀",
      "translation": null
    },
    {
      "time": 169.909,
      "time_str": "02:49.909",
      "text": "让那老的少的男的女的大家都爱看",
      "translation": null
    },
    {
      "time": 174.531,
      "time_str": "02:54.531",
      "text": "民族遗产一代一代往下传",
      "translation": null
    },
    {
      "time": 181.74,
      "time_str": "03:01.740",
      "text": "一幅幅鲜明的鸳鸯瓦",
      "translation": null
    },
    {
      "time": 184.887,
      "time_str": "03:04.887",
      "text": "一群群生动的活菩萨",
      "translation": null
    },
    {
      "time": 188.349,
      "time_str": "03:08.349",
      "text": "一笔笔勾描一点点夸大",
      "translation": null
    },
    {
      "time": 191.658,
      "time_str": "03:11.658",
      "text": "一张张脸谱美佳佳",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "说唱脸谱 - 谢津.lrc"
}