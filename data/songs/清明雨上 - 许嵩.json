  "lyrics": [
    {
      "time": 29.81,
      "time_str": "00:29.810",
      "text": "窗透初晓 日照西桥 云自摇",
      "translation": null
    },
    {
      "time": 35.71,
      "time_str": "00:35.710",
      "text": "想你当年荷风微摆的衣角",
      "translation": null
    },
    {
      "time": 43.06,
      "time_str": "00:43.060",
      "text": "木雕流金 岁月涟漪 七年前封笔",
      "translation": null
    },
    {
      "time": 49.34,
      "time_str": "00:49.340",
      "text": "因为我今生挥毫只为你",
      "translation": null
    },
    {
      "time": 56.41,
      "time_str": "00:56.410",
      "text": "雨打湿了眼眶 年年倚井盼归堂",
      "translation": null
    },
    {
      "time": 62.9,
      "time_str": "01:02.900",
      "text": "最怕不觉泪已拆两行",
      "translation": null
    },
    {
      "time": 68.61,
      "time_str": "01:08.610",
      "text": "我在人间彷徨 寻不到你的天堂",
      "translation": null
    },
    {
      "time": 75.35,
      "time_str": "01:15.350",
      "text": "东瓶西镜放 恨不能遗忘",
      "translation": null
    },
    {
      "time": 81.95,
      "time_str": "01:21.950",
      "text": "又是清明雨上 折菊寄到你身旁",
      "translation": null
    },
    {
      "time": 88.9,
      "time_str": "01:28.900",
      "text": "把你最爱的歌来轻轻唱",
      "translation": null
    },
    {
      "time": 109.15,
      "time_str": "01:49.150",
      "text": "远方有琴 愀然空灵 声声催天雨",
      "translation": null
    },
    {
      "time": 115.89,
      "time_str": "01:55.890",
      "text": "涓涓心事说给自己听",
      "translation": null
    },
    {
      "time": 122.55,
      "time_str": "02:02.550",
      "text": "月影憧憧 烟火几重 烛花红",
      "translation": null
    },
    {
      "time": 129.2,
      "time_str": "02:09.200",
      "text": "红尘旧梦 梦断都成空",
      "translation": null
    },
    {
