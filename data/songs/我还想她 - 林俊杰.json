  "lyrics": [
    {
      "time": 24.07,
      "time_str": "00:24.070",
      "text": "泪水将我淹没 到底谁该难过",
      "translation": null
    },
    {
      "time": 33.0,
      "time_str": "00:33.000",
      "text": "究竟是谁放掉 这段感情",
      "translation": null
    },
    {
      "time": 40.19,
      "time_str": "00:40.190",
      "text": "我才终于明白 办不到的承诺 就成了枷锁",
      "translation": null
    },
    {
      "time": 48.8,
      "time_str": "00:48.800",
      "text": "现实中幸福永远缺货",
      "translation": null
    },
    {
      "time": 55.52,
      "time_str": "00:55.520",
      "text": "请告诉她 我不爱她",
      "translation": null
    },
    {
      "time": 59.54,
      "time_str": "00:59.540",
      "text": "笑着难过 自我惩罚",
      "translation": null
    },
    {
      "time": 63.61,
      "time_str": "01:03.610",
      "text": "想终止这 一切挣扎",
      "translation": null
    },
    {
      "time": 67.4,
      "time_str": "01:07.400",
      "text": "横了心说真心谎话",
      "translation": null
    },
    {
      "time": 71.57,
      "time_str": "01:11.570",
      "text": "别告诉她 我还想她",
      "translation": null
    },
    {
      "time": 75.76,
      "time_str": "01:15.760",
      "text": "恨总比爱容易放下",
      "translation": null
    },
    {
      "time": 79.6,
      "time_str": "01:19.600",
      "text": "当泪水堵住了胸口",
      "translation": null
    },
    {
      "time": 83.57,
      "time_str": "01:23.570",
      "text": "就让沉默 代替所有回答",
      "translation": null
