  "lyrics": [
    {
      "time": 33.3,
      "time_str": "00:33.300",
      "text": "你问我这世界",
      "translation": null
    },
    {
      "time": 35.98,
      "time_str": "00:35.980",
      "text": "最远的地方在哪里",
      "translation": null
    },
    {
      "time": 41.0,
      "time_str": "00:41.000",
      "text": "我将答案抛向蓝天之外",
      "translation": null
    },
    {
      "time": 43.34,
      "time_str": "00:43.340",
      "text": "落在你心底",
      "translation": null
    },
    {
      "time": 47.29,
      "time_str": "00:47.290",
      "text": "如果你的爱",
      "translation": null
    },
    {
      "time": 49.64,
      "time_str": "00:49.640",
      "text": "总是逆向行驶",
      "translation": null
    },
    {
      "time": 54.62,
      "time_str": "00:54.620",
      "text": "你说你爱我",
      "translation": null
    },
    {
      "time": 56.9,
      "time_str": "00:56.900",
      "text": "我怎么能跟的上你",
      "translation": null
    },
    {
      "time": 62.88,
      "time_str": "01:02.880",
      "text": "你问我这世界",
      "translation": null
    },
    {
      "time": 65.07,
      "time_str": "01:05.070",
      "text": "最后的真爱在哪里",
      "translation": null
    },
    {
      "time": 70.08,
      "time_str": "01:10.080",
      "text": "我把线索指向大海之外",
      "translation": null
    },
    {
      "time": 72.36,
      "time_str": "01:12.360",
      "text": "直达我怀里",
      "translation": null
    },
    {
      "time": 76.44,
      "time_str": "01:16.440",
      "text": "如果你的心",
      "translation": null
    },
    {
      "time": 78.7,
      "time_str": "01:18.700",
      "text": "总是闭上耳朵",
      "translation": null
    },
    {
      "time": 83.7,
      "time_str": "01:23.700",
      "text": "我说我爱你",
      "translation": null
    },
    {
      "time": 86.01,
      "time_str": "01:26.010",
      "text": "你怎么能听得下去",
      "translation": null
    },
    {
      "time": 91.39,
      "time_str": "01:31.390",
      "text": "诺言背叛诺言",
      "translation": null
    },
    {
      "time": 93.15,
      "time_str": "01:33.150",
      "text": "刀子背叛缠绵",
      "translation": null
    },
    {
      "time": 95.05,
      "time_str": "01:35.050",
      "text": "刺进心头我却看不见",
      "translation": null
    },
    {
      "time": 98.53,
      "time_str": "01:38.530",
      "text": "我忘了喊痛忘了恩怨",
      "translation": null
    },
    {
      "time": 102.07,
      "time_str": "01:42.070",
      "text": "任爱情麻木哭泣的脸",
      "translation": null
    },
    {
      "time": 105.78,
      "time_str": "01:45.780",
      "text": "永远背叛永远",
      "translation": null
    },
    {
      "time": 107.54,
      "time_str": "01:47.540",
      "text": "泪水背叛双眼",
      "translation": null
    },
    {
      "time": 109.46,
      "time_str": "01:49.460",
      "text": "爱到深渊我还不改变",
      "translation": null
    },
    {
      "time": 113.1,
      "time_str": "01:53.100",
      "text": "我宁愿相信你的欺骗",
      "translation": null
    },
    {
      "time": 116.67,
      "time_str": "01:56.670",
      "text": "再不让我有对你去恨",
      "translation": null
    },
    {
      "time": 121.49,
      "time_str": "02:01.490",
      "text": "的一天",
      "translation": null
