  "lyrics": [
    {
      "time": 25.65,
      "time_str": "00:25.650",
      "text": "你说你最爱丁香花",
      "translation": null
    },
    {
      "time": 29.18,
      "time_str": "00:29.180",
      "text": "因为你的名字就是她",
      "translation": null
    },
    {
      "time": 32.98,
      "time_str": "00:32.980",
      "text": "多么忧郁的花",
      "translation": null
    },
    {
      "time": 36.57,
      "time_str": "00:36.570",
      "text": "多愁善感的人啊",
      "translation": null
    },
    {
      "time": 39.93,
      "time_str": "00:39.930",
      "text": "当花儿枯萎的时候",
      "translation": null
    },
    {
      "time": 43.27,
      "time_str": "00:43.270",
      "text": "当画面定格的时候",
      "translation": null
    },
    {
      "time": 47.2,
      "time_str": "00:47.200",
      "text": "多么娇嫩的花",
      "translation": null
    },
    {
      "time": 50.4,
      "time_str": "00:50.400",
      "text": "却躲不过风吹雨打",
      "translation": null
    },
    {
      "time": 54.16,
      "time_str": "00:54.160",
      "text": "飘啊摇啊的一生",
      "translation": null
    },
    {
      "time": 57.64,
      "time_str": "00:57.640",
      "text": "多少美丽编织的梦啊",
      "translation": null
    },
    {
      "time": 61.06,
      "time_str": "01:01.060",
      "text": "就这样匆匆你走了",
      "translation": null
    },
    {
      "time": 64.84,
      "time_str": "01:04.840",
      "text": "留给我一生牵挂",
      "translation": null
    },
    {
      "time": 68.39,
      "time_str": "01:08.390",
      "text": "那坟前开满鲜花",
      "translation": null
    },
    {
      "time": 71.88,
      "time_str": "01:11.880",
      "text": "是你多么渴望的美啊",
      "translation": null
    },
    {
      "time": 75.41,
      "time_str": "01:15.410",
      "text": "你看啊漫山遍野",
      "translation": null
    },
    {
      "time": 78.95,
      "time_str": "01:18.950",
      "text": "你还觉得孤单吗",
      "translation": null
    },
    {
      "time": 82.48,
      "time_str": "01:22.480",
      "text": "你听啊有人在唱",
      "translation": null
    },
    {
      "time": 86.02,
      "time_str": "01:26.020",
      "text": "那首你最爱的歌谣啊",
      "translation": null
    },
    {
      "time": 89.47,
      "time_str": "01:29.470",
      "text": "尘世间多少繁芜",
      "translation": null
    },
    {
      "time": 93.05,
      "time_str": "01:33.050",
      "text": "从此不必再牵挂",
      "translation": null
    },
