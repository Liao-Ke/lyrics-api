  "lyrics": [
    {
      "time": 25.9,
      "time_str": "00:25.900",
      "text": "与你相逢 其实就像一个梦",
      "translation": null
    },
    {
      "time": 29.9,
      "time_str": "00:29.900",
      "text": "梦醒无影又无踪",
      "translation": null
    },
    {
      "time": 33.9,
      "time_str": "00:33.900",
      "text": "总是看了不能忘 总是过了不能想",
      "translation": null
    },
    {
      "time": 37.9,
      "time_str": "00:37.900",
      "text": "总让我为你痴狂",
      "translation": null
    },
    {
      "time": 44.9,
      "time_str": "00:44.900",
      "text": "让我爱上你 其实没什么道理",
      "translation": null
    },
    {
      "time": 48.9,
      "time_str": "00:48.900",
      "text": "明明知道不可以",
      "translation": null
    },
    {
      "time": 52.9,
      "time_str": "00:52.900",
      "text": "让我痛苦为了你 让我快乐为了你",
      "translation": null
    },
    {
      "time": 56.9,
      "time_str": "00:56.900",
      "text": "没有你还有什么意义",
      "translation": null
    },
    {
      "time": 62.9,
      "time_str": "01:02.900",
      "text": "看那东南西北风 吹着不同的脸孔",
      "translation": null
    },
    {
      "time": 66.9,
      "time_str": "01:06.900",
      "text": "难道爱情只是一阵风",
      "translation": null
    },
    {
      "time": 71.9,
      "time_str": "01:11.900",
      "text": "我的心儿碰呀碰 因为有你在梦中",
      "translation": null
    },
    {
      "time": 75.9,
      "time_str": "01:15.900",
      "text": "从此生命不再空呀空",
      "translation": null
    },
    {
      "time": 79.9,
      "time_str": "01:19.900",
      "text": "也许爱变得更浓 也许变得无影踪",
      "translation": null
    },
    {
      "time": 83.9,
      "time_str": "01:23.900",
      "text": "只要有你我就有笑容",
      "translation": null
    },
    {
      "time": 90.9,
      "time_str": "01:30.900",
      "text": "让我爱上你 其实没什么道理",
      "translation": null
