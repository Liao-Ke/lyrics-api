  "lyrics": [
    {
      "time": 0.73,
      "time_str": "00:00.730",
      "text": "蔚蓝的星球是我们不变的守候",
      "translation": null
    },
    {
      "time": 7.36,
      "time_str": "00:07.360",
      "text": "期待你永远的奥特曼",
      "translation": null
    },
    {
      "time": 31.05,
      "time_str": "00:31.050",
      "text": "大地渐渐苏醒",
      "translation": null
    },
    {
      "time": 33.47,
      "time_str": "00:33.470",
      "text": "一丝晨光打破了夜的寂静",
      "translation": null
    },
    {
      "time": 39.83,
      "time_str": "00:39.830",
      "text": "炙热的心在跳动",
      "translation": null
    },
    {
      "time": 44.35,
      "time_str": "00:44.350",
      "text": "祈祷和平降临",
      "translation": null
    },
    {
      "time": 49.7,
      "time_str": "00:49.700",
      "text": "我们一起追寻前途弥漫荆棘和险峻",
      "translation": null
    },
    {
      "time": 58.55,
      "time_str": "00:58.550",
      "text": "心中呐喊无边天际放射光明",
      "translation": null
    },
    {
      "time": 67.36,
      "time_str": "01:07.360",
      "text": "看那蔚蓝色的星球",
      "translation": null
    },
    {
      "time": 71.16,
      "time_str": "01:11.160",
      "text": "是我们永远的守候",
      "translation": null
    },
    {
      "time": 74.86,
      "time_str": "01:14.860",
      "text": "我伫立在这里倾听风的声音",
      "translation": null
    },
    {
      "time": 80.35,
      "time_str": "01:20.350",
      "text": "来吧我的热情在飞翔",
      "translation": null
    },
    {
      "time": 84.06,
      "time_str": "01:24.060",
      "text": "带着那灿烂的希望",
      "translation": null
    },
    {
      "time": 87.48,
      "time_str": "01:27.480",
      "text": "我们携手并肩穿越时空界限",
      "translation": null
    },
    {
      "time": 90.93,
      "time_str": "01:30.930",
      "text": "冲破黑暗",
      "translation": null
    },
    {
      "time": 94.76,
      "time_str": "01:34.760",
      "text": "YOU ARE ALWAYS MY HERO",
      "translation": null
    },
    {
      "time": 99.15,
      "time_str": "01:39.150",
      "text": "......",
      "translation": null
