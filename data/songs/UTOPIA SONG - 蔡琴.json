    {
      "time": 12.16,
      "time_str": "00:12.160",
      "text": "我要帶你到處去飛翔",
      "translation": null
    },
    {
      "time": 17.98,
      "time_str": "00:17.980",
      "text": "走遍世界各地去觀賞",
      "translation": null
    },
    {
      "time": 24.85,
      "time_str": "00:24.850",
      "text": "沒有煩惱沒有那悲傷",
      "translation": null
    },
    {
      "time": 30.76,
      "time_str": "00:30.760",
      "text": "自由自在身心多開朗",
      "translation": null
    },
    {
      "time": 37.46,
      "time_str": "00:37.460",
      "text": "忘掉痛苦忘掉那悲傷",
      "translation": null
    },
    {
      "time": 43.18,
      "time_str": "00:43.180",
      "text": "我們一起啟程去流浪",
      "translation": null
    },
    {
      "time": 49.42,
      "time_str": "00:49.420",
      "text": "雖然沒有華廈美衣裳",
      "translation": null
    },
    {
      "time": 55.16,
      "time_str": "00:55.160",
      "text": "但是心裏充滿著希望",
      "translation": null
    },
    {
      "time": 60.96,
      "time_str": "01:00.960",
      "text": "我們要飛到那遙遠地方 看一看",
      "translation": null
    },
    {
      "time": 68.56,
      "time_str": "01:08.560",
      "text": "這世界並非那麼凄涼",
      "translation": null
    },
    {
      "time": 73.99,
      "time_str": "01:13.990",
      "text": "我們要飛到那遙遠地方 望一望",
      "translation": null
    },
    {
      "time": 80.49,
      "time_str": "01:20.490",
      "text": "這世界還是一片的光亮",
