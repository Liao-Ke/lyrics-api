  "lyrics": [
    {
      "time": 18.78,
      "time_str": "00:18.780",
      "text": "很想知道你现在的消息",
      "translation": null
    },
    {
      "time": 22.91,
      "time_str": "00:22.910",
      "text": "不清楚自己是怎样的心情",
      "translation": null
    },
    {
      "time": 27.74,
      "time_str": "00:27.740",
      "text": "那个曾经只给我依靠的肩膀",
      "translation": null
    },
    {
      "time": 32.26,
      "time_str": "00:32.260",
      "text": "如今给了谁",
      "translation": null
    },
    {
      "time": 36.75,
      "time_str": "00:36.750",
      "text": "时间改变了你我的样子",
      "translation": null
    },
    {
      "time": 41.24,
      "time_str": "00:41.240",
      "text": "却留下你爱我时的影子",
      "translation": null
    },
    {
      "time": 45.95,
      "time_str": "00:45.950",
      "text": "那些曾经只给我流过的眼泪",
      "translation": null
    },
    {
      "time": 50.35,
      "time_str": "00:50.350",
      "text": "如今为了谁",
      "translation": null
    },
    {
      "time": 55.48,
      "time_str": "00:55.480",
      "text": "你和我不了了之的爱情",
      "translation": null
    },
    {
      "time": 60.27,
      "time_str": "01:00.270",
      "text": "有一段不了了之的回忆",
      "translation": null
    },
    {
      "time": 65.44,
      "time_str": "01:05.440",
      "text": "你记得我 还是已经忘记",
      "translation": null
    },
    {
      "time": 70.12,
      "time_str": "01:10.120",
      "text": "谁为谁放弃",
      "translation": null
    },
    {
