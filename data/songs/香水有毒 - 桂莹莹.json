  "lyrics": [
    {
      "time": 19.01,
      "time_str": "00:19.010",
      "text": "我曾经爱过这样一个男人",
      "translation": null
    },
    {
      "time": 23.55,
      "time_str": "00:23.550",
      "text": "他说我是世上最美的女人",
      "translation": null
    },
    {
      "time": 28.35,
      "time_str": "00:28.350",
      "text": "我为他保留着那一份天真",
      "translation": null
    },
    {
      "time": 33.68,
      "time_str": "00:33.680",
      "text": "关上爱别人的门",
      "translation": null
    },
    {
      "time": 37.58,
      "time_str": "00:37.580",
      "text": "也是这个被我深爱的男人",
      "translation": null
    },
    {
      "time": 42.21,
      "time_str": "00:42.210",
      "text": "把我变成世上最笨的女人",
      "translation": null
    },
    {
      "time": 46.98,
      "time_str": "00:46.980",
      "text": "他说的每句话我都会当真",
      "translation": null
    },
    {
      "time": 52.17,
      "time_str": "00:52.170",
      "text": "他说最爱我的唇",
      "translation": null
    },
    {
      "time": 56.28,
      "time_str": "00:56.280",
      "text": "我的要求并不高",
      "translation": null
    },
    {
      "time": 60.85,
      "time_str": "01:00.850",
      "text": "待我像从前一样好",
      "translation": null
    },
    {
      "time": 65.62,
      "time_str": "01:05.620",
      "text": "可是有一天",
      "translation": null
    },
    {
      "time": 67.85,
      "time_str": "01:07.850",
      "text": "你说了同样的话",
      "translation": null
    },
    {
      "time": 70.5,
      "time_str": "01:10.500",
      "text": "把别人拥入怀抱",
      "translation": null
    },
    {
      "time": 77.02,
      "time_str": "01:17.020",
      "text": "你身上有她的香水味",
      "translation": null
    },
    {
      "time": 82.34,
      "time_str": "01:22.340",
      "text": "是我鼻子犯的罪",
      "translation": null
    },
    {
      "time": 86.98,
      "time_str": "01:26.980",
      "text": "不该嗅到她的美",
      "translation": null
    },
    {
      "time": 91.69,
      "time_str": "01:31.690",
      "text": "擦掉一切陪你睡",
      "translation": null
    },
