  "lyrics": [
    {
      "time": 13.53,
      "time_str": "00:13.530",
      "text": "不知道在那天边可会有尽头",
      "translation": null
    },
    {
      "time": 19.47,
      "time_str": "00:19.470",
      "text": "只知道逝去光阴不会再回头",
      "translation": null
    },
    {
      "time": 25.7,
      "time_str": "00:25.700",
      "text": "每一串泪水伴每一个梦想",
      "translation": null
    },
    {
      "time": 30.95,
      "time_str": "00:30.950",
      "text": "不知不觉全溜走",
      "translation": null
    },
    {
      "time": 36.18,
      "time_str": "00:36.180",
      "text": "不经意在这圈中转到这年头",
      "translation": null
    },
    {
      "time": 41.66,
      "time_str": "00:41.660",
      "text": "只感到在这圈中经过顺逆流",
      "translation": null
    },
    {
      "time": 47.95,
      "time_str": "00:47.950",
      "text": "每颗冷酷眼光",
      "translation": null
    },
    {
      "time": 50.6,
      "time_str": "00:50.600",
      "text": "共每声友善笑声",
      "translation": null
    },
    {
      "time": 53.22,
      "time_str": "00:53.220",
      "text": "默然一一尝透",
      "translation": null
    },
    {
      "time": 59.21,
      "time_str": "00:59.210",
      "text": "几多艰苦当天我默默接受",
      "translation": null
    },
    {
      "time": 64.72,
      "time_str": "01:04.720",
      "text": "几多辛酸也未放手",
      "translation": null
    },
    {
      "time": 70.35,
      "time_str": "01:10.350",
      "text": "故意挑剔今天我不在乎",
      "translation": null
    },
    {
      "time": 75.88,
      "time_str": "01:15.880",
      "text": "只跟心中意愿去走",
      "translation": null
    },
    {
      "time": 80.82,
      "time_str": "01:20.820",
      "text": "不相信未作牺牲竟先可拥有",
      "translation": null
    },
    {
      "time": 86.22,
      "time_str": "01:26.220",
      "text": "只相信是靠双手找到我欲求",
      "translation": null
    },
    {
      "time": 92.59,
      "time_str": "01:32.590",
      "text": "每一串汗水",
      "translation": null
    },
    {
      "time": 95.04,
      "time_str": "01:35.040",
      "text": "换每一个成就",
      "translation": null
    },
    {
      "time": 97.82,
