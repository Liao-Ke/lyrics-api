    "arranger": null
  },
  "lyrics": [
    {
      "time": 23.5,
      "time_str": "00:23.500",
      "text": "我记得那个夏天球场边的约定",
      "translation": null
    },
    {
      "time": 28.76,
      "time_str": "00:28.760",
      "text": "和窗外挂在树梢的白云",
      "translation": null
    },
    {
      "time": 33.67,
      "time_str": "00:33.670",
      "text": "我怀念曾经感动的旋律",
      "translation": null
    },
    {
      "time": 37.88,
      "time_str": "00:37.880",
      "text": "是永远说不完的话题",
      "translation": null
    },
    {
      "time": 43.4,
      "time_str": "00:43.400",
      "text": "你送的相片我会好好藏在抽屉",
      "translation": null
    },
    {
      "time": 48.39,
      "time_str": "00:48.390",
      "text": "偶尔才翻开那些青涩回忆",
      "translation": null
    },
    {
      "time": 53.26,
      "time_str": "00:53.260",
      "text": "幸福的笑容里一点一滴",
      "translation": null
    },
    {
      "time": 57.51,
      "time_str": "00:57.510",
      "text": "那属于我们的秘密",
      "translation": null
    },
    {
      "time": 62.02,
      "time_str": "01:02.020",
      "text": "回忆好像天上片片繁星",
      "translation": null
    },
    {
      "time": 67.45,
      "time_str": "01:07.450",
      "text": "从不曾被时间忘记",
      "translation": null
    },
    {
      "time": 72.25,
      "time_str": "01:12.250",
      "text": "当阳光照亮提醒黎明的苏醒",
      "translation": null
    },
    {
      "time": 77.14,
      "time_str": "01:17.140",
      "text": "我们都试着学会抛开过去",
      "translation": null
    },
    {
      "time": 82.94,
      "time_str": "01:22.940",
      "text": "我知道风会带来关于你的消息",
      "translation": null
    },
    {
      "time": 87.74,
      "time_str": "01:27.740",
      "text": "也知道烂漫天真终会远离",
      "translation": null
    },
    {
      "time": 92.63,
      "time_str": "01:32.630",
      "text": "在心中泛起那小小涟漪",
      "translation": null
    },
    {
      "time": 97.0,
      "time_str": "01:37.000",
      "text": "是风吹过的痕迹",
      "translation": null
    },
    {
