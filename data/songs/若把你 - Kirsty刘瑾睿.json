      "time": 18.84,
      "time_str": "00:18.840",
      "text": "落叶无归根 单丝不成线",
      "translation": null
    },
    {
      "time": 27.71,
      "time_str": "00:27.710",
      "text": "无所寄托 亦无心流浪",
      "translation": null
    },
    {
      "time": 36.57,
      "time_str": "00:36.570",
      "text": "你把红豆赠我不如写我一首歌",
      "translation": null
    },
    {
      "time": 44.24,
      "time_str": "00:44.240",
      "text": "落款你的名字 工整又好看",
      "translation": null
    },
    {
      "time": 52.47,
      "time_str": "00:52.470",
      "text": "若把你比作歌",
      "translation": null
    },
    {
