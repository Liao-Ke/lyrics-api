  "lyrics": [
    {
      "time": 32.68,
      "time_str": "00:32.680",
      "text": "爱还没来 天地间风云忽然变",
      "translation": null
    },
    {
      "time": 39.29,
      "time_str": "00:39.290",
      "text": "有情有义的人都要回来",
      "translation": null
    },
    {
      "time": 47.03,
      "time_str": "00:47.030",
      "text": "爱总会来 生死注定的来世再爱",
      "translation": null
    },
    {
      "time": 54.15,
      "time_str": "00:54.150",
      "text": "都等了太久 哭尽无奈",
      "translation": null
    },
    {
      "time": 61.22,
      "time_str": "01:01.220",
      "text": "她从树中来 追随前世真爱",
      "translation": null
    },
    {
      "time": 64.78,
      "time_str": "01:04.780",
      "text": "亲身体验过 春去秋又来",
      "translation": null
    },
    {
      "time": 68.33,
      "time_str": "01:08.330",
      "text": "情到至深时 乌发也浓白",
      "translation": null
    },
    {
      "time": 71.88,
      "time_str": "01:11.880",
      "text": "剑成人后心动花灿烂地开",
      "translation": null
    },
    {
      "time": 77.32,
      "time_str": "01:17.320",
      "text": "爱恨纠缠的生生世世",
      "translation": null
    },
    {
      "time": 80.56,
      "time_str": "01:20.560",
      "text": "心底执着的信念为你存在",
      "translation": null
    },
    {
      "time": 84.06,
      "time_str": "01:24.060",
      "text": "多遥远的路 都阻挡不住",
      "translation": null
    },
    {
      "time": 87.61,
      "time_str": "01:27.610",
      "text": "再次拥有没距离的温度",
      "translation": null
    },
    {
      "time": 91.33,
      "time_str": "01:31.330",
      "text": "失去自由的生生世世",
      "translation": null
    },
    {
      "time": 94.68,
      "time_str": "01:34.680",
      "text": "有爱不懂相拥错过了最爱",
      "translation": null
    },
    {
      "time": 98.28,
      "time_str": "01:38.280",
      "text": "送一剑祝福 再默默相助",
      "translation": null
    },
    {
      "time": 101.83,
      "time_str": "01:41.830",
      "text": "恐怕没以后不自觉留退路",
      "translation": null
    },
    {
      "time": 107.51,
      "time_str": "01:47.510",
      "text": "【间奏】",
      "translation": null
    },
    {
      "time": 137.51,
      "time_str": "02:17.510",
      "text": "爱还没来 天地间风云忽然变",
      "translation": null
