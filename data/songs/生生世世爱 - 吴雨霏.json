    {
      "time": 210.54,
      "time_str": "03:30.540",
      "text": "为情所困的生生世世",
      "translation": null
    },
    {
      "time": 213.84,
      "time_str": "03:33.840",
      "text": "伤也被伤 命中成双的伤害",
      "translation": null
    },
    {
      "time": 217.39,
      "time_str": "03:37.390",
      "text": "等不到日出 一个人孤独",
      "translation": null
    },
    {
      "time": 220.9,
      "time_str": "03:40.900",
      "text": "让星光代替我伴你远途",
      "translation": null
    },
    {
      "time": 224.64,
      "time_str": "03:44.640",
      "text": "黑白轮回的生生世世",
      "translation": null
    },
    {
      "time": 227.95,
      "time_str": "03:47.950",
      "text": "彻底放开成全永远的依赖",
      "translation": null
    },
    {
      "time": 231.55,
      "time_str": "03:51.550",
      "text": "是乱世英雄 或凡间俗梦",
      "translation": null
    },
    {
      "time": 235.09,
      "time_str": "03:55.090",
      "text": "爱不离爱是把这感动留住",
