      "time": 1.52,
      "time_str": "00:01.520",
      "text": "形状 - 星一问水",
      "translation": null
    },
    {
      "time": 5.96,
      "time_str": "00:05.960",
      "text": "后期：Jove、星一问水",
      "translation": null
    },
    {
      "time": 15.88,
      "time_str": "00:15.880",
      "text": "我占有 你岁月 多少时光",
      "translation": null
    },
    {
      "time": 20.15,
      "time_str": "00:20.150",
      "text": "怎么就 转眼已 各自散场",
      "translation": null
    },
    {
      "time": 24.08,
      "time_str": "00:24.080",
      "text": "来不及失落 就跌宕",
      "translation": null
    },
    {
      "time": 31.6,
      "time_str": "00:31.600",
      "text": "我为你 也有过 几年疯狂",
      "translation": null
    },
    {
      "time": 35.25,
      "time_str": "00:35.250",
      "text": "当爱由 具体已 开始抽象",
      "translation": null
    },
    {
      "time": 39.38,
      "time_str": "00:39.380",
      "text": "我沉浸 虚空的梦乡",
      "translation": null
    },
    {
      "time": 45.43,
      "time_str": "00:45.430",
      "text": "是我执着 选择迷茫",
      "translation": null
    },
    {
      "time": 48.63,
      "time_str": "00:48.630",
      "text": "是我偏要 失去方向",
      "translation": null
    },
    {
      "time": 53.31,
      "time_str": "00:53.310",
      "text": "是我太张扬",
      "translation": null
    },
    {
      "time": 55.59,
      "time_str": "00:55.590",
      "text": "才让你退场 避开我锋芒",
      "translation": null
    },
    {
      "time": 60.56,
      "time_str": "01:00.560",
      "text": "如果 孤独有形状",
      "translation": null
    },
    {
      "time": 62.93,
      "time_str": "01:02.930",
      "text": "大概是我的模样",
      "translation": null
    },
    {
      "time": 65.09,
      "time_str": "01:05.090",
      "text": "是你离开太坦荡",
      "translation": null
    },
    {
      "time": 66.88,
      "time_str": "01:06.880",
      "text": "任我 独自流浪",
      "translation": null
    },
    {
      "time": 68.72,
      "time_str": "01:08.720",
      "text": "面对这夜里难抵的 一片空荡",
      "translation": null
    },
    {
      "time": 72.79,
      "time_str": "01:12.790",
      "text": "消磨期望 背光生长",
      "translation": null
