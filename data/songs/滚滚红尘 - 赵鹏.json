    {
      "time": 48.0,
      "time_str": "00:48.000",
      "text": "起初不经意的你",
      "translation": null
    },
    {
      "time": 53.0,
      "time_str": "00:53.000",
      "text": "和少年不经世的我",
      "translation": null
    },
    {
      "time": 58.0,
      "time_str": "00:58.000",
      "text": "红尘中的情缘",
      "translation": null
    },
    {
      "time": 60.0,
      "time_str": "01:00.000",
      "text": "只因那生命匆匆不语的胶着",
      "translation": null
    },
    {
      "time": 66.0,
      "time_str": "01:06.000",
      "text": "想是人世间的错",
      "translation": null
    },
    {
      "time": 70.0,
      "time_str": "01:10.000",
      "text": "或前世流传的因果",
      "translation": null
    },
    {
      "time": 74.0,
      "time_str": "01:14.000",
      "text": "终生的所有",
      "translation": null
    },
    {
      "time": 77.0,
      "time_str": "01:17.000",
      "text": "也不惜换取刹那阴阳的交流",
      "translation": null
    },
    {
      "time": 83.0,
      "time_str": "01:23.000",
      "text": "来易来去难去",
      "translation": null
    },
    {
      "time": 87.0,
      "time_str": "01:27.000",
      "text": "数十载的人世游",
      "translation": null
    },
    {
      "time": 91.0,
      "time_str": "01:31.000",
      "text": "分易分聚难聚",
      "translation": null
    },
    {
      "time": 96.0,
      "time_str": "01:36.000",
      "text": "爱与恨的千古愁",
      "translation": null
    },
    {
      "time": 100.0,
      "time_str": "01:40.000",
      "text": "本应属于你的心",
      "translation": null
    },
    {
      "time": 103.0,
      "time_str": "01:43.000",
      "text": "它依然护紧我胸口",
      "translation": null
    },
    {
      "time": 108.0,
      "time_str": "01:48.000",
      "text": "为只为那尘世转变的面孔后的翻云覆雨手",
      "translation": null
    },
    {
      "time": 116.0,
