    {
      "time": 31.94,
      "time_str": "00:31.940",
      "text": "不要问我 一生曾经爱过多少人",
      "translation": null
    },
    {
      "time": 38.978,
      "time_str": "00:38.978",
      "text": "你不懂我伤有多深",
      "translation": null
    },
    {
      "time": 46.353,
      "time_str": "00:46.353",
      "text": "要剥开伤口总是很残忍",
      "translation": null
    },
    {
      "time": 49.829,
      "time_str": "00:49.829",
      "text": "劝你别做痴心人",
      "translation": null
    },
    {
      "time": 54.445,
      "time_str": "00:54.445",
      "text": "多情暂且保留几分",
      "translation": null
    },
    {
      "time": 61.289,
      "time_str": "01:01.289",
      "text": "不喜欢孤独",
      "translation": null
    },
    {
      "time": 64.543,
      "time_str": "01:04.543",
      "text": "却又害怕两个人相处",
      "translation": null
    },
    {
      "time": 68.433,
      "time_str": "01:08.433",
      "text": "这分明是一种痛苦",
      "translation": null
    },
    {
      "time": 75.78,
      "time_str": "01:15.780",
      "text": "在人多时候最沉默",
      "translation": null
    },
    {
      "time": 79.729,
      "time_str": "01:19.729",
      "text": "笑容也寂寞",
      "translation": null
    },
    {
      "time": 83.151,
      "time_str": "01:23.151",
      "text": "在万丈红尘中 啊",
      "translation": null
    },
    {
      "time": 87.103,
      "time_str": "01:27.103",
      "text": "找个人爱我",
      "translation": null
    },
    {
      "time": 90.304,
      "time_str": "01:30.304",
      "text": "当我避开你的柔情后",
      "translation": null
    },
    {
      "time": 93.043,
      "time_str": "01:33.043",
      "text": "泪开始坠落",
      "translation": null
    },
    {
      "time": 97.861,
      "time_str": "01:37.861",
      "text": "是不敢不想不应该",
      "translation": null
    },
    {
      "time": 101.555,
      "time_str": "01:41.555",
      "text": "再谢谢你的爱",
      "translation": null
    },
    {
      "time": 105.24,
      "time_str": "01:45.240",
      "text": "我不得不存在",
      "translation": null
    },
    {
      "time": 109.169,
      "time_str": "01:49.169",
      "text": "像一颗尘埃",
      "translation": null
    },
    {
      "time": 112.585,
      "time_str": "01:52.585",
      "text": "还是会带给你伤害",
      "translation": null
    },
    {
