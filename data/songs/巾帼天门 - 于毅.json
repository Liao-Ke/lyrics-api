  "lyrics": [
    {
      "time": 43.28,
      "time_str": "00:43.280",
      "text": "男：狼烟似血烧 战鼓若心跳",
      "translation": null
    },
    {
      "time": 46.42,
      "time_str": "00:46.420",
      "text": "万马丛横刀 你仰天长啸",
      "translation": null
    },
    {
      "time": 49.74,
      "time_str": "00:49.740",
      "text": "胡儿略地 将军恨不消",
      "translation": null
    },
    {
      "time": 52.75,
      "time_str": "00:52.750",
      "text": "桃花深夜无寐 蹄声雨 敲",
      "translation": null
    },
    {
      "time": 56.37,
      "time_str": "00:56.370",
      "text": "江山画飘摇 边塞虎狼嚎",
      "translation": null
    },
    {
      "time": 59.56,
      "time_str": "00:59.560",
      "text": "披戎装扬眉 你剑锋出 鞘",
      "translation": null
    },
    {
      "time": 62.86,
      "time_str": "01:02.860",
      "text": "雄关雁门 尘暗旧征袍",
      "translation": null
    },
    {
      "time": 66.06,
      "time_str": "01:06.060",
      "text": "纛旗号令风萧萧",
      "translation": null
    },
    {
      "time": 68.99,
      "time_str": "01:08.990",
      "text": "旦角：桃花 马上威风凛凛 敌血飞溅石榴裙",
      "translation": null
    },
    {
      "time": 75.75,
      "time_str": "01:15.750",
      "text": "有生之日 责任应尽 一剑当万兵",
      "translation": null
    },
    {
      "time": 81.5,
      "time_str": "01:21.500",
      "text": "回望汴京故里父老",
      "translation": null
    },
    {
      "time": 85.37,
      "time_str": "01:25.370",
      "text": "男：殷殷深情路迢迢",
      "translation": null
    },
    {
      "time": 88.27,
      "time_str": "01:28.270",
      "text": "旦角：万斤之重千仞之高",
      "translation": null
    },
    {
      "time": 91.78,
      "time_str": "01:31.780",
      "text": "男：家国霜雪一肩挑",
      "translation": null
    },
    {
      "time": 94.85,
      "time_str": "01:34.850",
      "text": "旦角：决战天门英豪",
      "translation": null
    },
    {
      "time": 98.43,
      "time_str": "01:38.430",
      "text": "男：拳拳赤胆浪滔滔",
      "translation": null
    },
    {
      "time": 101.12,
      "time_str": "01:41.120",
      "text": "千军逞一勇万夫麾下招",
      "translation": null
    },
    {
      "time": 104.86,
      "time_str": "01:44.860",
      "text": "生死 往兮你笑傲",
      "translation": null
    },
