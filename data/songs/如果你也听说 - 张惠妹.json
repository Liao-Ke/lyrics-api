  "lyrics": [
    {
      "time": 20.56,
      "time_str": "00:20.560",
      "text": "突然发现站了好久",
      "translation": null
    },
    {
      "time": 24.71,
      "time_str": "00:24.710",
      "text": "不知道要往哪走",
      "translation": null
    },
    {
      "time": 29.07,
      "time_str": "00:29.070",
      "text": "还不想回家的我",
      "translation": null
    },
    {
      "time": 32.91,
      "time_str": "00:32.910",
      "text": "再多人陪 只会更寂寞",
      "translation": null
    },
    {
      "time": 37.11,
      "time_str": "00:37.110",
      "text": "许多话题 关于我",
      "translation": null
    },
    {
      "time": 41.05,
      "time_str": "00:41.050",
      "text": "就连我 也有听过",
      "translation": null
    },
    {
      "time": 45.17,
      "time_str": "00:45.170",
      "text": "我的快乐 要被认可",
      "translation": null
    },
    {
      "time": 49.23,
      "time_str": "00:49.230",
      "text": "委屈却没有人诉说",
      "translation": null
    },
    {
      "time": 53.1,
      "time_str": "00:53.100",
      "text": "夜把心洋葱般剥落",
      "translation": null
    },
    {
      "time": 57.26,
      "time_str": "00:57.260",
      "text": "拿掉防卫 剩下什么",
      "translation": null
    },
    {
      "time": 61.33,
      "time_str": "01:01.330",
      "text": "为什么脆弱时候 想你更多",
      "translation": null
    },
    {
      "time": 68.54,
      "time_str": "01:08.540",
      "text": "如果你也听说 有没有想过我",
      "translation": null
    },
    {
      "time": 76.69,
      "time_str": "01:16.690",
      "text": "像普通旧朋友",
      "translation": null
    },
    {
      "time": 80.3,
      "time_str": "01:20.300",
      "text": "还是你依然会心疼我",
      "translation": null
    },
    {
      "time": 85.46,
      "time_str": "01:25.460",
      "text": "好多好多的话想对你说",
      "translation": null
    },
    {
      "time": 90.0,
      "time_str": "01:30.000",
      "text": "悬着一颗心没着落",
      "translation": null
    },
    {
      "time": 94.22,
      "time_str": "01:34.220",
      "text": "要怎么附和 舍不得 又无可奈何",
      "translation": null
    },
    {
      "time": 101.57,
      "time_str": "01:41.570",
      "text": "如果你也听说 会不会相信我",
      "translation": null
    },
    {
      "time": 109.52,
      "time_str": "01:49.520",
      "text": "对流言会附和",
      "translation": null
    },
    {
      "time": 113.15,
      "time_str": "01:53.150",
      "text": "还是你知道我还是我",
      "translation": null
    },
    {
      "time": 118.3,
      "time_str": "01:58.300",
      "text": "跌跌撞撞才明白了许多",
      "translation": null
    },
    {
      "time": 122.85,
      "time_str": "02:02.850",
      "text": "懂我的人就你一个",
      "translation": null
    },
    {
