  "lyrics": [
    {
      "time": 17.61,
      "time_str": "00:17.610",
      "text": "你的晚安 是下意识的恻隐",
      "translation": null
    },
    {
      "time": 24.27,
      "time_str": "00:24.270",
      "text": "我留至夜深 治疗失眠梦呓",
      "translation": null
    },
    {
      "time": 30.19,
      "time_str": "00:30.190",
      "text": "那封手写信 留在行李箱底",
      "translation": null
    },
    {
      "time": 36.28,
      "time_str": "00:36.280",
      "text": "来不及 赋予它旅途的意义",
      "translation": null
    },
    {
      "time": 43.25,
      "time_str": "00:43.250",
      "text": "若一切 都已云烟成雨",
      "translation": null
    },
    {
      "time": 48.89,
      "time_str": "00:48.890",
      "text": "我能否 变成淤泥",
      "translation": null
    },
    {
      "time": 51.89,
      "time_str": "00:51.890",
      "text": "再一次 沾染你",
      "translation": null
    },
    {
      "time": 55.05,
      "time_str": "00:55.050",
      "text": "若生命 如过场电影",
      "translation": null
    },
    {
      "time": 60.929,
      "time_str": "01:00.929",
      "text": "Oh 让我再一次 甜梦里惊醒",
      "translation": null
    },
    {
      "time": 73.269,
      "time_str": "01:13.269",
      "text": "我多想再见你",
      "translation": null
    },
    {
      "time": 74.888,
      "time_str": "01:14.888",
      "text": "哪怕匆匆一眼就别离",
      "translation": null
    },
    {
      "time": 79.159,
      "time_str": "01:19.159",
      "text": "路灯下昏黄的剪影",
      "translation": null
    },
    {
      "time": 82.159,
      "time_str": "01:22.159",
      "text": "越走越漫长的林径",
      "translation": null
    },
    {
      "time": 85.349,
      "time_str": "01:25.349",
      "text": "我多想再见你",
      "translation": null
