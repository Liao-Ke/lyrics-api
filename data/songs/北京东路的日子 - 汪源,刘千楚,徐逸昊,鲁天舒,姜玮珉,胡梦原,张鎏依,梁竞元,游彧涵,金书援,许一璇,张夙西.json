  "lyrics": [
    {
      "time": 3.25,
      "time_str": "00:03.250",
      "text": "开始的开始 我们都是孩子",
      "translation": null
    },
    {
      "time": 5.65,
      "time_str": "00:05.650",
      "text": "最后的最后 渴望变成天使",
      "translation": null
    },
    {
      "time": 10.69,
      "time_str": "00:10.690",
      "text": "歌谣的歌谣 藏着童话的影子",
      "translation": null
    },
    {
      "time": 15.43,
      "time_str": "00:15.430",
      "text": "孩子的孩子... 该要飞往哪去",
      "translation": null
    },
