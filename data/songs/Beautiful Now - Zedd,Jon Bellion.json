    {
      "time": 3.05,
      "time_str": "00:03.050",
      "text": "I see what you're wearing, there's nothing beneath it",
      "translation": "我看见了你身着何物，毫无掩映显现于我眼前"
    },
    {
      "time": 6.48,
      "time_str": "00:06.480",
      "text": "Forgive me for staring, forgive me for breathing",
      "translation": "原谅我的不住凝视，原谅我的短暂窒息"
    },
    {
      "time": 10.2,
      "time_str": "00:10.200",
      "text": "We might not know why, we might not know how",
      "translation": "我们可能不知道为何，亦不知道如何"
    },
    {
      "time": 13.96,
      "time_str": "00:13.960",
      "text": "But baby, tonight, we're beautiful now",
      "translation": "但是我的爱人，今晚，我们如此绚烂"
    },
