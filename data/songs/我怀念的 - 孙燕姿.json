      "text": "谁忘了",
      "translation": null
    },
    {
      "time": 171.76,
      "time_str": "02:51.760",
      "text": "我怀念的 是无言感动",
      "translation": null
    },
    {
      "time": 175.14,
      "time_str": "02:55.140",
      "text": "我怀念的 是绝对炽热",
      "translation": null
    },
    {
      "time": 178.52,
      "time_str": "02:58.520",
      "text": "我怀念的 是你很激动",
      "translation": null
    },
    {
      "time": 181.54,
      "time_str": "03:01.540",
      "text": "求我原谅 抱得我都痛",
      "translation": null
    },
    {
      "time": 185.69,
      "time_str": "03:05.690",
      "text": "我记得你在背后",
      "translation": null
    },
    {
      "time": 189.04,
      "time_str": "03:09.040",
      "text": "也记得我颤抖着",
      "translation": null
    },
    {
      "time": 192.26,
      "time_str": "03:12.260",
      "text": "记得感觉汹涌",
      "translation": null
    },
    {
      "time": 194.37,
      "time_str": "03:14.370",
      "text": "最美的烟火",
      "translation": null
    },
    {
      "time": 195.97,
      "time_str": "03:15.970",
      "text": "最长的相拥",
      "translation": null
    },
    {
      "time": 197.35,
      "time_str": "03:17.350",
      "text": "谁爱得太自由",
      "translation": null
    },
    {
      "time": 200.9,
      "time_str": "03:20.900",
      "text": "谁过头太远了",
      "translation": null
    },
    {
      "time": 204.17,
      "time_str": "03:24.170",
      "text": "谁要走我的心",
      "translation": null
    },
    {
      "time": 207.59,
      "time_str": "03:27.590",
      "text": "谁忘了那就是承诺",
      "translation": null
    },
    {
      "time": 211.21,
      "time_str": "03:31.210",
      "text": "谁自顾自地走",
      "translation": null
    },
    {
      "time": 214.49,
      "time_str": "03:34.490",
      "text": "谁忘了看着我",
      "translation": null
    },
    {
      "time": 217.89,
      "time_str": "03:37.890",
      "text": "谁让爱变沉重",
      "translation": null
    },
    {
      "time": 221.35,
      "time_str": "03:41.350",
      "text": "谁忘了要给你温柔",
      "translation": null
    },
    {
      "time": 236.86,
      "time_str": "03:56.860",
      "text": "我怀念的",
      "translation": null
    },
    {
      "time": 239.42,
      "time_str": "03:59.420",
      "text": "我还有想要 爱你的冲动",
      "translation": null
    },
    {
      "time": 243.77,
      "time_str": "04:03.770",
      "text": "我记得那年生日",
      "translation": null
    },
    {
      "time": 247.11,
      "time_str": "04:07.110",
      "text": "也记得那一首歌",
      "translation": null
    },
    {
      "time": 250.25,
      "time_str": "04:10.250",
      "text": "记得那片星空",
      "translation": null
    },
    {
      "time": 252.05,
      "time_str": "04:12.050",
      "text": "最紧的右手",
      "translation": null
    },
    {
      "time": 253.86,
      "time_str": "04:13.860",
      "text": "最暖的胸口",
      "translation": null
    },
    {
      "time": 255.35,
      "time_str": "04:15.350",
      "text": "我放手",
      "translation": null
    },
    {
      "time": 258.74,
      "time_str": "04:18.740",
      "text": "我让座",
      "translation": null
    },
    {
      "time": 262.09,
      "time_str": "04:22.090",
      "text": "假洒脱",
      "translation": null
    },
    {
      "time": 265.51,
      "time_str": "04:25.510",
      "text": "谁懂我多么不舍得",
      "translation": null
    },
    {
      "time": 269.34,
      "time_str": "04:29.340",
      "text": "太爱了",
      "translation": null
    },
    {
      "time": 272.37,
      "time_str": "04:32.370",
      "text": "所以我",
      "translation": null
    },
    {
      "time": 275.91,
      "time_str": "04:35.910",
      "text": "没有哭",
      "translation": null
    },
    {
      "time": 279.24,
      "time_str": "04:39.240",
      "text": "没有说",
      "translation": null
    }
