  "lyrics": [
    {
      "time": 16.86,
      "time_str": "00:16.860",
      "text": "我问为什么",
      "translation": null
    },
    {
      "time": 19.18,
      "time_str": "00:19.180",
      "text": "那女孩 传简讯给我",
      "translation": null
    },
    {
      "time": 24.4,
      "time_str": "00:24.400",
      "text": "而你为什么",
      "translation": null
    },
    {
      "time": 26.48,
      "time_str": "00:26.480",
      "text": "不解释 低着头沉默",
      "translation": null
    },
    {
      "time": 30.61,
      "time_str": "00:30.610",
      "text": "我该相信你很爱我",
      "translation": null
    },
    {
      "time": 34.21,
      "time_str": "00:34.210",
      "text": "不愿意敷衍我",
      "translation": null
    },
    {
      "time": 37.63,
      "time_str": "00:37.630",
      "text": "还是明白",
      "translation": null
    },
    {
      "time": 39.13,
      "time_str": "00:39.130",
      "text": "你已不想挽回什么",
      "translation": null
    },
    {
      "time": 45.71,
      "time_str": "00:45.710",
      "text": "想问为什么",
      "translation": null
    },
    {
      "time": 48.27,
      "time_str": "00:48.270",
      "text": "我不再 是你的快乐",
      "translation": null
    },
    {
      "time": 53.26,
      "time_str": "00:53.260",
      "text": "可是为什么",
      "translation": null
    },
    {
      "time": 55.33,
      "time_str": "00:55.330",
      "text": "却苦笑 说我都懂了",
      "translation": null
    },
    {
      "time": 59.37,
      "time_str": "00:59.370",
      "text": "自尊常常将人拖着",
      "translation": null
    },
    {
      "time": 63.02,
      "time_str": "01:03.020",
      "text": "把爱都走曲折",
      "translation": null
    },
    {
      "time": 66.27,
      "time_str": "01:06.270",
      "text": "假装了解是怕",
      "translation": null
    },
    {
      "time": 68.37,
      "time_str": "01:08.370",
      "text": "真相 太赤裸裸",
      "translation": null
    },
    {
      "time": 71.87,
      "time_str": "01:11.870",
      "text": "狼狈比失去难受",
      "translation": null
    },
    {
      "time": 74.36,
      "time_str": "01:14.360",
      "text": "我怀念的 是无话不说",
      "translation": null
    },
    {
      "time": 77.72,
      "time_str": "01:17.720",
      "text": "我怀念的 是一起做梦",
      "translation": null
    },
    {
      "time": 81.28,
      "time_str": "01:21.280",
      "text": "我怀念的 是争吵以后",
      "translation": null
    },
    {
      "time": 84.5,
      "time_str": "01:24.500",
      "text": "还是想要 爱你的冲动",
      "translation": null
    },
    {
      "time": 88.54,
      "time_str": "01:28.540",
      "text": "我记得那年生日",
      "translation": null
    },
    {
      "time": 91.81,
      "time_str": "01:31.810",
      "text": "也记得那一首歌",
      "translation": null
    },
    {
      "time": 95.14,
      "time_str": "01:35.140",
      "text": "记得那片星空",
      "translation": null
    },
    {
      "time": 97.12,
      "time_str": "01:37.120",
      "text": "最紧的右手",
      "translation": null
    },
    {
      "time": 98.81,
      "time_str": "01:38.810",
      "text": "最暖的胸口",
      "translation": null
    },
    {
      "time": 100.34,
      "time_str": "01:40.340",
      "text": "谁记得",
      "translation": null
    },
    {
      "time": 103.84,
      "time_str": "01:43.840",
      "text": "谁忘了",
      "translation": null
    },
    {
