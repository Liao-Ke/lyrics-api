  "lyrics": [
    {
      "time": 3.15,
      "time_str": "00:03.150",
      "text": "你永远在远处发着光",
      "translation": null
    },
    {
      "time": 6.86,
      "time_str": "00:06.860",
      "text": "但我却怎么也抓不到",
      "translation": null
    },
    {
      "time": 10.62,
      "time_str": "00:10.620",
      "text": "即使前路一片漆黑",
      "translation": null
    },
    {
      "time": 13.56,
      "time_str": "00:13.560",
      "text": "但是",
      "translation": null
    },
    {
      "time": 15.4,
      "time_str": "00:15.400",
      "text": "我愿意",
      "translation": null
    },
    {
      "time": 24.46,
      "time_str": "00:24.460",
      "text": "你似光",
      "translation": null
    },
    {
      "time": 29.2,
      "time_str": "00:29.200",
      "text": "注定燃亮我心火",
      "translation": null
    },
    {
      "time": 29.41,
      "time_str": "00:29.410",
      "text": "即管重复地划破",
      "translation": null
    },
    {
      "time": 33.12,
      "time_str": "00:33.120",
      "text": "告别我",
      "translation": null
    },
    {
      "time": 34.61,
      "time_str": "00:34.610",
      "text": "唯独亦不熄感觉",
      "translation": null
    },
    {
      "time": 37.71,
      "time_str": "00:37.710",
      "text": "像最初",
      "translation": null
    },
    {
      "time": 39.34,
      "time_str": "00:39.340",
      "text": "我是无惧那一个",
      "translation": null
    },
    {
      "time": 42.35,
      "time_str": "00:42.350",
      "text": "漆黑里敢于自我",
      "translation": null
    },
    {
      "time": 48.01,
      "time_str": "00:48.010",
      "text": "直到光交错于身擦过",
      "translation": null
    },
    {
      "time": 51.17,
      "time_str": "00:51.170",
      "text": "没法一起是我想得太多",
      "translation": null
    },
    {
      "time": 60.5,
      "time_str": "01:00.500",
      "text": "原来幸福装载对岸",
      "translation": null
    },
    {
      "time": 63.86,
      "time_str": "01:03.860",
      "text": "一闪过不要太惊慌",
      "translation": null
    },
    {
      "time": 67.07,
      "time_str": "01:07.070",
      "text": "为何未写过便要放",
      "translation": null
    },
    {
      "time": 70.6,
      "time_str": "01:10.600",
      "text": "可给我终确定答案",
      "translation": null
    },
    {
      "time": 73.65,
      "time_str": "01:13.650",
      "text": "原来自卑淹没过我",
      "translation": null
    },
    {
      "time": 77.12,
      "time_str": "01:17.120",
      "text": "不敢去拥抱那束光",
      "translation": null
    },
    {
      "time": 80.6,
      "time_str": "01:20.600",
      "text": "情愿没改变像困我",
      "translation": null
    },
    {
      "time": 84.31,
      "time_str": "01:24.310",
      "text": "若有错",
      "translation": null
    },
    {
      "time": 86.9,
      "time_str": "01:26.900",
      "text": "可否改过",
      "translation": null
