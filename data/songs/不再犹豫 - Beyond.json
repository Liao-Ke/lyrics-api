  "lyrics": [
    {
      "time": 28.74,
      "time_str": "00:28.740",
      "text": "无聊望见了犹豫",
      "translation": null
    },
    {
      "time": 32.25,
      "time_str": "00:32.250",
      "text": "达到理想不太易",
      "translation": null
    },
    {
      "time": 35.85,
      "time_str": "00:35.850",
      "text": "即使有信心",
      "translation": null
    },
    {
      "time": 38.07,
      "time_str": "00:38.070",
      "text": "斗志却抑止",
      "translation": null
    },
    {
      "time": 42.99,
      "time_str": "00:42.990",
      "text": "谁人定我去或留",
      "translation": null
    },
    {
      "time": 45.33,
      "time_str": "00:45.330",
      "text": "定我心中的宇宙",
      "translation": null
    },
    {
      "time": 50.19,
      "time_str": "00:50.190",
      "text": "只想靠两手",
      "translation": null
    },
    {
      "time": 52.32,
      "time_str": "00:52.320",
      "text": "向理想挥手",
      "translation": null
    },
    {
      "time": 57.36,
      "time_str": "00:57.360",
      "text": "问句天几高",
      "translation": null
    },
    {
      "time": 59.01,
      "time_str": "00:59.010",
      "text": "心中志比天更高",
      "translation": null
    },
    {
      "time": 64.59,
      "time_str": "01:04.590",
      "text": "自信打不死的心态活到老",
      "translation": null
    },
    {
      "time": 71.93,
      "time_str": "01:11.930",
      "text": "Woo ho",
      "translation": null
    },
    {
      "time": 75.329,
      "time_str": "01:15.329",
      "text": "我有我心底故事",
      "translation": null
    },
    {
      "time": 78.87,
      "time_str": "01:18.870",
      "text": "亲手写上每段",
      "translation": null
    },
    {
      "time": 81.09,
      "time_str": "01:21.090",
      "text": "得失乐与悲与梦儿",
      "translation": null
    },
    {
      "time": 86.05,
      "time_str": "01:26.050",
      "text": "Woo ho",
      "translation": null
    },
    {
      "time": 89.61,
      "time_str": "01:29.610",
      "text": "纵有创伤不退避",
      "translation": null
    },
    {
      "time": 93.18,
      "time_str": "01:33.180",
      "text": "梦想有日达成",
      "translation": null
    },
    {
      "time": 95.37,
      "time_str": "01:35.370",
      "text": "找到心底梦想的世界",
      "translation": null
    },
    {
