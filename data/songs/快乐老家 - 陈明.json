  "lyrics": [
    {
      "time": 26.0,
      "time_str": "00:26.000",
      "text": "跟我走吧 天亮就出发",
      "translation": null
    },
    {
      "time": 34.0,
      "time_str": "00:34.000",
      "text": "梦已经醒来 心不会害怕",
      "translation": null
    },
    {
      "time": 43.0,
      "time_str": "00:43.000",
      "text": "有一个地方 那是快乐老家",
      "translation": null
    },
    {
      "time": 51.0,
      "time_str": "00:51.000",
      "text": "它近在心灵 却远在天涯",
      "translation": null
    },
    {
      "time": 60.0,
      "time_str": "01:00.000",
      "text": "我所有的一切都只为找到它",
      "translation": null
    },
    {
      "time": 64.0,
      "time_str": "01:04.000",
      "text": "哪怕付出忧伤代价",
      "translation": null
    },
    {
      "time": 68.0,
      "time_str": "01:08.000",
      "text": "也许再穿过一条烦恼的河流",
      "translation": null
    },
    {
      "time": 73.0,
      "time_str": "01:13.000",
      "text": "明天就能够到达",
      "translation": null
    },
    {
      "time": 78.0,
      "time_str": "01:18.000",
      "text": "我生命的一切都只为拥有它",
      "translation": null
    },
    {
      "time": 81.0,
      "time_str": "01:21.000",
      "text": "让我们来真心对待吧",
      "translation": null
    },
    {
      "time": 85.0,
      "time_str": "01:25.000",
      "text": "等每一颗飘流的心都不再牵挂",
      "translation": null
    },
    {
      "time": 90.0,
      "time_str": "01:30.000",
      "text": "快乐是永远的家",
      "translation": null
    },
    {
