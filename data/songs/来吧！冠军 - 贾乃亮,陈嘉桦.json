  "lyrics": [
    {
      "time": 25.83,
      "time_str": "00:25.830",
      "text": "我们这里 英雄辈出",
      "translation": null
    },
    {
      "time": 29.47,
      "time_str": "00:29.470",
      "text": "无所畏惧 从不怕输",
      "translation": null
    },
    {
      "time": 32.89,
      "time_str": "00:32.890",
      "text": "每个人都能爆发潜在的能量",
      "translation": null
    },
    {
      "time": 36.73,
      "time_str": "00:36.730",
      "text": "把世界去征服",
      "translation": null
    },
    {
      "time": 40.29,
      "time_str": "00:40.290",
      "text": "是谁踏平 漫漫长路",
      "translation": null
    },
    {
      "time": 44.22,
      "time_str": "00:44.220",
      "text": "自在荣光 心有猛虎",
      "translation": null
    },
    {
      "time": 47.86,
      "time_str": "00:47.860",
      "text": "全心全意体会感触",
      "translation": null
    },
    {
      "time": 51.53,
      "time_str": "00:51.530",
      "text": "今晚我们拼到最酷",
      "translation": null
    },
    {
      "time": 57.0,
      "time_str": "00:57.000",
      "text": "即使输了又何妨 我也曾经 流汗付出",
      "translation": null
    },
    {
      "time": 64.34,
      "time_str": "01:04.340",
      "text": "只需要努力 就能把 绝境冲出",
      "translation": null
    },
    {
      "time": 71.94,
      "time_str": "01:11.940",
      "text": "I believe I can do 我就是我的救世主",
      "translation": null
    },
    {
      "time": 79.26,
      "time_str": "01:19.260",
      "text": "第一名属于 每一个人",
      "translation": null
    },
    {
      "time": 83.02,
      "time_str": "01:23.020",
      "text": "不拼怎能轻易认输 轻易认输",
      "translation": null
    },
    {
      "time": 105.46,
      "time_str": "01:45.460",
      "text": "山峰再高 大海再深",
      "translation": null
    },
    {
      "time": 108.88,
      "time_str": "01:48.880",
      "text": "无所畏惧也要追逐",
      "translation": null
    },
    {
      "time": 112.45,
      "time_str": "01:52.450",
      "text": "我们心中燃烧最初的梦想",
      "translation": null
    },
    {
