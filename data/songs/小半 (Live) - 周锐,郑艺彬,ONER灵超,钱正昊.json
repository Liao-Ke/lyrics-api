  "lyrics": [
    {
      "time": 3.89,
      "time_str": "00:03.890",
      "text": "改编编曲：郑楠",
      "translation": null
    },
    {
      "time": 17.12,
      "time_str": "00:17.120",
      "text": "周锐：",
      "translation": null
    },
    {
      "time": 17.96,
      "time_str": "00:17.960",
      "text": "不敢回看",
      "translation": null
    },
    {
      "time": 20.29,
      "time_str": "00:20.290",
      "text": "左顾右盼不自然的暗自喜欢",
      "translation": null
    },
    {
      "time": 24.69,
      "time_str": "00:24.690",
      "text": "偷偷搭讪总没完地坐立难安",
      "translation": null
    },
    {
      "time": 29.09,
      "time_str": "00:29.090",
      "text": "试探说晚安 多空泛又心酸",
      "translation": null
    },
    {
      "time": 34.67,
      "time_str": "00:34.670",
      "text": "郑锐彬：",
      "translation": null
    },
    {
      "time": 35.71,
      "time_str": "00:35.710",
      "text": "低头呢喃",
      "translation": null
    },
    {
      "time": 37.88,
      "time_str": "00:37.880",
      "text": "对你的偏爱太过于明目张胆",
      "translation": null
    },
    {
      "time": 41.96,
      "time_str": "00:41.960",
      "text": "在原地打转的小丑伤心不断",
      "translation": null
    },
    {
      "time": 46.54,
      "time_str": "00:46.540",
      "text": "空空留遗憾 多难堪又为难",
      "translation": null
    },
    {
      "time": 53.06,
      "time_str": "00:53.060",
      "text": "释然 慵懒 尽欢 时间风干后你与我无关 (灵超)",
      "translation": null
    },
    {
      "time": 61.55,
      "time_str": "01:01.550",
      "text": "没答案 怎么办 看不惯自我欺瞒 (钱正昊)",
      "translation": null
    },
    {
      "time": 69.13,
      "time_str": "01:09.130",
      "text": "周锐：",
      "translation": null
    },
    {
      "time": 69.97,
      "time_str": "01:09.970",
      "text": "纵容着 喜欢的 讨厌的 宠溺的 厌倦的",
      "translation": null
    },
    {
      "time": 74.92,
      "time_str": "01:14.920",
      "text": "一个个慢慢黯淡",
      "translation": null
    },
    {
      "time": 78.71,
      "time_str": "01:18.710",
      "text": "郑锐彬：",
      "translation": null
    },
    {
      "time": 78.92,
      "time_str": "01:18.920",
      "text": "纵容着 任性的 随意的 放肆的 轻易的",
      "translation": null
    },
    {
      "time": 83.85,
      "time_str": "01:23.850",
      "text": "将所有欢脱倾翻",
      "translation": null
    },
    {
      "time": 86.8,
      "time_str": "01:26.800",
      "text": "灵超：",
      "translation": null
    },
    {
      "time": 87.24,
      "time_str": "01:27.240",
      "text": "不应该 太心软 不大胆 太死板 不果断",
      "translation": null
    },
    {
      "time": 92.53,
      "time_str": "01:32.530",
      "text": "玩弄着肆无忌惮",
      "translation": null
    },
    {
      "time": 96.04,
      "time_str": "01:36.040",
      "text": "不应该 舍弃了 死心了 放手了 断念了 (钱正昊)",
      "translation": null
    },
    {
      "time": 101.33,
      "time_str": "01:41.330",
      "text": "无可奈何不耐烦 (钱正昊)",
      "translation": null
    },
    {
      "time": 105.44,
      "time_str": "01:45.440",
      "text": "不算 (钱正昊)",
      "translation": null
    },
    {
      "time": 110.1,
      "time_str": "01:50.100",
      "text": "不算 (集体)",
      "translation": null
    },
    {
      "time": 114.14,
      "time_str": "01:54.140",
      "text": "不算 (周锐)",
      "translation": null
    },
    {
      "time": 122.62,
      "time_str": "02:02.620",
      "text": "灵超：",
      "translation": null
    },
    {
      "time": 123.55,
      "time_str": "02:03.550",
      "text": "喜欢的 讨厌的 宠溺的 厌倦的",
      "translation": null
    },
    {
      "time": 127.71,
      "time_str": "02:07.710",
      "text": "一个个慢慢黯淡",
      "translation": null
    },
    {
      "time": 131.1,
      "time_str": "02:11.100",
      "text": "钱正昊：",
      "translation": null
    },
    {
      "time": 131.76,
      "time_str": "02:11.760",
      "text": "任性的 随意的 放肆的 轻易的",
      "translation": null
    },
    {
      "time": 136.95,
      "time_str": "02:16.950",
      "text": "WOO",
      "translation": null
    },
    {
      "time": 142.27,
      "time_str": "02:22.270",
      "text": "任由着 你躲闪 我追赶 你走散 我呼喊 (周锐、郑锐彬、钱正昊)",
      "translation": null
    },
    {
      "time": 147.59,
      "time_str": "02:27.590",
      "text": "是谁在泛泛而谈 (周锐、郑锐彬、钱正昊)",
      "translation": null
    },
    {
      "time": 151.21,
      "time_str": "02:31.210",
      "text": "灵超：",
      "translation": null
    },
    {
      "time": 151.46,
      "time_str": "02:31.460",
      "text": "任由着 你来了 你笑了 你走了 不看我",
      "translation": null
    },
    {
      "time": 156.32,
      "time_str": "02:36.320",
      "text": "与理所当然分摊",
      "translation": null
    },
    {
      "time": 159.68,
      "time_str": "02:39.680",
      "text": "钱正昊：",
      "translation": null
    },
    {
      "time": 160.01,
      "time_str": "02:40.010",
      "text": "不明白 残存的 没用的 多余的 不必了",
      "translation": null
    },
    {
      "time": 165.15,
      "time_str": "02:45.150",
      "text": "破烂也在手紧攥",
      "translation": null
    },
    {
      "time": 168.57,
      "time_str": "02:48.570",
      "text": "郑锐彬：",
      "translation": null
    },
    {
      "time": 168.81,
      "time_str": "02:48.810",
      "text": "不明白 谁赧然 谁无端 谁古板 谁极端",
      "translation": null
    },
    {
      "time": 173.8,
      "time_str": "02:53.800",
      "text": "无辜不知所以然",
      "translation": null
    },
    {
      "time": 180.65,
      "time_str": "03:00.650",
      "text": "不算",
      "translation": null
    },
    {
      "time": 184.95,
