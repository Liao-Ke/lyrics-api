{
  "title": "爱得太迟",
  "title_raw": "爱得太迟",
  "version": null,
  "artist": "古巨基",
  "group_key": "爱得太迟|古巨基",
  "writers": {
    "lyricist": "林夕",
    "composer": "杨镇邦",
    "arranger": "雷颂德"
  },
  "lyrics": [
    {
      "time": 20.32,
      "time_str": "00:20.320",
      "text": "我过去 那死党 早晚共对",
      "translation": null
    },
    {
      "time": 23.63,
      "time_str": "00:23.630",
      "text": "各也扎职以后 没法 畅聚",
      "translation": null
    },
    {
      "time": 28.63,
      "time_str": "00:28.630",
      "text": "而终於 相约到 但无言共对 疏淡如水",
      "translation": null
    },
    {
      "time": 36.5,
      "time_str": "00:36.500",
      "text": "日夜做 见爸爸 刚好想呻",
      "translation": null
    },
    {
      "time": 40.69,
      "time_str": "00:40.690",
      "text": "却霎眼 看出他 多了皱纹",
      "translation": null
    },
    {
      "time": 44.63,
      "time_str": "00:44.630",
      "text": "而他的苍老感 是从来未觉 太内疚担心",
      "translation": null
    },
    {
      "time": 51.25,
      "time_str": "00:51.250",
      "text": "最心痛是 爱得太迟",
      "translation": null
    },
    {
      "time": 55.25,
      "time_str": "00:55.250",
      "text": "有些心意 不可等某个日子",
      "translation": null
    },
    {
      "time": 59.38,
      "time_str": "00:59.380",
      "text": "盲目地发奋 忙忙忙其实自私",
      "translation": null
    },
    {
      "time": 63.56,
      "time_str": "01:03.560",
      "text": "梦中也习惯 有压力要我得志",
      "translation": null
    },
    {
      "time": 67.63,
      "time_str": "01:07.630",
      "text": "最可怕是 爱需要及时",
      "translation": null
    },
    {
      "time": 71.69,
      "time_str": "01:11.690",
      "text": "只差一秒 心声都已变历史",
      "translation": null
    },
    {
      "time": 75.13,
      "time_str": "01:15.130",
      "text": "忙极亦放肆 见我爱见的相知",
      "translation": null
    },
    {
      "time": 79.44,
      "time_str": "01:19.440",
      "text": "要抱要吻要怎么也好 偏要推说等下一次",
      "translation": null
    },
    {
      "time": 98.06,
      "time_str": "01:38.060",
      "text": "我也觉 我体质 彷似下降",
      "translation": null
    },
    {
      "time": 102.25,
      "time_str": "01:42.250",
      "text": "看了症得到是 别要太忙",
      "translation": null
    },
    {
      "time": 106.38,
      "time_str": "01:46.380",
      "text": "而影碟 都扫光 但从来未看 因有事赶",
      "translation": null
    },
    {
      "time": 111.94,
      "time_str": "01:51.940",
      "text": "日夜做 储的钱 都应该够",
      "translation": null
    },
    {
      "time": 118.57,
      "time_str": "01:58.570",
      "text": "到圣诞 正好讲 跟我白头",
      "translation": null
    },
    {
      "time": 122.81,
      "time_str": "02:02.810",
      "text": "谁知她开了口 未能挨下去 已恨我很久",
      "translation": null
    },
    {
      "time": 129.19,
      "time_str": "02:09.190",
      "text": "错失太易 爱得太迟",
      "translation": null
    },
    {
      "time": 133.13,
      "time_str": "02:13.130",
      "text": "我怎想到 她忍不到那日子",
      "translation": null
    },
    {
      "time": 136.37,
      "time_str": "02:16.370",
      "text": "盲目地发奋 忙忙忙从来未知",
      "translation": null
    },
    {
      "time": 141.38,
      "time_str": "02:21.380",
      "text": "幸福会掠过 再也没法说钟意",
      "translation": null
    },
    {
      "time": 145.44,
      "time_str": "02:25.440",
      "text": "爱一个字 也需要及时",
      "translation": null
    },
    {
      "time": 149.75,
      "time_str": "02:29.750",
      "text": "只差一秒 心声都已变历史",
      "translation": null
    },
    {
      "time": 153.94,
      "time_str": "02:33.940",
      "text": "为何未放肆 见我爱见的相知",
      "translation": null
    },
    {
      "time": 157.44,
      "time_str": "02:37.440",
      "text": "要抱要吻要怎么也好 不要相信一切有下次",
      "translation": null
    },
    {
      "time": 165.19,
      "time_str": "02:45.190",
      "text": "相拥我所爱又花几多秒",
      "translation": null
    },
    {
      "time": 169.0,
      "time_str": "02:49.000",
      "text": "这几秒 能够做到又有多少",
      "translation": null
    },
    {
      "time": 174.69,
      "time_str": "02:54.690",
      "text": "未算少 足够遗憾忘掉",
      "translation": null
    },
    {
      "time": 178.38,
      "time_str": "02:58.380",
      "text": "多少抱憾 多少过路人",
      "translation": null
    },
    {
      "time": 182.56,
      "time_str": "03:02.560",
      "text": "太懂估计 却不懂爱惜自身",
      "translation": null
    },
    {
      "time": 186.5,
      "time_str": "03:06.500",
      "text": "人人在发奋 想起他朝都兴奋",
      "translation": null
    },
    {
      "time": 190.69,
      "time_str": "03:10.690",
      "text": "但今晚未过 你要过也很吸引",
      "translation": null
    },
    {
      "time": 194.94,
      "time_str": "03:14.940",
      "text": "纵不信运 你不过是人",
      "translation": null
    },
    {
      "time": 198.94,
      "time_str": "03:18.940",
      "text": "理想很远 爱於咫尺却在等",
      "translation": null
    },
    {
      "time": 203.06,
      "time_str": "03:23.060",
      "text": "来日别操心 趁你有能力开心",
      "translation": null
    },
    {
      "time": 206.62,
      "time_str": "03:26.620",
      "text": "世界有太多东西发生 不要等到天上俯瞰",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "爱得太迟 - 古巨基.lrc"
}