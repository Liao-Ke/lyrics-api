  "lyrics": [
    {
      "time": 30.819,
      "time_str": "00:30.819",
      "text": "吞风吻雨 葬落日",
      "translation": null
    },
    {
      "time": 32.336,
      "time_str": "00:32.336",
      "text": "未曾彷徨",
      "translation": null
    },
    {
      "time": 33.407,
      "time_str": "00:33.407",
      "text": "欺山赶海 践雪径",
      "translation": null
    },
    {
      "time": 34.911,
      "time_str": "00:34.911",
      "text": "也未绝望",
      "translation": null
    },
    {
      "time": 35.997,
      "time_str": "00:35.997",
      "text": "拈花把酒 偏折煞",
      "translation": null
    },
    {
      "time": 37.46,
      "time_str": "00:37.460",
      "text": "世人情狂",
      "translation": null
    },
    {
      "time": 38.551,
      "time_str": "00:38.551",
      "text": "凭这两眼 与百臂",
      "translation": null
    },
    {
      "time": 39.999,
      "time_str": "00:39.999",
      "text": "或千手 不能防",
      "translation": null
    },
    {
      "time": 41.249,
      "time_str": "00:41.249",
      "text": "天阔阔 雪漫漫",
      "translation": null
    },
    {
      "time": 42.527,
      "time_str": "00:42.527",
      "text": "共谁同航",
      "translation": null
    },
    {
      "time": 43.616,
      "time_str": "00:43.616",
      "text": "这沙滚滚 水皱皱",
      "translation": null
    },
    {
      "time": 45.079,
      "time_str": "00:45.079",
      "text": "笑着浪荡",
      "translation": null
    },
    {
      "time": 46.164,
      "time_str": "00:46.164",
      "text": "贪欢一饷",
      "translation": null
    },
    {
      "time": 46.982,
      "time_str": "00:46.982",
      "text": "偏教那女儿情长埋葬",
      "translation": null
    },
    {
      "time": 61.761,
      "time_str": "01:01.761",
      "text": "笑你我枉花光心计",
      "translation": null
    },
    {
      "time": 64.31,
      "time_str": "01:04.310",
      "text": "爱竞逐镜花那美丽",
      "translation": null
    },
    {
      "time": 66.849,
      "time_str": "01:06.849",
      "text": "怕幸运会转眼远逝",
      "translation": null
    },
    {
      "time": 69.418,
      "time_str": "01:09.418",
      "text": "为贪嗔喜恶怒着迷",
      "translation": null
    },
    {
      "time": 71.954,
      "time_str": "01:11.954",
      "text": "责你我太贪功恋势",
      "translation": null
    },
    {
      "time": 74.481,
      "time_str": "01:14.481",
      "text": "怪大地众生太美丽",
      "translation": null
    },
    {
      "time": 77.031,
      "time_str": "01:17.031",
      "text": "悔旧日太执信约誓",
      "translation": null
    },
    {
      "time": 79.655,
      "time_str": "01:19.655",
      "text": "为悲欢哀怨妒着迷",
      "translation": null
    },
    {
      "time": 82.182,
      "time_str": "01:22.182",
      "text": "啊 哈",
      "translation": null
    },
    {
      "time": 84.731,
      "time_str": "01:24.731",
      "text": "舍不得 璀璨俗世",
      "translation": null
    },
    {
      "time": 87.285,
      "time_str": "01:27.285",
      "text": "啊 哈",
      "translation": null
    },
    {
      "time": 89.813,
      "time_str": "01:29.813",
      "text": "躲不开 痴恋的欣慰",
      "translation": null
    },
    {
      "time": 92.392,
      "time_str": "01:32.392",
      "text": "啊 哈",
      "translation": null
    },
    {
      "time": 94.942,
      "time_str": "01:34.942",
      "text": "找不到 色相代替",
      "translation": null
    },
    {
      "time": 97.535,
      "time_str": "01:37.535",
      "text": "啊 哈",
      "translation": null
    },
    {
      "time": 100.075,
      "time_str": "01:40.075",
      "text": "参一生 参不透 这条难题",
      "translation": null
    },
