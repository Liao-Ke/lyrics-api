  "lyrics": [
    {
      "time": 14.63,
      "time_str": "00:14.630",
      "text": "童丽",
      "translation": null
    },
    {
      "time": 39.52,
      "time_str": "00:39.520",
      "text": "我走过你窗前  泪滴",
      "translation": null
    },
    {
      "time": 48.33,
      "time_str": "00:48.330",
      "text": "你伏在她肩上哭泣",
      "translation": null
    },
    {
      "time": 56.76,
      "time_str": "00:56.760",
      "text": "一朵花飘落地",
      "translation": null
    },
    {
      "time": 60.88,
      "time_str": "01:00.880",
      "text": "它名字叫回忆",
      "translation": null
    },
    {
      "time": 65.14,
      "time_str": "01:05.140",
      "text": "我找不到爱的勇气",
      "translation": null
    },
    {
      "time": 73.5,
      "time_str": "01:13.500",
      "text": "我独自飘零在雨里",
      "translation": null
    },
    {
      "time": 81.91,
      "time_str": "01:21.910",
      "text": "你看上去幸福甜蜜",
      "translation": null
    },
    {
      "time": 90.58,
      "time_str": "01:30.580",
      "text": "一场雨打散了 我过去的记忆",
      "translation": null
    },
    {
      "time": 99.01,
      "time_str": "01:39.010",
      "text": "它将所有埋藏铭记",
      "translation": null
    },
    {
      "time": 107.42,
      "time_str": "01:47.420",
      "text": "花瓣一片片飘风里",
      "translation": null
    },
    {
      "time": 116.47,
      "time_str": "01:56.470",
      "text": "那尘土掩埋（盖）我情意",
      "translation": null
    },
    {
      "time": 124.32,
      "time_str": "02:04.320",
      "text": "那每一片花儿  曾是我的甜蜜",
      "translation": null
    },
    {
      "time": 132.91,
      "time_str": "02:12.910",
      "text": "而如今它已成回忆",
      "translation": null
    },
    {
      "time": 141.53,
      "time_str": "02:21.530",
      "text": "星照亮着  那月色迷离",
      "translation": null
    },
    {
      "time": 148.67,
      "time_str": "02:28.670",
      "text": "在你面前依然美丽",
      "translation": null
    },
    {
      "time": 158.2,
      "time_str": "02:38.200",
      "text": "花瓣飘落  你的心不再有孤寂",
      "translation": null
    },
    {
      "time": 166.71,
      "time_str": "02:46.710",
      "text": "我不要回忆",
      "translation": null
    },
    {
      "time": 172.8,
      "time_str": "02:52.800",
      "text": "忘了吧",
      "translation": null
    },
    {
      "time": 176.15,
