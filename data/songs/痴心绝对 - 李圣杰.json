    {
      "time": 17.86,
      "time_str": "00:17.860",
      "text": "想用一杯Latte把你灌醉",
      "translation": null
    },
    {
      "time": 22.25,
      "time_str": "00:22.250",
      "text": "好让你能多爱我一点",
      "translation": null
    },
    {
      "time": 26.82,
      "time_str": "00:26.820",
      "text": "暗恋的滋味你不懂这种感觉",
      "translation": null
    },
    {
      "time": 31.7,
      "time_str": "00:31.700",
      "text": "早有人陪的你永远不会",
      "translation": null
    },
    {
      "time": 38.19,
      "time_str": "00:38.190",
      "text": "看见你和他在我面前",
      "translation": null
    },
    {
      "time": 42.61,
      "time_str": "00:42.610",
      "text": "证明我的爱只是愚昧",
      "translation": null
    },
    {
      "time": 47.09,
      "time_str": "00:47.090",
      "text": "你不懂我的 那些憔悴",
      "translation": null
    },
    {
      "time": 51.61,
      "time_str": "00:51.610",
      "text": "是你永远不曾过的体会",
      "translation": null
    },
    {
      "time": 58.41,
      "time_str": "00:58.410",
      "text": "为你付出那种伤心你永远不了解",
      "translation": null
    },
    {
      "time": 62.89,
      "time_str": "01:02.890",
      "text": "我又何苦勉强自己爱上你的一切",
      "translation": null
    },
    {
      "time": 67.42,
      "time_str": "01:07.420",
      "text": "你又狠狠逼退 我的防备",
      "translation": null
    },
    {
      "time": 71.95,
      "time_str": "01:11.950",
      "text": "静静关上门来默数我的泪",
      "translation": null
    },
    {
      "time": 76.16,
      "time_str": "01:16.160",
      "text": "明知道让你离开他的世界不可能会",
      "translation": null
    },
    {
      "time": 80.93,
      "time_str": "01:20.930",
      "text": "我还傻傻等到奇迹出现的那一天",
      "translation": null
    },
    {
      "time": 85.4,
      "time_str": "01:25.400",
      "text": "直到那一天 你会发现",
      "translation": null
    },
    {
      "time": 89.9,
      "time_str": "01:29.900",
      "text": "真正爱你的人独自守着伤悲",
