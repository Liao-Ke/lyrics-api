  "lyrics": [
    {
      "time": 21.63,
      "time_str": "00:21.630",
      "text": "我从春天走来你在秋天说要分开",
      "translation": null
    },
    {
      "time": 32.55,
      "time_str": "00:32.550",
      "text": "说好不为你忧伤但心情怎会无恙",
      "translation": null
    },
    {
      "time": 43.02,
      "time_str": "00:43.020",
      "text": "为何总是这样在我心中深苦藏着你",
      "translation": null
    },
    {
      "time": 53.91,
      "time_str": "00:53.910",
      "text": "想要问你想不想陪我到地老天荒",
      "translation": null
    },
    {
      "time": 64.65,
      "time_str": "01:04.650",
      "text": "如果爱情这样忧伤为何不让我分享",
      "translation": null
    },
    {
      "time": 75.42,
      "time_str": "01:15.420",
      "text": "日夜都问你也不回答怎么你会变这样",
      "translation": null
    },
    {
      "time": 87.57,
      "time_str": "01:27.570",
      "text": "想要问问你敢不敢",
      "translation": null
    },
    {
      "time": 92.85,
      "time_str": "01:32.850",
      "text": "像你说过那样的爱我",
      "translation": null
    },
    {
      "time": 98.22,
      "time_str": "01:38.220",
      "text": "想要问问你敢不敢",
      "translation": null
    },
    {
      "time": 103.53,
      "time_str": "01:43.530",
      "text": "像我这样为爱痴狂",
      "translation": null
