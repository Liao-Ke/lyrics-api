  "lyrics": [
    {
      "time": 19.99,
      "time_str": "00:19.990",
      "text": "走在这冰冷的街 耳机里循环着播放",
      "translation": null
    },
    {
      "time": 23.46,
      "time_str": "00:23.460",
      "text": "你爱的歌 怎么都变得这么悲伤",
      "translation": null
    },
    {
      "time": 26.73,
      "time_str": "00:26.730",
      "text": "掉落的爱淹入水底留下记号",
      "translation": null
    },
    {
      "time": 29.65,
      "time_str": "00:29.650",
      "text": "过往的画面化作空气也成为气泡",
      "translation": null
    },
    {
      "time": 33.51,
      "time_str": "00:33.510",
      "text": "画面太多 确实难忘 曾经的爱 变为奢望",
      "translation": null
    },
    {
      "time": 36.9,
      "time_str": "00:36.900",
      "text": "一直在想 一直在想 怎变成这样",
      "translation": null
    },
    {
      "time": 40.07,
      "time_str": "00:40.070",
      "text": "你发来的短信也成为我睡前的必读文章",
      "translation": null
    },
    {
      "time": 42.8,
      "time_str": "00:42.800",
      "text": "我想如果可以梦里继续延续你和我的篇章 girl",
      "translation": null
    },
    {
      "time": 46.87,
      "time_str": "00:46.870",
      "text": "多希望天黑之前可以打通你电话",
      "translation": null
    },
    {
      "time": 50.15,
      "time_str": "00:50.150",
      "text": "这样我再多矫情都不必深夜融化",
      "translation": null
    },
    {
      "time": 53.5,
      "time_str": "00:53.500",
      "text": "乌黑的头发 浅白色的发卡 投影在我深夜脑海中出现的那幅画",
      "translation": null
    },
    {
      "time": 62.11,
      "time_str": "01:02.110",
      "text": "抵不过思念的那堵墙",
      "translation": null
    },
    {
      "time": 65.51,
      "time_str": "01:05.510",
      "text": "我控制自己别去想",
      "translation": null
    },
    {
      "time": 68.95,
      "time_str": "01:08.950",
      "text": "无非最后留我感伤",
      "translation": null
    },
    {
      "time": 72.72,
      "time_str": "01:12.720",
      "text": "都怪我没留住你 让你一个人逃避",
      "translation": null
    },
    {
      "time": 79.06,
      "time_str": "01:19.060",
      "text": "消极的话我说多 留你在哭泣",
      "translation": null
    },
    {
      "time": 85.58,
      "time_str": "01:25.580",
      "text": "邮箱不再是你的信 冰冷的房间我自己",
      "translation": null
    },
    {
      "time": 92.37,
      "time_str": "01:32.370",
      "text": "下次如果 你会经过 我不会让风带走你",
      "translation": null
    },
    {
      "time": 99.24,
      "time_str": "01:39.240",
      "text": "都怪我没留住你 让你一个人逃离",
      "translation": null
    },
    {
      "time": 105.92,
      "time_str": "01:45.920",
      "text": "我等的不再是光 而是你的归期",
      "translation": null
    },
    {
      "time": 112.36,
      "time_str": "01:52.360",
      "text": "手边不再是你 冰冷的房间我自己",
      "translation": null
    },
    {
      "time": 119.06,
      "time_str": "01:59.060",
      "text": "等候着你 如果再会遇见我会留住你",
      "translation": null
    },
    {
      "time": 129.51,
      "time_str": "02:09.510",
      "text": "曾经的大雨在倒流",
      "translation": null
    },
    {
      "time": 131.01,
      "time_str": "02:11.010",
      "text": "沙漏里时间倒着走",
      "translation": null
    },
    {
      "time": 132.8,
      "time_str": "02:12.800",
      "text": "我回到初识的巷口",
      "translation": null
    },
    {
      "time": 134.41,
      "time_str": "02:14.410",
      "text": "男孩和女孩手牵手",
      "translation": null
    },
    {
      "time": 136.16,
      "time_str": "02:16.160",
      "text": "要无忧无虑的漫游在每个街头",
      "translation": null
    },
    {
      "time": 138.53,
      "time_str": "02:18.530",
      "text": "分享着彼此的双眸",
      "translation": null
    },
    {
      "time": 140.08,
      "time_str": "02:20.080",
      "text": "感受着彼此的tempo",
      "translation": null
    },
    {
      "time": 141.74,
      "time_str": "02:21.740",
      "text": "珍惜每一次的停留",
      "translation": null
    },
    {
      "time": 143.42,
      "time_str": "02:23.420",
      "text": "陷入太深导致我不敢想",
      "translation": null
    },
    {
      "time": 146.6,
      "time_str": "02:26.600",
      "text": "你的味道声音我忘不掉",
      "translation": null
    },
    {
      "time": 150.02,
      "time_str": "02:30.020",
      "text": "希望你离开后会过的好",
      "translation": null
    },
    {
      "time": 153.28,
      "time_str": "02:33.280",
      "text": "都怪我 没能留住你给我的微笑",
      "translation": null
    },
