  "lyrics": [
    {
      "time": 22.837,
      "time_str": "00:22.837",
      "text": "山隔壁还是山",
      "translation": null
    },
    {
      "time": 25.169,
      "time_str": "00:25.169",
      "text": "都有一个伴",
      "translation": null
    },
    {
      "time": 28.202,
      "time_str": "00:28.202",
      "text": "相信海枯石烂",
      "translation": null
    },
    {
      "time": 30.686,
      "time_str": "00:30.686",
      "text": "也许我笨蛋",
      "translation": null
    },
    {
      "time": 33.686,
      "time_str": "00:33.686",
      "text": "飞太慢会落单",
      "translation": null
    },
    {
      "time": 36.202,
      "time_str": "00:36.202",
      "text": "太快会受伤",
      "translation": null
    },
    {
      "time": 39.237,
      "time_str": "00:39.237",
      "text": "日子不就都这样",
      "translation": null
    },
    {
      "time": 45.221,
      "time_str": "00:45.221",
      "text": "天会晴就会暗",
      "translation": null
    },
    {
      "time": 47.654,
      "time_str": "00:47.654",
      "text": "我早就习惯",
      "translation": null
    },
    {
      "time": 50.602,
      "time_str": "00:50.602",
      "text": "一日为了三餐",
      "translation": null
    },
    {
      "time": 53.119,
      "time_str": "00:53.119",
      "text": "不至于寒酸",
      "translation": null
    },
    {
      "time": 56.353,
      "time_str": "00:56.353",
      "text": "为给你取暖我把翅膀折断",
      "translation": null
    },
    {
      "time": 61.722,
      "time_str": "01:01.722",
      "text": "我遭遇那些苦难",
      "translation": null
    },
    {
      "time": 64.537,
      "time_str": "01:04.537",
      "text": "你却不管",
      "translation": null
    },
    {
      "time": 67.138,
      "time_str": "01:07.138",
      "text": "我飞翔在乌云之中",
      "translation": null
    },
    {
      "time": 70.388,
      "time_str": "01:10.388",
      "text": "你看着我无动于衷",
      "translation": null
    },
    {
      "time": 73.186,
      "time_str": "01:13.186",
      "text": "有多少次波涛汹涌",
      "translation": null
    },
    {
      "time": 76.203,
      "time_str": "01:16.203",
      "text": "在我 心中",
      "translation": null
    },
    {
      "time": 78.619,
      "time_str": "01:18.619",
      "text": "你飞向了雪山之巅",
      "translation": null
    },
    {
      "time": 81.552,
      "time_str": "01:21.552",
      "text": "我留在你回忆里面",
      "translation": null
    },
    {
      "time": 84.403,
      "time_str": "01:24.403",
      "text": "你成仙我替你留守人间",
      "translation": null
    },
    {
      "time": 90.019,
      "time_str": "01:30.019",
      "text": "麻雀也有明天",
      "translation": null
    },
