  "lyrics": [
    {
      "time": 17.4,
      "time_str": "00:17.400",
      "text": "男：解开我",
      "translation": null
    },
    {
      "time": 19.799,
      "time_str": "00:19.799",
      "text": "最神秘的等待",
      "translation": null
    },
    {
      "time": 23.339,
      "time_str": "00:23.339",
      "text": "星星坠落 风在吹动",
      "translation": null
    },
    {
      "time": 29.178,
      "time_str": "00:29.178",
      "text": "终于再将你拥入怀中",
      "translation": null
    },
    {
      "time": 38.588,
      "time_str": "00:38.588",
      "text": "两颗心颤抖",
      "translation": null
    },
    {
      "time": 45.398,
      "time_str": "00:45.398",
      "text": "相信我 不变的真心",
      "translation": null
    },
    {
      "time": 52.908,
      "time_str": "00:52.908",
      "text": "千年等待 有我承诺",
      "translation": null
    },
    {
      "time": 59.148,
      "time_str": "00:59.148",
      "text": "无论经过多少的寒冬",
      "translation": null
    },
    {
      "time": 69.099,
      "time_str": "01:09.099",
      "text": "我决不放手",
      "translation": null
    },
    {
      "time": 75.28,
      "time_str": "01:15.280",
      "text": "女：이제 나의 손을 잡고 눈을 감아요",
      "translation": "现在紧抓住我的手闭上眼睛"
    },
    {
      "time": 81.987,
      "time_str": "01:21.987",
      "text": "우리 사랑했던 날들 생각해봐요",
      "translation": "请你回想起过去我们恋爱的日子"
    },
    {
      "time": 89.408,
      "time_str": "01:29.408",
      "text": "우리 너무 사랑해서 아팠었네요",
      "translation": "我们是因为太爱 所以更使得我们痛苦"
    },
    {
      "time": 97.488,
      "time_str": "01:37.488",
      "text": "서로 사랑한단 말도 못했었네요",
      "translation": "我们连\"爱你\"这句话都无法讲"
    },
    {
      "time": 119.968,
      "time_str": "01:59.968",
      "text": "男：每一夜 被心痛穿越",
      "translation": null
    },
    {
      "time": 126.479,
      "time_str": "02:06.479",
      "text": "思念永没有终点",
      "translation": null
    },
    {
      "time": 132.599,
      "time_str": "02:12.599",
      "text": "早习惯了孤独相随",
      "translation": null
    },
    {
      "time": 142.2,
      "time_str": "02:22.200",
      "text": "我微笑面对",
      "translation": null
    },
    {
      "time": 149.499,
      "time_str": "02:29.499",
      "text": "相信我 你选择等待",
      "translation": null
    },
    {
      "time": 156.528,
      "time_str": "02:36.528",
      "text": "再多苦痛也不闪躲",
      "translation": null
    },
    {
      "time": 162.799,
      "time_str": "02:42.799",
      "text": "只有你的温柔能解救",
      "translation": null
    },
    {
      "time": 171.099,
