  "lyrics": [
    {
      "time": 27.37,
      "time_str": "00:27.370",
      "text": "自你离开以后",
      "translation": null
    },
    {
      "time": 32.72,
      "time_str": "00:32.720",
      "text": "从此就丢了温柔",
      "translation": null
    },
    {
      "time": 38.67,
      "time_str": "00:38.670",
      "text": "等待在这雪山路漫长",
      "translation": null
    },
    {
      "time": 45.28,
      "time_str": "00:45.280",
      "text": "听寒风呼啸依旧",
      "translation": null
    },
    {
      "time": 51.7,
      "time_str": "00:51.700",
      "text": "一眼望不到边",
      "translation": null
    },
    {
      "time": 57.89,
      "time_str": "00:57.890",
      "text": "风似刀割我的脸",
      "translation": null
    },
    {
      "time": 64.71,
      "time_str": "01:04.710",
      "text": "等不到西海天际蔚蓝",
      "translation": null
    },
    {
      "time": 70.82,
      "time_str": "01:10.820",
      "text": "无言着苍茫的高原",
      "translation": null
    },
    {
      "time": 77.85,
      "time_str": "01:17.850",
      "text": "还记得你答应过我不会让我把你找不见",
      "translation": null
    },
    {
      "time": 85.64,
      "time_str": "01:25.640",
      "text": "可你跟随那南归的候鸟飞得那么远",
      "translation": null
    },
    {
      "time": 92.07,
      "time_str": "01:32.070",
      "text": "爱象风筝断了线",
      "translation": null
    },
    {
      "time": 95.2,
      "time_str": "01:35.200",
      "text": "拉不住你许下的诺言",
      "translation": null
    },
    {
      "time": 101.94,
      "time_str": "01:41.940",
      "text": "我在苦苦等待雪山之巅温暖的春天",
      "translation": null
    },
    {
      "time": 108.63,
      "time_str": "01:48.630",
      "text": "等待高原冰雪融化之后归来的孤雁",
      "translation": null
    },
    {
      "time": 114.55,
      "time_str": "01:54.550",
      "text": "爱再难以续情缘",
      "translation": null
    },
    {
      "time": 117.62,
      "time_str": "01:57.620",
      "text": "回不到我们的从前",
      "translation": null
    },
