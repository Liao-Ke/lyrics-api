    {
      "time": 2.13,
      "time_str": "00:02.130",
      "text": "明天你是否会想起",
      "translation": null
    },
    {
      "time": 5.76,
      "time_str": "00:05.760",
      "text": "昨天你写的日记",
      "translation": null
    },
    {
      "time": 9.42,
      "time_str": "00:09.420",
      "text": "明天你是否还惦记",
      "translation": null
    },
    {
      "time": 12.97,
      "time_str": "00:12.970",
      "text": "曾经最爱哭的你",
      "translation": null
    },
    {
      "time": 16.8,
      "time_str": "00:16.800",
      "text": "老师们都已想不起",
      "translation": null
    },
    {
      "time": 20.4,
      "time_str": "00:20.400",
      "text": "猜不出问题的你",
      "translation": null
    },
    {
      "time": 24.03,
      "time_str": "00:24.030",
      "text": "我也是偶然翻相片",
      "translation": null
    },
    {
      "time": 27.72,
      "time_str": "00:27.720",
      "text": "才想起同桌的你",
      "translation": null
    },
    {
      "time": 31.38,
      "time_str": "00:31.380",
      "text": "谁娶了多愁善感的你",
      "translation": null
    },
    {
      "time": 35.11,
      "time_str": "00:35.110",
      "text": "谁看了你的日记",
      "translation": null
    },
    {
      "time": 38.69,
      "time_str": "00:38.690",
      "text": "谁把你的长发盘起",
      "translation": null
    },
    {
      "time": 42.4,
      "time_str": "00:42.400",
      "text": "谁给你做的嫁衣",
      "translation": null
    },
    {
      "time": 74.79,
      "time_str": "01:14.790",
      "text": "你从前总是很小心",
      "translation": null
    },
    {
      "time": 78.36,
      "time_str": "01:18.360",
      "text": "问我借半块橡皮",
      "translation": null
    },
    {
      "time": 81.9,
      "time_str": "01:21.900",
      "text": "你也曾无意中说起",
      "translation": null
    },
    {
      "time": 85.6,
      "time_str": "01:25.600",
      "text": "喜欢跟我在一起",
      "translation": null
    },
    {
      "time": 89.62,
      "time_str": "01:29.620",
      "text": "那时候天总是很蓝",
      "translation": null
    },
    {
      "time": 93.05,
      "time_str": "01:33.050",
      "text": "日子总过得太慢",
      "translation": null
    },
    {
      "time": 96.62,
      "time_str": "01:36.620",
      "text": "你总说毕业遥遥无期",
