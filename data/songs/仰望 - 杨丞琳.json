    {
      "time": 15.57,
      "time_str": "00:15.570",
      "text": "如果能重来 我的答案",
      "translation": null
    },
    {
      "time": 20.5,
      "time_str": "00:20.500",
      "text": "会不会更改 或是等待",
      "translation": null
    },
    {
      "time": 23.95,
      "time_str": "00:23.950",
      "text": "守在你身旁 绝对不逃开",
      "translation": null
    },
    {
      "time": 27.86,
      "time_str": "00:27.860",
      "text": "不让谁 将我们冲散",
      "translation": null
    },
    {
      "time": 31.99,
      "time_str": "00:31.990",
      "text": "不怕风看穿 我的孤单",
      "translation": null
    },
    {
      "time": 35.99,
      "time_str": "00:35.990",
      "text": "不怕雨纠缠 眼泪擦干",
      "translation": null
    },
    {
      "time": 39.73,
      "time_str": "00:39.730",
      "text": "让回忆倒带 我将爱保管",
      "translation": null
    },
    {
      "time": 43.59,
      "time_str": "00:43.590",
      "text": "别让我 一个人承担",
      "translation": null
    },
    {
      "time": 47.85,
      "time_str": "00:47.850",
      "text": "这个失去你的遗憾 我会勇敢",
      "translation": null
    },
    {
      "time": 51.7,
      "time_str": "00:51.700",
      "text": "仰望风 能带你回来",
      "translation": null
    },
    {
      "time": 55.32,
      "time_str": "00:55.320",
      "text": "仰望雨 能安静听完",
      "translation": null
    },
    {
      "time": 59.25,
      "time_str": "00:59.250",
      "text": "脸庞发烫 眼眶抵抗",
      "translation": null
    },
    {
      "time": 62.39,
      "time_str": "01:02.390",
      "text": "不肯让你离开 丢下我流浪",
      "translation": null
    },
    {
      "time": 67.03,
      "time_str": "01:07.030",
      "text": "仰望你 抱我在胸膛",
      "translation": null
    },
    {
      "time": 71.4,
      "time_str": "01:11.400",
      "text": "仰望梦 能给我力量",
      "translation": null
    },
    {
