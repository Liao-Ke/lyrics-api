  "lyrics": [
    {
      "time": 18.77,
      "time_str": "00:18.770",
      "text": "深色的海面布满白色的月光",
      "translation": null
    },
    {
      "time": 25.11,
      "time_str": "00:25.110",
      "text": "我出神望着海 心不知飞哪去",
      "translation": null
    },
    {
      "time": 31.64,
      "time_str": "00:31.640",
      "text": "听到她在告诉你",
      "translation": null
    },
    {
      "time": 35.28,
      "time_str": "00:35.280",
      "text": "说她真的喜欢你",
      "translation": null
    },
    {
      "time": 39.48,
      "time_str": "00:39.480",
      "text": "我不知该 躲哪里",
      "translation": null
    },
    {
      "time": 47.17,
      "time_str": "00:47.170",
      "text": "爱一个人是不是应该有默契",
      "translation": null
    },
    {
      "time": 54.15,
      "time_str": "00:54.150",
      "text": "我以为你懂得每当我看着你",
      "translation": null
    },
    {
      "time": 60.07,
      "time_str": "01:00.070",
      "text": "我藏起来的秘密",
      "translation": null
    },
    {
      "time": 63.67,
      "time_str": "01:03.670",
      "text": "在每一天清晨里",
      "translation": null
    },
    {
      "time": 67.6,
      "time_str": "01:07.600",
      "text": "暖成咖啡 安静的拿给你",
      "translation": null
    },
    {
      "time": 74.33,
      "time_str": "01:14.330",
      "text": "愿意 用一支黑色的铅笔",
      "translation": null
    },
    {
      "time": 78.81,
      "time_str": "01:18.810",
      "text": "画一出沉默舞台剧",
      "translation": null
    },
    {
      "time": 82.95,
      "time_str": "01:22.950",
      "text": "灯光再亮 也抱住你",
      "translation": null
    },
    {
      "time": 88.53,
      "time_str": "01:28.530",
      "text": "愿意 在角落唱沙哑的歌",
      "translation": null
    },
    {
      "time": 93.06,
      "time_str": "01:33.060",
      "text": "再大声也都是给你",
      "translation": null
    },
    {
      "time": 97.24,
      "time_str": "01:37.240",
      "text": "请用心听 不要说话",
