{
  "title": "再见 小时候",
  "title_raw": "再见 小时候",
  "version": null,
  "artist": "南拳妈妈",
  "group_key": "再见 小时候|南拳妈妈",
  "writers": {
    "lyricist": "宋健彰/詹宇豪",
    "composer": "詹宇豪",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 29.269,
      "time_str": "00:29.269",
      "text": "有一天我 翻开旧旧的相簿",
      "translation": null
    },
    {
      "time": 32.668,
      "time_str": "00:32.668",
      "text": "上面写着 给最亲爱的宝物",
      "translation": null
    },
    {
      "time": 36.18,
      "time_str": "00:36.180",
      "text": "里面有我 穿幼稚园的制服",
      "translation": null
    },
    {
      "time": 39.198,
      "time_str": "00:39.198",
      "text": "还有一张 是我妈妈的笑容",
      "translation": null
    },
    {
      "time": 42.308,
      "time_str": "00:42.308",
      "text": "突然发现 时间变的很仓促",
      "translation": null
    },
    {
      "time": 45.848,
      "time_str": "00:45.848",
      "text": "爸爸妈妈 变的互相不认输",
      "translation": null
    },
    {
      "time": 49.208,
      "time_str": "00:49.208",
      "text": "我放下相簿 头靠着窗户",
      "translation": null
    },
    {
      "time": 52.798,
      "time_str": "00:52.798",
      "text": "看着天空 视线变模糊",
      "translation": null
    },
    {
      "time": 55.348,
      "time_str": "00:55.348",
      "text": "童年糖果罐 已经快溶化完",
      "translation": null
    },
    {
      "time": 58.508,
      "time_str": "00:58.508",
      "text": "缤纷的气球 在骊歌中飘散",
      "translation": null
    },
    {
      "time": 62.248,
      "time_str": "01:02.248",
      "text": "我们 就这样紧紧 牵起了勇敢",
      "translation": null
    },
    {
      "time": 68.698,
      "time_str": "01:08.698",
      "text": "隔壁班的女孩 我喜欢的女孩",
      "translation": null
    },
    {
      "time": 72.299,
      "time_str": "01:12.299",
      "text": "她从来不爱我",
      "translation": null
    },
    {
      "time": 74.349,
      "time_str": "01:14.349",
      "text": "抽屉还摆着 被退回的温柔",
      "translation": null
    },
    {
      "time": 80.998,
      "time_str": "01:20.998",
      "text": "再见了小时候 懵懂的我",
      "translation": null
    },
    {
      "time": 84.688,
      "time_str": "01:24.688",
      "text": "现在的梦已经成熟",
      "translation": null
    },
    {
      "time": 87.958,
      "time_str": "01:27.958",
      "text": "风在朗诵 下课的钟",
      "translation": null
    },
    {
      "time": 91.278,
      "time_str": "01:31.278",
      "text": "而时光静静地走",
      "translation": null
    },
    {
      "time": 94.528,
      "time_str": "01:34.528",
      "text": "鲜嫩的梦 已经熟透",
      "translation": null
    },
    {
      "time": 97.998,
      "time_str": "01:37.998",
      "text": "夕阳洒落 让剪影斑驳",
      "translation": null
    },
    {
      "time": 100.927,
      "time_str": "01:40.927",
      "text": "旧旧的 围墙外头",
      "translation": null
    },
    {
      "time": 104.129,
      "time_str": "01:44.129",
      "text": "悄悄围起未来的 轮廓",
      "translation": null
    },
    {
      "time": 133.179,
      "time_str": "02:13.179",
      "text": "童年糖果罐 已经快溶化完",
