  "lyrics": [
    {
      "time": 8.62,
      "time_str": "00:08.620",
      "text": "我怕我没有机会",
      "translation": null
    },
    {
      "time": 12.44,
      "time_str": "00:12.440",
      "text": "跟你说一声再见",
      "translation": null
    },
    {
      "time": 16.31,
      "time_str": "00:16.310",
      "text": "因为也许就再也见不到你",
      "translation": null
    },
    {
      "time": 24.24,
      "time_str": "00:24.240",
      "text": "明天我要离开",
      "translation": null
    },
    {
      "time": 27.92,
      "time_str": "00:27.920",
      "text": "熟悉的地方和你",
      "translation": null
    },
    {
      "time": 31.86,
      "time_str": "00:31.860",
      "text": "要分离",
      "translation": null
    },
    {
      "time": 34.08,
      "time_str": "00:34.080",
      "text": "我眼泪就掉下去",
      "translation": null
    },
    {
      "time": 39.63,
      "time_str": "00:39.630",
      "text": "我会牢牢记住你的脸",
      "translation": null
    },
    {
      "time": 43.44,
      "time_str": "00:43.440",
      "text": "我会珍惜你给的思念",
      "translation": null
    },
    {
      "time": 47.29,
      "time_str": "00:47.290",
      "text": "这些日子在我心中永远都不会抹去",
      "translation": null
    },
    {
      "time": 55.11,
      "time_str": "00:55.110",
      "text": "我不能答应你",
      "translation": null
    },
    {
      "time": 58.91,
      "time_str": "00:58.910",
      "text": "我是否会再回来",
      "translation": null
    },
    {
      "time": 62.74,
      "time_str": "01:02.740",
      "text": "不回头",
      "translation": null
    },
    {
      "time": 65.409,
      "time_str": "01:05.409",
      "text": "不回头地走下去",
      "translation": null
    },
