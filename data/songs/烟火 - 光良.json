      "time_str": "01:07.730",
      "text": "在你我之间",
      "translation": null
    },
    {
      "time": 69.98,
      "time_str": "01:09.980",
      "text": "有时说变就变就像烟火",
      "translation": null
    },
    {
      "time": 74.44,
      "time_str": "01:14.440",
      "text": "下一秒消失不见",
      "translation": null
