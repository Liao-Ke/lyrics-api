    {
      "time": 17.78,
      "time_str": "00:17.780",
      "text": "是否还记得一起看烟火",
      "translation": null
    },
    {
      "time": 24.96,
      "time_str": "00:24.960",
      "text": "我在你眼里看到闪烁",
      "translation": null
    },
    {
      "time": 31.95,
      "time_str": "00:31.950",
      "text": "冷冽的寒风把你吹向我",
      "translation": null
    },
    {
      "time": 38.2,
      "time_str": "00:38.200",
      "text": "抱你在我怀中没想太多",
      "translation": null
    },
    {
      "time": 45.48,
      "time_str": "00:45.480",
      "text": "爱情里的心动",
      "translation": null
    },
    {
      "time": 48.07,
      "time_str": "00:48.070",
      "text": "常常让我难以去捉摸",
      "translation": null
    },
    {
      "time": 52.55,
      "time_str": "00:52.550",
      "text": "付出感情太多",
      "translation": null
    },
    {
      "time": 55.37,
      "time_str": "00:55.370",
      "text": "原来多情人总被伤的最重",
      "translation": null
    },
    {
      "time": 62.86,
      "time_str": "01:02.860",
      "text": "想起你的拥抱",
      "translation": null
    },
    {
      "time": 64.32,
      "time_str": "01:04.320",
      "text": "这感觉短暂纪念",
      "translation": null
    },
    {
