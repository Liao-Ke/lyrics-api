      "text": "SP：SAMP (Beijing) Co., Ltd索雅音乐版权代理(北京)有限公司",
      "translation": null
    },
    {
      "time": 43.713,
      "time_str": "00:43.713",
      "text": "想借天使的翅膀",
      "translation": null
    },
    {
      "time": 47.172,
      "time_str": "00:47.172",
      "text": "抓住云端的彩虹",
      "translation": null
    },
    {
      "time": 53.248,
      "time_str": "00:53.248",
      "text": "总在将要触碰时消散",
      "translation": null
    },
    {
      "time": 57.514,
      "time_str": "00:57.514",
      "text": "错觉的地久天长",
      "translation": null
    },
    {
      "time": 61.19,
      "time_str": "01:01.190",
      "text": "其实是一无所有",
      "translation": null
    },
    {
      "time": 68.857,
      "time_str": "01:08.857",
      "text": "童话说雨后会有一道彩虹",
      "translation": null
    },
    {
      "time": 75.984,
      "time_str": "01:15.984",
      "text": "却不曾说过它也会转瞬成空",
      "translation": null
    },
    {
      "time": 82.758,
      "time_str": "01:22.758",
      "text": "想要把绚烂紧紧握在手中",
      "translation": null
    },
    {
      "time": 89.681,
      "time_str": "01:29.681",
      "text": "忽然发现你已不见",
      "translation": null
    },
    {
      "time": 125.849,
      "time_str": "02:05.849",
      "text": "站在无尽红尘中",
      "translation": null
    },
    {
      "time": 129.604,
      "time_str": "02:09.604",
      "text": "仰望曾有你的苍穹",
      "translation": null
    },
    {
      "time": 135.676,
      "time_str": "02:15.676",
      "text": "得到以后转眼又落空",
      "translation": null
    },
    {
      "time": 139.834,
      "time_str": "02:19.834",
      "text": "究竟什么是永恒",
      "translation": null
    },
    {
      "time": 143.49,
      "time_str": "02:23.490",
      "text": "都无法拥有完整",
      "translation": null
    },
    {
      "time": 148.893,
      "time_str": "02:28.893",
      "text": "Oh my love",
      "translation": null
    },
    {
      "time": 151.573,
      "time_str": "02:31.573",
      "text": "我看见希望闪耀在虹之间",
      "translation": null
    },
    {
      "time": 158.08,
      "time_str": "02:38.080",
      "text": "光芒凝结于你我的那片天",
      "translation": null
    },
    {
      "time": 164.879,
      "time_str": "02:44.879",
      "text": "不再追问你为何不能停留",
      "translation": null
    },
    {
      "time": 171.542,
      "time_str": "02:51.542",
      "text": "微笑看见爱的浮现",
      "translation": null
    },
    {
      "time": 178.915,
      "time_str": "02:58.915",
      "text": "雨后的天空重又出现彩虹",
      "translation": null
    },
    {
      "time": 185.128,
      "time_str": "03:05.128",
      "text": "天使的恩惠亲吻着世间万众",
      "translation": null
    },
    {
      "time": 192.559,
      "time_str": "03:12.559",
      "text": "不再追问你为何不能停留",
      "translation": null
    },
    {
      "time": 198.901,
      "time_str": "03:18.901",
      "text": "放下了执念微笑现在",
      "translation": null
    }
  ],
