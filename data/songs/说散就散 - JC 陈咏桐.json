  "lyrics": [
    {
      "time": 8.12,
      "time_str": "00:08.120",
      "text": "抱一抱就当作从没有在一起",
      "translation": null
    },
    {
      "time": 14.55,
      "time_str": "00:14.550",
      "text": "好不好要解释都已经来不及",
      "translation": null
    },
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "算了吧我付出过什么没关系",
      "translation": null
    },
    {
      "time": 26.89,
      "time_str": "00:26.890",
      "text": "我忽略自己就因为遇见你",
      "translation": null
    },
    {
      "time": 33.83,
      "time_str": "00:33.830",
      "text": "没办法好可怕那个我不像话",
      "translation": null
    },
    {
      "time": 40.54,
      "time_str": "00:40.540",
      "text": "一直奋不顾身是我太傻",
      "translation": null
    },
    {
      "time": 46.26,
      "time_str": "00:46.260",
      "text": "说不上爱别说谎就一点喜欢",
      "translation": null
    },
    {
      "time": 53.58,
      "time_str": "00:53.580",
      "text": "说不上恨别纠缠别装作感叹",
      "translation": null
    },
    {
      "time": 60.4,
      "time_str": "01:00.400",
      "text": "就当作我太麻烦不停让自己受伤",
      "translation": null
    },
    {
      "time": 64.29,
      "time_str": "01:04.290",
      "text": "我告诉我自己感情就是这样",
      "translation": null
    },
    {
      "time": 70.31,
      "time_str": "01:10.310",
      "text": "怎么一不小心太疯狂",
      "translation": null
    },
    {
      "time": 83.46,
      "time_str": "01:23.460",
      "text": "抱一抱再好好觉悟不能长久",
      "translation": null
    },
    {
      "time": 90.1,
      "time_str": "01:30.100",
      "text": "好不好有亏欠我们都别追究",
      "translation": null
    },
    {
      "time": 96.89,
      "time_str": "01:36.890",
      "text": "算了吧我付出再多都不足够",
      "translation": null
    },
    {
      "time": 102.38,
      "time_str": "01:42.380",
      "text": "我终于得救我不想再献丑",
      "translation": null
    },
    {
      "time": 109.6,
      "time_str": "01:49.600",
      "text": "没办法不好吗大家都不留下",
      "translation": null
    },
    {
      "time": 115.98,
      "time_str": "01:55.980",
      "text": "一直勉强相处总会累垮",
      "translation": null
    },
    {
      "time": 121.91,
      "time_str": "02:01.910",
      "text": "说不上爱别说谎就一点喜欢",
      "translation": null
    },
    {
