    },
    {
      "time": 151.95,
      "time_str": "02:31.950",
      "text": "别后悔就算错过",
      "translation": null
    },
    {
      "time": 155.29,
      "time_str": "02:35.290",
      "text": "在以后你少不免想起我",
      "translation": null
    },
    {
      "time": 161.25,
      "time_str": "02:41.250",
      "text": "还算不错",
      "translation": null
    },
    {
      "time": 164.8,
      "time_str": "02:44.800",
      "text": "当我不在你会不会难过",
      "translation": null
    },
    {
      "time": 168.42,
      "time_str": "02:48.420",
      "text": "你够不够我这样洒脱",
      "translation": null
    },
    {
      "time": 173.57,
