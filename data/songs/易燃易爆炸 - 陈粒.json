  "lyrics": [
    {
      "time": 15.82,
      "time_str": "00:15.820",
      "text": "盼我疯魔还盼我孑孓不独活",
      "translation": null
    },
    {
      "time": 20.16,
      "time_str": "00:20.160",
      "text": "想我冷艳还想我轻佻又下贱",
      "translation": null
    },
    {
      "time": 24.23,
      "time_str": "00:24.230",
      "text": "要我阳光还要我风情不摇晃",
      "translation": null
    },
    {
      "time": 28.45,
      "time_str": "00:28.450",
      "text": "戏我哭笑无主还戏我心如枯木",
      "translation": null
    },
    {
      "time": 32.44,
      "time_str": "00:32.440",
      "text": "赐我梦境还赐我很快就清醒",
      "translation": null
    },
    {
      "time": 36.7,
      "time_str": "00:36.700",
      "text": "与我沉睡还与我蹉跎无慈悲",
      "translation": null
    },
    {
      "time": 40.83,
      "time_str": "00:40.830",
      "text": "爱我纯粹还爱我赤裸不靡颓",
      "translation": null
    },
    {
      "time": 44.96,
      "time_str": "00:44.960",
      "text": "看我自弹自唱还看我痛心断肠",
      "translation": null
    },
    {
      "time": 49.6,
      "time_str": "00:49.600",
      "text": "愿我如烟还愿我曼丽又懒倦",
      "translation": null
    },
    {
      "time": 53.32,
      "time_str": "00:53.320",
      "text": "看我痴狂还看我风趣又端庄",
      "translation": null
    },
    {
      "time": 57.5,
      "time_str": "00:57.500",
      "text": "要我美艳还要我杀人不眨眼",
      "translation": null
    },
    {
      "time": 61.57,
      "time_str": "01:01.570",
      "text": "祝我从此幸福还祝我枯萎不渡",
      "translation": null
    },
    {
      "time": 65.86,
      "time_str": "01:05.860",
      "text": "为我撩人还为我双眸失神",
      "translation": null
    },
    {
      "time": 69.88,
      "time_str": "01:09.880",
      "text": "图我情真还图我眼波销魂",
      "translation": null
    },
    {
      "time": 74.09,
      "time_str": "01:14.090",
      "text": "与我私奔还与我做不贰臣",
      "translation": null
    },
    {
      "time": 78.18,
      "time_str": "01:18.180",
      "text": "夸我含苞待放还夸我欲盖弥彰",
      "translation": null
    },
    {
      "time": 99.14,
      "time_str": "01:39.140",
      "text": "赐我梦境还赐我很快就清醒",
      "translation": null
    },
    {
