      "text": "夸我含苞待放还夸我欲盖弥彰",
      "translation": null
    },
    {
      "time": 149.21,
      "time_str": "02:29.210",
      "text": "请我迷人还请我艳情透渗",
      "translation": null
    },
    {
      "time": 153.52,
      "time_str": "02:33.520",
      "text": "似我盛放还似我缺氧乖张",
      "translation": null
    },
    {
      "time": 157.77,
      "time_str": "02:37.770",
      "text": "由我美丽还由我贪恋着迷",
      "translation": null
    },
    {
      "time": 161.8,
      "time_str": "02:41.800",
      "text": "怨我百岁无忧还怨我徒有泪流",
      "translation": null
    }
