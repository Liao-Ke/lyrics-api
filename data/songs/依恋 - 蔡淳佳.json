  "lyrics": [
    {
      "time": 9.618,
      "time_str": "00:09.618",
      "text": "依恋 坐在我旁边",
      "translation": null
    },
    {
      "time": 14.892,
      "time_str": "00:14.892",
      "text": "厚厚的想念",
      "translation": null
    },
    {
      "time": 18.125,
      "time_str": "00:18.125",
      "text": "随月光蔓延",
      "translation": null
    },
    {
      "time": 22.605,
      "time_str": "00:22.605",
      "text": "依恋 跟在你身边",
      "translation": null
    },
    {
      "time": 27.833,
      "time_str": "00:27.833",
      "text": "看你的笑脸",
      "translation": null
    },
    {
      "time": 31.119,
      "time_str": "00:31.119",
      "text": "吻你的唇边",
      "translation": null
    },
    {
      "time": 35.131,
      "time_str": "00:35.131",
      "text": "如果爱是座秋千",
      "translation": null
    },
    {
      "time": 41.607,
      "time_str": "00:41.607",
      "text": "你就是我的原点",
      "translation": null
    },
    {
      "time": 48.561,
      "time_str": "00:48.561",
      "text": "依恋 是一叠昨天",
      "translation": null
    },
    {
      "time": 53.795,
      "time_str": "00:53.795",
      "text": "你给的抱歉",
      "translation": null
    },
    {
      "time": 57.035,
      "time_str": "00:57.035",
      "text": "多想没听见",
      "translation": null
    },
    {
      "time": 61.499,
      "time_str": "01:01.499",
      "text": "依恋 是一条天线",
      "translation": null
    },
    {
      "time": 66.754,
      "time_str": "01:06.754",
      "text": "只收到从前",
      "translation": null
    },
    {
      "time": 70.004,
      "time_str": "01:10.004",
      "text": "回忆的画面",
      "translation": null
    },
    {
      "time": 74.046,
      "time_str": "01:14.046",
      "text": "没有你该怎么演",
      "translation": null
    },
    {
      "time": 80.563,
      "time_str": "01:20.563",
      "text": "那些你说的永远",
      "translation": null
    },
    {
      "time": 87.459,
      "time_str": "01:27.459",
      "text": "依恋 就让它依恋",
      "translation": null
    },
    {
      "time": 92.715,
      "time_str": "01:32.715",
      "text": "毕竟拥有过",
      "translation": null
    },
    {
      "time": 95.923,
      "time_str": "01:35.923",
      "text": "你一段时间",
      "translation": null
    },
    {
      "time": 100.426,
      "time_str": "01:40.426",
      "text": "或许 分开是一种",
      "translation": null
    },
    {
      "time": 105.674,
      "time_str": "01:45.674",
      "text": "所谓的成全",
      "translation": null
    },
    {
      "time": 108.932,
      "time_str": "01:48.932",
      "text": "爱我会放在心里面",
      "translation": null
    },
    {
      "time": 112.146,
      "time_str": "01:52.146",
      "text": "有些事不会有期限",
      "translation": null
    },
