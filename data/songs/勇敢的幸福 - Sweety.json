  "lyrics": [
    {
      "time": 3.56,
      "time_str": "00:03.560",
      "text": "勇敢的幸福---sweety",
      "translation": null
    },
    {
      "time": 25.77,
      "time_str": "00:25.770",
      "text": "伴着盛开的花 蝴蝶才能飞舞",
      "translation": null
    },
    {
      "time": 30.0,
      "time_str": "00:30.000",
      "text": "带着希望 梦想才能飞往高处",
      "translation": null
    },
    {
      "time": 34.73,
      "time_str": "00:34.730",
      "text": "迎着温暖的风 我们不再无助",
      "translation": null
    },
    {
      "time": 39.52,
      "time_str": "00:39.520",
      "text": "因为你的祝福 我的爱不辛苦",
      "translation": null
    },
    {
      "time": 43.86,
      "time_str": "00:43.860",
      "text": "呼吸感动 我不再退步",
      "translation": null
    },
    {
      "time": 48.91,
      "time_str": "00:48.910",
      "text": "让音乐 赶走我的孤独",
      "translation": null
    },
    {
      "time": 53.2,
      "time_str": "00:53.200",
      "text": "我的勇气 因为你的保护",
      "translation": null
    },
    {
      "time": 58.79,
      "time_str": "00:58.790",
      "text": "不曾停下追逐真爱的脚步",
      "translation": null
    },
    {
      "time": 63.53,
      "time_str": "01:03.530",
      "text": "种下爱 种下梦  种下我们的心愿",
      "translation": null
    },
    {
      "time": 67.88,
      "time_str": "01:07.880",
      "text": "让阳光 照亮在 我们心灵最深处",
      "translation": null
    },
    {
      "time": 72.89,
      "time_str": "01:12.890",
      "text": "那些事 那些歌",
      "translation": null
    },
    {
      "time": 75.01,
      "time_str": "01:15.010",
      "text": "伴着我们的誓约",
      "translation": null
    },
    {
      "time": 77.38,
      "time_str": "01:17.380",
      "text": "不能哭 我们要 挑战未知旅途",
      "translation": null
    },
    {
      "time": 82.19,
      "time_str": "01:22.190",
      "text": "不怕输 我们有 笑声交织着泪水",
      "translation": null
    },
    {
