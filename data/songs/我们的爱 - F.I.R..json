  "lyrics": [
    {
      "time": 21.9,
      "time_str": "00:21.900",
      "text": "回忆里想起模糊的小时候",
      "translation": null
    },
    {
      "time": 28.94,
      "time_str": "00:28.940",
      "text": "云朵漂浮在蓝蓝的天空",
      "translation": null
    },
    {
      "time": 34.68,
      "time_str": "00:34.680",
      "text": "那时的你说 要和我手牵手",
      "translation": null
    },
    {
      "time": 42.68,
      "time_str": "00:42.680",
      "text": "一起走到时间的尽头",
      "translation": null
    },
    {
      "time": 50.11,
      "time_str": "00:50.110",
      "text": "从此以后我都不敢抬头看",
      "translation": null
    },
    {
      "time": 57.17,
      "time_str": "00:57.170",
      "text": "仿佛我的天空失去了颜色",
      "translation": null
    },
    {
      "time": 62.89,
      "time_str": "01:02.890",
      "text": "从那一天起 我忘记了呼吸",
      "translation": null
    },
    {
      "time": 70.86,
      "time_str": "01:10.860",
      "text": "眼泪啊永远不再 不再哭泣",
      "translation": null
    },
    {
      "time": 80.53,
      "time_str": "01:20.530",
      "text": "我们的爱 过了就不再回来",
      "translation": null
    },
    {
      "time": 88.51,
      "time_str": "01:28.510",
      "text": "直到现在 我还默默的等待",
      "translation": null
    },
    {
      "time": 94.73,
      "time_str": "01:34.730",
      "text": "我们的爱 我明白",
      "translation": null
    },
    {
      "time": 98.65,
      "time_str": "01:38.650",
      "text": "已变成你的负担",
      "translation": null
    },
    {
      "time": 102.66,
      "time_str": "01:42.660",
      "text": "只是永远 我都放不开",
      "translation": null
    },
    {
      "time": 107.92,
      "time_str": "01:47.920",
      "text": "最后的温暖",
      "translation": null
    },
    {
