  "lyrics": [
    {
      "time": 22.95,
      "time_str": "00:22.950",
      "text": "到底要笑得多虚伪",
      "translation": null
    },
    {
      "time": 25.67,
      "time_str": "00:25.670",
      "text": "才能够融入这世界",
      "translation": null
    },
    {
      "time": 28.37,
      "time_str": "00:28.370",
      "text": "每个人的脸上都像是",
      "translation": null
    },
    {
      "time": 31.14,
      "time_str": "00:31.140",
      "text": "贴了张一样的假面",
      "translation": null
    },
    {
      "time": 33.91,
      "time_str": "00:33.910",
      "text": "想不起我在做什么",
      "translation": null
    },
    {
      "time": 36.6,
      "time_str": "00:36.600",
      "text": "想不起我在想什么",
      "translation": null
    },
    {
      "time": 39.28,
      "time_str": "00:39.280",
      "text": "想不起灵魂深处",
      "translation": null
    },
    {
      "time": 41.0,
      "time_str": "00:41.000",
      "text": "到底发生了什么",
      "translation": null
    },
    {
      "time": 44.05,
      "time_str": "00:44.050",
      "text": "迷雾 迷雾 在迷雾",
      "translation": null
    },
    {
      "time": 46.4,
      "time_str": "00:46.400",
      "text": "我惊觉自己在原地踏步",
      "translation": null
    },
    {
      "time": 49.08,
      "time_str": "00:49.080",
      "text": "到底是谁把我 心蒙住",
      "translation": null
    },
    {
      "time": 52.0,
      "time_str": "00:52.000",
      "text": "不想再糊涂",
      "translation": null
    },
    {
      "time": 54.89,
      "time_str": "00:54.890",
      "text": "迷路 迷路 迷了路",
      "translation": null
    },
    {
      "time": 57.19,
      "time_str": "00:57.190",
      "text": "我就彻底被这团迷雾困住",
      "translation": null
    },
    {
      "time": 60.08,
      "time_str": "01:00.080",
      "text": "谁能够指引我 一条路",
      "translation": null
    },
    {
      "time": 63.0,
      "time_str": "01:03.000",
      "text": "带我走上正途",
      "translation": null
    },
    {
      "time": 77.54,
      "time_str": "01:17.540",
      "text": "装不出融入的态度",
      "translation": null
    },
    {
      "time": 80.3,
      "time_str": "01:20.300",
      "text": "空气里充斥着虚无",
      "translation": null
    },
    {
      "time": 83.0,
