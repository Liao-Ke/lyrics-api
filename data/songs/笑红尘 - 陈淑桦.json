  "lyrics": [
    {
      "time": 11.81,
      "time_str": "00:11.810",
      "text": "红尘多可笑",
      "translation": null
    },
    {
      "time": 13.78,
      "time_str": "00:13.780",
      "text": "痴情最无聊",
      "translation": null
    },
    {
      "time": 16.23,
      "time_str": "00:16.230",
      "text": "目空一切也好",
      "translation": null
    },
    {
      "time": 20.16,
      "time_str": "00:20.160",
      "text": "此生未了",
      "translation": null
    },
    {
      "time": 21.6,
      "time_str": "00:21.600",
      "text": "心却已无所扰",
      "translation": null
    },
    {
      "time": 24.08,
      "time_str": "00:24.080",
      "text": "只想换得半世逍遥",
      "translation": null
    },
    {
      "time": 27.54,
      "time_str": "00:27.540",
      "text": "醒时对人笑",
      "translation": null
    },
    {
      "time": 29.51,
      "time_str": "00:29.510",
      "text": "梦中全忘掉",
      "translation": null
    },
    {
      "time": 31.95,
      "time_str": "00:31.950",
      "text": "叹天黑得太早",
      "translation": null
    },
    {
      "time": 35.87,
      "time_str": "00:35.870",
      "text": "来生难料",
      "translation": null
    },
    {
      "time": 37.42,
      "time_str": "00:37.420",
      "text": "爱恨一笔勾销",
      "translation": null
    },
    {
      "time": 39.82,
      "time_str": "00:39.820",
      "text": "对酒当歌我只愿开心到老",
      "translation": null
    },
    {
      "time": 43.23,
      "time_str": "00:43.230",
      "text": "风再冷不想逃",
      "translation": null
    },
    {
      "time": 45.24,
      "time_str": "00:45.240",
      "text": "花再美也不想要",
      "translation": null
    },
    {
      "time": 47.2,
      "time_str": "00:47.200",
      "text": "任我飘摇",
      "translation": null
    },
    {
      "time": 51.16,
      "time_str": "00:51.160",
      "text": "天越高心越小",
      "translation": null
    },
    {
      "time": 53.16,
      "time_str": "00:53.160",
      "text": "不问因果有多少",
      "translation": null
    },
    {
      "time": 55.12,
      "time_str": "00:55.120",
      "text": "独自醉倒",
      "translation": null
    },
    {
      "time": 59.04,
      "time_str": "00:59.040",
      "text": "今天哭明天笑",
      "translation": null
    },
    {
      "time": 61.01,
      "time_str": "01:01.010",
      "text": "不求有人能明了",
      "translation": null
    },
    {
      "time": 62.95,
      "time_str": "01:02.950",
      "text": "一身骄傲",
      "translation": null
    },
    {
      "time": 66.93,
      "time_str": "01:06.930",
      "text": "歌在唱舞在跳",
      "translation": null
    },
    {
      "time": 68.9,
      "time_str": "01:08.900",
      "text": "长夜漫漫不觉晓将快乐寻找",
      "translation": null
    },
