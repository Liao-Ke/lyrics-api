  "lyrics": [
    {
      "time": 29.65,
      "time_str": "00:29.650",
      "text": "盼不到我爱的人",
      "translation": null
    },
    {
      "time": 32.609,
      "time_str": "00:32.609",
      "text": "我知道我愿意再等",
      "translation": null
    },
    {
      "time": 36.809,
      "time_str": "00:36.809",
      "text": "疼不了爱我的人",
      "translation": null
    },
    {
      "time": 39.559,
      "time_str": "00:39.559",
      "text": "片刻柔情他骗不了人",
      "translation": null
    },
    {
      "time": 43.559,
      "time_str": "00:43.559",
      "text": "我不是无情的人",
      "translation": null
    },
    {
      "time": 45.209,
      "time_str": "00:45.209",
      "text": "却将你伤的最深",
      "translation": null
    },
    {
      "time": 47.229,
      "time_str": "00:47.229",
      "text": "我不忍 我不能",
      "translation": null
    },
    {
      "time": 51.429,
      "time_str": "00:51.429",
      "text": "别再认真忘了我的人",
      "translation": null
    },
    {
      "time": 58.649,
      "time_str": "00:58.649",
      "text": "离不开我爱的人",
      "translation": null
    },
    {
      "time": 61.649,
      "time_str": "01:01.649",
      "text": "我知道爱需要缘份",
      "translation": null
    },
    {
      "time": 65.509,
      "time_str": "01:05.509",
      "text": "放不下爱我的人",
      "translation": null
    },
    {
      "time": 68.709,
      "time_str": "01:08.709",
      "text": "因为了解他多么认真",
      "translation": null
    },
    {
      "time": 72.619,
      "time_str": "01:12.619",
      "text": "为什么最真的心",
      "translation": null
    },
    {
      "time": 74.99,
      "time_str": "01:14.990",
      "text": "碰不到最好的人",
      "translation": null
    },
    {
      "time": 77.419,
      "time_str": "01:17.419",
      "text": "我不问 我不能",
      "translation": null
    },
    {
      "time": 80.529,
      "time_str": "01:20.529",
      "text": "拥在怀中直到它变冷",
      "translation": null
    },
    {
      "time": 87.159,
      "time_str": "01:27.159",
      "text": "爱我的人对我痴心不悔",
      "translation": null
    },
    {
      "time": 90.619,
      "time_str": "01:30.619",
      "text": "我却为我爱的人甘心一生伤悲",
      "translation": null
    },
    {
      "time": 95.119,
      "time_str": "01:35.119",
      "text": "在乎的人始终不对",
      "translation": null
    },
    {
      "time": 98.69,
      "time_str": "01:38.690",
      "text": "谁对谁不必虚伪",
      "translation": null
    },
    {
      "time": 101.279,
      "time_str": "01:41.279",
      "text": "爱我的人为我付出一切",
      "translation": null
    },
    {
      "time": 104.889,
      "time_str": "01:44.889",
      "text": "我却为我爱的人流泪狂乱心碎",
      "translation": null
    },
    {
      "time": 108.849,
      "time_str": "01:48.849",
      "text": "爱与被爱同样受罪",
      "translation": null
    },
    {
      "time": 112.699,
      "time_str": "01:52.699",
      "text": "为什么不懂拒绝痴情的包围",
      "translation": null
    },
