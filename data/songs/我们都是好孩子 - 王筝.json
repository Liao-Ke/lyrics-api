      "time": 8.05,
      "time_str": "00:08.050",
      "text": "推开窗看天边白色的鸟",
      "translation": null
    },
    {
      "time": 12.66,
      "time_str": "00:12.660",
      "text": "想起你薄荷味的笑",
      "translation": null
    },
    {
      "time": 20.51,
      "time_str": "00:20.510",
      "text": "那时你在操场上奔跑",
      "translation": null
    },
    {
      "time": 27.5,
      "time_str": "00:27.500",
      "text": "大声喊 我爱你你知不知道",
      "translation": null
    },
    {
      "time": 35.1,
      "time_str": "00:35.100",
      "text": "那时我们什么都不怕",
      "translation": null
    },
    {
      "time": 39.53,
      "time_str": "00:39.530",
      "text": "看咖啡色夕阳又要落下",
      "translation": null
    },
    {
