    {
      "time": 21.09,
      "time_str": "00:21.090",
      "text": "思念的滋味",
      "translation": null
    },
    {
      "time": 24.92,
      "time_str": "00:24.920",
      "text": "就像这杯苦咖啡",
      "translation": null
    },
    {
      "time": 28.98,
      "time_str": "00:28.980",
      "text": "虽然可以加点糖",
      "translation": null
    },
    {
      "time": 33.029,
      "time_str": "00:33.029",
      "text": "依然叫人心憔悴",
      "translation": null
    },
    {
      "time": 36.96,
      "time_str": "00:36.960",
      "text": "往事不可追",
      "translation": null
    },
    {
      "time": 40.87,
      "time_str": "00:40.870",
      "text": "回忆仿佛冷风吹",
      "translation": null
    },
    {
      "time": 44.97,
      "time_str": "00:44.970",
      "text": "当初都是我的错",
      "translation": null
    },
    {
      "time": 48.94,
      "time_str": "00:48.940",
      "text": "让你伤心头也不回",
      "translation": null
    },
    {
      "time": 52.93,
      "time_str": "00:52.930",
      "text": "现在我整夜后悔",
      "translation": null
    },
    {
      "time": 56.84,
      "time_str": "00:56.840",
      "text": "多盼望你能归",
      "translation": null
    },
    {
      "time": 60.88,
      "time_str": "01:00.880",
      "text": "未来没有你作陪",
      "translation": null
    },
    {
      "time": 64.88,
      "time_str": "01:04.880",
      "text": "我该怎样面对",
      "translation": null
    },
    {
      "time": 68.83,
      "time_str": "01:08.830",
      "text": "老天 请给我机会",
      "translation": null
    },
    {
      "time": 72.3,
      "time_str": "01:12.300",
      "text": "补偿心上人些许安慰",
