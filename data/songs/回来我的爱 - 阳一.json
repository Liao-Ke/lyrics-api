    },
    {
      "time": 76.81,
      "time_str": "01:16.810",
      "text": "如果 生命可以轮回",
      "translation": null
    },
    {
      "time": 80.8,
      "time_str": "01:20.800",
      "text": "我宁愿时光倒退",
      "translation": null
    },
    {
      "time": 84.76,
      "time_str": "01:24.760",
      "text": "明天 我还要受罪",
      "translation": null
    },
    {
      "time": 89.1,
      "time_str": "01:29.100",
      "text": "任凭心情被寂寞包围",
