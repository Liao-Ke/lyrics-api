      "translation": null
    },
    {
      "time": 163.38,
      "time_str": "02:43.380",
      "text": "我往前飞 飞过一片时间海",
      "translation": null
    },
    {
      "time": 168.298,
      "time_str": "02:48.298",
      "text": "我们也曾在爱情里受伤害",
      "translation": null
    },
    {
      "time": 173.689,
      "time_str": "02:53.689",
      "text": "我看着路 梦的入口有点窄",
      "translation": null
    },
    {
      "time": 178.748,
      "time_str": "02:58.748",
      "text": "我遇见你是最美丽的意外",
      "translation": null
    },
    {
      "time": 185.888,
      "time_str": "03:05.888",
      "text": "总有一天 我的谜底会揭开",
      "translation": null
