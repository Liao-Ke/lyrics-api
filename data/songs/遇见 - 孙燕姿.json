  "lyrics": [
    {
      "time": 24.898,
      "time_str": "00:24.898",
      "text": "听见 冬天的离开",
      "translation": null
    },
    {
      "time": 29.697,
      "time_str": "00:29.697",
      "text": "我在某年某月 醒过来",
      "translation": null
    },
    {
      "time": 34.768,
      "time_str": "00:34.768",
      "text": "我想 我等 我期待",
      "translation": null
    },
    {
      "time": 40.598,
      "time_str": "00:40.598",
      "text": "未来却不能因此安排",
      "translation": null
    },
    {
      "time": 53.398,
      "time_str": "00:53.398",
      "text": "阴天 傍晚 车窗外",
      "translation": null
    },
    {
      "time": 58.758,
      "time_str": "00:58.758",
      "text": "未来有一个人在等待",
      "translation": null
    },
    {
      "time": 64.298,
      "time_str": "01:04.298",
      "text": "向左向右向前看",
      "translation": null
    },
    {
      "time": 69.599,
      "time_str": "01:09.599",
      "text": "爱要拐几个弯才来",
      "translation": null
    },
    {
      "time": 74.369,
      "time_str": "01:14.369",
      "text": "我遇见谁 会有怎样的对白",
      "translation": null
    },
    {
      "time": 79.638,
      "time_str": "01:19.638",
      "text": "我等的人 他在多远的未来",
      "translation": null
    },
    {
      "time": 84.839,
      "time_str": "01:24.839",
      "text": "我听见风来自地铁和人海",
      "translation": null
    },
    {
      "time": 90.399,
      "time_str": "01:30.399",
      "text": "我排着队 拿着爱的号码牌",
      "translation": null
    },
    {
