  "lyrics": [
    {
      "time": 27.52,
      "time_str": "00:27.520",
      "text": "烽烟起寻爱似浪淘沙",
      "translation": null
    },
    {
      "time": 34.181,
      "time_str": "00:34.181",
      "text": "遇见她如春水映梨花",
      "translation": null
    },
    {
      "time": 40.947,
      "time_str": "00:40.947",
      "text": "挥剑断天涯相思轻放下",
      "translation": null
    },
    {
      "time": 47.686,
      "time_str": "00:47.686",
      "text": "梦中我痴痴牵挂",
      "translation": null
    },
    {
      "time": 54.766,
      "time_str": "00:54.766",
      "text": "顾不顾将相王侯",
      "translation": null
    },
    {
      "time": 56.176,
      "time_str": "00:56.176",
      "text": "管不管万世千秋",
      "translation": null
    },
    {
      "time": 57.953,
      "time_str": "00:57.953",
      "text": "求只求爱化解",
      "translation": null
    },
    {
      "time": 59.546,
      "time_str": "00:59.546",
      "text": "这万丈红尘纷乱永无休",
      "translation": null
    },
    {
      "time": 62.002,
      "time_str": "01:02.002",
      "text": "爱更爱天长地久",
      "translation": null
    },
    {
      "time": 63.778,
      "time_str": "01:03.778",
      "text": "要更要似水温柔",
      "translation": null
    },
    {
      "time": 65.45,
      "time_str": "01:05.450",
      "text": "谁在乎谁主春秋",
      "translation": null
    },
    {
      "time": 67.696,
      "time_str": "01:07.696",
      "text": "一生有爱何惧风飞沙",
      "translation": null
    },
    {
      "time": 70.805,
      "time_str": "01:10.805",
      "text": "悲白发留不住芳华",
      "translation": null
    },
    {
      "time": 74.645,
      "time_str": "01:14.645",
      "text": "抛去江山如画换她笑面如花",
      "translation": null
    },
    {
      "time": 77.832,
      "time_str": "01:17.832",
      "text": "抵过这一生空牵挂",
      "translation": null
    },
    {
      "time": 81.097,
      "time_str": "01:21.097",
      "text": "心若无怨爱恨也随她",
      "translation": null
    },
    {
      "time": 84.101,
      "time_str": "01:24.101",
      "text": "天地大情路永无涯",
      "translation": null
    },
    {
      "time": 87.68,
      "time_str": "01:27.680",
      "text": "只为她袖手天下",
      "translation": null
    },
    {
