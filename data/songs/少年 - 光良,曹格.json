  "lyrics": [
    {
      "time": 21.12,
      "time_str": "00:21.120",
      "text": "你又想起某个夏天 热闹海岸线",
      "translation": null
    },
    {
      "time": 30.61,
      "time_str": "00:30.610",
      "text": "记忆中的那个少年 骄傲的宣言",
      "translation": null
    },
    {
      "time": 40.17,
      "time_str": "00:40.170",
      "text": "伸出双手就能 拥抱全世界",
      "translation": null
    },
    {
      "time": 45.92,
      "time_str": "00:45.920",
      "text": "相信所有的梦想 一定会实现",
      "translation": null
    },
    {
      "time": 50.56,
      "time_str": "00:50.560",
      "text": "一切看起来 都不会太遥远",
      "translation": null
    },
    {
      "time": 54.83,
      "time_str": "00:54.830",
      "text": "转眼之间 过了几年",
      "translation": null
    },
    {
      "time": 60.0,
      "time_str": "01:00.000",
      "text": "轻浮的语言 都已慢慢沉淀",
      "translation": null
    },
    {
      "time": 64.69,
      "time_str": "01:04.690",
      "text": "即使难免会 变得更加洗炼",
      "translation": null
    },
    {
      "time": 68.71,
      "time_str": "01:08.710",
      "text": "我们 不曾妥协",
      "translation": null
    },
    {
      "time": 78.13,
      "time_str": "01:18.130",
      "text": "那是我们 都回不去的从前",
      "translation": null
    },
    {
      "time": 83.47,
      "time_str": "01:23.470",
      "text": "幸好还可以 坚持当时的信念",
      "translation": null
    },
    {
      "time": 88.38,
      "time_str": "01:28.380",
      "text": "世界尝试改变 当初的那个少年",
      "translation": null
    },
    {
      "time": 97.36,
      "time_str": "01:37.360",
      "text": "那是我们 都回不去的从前",
      "translation": null
    },
    {
      "time": 102.43,
      "time_str": "01:42.430",
      "text": "当你站在 那个夏天的海岸线",
      "translation": null
    },
    {
      "time": 107.37,
      "time_str": "01:47.370",
      "text": "我们还是心里面 那个偏执的少年",
