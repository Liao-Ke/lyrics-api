    {
      "time": 39.0,
      "time_str": "00:39.000",
      "text": "柔情似水爱共永",
      "translation": null
    },
    {
      "time": 46.5,
      "time_str": "00:46.500",
      "text": "未怕罡风吹散了热爱",
      "translation": null
    },
    {
      "time": 55.0,
      "time_str": "00:55.000",
      "text": "万水千山总是情",
      "translation": null
    },
    {
      "time": 63.0,
      "time_str": "01:03.000",
      "text": "聚散也有天注定",
