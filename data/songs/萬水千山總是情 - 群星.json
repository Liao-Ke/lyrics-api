      "time_str": "00:14.000",
      "text": "莫说青山多障碍",
      "translation": null
    },
    {
      "time": 19.0,
      "time_str": "00:19.000",
      "text": "风也急风也劲",
      "translation": null
    },
    {
      "time": 24.0,
      "time_str": "00:24.000",
      "text": "白云过山峰也可传情",
      "translation": null
    },
    {
      "time": 31.0,
      "time_str": "00:31.000",
      "text": "莫说水中多变幻",
      "translation": null
