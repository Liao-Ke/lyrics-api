  "lyrics": [
    {
      "time": 31.18,
      "time_str": "00:31.180",
      "text": "当你边飞边流下泪滴",
      "translation": null
    },
    {
      "time": 34.78,
      "time_str": "00:34.780",
      "text": "我不认为谁已变了心",
      "translation": null
    },
    {
      "time": 38.45,
      "time_str": "00:38.450",
      "text": "你不过是累了去旅行",
      "translation": null
    },
    {
      "time": 41.94,
      "time_str": "00:41.940",
      "text": "而我是家永远会等你",
      "translation": null
    },
    {
      "time": 45.78,
      "time_str": "00:45.780",
      "text": "听说你的爱碰上雨季",
      "translation": null
    },
    {
      "time": 49.47,
      "time_str": "00:49.470",
      "text": "又湿又冷生了一场病",
      "translation": null
    },
    {
      "time": 52.95,
      "time_str": "00:52.950",
      "text": "心疼的我想给你暖意",
      "translation": null
    },
    {
      "time": 56.83,
      "time_str": "00:56.830",
      "text": "倔强的你不让我走近",
      "translation": null
    },
    {
      "time": 62.09,
      "time_str": "01:02.090",
      "text": "月光在你眼里",
      "translation": null
    },
    {
      "time": 66.16,
      "time_str": "01:06.160",
      "text": "你说你没资格",
      "translation": null
    },
    {
      "time": 68.99,
      "time_str": "01:08.990",
      "text": "让我呵护痛惜",
      "translation": null
    },
    {
      "time": 74.29,
      "time_str": "01:14.290",
      "text": "就算我真能抛弃一切",
      "translation": null
    },
    {
      "time": 77.89,
      "time_str": "01:17.890",
      "text": "你又怎么去战胜自己",
      "translation": null
    },
    {
      "time": 82.83,
      "time_str": "01:22.830",
      "text": "不顾一切的爱才算是爱",
      "translation": null
    },
    {
      "time": 86.43,
      "time_str": "01:26.430",
      "text": "从来没有感慨一路走来",
      "translation": null
    },
    {
      "time": 90.24,
      "time_str": "01:30.240",
      "text": "不记得悲哀",
      "translation": null
    },
    {
      "time": 91.92,
      "time_str": "01:31.920",
      "text": "只记得愉快",
      "translation": null
    },
    {
      "time": 93.9,
      "time_str": "01:33.900",
      "text": "总想为你实现你的期待",
      "translation": null
    },
    {
      "time": 97.57,
      "time_str": "01:37.570",
      "text": "不顾一切的爱无可取代",
      "translation": null
    },
    {
      "time": 101.1,
      "time_str": "01:41.100",
      "text": "所受的伤害都像是告白",
      "translation": null
    },
    {
      "time": 105.78,
      "time_str": "01:45.780",
      "text": "我不走开",
      "translation": null
    },
    {
      "time": 107.54,
      "time_str": "01:47.540",
      "text": "等你随时再回来",
      "translation": null
    },
    {
