  "lyrics": [
    {
      "time": 20.23,
      "time_str": "00:20.230",
      "text": "一直以为自己可以很坚强",
      "translation": null
    },
    {
      "time": 26.86,
      "time_str": "00:26.860",
      "text": "原来和你一样害怕着孤单",
      "translation": null
    },
    {
      "time": 33.84,
      "time_str": "00:33.840",
      "text": "没有你的夜晚",
      "translation": null
    },
    {
      "time": 37.87,
      "time_str": "00:37.870",
      "text": "星星和我一样彷徨",
      "translation": null
    },
    {
      "time": 42.14,
      "time_str": "00:42.140",
      "text": "挂在天上 忽明又忽暗",
      "translation": null
    },
    {
      "time": 49.87,
      "time_str": "00:49.870",
      "text": "不知不觉窗外的天已变亮",
      "translation": null
    },
    {
      "time": 57.19,
      "time_str": "00:57.190",
      "text": "原来醒的时间越来越长",
      "translation": null
    },
    {
      "time": 65.04,
      "time_str": "01:05.040",
      "text": "没有你的异乡",
      "translation": null
    },
    {
      "time": 68.69,
      "time_str": "01:08.690",
      "text": "只有冷风陪我流浪",
      "translation": null
    },
    {
      "time": 72.73,
      "time_str": "01:12.730",
      "text": "我怕我的思念",
      "translation": null
    },
    {
      "time": 75.24,
      "time_str": "01:15.240",
      "text": "游不过这片海洋",
      "translation": null
    },
    {
      "time": 80.49,
      "time_str": "01:20.490",
      "text": "别对我说永远 永远 永远",
      "translation": null
    },
    {
      "time": 84.36,
      "time_str": "01:24.360",
      "text": "永远是太昂贵的誓言",
      "translation": null
    },
    {
      "time": 88.13,
      "time_str": "01:28.130",
      "text": "我握不住也看不见",
      "translation": null
    },
    {
      "time": 92.19,
      "time_str": "01:32.190",
      "text": "最后随着浪涛消失不见",
      "translation": null
    },
    {
      "time": 96.2,
      "time_str": "01:36.200",
      "text": "别对我说永远 永远 永远",
      "translation": null
    },
    {
      "time": 99.66,
      "time_str": "01:39.660",
      "text": "永远不是我要的明天",
      "translation": null
    },
    {
      "time": 103.4,
      "time_str": "01:43.400",
      "text": "你爱过我就已足够",
      "translation": null
    },
    {
      "time": 107.73,
      "time_str": "01:47.730",
      "text": "就算到了最后爱已搁浅",
      "translation": null
    },
    {
      "time": 111.44,
      "time_str": "01:51.440",
      "text": "只求你留我在你心田",
      "translation": null
    },
