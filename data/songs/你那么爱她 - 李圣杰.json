    {
      "time": 35.45,
      "time_str": "00:35.450",
      "text": "直到爱消失 你才懂得",
      "translation": null
    },
    {
      "time": 39.93,
      "time_str": "00:39.930",
      "text": "去珍惜身边每个 美好风景",
      "translation": null
    },
    {
      "time": 45.99,
      "time_str": "00:45.990",
      "text": "只是她早已离去",
      "translation": null
    },
    {
      "time": 51.39,
      "time_str": "00:51.390",
      "text": "直到你想通 她早已经",
      "translation": null
    },
    {
      "time": 56.0,
      "time_str": "00:56.000",
      "text": "不再对你留恋",
      "translation": null
    },
    {
      "time": 59.93,
      "time_str": "00:59.930",
      "text": "最后的你 开始了一段挣扎",
      "translation": null
    },
    {
      "time": 67.21,
      "time_str": "01:07.210",
      "text": "你那么爱她",
      "translation": null
    },
    {
      "time": 69.51,
      "time_str": "01:09.510",
      "text": "为什么不把她留下",
      "translation": null
    },
    {
      "time": 73.48,
