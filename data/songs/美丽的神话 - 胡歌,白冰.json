  "lyrics": [
    {
      "time": 21.0,
      "time_str": "00:21.000",
      "text": "【胡】解开我最神秘的等待",
      "translation": null
    },
    {
      "time": 28.68,
      "time_str": "00:28.680",
      "text": "星星坠落风在吹动",
      "translation": null
    },
    {
      "time": 36.15,
      "time_str": "00:36.150",
      "text": "终于再将你拥入怀中",
      "translation": null
    },
    {
      "time": 43.79,
      "time_str": "00:43.790",
      "text": "两颗心颤抖",
      "translation": null
    },
    {
      "time": 51.29,
      "time_str": "00:51.290",
      "text": "相信我不变的真心",
      "translation": null
    },
    {
      "time": 58.89,
      "time_str": "00:58.890",
      "text": "千年等待有我承诺",
      "translation": null
    },
    {
      "time": 66.59,
      "time_str": "01:06.590",
      "text": "无论经过多少的寒冬",
      "translation": null
    },
    {
      "time": 74.34,
      "time_str": "01:14.340",
      "text": "我决不放手",
      "translation": null
    },
    {
      "time": 80.9,
      "time_str": "01:20.900",
      "text": "【白】紧紧久久与我牵绊",
      "translation": null
    },
    {
      "time": 85.64,
      "time_str": "01:25.640",
      "text": "这副十指扣",
      "translation": null
    },
    {
      "time": 88.44,
      "time_str": "01:28.440",
      "text": "等到来生擦肩回眸 再次的相守",
      "translation": null
    },
    {
      "time": 96.27,
      "time_str": "01:36.270",
      "text": "苦苦痛痛爱的解救 愿与你同受",
      "translation": null
    },
    {
      "time": 103.82,
      "time_str": "01:43.820",
      "text": "却连一句我爱你都 不能说出口",
      "translation": null
    },
    {
      "time": 127.52,
      "time_str": "02:07.520",
      "text": "【胡】每一夜被心痛穿越",
      "translation": null
    },
    {
      "time": 135.17,
      "time_str": "02:15.170",
      "text": "思念永没有终点",
      "translation": null
    },
    {
      "time": 142.8,
      "time_str": "02:22.800",
      "text": "早习惯了孤独相随",
      "translation": null
    },
    {
      "time": 150.4,
      "time_str": "02:30.400",
      "text": "我微笑面对",
      "translation": null
    },
    {
      "time": 158.06,
      "time_str": "02:38.060",
      "text": "相信我你选择等待",
      "translation": null
    },
    {
      "time": 165.7,
      "time_str": "02:45.700",
      "text": "再多苦痛也不闪躲",
      "translation": null
    },
    {
      "time": 173.28,
      "time_str": "02:53.280",
      "text": "只有你的温柔能解救",
      "translation": null
    },
    {
      "time": 180.83,
      "time_str": "03:00.830",
      "text": "无边的冷漠",
      "translation": null
    },
    {
      "time": 187.51,
      "time_str": "03:07.510",
      "text": "【白】紧紧久久与我牵绊",
      "translation": null
    },
    {
      "time": 192.19,
      "time_str": "03:12.190",
      "text": "这副十指扣",
      "translation": null
    },
    {
      "time": 195.04,
      "time_str": "03:15.040",
      "text": "等到来生擦肩回眸 再次的相守",
      "translation": null
    },
    {
      "time": 202.65,
      "time_str": "03:22.650",
      "text": "苦苦痛痛爱的解救 愿与你同受",
      "translation": null
    },
    {
      "time": 210.24,
      "time_str": "03:30.240",
      "text": "却连一句我爱你都 不能说出口",
      "translation": null
    },
    {
      "time": 217.84,
      "time_str": "03:37.840",
      "text": "【合】让爱成为你我心中",
      "translation": null
    },
    {
      "time": 222.61,
      "time_str": "03:42.610",
      "text": "那永远盛开的花",
      "translation": null
    },
    {
      "time": 225.41,
      "time_str": "03:45.410",
      "text": "穿越时空决不低头永不放弃的梦",
      "translation": null
    },
    {
      "time": 233.01,
      "time_str": "03:53.010",
      "text": "【白】苦苦痛痛爱的解救",
      "translation": null
    },
    {
