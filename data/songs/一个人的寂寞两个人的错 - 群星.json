    },
    {
      "time": 51.72,
      "time_str": "00:51.720",
      "text": "相信真爱天长地久",
      "translation": null
    },
    {
      "time": 55.49,
      "time_str": "00:55.490",
      "text": "到最后却一无所有",
      "translation": null
    },
