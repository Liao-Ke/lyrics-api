  "lyrics": [
    {
      "time": 23.75,
      "time_str": "00:23.750",
      "text": "明天我们暂时要分离 电话中你不舍的语气",
      "translation": null
    },
    {
      "time": 34.7,
      "time_str": "00:34.700",
      "text": "你说可不可以 放你的心在行李",
      "translation": null
    },
    {
      "time": 41.1,
      "time_str": "00:41.100",
      "text": "跟着我飞行 我们就可以永远不分离",
      "translation": null
    },
    {
      "time": 49.19,
      "time_str": "00:49.190",
      "text": "每天要听一次我爱你 你说这样会感觉贴心",
      "translation": null
    },
    {
      "time": 60.63,
      "time_str": "01:00.630",
      "text": "如果说我离去 你的心会下起雨",
      "translation": null
    },
    {
      "time": 67.7,
      "time_str": "01:07.700",
      "text": "满天是乌云 整个世界少了空气",
      "translation": null
    },
    {
      "time": 74.98,
      "time_str": "01:14.980",
      "text": "把你抱在怀里 我们没有言语",
      "translation": null
    },
    {
      "time": 81.19,
      "time_str": "01:21.190",
      "text": "感觉离别前两颗心在一起",
      "translation": null
    },
    {
      "time": 87.8,
      "time_str": "01:27.800",
      "text": "我们抱在怀里 我们不想言语",
      "translation": null
    },
    {
      "time": 94.229,
      "time_str": "01:34.229",
      "text": "今天以后留下回忆 我们可以温习",
      "translation": null
    },
    {
      "time": 101.11,
      "time_str": "01:41.110",
      "text": "我爱你 不言语 这一刻天在哭泣",
      "translation": null
    },
    {
      "time": 114.759,
      "time_str": "01:54.759",
      "text": "离别那天你为我送行 说好我们不难过伤心",
      "translation": null
    },
    {
      "time": 125.42,
      "time_str": "02:05.420",
      "text": "我说可不可以 一路握你的手心",
      "translation": null
    },
    {
      "time": 130.99,
      "time_str": "02:10.990",
      "text": "放在我怀里 这样才能感觉你的呼吸",
      "translation": null
    },
    {
      "time": 139.47,
      "time_str": "02:19.470",
      "text": "站在离境门前看着你 脸上你舍不得的表情",
      "translation": null
    },
    {
      "time": 150.59,
      "time_str": "02:30.590",
      "text": "如果说我可以 用全宇宙的魔力",
      "translation": null
    },
    {
