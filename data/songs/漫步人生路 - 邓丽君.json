  "lyrics": [
    {
      "time": 3.0,
      "time_str": "00:03.000",
      "text": "Publisher : Yamaha Ms Foundation (EMI)",
      "translation": null
    },
    {
      "time": 25.9,
      "time_str": "00:25.900",
      "text": "在你身边路虽远未疲倦",
      "translation": null
    },
    {
      "time": 30.849,
      "time_str": "00:30.849",
      "text": "伴你漫行一段接一段",
      "translation": null
    },
    {
      "time": 36.518,
      "time_str": "00:36.518",
      "text": "越过高峰另一峰却又见",
      "translation": null
    },
    {
      "time": 41.511,
      "time_str": "00:41.511",
      "text": "目标推远 让理想永远在前面",
      "translation": null
    },
    {
      "time": 47.17,
      "time_str": "00:47.170",
      "text": "路纵崎岖亦不怕受磨练",
      "translation": null
    },
    {
      "time": 52.173,
      "time_str": "00:52.173",
      "text": "愿一生中苦痛快乐也体验",
      "translation": null
    },
    {
      "time": 57.864,
      "time_str": "00:57.864",
      "text": "愉快悲哀在身边转又转",
      "translation": null
    },
    {
      "time": 62.814,
      "time_str": "01:02.814",
      "text": "风中赏雪 雾里赏花 快乐回旋",
      "translation": null
    },
    {
      "time": 67.919,
      "time_str": "01:07.919",
      "text": "毋用计较 快欣赏身边美丽每一天",
      "translation": null
    },
    {
      "time": 73.161,
      "time_str": "01:13.161",
      "text": "还愿确信美景良辰在脚边",
      "translation": null
    },
    {
      "time": 78.807,
      "time_str": "01:18.807",
      "text": "愿将欢笑声盖掩苦痛那一面",
      "translation": null
    },
    {
      "time": 83.883,
      "time_str": "01:23.883",
      "text": "悲也好 喜也好",
      "translation": null
    },
    {
      "time": 86.494,
      "time_str": "01:26.494",
      "text": "每天找到新发现",
      "translation": null
    },
    {
      "time": 89.159,
      "time_str": "01:29.159",
      "text": "让疾风吹呀吹",
      "translation": null
    },
    {
      "time": 91.824,
      "time_str": "01:31.824",
      "text": "尽管给我俩考验",
      "translation": null
    },
    {
      "time": 94.522,
      "time_str": "01:34.522",
      "text": "小雨点 放心洒",
      "translation": null
    },
    {
      "time": 97.205,
      "time_str": "01:37.205",
      "text": "早已决心向着前",
      "translation": null
    },
    {
