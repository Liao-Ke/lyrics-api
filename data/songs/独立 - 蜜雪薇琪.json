    {
      "time": 12.28,
      "time_str": "00:12.280",
      "text": "谁会先知道 可能会有多少",
      "translation": null
    },
    {
      "time": 17.97,
      "time_str": "00:17.970",
      "text": "去掉一半的自己",
      "translation": null
    },
    {
      "time": 20.6,
      "time_str": "00:20.600",
      "text": "然后互相撞击",
      "translation": null
    },
    {
      "time": 23.64,
      "time_str": "00:23.640",
      "text": "没想到更好 我有双份的我",
      "translation": null
    },
    {
      "time": 28.34,
      "time_str": "00:28.340",
      "text": "欣赏你赞美我 挑战你解决我",
      "translation": null
    },
    {
      "time": 31.22,
      "time_str": "00:31.220",
      "text": "交手中 看到真正的我",
      "translation": null
    },
    {
      "time": 34.49,
      "time_str": "00:34.490",
      "text": "爱 让我聪明的独立",
      "translation": null
    },
    {
      "time": 37.87,
      "time_str": "00:37.870",
      "text": "用自己 去爱人",
      "translation": null
    },
    {
      "time": 40.65,
      "time_str": "00:40.650",
      "text": "搞定想要的东西",
      "translation": null
    },
    {
      "time": 43.63,
      "time_str": "00:43.630",
      "text": "有一半已经成立",
      "translation": null
    },
    {
      "time": 46.54,
      "time_str": "00:46.540",
      "text": "准备随时能独立",
      "translation": null
    },
    {
      "time": 49.25,
      "time_str": "00:49.250",
      "text": "不贪心 不委屈",
      "translation": null
    },
    {
      "time": 52.2,
      "time_str": "00:52.200",
      "text": "勇闯每一个遭遇",
      "translation": null
    },
    {
      "time": 54.99,
      "time_str": "00:54.990",
      "text": "都跟自己有关系",
      "translation": null
    },
    {
      "time": 69.48,
      "time_str": "01:09.480",
      "text": "道理这么说 人要学着独立",
      "translation": null
    },
    {
