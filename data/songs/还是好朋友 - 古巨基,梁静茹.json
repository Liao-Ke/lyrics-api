    {
      "time": 40.599,
      "time_str": "00:40.599",
      "text": "没有人要内疚 没需要缘由",
      "translation": null
    },
    {
      "time": 49.729,
      "time_str": "00:49.729",
      "text": "在十字街头 就相互保佑",
      "translation": null
    },
    {
      "time": 58.307,
      "time_str": "00:58.307",
      "text": "那些体贴问候 那美丽镜头",
      "translation": null
    },
    {
      "time": 65.033,
      "time_str": "01:05.033",
      "text": "没必要一分开就变成了诅咒",
      "translation": null
    },
    {
      "time": 72.893,
      "time_str": "01:12.893",
      "text": "相爱这一场",
      "translation": null
    },
    {
      "time": 75.091,
      "time_str": "01:15.091",
      "text": "可能是为了",
      "translation": null
    },
    {
      "time": 76.793,
      "time_str": "01:16.793",
      "text": "能拥有一个好朋友",
      "translation": null
    },
    {
      "time": 83.223,
      "time_str": "01:23.223",
      "text": "还是好朋友 比爱人长久",
      "translation": null
    },
    {
      "time": 87.412,
      "time_str": "01:27.412",
      "text": "不能牵的手按在心头",
      "translation": null
    },
    {
      "time": 90.293,
      "time_str": "01:30.293",
      "text": "在最寂寞的关头 永远在左右",
      "translation": null
    },
    {
      "time": 98.884,
      "time_str": "01:38.884",
      "text": "事过情迁后",
      "translation": null
    },
    {
      "time": 100.985,
      "time_str": "01:40.985",
      "text": "（升华以后）升华眼泪后",
      "translation": null
    },
    {
      "time": 103.134,
      "time_str": "01:43.134",
      "text": "思念是最漫长的享受",
      "translation": null
    },
    {
      "time": 107.274,
      "time_str": "01:47.274",
      "text": "（漫长的享受）",
      "translation": null
    },
    {
      "time": 108.553,
      "time_str": "01:48.553",
      "text": "那无痛的伤口 还带着温柔到白头",
      "translation": null
    },
    {
