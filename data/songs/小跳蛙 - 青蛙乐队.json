    {
      "time": 14.81,
      "time_str": "00:14.810",
      "text": "快乐池塘栽种了 梦想就变成海洋",
      "translation": null
    },
    {
      "time": 18.73,
      "time_str": "00:18.730",
      "text": "鼓的眼睛大嘴巴 同样唱的响亮",
      "translation": null
    },
    {
      "time": 22.82,
      "time_str": "00:22.820",
      "text": "借我一双小翅膀 就能飞向太阳",
      "translation": null
    },
    {
      "time": 26.76,
      "time_str": "00:26.760",
      "text": "我相信 奇迹就在身上",
      "translation": null
    },
    {
      "time": 31.05,
      "time_str": "00:31.050",
      "text": "啦......",
      "translation": null
    },
    {
      "time": 36.94,
      "time_str": "00:36.940",
      "text": "有你相伴 leap frog",
      "translation": null
    },
    {
      "time": 38.71,
