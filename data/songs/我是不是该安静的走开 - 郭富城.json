  "lyrics": [
    {
      "time": 19.76,
      "time_str": "00:19.760",
      "text": "我不知道为什么这样",
      "translation": null
    },
    {
      "time": 24.4,
      "time_str": "00:24.400",
      "text": "爱情不是我想像",
      "translation": null
    },
    {
      "time": 29.07,
      "time_str": "00:29.070",
      "text": "就是找不到往你的方向",
      "translation": null
    },
    {
      "time": 34.75,
      "time_str": "00:34.750",
      "text": "更别说怎么遗忘",
      "translation": null
    },
    {
      "time": 38.94,
      "time_str": "00:38.940",
      "text": "站在雨里泪水在眼底",
      "translation": null
    },
    {
      "time": 43.63,
      "time_str": "00:43.630",
      "text": "不知该往哪里去",
      "translation": null
    },
    {
      "time": 48.68,
      "time_str": "00:48.680",
      "text": "心中千万遍不停呼唤你",
      "translation": null
    },
    {
      "time": 54.12,
      "time_str": "00:54.120",
      "text": "不停疯狂找寻你",
      "translation": null
    },
    {
      "time": 58.92,
      "time_str": "00:58.920",
      "text": "我是不是该安静的走开",
      "translation": null
    },
    {
      "time": 63.03,
      "time_str": "01:03.030",
      "text": "还是该勇敢留下来",
      "translation": null
    },
    {
      "time": 68.66,
      "time_str": "01:08.660",
      "text": "我也不知道那么多无奈",
      "translation": null
    },
    {
      "time": 73.69,
      "time_str": "01:13.690",
      "text": "可不可以都重来",
      "translation": null
    },
    {
      "time": 78.35,
      "time_str": "01:18.350",
      "text": "我是不是该安静的走开",
      "translation": null
    },
    {
      "time": 82.39,
      "time_str": "01:22.390",
      "text": "还是该在这里等待",
      "translation": null
    },
    {
      "time": 87.55,
      "time_str": "01:27.550",
      "text": "等你明白我给你的爱",
      "translation": null
    },
    {
      "time": 94.43,
      "time_str": "01:34.430",
      "text": "永远都不能走开",
      "translation": null
    },
