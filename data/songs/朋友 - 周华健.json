    {
      "time": 38.7,
      "time_str": "00:38.700",
      "text": "这些年 一个人",
      "translation": null
    },
    {
      "time": 42.235,
      "time_str": "00:42.235",
      "text": "风也过 雨也走",
      "translation": null
    },
    {
      "time": 45.687,
      "time_str": "00:45.687",
      "text": "有过泪 有过错",
      "translation": null
    },
    {
      "time": 49.17,
      "time_str": "00:49.170",
      "text": "还记得坚持什么",
      "translation": null
    },
    {
      "time": 52.645,
      "time_str": "00:52.645",
      "text": "真爱过 才会懂",
      "translation": null
    },
    {
      "time": 56.158,
      "time_str": "00:56.158",
      "text": "会寂寞 会回首",
      "translation": null
    },
    {
      "time": 59.571,
      "time_str": "00:59.571",
      "text": "终有梦 终有你 在心中",
      "translation": null
    },
    {
      "time": 66.566,
      "time_str": "01:06.566",
      "text": "朋友 一生一起走",
      "translation": null
    },
    {
      "time": 70.023,
      "time_str": "01:10.023",
      "text": "那些日子 不再有",
      "translation": null
    },
    {
      "time": 73.498,
      "time_str": "01:13.498",
      "text": "一句话 一辈子",
      "translation": null
    },
    {
      "time": 77.014,
      "time_str": "01:17.014",
      "text": "一生情 一杯酒",
      "translation": null
    },
    {
      "time": 80.434,
      "time_str": "01:20.434",
      "text": "朋友 不曾孤单过",
      "translation": null
    },
    {
      "time": 83.976,
      "time_str": "01:23.976",
      "text": "一声朋友 你会懂",
      "translation": null
    },
    {
      "time": 87.398,
      "time_str": "01:27.398",
      "text": "还有伤 还有痛",
