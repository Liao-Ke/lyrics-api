    "arranger": "Adam Lee"
  },
  "lyrics": [
    {
      "time": 25.5,
      "time_str": "00:25.500",
      "text": "心很空 天很大 云很重",
      "translation": null
    },
    {
      "time": 29.3,
      "time_str": "00:29.300",
      "text": "我恨孤单 却赶不走",
      "translation": null
    },
    {
      "time": 35.269,
      "time_str": "00:35.269",
      "text": "捧着她的名字",
      "translation": null
    },
    {
      "time": 40.09,
      "time_str": "00:40.090",
      "text": "她的喜怒哀乐",
      "translation": null
    },
    {
      "time": 42.239,
      "time_str": "00:42.239",
      "text": "往前走 多久了",
      "translation": null
    },
    {
      "time": 48.79,
      "time_str": "00:48.790",
      "text": "一个人心中",
      "translation": null
    },
    {
      "time": 50.979,
      "time_str": "00:50.979",
      "text": "只有一个宝贝",
      "translation": null
    },
    {
      "time": 53.559,
      "time_str": "00:53.559",
      "text": "久了之后",
      "translation": null
    },
    {
      "time": 55.439,
      "time_str": "00:55.439",
      "text": "她变成了眼泪",
      "translation": null
    },
    {
      "time": 60.919,
      "time_str": "01:00.919",
      "text": "泪一滴在左手",
      "translation": null
    },
    {
      "time": 63.999,
      "time_str": "01:03.999",
      "text": "凝固成为寂寞",
      "translation": null
    },
    {
      "time": 66.599,
      "time_str": "01:06.599",
      "text": "往回看 有什么",
      "translation": null
    },
    {
      "time": 70.519,
      "time_str": "01:10.519",
      "text": "那女孩对我说",
      "translation": null
    },
    {
      "time": 72.979,
      "time_str": "01:12.979",
      "text": "说我保护她的梦",
      "translation": null
    },
    {
      "time": 76.169,
      "time_str": "01:16.169",
      "text": "说这个世界",
      "translation": null
    },
    {
      "time": 79.049,
      "time_str": "01:19.049",
      "text": "对她这样的不多",
      "translation": null
    },
    {
      "time": 82.849,
      "time_str": "01:22.849",
      "text": "她渐渐忘了我",
      "translation": null
    },
    {
      "time": 85.269,
      "time_str": "01:25.269",
      "text": "但是她并不晓得",
      "translation": null
    },
    {
      "time": 88.729,
      "time_str": "01:28.729",
      "text": "遍体鳞伤的我",
      "translation": null
    },
    {
      "time": 91.288,
      "time_str": "01:31.288",
      "text": "一天也没再爱过",
      "translation": null
    },
    {
      "time": 94.709,
      "time_str": "01:34.709",
      "text": "那女孩对我说",
      "translation": null
    },
    {
      "time": 97.288,
      "time_str": "01:37.288",
      "text": "说我是一个小偷",
      "translation": null
    },
    {
      "time": 100.839,
      "time_str": "01:40.839",
      "text": "偷她的回忆",
      "translation": null
    },
    {
      "time": 103.279,
      "time_str": "01:43.279",
      "text": "塞进我的脑海中",
      "translation": null
    },
    {
      "time": 106.769,
      "time_str": "01:46.769",
      "text": "我不需要自由",
      "translation": null
    },
    {
      "time": 109.319,
      "time_str": "01:49.319",
      "text": "只想背着她的梦",
      "translation": null
    },
    {
      "time": 112.749,
      "time_str": "01:52.749",
      "text": "一步步向前走",
      "translation": null
    },
    {
      "time": 115.288,
      "time_str": "01:55.288",
      "text": "她给的永远 不重",
      "translation": null
    },
    {
