  "lyrics": [
    {
      "time": 7.0,
      "time_str": "00:07.000",
      "text": "Bass：陈任佑",
      "translation": null
    },
    {
      "time": 11.0,
      "time_str": "00:11.000",
      "text": "录音助理：刘勇志",
      "translation": null
    },
    {
      "time": 19.51,
      "time_str": "00:19.510",
      "text": "亲爱的总有些事没办法教",
      "translation": null
    },
    {
      "time": 23.07,
      "time_str": "00:23.070",
      "text": "表错情的感觉有一点糟",
      "translation": null
    },
    {
      "time": 26.41,
      "time_str": "00:26.410",
      "text": "赖着不走会让人很感冒",
      "translation": null
    },
    {
      "time": 29.39,
      "time_str": "00:29.390",
      "text": "以上这道理我全都了",
      "translation": null
    },
    {
      "time": 32.53,
      "time_str": "00:32.530",
      "text": "我将不该犯的错都默背好",
      "translation": null
    },
    {
      "time": 35.86,
      "time_str": "00:35.860",
      "text": "仔细观察她的喜好",
      "translation": null
    },
    {
      "time": 39.26,
      "time_str": "00:39.260",
      "text": "而我紧绷的外表",
      "translation": null
    },
    {
      "time": 40.75,
      "time_str": "00:40.750",
      "text": "像上紧后的发条",
      "translation": null
    },
    {
      "time": 42.33,
      "time_str": "00:42.330",
      "text": "等她的答案揭晓",
      "translation": null
    },
    {
      "time": 45.32,
      "time_str": "00:45.320",
      "text": "她的睫毛 弯的嘴角",
      "translation": null
    },
    {
      "time": 48.49,
      "time_str": "00:48.490",
      "text": "无预警地对我笑",
      "translation": null
    },
    {
      "time": 51.67,
      "time_str": "00:51.670",
      "text": "没有预兆出乎预料",
      "translation": null
    },
    {
      "time": 54.83,
      "time_str": "00:54.830",
      "text": "竟然先对我示好",
      "translation": null
    },
    {
      "time": 57.94,
      "time_str": "00:57.940",
      "text": "她的睫毛弯的嘴角",
      "translation": null
    },
    {
      "time": 61.16,
      "time_str": "01:01.160",
      "text": "用眼神对我拍照",
      "translation": null
    },
    {
      "time": 64.31,
      "time_str": "01:04.310",
      "text": "我戒不掉她的微笑",
      "translation": null
    },
    {
      "time": 67.42,
      "time_str": "01:07.420",
      "text": "洋溢幸福的味道",
      "translation": null
    },
    {
      "time": 70.77,
      "time_str": "01:10.770",
      "text": "有些事没办法教",
      "translation": null
    },
    {
      "time": 73.5,
      "time_str": "01:13.500",
      "text": "表错情的感觉有一点糟",
      "translation": null
    },
    {
      "time": 76.9,
      "time_str": "01:16.900",
      "text": "赖着不走会让人很感冒",
      "translation": null
    },
    {
      "time": 79.84,
      "time_str": "01:19.840",
      "text": "以上这道理我全都了",
      "translation": null
    },
    {
      "time": 83.11,
      "time_str": "01:23.110",
      "text": "恋爱的方式无法拿笔来抄",
      "translation": null
    },
    {
      "time": 86.15,
      "time_str": "01:26.150",
      "text": "也没有规则可以取巧",
      "translation": null
    },
    {
      "time": 89.66,
      "time_str": "01:29.660",
      "text": "被动的缘分很不可靠",
      "translation": null
    },
    {
      "time": 92.61,
      "time_str": "01:32.610",
      "text": "喜欢的对象要自己挑",
      "translation": null
    },
    {
      "time": 95.84,
      "time_str": "01:35.840",
      "text": "她粉嫩清秀的外表",
      "translation": null
    },
    {
      "time": 98.37,
      "time_str": "01:38.370",
      "text": "像是多汁的水蜜桃谁都想咬",
      "translation": null
    },
    {
      "time": 102.2,
      "time_str": "01:42.200",
      "text": "她嘴上亮丽的唇膏",
      "translation": null
    },
    {
      "time": 104.74,
      "time_str": "01:44.740",
      "text": "有一股自信的骄傲我看得到",
      "translation": null
    },
