    },
    {
      "time": 32.48,
      "time_str": "00:32.480",
      "text": "清晨我站在青青的牧场",
      "translation": null
    },
    {
      "time": 39.82,
      "time_str": "00:39.820",
      "text": "看到神鹰披着那霞光",
      "translation": null
    },
    {
      "time": 47.36,
      "time_str": "00:47.360",
      "text": "象一片祥云飞过蓝天",
      "translation": null
    },
    {
      "time": 54.88,
      "time_str": "00:54.880",
      "text": "为藏家儿女带来吉祥",
      "translation": null
    },
    {
      "time": 70.34,
      "time_str": "01:10.340",
      "text": "黄昏我站在高高的山岗",
      "translation": null
    },
    {
      "time": 77.76,
      "time_str": "01:17.760",
      "text": "看那铁路修到我家乡",
      "translation": null
    },
    {
      "time": 85.18,
      "time_str": "01:25.180",
      "text": "一条条巨龙翻山越岭",
      "translation": null
    },
    {
      "time": 93.09,
      "time_str": "01:33.090",
      "text": "为雪域高原送来安康",
      "translation": null
    },
    {
      "time": 102.35,
      "time_str": "01:42.350",
      "text": "那是一条神奇的天路",
      "translation": null
    },
    {
      "time": 109.26,
      "time_str": "01:49.260",
      "text": "把人间的温暖送到边疆",
      "translation": null
    },
    {
      "time": 116.97,
      "time_str": "01:56.970",
      "text": "从此山不再高路不再漫长",
      "translation": null
    },
    {
