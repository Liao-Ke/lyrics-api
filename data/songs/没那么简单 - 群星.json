  "lyrics": [
    {
      "time": 29.7,
      "time_str": "00:29.700",
      "text": "没那么简单",
      "translation": null
    },
    {
      "time": 31.78,
      "time_str": "00:31.780",
      "text": "就能找到聊得来的伴",
      "translation": null
    },
    {
      "time": 37.11,
      "time_str": "00:37.110",
      "text": "尤其是在看过了那么多的背叛",
      "translation": null
    },
    {
      "time": 42.89,
      "time_str": "00:42.890",
      "text": "总是不安只好强悍",
      "translation": null
    },
    {
      "time": 54.19,
      "time_str": "00:54.190",
      "text": "谁谋杀了我的浪漫",
      "translation": null
    },
    {
      "time": 60.09,
      "time_str": "01:00.090",
      "text": "没那么简单",
      "translation": null
    },
    {
      "time": 62.23,
      "time_str": "01:02.230",
      "text": "就能去爱别的全不看",
      "translation": null
    },
    {
      "time": 66.61,
      "time_str": "01:06.610",
      "text": "变得实际也许好也许坏各一半",
      "translation": null
    },
    {
      "time": 73.32,
      "time_str": "01:13.320",
      "text": "不爱孤单一久也习惯",
      "translation": null
    },
    {
      "time": 79.81,
      "time_str": "01:19.810",
      "text": "不用担心谁也不用被谁管",
      "translation": null
    },
    {
      "time": 86.52,
      "time_str": "01:26.520",
      "text": "感觉快乐就忙东忙西",
      "translation": null
    },
    {
      "time": 89.82,
      "time_str": "01:29.820",
      "text": "感觉累了就放空自己",
      "translation": null
    },
    {
      "time": 93.32,
      "time_str": "01:33.320",
      "text": "别人说的话随便听一听",
      "translation": null
    },
    {
      "time": 99.03,
      "time_str": "01:39.030",
      "text": "自己作决定",
      "translation": null
    },
    {
      "time": 102.53,
      "time_str": "01:42.530",
      "text": "不想拥有太多情绪",
      "translation": null
    },
    {
      "time": 105.93,
      "time_str": "01:45.930",
      "text": "一杯红酒配电影",
      "translation": null
    },
    {
      "time": 109.39,
      "time_str": "01:49.390",
      "text": "在周末晚上关上了手机",
      "translation": null
    },
    {
      "time": 112.74,
      "time_str": "01:52.740",
      "text": "舒服窝在沙发里",
      "translation": null
    },
    {
      "time": 115.89,
      "time_str": "01:55.890",
      "text": "相爱没有那么容易",
      "translation": null
    },
    {
      "time": 119.29,
      "time_str": "01:59.290",
      "text": "每个人有他的脾气",
      "translation": null
    },
    {
      "time": 122.64,
      "time_str": "02:02.640",
      "text": "过了爱作梦的年纪",
      "translation": null
    },
    {
      "time": 126.1,
      "time_str": "02:06.100",
      "text": "轰轰烈烈不如平静",
      "translation": null
    },
    {
      "time": 129.45,
      "time_str": "02:09.450",
      "text": "幸福没有那么容易",
      "translation": null
    },
    {
      "time": 132.85,
      "time_str": "02:12.850",
      "text": "才会特别让人着迷",
      "translation": null
    },
    {
      "time": 136.35,
      "time_str": "02:16.350",
      "text": "什么都不懂的年纪",
      "translation": null
    },
    {
      "time": 139.86,
      "time_str": "02:19.860",
      "text": "曾经最掏心",
