  "lyrics": [
    {
      "time": 19.71,
      "time_str": "00:19.710",
      "text": "Well I wonder could it be",
      "translation": "我想知道,这是否可能？"
    },
    {
      "time": 24.48,
      "time_str": "00:24.480",
      "text": "When I was dreaming about you baby",
      "translation": "当我梦到你的时候"
    },
    {
      "time": 27.56,
      "time_str": "00:27.560",
      "text": "You were dreaming of me",
      "translation": "你的梦中是否也有我"
    },
    {
      "time": 29.71,
      "time_str": "00:29.710",
      "text": "Call me crazy",
      "translation": "有人说我疯狂"
    },
    {
      "time": 32.49,
      "time_str": "00:32.490",
      "text": "Call me blind",
      "translation": "让我盲目"
    },
    {
      "time": 34.919,
      "time_str": "00:34.919",
      "text": "To still be suffering is stupid after",
      "translation": "已过去那么长时间"
    },
    {
      "time": 38.449,
      "time_str": "00:38.449",
      "text": "all of this time",
      "translation": "仍然在为此伤痛真是太傻了"
    },
    {
      "time": 39.739,
      "time_str": "00:39.739",
      "text": "Did I lose my love to someone better",
      "translation": "我把我的爱输给了更好的人吗？"
    },
    {
      "time": 43.659,
      "time_str": "00:43.659",
      "text": "And does she love you like I do",
      "translation": "她会像我那样爱你吗 ？"
    },
    {
      "time": 46.69,
      "time_str": "00:46.690",
      "text": "I do, you know I really really do",
      "translation": "是的,你知道我真的真的很爱你"
    },
    {
      "time": 52.29,
      "time_str": "00:52.290",
      "text": "Well hey",
      "translation": "嗨"
    },
    {
      "time": 52.589,
      "time_str": "00:52.589",
      "text": "So much I need to say",
      "translation": "我需要说的有太多太多"
    },
    {
      "time": 54.669,
      "time_str": "00:54.669",
      "text": "Been lonely since the day",
      "translation": "从那一天起我是多么的孤独"
    },
    {
      "time": 56.939,
      "time_str": "00:56.939",
      "text": "The day you went away",
      "translation": "你离去的那一天"
    },
    {
      "time": 60.89,
      "time_str": "01:00.890",
      "text": "So sad but true",
      "translation": "我是真的很难过"
    },
    {
      "time": 62.599,
      "time_str": "01:02.599",
      "text": "For me there's only you",
      "translation": "你是我的唯一"
    },
    {
      "time": 64.639,
      "time_str": "01:04.639",
      "text": "Been crying since the day",
      "translation": "从那一天起我就一直在哭泣"
    },
    {
      "time": 68.109,
      "time_str": "01:08.109",
      "text": "The day you went away",
      "translation": "你离去的那一天"
    },
    {
      "time": 82.689,
      "time_str": "01:22.689",
      "text": "I remember date and time",
      "translation": "我记得那一天那一刻"
    },
    {
      "time": 87.659,
      "time_str": "01:27.659",
      "text": "September twenty second",
      "translation": "九月22日"
    },
    {
      "time": 89.799,
      "time_str": "01:29.799",
      "text": "Sunday twenty five after nine",
      "translation": "星期天的九点二十五分"
    },
    {
      "time": 92.589,
      "time_str": "01:32.589",
      "text": "In the doorway with your case",
      "translation": "在门口拿着你的行李"
    },
    {
      "time": 97.759,
      "time_str": "01:37.759",
      "text": "No longer shouting at each other",
      "translation": "我们不再争吵"
    },
    {
      "time": 100.879,
      "time_str": "01:40.879",
      "text": "There were tears on our faces",
      "translation": "泪水挂在我们的脸上"
    },
    {
      "time": 103.89,
      "time_str": "01:43.890",
      "text": "And we were letting go of something special",
      "translation": "我们让某些特别的东西溜走"
    },
    {
      "time": 106.789,
      "time_str": "01:46.789",
      "text": "Something we'll never have again",
      "translation": "这些东西我们再也不会得到"
    },
    {
      "time": 109.399,
      "time_str": "01:49.399",
      "text": "I know, I guess I really really know",
      "translation": "我明白,我想我真的真的明白了"
    },
    {
      "time": 114.99,
      "time_str": "01:54.990",
      "text": "Well hey",
      "translation": "是的"
    },
