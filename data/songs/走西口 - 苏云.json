  "lyrics": [
    {
      "time": 19.66,
      "time_str": "00:19.660",
      "text": "哥哥你走西口，小妹妹我实在难留，",
      "translation": null
    },
    {
      "time": 27.64,
      "time_str": "00:27.640",
      "text": "手拉着哥哥的手，送哥送到大门口。",
      "translation": null
    },
    {
      "time": 38.1,
      "time_str": "00:38.10",
      "text": "哥哥你出村口，小妹妹我有句话儿留，",
      "translation": null
    },
    {
      "time": 46.36,
      "time_str": "00:46.36",
      "text": "走路走那大路口，人马多来解忧愁。",
      "translation": null
    },
    {
      "time": 56.76,
      "time_str": "00:56.76",
      "text": "紧紧地拉着哥哥的袖，汪汪的泪水肚里流，",
      "translation": null
    },
    {
      "time": 65.52,
      "time_str": "01:05.52",
      "text": "只恨妹妹我不能跟你一起走，",
      "translation": null
    },
    {
      "time": 72.36,
      "time_str": "01:12.36",
      "text": "只盼哥哥你早回家门口。",
      "translation": null
    },
    {
      "time": 78.8,
      "time_str": "01:18.800",
      "text": "Music",
      "translation": null
    },
    {
