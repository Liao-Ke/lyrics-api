{
  "title": "串烧",
  "title_raw": "串烧",
  "version": null,
  "artist": "许天昱,陈旭辉-nn,单子玹,RichDD",
  "group_key": "串烧|许天昱,陈旭辉-nn,单子玹,richdd",
  "writers": {
    "lyricist": "群星",
    "composer": "群星",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 4.49,
      "time_str": "00:04.490",
      "text": "时间是让人猝不及防的东西",
      "translation": null
    },
    {
      "time": 7.49,
      "time_str": "00:07.490",
      "text": "晴时有风阴有时雨",
      "translation": null
    },
    {
      "time": 11.49,
      "time_str": "00:11.490",
      "text": "争不过朝夕 又念着往昔",
      "translation": null
    },
    {
      "time": 15.49,
      "time_str": "00:15.490",
      "text": "偷走了青丝却留住一个你",
      "translation": null
    },
    {
      "time": 24.49,
      "time_str": "00:24.490",
      "text": "演唱：单子玹 陈旭辉 蒋笛含",
      "translation": null
    },
    {
      "time": 32.49,
      "time_str": "00:32.490",
      "text": "有没有那么一种永远",
      "translation": null
    },
    {
      "time": 37.49,
      "time_str": "00:37.490",
      "text": "永远不改变",
      "translation": null
    },
    {
      "time": 41.49,
      "time_str": "00:41.490",
      "text": "拥抱过的美丽都再也不破碎",
      "translation": null
    },
    {
      "time": 48.49,
      "time_str": "00:48.490",
      "text": "让险峻岁月不能在脸上撒野",
      "translation": null
    },
    {
      "time": 55.49,
      "time_str": "00:55.490",
      "text": "让生离和死别都遥远",
      "translation": null
    },
    {
      "time": 62.49,
      "time_str": "01:02.490",
      "text": "有谁能听见",
      "translation": null
    },
    {
      "time": 68.49,
      "time_str": "01:08.490",
      "text": "一闪一闪亮晶晶",
      "translation": null
    },
    {
      "time": 72.49,
      "time_str": "01:12.490",
      "text": "好像你的身体",
      "translation": null
    },
    {
      "time": 76.49,
      "time_str": "01:16.490",
      "text": "藏在众多孤星之中 还是找得到你",
      "translation": null
    },
    {
      "time": 82.49,
      "time_str": "01:22.490",
      "text": "挂在天上放光明",
      "translation": null
    },
    {
      "time": 87.49,
      "time_str": "01:27.490",
      "text": "反射我的过去",
      "translation": null
    },
    {
      "time": 90.49,
      "time_str": "01:30.490",
      "text": "提醒我 我不再是一颗寂寞的星星",
      "translation": null
    },
    {
      "time": 104.49,
      "time_str": "01:44.490",
      "text": "那是我们都回不去的从前",
      "translation": null
    },
    {
      "time": 108.49,
      "time_str": "01:48.490",
      "text": "幸好还可以坚持当时的信念",
      "translation": null
    },
    {
      "time": 111.49,
      "time_str": "01:51.490",
      "text": "世界尝试改变",
      "translation": null
    },
    {
      "time": 113.49,
      "time_str": "01:53.490",
      "text": "当初的那个少年",
      "translation": null
    },
    {
      "time": 119.49,
      "time_str": "01:59.490",
      "text": "那是我们都回不去的从前",
      "translation": null
    },
    {
      "time": 122.49,
      "time_str": "02:02.490",
      "text": "当你站在那个夏天的海岸线",
      "translation": null
    },
    {
      "time": 126.49,
      "time_str": "02:06.490",
      "text": "我们还是心里面",
      "translation": null
    },
    {
      "time": 128.49,
      "time_str": "02:08.490",
      "text": "那个偏执的少年",
      "translation": null
    },
    {
      "time": 131.49,
      "time_str": "02:11.490",
      "text": "落叶的位置 谱出一首诗",
      "translation": null
    },
    {
      "time": 139.49,
      "time_str": "02:19.490",
      "text": "时间在消逝 我们的故事开始",
      "translation": null
    },
    {
      "time": 146.49,
      "time_str": "02:26.490",
      "text": "这是第一次 让我见识爱情",
      "translation": null
    },
    {
      "time": 154.49,
      "time_str": "02:34.490",
      "text": "可以慷慨又自私 你是我的关键词",
      "translation": null
    },
    {
      "time": 160.49,
      "time_str": "02:40.490",
      "text": "落叶的位置 谱出一首诗 好好爱自己 就有人会爱你 这乐观的说词",
      "translation": null
    },
    {
      "time": 167.49,
      "time_str": "02:47.490",
      "text": "时间在消逝 我们的故事开始 幸福的样子 我感觉好真实 找不到形容词",
      "translation": null
    },
    {
      "time": 175.49,
      "time_str": "02:55.490",
      "text": "这是第一次 让我见识爱情 沉默在掩饰 快泛滥的激情 只剩下语助词",
      "translation": null
    },
    {
      "time": 182.49,
      "time_str": "03:02.490",
      "text": "可以慷慨又自私 你是我的关键词 有一种踏实 当你口中喊我名字",
      "translation": null
    },
    {
      "time": 191.49,
      "time_str": "03:11.490",
      "text": "那时候最好的我们",
      "translation": null
    },
    {
      "time": 195.49,
      "time_str": "03:15.490",
      "text": "有简单勇敢的天真",
      "translation": null
    },
    {
      "time": 199.49,
      "time_str": "03:19.490",
      "text": "到现在夜空闪烁",
      "translation": null
    },
    {
      "time": 201.49,
      "time_str": "03:21.490",
      "text": "只留下我一个人看烟火",
      "translation": null
    },
    {
      "time": 206.49,
      "time_str": "03:26.490",
      "text": "那时候最好的我们",
      "translation": null
    },
    {
      "time": 209.49,
      "time_str": "03:29.490",
      "text": "有明亮坚定的眼神",
      "translation": null
    },
    {
      "time": 215.49,
      "time_str": "03:35.490",
      "text": "你说这些经过",
      "translation": null
    },
    {
      "time": 217.49,
      "time_str": "03:37.490",
      "text": "平凡而又深刻",
      "translation": null
    },
    {
      "time": 218.49,
      "time_str": "03:38.490",
      "text": "却没见你",
      "translation": null
    },
    {
      "time": 220.49,
      "time_str": "03:40.490",
      "text": "留下任何的颜色",
      "translation": null
    },
    {
      "time": 230.49,
      "time_str": "03:50.490",
      "text": "我怎么变这样",
      "translation": null
    },
    {
      "time": 232.49,
      "time_str": "03:52.490",
      "text": "变得这样疯狂",
      "translation": null
    },
    {
      "time": 235.49,
      "time_str": "03:55.490",
      "text": "用这灿烂时光",
      "translation": null
    },
    {
      "time": 238.49,
      "time_str": "03:58.490",
      "text": "绽放不一样的光",
      "translation": null
    },
    {
      "time": 243.49,
      "time_str": "04:03.490",
      "text": "就算黑夜太漫长",
      "translation": null
    },
    {
      "time": 246.49,
      "time_str": "04:06.490",
      "text": "风景全被遮挡",
      "translation": null
    },
    {
      "time": 251.49,
      "time_str": "04:11.490",
      "text": "抬头就有一片星光",
      "translation": null
    },
    {
      "time": 257.49,
      "time_str": "04:17.490",
      "text": "你说一二三转身,你听被抹掉的慌张",
      "translation": null
    },
    {
      "time": 273.49,
      "time_str": "04:33.490",
      "text": "我想,抬头暖阳春草,你给我简单拥抱",
      "translation": null
    },
    {
      "time": 288.49,
      "time_str": "04:48.490",
      "text": "我想,踩碎了迷茫走过时光,睁开眼你就会听到",
      "translation": null
    },
    {
      "time": 303.49,
      "time_str": "05:03.490",
      "text": "我想,一个眼神,就到老",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "串烧 - 许天昱,陈旭辉-nn,单子玹,RichDD.lrc"
}