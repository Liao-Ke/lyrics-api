      "translation": null
    },
    {
      "time": 164.1,
      "time_str": "02:44.100",
      "text": "难堪的关系不可畏",
      "translation": null
    },
    {
      "time": 167.57,
      "time_str": "02:47.570",
      "text": "离开的恋人都",
      "translation": null
    },
    {
      "time": 171.03,
