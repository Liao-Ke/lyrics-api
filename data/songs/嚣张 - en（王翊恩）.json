  "lyrics": [
    {
      "time": 29.75,
      "time_str": "00:29.750",
      "text": "太多的 太重的 太残忍的话",
      "translation": null
    },
    {
      "time": 36.75,
      "time_str": "00:36.750",
      "text": "没纠缠 是你的 理由太假",
      "translation": null
    },
    {
      "time": 43.44,
      "time_str": "00:43.440",
      "text": "我觉得 你大可不必说得天花乱坠",
      "translation": null
    },
    {
      "time": 50.62,
      "time_str": "00:50.620",
      "text": "是天使 是魔鬼 都没有绝对",
      "translation": null
    },
    {
      "time": 57.94,
      "time_str": "00:57.940",
      "text": "没想的 没说的 都请收起吧",
      "translation": null
    },
    {
      "time": 65.12,
      "time_str": "01:05.120",
      "text": "你扮演 的角色 更可悲吗",
      "translation": null
    },
    {
      "time": 72.25,
      "time_str": "01:12.250",
      "text": "放弃的 就大可不必再争辩是非",
      "translation": null
    },
    {
      "time": 79.44,
      "time_str": "01:19.440",
      "text": "放下的 就请你 烧得干脆",
      "translation": null
    },
    {
      "time": 86.44,
      "time_str": "01:26.440",
      "text": "你的一字一句犹如刀疤划心上",
      "translation": null
    },
    {
      "time": 90.56,
      "time_str": "01:30.560",
      "text": "我的一举一动随你改变多荒唐",
      "translation": null
    },
    {
      "time": 93.88,
      "time_str": "01:33.880",
      "text": "任你肆意玩弄 从没去想",
      "translation": null
    },
    {
      "time": 97.87,
      "time_str": "01:37.870",
      "text": "你是有多嚣张",
      "translation": null
    },
    {
      "time": 100.56,
      "time_str": "01:40.560",
      "text": "我的心脏脉搏为你跳动为你狂",
      "translation": null
    },
    {
      "time": 104.81,
      "time_str": "01:44.810",
      "text": "你说我真的多余不如离开流浪",
      "translation": null
    },
    {
      "time": 108.25,
      "time_str": "01:48.250",
      "text": "都怪我 没治愈我的伤",
      "translation": null
    },
    {
