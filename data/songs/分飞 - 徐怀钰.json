  },
  "lyrics": [
    {
      "time": 25.02,
      "time_str": "00:25.020",
      "text": "你和我 相约在",
      "translation": null
    },
    {
      "time": 27.74,
      "time_str": "00:27.740",
      "text": "午夜喧哗的大街",
      "translation": null
    },
    {
      "time": 30.64,
      "time_str": "00:30.640",
      "text": "告诉我 这段感情",
      "translation": null
    },
    {
      "time": 33.43,
      "time_str": "00:33.430",
      "text": "今夜将会是终点",
      "translation": null
    },
    {
      "time": 36.17,
      "time_str": "00:36.170",
      "text": "傻傻地 看着你",
      "translation": null
    },
    {
      "time": 39.0,
      "time_str": "00:39.000",
      "text": "眼角不流一滴泪",
      "translation": null
    },
    {
      "time": 41.9,
      "time_str": "00:41.900",
      "text": "说好了 要坚强",
      "translation": null
    },
    {
      "time": 44.72,
      "time_str": "00:44.720",
      "text": "不流泪",
      "translation": null
    },
    {
      "time": 47.62,
      "time_str": "00:47.620",
      "text": "我以为 我可以",
      "translation": null
    },
    {
      "time": 50.36,
      "time_str": "00:50.360",
      "text": "让爱变得很甜美",
      "translation": null
    },
    {
      "time": 53.18,
      "time_str": "00:53.180",
      "text": "才发现 爱情竟是",
      "translation": null
    },
    {
      "time": 56.05,
      "time_str": "00:56.050",
      "text": "一场残酷的考验",
      "translation": null
    },
    {
      "time": 58.8,
      "time_str": "00:58.800",
      "text": "太愚昧 太依恋",
      "translation": null
    },
    {
      "time": 61.64,
      "time_str": "01:01.640",
      "text": "才放你去自由飞",
      "translation": null
    },
    {
      "time": 64.47,
      "time_str": "01:04.470",
      "text": "一瞬间 爱决堤",
      "translation": null
    },
    {
      "time": 67.34,
      "time_str": "01:07.340",
      "text": "在今夜",
      "translation": null
    },
    {
      "time": 73.06,
      "time_str": "01:13.060",
      "text": "雨纷飞",
      "translation": null
    },
    {
      "time": 74.7,
      "time_str": "01:14.700",
      "text": "飞在天空里是我的眼泪",
      "translation": null
    },
    {
      "time": 78.6,
      "time_str": "01:18.600",
      "text": "泪低垂",
      "translation": null
    },
    {
      "time": 80.37,
      "time_str": "01:20.370",
      "text": "垂在手心里是你的余味",
      "translation": null
    },
    {
      "time": 84.29,
      "time_str": "01:24.290",
      "text": "谁了解",
      "translation": null
    },
    {
      "time": 86.09,
      "time_str": "01:26.090",
      "text": "真心的付出换来是离别",
      "translation": null
    },
    {
      "time": 90.06,
      "time_str": "01:30.060",
      "text": "我知道",
      "translation": null
    },
    {
      "time": 91.76,
      "time_str": "01:31.760",
      "text": "爱过后会心碎",
      "translation": null
    },
    {
      "time": 95.63,
      "time_str": "01:35.630",
      "text": "我相信",
      "translation": null
    },
    {
      "time": 97.27,
      "time_str": "01:37.270",
      "text": "爱情没有永远",
      "translation": null
    },
    {
