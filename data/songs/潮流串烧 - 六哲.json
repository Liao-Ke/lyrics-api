  "lyrics": [
    {
      "time": 31.229,
      "time_str": "00:31.229",
      "text": "爱过的人 我已不再拥有",
      "translation": null
    },
    {
      "time": 37.96,
      "time_str": "00:37.960",
      "text": "许多故事有伤心的理由",
      "translation": null
    },
    {
      "time": 44.019,
      "time_str": "00:44.019",
      "text": "别再想以后时间差不多",
      "translation": null
    },
    {
      "time": 47.449,
      "time_str": "00:47.449",
      "text": "让我再为你演奏到午后",
      "translation": null
    },
    {
      "time": 54.999,
      "time_str": "00:54.999",
      "text": "风到这里就停 雨到这里无声",
      "translation": null
    },
    {
      "time": 58.179,
      "time_str": "00:58.179",
      "text": "它也在笑我多情",
      "translation": null
    },
    {
      "time": 61.609,
      "time_str": "01:01.609",
      "text": "影子陪在身旁 细数那些过往",
      "translation": null
    },
    {
      "time": 65.05,
      "time_str": "01:05.050",
      "text": "多少年快乐和忧伤",
      "translation": null
    },
    {
      "time": 68.04,
      "time_str": "01:08.040",
      "text": "最后的理由 是勇敢放手",
      "translation": null
    },
    {
      "time": 71.35,
      "time_str": "01:11.350",
      "text": "什么都没说 就要到尽头",
      "translation": null
    },
    {
      "time": 79.02,
      "time_str": "01:19.020",
      "text": "忧郁的钢琴还在伴奏着",
      "translation": null
    },
    {
      "time": 85.639,
      "time_str": "01:25.639",
      "text": "眼眶的泪水也开始沉没",
      "translation": null
    },
    {
      "time": 98.7,
      "time_str": "01:38.700",
      "text": "是我爱死了昨天 誓言割碎你的脸",
      "translation": null
    },
    {
      "time": 104.729,
      "time_str": "01:44.729",
      "text": "一切都回不到那些从前美好的画面",
      "translation": null
    },
    {
      "time": 112.3,
      "time_str": "01:52.300",
      "text": "我承认都是月亮惹的祸",
      "translation": null
    },
    {
      "time": 115.15,
      "time_str": "01:55.150",
      "text": "那样的夜色太美你太温柔",
      "translation": null
    },
    {
      "time": 118.589,
      "time_str": "01:58.589",
      "text": "再怎么心如钢铁也成绕指柔",
      "translation": null
    },
    {
      "time": 140.53,
      "time_str": "02:20.530",
      "text": "初秋的天冰冷的夜",
      "translation": null
    },
    {
      "time": 143.65,
      "time_str": "02:23.650",
      "text": "回忆慢慢袭来",
      "translation": null
    },
    {
      "time": 147.38,
      "time_str": "02:27.380",
      "text": "真心的爱 就像落叶",
      "translation": null
    },
    {
      "time": 150.81,
      "time_str": "02:30.810",
      "text": "为何却要分开",
      "translation": null
    },
    {
      "time": 154.62,
      "time_str": "02:34.620",
      "text": "爱 就这样 匆匆离开",
      "translation": null
    },
    {
      "time": 165.6,
      "time_str": "02:45.600",
      "text": "等待良人归来那一刻",
      "translation": null
    },
    {
      "time": 171.529,
      "time_str": "02:51.529",
      "text": "眼泪为你唱歌",
      "translation": null
    },
    {
      "time": 177.59,
      "time_str": "02:57.590",
      "text": "就忘了吧  就放了吧",
      "translation": null
    },
    {
      "time": 181.08,
      "time_str": "03:01.080",
      "text": "不要记得所有你的好",
      "translation": null
    },
    {
      "time": 185.19,
      "time_str": "03:05.190",
      "text": "你留给我所有的一切都忘掉",
      "translation": null
    },
    {
      "time": 192.61,
      "time_str": "03:12.610",
      "text": "爱算什么这样苦苦折磨",
      "translation": null
    },
    {
      "time": 198.85,
      "time_str": "03:18.850",
      "text": "给我致命的伤害 还要我等待",
      "translation": null
    },
    {
      "time": 205.28,
      "time_str": "03:25.280",
      "text": "最后终于明白",
      "translation": null
    },
    {
      "time": 206.78,
      "time_str": "03:26.780",
      "text": "要一个人来爱",
      "translation": null
    },
    {
      "time": 208.53,
      "time_str": "03:28.530",
      "text": "遥远的空间拼不出未来",
      "translation": null
    },
    {
      "time": 212.8,
      "time_str": "03:32.800",
      "text": "关于现在  用音符记下来",
      "translation": null
    },
    {
      "time": 216.1,
      "time_str": "03:36.100",
      "text": "描述这一场恋爱",
      "translation": null
    },
    {
      "time": 219.13,
      "time_str": "03:39.130",
      "text": "一千个伤心的理由",
      "translation": null
    },
    {
      "time": 222.75,
      "time_str": "03:42.750",
      "text": "一千个伤心的理由",
      "translation": null
    },
    {
      "time": 226.31,
      "time_str": "03:46.310",
      "text": "再怎么心如钢铁也成绕指柔",
      "translation": null
    }
  ],
