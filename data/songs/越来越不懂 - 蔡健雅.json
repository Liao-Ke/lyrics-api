  "lyrics": [
    {
      "time": 15.8,
      "time_str": "00:15.800",
      "text": "在我二十二岁时",
      "translation": null
    },
    {
      "time": 19.16,
      "time_str": "00:19.160",
      "text": "回想起当时多么想谈恋爱",
      "translation": null
    },
    {
      "time": 24.0,
      "time_str": "00:24.000",
      "text": "妈妈说就让它来",
      "translation": null
    },
    {
      "time": 28.91,
      "time_str": "00:28.910",
      "text": "然而在我三十二岁时",
      "translation": null
    },
    {
      "time": 33.09,
      "time_str": "00:33.090",
      "text": "发现我没太多的心去等待",
      "translation": null
    },
    {
      "time": 37.7,
      "time_str": "00:37.700",
      "text": "它失去某种色彩",
      "translation": null
    },
    {
      "time": 43.44,
      "time_str": "00:43.440",
      "text": "得不到的就更加爱",
      "translation": null
    },
    {
      "time": 46.94,
      "time_str": "00:46.940",
      "text": "太容易来的就不理睬",
      "translation": null
    },
    {
      "time": 50.1,
      "time_str": "00:50.100",
      "text": "其实谁不想遇见真爱",
      "translation": null
    },
    {
      "time": 53.86,
      "time_str": "00:53.860",
      "text": "爱得绝对",
      "translation": null
    },
    {
      "time": 55.55,
      "time_str": "00:55.550",
      "text": "爱得坦白",
      "translation": null
    },
    {
      "time": 57.37,
      "time_str": "00:57.370",
      "text": "以为遇上了就会明白",
      "translation": null
    },
    {
      "time": 60.55,
      "time_str": "01:00.550",
      "text": "但每次它只留下",
      "translation": null
    },
    {
      "time": 62.56,
      "time_str": "01:02.560",
      "text": "惊鸿一瞥的感慨",
      "translation": null
    },
    {
      "time": 67.58,
      "time_str": "01:07.580",
      "text": "我越来越不懂爱",
      "translation": null
    },
    {
      "time": 85.34,
      "time_str": "01:25.340",
      "text": "才三十二岁的我",
      "translation": null
    },
    {
      "time": 88.68,
      "time_str": "01:28.680",
      "text": "虽然一个人过",
      "translation": null
    },
    {
      "time": 90.43,
      "time_str": "01:30.430",
      "text": "也过得够精彩",
      "translation": null
    },
    {
      "time": 93.53,
      "time_str": "01:33.530",
      "text": "偶尔才想谈恋爱",
      "translation": null
    },
    {
      "time": 98.45,
      "time_str": "01:38.450",
      "text": "然而爱总是乱了节拍",
      "translation": null
    },
    {
      "time": 102.63,
      "time_str": "01:42.630",
      "text": "我只能够瞎猜",
      "translation": null
    },
    {
      "time": 104.38,
      "time_str": "01:44.380",
      "text": "也许能中乐透彩",
      "translation": null
    },
    {
      "time": 107.54,
