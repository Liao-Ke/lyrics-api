    {
      "time": 15.3,
      "time_str": "00:15.300",
      "text": "是谁把慷慨变成伤害",
      "translation": null
    },
    {
      "time": 19.2,
      "time_str": "00:19.200",
      "text": "是谁把心酸化成无奈",
      "translation": null
    },
    {
      "time": 23.5,
      "time_str": "00:23.500",
      "text": "等待了多久才会明白",
      "translation": null
    },
    {
      "time": 27.759,
      "time_str": "00:27.759",
      "text": "细数你冠冕堂皇的对白",
      "translation": null
    },
    {
      "time": 31.6,
      "time_str": "00:31.600",
      "text": "开始的热情和小澎湃",
      "translation": null
    },
    {
      "time": 35.5,
      "time_str": "00:35.500",
      "text": "最后的摇摆和不理 睬",
      "translation": null
    },
    {
      "time": 39.0,
      "time_str": "00:39.000",
      "text": "明天和意外哪个先来",
      "translation": null
    },
    {
      "time": 43.6,
      "time_str": "00:43.600",
      "text": "别问我痴心不改应不应该",
      "translation": null
    },
    {
      "time": 49.0,
      "time_str": "00:49.000",
      "text": "终于明白对你的爱责无旁贷",
      "translation": null
    },
    {
      "time": 53.5,
      "time_str": "00:53.500",
      "text": "终于想开爱情是一个人还债",
      "translation": null
    },
    {
      "time": 57.5,
      "time_str": "00:57.500",
      "text": "承诺不该轻易更改轻易忘怀",
      "translation": null
    },
    {
      "time": 61.48,
      "time_str": "01:01.480",
      "text": "别把这一场热爱变成了一种责怪",
      "translation": null
    },
    {
      "time": 65.71,
      "time_str": "01:05.710",
      "text": "终于明白对你的爱责无旁贷",
      "translation": null
    },
    {
      "time": 69.7,
      "time_str": "01:09.700",
      "text": "终于换来面朝大海春暖花开",
      "translation": null
    },
    {
      "time": 73.7,
      "time_str": "01:13.700",
      "text": "幸好最后我们选择不再分开",
      "translation": null
    },
    {
      "time": 77.4,
      "time_str": "01:17.400",
      "text": "就让这一次相爱像飞蛾扑向火海",
      "translation": null
    },
    {
