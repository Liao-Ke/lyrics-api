  "lyrics": [
    {
      "time": 20.17,
      "time_str": "00:20.170",
      "text": "我在仰望 月亮之上",
      "translation": null
    },
    {
      "time": 25.04,
      "time_str": "00:25.040",
      "text": "有多少梦想在自由的飞翔",
      "translation": null
    },
    {
      "time": 30.04,
      "time_str": "00:30.040",
      "text": "昨天遗忘啊 风干了忧伤",
      "translation": null
    },
    {
      "time": 35.04,
      "time_str": "00:35.040",
      "text": "我要和你重逢在那苍茫的路上",
      "translation": null
    },
    {
      "time": 39.98,
      "time_str": "00:39.980",
      "text": "生命已被指引 潮落潮涨",
      "translation": null
    },
    {
      "time": 45.11,
      "time_str": "00:45.110",
      "text": "有你的远方 就是天堂",
      "translation": null
    },
    {
      "time": 72.78,
      "time_str": "01:12.780",
      "text": "谁在呼唤 情深意长",
      "translation": null
    },
    {
      "time": 77.47,
      "time_str": "01:17.470",
      "text": "让我的渴望像白云在飘荡",
      "translation": null
    },
    {
      "time": 82.59,
      "time_str": "01:22.590",
      "text": "东边牧马 西边放羊",
      "translation": null
    },
    {
      "time": 87.4,
      "time_str": "01:27.400",
      "text": "野辣辣的情歌就唱到了天亮",
      "translation": null
    },
    {
      "time": 92.59,
      "time_str": "01:32.590",
      "text": "在日月沧桑后 你在谁身旁",
      "translation": null
    },
    {
      "time": 97.34,
      "time_str": "01:37.340",
      "text": "用温柔眼光 让黑夜绚烂",
      "translation": null
    },
    {
      "time": 162.5,
      "time_str": "02:42.500",
      "text": "Yo Yo Come On Baby Go",
      "translation": null
    },
    {
      "time": 167.5,
      "time_str": "02:47.500",
      "text": "Yo Yo 这 这感觉就像",
      "translation": null
    },
    {
      "time": 171.26,
      "time_str": "02:51.260",
      "text": "一路的芳香还有婆娑轻波",
      "translation": null
    },
    {
      "time": 174.07,
      "time_str": "02:54.070",
      "text": "转了念的想那些是非因果",
      "translation": null
    },
    {
      "time": 176.51,
      "time_str": "02:56.510",
      "text": "一路的芳香让我不停捉摸",
      "translation": null
    },
    {
      "time": 179.07,
      "time_str": "02:59.070",
      "text": "Yo Yo Baby go Come On",
      "translation": null
    },
    {
      "time": 181.76,
      "time_str": "03:01.760",
      "text": "是谁在唱歌温暖了寂寞",
      "translation": null
    },
    {
      "time": 186.88,
      "time_str": "03:06.880",
      "text": "白云悠悠蓝天依旧泪水在漂泊",
      "translation": null
    },
    {
      "time": 192.07,
      "time_str": "03:12.070",
      "text": "在那一片苍茫中一个人生活",
      "translation": null
    },
    {
      "time": 197.24,
      "time_str": "03:17.240",
      "text": "看见远方天国那璀璨的烟火",
      "translation": null
    },
    {
