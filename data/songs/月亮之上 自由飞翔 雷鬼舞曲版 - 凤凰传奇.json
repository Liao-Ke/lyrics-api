    {
      "time": 223.05,
      "time_str": "03:43.050",
      "text": "是谁听着歌遗忘了寂寞",
      "translation": null
    },
    {
      "time": 228.18,
      "time_str": "03:48.180",
      "text": "漫漫长夜一路芬芳岁月曾流过",
      "translation": null
    },
    {
      "time": 233.37,
      "time_str": "03:53.370",
      "text": "在那人潮人海中你也在沉默",
      "translation": null
    },
    {
      "time": 238.49,
      "time_str": "03:58.490",
      "text": "和我一起漂泊到天涯的交错",
      "translation": null
    },
    {
