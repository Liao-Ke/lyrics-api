  "lyrics": [
    {
      "time": 37.75,
      "time_str": "00:37.750",
      "text": "闪烁不停 爱的讯息",
      "translation": null
    },
    {
      "time": 44.74,
      "time_str": "00:44.740",
      "text": "三言两语扣进心里",
      "translation": null
    },
    {
      "time": 51.68,
      "time_str": "00:51.680",
      "text": "捂住脸呵口气",
      "translation": null
    },
    {
      "time": 54.11,
      "time_str": "00:54.110",
      "text": "才不轻易泄露了心情",
      "translation": null
    },
    {
      "time": 58.51,
      "time_str": "00:58.510",
      "text": "仅仅傻笑而已",
      "translation": null
    },
    {
      "time": 60.7,
      "time_str": "01:00.700",
      "text": "也能够彻夜的想你",
      "translation": null
    },
    {
      "time": 64.58,
      "time_str": "01:04.580",
      "text": "爱到不可思议",
      "translation": null
    },
    {
      "time": 66.47,
      "time_str": "01:06.470",
      "text": "创世纪到末期",
      "translation": null
    },
    {
      "time": 68.02,
      "time_str": "01:08.020",
      "text": "不用甜言蜜语",
      "translation": null
    },
    {
      "time": 70.07,
      "time_str": "01:10.070",
      "text": "其实我爱的是你 是你",
      "translation": null
    },
    {
      "time": 72.89,
      "time_str": "01:12.890",
      "text": "烦恼的是我虽然很粗心",
      "translation": null
    },
    {
      "time": 76.09,
      "time_str": "01:16.090",
      "text": "但我会很努力",
      "translation": null
    },
    {
      "time": 78.11,
      "time_str": "01:18.110",
      "text": "爱到不可思议",
      "translation": null
    },
    {
      "time": 80.05,
      "time_str": "01:20.050",
      "text": "越老却越美丽",
      "translation": null
    },
    {
      "time": 81.69,
      "time_str": "01:21.690",
      "text": "牙掉了没关系",
      "translation": null
    },
    {
      "time": 83.61,
      "time_str": "01:23.610",
      "text": "皮肤皱皱也爱你 爱你",
      "translation": null
    },
    {
      "time": 86.67,
      "time_str": "01:26.670",
      "text": "就孩子气",
      "translation": null
    },
    {
      "time": 87.39,
      "time_str": "01:27.390",
      "text": "这一百分的相遇就是我和你",
      "translation": null
    },
    {
      "time": 102.61,
      "time_str": "01:42.610",
      "text": "你的讯息传个不停",
      "translation": null
    },
    {
      "time": 109.56,
      "time_str": "01:49.560",
      "text": "随时提醒甜蜜关系",
      "translation": null
    },
    {
      "time": 116.53,
      "time_str": "01:56.530",
      "text": "丢个硬币决定",
      "translation": null
    },
    {
      "time": 118.67,
      "time_str": "01:58.670",
      "text": "每天应该说几遍爱你",
      "translation": null
    },
    {
