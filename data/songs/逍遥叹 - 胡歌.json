  "lyrics": [
    {
      "time": 26.412,
      "time_str": "00:26.412",
      "text": "岁月难得沉默",
      "translation": null
    },
    {
      "time": 29.745,
      "time_str": "00:29.745",
      "text": "秋风厌倦漂泊",
      "translation": null
    },
    {
      "time": 33.067,
      "time_str": "00:33.067",
      "text": "夕阳赖着不走",
      "translation": null
    },
    {
      "time": 35.563,
      "time_str": "00:35.563",
      "text": "挂在墙头舍不得我",
      "translation": null
    },
    {
      "time": 39.73,
      "time_str": "00:39.730",
      "text": "昔日伊人耳边话",
      "translation": null
    },
    {
      "time": 43.067,
      "time_str": "00:43.067",
      "text": "已和潮声向东流",
      "translation": null
    },
    {
      "time": 46.392,
      "time_str": "00:46.392",
      "text": "再回首",
      "translation": null
    },
    {
      "time": 48.016,
      "time_str": "00:48.016",
      "text": "往事也随枫叶一片片落",
      "translation": null
    },
    {
      "time": 53.048,
      "time_str": "00:53.048",
      "text": "爱已走到尽头",
      "translation": null
    },
    {
      "time": 56.396,
      "time_str": "00:56.396",
      "text": "恨也放弃承诺",
      "translation": null
    },
    {
      "time": 59.75,
      "time_str": "00:59.750",
      "text": "命运自认幽默",
      "translation": null
    },
    {
      "time": 62.209,
      "time_str": "01:02.209",
      "text": "想法太多由不得我",
      "translation": null
    },
    {
      "time": 66.381,
      "time_str": "01:06.381",
      "text": "壮志凌云几分酬",
      "translation": null
    },
    {
      "time": 69.726,
      "time_str": "01:09.726",
      "text": "知己难逢几人留",
      "translation": null
    },
    {
      "time": 73.075,
      "time_str": "01:13.075",
      "text": "再回首",
      "translation": null
    },
    {
      "time": 74.706,
      "time_str": "01:14.706",
      "text": "却闻笑传醉梦中",
      "translation": null
    },
    {
      "time": 81.001,
      "time_str": "01:21.001",
      "text": "笑叹词穷 古痴今狂 终成空",
      "translation": null
    },
    {
      "time": 87.685,
      "time_str": "01:27.685",
      "text": "刀钝刃乏 恩断义绝 梦方破",
      "translation": null
    },
    {
      "time": 94.333,
      "time_str": "01:34.333",
      "text": "路荒遗叹 饱览足迹 没人懂",
      "translation": null
    },
    {
      "time": 100.973,
      "time_str": "01:40.973",
      "text": "多年望眼欲穿过",
      "translation": null
    },
    {
      "time": 103.896,
      "time_str": "01:43.896",
      "text": "红尘滚滚 我没看透",
      "translation": null
    },
    {
      "time": 107.623,
      "time_str": "01:47.623",
      "text": "自嘲墨尽 千情万怨 英杰愁",
      "translation": null
    },
    {
      "time": 114.271,
      "time_str": "01:54.271",
      "text": "曲终人散 发华鬓白 红颜殁",
      "translation": null
    },
    {
      "time": 120.978,
      "time_str": "02:00.978",
      "text": "烛残未觉 与日争辉 徒消瘦",
      "translation": null
    },
    {
      "time": 127.635,
      "time_str": "02:07.635",
      "text": "当泪干血盈眶涌",
      "translation": null
    },
    {
      "time": 130.542,
      "time_str": "02:10.542",
      "text": "白雪纷飞 都成空",
      "translation": null
    },
    {
      "time": 159.775,
      "time_str": "02:39.775",
      "text": "爱已走到尽头",
      "translation": null
