      "time": 29.47,
      "time_str": "00:29.470",
      "text": "岁月在蒸发",
      "translation": null
    },
    {
      "time": 32.56,
      "time_str": "00:32.560",
      "text": "蝴蝶依旧恋着花",
      "translation": null
    },
    {
      "time": 36.49,
      "time_str": "00:36.490",
      "text": "我笑她太傻",
      "translation": null
    },
    {
      "time": 39.56,
      "time_str": "00:39.560",
      "text": "守着枯萎的枝丫",
      "translation": null
    },
    {
      "time": 43.19,
      "time_str": "00:43.190",
      "text": "没结果的花 它痴恋着沙",
      "translation": null
    },
    {
