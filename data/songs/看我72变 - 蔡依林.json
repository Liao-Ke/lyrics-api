    {
      "time": 29.3,
      "time_str": "00:29.300",
      "text": "梦里面 空气开始冒烟",
      "translation": null
    },
    {
      "time": 33.0,
      "time_str": "00:33.000",
      "text": "蒙眬中完美的脸 慢慢的出现",
      "translation": null
    },
    {
      "time": 36.87,
      "time_str": "00:36.870",
      "text": "再见丑小鸭再见 我要洗心革面",
      "translation": null
    },
    {
      "time": 40.28,
      "time_str": "00:40.280",
      "text": "人力可以胜天 梦想近在眼前",
      "translation": null
    },
    {
      "time": 45.35,
      "time_str": "00:45.350",
      "text": "今天 新鲜 改变 再见",
      "translation": null
    },
    {
      "time": 52.28,
      "time_str": "00:52.280",
      "text": "美丽极限 爱漂亮没有终点",
      "translation": null
    },
    {
      "time": 55.22,
      "time_str": "00:55.220",
      "text": "追求完美的境界 人不爱美天诛地灭",
      "translation": null
    },
    {
      "time": 59.57,
      "time_str": "00:59.570",
      "text": "别气馁 旧观念抛到一边",
      "translation": null
    },
    {
      "time": 62.61,
      "time_str": "01:02.610",
      "text": "现在就开始改变 麻雀也能飞上青天",
      "translation": null
    },
    {
      "time": 66.99,
      "time_str": "01:06.990",
      "text": "无所谓 管它缺不缺陷",
      "translation": null
    },
    {
      "time": 69.9,
      "time_str": "01:09.900",
      "text": "让鼻子再高一点 空气才新鲜",
      "translation": null
    },
    {
      "time": 73.74,
      "time_str": "01:13.740",
      "text": "再见单眼皮再见 腰围再小一点",
      "translation": null
    },
    {
      "time": 77.32,
      "time_str": "01:17.320",
      "text": "努力战胜一切 缺点变成焦点",
      "translation": null
    },
    {
