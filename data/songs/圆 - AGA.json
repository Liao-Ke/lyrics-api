  "lyrics": [
    {
      "time": 15.84,
      "time_str": "00:15.840",
      "text": "圆是美满 圆是那个令人甜蜜笑脸",
      "translation": null
    },
    {
      "time": 21.71,
      "time_str": "00:21.710",
      "text": "圆是翩翩起舞转的圈圈",
      "translation": null
    },
    {
      "time": 25.62,
      "time_str": "00:25.620",
      "text": "转出一圈圈眷恋",
      "translation": null
    },
    {
      "time": 31.45,
      "time_str": "00:31.450",
      "text": "完是欠缺 完是那句令人难受再见",
      "translation": null
    },
    {
      "time": 37.18,
      "time_str": "00:37.180",
      "text": "最怕最爱已经不会再见",
      "translation": null
    },
    {
      "time": 41.17,
      "time_str": "00:41.170",
      "text": "欢欣都只靠悼念",
      "translation": null
    },
    {
      "time": 46.71,
      "time_str": "00:46.710",
      "text": "谁等 等 等 等不到月圆",
      "translation": null
    },
    {
      "time": 54.6,
      "time_str": "00:54.600",
      "text": "谁怕 怕 怕 快乐快用完",
      "translation": null
    },
    {
      "time": 61.53,
      "time_str": "01:01.530",
      "text": "可知有情人永远",
      "translation": null
    },
    {
      "time": 64.99,
      "time_str": "01:04.990",
      "text": "结尾才是新的开端",
      "translation": null
    },
    {
      "time": 69.22,
      "time_str": "01:09.220",
      "text": "情人团聚的小心愿",
      "translation": null
    },
    {
      "time": 72.09,
      "time_str": "01:12.090",
      "text": "离开一段开一段新一段",
      "translation": null
    },
    {
      "time": 76.17,
      "time_str": "01:16.170",
      "text": "人间的圆虽则是不够缘",
      "translation": null
    },
    {
      "time": 79.95,
      "time_str": "01:19.950",
      "text": "而有生一天会遇见",
      "translation": null
    },
    {
      "time": 84.85,
      "time_str": "01:24.850",
      "text": "成为遗憾的小心愿",
      "translation": null
    },
    {
      "time": 87.68,
      "time_str": "01:27.680",
      "text": "诚心许愿一千段都甘愿",
      "translation": null
    },
    {
      "time": 91.63,
      "time_str": "01:31.630",
      "text": "如果保存幸福一段",
      "translation": null
    },
    {
      "time": 95.14,
      "time_str": "01:35.140",
      "text": "这一段 都一样暖",
      "translation": null
    },
    {
      "time": 99.91,
      "time_str": "01:39.910",
      "text": "纵使谱不上美满的 圆的线",
      "translation": null
    },
    {
      "time": 120.96,
      "time_str": "02:00.960",
      "text": "谁走 走 走 走出了乐园",
      "translation": null
    },
    {
      "time": 128.6,
      "time_str": "02:08.600",
      "text": "谁痛 痛 痛 痛恨里复元",
      "translation": null
    },
    {
      "time": 135.7,
      "time_str": "02:15.700",
      "text": "即使距离还太远",
      "translation": null
    },
    {
      "time": 139.03,
      "time_str": "02:19.030",
      "text": "我信缘分安于身边",
      "translation": null
    },
    {
      "time": 143.62,
      "time_str": "02:23.620",
      "text": "情人团聚的小心愿",
      "translation": null
    },
    {
      "time": 146.35,
      "time_str": "02:26.350",
      "text": "离开一段开一段新一段",
      "translation": null
    },
    {
      "time": 150.28,
      "time_str": "02:30.280",
      "text": "人间的圆虽则是不够缘",
      "translation": null
    },
    {
      "time": 154.05,
      "time_str": "02:34.050",
      "text": "而有生一天会遇见",
      "translation": null
    },
    {
      "time": 159.1,
      "time_str": "02:39.100",
      "text": "成为遗憾的小心愿",
      "translation": null
    },
    {
      "time": 161.95,
      "time_str": "02:41.950",
      "text": "诚心许愿一千段都甘愿",
      "translation": null
    },
    {
      "time": 165.8,
      "time_str": "02:45.800",
      "text": "如果保存幸福一段",
      "translation": null
    },
    {
      "time": 169.42,
      "time_str": "02:49.420",
      "text": "这一段 都一样暖",
      "translation": null
    },
    {
      "time": 174.4,
      "time_str": "02:54.400",
      "text": "纵使少一块缺了的圆圈",
      "translation": null
    },
    {
      "time": 180.08,
      "time_str": "03:00.080",
      "text": "悲观的豁达点 给生命望更远",
      "translation": null
    },
    {
      "time": 185.83,
      "time_str": "03:05.830",
      "text": "别介意永远差一点的欢笑",
      "translation": null
    },
    {
      "time": 189.64,
      "time_str": "03:09.640",
      "text": "差一点的温暖差一点好好发展",
      "translation": null
    },
    {
      "time": 195.2,
      "time_str": "03:15.200",
      "text": "小心愿 离开一段开一段新一段",
      "translation": null
    },
    {
      "time": 200.91,
      "time_str": "03:20.910",
      "text": "人间的缘可绘画一个圆",
      "translation": null
    },
    {
      "time": 204.77,
      "time_str": "03:24.770",
      "text": "从前那一些小缺陷会令世界美满点",
      "translation": null
    },
    {
      "time": 209.79,
      "time_str": "03:29.790",
      "text": "仍然怀着的小心愿",
      "translation": null
    },
    {
      "time": 212.63,
      "time_str": "03:32.630",
      "text": "求新一年多一年新一段",
      "translation": null
    },
    {
      "time": 216.53,
      "time_str": "03:36.530",
      "text": "如果保存幸福一段",
      "translation": null
    },
    {
      "time": 220.07,
      "time_str": "03:40.070",
      "text": "这一段 都一样暖",
      "translation": null
    },
    {
      "time": 224.79,
      "time_str": "03:44.790",
      "text": "至少今天你欠缺的 明天见",
      "translation": null
    }
