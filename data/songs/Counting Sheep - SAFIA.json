{
  "title": "Counting Sheep",
  "title_raw": "Counting Sheep",
  "version": null,
  "artist": "SAFIA",
  "group_key": "counting sheep|safia",
  "writers": {
    "lyricist": "Benjamin Woolner",
    "composer": "SAFIA",
