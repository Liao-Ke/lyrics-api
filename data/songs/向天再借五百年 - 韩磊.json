  "lyrics": [
    {
      "time": 23.7,
      "time_str": "00:23.700",
      "text": "沿着江山起起伏伏温柔的曲线",
      "translation": null
    },
    {
      "time": 31.7,
      "time_str": "00:31.700",
      "text": "放马爱的中原爱的北国和江南",
      "translation": null
    },
    {
      "time": 39.699,
      "time_str": "00:39.699",
      "text": "面对冰刀雪剑风雨多情的陪伴",
      "translation": null
    },
    {
      "time": 48.699,
      "time_str": "00:48.699",
      "text": "珍惜苍天赐给我的金色的华年",
      "translation": null
    },
    {
      "time": 54.699,
      "time_str": "00:54.699",
      "text": "做人一地肝胆 做人何惧艰险",
      "translation": null
    },
    {
      "time": 61.098,
      "time_str": "01:01.098",
      "text": "豪情不变年复一年",
      "translation": null
    },
    {
      "time": 62.699,
      "time_str": "01:02.699",
      "text": "做人有苦有甜 善恶分开两边",
      "translation": null
    },
    {
      "time": 69.198,
      "time_str": "01:09.198",
      "text": "都为梦中的明天",
      "translation": null
    },
    {
      "time": 72.699,
      "time_str": "01:12.699",
      "text": "看铁蹄铮铮 踏遍万里河山",
      "translation": null
    },
    {
      "time": 80.699,
      "time_str": "01:20.699",
      "text": "我站在风口浪尖紧握住日月旋转",
      "translation": null
    },
    {
      "time": 89.699,
      "time_str": "01:29.699",
      "text": "愿烟火人间 安得太平美满",
      "translation": null
    },
    {
      "time": 97.699,
      "time_str": "01:37.699",
      "text": "我真的还想再活五百年",
      "translation": null
    },
    {
