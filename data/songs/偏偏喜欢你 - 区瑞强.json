  "lyrics": [
    {
      "time": 14.45,
      "time_str": "00:14.450",
      "text": "愁绪挥不去苦闷散不去",
      "translation": null
    },
    {
      "time": 20.47,
      "time_str": "00:20.470",
      "text": "为何我心一片空虚",
      "translation": null
    },
    {
      "time": 26.65,
      "time_str": "00:26.650",
      "text": "感情已失去一切都失去",
      "translation": null
    },
    {
      "time": 33.14,
      "time_str": "00:33.140",
      "text": "满腔恨愁不可消除",
      "translation": null
    },
    {
      "time": 39.08,
      "time_str": "00:39.080",
      "text": "为何你的嘴里总是那一句",
      "translation": null
    },
    {
      "time": 45.13,
      "time_str": "00:45.130",
      "text": "为何我的心不会死",
      "translation": null
    },
    {
      "time": 50.82,
      "time_str": "00:50.820",
      "text": "明白到爱失去一切都失去",
      "translation": null
    },
    {
      "time": 57.26,
      "time_str": "00:57.260",
      "text": "我又为何偏偏喜欢你",
      "translation": null
    },
    {
      "time": 63.04,
      "time_str": "01:03.040",
      "text": "爱已是负累",
      "translation": null
    },
    {
      "time": 66.8,
      "time_str": "01:06.800",
      "text": "相爱似受罪",
      "translation": null
    },
    {
      "time": 70.44,
      "time_str": "01:10.440",
      "text": "心底如今满苦泪",
      "translation": null
    },
    {
      "time": 76.36,
      "time_str": "01:16.360",
      "text": "旧日情如醉此际怕再追",
      "translation": null
    },
    {
      "time": 83.26,
      "time_str": "01:23.260",
      "text": "偏偏痴心想见你",
      "translation": null
    },
    {
      "time": 89.06,
      "time_str": "01:29.060",
      "text": "为何我心分秒想着过去",
      "translation": null
    },
    {
      "time": 95.26,
      "time_str": "01:35.260",
      "text": "为何你一点都不记起",
      "translation": null
    },
    {
      "time": 100.68,
      "time_str": "01:40.680",
      "text": "情义已失去恩爱都失去",
      "translation": null
    },
    {
      "time": 107.35,
      "time_str": "01:47.350",
      "text": "我却为何偏偏喜欢你",
