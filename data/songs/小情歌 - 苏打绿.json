    {
      "time": 29.67,
      "time_str": "00:29.670",
      "text": "这是一首简单的小情歌",
      "translation": null
    },
    {
      "time": 36.85,
      "time_str": "00:36.850",
      "text": "唱着人们心肠的曲折",
      "translation": null
    },
    {
      "time": 42.99,
      "time_str": "00:42.990",
      "text": "我想我很快乐",
      "translation": null
    },
    {
      "time": 46.67,
      "time_str": "00:46.670",
      "text": "当有你的温热",
      "translation": null
    },
    {
      "time": 50.91,
      "time_str": "00:50.910",
      "text": "脚边的空气转了",
      "translation": null
    },
    {
      "time": 73.278,
      "time_str": "01:13.278",
      "text": "这是一首简单的小情歌",
      "translation": null
    },
    {
      "time": 80.59,
      "time_str": "01:20.590",
      "text": "唱着我们心头的白鸽",
      "translation": null
    },
    {
      "time": 86.76,
      "time_str": "01:26.760",
      "text": "我想我很适合",
      "translation": null
    },
    {
      "time": 90.358,
      "time_str": "01:30.358",
      "text": "当一个歌颂者",
      "translation": null
    },
    {
      "time": 94.65,
      "time_str": "01:34.650",
      "text": "青春在风中飘着",
      "translation": null
    },
    {
      "time": 101.29,
      "time_str": "01:41.290",
      "text": "你知道就算大雨让整座城市颠倒",
      "translation": null
    },
    {
      "time": 106.18,
      "time_str": "01:46.180",
      "text": "我会给你怀抱",
      "translation": null
    },
    {
      "time": 108.61,
      "time_str": "01:48.610",
      "text": "受不了看见你背影来到",
      "translation": null
    },
    {
      "time": 112.129,
      "time_str": "01:52.129",
      "text": "写下我度秒如年难捱的离骚",
      "translation": null
    },
    {
      "time": 116.87,
      "time_str": "01:56.870",
      "text": "就算整个世界被寂寞绑票",
      "translation": null
    },
    {
      "time": 120.599,
      "time_str": "02:00.599",
      "text": "我也不会奔跑",
      "translation": null
    },
    {
      "time": 123.09,
      "time_str": "02:03.090",
      "text": "逃不了最后谁也都苍老",
