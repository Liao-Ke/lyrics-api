  "lyrics": [
    {
      "time": 67.43,
      "time_str": "01:07.430",
      "text": "初一到十五 十五的月儿高",
      "translation": null
    },
    {
      "time": 74.89,
      "time_str": "01:14.890",
      "text": "那春风摆动 杨呀么杨柳捎",
      "translation": null
    },
    {
      "time": 90.79,
      "time_str": "01:30.790",
      "text": "三月桃花开 情人捎书来",
      "translation": null
    },
    {
      "time": 98.34,
      "time_str": "01:38.340",
      "text": "捎书书带信信 要一个荷包袋",
      "translation": null
    },
    {
      "time": 137.59,
      "time_str": "02:17.590",
      "text": "一绣一只船 船上撑着帆",
      "translation": null
    },
    {
      "time": 145.04,
      "time_str": "02:25.040",
      "text": "里面的意思 情郎呀你去猜",
      "translation": null
    },
    {
      "time": 161.05,
      "time_str": "02:41.050",
      "text": "二绣鸳鸯鸟 栖息在河边",
      "translation": null
    },
    {
      "time": 168.55,
      "time_str": "02:48.550",
      "text": "你依依我靠靠 永远吗不分开",
      "translation": null
    },
    {
      "time": 207.65,
      "time_str": "03:27.650",
      "text": "郎是年轻汉 妹如花初开",
      "translation": null
    },
    {
      "time": 215.4,
      "time_str": "03:35.400",
      "text": "收到这荷包袋 郎你要早回来",
      "translation": null
    },
    {
