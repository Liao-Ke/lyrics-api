    {
      "time": 17.41,
      "time_str": "00:17.410",
      "text": "你给的甜蜜的伤口",
      "translation": null
    },
    {
      "time": 21.33,
      "time_str": "00:21.330",
      "text": "陪着我停停又走走",
      "translation": null
    },
    {
      "time": 25.03,
      "time_str": "00:25.030",
      "text": "那些爱过的理由原来是借口",
      "translation": null
    },
    {
      "time": 33.37,
      "time_str": "00:33.370",
      "text": "我只能独自离开",
      "translation": null
    },
    {
      "time": 35.32,
      "time_str": "00:35.320",
      "text": "去一个没有回忆的城市",
      "translation": null
    },
    {
      "time": 40.4,
      "time_str": "00:40.400",
      "text": "我删掉你的照片",
      "translation": null
    },
    {
      "time": 42.5,
      "time_str": "00:42.500",
      "text": "却还是忘不掉你的样子",
      "translation": null
    },
    {
      "time": 48.26,
      "time_str": "00:48.260",
      "text": "有些痛无法忘记",
      "translation": null
    },
    {
      "time": 49.91,
      "time_str": "00:49.910",
      "text": "有些事情非得已",
      "translation": null
    },
    {
      "time": 51.88,
      "time_str": "00:51.880",
      "text": "有些梦并不是想象中好美丽",
      "translation": null
    },
    {
      "time": 55.4,
      "time_str": "00:55.400",
      "text": "当爱已无法继续",
      "translation": null
    },
    {
      "time": 57.42,
      "time_str": "00:57.420",
      "text": "谁又舍得放弃",
      "translation": null
    },
    {
