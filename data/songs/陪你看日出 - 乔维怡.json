    {
      "time": 36.45,
      "time_str": "00:36.450",
      "text": "雨的气息是回家的小路",
      "translation": null
    },
    {
      "time": 42.64,
      "time_str": "00:42.640",
      "text": "路上有我追着你的脚步",
      "translation": null
    },
    {
      "time": 48.83,
      "time_str": "00:48.830",
      "text": "脚下边保存着昨天的温度",
      "translation": null
    },
    {
      "time": 55.33,
      "time_str": "00:55.330",
      "text": "你抱着我就像温暖的大树",
      "translation": null
    },
    {
      "time": 62.14,
      "time_str": "01:02.140",
      "text": "雨下了走好路",
      "translation": null
    },
    {
      "time": 65.76,
      "time_str": "01:05.760",
      "text": "这句话我记住",
      "translation": null
    },
    {
      "time": 69.89,
      "time_str": "01:09.890",
      "text": "风再大吹不走祝福",
      "translation": null
    },
    {
      "time": 75.14,
      "time_str": "01:15.140",
      "text": "雨过了就有路",
      "translation": null
    },
    {
      "time": 78.58,
      "time_str": "01:18.580",
      "text": "像那年看日出",
      "translation": null
    },
    {
      "time": 82.39,
      "time_str": "01:22.390",
      "text": "你牵着我穿过了雾",
      "translation": null
    },
    {
      "time": 88.84,
      "time_str": "01:28.840",
      "text": "叫我看希望就在黑夜的尽处",
      "translation": null
    },
    {
      "time": 109.58,
      "time_str": "01:49.580",
      "text": "哭过的眼看岁月更清楚",
      "translation": null
    },
    {
      "time": 115.96,
      "time_str": "01:55.960",
      "text": "想一个人闪着泪光是一种幸福",
      "translation": null
    },
    {
