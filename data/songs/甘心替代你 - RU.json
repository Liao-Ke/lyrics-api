    {
      "time": 5.0,
      "time_str": "00:05.000",
      "text": "歌曲已获正版授权",
      "translation": null
    },
    {
      "time": 6.0,
      "time_str": "00:06.000",
      "text": "不管天边风已起",
      "translation": null
    },
    {
      "time": 10.0,
      "time_str": "00:10.000",
      "text": "只想依依看着你",
      "translation": null
    },
    {
      "time": 13.0,
      "time_str": "00:13.000",
      "text": "夜阑人静会否仍可希冀",
      "translation": null
    },
    {
      "time": 19.0,
      "time_str": "00:19.000",
      "text": "经得起忧伤与悲",
      "translation": null
    },
    {
      "time": 23.0,
      "time_str": "00:23.000",
      "text": "只因心中有着你",
      "translation": null
    },
    {
      "time": 27.0,
      "time_str": "00:27.000",
      "text": "路遥长夜记忆从不舍弃",
      "translation": null
    },
    {
      "time": 33.0,
      "time_str": "00:33.000",
      "text": "长街的身影 穿过风雨有傲气",
      "translation": null
    },
    {
      "time": 38.0,
      "time_str": "00:38.000",
      "text": "曾一起出走不怕闯进了绝地",
      "translation": null
    },
    {
      "time": 45.0,
      "time_str": "00:45.000",
      "text": "如雾如烟 全像游戏",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "仿佛天和地在挑选我跟你",
      "translation": null
    },
    {
      "time": 61.0,
      "time_str": "01:01.000",
      "text": "如像我亦重遇了生死",
      "translation": null
    },
    {
      "time": 68.0,
      "time_str": "01:08.000",
      "text": "难道只好淌泪心痛告别你",
      "translation": null
    },
    {
      "time": 74.0,
      "time_str": "01:14.000",
      "text": "无法让我此际替代你",
