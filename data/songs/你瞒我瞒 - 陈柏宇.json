  "lyrics": [
    {
      "time": 19.375,
      "time_str": "00:19.375",
      "text": "约会像是为 分享到饱肚滋味",
      "translation": null
    },
    {
      "time": 25.726,
      "time_str": "00:25.726",
      "text": "有任何难题 却不提起",
      "translation": null
    },
    {
      "time": 32.054,
      "time_str": "00:32.054",
      "text": "这若是浪漫 我怎么觉得就快分离",
      "translation": null
    },
    {
      "time": 37.909,
      "time_str": "00:37.909",
      "text": "你哭过 但眼影闪得更艳美",
      "translation": null
    },
    {
      "time": 44.627,
      "time_str": "00:44.627",
      "text": "我是谁情人 你始终也是你",
      "translation": null
    },
    {
      "time": 50.577,
      "time_str": "00:50.577",
      "text": "微笑静默互望 笑比哭更可悲",
      "translation": null
    },
    {
      "time": 57.196,
      "time_str": "00:57.196",
      "text": "就算怎开心皱着眉",
      "translation": null
    },
    {
      "time": 60.428,
      "time_str": "01:00.428",
      "text": "尽管紧紧抱得稳你",
      "translation": null
    },
    {
      "time": 63.939,
      "time_str": "01:03.939",
      "text": "两臂 却分得开我共你",
      "translation": null
    },
    {
      "time": 69.425,
      "time_str": "01:09.425",
      "text": "无言的亲亲亲 侵袭我心",
      "translation": null
    },
    {
      "time": 75.735,
      "time_str": "01:15.735",
      "text": "仍宁愿亲口讲你累得很",
      "translation": null
    },
    {
      "time": 82.096,
      "time_str": "01:22.096",
      "text": "如除我以外在你心",
      "translation": null
    },
    {
      "time": 85.978,
      "time_str": "01:25.978",
      "text": "还多出一个人 你瞒住我",
      "translation": null
    },
    {
      "time": 91.16,
      "time_str": "01:31.160",
      "text": "我亦 瞒住我 太合衬",
      "translation": null
    },
    {
      "time": 107.784,
      "time_str": "01:47.784",
      "text": "这就是谈情 客气得吓着我",
      "translation": null
    },
    {
      "time": 113.598,
      "time_str": "01:53.598",
      "text": "除了近来繁忙 我所知有几多",
      "translation": null
    },
    {
      "time": 120.327,
      "time_str": "02:00.327",
      "text": "若要哭不哭诉为何",
      "translation": null
    },
    {
      "time": 123.594,
      "time_str": "02:03.594",
      "text": "大家争吵斗嘴好过",
      "translation": null
    },
    {
      "time": 126.987,
      "time_str": "02:06.987",
      "text": "胜过 笑不出声抱着我",
      "translation": null
    },
    {
      "time": 132.503,
      "time_str": "02:12.503",
      "text": "无言的亲亲亲 侵袭我心",
      "translation": null
