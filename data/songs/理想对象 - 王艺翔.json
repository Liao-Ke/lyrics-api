  "lyrics": [
    {
      "time": 20.74,
      "time_str": "00:20.740",
      "text": "我们一起看见了爱情的模样",
      "translation": null
    },
    {
      "time": 25.24,
      "time_str": "00:25.240",
      "text": "一起见证满天的星光",
      "translation": null
    },
    {
      "time": 29.29,
      "time_str": "00:29.290",
      "text": "我用鲜花和勇气酿出芬芳",
      "translation": null
    },
    {
      "time": 33.848,
      "time_str": "00:33.848",
      "text": "等你用日记本来珍藏",
      "translation": null
    },
    {
      "time": 38.88,
      "time_str": "00:38.880",
      "text": "我们一起刻画出快乐的形状",
      "translation": null
    },
    {
      "time": 42.618,
      "time_str": "00:42.618",
      "text": "一起为了日落而感伤",
      "translation": null
    },
    {
      "time": 46.728,
      "time_str": "00:46.728",
      "text": "我在未来路上写下了愿望",
      "translation": null
    },
    {
      "time": 51.318,
      "time_str": "00:51.318",
      "text": "做你环游世界的翅膀",
      "translation": null
    },
    {
      "time": 55.28,
      "time_str": "00:55.280",
      "text": "我最大理想做你的对象",
      "translation": null
    },
    {
      "time": 59.448,
      "time_str": "00:59.448",
      "text": "做你偶尔脆弱时要的坚强",
      "translation": null
    },
    {
      "time": 64.18,
      "time_str": "01:04.180",
      "text": "无论你走在一种坚定或迷茫",
      "translation": null
    },
    {
      "time": 69.368,
      "time_str": "01:09.368",
      "text": "都有我在你身旁",
      "translation": null
    },
    {
      "time": 72.479,
      "time_str": "01:12.479",
      "text": "我所有理想做你的对象",
      "translation": null
    },
    {
      "time": 77.8,
      "time_str": "01:17.800",
      "text": "做你每次贫穷时要的宝藏",
      "translation": null
    },
    {
      "time": 81.529,
      "time_str": "01:21.529",
      "text": "当我们一起经历过单纯沧桑",
      "translation": null
    },
    {
      "time": 86.398,
      "time_str": "01:26.398",
      "text": "会有幸福的泪在脸上",
      "translation": null
    },
