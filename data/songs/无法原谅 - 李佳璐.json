      "time": 1.554,
      "time_str": "00:01.554",
      "text": "无法原谅-李佳璐(Yoko Li)词:新月/秋怡纶/李京曲:刘永宣/朴惠洞",
      "translation": null
    },
    {
      "time": 34.215,
      "time_str": "00:34.215",
      "text": "为所有爱执着的痛",
      "translation": null
    },
    {
      "time": 37.886,
      "time_str": "00:37.886",
      "text": "为所有恨执着的伤",
      "translation": null
    },
    {
      "time": 41.902,
      "time_str": "00:41.902",
      "text": "我已分不清爱与恨是否就这样",
      "translation": null
    },
    {
      "time": 48.677,
      "time_str": "00:48.677",
      "text": "血和眼泪在一起滑落",
      "translation": null
    },
    {
      "time": 52.191,
      "time_str": "00:52.191",
      "text": "我的心破碎风化",
      "translation": null
    },
    {
      "time": 56.211,
      "time_str": "00:56.211",
      "text": "颤抖的手 却无法停止",
      "translation": null
    },
    {
      "time": 61.242,
      "time_str": "01:01.242",
      "text": "无法原谅",
      "translation": null
    },
    {
      "time": 66.262,
      "time_str": "01:06.262",
      "text": "一次次抱着你手不放",
      "translation": null
    },
    {
      "time": 72.034,
      "time_str": "01:12.034",
      "text": "是多么卑微",
      "translation": null
    },
    {
      "time": 75.539,
      "time_str": "01:15.539",
      "text": "挽回你 我垂死的挣扎",
      "translation": null
    },
    {
      "time": 82.557,
      "time_str": "01:22.557",
      "text": "高高在上 紧闭着 你的双唇",
      "translation": null
    },
    {
      "time": 89.835,
      "time_str": "01:29.835",
      "text": "冷酷的眼神眨也不眨",
      "translation": null
    },
    {
      "time": 97.361,
      "time_str": "01:37.361",
      "text": "我们的曾经燃烧成灰烬",
      "translation": null
    },
    {
      "time": 104.171,
      "time_str": "01:44.171",
      "text": "无所谓了吗也许吧",
      "translation": null
    },
    {
      "time": 110.447,
      "time_str": "01:50.447",
      "text": "多残酷的童话",
      "translation": null
    },
    {
      "time": 114.713,
      "time_str": "01:54.713",
      "text": "重复上演 谎言背叛谎言",
      "translation": null
    },
    {
      "time": 121.008,
      "time_str": "02:01.008",
