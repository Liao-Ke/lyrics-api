  "lyrics": [
    {
      "time": 34.91,
      "time_str": "00:34.910",
      "text": "让我的爱伴着你直到永远",
      "translation": null
    },
    {
      "time": 43.3,
      "time_str": "00:43.300",
      "text": "你有没有感觉到我为你担心",
      "translation": null
    },
    {
      "time": 51.32,
      "time_str": "00:51.320",
      "text": "在相对的视线里才发现什么是缘",
      "translation": null
    },
    {
      "time": 60.29,
      "time_str": "01:00.290",
      "text": "你是否也在等待有一个知心爱人",
      "translation": null
    },
    {
      "time": 68.31,
      "time_str": "01:08.310",
      "text": "把你的情记在心里直到永远",
      "translation": null
    },
    {
      "time": 76.1,
      "time_str": "01:16.100",
      "text": "漫漫长路拥有着我不变的心",
      "translation": null
    },
    {
      "time": 84.38,
      "time_str": "01:24.380",
      "text": "在风起的时候让你感受什么是暖",
      "translation": null
    },
    {
      "time": 93.3,
      "time_str": "01:33.300",
      "text": "一生之中最难得有一个知心爱人",
      "translation": null
    },
    {
      "time": 101.229,
      "time_str": "01:41.229",
      "text": "不管是现在",
      "translation": null
    },
    {
      "time": 105.7,
      "time_str": "01:45.700",
      "text": "还是在遥远的未来",
      "translation": null
    },
    {
      "time": 109.46,
      "time_str": "01:49.460",
      "text": "我们彼此都保护好今天的爱",
      "translation": null
    },
    {
      "time": 113.36,
      "time_str": "01:53.360",
      "text": "不管风雨再不再来",
      "translation": null
    },
    {
      "time": 117.35,
      "time_str": "01:57.350",
      "text": "从此不再受伤害",
      "translation": null
    },
    {
      "time": 121.9,
      "time_str": "02:01.900",
      "text": "我的梦不再徘徊",
      "translation": null
    },
    {
      "time": 125.86,
      "time_str": "02:05.860",
      "text": "我们彼此都保存着那份爱",
      "translation": null
    },
