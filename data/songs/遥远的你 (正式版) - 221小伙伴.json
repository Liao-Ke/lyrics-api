  "lyrics": [
    {
      "time": 3.06,
      "time_str": "00:03.060",
      "text": "演唱：221小伙伴（王明明/李鑫然/李尚阳/谷天丰/孔维通/曹翼）",
      "translation": null
    },
    {
      "time": 14.73,
      "time_str": "00:14.730",
      "text": "明明：",
      "translation": null
    },
    {
      "time": 15.2,
      "time_str": "00:15.200",
      "text": "眼角闪起的泪光",
      "translation": null
    },
    {
      "time": 18.77,
      "time_str": "00:18.770",
      "text": "无边无际地游荡",
      "translation": null
    },
    {
      "time": 22.35,
      "time_str": "00:22.350",
      "text": "眉下的一记荒唐",
      "translation": null
    },
    {
      "time": 25.9,
      "time_str": "00:25.900",
      "text": "庸俗地写在脸上",
      "translation": null
    },
    {
      "time": 29.04,
      "time_str": "00:29.040",
      "text": "鑫然：",
      "translation": null
    },
    {
      "time": 29.7,
      "time_str": "00:29.700",
      "text": "犹如一缕阳光",
      "translation": null
    },
    {
      "time": 33.11,
      "time_str": "00:33.110",
      "text": "但却觉得感伤",
      "translation": null
    },
    {
      "time": 36.69,
      "time_str": "00:36.690",
      "text": "记忆挥散不去",
      "translation": null
    },
    {
      "time": 40.26,
      "time_str": "00:40.260",
      "text": "却藏进了 我的诗句",
      "translation": null
    },
    {
      "time": 46.69,
      "time_str": "00:46.690",
      "text": "合：",
      "translation": null
    },
    {
      "time": 47.04,
      "time_str": "00:47.040",
      "text": "七月的风 八月的雨",
      "translation": null
    },
    {
      "time": 50.58,
      "time_str": "00:50.580",
      "text": "卑微的我喜欢遥远的你",
      "translation": null
    },
    {
      "time": 54.17,
      "time_str": "00:54.170",
      "text": "你还未来 怎敢老去",
      "translation": null
    },
    {
      "time": 57.78,
      "time_str": "00:57.780",
      "text": "未来的我和你奉陪到底",
      "translation": null
    },
    {
      "time": 61.32,
      "time_str": "01:01.320",
      "text": "你若同意 我一定去",
      "translation": null
    },
    {
      "time": 64.94,
      "time_str": "01:04.940",
      "text": "可你并不在意我的出席",
      "translation": null
    },
    {
      "time": 68.5,
      "time_str": "01:08.500",
      "text": "你的过去 无法参与",
      "translation": null
    },
    {
      "time": 72.46,
      "time_str": "01:12.460",
      "text": "但我还是 喜欢你",
      "translation": null
    },
    {
      "time": 93.58,
      "time_str": "01:33.580",
      "text": "尚阳：",
      "translation": null
    },
    {
      "time": 93.96,
      "time_str": "01:33.960",
      "text": "我有一把钥匙",
      "translation": null
    },
    {
      "time": 97.52,
      "time_str": "01:37.520",
      "text": "能解开你的故事",
      "translation": null
    },
    {
      "time": 101.06,
      "time_str": "01:41.060",
      "text": "单纯的像个孩子",
      "translation": null
    },
    {
      "time": 104.67,
      "time_str": "01:44.670",
      "text": "偏藏进了 我的诗句",
      "translation": null
