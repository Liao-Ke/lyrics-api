    {
      "time": 28.38,
      "time_str": "00:28.380",
      "text": "你和我就算了吗",
      "translation": null
    },
    {
      "time": 32.59,
      "time_str": "00:32.590",
      "text": "别用沉默代替回答",
      "translation": null
    },
    {
      "time": 36.14,
      "time_str": "00:36.140",
      "text": "陌生的让我害怕",
      "translation": null
    },
    {
      "time": 38.96,
      "time_str": "00:38.960",
      "text": "心像被针扎了一下",
      "translation": null
    },
    {
      "time": 44.15,
      "time_str": "00:44.150",
      "text": "总是不提那句话",
      "translation": null
    },
    {
      "time": 48.64,
      "time_str": "00:48.640",
      "text": "我想你是故意装傻",
      "translation": null
    },
    {
      "time": 51.77,
      "time_str": "00:51.770",
      "text": "不是不懂得表达",
      "translation": null
    },
    {
      "time": 54.52,
      "time_str": "00:54.520",
      "text": "还在等什么说清楚吧",
      "translation": null
    },
    {
      "time": 61.4,
      "time_str": "01:01.400",
      "text": "我想你不是真的爱我",
      "translation": null
    },
    {
      "time": 65.03,
      "time_str": "01:05.030",
      "text": "习惯被忽略不算自由",
      "translation": null
    },
    {
      "time": 69.15,
      "time_str": "01:09.150",
      "text": "相爱的人总是不懂",
      "translation": null
    },
    {
      "time": 72.02,
      "time_str": "01:12.020",
      "text": "为什么真心伤的特别重",
      "translation": null
    },
    {
      "time": 77.09,
