    },
    {
      "time": 84.77,
      "time_str": "01:24.770",
      "text": "其实爱有很多选择",
      "translation": null
    },
    {
      "time": 88.21,
      "time_str": "01:28.210",
      "text": "我也可以给你自由",
      "translation": null
