    {
      "time": 15.11,
      "time_str": "00:15.110",
      "text": "固执押韵的排比",
      "translation": null
    },
    {
      "time": 18.86,
      "time_str": "00:18.860",
      "text": "固执幼稚的押韵",
      "translation": null
    },
    {
      "time": 22.15,
      "time_str": "00:22.150",
      "text": "零零散散凑齐了阵营",
      "translation": null
    },
    {
      "time": 29.66,
      "time_str": "00:29.660",
      "text": "固执美丽的意义",
      "translation": null
    },
    {
      "time": 33.54,
      "time_str": "00:33.540",
      "text": "固执空洞的美丽",
      "translation": null
    },
    {
      "time": 37.08,
      "time_str": "00:37.080",
      "text": "飘飘然然空中遇见你",
      "translation": null
    },
    {
      "time": 43.83,
      "time_str": "00:43.830",
      "text": "你是我未曾拥有无法捕捉的亲昵",
      "translation": null
    },
    {
      "time": 47.59,
      "time_str": "00:47.590",
      "text": "我却有你的吻你的魂你的心",
      "translation": null
    },
    {
      "time": 51.34,
      "time_str": "00:51.340",
      "text": "载着我飞呀飞呀飞 越过了意义",
      "translation": null
    },
    {
      "time": 58.59,
      "time_str": "00:58.590",
      "text": "你是我朝夕相伴触手可及的虚拟",
      "translation": null
    },
    {
      "time": 62.34,
      "time_str": "01:02.340",
      "text": "陪着我像纸笔像自己像雨滴",
      "translation": null
    },
    {
      "time": 66.09,
      "time_str": "01:06.090",
      "text": "看着我坠啊坠啊坠落到云里",
      "translation": null
    },
    {
      "time": 81.63,
      "time_str": "01:21.630",
      "text": "固执有趣的零星",
      "translation": null
    },
    {
      "time": 84.87,
      "time_str": "01:24.870",
      "text": "固执无聊的有趣",
      "translation": null
    },
    {
      "time": 88.88,
      "time_str": "01:28.880",
      "text": "平平淡淡管住了情绪",
      "translation": null
