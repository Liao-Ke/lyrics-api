  "lyrics": [
    {
      "time": 11.73,
      "time_str": "00:11.730",
      "text": "(于莎莎)想念伴着天空蓝",
      "translation": null
    },
    {
      "time": 14.63,
      "time_str": "00:14.630",
      "text": "晨光到向晚",
      "translation": null
    },
    {
      "time": 16.96,
      "time_str": "00:16.960",
      "text": "旅行相册的里面",
      "translation": null
    },
    {
      "time": 19.71,
      "time_str": "00:19.710",
      "text": "有人笑得多疯癫",
      "translation": null
    },
    {
      "time": 22.18,
      "time_str": "00:22.180",
      "text": "(魏晨)口袋中的明信片",
      "translation": null
    },
    {
      "time": 25.06,
      "time_str": "00:25.060",
      "text": "贴着心的暖",
      "translation": null
    },
    {
      "time": 27.22,
      "time_str": "00:27.220",
      "text": "手心甜蜜的指环",
      "translation": null
    },
    {
      "time": 30.13,
      "time_str": "00:30.130",
      "text": "我忐忑的不安",
      "translation": null
    },
    {
      "time": 33.64,
      "time_str": "00:33.640",
      "text": "（于莎莎）从现在 会习惯",
      "translation": null
    },
    {
      "time": 36.55,
      "time_str": "00:36.550",
      "text": "将幸福给你保管",
      "translation": null
    },
    {
      "time": 39.18,
      "time_str": "00:39.180",
      "text": "(魏晨)把绚烂 变平凡",
      "translation": null
    },
    {
      "time": 41.97,
      "time_str": "00:41.970",
      "text": "不让一个人落单",
      "translation": null
    },
    {
      "time": 44.38,
      "time_str": "00:44.380",
      "text": "(于莎莎)我喜欢 你平淡",
      "translation": null
    },
    {
      "time": 46.77,
      "time_str": "00:46.770",
      "text": "却不冷却的温暖",
      "translation": null
    },
    {
      "time": 49.6,
      "time_str": "00:49.600",
      "text": "（魏晨）让你坐 我身边",
      "translation": null
    },
    {
      "time": 52.33,
      "time_str": "00:52.330",
      "text": "我最情愿的负担",
      "translation": null
    },
    {
      "time": 74.36,
      "time_str": "01:14.360",
      "text": "(于莎莎)转弯书店镜子前",
