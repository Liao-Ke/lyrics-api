    {
      "time": 25.45,
      "time_str": "00:25.450",
      "text": "有些人爱到忘了形",
      "translation": null
    },
    {
      "time": 28.45,
      "time_str": "00:28.450",
      "text": "结果落的一败涂地",
      "translation": null
    },
    {
      "time": 33.48,
      "time_str": "00:33.480",
      "text": "有些人永远在憧憬",
      "translation": null
    },
    {
      "time": 36.97,
      "time_str": "00:36.970",
      "text": "却只差一步距离",
      "translation": null
    },
    {
      "time": 41.39,
      "time_str": "00:41.390",
      "text": "问世间什么最美丽",
      "translation": null
    },
    {
      "time": 44.49,
      "time_str": "00:44.490",
      "text": "爱情绝对是个奇迹",
      "translation": null
    },
    {
      "time": 49.44,
      "time_str": "00:49.440",
      "text": "我明白会有一颗心",
      "translation": null
    },
    {
      "time": 52.99,
      "time_str": "00:52.990",
      "text": "在远方等我靠近",
      "translation": null
    },
    {
      "time": 56.74,
      "time_str": "00:56.740",
      "text": "Oh 我要找到你 不管南北东西",
      "translation": null
    },
    {
      "time": 60.94,
      "time_str": "01:00.940",
      "text": "直觉会给我指引",
      "translation": null
    },
    {
      "time": 64.97,
      "time_str": "01:04.970",
      "text": "若是爱上你 别问什么原因",
      "translation": null
    },
    {
      "time": 68.96,
      "time_str": "01:08.960",
      "text": "第一眼就能够认出你",
      "translation": null
    },
    {
      "time": 72.67,
      "time_str": "01:12.670",
      "text": "Oh 我要找到你 喊出你的名字",
      "translation": null
    },
    {
      "time": 76.97,
      "time_str": "01:16.970",
      "text": "打开幸福的盒子",
      "translation": null
