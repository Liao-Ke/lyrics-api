    {
      "time": 165.616,
      "time_str": "02:45.616",
      "text": "所以南北的路从此不再漫长",
      "translation": null
    },
    {
      "time": 170.448,
      "time_str": "02:50.448",
      "text": "灵魂不再无处安放",
      "translation": null
    },
    {
      "time": 181.235,
      "time_str": "03:01.235",
      "text": "一杯敬明天 一杯敬过往",
      "translation": null
    },
    {
      "time": 185.448,
      "time_str": "03:05.448",
      "text": "支撑我的身体 厚重了肩膀",
      "translation": null
    },
    {
      "time": 189.182,
      "time_str": "03:09.182",
      "text": "虽然从不相信所谓山高水长",
      "translation": null
    },
    {
      "time": 194.006,
      "time_str": "03:14.006",
      "text": "人生苦短何必念念不忘",
      "translation": null
    },
    {
      "time": 198.366,
      "time_str": "03:18.366",
      "text": "一杯敬自由 一杯敬死亡",
      "translation": null
    },
    {
      "time": 202.599,
      "time_str": "03:22.599",
      "text": "宽恕我的平凡 驱散了迷惘",
      "translation": null
    },
    {
      "time": 206.365,
      "time_str": "03:26.365",
      "text": "好吧天亮之后总是潦草离场",
      "translation": null
    },
    {
