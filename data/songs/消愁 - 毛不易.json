  "lyrics": [
    {
      "time": 31.626,
      "time_str": "00:31.626",
      "text": "当你走进这欢乐场",
      "translation": null
    },
    {
      "time": 35.809,
      "time_str": "00:35.809",
      "text": "背上所有的梦与想",
      "translation": null
    },
    {
      "time": 40.096,
      "time_str": "00:40.096",
      "text": "各色的脸上各色的妆",
      "translation": null
    },
    {
      "time": 44.392,
      "time_str": "00:44.392",
      "text": "没人记得你的模样",
      "translation": null
    },
    {
      "time": 48.679,
      "time_str": "00:48.679",
      "text": "三巡酒过你在角落",
      "translation": null
    },
    {
      "time": 52.947,
      "time_str": "00:52.947",
      "text": "固执的唱着苦涩的歌",
      "translation": null
    },
    {
      "time": 57.198,
      "time_str": "00:57.198",
      "text": "听它在喧嚣里被淹没",
      "translation": null
    },
    {
      "time": 61.143,
      "time_str": "01:01.143",
      "text": "你拿起酒杯对自己说",
      "translation": null
    },
    {
      "time": 67.825,
      "time_str": "01:07.825",
      "text": "一杯敬朝阳 一杯敬月光",
      "translation": null
    },
    {
      "time": 71.847,
      "time_str": "01:11.847",
      "text": "唤醒我的向往 温柔了寒窗",
      "translation": null
    },
    {
      "time": 75.599,
      "time_str": "01:15.599",
      "text": "于是可以不回头地逆风飞翔",
      "translation": null
    },
    {
      "time": 80.421,
      "time_str": "01:20.421",
      "text": "不怕心头有雨 眼底有霜",
      "translation": null
    },
    {
      "time": 84.774,
      "time_str": "01:24.774",
      "text": "一杯敬故乡 一杯敬远方",
      "translation": null
    },
    {
      "time": 88.977,
      "time_str": "01:28.977",
      "text": "守着我的善良 催着我成长",
      "translation": null
    },
    {
      "time": 92.813,
      "time_str": "01:32.813",
      "text": "所以南北的路从此不再漫长",
      "translation": null
    },
    {
      "time": 97.599,
      "time_str": "01:37.599",
      "text": "灵魂不再无处安放",
      "translation": null
    },
    {
      "time": 123.441,
      "time_str": "02:03.441",
      "text": "躁动不安的座上客",
      "translation": null
    },
    {
      "time": 127.561,
      "time_str": "02:07.561",
      "text": "自以为是地表演着",
      "translation": null
    },
    {
      "time": 132.099,
      "time_str": "02:12.099",
      "text": "伪装着 舞蹈着 疲惫着",
      "translation": null
    },
    {
      "time": 135.645,
      "time_str": "02:15.645",
      "text": "你拿起酒杯对自己说",
      "translation": null
    },
    {
      "time": 140.495,
      "time_str": "02:20.495",
      "text": "一杯敬朝阳 一杯敬月光",
      "translation": null
    },
    {
