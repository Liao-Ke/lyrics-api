  "lyrics": [
    {
      "time": 24.185,
      "time_str": "00:24.185",
      "text": "羞答答的玫瑰静悄悄地开",
      "translation": null
    },
    {
      "time": 29.157,
      "time_str": "00:29.157",
      "text": "慢慢地绽放她留给我的情怀",
      "translation": null
    },
    {
      "time": 34.4,
      "time_str": "00:34.400",
      "text": "春天的手呀翻阅她的等待",
      "translation": null
    },
    {
      "time": 38.6,
      "time_str": "00:38.600",
      "text": "我在暗暗思量该不该将她轻轻地摘",
      "translation": null
    },
    {
      "time": 44.0,
      "time_str": "00:44.000",
      "text": "羞答答的玫瑰静悄悄地开",
      "translation": null
    },
    {
      "time": 48.17,
      "time_str": "00:48.170",
      "text": "慢慢地燃烧她不承认的情怀",
      "translation": null
    },
    {
      "time": 53.6,
      "time_str": "00:53.600",
      "text": "清风的手呀试探她的等待",
      "translation": null
    },
    {
      "time": 57.14,
      "time_str": "00:57.140",
      "text": "我在暗暗犹豫该不该将她轻轻地摘",
      "translation": null
    },
    {
      "time": 64.248,
      "time_str": "01:04.248",
      "text": "怎么舍得如此接受你的爱",
      "translation": null
    },
    {
      "time": 68.3,
      "time_str": "01:08.300",
      "text": "从来喜欢都会被爱成悲哀",
      "translation": null
    },
    {
      "time": 74.0,
      "time_str": "01:14.000",
      "text": "怎么舍得如此揽你入胸怀",
      "translation": null
    },
    {
      "time": 78.33,
      "time_str": "01:18.330",
      "text": "当我越是深爱脾气就会越坏",
      "translation": null
    },
    {
      "time": 83.8,
      "time_str": "01:23.800",
      "text": "羞答答的玫瑰静悄悄地开",
      "translation": null
    },
    {
      "time": 88.289,
      "time_str": "01:28.289",
      "text": "慢慢地同时凋零同时盛开",
      "translation": null
    },
    {
      "time": 93.1,
      "time_str": "01:33.100",
      "text": "爱情的手呀抚过她的等待",
      "translation": null
    },
    {
      "time": 96.8,
      "time_str": "01:36.800",
      "text": "我在暗暗惆怅竟不曾将她轻轻地摘",
      "translation": null
    },
