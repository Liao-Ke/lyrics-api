  },
  "lyrics": [
    {
      "time": 0.15,
      "time_str": "00:00.150",
      "text": "“不是说好拥抱过后 两个人就一起放手”",
      "translation": null
    },
    {
      "time": 20.15,
      "time_str": "00:20.150",
      "text": "小暖： 都说好 下个路口就分手",
      "translation": null
    },
    {
      "time": 23.16,
      "time_str": "00:23.160",
      "text": "谁也不许再次回过头",
      "translation": null
    },
    {
      "time": 26.4,
      "time_str": "00:26.400",
      "text": "两个人沿着街一直走",
      "translation": null
    },
    {
      "time": 28.97,
      "time_str": "00:28.970",
      "text": "谁也不能够停留",
      "translation": null
    },
    {
      "time": 31.53,
      "time_str": "00:31.530",
      "text": "为什么 又是下一个路口",
      "translation": null
    },
    {
      "time": 34.29,
      "time_str": "00:34.290",
      "text": "但是我们依然牵着手",
      "translation": null
    },
    {
      "time": 37.5,
      "time_str": "00:37.500",
      "text": "求求你不要再看着我",
      "translation": null
    },
    {
      "time": 39.86,
      "time_str": "00:39.860",
      "text": "我怕我控制不了",
      "translation": null
    },
    {
      "time": 42.91,
      "time_str": "00:42.910",
      "text": "徐良： 说好要和平分手",
      "translation": null
    },
    {
      "time": 45.31,
      "time_str": "00:45.310",
      "text": "没有选择的你我",
      "translation": null
    },
    {
      "time": 48.14,
      "time_str": "00:48.140",
      "text": "我们微笑约定 沉默接受 彼此更成熟",
      "translation": null
    },
    {
      "time": 53.72,
      "time_str": "00:53.720",
      "text": "时间一点点走过",
      "translation": null
    },
    {
      "time": 56.42,
      "time_str": "00:56.420",
      "text": "越来越近的割舍",
      "translation": null
    },
    {
      "time": 59.27,
      "time_str": "00:59.270",
      "text": "意志逐渐崩溃 矜持不见 牵痛了双手",
      "translation": null
    },
    {
      "time": 64.86,
      "time_str": "01:04.860",
      "text": "小暖： 不是说好拥抱过后",
      "translation": null
    },
    {
      "time": 67.6,
      "time_str": "01:07.600",
      "text": "两个人就一起放手",
      "translation": null
    },
    {
      "time": 70.38,
      "time_str": "01:10.380",
      "text": "徐良： 为什么还不走",
      "translation": null
    },
    {
      "time": 71.92,
      "time_str": "01:11.920",
      "text": "因为抱的太久 反而难以承受",
      "translation": null
    },
    {
      "time": 75.85,
      "time_str": "01:15.850",
      "text": "小暖： 不是说好泪不许流",
      "translation": null
    },
    {
      "time": 78.65,
      "time_str": "01:18.650",
      "text": "直到两人转身之后",
      "translation": null
    },
    {
      "time": 81.63,
      "time_str": "01:21.630",
      "text": "徐良： 那声再见为何说不出口",
      "translation": null
    },
    {
      "time": 84.53,
      "time_str": "01:24.530",
      "text": "下一秒停留",
      "translation": null
    },
    {
