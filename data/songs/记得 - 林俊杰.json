    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "原唱 : 张惠妹",
      "translation": null
    },
    {
      "time": 16.98,
      "time_str": "00:16.980",
      "text": "谁还记得是谁先说 永远的爱我",
      "translation": null
    },
    {
      "time": 26.09,
      "time_str": "00:26.090",
      "text": "以前的一句话是我们 以后的伤口",
      "translation": null
    },
    {
      "time": 33.64,
      "time_str": "00:33.640",
      "text": "过了太久没人记得 当初那些温柔",
      "translation": null
    },
    {
      "time": 42.25,
      "time_str": "00:42.250",
      "text": "我和你手牵手说要一起 走到最后",
      "translation": null
    },
    {
      "time": 66.73,
      "time_str": "01:06.730",
      "text": "我们都忘了 这条路走了多久",
      "translation": null
    },
    {
      "time": 75.1,
      "time_str": "01:15.100",
      "text": "心中是清楚的 有一天 有一天都会停的",
      "translation": null
    },
    {
      "time": 83.08,
      "time_str": "01:23.080",
      "text": "让时间说真话 虽然我也害怕",
      "translation": null
    },
    {
      "time": 90.88,
      "time_str": "01:30.880",
      "text": "在天黑了以后 我们都不知道 会不会有以后",
      "translation": null
    },
    {
      "time": 101.76,
      "time_str": "01:41.760",
      "text": "谁还记得是谁先说 永远的爱我",
      "translation": null
    },
    {
      "time": 110.24,
      "time_str": "01:50.240",
      "text": "以前的一句话是我们 以后的伤口",
      "translation": null
    },
    {
      "time": 117.83,
      "time_str": "01:57.830",
      "text": "过了太久没人记得 当初那些温柔",
      "translation": null
    },
    {
      "time": 126.17,
      "time_str": "02:06.170",
      "text": "我和你手牵手说要一起 走到最后",
      "translation": null
    },
    {
      "time": 149.89,
      "time_str": "02:29.890",
      "text": "我们都累了 却没办法往回走",
      "translation": null
    },
    {
      "time": 158.0,
      "time_str": "02:38.000",
      "text": "两颗心都迷惑 怎么说 怎么说都没有救",
      "translation": null
    },
    {
      "time": 166.15,
      "time_str": "02:46.150",
      "text": "亲爱的为什么 也许你也不懂",
      "translation": null
    },
    {
      "time": 174.22,
      "time_str": "02:54.220",
      "text": "两个相爱的人 等着对方先说 想分开的理由",
      "translation": null
    },
    {
      "time": 185.06,
      "time_str": "03:05.060",
      "text": "谁还记得爱情开始变化的时候",
      "translation": null
    },
    {
      "time": 193.53,
      "time_str": "03:13.530",
      "text": "我和你的眼中看见了 不同的天空",
      "translation": null
    },
    {
      "time": 200.99,
      "time_str": "03:20.990",
      "text": "走得太远终于走到 分岔路的路口",
      "translation": null
    },
    {
      "time": 209.3,
      "time_str": "03:29.300",
      "text": "是不是你和我 要有两个 相反的梦",
      "translation": null
    },
