    },
    {
      "time": 95.0,
      "time_str": "01:35.000",
      "text": "爱是谁来还谁的债",
      "translation": null
    },
    {
      "time": 102.11,
      "time_str": "01:42.110",
      "text": "决定醒来躲开伤害",
      "translation": null
    },
    {
      "time": 107.91,
      "time_str": "01:47.910",
      "text": "而命运的安排已无法更改",
