    {
      "time": 29.84,
      "time_str": "00:29.840",
      "text": "春去秋来花谢花开",
      "translation": null
    },
    {
      "time": 36.96,
      "time_str": "00:36.960",
      "text": "记忆深埋那片心海",
      "translation": null
    },
    {
      "time": 44.02,
      "time_str": "00:44.020",
      "text": "所谓纠缠只是伤害",
      "translation": null
    },
    {
      "time": 49.82,
      "time_str": "00:49.820",
      "text": "没有人去灌溉一切成黑白",
      "translation": null
    },
    {
      "time": 56.52,
      "time_str": "00:56.520",
      "text": "只是我还放不开",
      "translation": null
    },
    {
      "time": 60.06,
      "time_str": "01:00.060",
      "text": "对你太依赖",
      "translation": null
    },
    {
      "time": 63.59,
      "time_str": "01:03.590",
      "text": "只是我还不能够释怀",
      "translation": null
    },
    {
      "time": 70.75,
      "time_str": "01:10.750",
      "text": "只是我还放不开",
      "translation": null
    },
    {
