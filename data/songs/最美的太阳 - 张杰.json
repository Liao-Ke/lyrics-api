  "lyrics": [
    {
      "time": 43.783,
      "time_str": "00:43.783",
      "text": "我的世界",
      "translation": null
    },
    {
      "time": 47.332,
      "time_str": "00:47.332",
      "text": "因为有你才会美",
      "translation": null
    },
    {
      "time": 50.142,
      "time_str": "00:50.142",
      "text": "我的天空",
      "translation": null
    },
    {
      "time": 53.67,
      "time_str": "00:53.670",
      "text": "因为有你不会黑",
      "translation": null
    },
    {
      "time": 56.578,
      "time_str": "00:56.578",
      "text": "给我快乐",
      "translation": null
    },
    {
      "time": 60.101,
      "time_str": "01:00.101",
      "text": "为我伤心流眼泪",
      "translation": null
    },
    {
      "time": 63.0,
      "time_str": "01:03.000",
      "text": "给我宽容",
      "translation": null
    },
    {
      "time": 66.509,
      "time_str": "01:06.509",
      "text": "让我能展翅高飞",
      "translation": null
    },
    {
      "time": 68.956,
      "time_str": "01:08.956",
      "text": "你的话你的泪",
      "translation": null
    },
    {
      "time": 72.128,
      "time_str": "01:12.128",
      "text": "你的笑你的美",
      "translation": null
    },
    {
      "time": 75.349,
      "time_str": "01:15.349",
      "text": "在我眼中胜过最美的玫瑰",
      "translation": null
    },
    {
      "time": 81.735,
      "time_str": "01:21.735",
      "text": "抱着梦 往前飞",
      "translation": null
    },
    {
      "time": 84.904,
      "time_str": "01:24.904",
      "text": "不逃避 不后退",
      "translation": null
    },
    {
      "time": 88.091,
      "time_str": "01:28.091",
      "text": "你是我成功路上的堡垒",
      "translation": null
    },
    {
      "time": 98.146,
      "time_str": "01:38.146",
      "text": "给我翅膀",
      "translation": null
    },
    {
      "time": 101.929,
      "time_str": "01:41.929",
      "text": "让我可以翱翔",
      "translation": null
    },
    {
      "time": 104.585,
      "time_str": "01:44.585",
      "text": "给我力量",
      "translation": null
    },
    {
      "time": 108.054,
      "time_str": "01:48.054",
      "text": "是你让我变坚强",
      "translation": null
    },
    {
      "time": 110.947,
      "time_str": "01:50.947",
      "text": "不怕受伤",
      "translation": null
    },
    {
      "time": 114.309,
      "time_str": "01:54.309",
      "text": "因为有你在身旁",
      "translation": null
    },
    {
      "time": 116.923,
      "time_str": "01:56.923",
      "text": "你的笑 你的泪",
      "translation": null
    },
    {
      "time": 119.28,
      "time_str": "01:59.280",
      "text": "是我逐梦路上最美的太阳",
