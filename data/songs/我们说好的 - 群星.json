      "time": 16.92,
      "time_str": "00:16.920",
      "text": "好吗一句话就哽住了喉",
      "translation": null
    },
    {
      "time": 23.43,
      "time_str": "00:23.430",
      "text": "城市当背景的海市蜃楼",
      "translation": null
    },
    {
      "time": 30.17,
      "time_str": "00:30.170",
      "text": "我们像分隔成一整个宇宙",
      "translation": null
    },
    {
      "time": 36.95,
      "time_str": "00:36.950",
      "text": "再见都化作乌有",
      "translation": null
    },
    {
      "time": 43.15,
      "time_str": "00:43.150",
      "text": "我们说好决不放开相互牵的手",
      "translation": null
    },
    {
      "time": 50.34,
      "time_str": "00:50.340",
      "text": "可现实说过有爱还不够",
      "translation": null
    },
    {
      "time": 57.34,
      "time_str": "00:57.340",
      "text": "走到分岔的路口",
      "translation": null
    },
    {
      "time": 60.89,
      "time_str": "01:00.890",
      "text": "你向左我向右",
      "translation": null
    },
    {
      "time": 64.44,
      "time_str": "01:04.440",
      "text": "我们都倔强地不曾回头",
