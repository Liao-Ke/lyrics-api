    },
    {
      "time": 14.0,
      "time_str": "00:14.000",
      "text": "助理录音师 : 高濬哲/莫家伟",
      "translation": null
    },
    {
      "time": 16.0,
      "time_str": "00:16.000",
      "text": "SP : Rock Music Publ.(TWN) Co./Ltd.",
      "translation": null
    },
    {
      "time": 18.4,
      "time_str": "00:18.400",
      "text": "真的想 寂寞的时候有个伴",
      "translation": null
    },
    {
      "time": 25.93,
      "time_str": "00:25.930",
      "text": "日子再忙 也有人一起吃早餐",
      "translation": null
    },
    {
      "time": 32.9,
      "time_str": "00:32.900",
      "text": "虽然这种想法 明明就是太简单",
      "translation": null
    },
    {
      "time": 39.95,
      "time_str": "00:39.950",
      "text": "只想有人在一起",
      "translation": null
    },
    {
      "time": 43.44,
      "time_str": "00:43.440",
      "text": "不管明天在哪里",
      "translation": null
    },
    {
      "time": 47.84,
      "time_str": "00:47.840",
      "text": "爱从不容许人三心两意",
      "translation": null
    },
    {
      "time": 54.08,
      "time_str": "00:54.080",
      "text": "遇见浑然天成的交集",
      "translation": null
    },
    {
      "time": 57.58,
      "time_str": "00:57.580",
      "text": "错过多可惜",
      "translation": null
    },
    {
      "time": 61.11,
      "time_str": "01:01.110",
      "text": "如果我是真的 决定付出我的心",
      "translation": null
    },
    {
      "time": 68.02,
      "time_str": "01:08.020",
      "text": "能不能有人告诉他 别让我伤心",
      "translation": null
    },
    {
      "time": 75.06,
      "time_str": "01:15.060",
      "text": "每一次当爱在靠近",
      "translation": null
    },
    {
      "time": 78.16,
      "time_str": "01:18.160",
      "text": "感觉他在紧紧地抱住你",
      "translation": null
    },
    {
      "time": 82.12,
      "time_str": "01:22.120",
      "text": "他骚动你的心",
      "translation": null
    },
    {
      "time": 84.13,
      "time_str": "01:24.130",
      "text": "遮住你的眼睛",
      "translation": null
    },
    {
      "time": 85.89,
      "time_str": "01:25.890",
      "text": "又不让你知道去哪里",
      "translation": null
    },
    {
      "time": 88.88,
      "time_str": "01:28.880",
      "text": "每一次当爱在靠近",
      "translation": null
    },
    {
      "time": 92.24,
      "time_str": "01:32.240",
      "text": "都好像在等你要怎么回应",
      "translation": null
    },
    {
      "time": 96.36,
      "time_str": "01:36.360",
      "text": "天地都安静",
      "translation": null
    },
    {
      "time": 98.23,
      "time_str": "01:38.230",
      "text": "唯一不安的是 你的决定",
