  "lyrics": [
    {
      "time": 25.525,
      "time_str": "00:25.525",
      "text": "故人吟唱 昔日旧歌",
      "translation": null
    },
    {
      "time": 28.373,
      "time_str": "00:28.373",
      "text": "在耳边回响",
      "translation": null
    },
    {
      "time": 31.324,
      "time_str": "00:31.324",
      "text": "岁月长 还借着你的光",
      "translation": null
    },
    {
      "time": 37.37,
      "time_str": "00:37.370",
      "text": "残烛跳荡 热泪煮汤",
      "translation": null
    },
    {
      "time": 40.216,
      "time_str": "00:40.216",
      "text": "昨日梦一场",
      "translation": null
    },
    {
      "time": 43.372,
      "time_str": "00:43.372",
      "text": "这荒唐 是生活的原样",
      "translation": null
    },
    {
      "time": 49.121,
      "time_str": "00:49.121",
      "text": "它让你受折磨 觉得痛 觉得渴",
      "translation": null
    },
    {
      "time": 54.709,
      "time_str": "00:54.709",
      "text": "觉得无路走 无处躲",
      "translation": null
    },
    {
      "time": 58.59,
      "time_str": "00:58.590",
      "text": "无所求也求不得",
      "translation": null
    },
    {
      "time": 61.303,
      "time_str": "01:01.303",
      "text": "当我昏昏欲睡 摇摇欲坠",
      "translation": null
    },
    {
      "time": 65.119,
      "time_str": "01:05.119",
      "text": "却学会 放下错与对 是与非",
      "translation": null
    },
    {
      "time": 70.489,
      "time_str": "01:10.489",
      "text": "无所求必满载而归",
      "translation": null
    },
    {
      "time": 97.389,
      "time_str": "01:37.389",
      "text": "两两相忘 遍体鳞伤",
      "translation": null
    },
    {
      "time": 100.197,
      "time_str": "01:40.197",
      "text": "成长的战场",
      "translation": null
    },
    {
      "time": 103.372,
      "time_str": "01:43.372",
      "text": "我心上 还有个老故乡",
      "translation": null
    },
    {
