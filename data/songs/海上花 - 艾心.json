    {
      "time": 17.5,
      "time_str": "00:17.500",
      "text": "是这般柔情的你",
      "translation": null
    },
    {
      "time": 21.5,
      "time_str": "00:21.500",
      "text": "给我一个梦想",
      "translation": null
    },
    {
      "time": 25.5,
      "time_str": "00:25.500",
      "text": "徜徉在起伏的波浪中盈盈的荡漾",
      "translation": null
    },
    {
      "time": 31.5,
      "time_str": "00:31.500",
      "text": "在你的臂弯",
      "translation": null
    },
    {
      "time": 35.5,
      "time_str": "00:35.500",
      "text": "是这般深情的你",
      "translation": null
    },
    {
      "time": 38.5,
      "time_str": "00:38.500",
      "text": "摇晃我的梦想",
      "translation": null
    },
    {
      "time": 42.5,
      "time_str": "00:42.500",
      "text": "缠绵象海里每一个无名的浪花",
      "translation": null
    },
    {
      "time": 48.5,
      "time_str": "00:48.500",
      "text": "在你的身上",
      "translation": null
    },
    {
      "time": 52.5,
      "time_str": "00:52.500",
      "text": "睡梦成真",
      "translation": null
    },
    {
      "time": 55.5,
      "time_str": "00:55.500",
      "text": "转身浪影汹涌没红尘",
      "translation": null
    },
    {
      "time": 59.5,
      "time_str": "00:59.500",
      "text": "残留水纹  空留遗恨",
      "translation": null
    },
    {
      "time": 62.5,
      "time_str": "01:02.500",
      "text": "愿只愿他生",
      "translation": null
    },
    {
      "time": 66.5,
      "time_str": "01:06.500",
      "text": "昨日的身影能相随",
      "translation": null
    },
    {
      "time": 69.5,
      "time_str": "01:09.500",
      "text": "永生永世不离分",
      "translation": null
    },
    {
      "time": 74.5,
      "time_str": "01:14.500",
      "text": "是这般奇情的你",
      "translation": null
    },
    {
      "time": 78.5,
      "time_str": "01:18.500",
      "text": "粉碎我的梦想",
      "translation": null
    },
    {
      "time": 82.5,
      "time_str": "01:22.500",
      "text": "仿佛象水面泡沫的短暂光亮",
      "translation": null
    },
    {
      "time": 89.5,
      "time_str": "01:29.500",
      "text": "是我的一生",
