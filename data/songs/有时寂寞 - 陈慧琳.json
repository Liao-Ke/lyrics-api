    {
      "time": 7.75,
      "time_str": "00:07.750",
      "text": "Gonna Say Bye Bye",
      "translation": null
    },
    {
      "time": 9.81,
      "time_str": "00:09.810",
      "text": "谈情太似悬崖绝岭",
      "translation": null
    },
    {
      "time": 13.32,
      "time_str": "00:13.320",
      "text": "没有开心可保证",
      "translation": null
    },
    {
      "time": 15.42,
      "time_str": "00:15.420",
      "text": "有时寂寞亦是聪明",
      "translation": null
    },
    {
      "time": 19.61,
      "time_str": "00:19.610",
      "text": "人人会变 人人任性",
      "translation": null
    },
    {
      "time": 23.13,
      "time_str": "00:23.130",
      "text": "热吻不担保高兴",
      "translation": null
    },
    {
      "time": 25.34,
      "time_str": "00:25.340",
      "text": "有时寂寞亦是本领",
      "translation": null
    },
    {
      "time": 39.55,
      "time_str": "00:39.550",
      "text": "一个人 找到的节目 太多",
      "translation": null
    },
    {
      "time": 45.02,
      "time_str": "00:45.020",
      "text": "轻快得想哼歌",
      "translation": null
    },
    {
      "time": 49.91,
      "time_str": "00:49.910",
      "text": "宽慰得自在地消磨",
      "translation": null
    },
    {
      "time": 53.6,
      "time_str": "00:53.600",
      "text": "放心我可温暖得到心窝",
      "translation": null
    },
    {
      "time": 58.6,
      "time_str": "00:58.600",
      "text": "骤眼间我似落寞",
      "translation": null
    },
    {
      "time": 61.14,
      "time_str": "01:01.140",
      "text": "但是时日飞过",
      "translation": null
    },
    {
      "time": 64.26,
      "time_str": "01:04.260",
      "text": "我这哲学都跟恋爱差不多",
      "translation": null
    },
    {
      "time": 69.14,
      "time_str": "01:09.140",
      "text": "人间烟火勿来缠绕我",
      "translation": null
    },
    {
      "time": 73.31,
      "time_str": "01:13.310",
      "text": "撩乱错综 不会是我",
      "translation": null
    },
    {
