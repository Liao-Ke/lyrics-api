  "lyrics": [
    {
      "time": 8.7,
      "time_str": "00:08.700",
      "text": "原唱：一支榴莲",
      "translation": null
    },
    {
      "time": 13.32,
      "time_str": "00:13.320",
      "text": "改编词：唐恬",
      "translation": null
    },
    {
      "time": 23.02,
      "time_str": "00:23.020",
      "text": "散落的月光穿过了云",
      "translation": null
    },
    {
      "time": 30.49,
      "time_str": "00:30.490",
      "text": "躲着人群",
      "translation": null
    },
    {
      "time": 34.46,
      "time_str": "00:34.460",
      "text": "铺成大海的鳞",
      "translation": null
    },
    {
      "time": 37.87,
      "time_str": "00:37.870",
      "text": "海浪打湿白裙",
      "translation": null
    },
    {
      "time": 40.29,
      "time_str": "00:40.290",
      "text": "试图推你回去",
      "translation": null
    },
    {
      "time": 45.57,
      "time_str": "00:45.570",
      "text": "海浪唱摇篮曲",
      "translation": null
    },
    {
      "time": 48.2,
      "time_str": "00:48.200",
      "text": "妄想温暖你",
      "translation": null
    },
    {
      "time": 52.79,
      "time_str": "00:52.790",
      "text": "往海的深处听",
      "translation": null
    },
    {
      "time": 56.72,
      "time_str": "00:56.720",
      "text": "谁的哀鸣在指引",
      "translation": null
    },
    {
      "time": 61.119,
      "time_str": "01:01.119",
      "text": "灵魂没入寂静",
      "translation": null
    },
    {
      "time": 63.719,
      "time_str": "01:03.719",
      "text": "无人将你吵醒",
      "translation": null
    },
    {
      "time": 68.89,
      "time_str": "01:08.890",
      "text": "你喜欢海风咸咸的气息",
      "translation": null
    },
    {
      "time": 71.299,
      "time_str": "01:11.299",
      "text": "踩着湿湿的沙砾",
      "translation": null
    },
    {
      "time": 73.18,
      "time_str": "01:13.180",
      "text": "你说人们的归处应该回大海里",
      "translation": null
    },
    {
      "time": 76.409,
      "time_str": "01:16.409",
      "text": "你问我想念会去哪里",
      "translation": null
    },
    {
      "time": 78.97,
      "time_str": "01:18.970",
      "text": "有没有人爱你",
      "translation": null
    },
    {
      "time": 80.93,
      "time_str": "01:20.930",
      "text": "世界能否不再",
      "translation": null
    },
    {
      "time": 84.409,
      "time_str": "01:24.409",
      "text": "总爱对凉薄的人扯着笑脸",
      "translation": null
    },
    {
      "time": 88.22,
      "time_str": "01:28.220",
      "text": "岸上人们脸上都挂着无关",
      "translation": null
    },
    {
      "time": 92.11,
      "time_str": "01:32.110",
      "text": "人间昙花一现",
      "translation": null
    },
    {
      "time": 94.62,
      "time_str": "01:34.620",
      "text": "一切散为烟",
      "translation": null
    },
    {
      "time": 100.37,
      "time_str": "01:40.370",
      "text": "散落的月光穿过了云",
      "translation": null
    },
    {
      "time": 103.51,
      "time_str": "01:43.510",
      "text": "凝望人群",
      "translation": null
    },
    {
      "time": 104.519,
      "time_str": "01:44.519",
      "text": "我们孤独的心",
      "translation": null
    },
    {
      "time": 106.269,
      "time_str": "01:46.269",
      "text": "有时候像海底",
      "translation": null
    },
    {
      "time": 108.28,
      "time_str": "01:48.280",
      "text": "悲伤不是三言两语",
      "translation": null
    },
    {
      "time": 110.18,
      "time_str": "01:50.180",
      "text": "就能感同身受",
      "translation": null
    },
    {
      "time": 112.19,
      "time_str": "01:52.190",
      "text": "眼泪没有声音",
      "translation": null
    },
    {
      "time": 113.75,
      "time_str": "01:53.750",
      "text": "但我想抱紧你",
      "translation": null
    },
    {
      "time": 116.31,
      "time_str": "01:56.310",
      "text": "你是重要的存在",
      "translation": null
    },
    {
      "time": 118.11,
      "time_str": "01:58.110",
      "text": "是某人的星星",
      "translation": null
    },
    {
      "time": 120.099,
      "time_str": "02:00.099",
      "text": "当你孤身独行",
      "translation": null
    },
    {
      "time": 121.269,
      "time_str": "02:01.269",
      "text": "当你说被爱不过是侥幸",
      "translation": null
    },
    {
      "time": 124.0,
      "time_str": "02:04.000",
      "text": "孩子请你别忘记",
      "translation": null
    },
    {
      "time": 125.23,
      "time_str": "02:05.230",
      "text": "曾有温暖的声音呼唤你的姓名",
      "translation": null
    },
    {
      "time": 127.689,
      "time_str": "02:07.689",
      "text": "你问我路会通往哪里",
      "translation": null
    },
    {
      "time": 129.479,
      "time_str": "02:09.479",
      "text": "路通往我等你",
      "translation": null
    },
    {
      "time": 135.03,
      "time_str": "02:15.030",
      "text": "散落的月光穿过了云",
      "translation": null
    },
    {
      "time": 142.81,
      "time_str": "02:22.810",
      "text": "躲着人群",
      "translation": null
    },
    {
      "time": 146.59,
      "time_str": "02:26.590",
      "text": "溜进海底",
      "translation": null
    },
    {
      "time": 150.039,
      "time_str": "02:30.039",
      "text": "有光正在找你",
      "translation": null
    },
    {
      "time": 152.47,
      "time_str": "02:32.470",
      "text": "它想温暖你",
      "translation": null
    },
    {
      "time": 157.849,
      "time_str": "02:37.849",
      "text": "它说你听你听",
      "translation": null
    },
    {
      "time": 159.949,
      "time_str": "02:39.949",
      "text": "有人唤你回去",
      "translation": null
    },
    {
      "time": 165.349,
      "time_str": "02:45.349",
      "text": "你喜欢海风咸咸的气息",
      "translation": null
    },
    {
      "time": 168.11,
      "time_str": "02:48.110",
      "text": "踩着湿湿的沙砾",
      "translation": null
    },
    {
      "time": 169.96,
      "time_str": "02:49.960",
      "text": "你说人们的归处应该回大海里",
      "translation": null
    },
    {
      "time": 173.11,
      "time_str": "02:53.110",
      "text": "你问我想念会去哪里",
      "translation": null
    },
    {
      "time": 175.729,
      "time_str": "02:55.729",
      "text": "有没有人爱你",
      "translation": null
    },
    {
      "time": 177.66,
      "time_str": "02:57.660",
      "text": "世界为何如此安静",
      "translation": null
    },
    {
      "time": 181.219,
      "time_str": "03:01.219",
      "text": "总爱对凉薄的人扯着笑脸",
      "translation": null
    },
    {
      "time": 185.129,
      "time_str": "03:05.129",
      "text": "岸上人们脸上都挂着明暗",
      "translation": null
    },
    {
      "time": 188.889,
      "time_str": "03:08.889",
      "text": "人间岁岁年年",
      "translation": null
    },
    {
      "time": 191.259,
      "time_str": "03:11.259",
      "text": "谁敢说如烟",
      "translation": null
    },
    {
      "time": 199.81,
      "time_str": "03:19.810",
      "text": "来不及来不及",
      "translation": null
    },
    {
      "time": 203.889,
      "time_str": "03:23.889",
      "text": "你曾笑着哭泣",
      "translation": null
    },
    {
      "time": 207.61,
      "time_str": "03:27.610",
      "text": "来不及来不及",
      "translation": null
    },
    {
      "time": 211.49,
      "time_str": "03:31.490",
      "text": "也要唱给你听",
      "translation": null
    },
    {
      "time": 215.41,
      "time_str": "03:35.410",
      "text": "春日雨夏蝉鸣",
      "translation": null
    },
    {
      "time": 219.33,
      "time_str": "03:39.330",
      "text": "明天是个好天气",
      "translation": null
    },
    {
      "time": 223.12,
      "time_str": "03:43.120",
      "text": "秋风起雪花轻",
      "translation": null
    },
    {
      "time": 227.0,
      "time_str": "03:47.000",
      "text": "海底看不见四季",
      "translation": null
    },
    {
      "time": 235.259,
      "time_str": "03:55.259",
      "text": "音乐总监：刘卓",
      "translation": null
    },
    {
      "time": 237.169,
      "time_str": "03:57.169",
      "text": "乐队总监/program：尹之扬",
      "translation": null
    },
    {
      "time": 241.15,
      "time_str": "04:01.150",
      "text": "贝斯：娄弘荻",
      "translation": null
    },
    {
      "time": 244.37,
      "time_str": "04:04.370",
      "text": "键盘：孙莉",
      "translation": null
    }
  ],
