  "lyrics": [
    {
      "time": 27.58,
      "time_str": "00:27.580",
      "text": "冷风过境 回忆冻结成冰",
      "translation": null
    },
    {
      "time": 32.16,
      "time_str": "00:32.160",
      "text": "我的付出全都要不到回音",
      "translation": null
    },
    {
      "time": 38.08,
      "time_str": "00:38.080",
      "text": "悔恨就像是绵延不断的丘陵",
      "translation": null
    },
    {
      "time": 44.18,
      "time_str": "00:44.180",
      "text": "痛苦全方位的降临",
      "translation": null
    },
    {
      "time": 49.98,
      "time_str": "00:49.980",
      "text": "悲伤入侵 誓言下落不明",
      "translation": null
    },
    {
      "time": 54.78,
      "time_str": "00:54.780",
      "text": "我找不到那些爱过的曾经",
      "translation": null
    },
    {
      "time": 60.91,
      "time_str": "01:00.910",
      "text": "你像在寂寞上空盘旋的秃鹰",
      "translation": null
    },
    {
      "time": 66.8,
      "time_str": "01:06.800",
      "text": "将我想你 啃食干净",
      "translation": null
    },
    {
      "time": 71.84,
      "time_str": "01:11.840",
      "text": "月色摇晃树影",
      "translation": null
    },
    {
      "time": 74.81,
      "time_str": "01:14.810",
      "text": "穿梭在热带雨林",
      "translation": null
    },
    {
      "time": 77.56,
      "time_str": "01:17.560",
      "text": "你离去的原因",
      "translation": null
    },
    {
      "time": 80.14,
      "time_str": "01:20.140",
      "text": "从来不说明",
      "translation": null
    },
    {
      "time": 83.3,
      "time_str": "01:23.300",
      "text": "你的谎像陷阱",
      "translation": null
    },
    {
      "time": 86.07,
      "time_str": "01:26.070",
      "text": "我最后才清醒",
      "translation": null
    },
    {
      "time": 89.61,
      "time_str": "01:29.610",
      "text": "幸福只是水中的倒影",
      "translation": null
    },
    {
      "time": 94.55,
      "time_str": "01:34.550",
      "text": "月色摇晃树影",
      "translation": null
    },
    {
      "time": 97.24,
      "time_str": "01:37.240",
      "text": "穿梭在热带雨林",
      "translation": null
    },
    {
      "time": 100.17,
      "time_str": "01:40.170",
      "text": "悲伤的雨不停",
      "translation": null
    },
    {
      "time": 102.8,
      "time_str": "01:42.800",
      "text": "全身血淋淋",
      "translation": null
    },
    {
      "time": 105.85,
      "time_str": "01:45.850",
      "text": "那深陷在沼泽",
      "translation": null
    },
    {
      "time": 108.62,
      "time_str": "01:48.620",
      "text": "我不堪的爱情",
      "translation": null
    },
    {
      "time": 112.23,
      "time_str": "01:52.230",
      "text": "是我无能为力的伤心",
      "translation": null
    },
