  "lyrics": [
    {
      "time": 23.17,
      "time_str": "00:23.170",
      "text": "风若停了云要怎么飞",
      "translation": null
    },
    {
      "time": 29.17,
      "time_str": "00:29.170",
      "text": "你若走了我要怎么睡",
      "translation": null
    },
    {
      "time": 34.83,
      "time_str": "00:34.830",
      "text": "心若破了你要怎么赔",
      "translation": null
    },
    {
      "time": 39.3,
      "time_str": "00:39.300",
      "text": "若非你只是贪玩的蝴蝶",
      "translation": null
    },
    {
      "time": 52.23,
      "time_str": "00:52.230",
      "text": "天都黑了你在想着谁",
      "translation": null
    },
    {
      "time": 58.08,
      "time_str": "00:58.080",
      "text": "情都灭了我要怎么追",
      "translation": null
    },
    {
      "time": 63.56,
      "time_str": "01:03.560",
      "text": "话都说了你要怎么退",
      "translation": null
    },
    {
      "time": 68.22,
      "time_str": "01:08.220",
      "text": "原来你只会让我掉眼泪",
      "translation": null
    },
    {
      "time": 81.25,
      "time_str": "01:21.250",
      "text": "整个世界突然一起天黑",
      "translation": null
    },
    {
      "time": 87.71,
      "time_str": "01:27.710",
      "text": "爱在眼前无声崩溃",
      "translation": null
    },
    {
      "time": 93.38,
      "time_str": "01:33.380",
      "text": "摔成粉碎",
      "translation": null
    },
    {
      "time": 98.92,
      "time_str": "01:38.920",
      "text": "我闭上眼睛就是天黑",
      "translation": null
    },
    {
      "time": 103.65,
      "time_str": "01:43.650",
      "text": "一种撕裂的感觉",
      "translation": null
    },
    {
      "time": 110.86,
      "time_str": "01:50.860",
      "text": "嘴里泛着血腥滋味",
      "translation": null
    },
    {
      "time": 115.07,
      "time_str": "01:55.070",
      "text": "多么伤的离别",
      "translation": null
    },
    {
      "time": 121.95,
      "time_str": "02:01.950",
      "text": "我承认我最害怕天黑",
      "translation": null
    },
    {
      "time": 126.71,
      "time_str": "02:06.710",
      "text": "梦被掏空的错觉",
      "translation": null
    },
    {
      "time": 133.81,
      "time_str": "02:13.810",
      "text": "我已不再是你的谁",
      "translation": null
    },
    {
      "time": 138.09,
      "time_str": "02:18.090",
      "text": "想到就会心碎",
      "translation": null
