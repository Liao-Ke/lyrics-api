  "lyrics": [
    {
      "time": 19.91,
      "time_str": "00:19.910",
      "text": "消失的光阴散在风里",
      "translation": null
    },
    {
      "time": 24.13,
      "time_str": "00:24.130",
      "text": "彷彿想不起再面对",
      "translation": null
    },
    {
      "time": 27.68,
      "time_str": "00:27.680",
      "text": "流浪日子",
      "translation": null
    },
    {
      "time": 29.6,
      "time_str": "00:29.600",
      "text": "你在伴随",
      "translation": null
    },
    {
      "time": 30.88,
      "time_str": "00:30.880",
      "text": "有缘再聚",
      "translation": null
    },
    {
      "time": 35.37,
      "time_str": "00:35.370",
      "text": "天真的声音已在减退",
      "translation": null
    },
    {
      "time": 39.1,
      "time_str": "00:39.100",
      "text": "彼此为著目标相距",
      "translation": null
    },
    {
      "time": 42.48,
      "time_str": "00:42.480",
      "text": "凝望夜空",
      "translation": null
    },
    {
      "time": 44.0,
      "time_str": "00:44.000",
      "text": "往日是谁",
      "translation": null
    },
    {
      "time": 46.74,
      "time_str": "00:46.740",
      "text": "领会心中疲累",
      "translation": null
    },
    {
      "time": 51.8,
      "time_str": "00:51.800",
      "text": "来忘掉错对",
      "translation": null
    },
    {
      "time": 53.21,
      "time_str": "00:53.210",
      "text": "来怀念过去",
      "translation": null
    },
    {
      "time": 55.59,
      "time_str": "00:55.590",
      "text": "曾共渡患难日子总有乐趣",
      "translation": null
    },
    {
      "time": 59.5,
      "time_str": "00:59.500",
      "text": "不相信会绝望",
      "translation": null
    },
    {
      "time": 61.32,
      "time_str": "01:01.320",
      "text": "不感觉到踌躇",
      "translation": null
    },
    {
      "time": 63.37,
      "time_str": "01:03.370",
      "text": "在美梦里竞争",
      "translation": null
    },
    {
      "time": 64.5,
      "time_str": "01:04.500",
      "text": "每日拼命进取",
      "translation": null
    },
    {
      "time": 67.4,
      "time_str": "01:07.400",
      "text": "奔波的风雨里",
      "translation": null
    },
    {
      "time": 68.59,
      "time_str": "01:08.590",
      "text": "不羁的醒与醉",
      "translation": null
    },
    {
      "time": 70.66,
      "time_str": "01:10.660",
      "text": "所有故事像已发生飘泊岁月里",
      "translation": null
    },
    {
      "time": 74.31,
      "time_str": "01:14.310",
      "text": "风吹过已静下",
      "translation": null
    },
    {
      "time": 76.18,
      "time_str": "01:16.180",
      "text": "将心意再还谁",
      "translation": null
    },
