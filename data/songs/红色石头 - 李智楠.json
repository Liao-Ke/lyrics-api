  "lyrics": [
    {
      "time": 13.35,
      "time_str": "00:13.350",
      "text": "你离开我 真的 不痛",
      "translation": null
    },
    {
      "time": 23.129,
      "time_str": "00:23.129",
      "text": "迷迷糊糊 不懂",
      "translation": null
    },
    {
      "time": 31.698,
      "time_str": "00:31.698",
      "text": "也许在现实生活中 会多一只狗",
      "translation": null
    },
    {
      "time": 37.4,
      "time_str": "00:37.400",
      "text": "也多些无聊寂寞陪伴着我",
      "translation": null
    },
    {
      "time": 41.97,
      "time_str": "00:41.970",
      "text": "我没被打败 也没逃脱",
      "translation": null
    },
    {
      "time": 54.13,
      "time_str": "00:54.130",
      "text": "朋友问我 是的 分手",
      "translation": null
    },
    {
      "time": 65.39,
      "time_str": "01:05.390",
      "text": "不想你走 不说",
      "translation": null
    },
    {
      "time": 71.86,
      "time_str": "01:11.860",
      "text": "我无法在你眼中 那么不知所措",
      "translation": null
    },
    {
      "time": 78.39,
      "time_str": "01:18.390",
      "text": "也无法隐瞒自己那么脆弱",
      "translation": null
    },
    {
      "time": 83.8,
      "time_str": "01:23.800",
      "text": "我只能承认 爱很愚蠢",
      "translation": null
    },
    {
      "time": 93.79,
      "time_str": "01:33.790",
      "text": "你的心就像一颗 红色石头",
      "translation": null
    },
    {
      "time": 99.94,
      "time_str": "01:39.940",
      "text": "有着热情血液 和石头的冰冷",
      "translation": null
    },
    {
      "time": 105.5,
      "time_str": "01:45.500",
      "text": "顽固的把风 抛在背后",
      "translation": null
    },
    {
      "time": 109.36,
      "time_str": "01:49.360",
      "text": "知道你 不会再回头",
      "translation": null
    },
    {
      "time": 114.51,
      "time_str": "01:54.510",
      "text": "你的心就像一颗 红色石头",
      "translation": null
    },
    {
      "time": 120.7,
      "time_str": "02:00.700",
      "text": "将爱情全部打破",
      "translation": null
    },
    {
      "time": 124.92,
      "time_str": "02:04.920",
      "text": "回忆全部没收 留在沙漠",
      "translation": null
    },
    {
      "time": 130.29,
      "time_str": "02:10.290",
      "text": "手中握着一颗 红色石头",
      "translation": null
