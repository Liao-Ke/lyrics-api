    {
      "time": 24.64,
      "time_str": "00:24.640",
      "text": "有了天空 为何世界 还有地心引力",
      "translation": null
    },
    {
      "time": 31.41,
      "time_str": "00:31.410",
      "text": "有了希望 为何绝望 还是如影随形",
      "translation": null
    },
    {
      "time": 37.72,
      "time_str": "00:37.720",
      "text": "有了勇气 就让哭泣 埋藏过去",
      "translation": null
    },
    {
      "time": 43.53,
      "time_str": "00:43.530",
      "text": "去写一种历史  名字叫奇迹",
      "translation": null
    },
    {
      "time": 50.01,
      "time_str": "00:50.010",
      "text": "如果恐惧就像火炬 那就让它沸腾我血液",
      "translation": null
    },
    {
      "time": 55.54,
      "time_str": "00:55.540",
      "text": "带我到绝地 我才能完全觉醒",
      "translation": null
    },
    {
      "time": 64.98,
      "time_str": "01:04.980",
      "text": "在黑暗的对面是光明 光明后面是阴影",
      "translation": null
    },
    {
      "time": 71.5,
      "time_str": "01:11.500",
      "text": "正义 邪恶是谁有权定义",
      "translation": null
    },
    {
      "time": 77.73,
      "time_str": "01:17.730",
      "text": "在命运的前面我怀疑 在面具后面铁一般决心",
      "translation": null
    },
    {
      "time": 86.28,
      "time_str": "01:26.280",
      "text": "光荣的牺牲 也是种荣誉",
      "translation": null
    },
    {
      "time": 102.54,
      "time_str": "01:42.540",
      "text": "不怕人说 不要人懂 我要证明",
      "translation": null
    },
    {
      "time": 109.0,
      "time_str": "01:49.000",
      "text": "明天我的姓名 将会是传奇",
      "translation": null
    },
    {
