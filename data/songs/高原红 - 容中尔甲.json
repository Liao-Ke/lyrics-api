  "lyrics": [
    {
      "time": 26.63,
      "time_str": "00:26.630",
      "text": "许多的欢乐 留在你的帐篷",
      "translation": null
    },
    {
      "time": 34.03,
      "time_str": "00:34.030",
      "text": "初恋的琴声 撩动几次雪崩",
      "translation": null
    },
    {
      "time": 40.75,
      "time_str": "00:40.750",
      "text": "少年的我  为何不懂心痛",
      "translation": null
    },
    {
      "time": 47.34,
      "time_str": "00:47.340",
      "text": "蓦然回首  已是光阴如风",
      "translation": null
    },
    {
      "time": 55.88,
      "time_str": "00:55.880",
      "text": "离乡的行囊 总是越来越重",
      "translation": null
    },
    {
      "time": 63.13,
      "time_str": "01:03.130",
      "text": "滚滚的红尘 难掩你的笑容",
      "translation": null
    },
    {
      "time": 69.92,
      "time_str": "01:09.920",
      "text": "青藏的阳光 日夜与我相拥",
      "translation": null
    },
    {
      "time": 76.41,
      "time_str": "01:16.410",
      "text": "茫茫的雪域 何处寻觅你的影踪",
      "translation": null
    },
    {
      "time": 86.66,
      "time_str": "01:26.660",
      "text": "高原红  美丽的高原红",
      "translation": null
    },
    {
      "time": 93.86,
      "time_str": "01:33.860",
      "text": "煮了又煮的酥油茶",
      "translation": null
    },
    {
      "time": 97.52,
      "time_str": "01:37.520",
      "text": "还是当年那样浓",
      "translation": null
    },
    {
      "time": 101.11,
      "time_str": "01:41.110",
      "text": "高原红  梦里的高原红",
      "translation": null
    },
    {
      "time": 108.43,
      "time_str": "01:48.430",
      "text": "酿了又酿的青稞酒",
      "translation": null
    },
    {
      "time": 111.58,
      "time_str": "01:51.580",
      "text": "让我醉在不眠中",
      "translation": null
    },
    {
