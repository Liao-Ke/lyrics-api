    {
      "time": 16.03,
      "time_str": "00:16.030",
      "text": "就像阳光穿过黑夜",
      "translation": null
    },
    {
      "time": 19.08,
      "time_str": "00:19.080",
      "text": "黎明悄悄划过天边",
      "translation": null
    },
    {
      "time": 21.98,
      "time_str": "00:21.980",
      "text": "谁的身影穿梭轮回间",
      "translation": null
    },
    {
      "time": 27.96,
      "time_str": "00:27.960",
      "text": "未来的路就在脚下",
      "translation": null
    },
    {
      "time": 30.95,
      "time_str": "00:30.950",
      "text": "不要悲伤不要害怕",
      "translation": null
    },
    {
      "time": 34.04,
      "time_str": "00:34.040",
      "text": "充满信心期盼着明天",
      "translation": null
    },
    {
      "time": 39.22,
      "time_str": "00:39.220",
      "text": "新的风暴已经出现",
      "translation": null
    },
    {
      "time": 42.02,
      "time_str": "00:42.020",
      "text": "怎么能够停滞不前",
      "translation": null
    },
    {
      "time": 44.76,
      "time_str": "00:44.760",
      "text": "穿越时空竭尽全力",
      "translation": null
    },
    {
      "time": 48.15,
      "time_str": "00:48.150",
      "text": "我会来到你身边",
      "translation": null
    },
    {
      "time": 51.44,
      "time_str": "00:51.440",
      "text": "微笑面对危险",
      "translation": null
    },
    {
      "time": 54.02,
      "time_str": "00:54.020",
      "text": "梦想成真不会遥远",
      "translation": null
    },
    {
      "time": 56.71,
      "time_str": "00:56.710",
      "text": "鼓起勇气坚定向前",
      "translation": null
    },
    {
