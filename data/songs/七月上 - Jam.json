  "lyrics": [
    {
      "time": 12.88,
      "time_str": "00:12.880",
      "text": "我化尘埃飞扬，追寻赤裸逆翔",
      "translation": null
    },
    {
      "time": 21.25,
      "time_str": "00:21.250",
      "text": "奔去七月刑场，时间烧灼滚烫",
      "translation": null
    },
    {
      "time": 29.21,
      "time_str": "00:29.210",
      "text": "回忆撕毁臆想，路上行走匆忙",
      "translation": null
    },
    {
      "time": 37.46,
      "time_str": "00:37.460",
      "text": "难能可贵世上，散播留香磁场",
      "translation": null
    },
    {
      "time": 49.42,
      "time_str": "00:49.420",
      "text": "我欲乘风破浪，踏遍黄沙海洋",
      "translation": null
    },
    {
      "time": 53.45,
      "time_str": "00:53.450",
      "text": "与其误会一场，也要不负勇往",
      "translation": null
    },
    {
      "time": 57.6,
      "time_str": "00:57.600",
      "text": "我愿你是个谎，从未出现南墙",
      "translation": null
    },
    {
      "time": 61.89,
      "time_str": "01:01.890",
      "text": "笑是神的伪装，笑是强忍的伤",
      "translation": null
    },
    {
      "time": 66.35,
      "time_str": "01:06.350",
      "text": "就让我走向你，走向你的窗",
      "translation": null
    },
    {
      "time": 70.54,
      "time_str": "01:10.540",
      "text": "就让我看见你，看见你的伤",
      "translation": null
    },
    {
      "time": 75.05,
      "time_str": "01:15.050",
      "text": "我想你就站在，站在大漠边疆",
      "translation": null
    },
    {
      "time": 79.64,
      "time_str": "01:19.640",
      "text": "我想你就站在，站在七月上",
      "translation": null
    },
    {
