  "lyrics": [
    {
      "time": 15.87,
      "time_str": "00:15.870",
      "text": "是寂寞慢慢占领我的心",
      "translation": null
    },
    {
      "time": 22.212,
      "time_str": "00:22.212",
      "text": "长夜里愈来愈冷清",
      "translation": null
    },
    {
      "time": 25.735,
      "time_str": "00:25.735",
      "text": "回忆里愈来愈孤寂",
      "translation": null
    },
    {
      "time": 29.545,
      "time_str": "00:29.545",
      "text": "是后悔慢慢侵蚀我的心",
      "translation": null
    },
    {
      "time": 36.4,
      "time_str": "00:36.400",
      "text": "抹去了最后的泪滴",
      "translation": null
    },
    {
      "time": 39.396,
      "time_str": "00:39.396",
      "text": "从今后不再为谁哭泣",
      "translation": null
    },
    {
      "time": 51.01,
      "time_str": "00:51.010",
      "text": "我不敢再问",
      "translation": null
    },
    {
      "time": 53.338,
      "time_str": "00:53.338",
      "text": "是什么改变你的眼神",
      "translation": null
    },
    {
      "time": 57.638,
      "time_str": "00:57.638",
      "text": "对爱厌倦对爱疲惫",
      "translation": null
    },
    {
      "time": 61.149,
      "time_str": "01:01.149",
      "text": "对我已没有感觉",
      "translation": null
    },
    {
      "time": 65.73,
      "time_str": "01:05.730",
      "text": "温柔的缠绵",
      "translation": null
    },
    {
      "time": 67.853,
      "time_str": "01:07.853",
      "text": "难道只是一时的气氛",
      "translation": null
    },
    {
      "time": 71.712,
      "time_str": "01:11.712",
      "text": "留不住人留不住魂",
      "translation": null
    },
    {
      "time": 75.237,
      "time_str": "01:15.237",
      "text": "留不住你的一切",
      "translation": null
    },
    {
      "time": 82.322,
      "time_str": "01:22.322",
      "text": "是了解慢慢伤害我的心",
      "translation": null
    },
    {
      "time": 89.283,
      "time_str": "01:29.283",
      "text": "就让我醉死在梦里",
      "translation": null
    },
    {
      "time": 92.366,
      "time_str": "01:32.366",
      "text": "在梦里永远不要清醒",
      "translation": null
    },
    {
      "time": 100.283,
      "time_str": "01:40.283",
      "text": "是谁偷偷偷走我的心",
      "translation": null
    },
    {
      "time": 107.28,
      "time_str": "01:47.280",
      "text": "不能分辨黑夜或天明",
      "translation": null
    },
    {
      "time": 114.462,
      "time_str": "01:54.462",
      "text": "是谁偷偷偷走我的心",
      "translation": null
    },
    {
      "time": 121.16,
      "time_str": "02:01.160",
      "text": "我的眼睛看不见我自己",
      "translation": null
