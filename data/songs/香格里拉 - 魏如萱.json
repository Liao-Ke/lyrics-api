    {
      "time": 25.25,
      "time_str": "00:25.250",
      "text": "我以为认真去做就能实现我的梦",
      "translation": null
    },
    {
      "time": 32.267,
      "time_str": "00:32.267",
      "text": "以为写首好歌走路就能抬起头",
      "translation": null
    },
    {
      "time": 38.308,
      "time_str": "00:38.308",
      "text": "以为骑摩托车旅行就能变英雄",
      "translation": null
    },
    {
      "time": 44.374,
      "time_str": "00:44.374",
      "text": "现在的我失去了冲动",
      "translation": null
    },
    {
      "time": 50.78,
      "time_str": "00:50.780",
      "text": "有才华的人唾弃金光闪闪的奖座",
      "translation": null
    },
    {
      "time": 58.16,
      "time_str": "00:58.160",
      "text": "亲爱的Cobain是否也曾爱慕虚荣",
      "translation": null
    },
    {
      "time": 63.856,
      "time_str": "01:03.856",
      "text": "多希望有人冲破疑惑带我向前走",
      "translation": null
    },
    {
      "time": 70.354,
      "time_str": "01:10.354",
      "text": "现在的我变的好懦弱",
      "translation": null
    },
    {
      "time": 77.278,
      "time_str": "01:17.278",
      "text": "雨会下雨会停 这是不变的道理",
      "translation": null
    },
    {
      "time": 83.672,
      "time_str": "01:23.672",
      "text": "夜空中北极星 迷路的人不恐惧",
      "translation": null
    },
    {
      "time": 90.171,
      "time_str": "01:30.171",
      "text": "我唱歌你在听 一切风平又浪静",
      "translation": null
    },
    {
      "time": 96.702,
      "time_str": "01:36.702",
      "text": "G 和弦的根音 抚平脆弱的心灵",
      "translation": null
    },
    {
      "time": 103.289,
      "time_str": "01:43.289",
      "text": "我只想牵着你 走到很远的梦里",
      "translation": null
    },
    {
      "time": 109.627,
      "time_str": "01:49.627",
      "text": "小木屋红屋顶 地址是一个秘密",
      "translation": null
    },
    {
      "time": 116.075,
      "time_str": "01:56.075",
      "text": "你抱着小猫咪 蓝眼睛不再忧郁",
      "translation": null
