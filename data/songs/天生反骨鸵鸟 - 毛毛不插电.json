  "lyrics": [
    {
      "time": 0.183,
      "time_str": "00:00.183",
      "text": "我是天生反骨的 鸵鸟",
      "translation": null
    },
    {
      "time": 3.439,
      "time_str": "00:03.439",
      "text": "不是束手待宰的 羊羔",
      "translation": null
    },
    {
      "time": 6.686,
      "time_str": "00:06.686",
      "text": "冷枪暗刀 请放马过来 赐教",
      "translation": null
    },
    {
      "time": 10.182,
      "time_str": "00:10.182",
      "text": "别对我叫嚣 我任性逍遥 我没有小号",
      "translation": null
    },
    {
      "time": 13.686,
      "time_str": "00:13.686",
      "text": "我是天生反骨的 鸵鸟",
      "translation": null
    },
    {
      "time": 17.063,
      "time_str": "00:17.063",
      "text": "把小小宇宙充满 燃料",
      "translation": null
    },
    {
      "time": 20.066,
      "time_str": "00:20.066",
      "text": "跟上我的速度 烦恼 全甩掉",
      "translation": null
    },
    {
      "time": 23.577,
      "time_str": "00:23.577",
      "text": "别给我高帽 所有的梦想 都在熊熊燃烧",
      "translation": null
    },
    {
      "time": 31.517,
      "time_str": "00:31.517",
      "text": "命运 发出召唤的 信号",
      "translation": null
    },
    {
      "time": 34.512,
      "time_str": "00:34.512",
      "text": "拼了命 去挣脱寂寞 的铐",
      "translation": null
    },
    {
      "time": 37.52,
      "time_str": "00:37.520",
      "text": "我没有名号 别称我为 菜鸟",
      "translation": null
    },
    {
      "time": 41.025,
      "time_str": "00:41.025",
      "text": "把情歌关掉 把弱鸡踢爆",
      "translation": null
    },
    {
      "time": 44.914,
      "time_str": "00:44.914",
      "text": "漫天 飞砂走石在 呼啸",
      "translation": null
    },
    {
      "time": 47.913,
      "time_str": "00:47.913",
      "text": "怎么玩 不需要谁来 赐教",
      "translation": null
    },
    {
      "time": 50.922,
      "time_str": "00:50.922",
      "text": "烦恼全甩掉 每一刻都 闪耀",
      "translation": null
    },
    {
      "time": 54.362,
      "time_str": "00:54.362",
      "text": "极限的奔跑 速度已爆表",
      "translation": null
    },
