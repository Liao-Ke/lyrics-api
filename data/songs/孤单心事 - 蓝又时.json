  "lyrics": [
    {
      "time": 16.18,
      "time_str": "00:16.180",
      "text": "雨下在我窗前",
      "translation": null
    },
    {
      "time": 19.3,
      "time_str": "00:19.300",
      "text": "玻璃也在流眼泪",
      "translation": null
    },
    {
      "time": 23.19,
      "time_str": "00:23.190",
      "text": "街上的人都看起来",
      "translation": null
    },
    {
      "time": 27.36,
      "time_str": "00:27.360",
      "text": "比我幸福一点",
      "translation": null
    },
    {
      "time": 31.37,
      "time_str": "00:31.370",
      "text": "用寂寞来测验",
      "translation": null
    },
    {
      "time": 34.48,
      "time_str": "00:34.480",
      "text": "还是最想要你陪",
      "translation": null
    },
    {
      "time": 38.25,
      "time_str": "00:38.250",
      "text": "曾一起走过的夏天",
      "translation": null
    },
    {
      "time": 42.47,
      "time_str": "00:42.470",
      "text": "我常常会梦见",
      "translation": null
    },
    {
      "time": 46.32,
      "time_str": "00:46.320",
      "text": "我猜不到",
      "translation": null
    },
    {
      "time": 49.74,
      "time_str": "00:49.740",
      "text": "你真正的",
      "translation": null
    },
    {
      "time": 51.8,
      "time_str": "00:51.800",
      "text": "感觉",
      "translation": null
    },
    {
      "time": 55.14,
      "time_str": "00:55.140",
      "text": "思念写成脸上的黑眼圈",
      "translation": null
    },
    {
      "time": 63.228,
      "time_str": "01:03.228",
      "text": "有的时候我宁愿",
      "translation": null
    },
    {
      "time": 66.4,
      "time_str": "01:06.400",
      "text": "你对我坏一点",
      "translation": null
    },
    {
      "time": 70.349,
      "time_str": "01:10.349",
      "text": "无法停止幻想我们的永远",
      "translation": null
    },
    {
      "time": 76.76,
      "time_str": "01:16.760",
      "text": "爱你是孤单的心事",
      "translation": null
    },
    {
      "time": 80.31,
      "time_str": "01:20.310",
      "text": "不懂你微笑的意思",
      "translation": null
    },
    {
      "time": 84.599,
      "time_str": "01:24.599",
      "text": "只能像一朵向日葵",
      "translation": null
    },
    {
      "time": 87.81,
      "time_str": "01:27.810",
      "text": "在夜里默默地坚持",
      "translation": null
    },
    {
      "time": 91.938,
      "time_str": "01:31.938",
      "text": "爱你是孤单的心事",
      "translation": null
    },
    {
      "time": 95.45,
      "time_str": "01:35.450",
      "text": "多希望你对我诚实",
      "translation": null
