  "lyrics": [
    {
      "time": 21.6,
      "time_str": "00:21.600",
      "text": "我竟然没有调头",
      "translation": null
    },
    {
      "time": 24.92,
      "time_str": "00:24.920",
      "text": "最残忍那一刻",
      "translation": null
    },
    {
      "time": 28.46,
      "time_str": "00:28.460",
      "text": "静静看你走",
      "translation": null
    },
    {
      "time": 31.69,
      "time_str": "00:31.690",
      "text": "一点都不像我",
      "translation": null
    },
    {
      "time": 37.8,
      "time_str": "00:37.800",
      "text": "原来人会变得温柔",
      "translation": null
    },
    {
      "time": 41.09,
      "time_str": "00:41.090",
      "text": "是透彻的懂了",
      "translation": null
    },
    {
      "time": 44.68,
      "time_str": "00:44.680",
      "text": "爱情是流动的 不由人的",
      "translation": null
    },
    {
      "time": 49.28,
      "time_str": "00:49.280",
      "text": "何必激动着要理由",
      "translation": null
    },
    {
      "time": 54.48,
      "time_str": "00:54.480",
      "text": "相信你只是怕伤害我",
      "translation": null
    },
    {
      "time": 57.81,
      "time_str": "00:57.810",
      "text": "不是骗我",
      "translation": null
    },
    {
      "time": 60.23,
      "time_str": "01:00.230",
      "text": "很爱过谁会舍得",
      "translation": null
    },
    {
      "time": 64.21,
      "time_str": "01:04.210",
      "text": "把我的梦摇醒了",
      "translation": null
    },
    {
      "time": 66.98,
      "time_str": "01:06.980",
      "text": "宣布幸福不会来了",
      "translation": null
    },
    {
      "time": 70.77,
      "time_str": "01:10.770",
      "text": "用心酸微笑去原谅了",
      "translation": null
    },
    {
      "time": 74.15,
      "time_str": "01:14.150",
      "text": "也翻越了",
      "translation": null
    },
    {
      "time": 76.38,
      "time_str": "01:16.380",
      "text": "有昨天还是好的",
      "translation": null
    },
    {
      "time": 80.47,
      "time_str": "01:20.470",
      "text": "但明天是自己的",
      "translation": null
    },
    {
      "time": 83.2,
      "time_str": "01:23.200",
      "text": "开始懂了",
      "translation": null
    },
    {
