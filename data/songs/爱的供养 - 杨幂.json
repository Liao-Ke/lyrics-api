  "lyrics": [
    {
      "time": 0.0,
      "time_str": "00:00.000",
      "text": "杨幂 - 爱的供养",
      "translation": null
    },
    {
      "time": 13.35,
      "time_str": "00:13.350",
      "text": "把你捧在手上 虔诚地焚香",
      "translation": null
    },
    {
      "time": 21.7,
      "time_str": "00:21.700",
      "text": "剪下一段烛光 将经纶点亮",
      "translation": null
    },
    {
      "time": 29.74,
      "time_str": "00:29.740",
      "text": "不求荡气回肠 只求爱一场",
      "translation": null
    },
    {
      "time": 37.8,
      "time_str": "00:37.800",
      "text": "爱到最后受了伤 哭得好绝望",
      "translation": null
    },
    {
      "time": 45.21,
      "time_str": "00:45.210",
      "text": "我用尽一生一世 来将你供养",
      "translation": null
    },
    {
      "time": 53.11,
      "time_str": "00:53.110",
      "text": "只期盼你停住 流转的目光",
      "translation": null
    },
    {
      "time": 61.06,
      "time_str": "01:01.060",
      "text": "请赐予我无限爱 与被爱的力量",
      "translation": null
    },
    {
      "time": 68.78,
      "time_str": "01:08.780",
      "text": "让我能安心在菩提下 静静的观想",
      "translation": null
    },
    {
      "time": 92.51,
      "time_str": "01:32.510",
      "text": "把你放在心上 合起了手掌",
      "translation": null
    },
    {
      "time": 101.76,
      "time_str": "01:41.760",
      "text": "默默乞求上苍 指引我方向",
      "translation": null
    },
    {
      "time": 109.78,
      "time_str": "01:49.780",
      "text": "不求地久天长 只求在身旁",
      "translation": null
    },
    {
      "time": 117.84,
      "time_str": "01:57.840",
      "text": "累了醉倒温柔乡 轻轻地梵唱",
      "translation": null
    },
    {
      "time": 125.21,
      "time_str": "02:05.210",
      "text": "我用尽一生一世 来将你供养",
      "translation": null
    },
    {
      "time": 133.04,
      "time_str": "02:13.040",
      "text": "只期盼你停住 流转的目光",
      "translation": null
    },
    {
      "time": 141.07,
      "time_str": "02:21.070",
      "text": "请赐予我无限爱 与被爱的力量",
      "translation": null
    },
    {
      "time": 148.84,
      "time_str": "02:28.840",
      "text": "让我能安心在菩提下 静静的观想",
      "translation": null
    },
    {
      "time": 159.19,
      "time_str": "02:39.190",
      "text": "我用尽一生一世 来将你供养",
      "translation": null
    },
    {
      "time": 167.06,
      "time_str": "02:47.060",
      "text": "人世间有太多的 烦恼要忘",
      "translation": null
    },
    {
      "time": 175.05,
      "time_str": "02:55.050",
      "text": "苦海中飘荡着你 那旧时的模样",
      "translation": null
    },
    {
      "time": 182.88,
      "time_str": "03:02.880",
      "text": "一回头发现 早已踏出了红尘万丈",
      "translation": null
    }
  ],
