      "translation": null
    },
    {
      "time": 220.241,
      "time_str": "03:40.241",
      "text": "因为很想念 每天都是晴天",
      "translation": null
    },
    {
      "time": 225.572,
      "time_str": "03:45.572",
      "text": "心晴朗 就看到永远",
      "translation": null
    },
    {
      "time": 231.226,
      "time_str": "03:51.226",
      "text": "阳光中 风筝飞上天",
      "translation": null
    },
    {
      "time": 236.844,
      "time_str": "03:56.844",
      "text": "你笑着 回到我面前",
      "translation": null
    },
    {
      "time": 242.492,
      "time_str": "04:02.492",
      "text": "让我像 那风筝贴着天空的脸",
      "translation": null
    },
    {
      "time": 248.585,
      "time_str": "04:08.585",
      "text": "让爱是今生不断的线",
      "translation": null
    }
