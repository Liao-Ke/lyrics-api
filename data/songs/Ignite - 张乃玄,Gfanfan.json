    {
      "time": 0.32,
      "time_str": "00:00.320",
      "text": "Fanfan：",
      "translation": null
    },
    {
      "time": 10.68,
      "time_str": "00:10.680",
      "text": "Fireflies",
      "translation": "萤火虫"
    },
    {
      "time": 12.94,
      "time_str": "00:12.940",
      "text": "A million little pieces",
      "translation": "百万只"
    },
    {
      "time": 15.63,
      "time_str": "00:15.630",
      "text": "Feeds the dying light",
      "translation": "点燃垂死的光"
    },
    {
      "time": 17.85,
      "time_str": "00:17.850",
      "text": "And breathes me back to life",
      "translation": "使我苏醒"
    },
    {
      "time": 21.34,
      "time_str": "00:21.340",
      "text": "In your eyes",
      "translation": "在你眼中"
    },
    {
      "time": 23.33,
      "time_str": "00:23.330",
      "text": "I see something to believe in",
      "translation": "我看到信仰"
    },
    {
      "time": 26.22,
      "time_str": "00:26.220",
      "text": "Your hands are like a flame",
      "translation": "你双臂如灼热的火焰"
    },
    {
      "time": 28.66,
      "time_str": "00:28.660",
      "text": "Your palms the sweetest pain",
      "translation": "你掌心甜蜜的伤"
    },
    {
      "time": 31.99,
      "time_str": "00:31.990",
      "text": "Let the darkness lead us into the light",
      "translation": "让黑暗带我们进入光明"
    },
    {
      "time": 34.62,
      "time_str": "00:34.620",
      "text": "Let our dreams get lost feel the temperature rise",
      "translation": "让高温迷失我们的梦想"
    },
    {
      "time": 37.32,
      "time_str": "00:37.320",
      "text": "Baby tell me one more beautiful lie",
      "translation": "宝贝 再给我讲一个美丽的谎言"
    },
    {
      "time": 39.97,
      "time_str": "00:39.970",
      "text": "One touch and I ignite",
      "translation": "一触即燃"
    },
    {
      "time": 42.6,
      "time_str": "00:42.600",
      "text": "Like a starship speeding into the night",
      "translation": "像夜空航行的飞船"
    },
