    {
      "time": 32.85,
      "time_str": "00:32.850",
      "text": "清晨我站在青青的牧场",
      "translation": null
    },
    {
      "time": 40.93,
      "time_str": "00:40.930",
      "text": "看到神鹰披着那霞光",
      "translation": null
    },
    {
      "time": 48.13,
      "time_str": "00:48.130",
      "text": "像一片祥云飞过蓝天",
      "translation": null
    },
    {
      "time": 56.1,
      "time_str": "00:56.100",
      "text": "为藏家儿女带来吉祥",
      "translation": null
    },
    {
      "time": 65.77,
      "time_str": "01:05.770",
      "text": "黄昏我站在高高的山岗",
      "translation": null
    },
    {
      "time": 73.74,
      "time_str": "01:13.740",
      "text": "看那铁路修到我家乡",
      "translation": null
    },
    {
      "time": 81.01,
      "time_str": "01:21.010",
      "text": "一条条巨龙翻山越岭",
      "translation": null
    },
    {
      "time": 89.19,
      "time_str": "01:29.190",
      "text": "为雪域高原送来安康",
      "translation": null
    },
    {
      "time": 98.53,
      "time_str": "01:38.530",
      "text": "那是一条神奇的天路 哎",
      "translation": null
    },
    {
      "time": 105.95,
      "time_str": "01:45.950",
      "text": "把祖国的温暖送到边疆",
      "translation": null
    },
    {
      "time": 113.32,
      "time_str": "01:53.320",
      "text": "从此山不再高路不再漫长",
      "translation": null
    },
    {
