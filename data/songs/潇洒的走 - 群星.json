  "lyrics": [
    {
      "time": 25.77,
      "time_str": "00:25.770",
      "text": "昨日的朋友 悄悄的离去",
      "translation": null
    },
    {
      "time": 31.63,
      "time_str": "00:31.630",
      "text": "就这样无声无息离开你",
      "translation": null
    },
    {
      "time": 38.0,
      "time_str": "00:38.000",
      "text": "仿佛在你眼里感到无限的悲戚",
      "translation": null
    },
    {
      "time": 45.06,
      "time_str": "00:45.060",
      "text": "好象夜雾层层笼罩你的心里",
      "translation": null
    },
    {
      "time": 54.7,
      "time_str": "00:54.700",
      "text": "也许你从来不愿告诉我",
      "translation": null
    },
    {
      "time": 60.4,
      "time_str": "01:00.400",
      "text": "我也不想再问你为什么",
      "translation": null
    },
    {
      "time": 67.12,
      "time_str": "01:07.120",
      "text": "夏日风已吹远 吹得无影又无踪",
      "translation": null
    },
    {
      "time": 73.75,
      "time_str": "01:13.750",
      "text": "所以我将会忘记昨夜的你",
      "translation": null
    },
    {
      "time": 80.57,
      "time_str": "01:20.570",
      "text": "别说爱情就是你的名和姓",
      "translation": null
    },
    {
      "time": 86.36,
      "time_str": "01:26.360",
      "text": "就除了感情你都不愿再接近",
      "translation": null
    },
    {
      "time": 93.05,
      "time_str": "01:33.050",
      "text": "破碎的心难填平 昨日醉心的恋情",
      "translation": null
    },
    {
      "time": 99.21,
      "time_str": "01:39.210",
      "text": "所以我将忘记你的背影",
      "translation": null
    },
    {
