  "lyrics": [
    {
      "time": 12.42,
      "time_str": "00:12.420",
      "text": "我看见天空很蓝",
      "translation": null
    },
    {
      "time": 18.21,
      "time_str": "00:18.210",
      "text": "就像你在我身边的温暖",
      "translation": null
    },
    {
      "time": 23.64,
      "time_str": "00:23.640",
      "text": "生命有太多遗憾",
      "translation": null
    },
    {
      "time": 29.37,
      "time_str": "00:29.370",
      "text": "人越成长越觉得孤单",
      "translation": null
    },
    {
      "time": 34.41,
      "time_str": "00:34.410",
      "text": "我很想飞多远都不会累",
      "translation": null
    },
    {
      "time": 39.9,
      "time_str": "00:39.900",
      "text": "才明白爱的越深心就会越痛",
      "translation": null
    },
    {
      "time": 45.87,
      "time_str": "00:45.870",
      "text": "我只想飞在我的天空飞",
      "translation": null
    },
    {
      "time": 52.35,
      "time_str": "00:52.350",
      "text": "我知道你会在我身边",
      "translation": null
    },
    {
      "time": 57.66,
      "time_str": "00:57.660",
      "text": "回忆的画面记录的语言",
      "translation": null
    },
    {
      "time": 63.06,
      "time_str": "01:03.060",
      "text": "爱始终是你手中长长的线",
      "translation": null
    },
    {
      "time": 68.04,
      "time_str": "01:08.040",
      "text": "载着我的想念飞过了地平线",
      "translation": null
    },
    {
      "time": 73.8,
      "time_str": "01:13.800",
      "text": "你温暖的笑脸还一如从前",
      "translation": null
    },
    {
      "time": 80.46,
      "time_str": "01:20.460",
      "text": "回忆的画面记录的语言",
      "translation": null
    },
    {
      "time": 85.86,
      "time_str": "01:25.860",
      "text": "你说要我们学着勇敢一点",
      "translation": null
    },
    {
      "time": 90.99,
      "time_str": "01:30.990",
      "text": "偶尔哭红双眼你一定会了解",
      "translation": null
    },
    {
      "time": 96.6,
      "time_str": "01:36.600",
      "text": "眼泪是我心中另一种完美",
      "translation": null
    },
