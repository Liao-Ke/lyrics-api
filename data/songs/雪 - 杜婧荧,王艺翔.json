  "lyrics": [
    {
      "time": 21.52,
      "time_str": "00:21.520",
      "text": "(女)这季节风多了一些",
      "translation": null
    },
    {
      "time": 25.85,
      "time_str": "00:25.850",
      "text": "吹痛被爱遗忘的一切",
      "translation": null
    },
    {
      "time": 30.43,
      "time_str": "00:30.430",
      "text": "而我却躲不过这感觉",
      "translation": null
    },
    {
      "time": 34.67,
      "time_str": "00:34.670",
      "text": "痛的无力去改变",
      "translation": null
    },
    {
      "time": 39.01,
      "time_str": "00:39.010",
      "text": "谁了解在我的世界",
      "translation": null
    },
    {
      "time": 43.8,
      "time_str": "00:43.800",
      "text": "爱的信仰已被风熄灭",
      "translation": null
    },
    {
      "time": 47.58,
      "time_str": "00:47.580",
      "text": "就像离开树的落叶飘不见",
      "translation": null
    },
    {
      "time": 52.11,
      "time_str": "00:52.110",
      "text": "已经慢慢凋谢",
      "translation": null
    },
    {
      "time": 55.96,
      "time_str": "00:55.960",
      "text": "忽然下的一场雪飘的那么纯洁",
      "translation": null
    },
    {
      "time": 60.7,
      "time_str": "01:00.700",
      "text": "将我埋葬在你的世界",
      "translation": null
    },
    {
      "time": 66.01,
      "time_str": "01:06.010",
      "text": "冰封了我爱的期限",
      "translation": null
    },
    {
      "time": 69.53,
      "time_str": "01:09.530",
      "text": "却让痛成为永远",
      "translation": null
    },
    {
      "time": 73.25,
      "time_str": "01:13.250",
      "text": "在一瞬间曾经所有的梦都幻灭",
      "translation": null
    },
    {
      "time": 78.19,
      "time_str": "01:18.190",
      "text": "剩下回忆湿了我的眼",
      "translation": null
    },
    {
      "time": 83.5,
      "time_str": "01:23.500",
      "text": "还牵着你给过我的誓言",
      "translation": null
    },
    {
      "time": 87.45,
      "time_str": "01:27.450",
      "text": "发现已经无法兑现",
      "translation": null
    },
    {
      "time": 102.9,
      "time_str": "01:42.900",
      "text": "(男)一整夜 爱与恨重叠",
      "translation": null
    },
    {
      "time": 107.2,
      "time_str": "01:47.200",
      "text": "只剩心被撕裂的感觉",
      "translation": null
    },
    {
      "time": 110.9,
      "time_str": "01:50.900",
      "text": "属于我的幸福被你忽略",
      "translation": null
    },
    {
      "time": 116.1,
      "time_str": "01:56.100",
      "text": "我不愿 无法妥协",
      "translation": null
    },
    {
      "time": 119.21,
      "time_str": "01:59.210",
      "text": "忽然下的一场雪飘的那么纯洁",
