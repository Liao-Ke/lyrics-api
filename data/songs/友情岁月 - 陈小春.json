  "lyrics": [
    {
      "time": 8.94,
      "time_str": "00:08.940",
      "text": "消失的光阴散在风里",
      "translation": null
    },
    {
      "time": 13.09,
      "time_str": "00:13.090",
      "text": "彷彿想不起再面对",
      "translation": null
    },
    {
      "time": 17.12,
      "time_str": "00:17.120",
      "text": "流浪日子你在伴随",
      "translation": null
    },
    {
      "time": 21.35,
      "time_str": "00:21.350",
      "text": "有缘再聚",
      "translation": null
    },
    {
      "time": 25.28,
      "time_str": "00:25.280",
      "text": "天真的声音已在减退",
      "translation": null
    },
    {
      "time": 29.41,
      "time_str": "00:29.410",
      "text": "彼此为著目标相距",
      "translation": null
    },
    {
      "time": 33.31,
      "time_str": "00:33.310",
      "text": "凝望夜空 往日是谁",
      "translation": null
    },
    {
      "time": 37.46,
      "time_str": "00:37.460",
      "text": "领会心中疲累",
      "translation": null
    },
    {
      "time": 42.38,
      "time_str": "00:42.380",
      "text": "来忘掉错对 来怀念过去",
      "translation": null
    },
    {
      "time": 47.52,
      "time_str": "00:47.520",
      "text": "曾共渡患难日子总有乐趣",
      "translation": null
    },
    {
      "time": 51.38,
      "time_str": "00:51.380",
      "text": "不相信会绝望",
      "translation": null
    },
    {
      "time": 53.31,
      "time_str": "00:53.310",
      "text": "不感觉到踌躇",
      "translation": null
    },
    {
      "time": 55.35,
      "time_str": "00:55.350",
      "text": "在美梦里竞争",
      "translation": null
    },
    {
      "time": 57.38,
      "time_str": "00:57.380",
      "text": "每日拼命进取",
      "translation": null
    },
    {
      "time": 59.41,
      "time_str": "00:59.410",
      "text": "奔波的风雨里",
      "translation": null
    },
    {
      "time": 61.37,
      "time_str": "01:01.370",
      "text": "不羁的醒与醉",
      "translation": null
    },
    {
      "time": 63.65,
      "time_str": "01:03.650",
      "text": "所有故事像已发生飘泊岁月里",
      "translation": null
    },
    {
      "time": 67.62,
      "time_str": "01:07.620",
      "text": "风吹过已静下",
      "translation": null
    },
    {
      "time": 69.58,
      "time_str": "01:09.580",
      "text": "将心意再还谁",
      "translation": null
    },
    {
      "time": 71.61,
      "time_str": "01:11.610",
      "text": "让眼泪已带走 夜憔悴",
