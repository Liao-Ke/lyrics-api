    {
      "time": 24.5,
      "time_str": "00:24.500",
      "text": "Nobody ever knows",
      "translation": "谁也不知道"
    },
    {
      "time": 27.2,
      "time_str": "00:27.200",
      "text": "Nobody ever sees",
      "translation": "谁也没见到"
    },
    {
      "time": 30.03,
      "time_str": "00:30.030",
      "text": "I left my soul",
      "translation": "我丢弃了自己的灵魂"
    },
    {
      "time": 32.72,
      "time_str": "00:32.720",
      "text": "Back then, now I'm too weak",
      "translation": "那时不是我太软弱"
    },
    {
      "time": 35.51,
      "time_str": "00:35.510",
      "text": "Most nights I pray for you to come home",
      "translation": "多少夜晚我祈祷你回家"
    },
    {
      "time": 41.46,
      "time_str": "00:41.460",
      "text": "Praying to the lord",
      "translation": "向上帝祈祷"
    },
    {
      "time": 44.5,
      "time_str": "00:44.500",
      "text": "Praying for my soul",
      "translation": "为我灵魂祈祷"
    },
    {
      "time": 46.44,
      "time_str": "00:46.440",
      "text": "Now please don't go",
      "translation": "现在请别走"
    },
    {
      "time": 52.52,
      "time_str": "00:52.520",
      "text": "Most nights I hardly sleep when I'm alone",
      "translation": "多少夜晚我独自辗转难眠"
    },
    {
      "time": 57.71,
      "time_str": "00:57.710",
      "text": "Now please don't go, oh no",
      "translation": "现在请别走，哦不"
    },
    {
      "time": 63.649,
      "time_str": "01:03.649",
      "text": "I think of you whenever I'm alone",
