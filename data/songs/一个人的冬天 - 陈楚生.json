    {
      "time": 39.68,
      "time_str": "00:39.680",
      "text": "我在这里 和这座城市",
      "translation": null
    },
    {
      "time": 47.54,
      "time_str": "00:47.540",
      "text": "一起等待这个冬天的第一场雪",
      "translation": null
    },
    {
      "time": 56.81,
      "time_str": "00:56.810",
      "text": "你在哪里 我深爱的女人",
      "translation": null
    },
    {
      "time": 65.01,
      "time_str": "01:05.010",
      "text": "一直盼望分手之后第一次相聚",
      "translation": null
    },
    {
      "time": 73.55,
      "time_str": "01:13.55",
      "text": "这个冬天没有给我惊喜",
      "translation": null
    },
    {
      "time": 78.0,
      "time_str": "01:18.00",
      "text": "没有你在身边的空气",
      "translation": null
    },
    {
      "time": 82.44,
      "time_str": "01:22.44",
      "text": "那飘落的白色",
      "translation": null
    },
    {
      "time": 84.97,
      "time_str": "01:24.97",
      "text": "那孤单的角色",
      "translation": null
    },
    {
      "time": 87.23,
      "time_str": "01:27.23",
      "text": "那理所当然的失落",
      "translation": null
    },
    {
      "time": 90.65,
      "time_str": "01:30.65",
      "text": "这个冬天没有给我惊喜",
      "translation": null
    },
    {
      "time": 95.6,
      "time_str": "01:35.60",
      "text": "没有给我曾想象的画面",
      "translation": null
    },
    {
      "time": 100.01,
      "time_str": "01:40.01",
      "text": "也许久违的雪",
      "translation": null
    },
    {
      "time": 103.29,
      "time_str": "01:43.29",
      "text": "也许从未来过",
      "translation": null
    },
    {
      "time": 105.6,
      "time_str": "01:45.60",
      "text": "也许故事从未发生过",
      "translation": null
    },
    {
      "time": 109.91,
      "time_str": "01:49.91",
      "text": "爱 等待",
      "translation": null
    },
    {
      "time": 114.39,
      "time_str": "01:54.39",
      "text": "推开阴霾的晴朗",
      "translation": null
    },
    {
      "time": 118.52,
      "time_str": "01:58.52",
      "text": "情 埋在",
      "translation": null
    },
    {
      "time": 122.71,
      "time_str": "02:02.71",
      "text": "冰封的雪白",
      "translation": null
    },
    {
      "time": 126.93,
      "time_str": "02:06.93",
      "text": "我依然在等待",
      "translation": null
    },
    {
      "time": 131.77,
      "time_str": "02:11.77",
      "text": "你说的未来",
      "translation": null
