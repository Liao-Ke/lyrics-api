  "lyrics": [
    {
      "time": 16.83,
      "time_str": "00:16.830",
      "text": "以前人们在四月开始收获",
      "translation": null
    },
    {
      "time": 22.89,
      "time_str": "00:22.890",
      "text": "躺在高高的谷堆上面笑着",
      "translation": null
    },
    {
      "time": 28.69,
      "time_str": "00:28.690",
      "text": "我穿过 金黄的麦田",
      "translation": null
    },
    {
      "time": 31.94,
      "time_str": "00:31.940",
      "text": "去给 稻草人唱歌",
      "translation": null
    },
    {
      "time": 34.78,
      "time_str": "00:34.780",
      "text": "等着 落山风吹过",
      "translation": null
    },
    {
      "time": 40.98,
      "time_str": "00:40.980",
      "text": "你从一座叫“我”的小镇经过",
      "translation": null
    },
    {
      "time": 46.72,
      "time_str": "00:46.720",
      "text": "刚好屋顶的雪化成雨飘落",
      "translation": null
    },
    {
      "time": 52.45,
      "time_str": "00:52.450",
      "text": "你穿着 透明的衣服",
      "translation": null
    },
    {
      "time": 55.72,
      "time_str": "00:55.720",
      "text": "给我 一个人唱歌",
      "translation": null
    },
    {
      "time": 58.74,
      "time_str": "00:58.740",
      "text": "全都是 我喜欢的歌",
      "translation": null
    },
    {
      "time": 64.05,
      "time_str": "01:04.050",
      "text": "我们去大草原的湖边",
      "translation": null
    },
    {
      "time": 67.87,
      "time_str": "01:07.870",
      "text": "等候鸟飞回来",
      "translation": null
    },
    {
      "time": 70.56,
      "time_str": "01:10.560",
      "text": "等我们都长大了就生一个娃娃",
      "translation": null
    },
    {
      "time": 76.09,
      "time_str": "01:16.090",
      "text": "他会自己长大远去我们也各自远去",
      "translation": null
    },
    {
      "time": 82.02,
      "time_str": "01:22.020",
      "text": "我给你写信 你不会回信",
      "translation": null
    },
    {
      "time": 87.23,
      "time_str": "01:27.230",
      "text": "就这样吧",
      "translation": null
    },
    {
