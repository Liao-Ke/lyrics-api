    {
      "time": 18.84,
      "time_str": "00:18.840",
      "text": "不知不觉已经到了六月",
      "translation": null
    },
    {
      "time": 22.08,
      "time_str": "00:22.080",
      "text": "恍恍惚惚挤进这班地铁",
      "translation": null
    },
    {
      "time": 25.82,
      "time_str": "00:25.820",
      "text": "忍不住去看 手机有没有闪",
      "translation": null
    },
    {
      "time": 29.88,
      "time_str": "00:29.880",
      "text": "有没有你的任何一切",
      "translation": null
    },
    {
      "time": 33.19,
      "time_str": "00:33.190",
      "text": "朝九晚五频频忙到深夜",
      "translation": null
    },
    {
      "time": 36.81,
      "time_str": "00:36.810",
      "text": "一三五七根本没空去歇",
      "translation": null
    },
    {
      "time": 40.38,
      "time_str": "00:40.380",
      "text": "唯一的安慰 是你从前的体贴",
      "translation": null
    },
    {
      "time": 44.76,
      "time_str": "00:44.760",
      "text": "就像什么都没发生 一样难理解",
      "translation": null
    },
    {
      "time": 51.51,
      "time_str": "00:51.510",
      "text": "很期待 你的下一条微信",
      "translation": null
    },
    {
      "time": 54.74,
      "time_str": "00:54.740",
      "text": "你的下一句关心 什么都行",
      "translation": null
    },
    {
      "time": 59.1,
      "time_str": "00:59.100",
      "text": "只要不是还是做朋友",
      "translation": null
    },
    {
      "time": 62.6,
      "time_str": "01:02.600",
      "text": "以此类推的回应",
      "translation": null
    },
    {
      "time": 65.78,
      "time_str": "01:05.780",
      "text": "我删去 我们全部的微信",
      "translation": null
    },
    {
      "time": 69.05,
      "time_str": "01:09.050",
      "text": "我们全部的曾经 干干净净",
      "translation": null
    },
    {
      "time": 73.71,
      "time_str": "01:13.710",
      "text": "以为无论你什么反应",
