  "lyrics": [
    {
      "time": 37.01,
      "time_str": "00:37.010",
      "text": "风到这里就是粘",
      "translation": null
    },
    {
      "time": 40.534,
      "time_str": "00:40.534",
      "text": "粘住过客的思念",
      "translation": null
    },
    {
      "time": 44.795,
      "time_str": "00:44.795",
      "text": "雨到了这里缠成线",
      "translation": null
    },
    {
      "time": 48.546,
      "time_str": "00:48.546",
      "text": "缠着我们流连人世间",
      "translation": null
    },
    {
      "time": 53.038,
      "time_str": "00:53.038",
      "text": "你在身边就是缘",
      "translation": null
    },
    {
      "time": 56.569,
      "time_str": "00:56.569",
      "text": "缘分写在三生石上面",
      "translation": null
    },
    {
      "time": 61.023,
      "time_str": "01:01.023",
      "text": "爱有万分之一甜",
      "translation": null
    },
    {
      "time": 64.546,
      "time_str": "01:04.546",
      "text": "宁愿我就葬在这一点",
      "translation": null
    },
    {
      "time": 69.062,
      "time_str": "01:09.062",
      "text": "圈圈圆圆圈圈",
      "translation": null
    },
    {
      "time": 70.739,
      "time_str": "01:10.739",
      "text": "天天年年天天 的我",
      "translation": null
    },
    {
      "time": 73.546,
      "time_str": "01:13.546",
      "text": "深深看你的脸",
      "translation": null
    },
    {
      "time": 76.041,
      "time_str": "01:16.041",
      "text": "生气的温柔",
      "translation": null
    },
    {
      "time": 77.994,
      "time_str": "01:17.994",
      "text": "埋怨的温柔 的脸",
      "translation": null
    },
    {
      "time": 84.058,
      "time_str": "01:24.058",
      "text": "不懂爱恨情愁煎熬的我们",
      "translation": null
    },
    {
      "time": 87.737,
      "time_str": "01:27.737",
      "text": "都以为相爱就像风云的善变",
      "translation": null
    },
    {
      "time": 92.017,
      "time_str": "01:32.017",
      "text": "相信爱一天 抵过永远",
      "translation": null
    },
    {
      "time": 96.279,
      "time_str": "01:36.279",
      "text": "在这一刹那冻结了时间",
      "translation": null
    },
    {
      "time": 100.009,
      "time_str": "01:40.009",
      "text": "不懂怎么表现温柔的我们",
      "translation": null
    },
    {
      "time": 103.76,
      "time_str": "01:43.760",
      "text": "还以为殉情只是古老的传言",
      "translation": null
    },
    {
      "time": 107.751,
      "time_str": "01:47.751",
      "text": "离愁能有多痛 痛有多浓",
      "translation": null
    },
    {
      "time": 112.247,
      "time_str": "01:52.247",
      "text": "当梦被埋在江南烟雨中",
      "translation": null
    },
    {
      "time": 115.506,
      "time_str": "01:55.506",
      "text": "心碎了才懂",
      "translation": null
    },
