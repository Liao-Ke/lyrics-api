{
  "title": "春天里",
  "title_raw": "春天里",
  "version": null,
  "artist": "费玉清",
  "group_key": "春天里|费玉清",
  "writers": {
    "lyricist": "关露",
    "composer": "贺绿汀",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 16.368,
      "time_str": "00:16.368",
      "text": "春天里来百花香　郎里格朗里格朗里格朗",
      "translation": null
    },
    {
      "time": 21.818,
      "time_str": "00:21.818",
      "text": "和暖的太阳在天空照　照到了我的破衣裳",
      "translation": null
    },
    {
      "time": 27.153,
      "time_str": "00:27.153",
      "text": "朗里格朗格朗里格朗　穿过了大街走小巷",
      "translation": null
    },
    {
      "time": 32.358,
      "time_str": "00:32.358",
      "text": "为了吃来为了穿　昼夜都要忙",
      "translation": null
    },
    {
      "time": 37.63,
      "time_str": "00:37.630",
      "text": "朗里格朗朗里格朗　没有钱也得吃碗饭",
      "translation": null
    },
    {
      "time": 42.237,
      "time_str": "00:42.237",
      "text": "也得住间房　哪怕老板娘作那怪模样",
      "translation": null
    },
    {
      "time": 46.49,
      "time_str": "00:46.490",
      "text": "朗里格朗里格朗　朗里格朗朗里格朗",
      "translation": null
    },
    {
      "time": 52.293,
      "time_str": "00:52.293",
      "text": "里格朗里格朗里格朗里格朗",
      "translation": null
    },
    {
      "time": 54.614,
      "time_str": "00:54.614",
      "text": "贫穷不是从天降",
      "translation": null
    },
    {
      "time": 56.935,
      "time_str": "00:56.935",
      "text": "生铁久炼也成钢　也成钢",
      "translation": null
    },
    {
      "time": 61.769,
      "time_str": "01:01.769",
      "text": "只要努力向前进　哪怕高山把路挡",
      "translation": null
    },
    {
      "time": 67.33,
      "time_str": "01:07.330",
      "text": "朗里格朗格朗里格朗　遇见了一位好姑娘",
      "translation": null
    },
    {
      "time": 75.034,
      "time_str": "01:15.034",
      "text": "亲爱的好姑娘　天真的好姑娘",
      "translation": null
    },
    {
      "time": 80.342,
      "time_str": "01:20.342",
      "text": "不用悲　不用伤　人生好比上战场",
      "translation": null
    },
    {
      "time": 85.57,
      "time_str": "01:25.570",
      "text": "身体健　气力壮　努力来干一场",
      "translation": null
    },
    {
      "time": 90.686,
      "time_str": "01:30.686",
      "text": "身体健　气力壮　大家努力干一场",
      "translation": null
    },
    {
      "time": 113.613,
      "time_str": "01:53.613",
      "text": "秋季里来菊花黄　朗里格朗里格朗里格朗",
      "translation": null
    },
    {
      "time": 118.851,
      "time_str": "01:58.851",
      "text": "阵阵的微风在迎面吹　吹动了我的破衣裳",
      "translation": null
    },
    {
      "time": 124.217,
      "time_str": "02:04.217",
      "text": "朗里格朗格朗里格朗　穿过了大街走小巷",
      "translation": null
    },
    {
      "time": 129.335,
      "time_str": "02:09.335",
      "text": "为了吃来为了穿　昼夜都要忙",
      "translation": null
    },
    {
      "time": 134.298,
      "time_str": "02:14.298",
      "text": "朗里格朗　朗里格朗　没工作也得吃碗饭",
      "translation": null
    },
    {
      "time": 139.158,
      "time_str": "02:19.158",
      "text": "也得住间房　哪怕老板娘作那怪模样",
      "translation": null
    },
    {
      "time": 143.396,
      "time_str": "02:23.396",
      "text": "朗里格朗里格朗里格　朗里格朗里格朗",
      "translation": null
    },
    {
      "time": 147.186,
      "time_str": "02:27.186",
      "text": "里格朗里格朗里格朗里格朗",
      "translation": null
    },
    {
      "time": 150.862,
      "time_str": "02:30.862",
      "text": "成败不是从天降",
      "translation": null
    },
    {
      "time": 153.535,
      "time_str": "02:33.535",
      "text": "生铁久炼也成钢　也成钢",
      "translation": null
    },
    {
      "time": 158.449,
      "time_str": "02:38.449",
      "text": "只要努力向前进　哪怕高山把路挡",
      "translation": null
    },
    {
      "time": 163.618,
      "time_str": "02:43.618",
      "text": "朗里格朗里格朗里格朗　遇见了一位好姑娘",
      "translation": null
    },
    {
      "time": 171.118,
      "time_str": "02:51.118",
      "text": "亲爱的好姑娘　天真的好姑娘",
      "translation": null
    },
    {
      "time": 176.529,
      "time_str": "02:56.529",
      "text": "不用悲不用伤　前途自有风和浪",
      "translation": null
    },
    {
      "time": 181.58,
      "time_str": "03:01.580",
      "text": "稳把舵　齐鼓桨　哪怕是大海洋",
      "translation": null
    },
    {
      "time": 186.618,
      "time_str": "03:06.618",
      "text": "向前进　莫彷徨　黑暗尽处有曙光",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "春天里 - 费玉清.lrc"
}