  "lyrics": [
    {
      "time": 20.64,
      "time_str": "00:20.640",
      "text": "我是一只卑微的鸟",
      "translation": null
    },
    {
      "time": 25.86,
      "time_str": "00:25.860",
      "text": "总逃不出他的魔爪",
      "translation": null
    },
    {
      "time": 31.14,
      "time_str": "00:31.140",
      "text": "不是我的心在动摇",
      "translation": null
    },
    {
      "time": 36.18,
      "time_str": "00:36.180",
      "text": "是他对我不怎么好",
      "translation": null
    },
    {
      "time": 40.83,
      "time_str": "00:40.830",
      "text": "清早的阳光穿透了枝桠摇晃",
      "translation": null
    },
    {
      "time": 46.65,
      "time_str": "00:46.650",
      "text": "是谁存在一丝幻想",
      "translation": null
    },
    {
      "time": 51.33,
      "time_str": "00:51.330",
      "text": "你说我配不上你也不会勉强",
      "translation": null
    },
    {
      "time": 57.15,
      "time_str": "00:57.150",
      "text": "我也刚好不痛不痒",
      "translation": null
    },
    {
      "time": 61.5,
      "time_str": "01:01.500",
      "text": "孤独的鸟",
      "translation": null
    },
    {
      "time": 63.06,
      "time_str": "01:03.060",
      "text": "飞在蓝天怀抱",
      "translation": null
    },
    {
      "time": 66.69,
      "time_str": "01:06.690",
      "text": "远方的岛是我栖息依靠",
      "translation": null
    },
    {
      "time": 71.82,
      "time_str": "01:11.820",
      "text": "温暖阳光",
      "translation": null
    },
    {
      "time": 73.53,
      "time_str": "01:13.530",
      "text": "照在我的羽毛",
      "translation": null
    },
    {
      "time": 76.74,
      "time_str": "01:16.740",
      "text": "空虚烦恼",
      "translation": null
    },
    {
      "time": 79.98,
      "time_str": "01:19.980",
      "text": "减少",
      "translation": null
    },
    {
      "time": 82.35,
      "time_str": "01:22.350",
      "text": "孤独的鸟",
      "translation": null
    },
    {
      "time": 84.0,
      "time_str": "01:24.000",
      "text": "逃离世间喧嚣",
      "translation": null
    },
    {
      "time": 87.51,
      "time_str": "01:27.510",
      "text": "飞的更高",
      "translation": null
    },
    {
      "time": 89.22,
      "time_str": "01:29.220",
      "text": "迎接爱的怀抱",
      "translation": null
    },
    {
      "time": 92.7,
      "time_str": "01:32.700",
      "text": "我不在被困在爱情的牢",
      "translation": null
    },
    {
      "time": 97.65,
      "time_str": "01:37.650",
      "text": "没有烦恼",
      "translation": null
    },
