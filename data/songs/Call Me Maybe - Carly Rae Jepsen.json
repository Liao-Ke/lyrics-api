    {
      "time": 4.46,
      "time_str": "00:04.460",
      "text": "I threw a wish in the well",
      "translation": "我将一个愿望投入许愿池中"
    },
    {
      "time": 6.25,
      "time_str": "00:06.250",
      "text": "Don’t ask me I’ll never tell",
      "translation": "别问我,我绝不泄露"
    },
    {
      "time": 8.289,
      "time_str": "00:08.289",
      "text": "I looked to you as it fell",
      "translation": "它落下时我与你相遇"
    },
    {
      "time": 10.25,
      "time_str": "00:10.250",
      "text": "And now you’re in my way",
      "translation": "如今你出现在我面前"
    },
    {
      "time": 12.6,
      "time_str": "00:12.600",
      "text": "I’d trade my soul for a wish",
      "translation": "我用自己的灵魂交换一个愿望"
    },
    {
      "time": 14.279,
      "time_str": "00:14.279",
      "text": "Pennies and dimes for a kiss",
      "translation": "放弃了所有金钱只为了一个吻"
    },
    {
      "time": 16.289,
      "time_str": "00:16.289",
      "text": "I wasn’t looking for this",
      "translation": "这可不是我想要的"
    },
    {
      "time": 18.7,
      "time_str": "00:18.700",
      "text": "But now you’re in my way",
      "translation": "但是如今你出现在我的面前"
    },
    {
      "time": 20.59,
      "time_str": "00:20.590",
      "text": "Your stare was holding",
      "translation": "你眼神坚定"
    },
    {
