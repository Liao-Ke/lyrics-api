  "lyrics": [
    {
      "time": 16.86,
      "time_str": "00:16.860",
      "text": "习惯听你分享生活细节",
      "translation": null
    },
    {
      "time": 23.99,
      "time_str": "00:23.990",
      "text": "害怕破坏完美的平衡点",
      "translation": null
    },
    {
      "time": 31.53,
      "time_str": "00:31.530",
      "text": "保持着距离一颗心的遥远",
      "translation": null
    },
    {
      "time": 37.32,
      "time_str": "00:37.320",
      "text": "我的寂寞你就 听不见",
      "translation": null
    },
    {
      "time": 45.81,
      "time_str": "00:45.810",
      "text": "我走回从前你往未来飞",
      "translation": null
    },
    {
      "time": 53.19,
      "time_str": "00:53.190",
      "text": "遇见对的人错过交叉点",
      "translation": null
    },
    {
      "time": 60.77,
      "time_str": "01:00.770",
      "text": "明明你就已经站在我面前",
      "translation": null
    },
    {
      "time": 66.56,
      "time_str": "01:06.560",
      "text": "我却不断挥手说再见",
      "translation": null
    },
    {
      "time": 73.34,
      "time_str": "01:13.340",
      "text": "以后别做朋友",
      "translation": null
    },
    {
      "time": 77.28,
      "time_str": "01:17.280",
      "text": "朋友不能牵手",
      "translation": null
    },
    {
      "time": 81.12,
      "time_str": "01:21.120",
      "text": "想爱你的冲动我只能笑着带过",
      "translation": null
    },
    {
      "time": 88.39,
      "time_str": "01:28.390",
      "text": "最好的朋友有些梦不能说出口",
      "translation": null
    },
    {
      "time": 98.08,
      "time_str": "01:38.080",
      "text": "就不用承担会失去你的心痛",
      "translation": null
    },
    {
      "time": 123.26,
      "time_str": "02:03.260",
      "text": "划一个安全的天空界线",
      "translation": null
    },
    {
      "time": 130.69,
      "time_str": "02:10.690",
      "text": "谁都不准为我们掉眼泪",
      "translation": null
    },
    {
      "time": 137.96,
      "time_str": "02:17.960",
      "text": "放弃好好爱一个人的机会",
      "translation": null
    },
    {
      "time": 143.81,
      "time_str": "02:23.810",
      "text": "要看着你幸福到永远",
      "translation": null
    },
    {
      "time": 150.55,
      "time_str": "02:30.550",
      "text": "以后别做朋友",
      "translation": null
    },
    {
      "time": 154.54,
      "time_str": "02:34.540",
      "text": "朋友不能牵手",
      "translation": null
    },
    {
      "time": 158.44,
      "time_str": "02:38.440",
      "text": "想爱你的冲动我只能笑着带过",
      "translation": null
    },
    {
      "time": 165.56,
      "time_str": "02:45.560",
      "text": "最好的朋友有些梦不能说出口",
      "translation": null
    },
    {
      "time": 175.34,
      "time_str": "02:55.340",
      "text": "就不用承担会失去你的心痛",
      "translation": null
    },
    {
      "time": 183.01,
      "time_str": "03:03.010",
      "text": "忍住失控太折磨 我自作自受",
      "translation": null
    },
    {
      "time": 190.1,
      "time_str": "03:10.100",
      "text": "回忆都是我 好不了的伤口",
      "translation": null
    },
    {
      "time": 200.24,
      "time_str": "03:20.240",
      "text": "以后还是朋友",
      "translation": null
    },
    {
      "time": 204.45,
      "time_str": "03:24.450",
      "text": "还是你最懂我",
      "translation": null
    },
    {
      "time": 208.15,
      "time_str": "03:28.150",
      "text": "我们有始有终就走到世界尽头",
      "translation": null
    },
    {
      "time": 215.42,
      "time_str": "03:35.420",
      "text": "永远的朋友祝福我遇见爱以后",
      "translation": null
    },
    {
      "time": 226.94,
      "time_str": "03:46.940",
      "text": "不会再懦弱紧紧握住那双手",
      "translation": null
    },
