  "lyrics": [
    {
      "time": 3.0,
      "time_str": "00:03.000",
      "text": "女声 : 宋玉双",
      "translation": null
    },
    {
      "time": 25.39,
      "time_str": "00:25.390",
      "text": "你陪我步入蝉夏 越过城市喧嚣",
      "translation": null
    },
    {
      "time": 32.31,
      "time_str": "00:32.310",
      "text": "歌声还在游走 你榴花般的双眸",
      "translation": null
    },
    {
      "time": 38.42,
      "time_str": "00:38.420",
      "text": "不见你的温柔，丢失花间欢笑",
      "translation": null
    },
    {
      "time": 44.45,
      "time_str": "00:44.450",
      "text": "岁月无法停留，流云的等候",
      "translation": null
    },
    {
      "time": 53.3,
      "time_str": "00:53.300",
      "text": "我真的好想你，在每一个雨季",
      "translation": null
    },
    {
      "time": 58.84,
      "time_str": "00:58.840",
      "text": "你选择遗忘的，是我最不舍的",
      "translation": null
    },
    {
      "time": 64.617,
      "time_str": "01:04.617",
      "text": "纸短情长啊，道不尽太多涟漪",
      "translation": null
    },
    {
      "time": 70.409,
      "time_str": "01:10.409",
      "text": "我的故事都是关于你呀",
      "translation": null
    },
    {
      "time": 80.837,
      "time_str": "01:20.837",
      "text": "怎么会爱上了他，并决定跟他回家",
      "translation": null
    },
    {
      "time": 85.319,
      "time_str": "01:25.319",
      "text": "放弃了我的所有我的一切无所谓",
      "translation": null
    },
    {
      "time": 90.489,
      "time_str": "01:30.489",
      "text": "纸短情长啊，诉不完当时年少",
      "translation": null
