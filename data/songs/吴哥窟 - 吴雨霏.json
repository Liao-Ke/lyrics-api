  "lyrics": [
    {
      "time": 14.32,
      "time_str": "00:14.320",
      "text": "睁开双眼做场梦",
      "translation": null
    },
    {
      "time": 19.05,
      "time_str": "00:19.050",
      "text": "问你 送我归家有何用",
      "translation": null
    },
    {
      "time": 25.31,
      "time_str": "00:25.310",
      "text": "虽知道你的她 无言地向你尽忠",
      "translation": null
    },
    {
      "time": 31.8,
      "time_str": "00:31.800",
      "text": "望见你隐藏你戒指 便沉重",
      "translation": null
    },
    {
      "time": 39.86,
      "time_str": "00:39.860",
      "text": "心声安葬在岩洞",
      "translation": null
    },
    {
      "time": 44.88,
      "time_str": "00:44.880",
      "text": "上帝 四次三番再愚弄",
      "translation": null
    },
    {
      "time": 51.29,
      "time_str": "00:51.290",
      "text": "听得见耳边风 难逃避你那面孔",
      "translation": null
    },
    {
      "time": 57.75,
      "time_str": "00:57.750",
      "text": "越要退出 越向你生命移动",
      "translation": null
    },
    {
      "time": 64.299,
      "time_str": "01:04.299",
      "text": "难道我有勇气与你在一起",
      "translation": null
    },
    {
      "time": 68.986,
      "time_str": "01:08.986",
      "text": "庆祝正日",
      "translation": null
    },
    {
      "time": 70.736,
      "time_str": "01:10.736",
      "text": "难道你有勇气反悔诺言 你专一",
      "translation": null
    },
    {
      "time": 77.168,
      "time_str": "01:17.168",
      "text": "两个人 多挤迫",
      "translation": null
    },
    {
      "time": 80.808,
      "time_str": "01:20.808",
      "text": "难容纳多一番秘密",
      "translation": null
    },
    {
      "time": 83.816,
      "time_str": "01:23.816",
      "text": "捉不紧 变得更加固执",
      "translation": null
    },
    {
      "time": 127.569,
      "time_str": "02:07.569",
      "text": "不应该滥用名义",
      "translation": null
    },
    {
      "time": 132.358,
      "time_str": "02:12.358",
      "text": "被你 引诱多一个名字",
      "translation": null
    },
    {
      "time": 138.878,
      "time_str": "02:18.878",
      "text": "身份远 记忆深 浮尘滴进觉悟寺",
      "translation": null
    },
    {
      "time": 145.367,
      "time_str": "02:25.367",
      "text": "雾里看花 没有发生任何事",
      "translation": null
    },
    {
      "time": 151.788,
      "time_str": "02:31.788",
      "text": "难道我有勇气与你在一起",
      "translation": null
    },
    {
      "time": 156.06,
      "time_str": "02:36.060",
      "text": "庆祝正日",
      "translation": null
    },
    {
      "time": 158.328,
      "time_str": "02:38.328",
      "text": "难道你有勇气反悔诺言 你专一",
      "translation": null
    },
    {
      "time": 164.718,
      "time_str": "02:44.718",
      "text": "两个人 多挤迫",
      "translation": null
    },
    {
      "time": 168.348,
      "time_str": "02:48.348",
      "text": "难容纳多一番秘密",
      "translation": null
    },
    {
      "time": 171.387,
      "time_str": "02:51.387",
      "text": "捉不紧 变得更加固执",
      "translation": null
    },
    {
      "time": 177.778,
      "time_str": "02:57.778",
      "text": "原谅你太理性 与我在一起要守秘密",
      "translation": null
    },
    {
      "time": 184.298,
      "time_str": "03:04.298",
      "text": "原谅我太野性 想这段情更深刻",
      "translation": null
    },
    {
      "time": 190.727,
      "time_str": "03:10.727",
      "text": "两个人 一消失",
      "translation": null
    },
    {
      "time": 194.337,
      "time_str": "03:14.337",
      "text": "谣言便得不到证实",
      "translation": null
    },
    {
      "time": 197.318,
      "time_str": "03:17.318",
      "text": "只得幽暗的晚空 记得",
      "translation": null
    }
