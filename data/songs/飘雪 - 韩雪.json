  "lyrics": [
    {
      "time": 34.27,
      "time_str": "00:34.270",
      "text": "忧郁的一片天 飘着纷飞的雪",
      "translation": null
    },
    {
      "time": 40.65,
      "time_str": "00:40.650",
      "text": "这一泓伊豆的温泉",
      "translation": null
    },
    {
      "time": 44.25,
      "time_str": "00:44.250",
      "text": "浸湿我孤单的思念",
      "translation": null
    },
    {
      "time": 47.68,
      "time_str": "00:47.680",
      "text": "飘零的一片叶 就像你我的终结",
      "translation": null
    },
    {
      "time": 54.23,
      "time_str": "00:54.230",
      "text": "这一泓伊豆的温泉",
      "translation": null
    },
    {
      "time": 57.53,
      "time_str": "00:57.530",
      "text": "盛满温暖的从前",
      "translation": null
    },
    {
      "time": 62.14,
      "time_str": "01:02.140",
      "text": "你的手 曾经拥着我的肩",
      "translation": null
    },
    {
      "time": 68.55,
      "time_str": "01:08.550",
      "text": "呢喃着 爱我直到永远",
      "translation": null
    },
    {
      "time": 75.41,
      "time_str": "01:15.410",
      "text": "雪花 像绽放的礼花",
      "translation": null
    },
    {
      "time": 80.86,
      "time_str": "01:20.860",
      "text": "天地间肆意地飘洒",
      "translation": null
    },
    {
      "time": 85.44,
      "time_str": "01:25.440",
      "text": "纵情在一刹那",
      "translation": null
    },
    {
      "time": 88.81,
      "time_str": "01:28.810",
      "text": "为何现在只剩下  风吹乱我的发",
      "translation": null
    },
    {
      "time": 95.1,
      "time_str": "01:35.100",
      "text": "撕开我记忆的伤疤",
      "translation": null
    },
    {
      "time": 98.8,
      "time_str": "01:38.800",
      "text": "让往事像雾气慢慢地蒸发",
      "translation": null
    },
    {
      "time": 102.47,
      "time_str": "01:42.470",
      "text": "让我知道什么叫放不下",
      "translation": null
    },
    {
      "time": 106.33,
      "time_str": "01:46.330",
      "text": "为何我的泪，会不停地流下",
      "translation": null
    },
    {
      "time": 111.6,
      "time_str": "01:51.600",
      "text": "滑过你曾经亲吻的脸颊",
      "translation": null
    },
    {
      "time": 115.479,
      "time_str": "01:55.479",
      "text": "所有的对错在顷刻  崩塌",
      "translation": null
    },
    {
