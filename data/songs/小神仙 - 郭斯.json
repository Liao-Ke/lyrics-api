    {
      "time": 141.13,
      "time_str": "02:21.130",
      "text": "元神出了窍 七窍皆生烟",
      "translation": null
    },
    {
      "time": 147.82,
      "time_str": "02:27.820",
      "text": "昨夜我梦里 在阎罗殿",
      "translation": null
    },
    {
      "time": 151.25,
      "time_str": "02:31.250",
      "text": "给阎王老爷 相过面",
      "translation": null
