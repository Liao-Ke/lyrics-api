  "lyrics": [
    {
      "time": 9.05,
      "time_str": "00:09.050",
      "text": "封面：郭斯/山泠",
      "translation": null
    },
    {
      "time": 12.82,
      "time_str": "00:12.820",
      "text": "行过小周天 念咒掐指决",
      "translation": null
    },
    {
      "time": 19.38,
      "time_str": "00:19.380",
      "text": "贫道我本是 龙虎山",
      "translation": null
    },
    {
      "time": 22.94,
      "time_str": "00:22.940",
      "text": "得了道的小神仙",
      "translation": null
    },
    {
      "time": 25.86,
      "time_str": "00:25.860",
      "text": "-",
      "translation": null
    },
    {
      "time": 26.31,
      "time_str": "00:26.310",
      "text": "推过九宫图 演过离震乾",
      "translation": null
    },
    {
      "time": 32.83,
      "time_str": "00:32.830",
      "text": "贫道我通晓 天文地理",
      "translation": null
    },
    {
      "time": 36.35,
      "time_str": "00:36.350",
      "text": "上下这五千年",
      "translation": null
    },
    {
      "time": 39.2,
      "time_str": "00:39.200",
      "text": "-",
      "translation": null
    },
    {
      "time": 39.71,
      "time_str": "00:39.710",
      "text": "拜过三清祖 别过了龙虎山",
      "translation": null
    },
    {
      "time": 46.09,
      "time_str": "00:46.090",
      "text": "小道我走南又闯北",
      "translation": null
    },
    {
      "time": 49.64,
      "time_str": "00:49.640",
      "text": "修行在天地间",
      "translation": null
    },
    {
      "time": 52.68,
      "time_str": "00:52.680",
      "text": "-",
      "translation": null
    },
    {
      "time": 52.99,
      "time_str": "00:52.990",
      "text": "来到贵宝地 肚皮叫破天",
      "translation": null
    },
    {
      "time": 59.54,
      "time_str": "00:59.540",
      "text": "小道我 在此卜卦算命",
      "translation": null
    },
    {
      "time": 63.31,
      "time_str": "01:03.310",
      "text": "凭本事混口饭 劳烦",
      "translation": null
    },
    {
      "time": 67.99,
      "time_str": "01:07.990",
      "text": "-",
      "translation": null
    },
    {
      "time": 68.7,
      "time_str": "01:08.700",
      "text": "不论是问姻缘 还是来求官",
      "translation": null
    },
    {
      "time": 76.1,
      "time_str": "01:16.100",
      "text": "小道我念咒 掐指一算",
      "translation": null
    },
    {
      "time": 79.65,
      "time_str": "01:19.650",
      "text": "指点个一二三",
      "translation": null
    },
    {
      "time": 82.57,
      "time_str": "01:22.570",
      "text": "-",
      "translation": null
    },
    {
      "time": 82.91,
      "time_str": "01:22.910",
      "text": "不管你听不听 不管你信不信",
      "translation": null
    },
    {
      "time": 89.14,
      "time_str": "01:29.140",
      "text": "你我二人 在此相遇",
      "translation": null
    },
    {
      "time": 93.09,
      "time_str": "01:33.090",
      "text": "命中早注定",
      "translation": null
    },
    {
      "time": 95.83,
      "time_str": "01:35.830",
      "text": "-",
      "translation": null
    },
    {
      "time": 96.06,
      "time_str": "01:36.060",
      "text": "我是算命的小神仙",
      "translation": null
    },
    {
      "time": 101.17,
      "time_str": "01:41.170",
      "text": "卜卦来换酒钱",
      "translation": null
    },
    {
      "time": 104.07,
