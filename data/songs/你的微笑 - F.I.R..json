  "lyrics": [
    {
      "time": 37.85,
      "time_str": "00:37.850",
      "text": "喜欢用我的音调",
      "translation": null
    },
    {
      "time": 40.35,
      "time_str": "00:40.350",
      "text": "唱出你的味道",
      "translation": null
    },
    {
      "time": 42.06,
      "time_str": "00:42.060",
      "text": "这一秒",
      "translation": null
    },
    {
      "time": 43.34,
      "time_str": "00:43.340",
      "text": "有种感觉甜蜜的发酵",
      "translation": null
    },
    {
      "time": 45.76,
      "time_str": "00:45.760",
      "text": "一百种言语知道",
      "translation": null
    },
    {
      "time": 48.07,
      "time_str": "00:48.070",
      "text": "爱有一个声道",
      "translation": null
    },
    {
      "time": 49.79,
      "time_str": "00:49.790",
      "text": "才明了",
      "translation": null
    },
    {
      "time": 51.18,
      "time_str": "00:51.180",
      "text": "是你眼神传来的暗号",
      "translation": null
    },
    {
      "time": 53.43,
      "time_str": "00:53.430",
      "text": "太多的幸福报到",
      "translation": null
    },
    {
      "time": 55.91,
      "time_str": "00:55.910",
      "text": "拼凑爱的美妙",
      "translation": null
    },
    {
      "time": 57.56,
      "time_str": "00:57.560",
      "text": "笑一笑",
      "translation": null
    },
    {
      "time": 58.99,
      "time_str": "00:58.990",
      "text": "投入你怀里然后撒娇",
      "translation": null
    },
    {
      "time": 61.43,
      "time_str": "01:01.430",
      "text": "不需要别人来教",
      "translation": null
    },
    {
      "time": 63.56,
      "time_str": "01:03.560",
      "text": "把爱紧紧抓牢",
      "translation": null
    },
    {
      "time": 65.59,
      "time_str": "01:05.590",
      "text": "这一秒",
      "translation": null
    },
    {
      "time": 66.57,
      "time_str": "01:06.570",
      "text": "决定拥抱你给的美好",
      "translation": null
    },
    {
      "time": 68.81,
      "time_str": "01:08.810",
      "text": "爱情是你独特的味道",
      "translation": null
    },
    {
      "time": 71.56,
      "time_str": "01:11.560",
      "text": "在我的心中围绕",
      "translation": null
    },
    {
      "time": 73.22,
      "time_str": "01:13.220",
      "text": "别人都不了",
      "translation": null
    },
    {
      "time": 75.19,
      "time_str": "01:15.190",
      "text": "只有你知道",
      "translation": null
    },
    {
      "time": 77.01,
      "time_str": "01:17.010",
      "text": "因为你世界不再单调",
      "translation": null
    },
    {
      "time": 81.25,
      "time_str": "01:21.250",
      "text": "我的微笑你明白就很好",
      "translation": null
    },
    {
      "time": 84.78,
      "time_str": "01:24.780",
      "text": "你就像月亮绕着轨道",
      "translation": null
    },
    {
      "time": 86.73,
      "time_str": "01:26.730",
      "text": "拥抱着地球闪耀",
      "translation": null
    },
    {
      "time": 88.93,
      "time_str": "01:28.930",
      "text": "在我的星球写下惊叹号",
      "translation": null
    },
    {
      "time": 92.54,
      "time_str": "01:32.540",
      "text": "有了你世界神魂颠倒",
      "translation": null
    },
    {
      "time": 95.47,
      "time_str": "01:35.470",
      "text": "你的微笑",
      "translation": null
    },
    {
      "time": 98.18,
      "time_str": "01:38.180",
      "text": "编织了每一个奇妙",
