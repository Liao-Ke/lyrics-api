  "lyrics": [
    {
      "time": 21.62,
      "time_str": "00:21.620",
      "text": "我们等待过  也奢望过",
      "translation": null
    },
    {
      "time": 25.57,
      "time_str": "00:25.570",
      "text": "怀疑着一切没发生过",
      "translation": null
    },
    {
      "time": 29.6,
      "time_str": "00:29.600",
      "text": "原来寂寞都是一样的",
      "translation": null
    },
    {
      "time": 33.72,
      "time_str": "00:33.720",
      "text": "不管谁爱得更多",
      "translation": null
    },
    {
      "time": 37.97,
      "time_str": "00:37.970",
      "text": "所以沉默着  也很痛着",
      "translation": null
    },
    {
      "time": 42.45,
      "time_str": "00:42.450",
      "text": "靠近了又能说出什么",
      "translation": null
    },
    {
      "time": 46.47,
      "time_str": "00:46.470",
      "text": "想要抹去你笑的影子",
      "translation": null
    },
    {
      "time": 50.66,
      "time_str": "00:50.660",
      "text": "从这一刻到最后",
      "translation": null
    },
    {
      "time": 56.64,
      "time_str": "00:56.640",
      "text": "我一直在努力往前走",
      "translation": null
    },
    {
      "time": 60.74,
      "time_str": "01:00.740",
      "text": "要把一路风景都看过",
      "translation": null
    },
    {
      "time": 65.4,
      "time_str": "01:05.400",
      "text": "祝福能不能代替眼泪",
      "translation": null
    },
    {
      "time": 69.17,
      "time_str": "01:09.170",
      "text": "那幸福一直只是你的",
      "translation": null
    },
    {
      "time": 73.47,
      "time_str": "01:13.470",
      "text": "总该试着把风雨忘了",
      "translation": null
    },
    {
      "time": 77.37,
      "time_str": "01:17.370",
      "text": "爱与恨都已经舍不得",
      "translation": null
    },
    {
      "time": 82.8,
      "time_str": "01:22.800",
      "text": "不是朋友我们能是什么",
      "translation": null
    },
    {
      "time": 86.31,
      "time_str": "01:26.310",
      "text": "像陌生人相遇时一秒凝望着",
      "translation": null
    },
    {
