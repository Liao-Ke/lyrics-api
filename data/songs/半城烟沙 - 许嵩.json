  "lyrics": [
    {
      "time": 34.49,
      "time_str": "00:34.490",
      "text": "有些爱像断线纸鸢 结局悲余手中线",
      "translation": null
    },
    {
      "time": 42.69,
      "time_str": "00:42.690",
      "text": "有些恨像是一个圈 冤冤相报不了结",
      "translation": null
    },
    {
      "time": 50.05,
      "time_str": "00:50.050",
      "text": "只为了完成一个夙愿 还将付出几多鲜血",
      "translation": null
    },
    {
      "time": 58.3,
      "time_str": "00:58.300",
      "text": "忠义之言 自欺欺人的谎言",
      "translation": null
    },
    {
      "time": 67.64,
      "time_str": "01:07.640",
      "text": "有些情入苦难回绵 窗间月夕夕成玦",
      "translation": null
    },
    {
      "time": 75.81,
      "time_str": "01:15.810",
      "text": "有些仇心藏却无言 腹化风雪为刀剑",
      "translation": null
    },
    {
      "time": 83.28,
      "time_str": "01:23.280",
      "text": "只为了完成一个夙愿 荒乱中邪正如何辨",
      "translation": null
    },
    {
      "time": 90.99,
      "time_str": "01:30.990",
      "text": "飞沙狼烟将乱我 徒有悲添",
      "translation": null
    },
    {
      "time": 99.74,
      "time_str": "01:39.740",
      "text": "半城烟沙 兵临池下",
      "translation": null
    },
    {
      "time": 103.55,
      "time_str": "01:43.550",
      "text": "金戈铁马 替谁争天下",
      "translation": null
    },
    {
      "time": 107.49,
      "time_str": "01:47.490",
      "text": "一将成 万骨枯 多少白发送走黑发",
      "translation": null
    },
    {
      "time": 115.09,
      "time_str": "01:55.090",
      "text": "半城烟沙 随风而下",
      "translation": null
    },
    {
      "time": 120.72,
      "time_str": "02:00.720",
      "text": "手中还有 一缕牵挂",
      "translation": null
    },
    {
      "time": 125.4,
      "time_str": "02:05.400",
      "text": "只盼归田卸甲 还能捧回你沏的茶",
      "translation": null
    },
    {
