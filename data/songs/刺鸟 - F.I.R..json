    {
      "time": 35.73,
      "time_str": "00:35.730",
      "text": "也许就是要等 一百个世纪",
      "translation": null
    },
    {
      "time": 40.72,
      "time_str": "00:40.720",
      "text": "我们才能够发现真爱的美丽",
      "translation": null
    },
    {
      "time": 47.51,
      "time_str": "00:47.510",
      "text": "龙舌兰的花朵不代表绚丽",
      "translation": null
    },
    {
      "time": 52.69,
      "time_str": "00:52.690",
      "text": "选择燃烧了自己将真爱延续",
      "translation": null
    },
    {
      "time": 59.76,
      "time_str": "00:59.760",
      "text": "就像刺鸟的宿命悲剧却勇敢",
      "translation": null
    },
    {
      "time": 66.13,
      "time_str": "01:06.130",
      "text": "用生命交换结局的灿烂",
      "translation": null
    },
    {
      "time": 71.61,
      "time_str": "01:11.610",
      "text": "天上的风被谁推开",
      "translation": null
    },
    {
      "time": 74.66,
      "time_str": "01:14.660",
      "text": "温暖的手是你的爱",
      "translation": null
