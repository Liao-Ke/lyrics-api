    {
      "time": 8.804,
      "time_str": "00:08.804",
      "text": "有没有人可以告诉我,",
      "translation": null
    },
    {
      "time": 11.369,
      "time_str": "00:11.369",
      "text": "考验一断爱情或是要忘记一个人.",
      "translation": null
    },
    {
      "time": 15.132,
      "time_str": "00:15.132",
      "text": "究竟要多久的时间呢!",
      "translation": null
    },
    {
      "time": 17.256,
      "time_str": "00:17.256",
      "text": "两年.....足够长了吗?~",
      "translation": null
    },
    {
      "time": 22.264,
      "time_str": "00:22.264",
      "text": "翻开一本旧日记",
      "translation": null
    },
    {
      "time": 26.134,
      "time_str": "00:26.134",
      "text": "记载着一段旧恋情",
      "translation": null
    },
    {
      "time": 30.08,
      "time_str": "00:30.080",
      "text": "每段都那么的甜蜜",
      "translation": null
    },
    {
      "time": 34.288,
      "time_str": "00:34.288",
      "text": "往事历历在这里",
      "translation": null
    },
    {
      "time": 37.639,
      "time_str": "00:37.639",
      "text": "曾看过多少的风雨",
      "translation": null
    },
    {
      "time": 41.528,
      "time_str": "00:41.528",
      "text": "曾说过要到哪里去",
      "translation": null
    },
    {
      "time": 45.423,
      "time_str": "00:45.423",
      "text": "曾做过觉得傻的事",
      "translation": null
    },
    {
      "time": 49.708,
      "time_str": "00:49.708",
      "text": "爱过在这城市里",
      "translation": null
    },
    {
      "time": 53.135,
      "time_str": "00:53.135",
      "text": "昨晚下了一场雨",
      "translation": null
    },
    {
      "time": 55.504,
      "time_str": "00:55.504",
      "text": "让我忽然梦里见到你",
      "translation": null
    },
    {
      "time": 61.283,
      "time_str": "01:01.283",
      "text": "躲在某个地方哭泣",
      "translation": null
