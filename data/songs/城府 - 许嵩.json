    {
      "time": 78.8,
      "time_str": "01:18.800",
      "text": "我爱的有多蠢 不想再问",
      "translation": null
    },
    {
      "time": 82.95,
      "time_str": "01:22.950",
      "text": "也无法去恨 毕竟你是我最爱的人",
      "translation": null
    },
    {
      "time": 92.47,
      "time_str": "01:32.470",
      "text": "曾经你的眼神 看起来那么单纯",
      "translation": null
    },
    {
      "time": 95.51,
      "time_str": "01:35.510",
      "text": "嗯 指向你干净的灵魂",
      "translation": null
    },
    {
      "time": 98.88,
      "time_str": "01:38.880",
      "text": "什么时候开始变得满是伤痕",
      "translation": null
    },
    {
      "time": 102.17,
      "time_str": "01:42.170",
      "text": "戴上假面也好 如果不会疼",
      "translation": null
    },
    {
      "time": 105.67,
      "time_str": "01:45.670",
      "text": "爱情这个世界 有那么多的悖论",
      "translation": null
    },
    {
      "time": 108.86,
      "time_str": "01:48.860",
      "text": "小心翼翼不见得就会获得满分",
