  "lyrics": [
    {
      "time": 34.38,
      "time_str": "00:34.380",
      "text": "你走之后 一个夏季熬成一个秋",
      "translation": null
    },
    {
      "time": 37.92,
      "time_str": "00:37.920",
      "text": "我的书上你的正楷眉清目秀",
      "translation": null
    },
    {
      "time": 41.13,
      "time_str": "00:41.130",
      "text": "一字一字宣告我们和平分手",
      "translation": null
    },
    {
      "time": 44.56,
      "time_str": "00:44.560",
      "text": "好委婉的交流 还带一点征求",
      "translation": null
    },
    {
      "time": 48.41,
      "time_str": "00:48.410",
      "text": "你已成风 幻化的雨下错了季候",
      "translation": null
    },
    {
      "time": 51.6,
      "time_str": "00:51.600",
      "text": "明媚的眼眸里温柔化为了乌有",
      "translation": null
    },
    {
      "time": 54.66,
      "time_str": "00:54.660",
      "text": "一层一层院墙把你的心困守",
      "translation": null
    },
    {
      "time": 58.16,
      "time_str": "00:58.160",
      "text": "如果没法回头 这样也没不妥",
      "translation": null
    },
    {
      "time": 61.87,
      "time_str": "01:01.870",
      "text": "你的城府有多深",
      "translation": null
    },
    {
      "time": 65.22,
      "time_str": "01:05.220",
      "text": "我爱的有多蠢 是我太笨",
      "translation": null
    },
    {
      "time": 68.93,
      "time_str": "01:08.930",
      "text": "还是太认真 幻想和你过一生",
      "translation": null
    },
    {
      "time": 75.34,
      "time_str": "01:15.340",
      "text": "你的城府有多深",
      "translation": null
