  "lyrics": [
    {
      "time": 33.14,
      "time_str": "00:33.140",
      "text": "每当我听见忧郁的乐章 勾起回忆的伤",
      "translation": null
    },
    {
      "time": 40.06,
      "time_str": "00:40.060",
      "text": "每当我看见白色的月光 想起你的脸庞",
      "translation": null
    },
    {
      "time": 46.56,
      "time_str": "00:46.560",
      "text": "明知不该去想 不能去想 偏又想到迷惘",
      "translation": null
    },
    {
      "time": 53.78,
      "time_str": "00:53.780",
      "text": "是谁让我心酸 谁让我牵挂 是你呀",
      "translation": null
    },
    {
      "time": 60.817,
      "time_str": "01:00.817",
      "text": "我知道那些不该说的话 让你负气流浪",
      "translation": null
    },
    {
      "time": 67.561,
      "time_str": "01:07.561",
      "text": "想知道多年漂浮的时光 是否你也想家",
      "translation": null
    },
    {
      "time": 74.281,
      "time_str": "01:14.281",
      "text": "如果当时吻你 当时抱你 也许结局难讲",
      "translation": null
    },
    {
      "time": 81.45,
      "time_str": "01:21.450",
      "text": "我那么多遗憾 那么多期盼 你知道吗",
      "translation": null
    },
    {
      "time": 87.59,
      "time_str": "01:27.590",
      "text": "我爱你 是多么清楚多么坚固的信仰",
      "translation": null
    },
    {
      "time": 94.569,
      "time_str": "01:34.569",
      "text": "我爱你 是多么温暖多么勇敢的力量",
      "translation": null
    },
    {
      "time": 102.09,
      "time_str": "01:42.090",
      "text": "我不管心多伤 不管爱多慌 不管别人怎么想",
      "translation": null
    },
    {
      "time": 108.361,
      "time_str": "01:48.361",
      "text": "爱是一种信仰 把我带到你的身旁",
      "translation": null
    },
    {
