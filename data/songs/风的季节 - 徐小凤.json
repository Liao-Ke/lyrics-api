  "lyrics": [
    {
      "time": 21.0,
      "time_str": "00:21.000",
      "text": "凉风轻轻吹到悄然进了我衣襟",
      "translation": null
    },
    {
      "time": 26.0,
      "time_str": "00:26.000",
      "text": "夏天偷去听不见声音",
      "translation": null
    },
    {
      "time": 31.0,
      "time_str": "00:31.000",
      "text": "日子匆匆走过倍令我有百感生",
      "translation": null
    },
    {
      "time": 35.999,
      "time_str": "00:35.999",
      "text": "记挂那一片景象缤纷",
      "translation": null
    },
    {
      "time": 44.999,
      "time_str": "00:44.999",
      "text": "随风轻轻吹到你步进了我的心",
      "translation": null
    },
    {
      "time": 49.999,
      "time_str": "00:49.999",
      "text": "在一息间改变我一生",
      "translation": null
    },
    {
      "time": 54.999,
      "time_str": "00:54.999",
      "text": "付出多少热忱也没法去计得真",
      "translation": null
    },
    {
      "time": 59.998,
      "time_str": "00:59.998",
      "text": "却也不需再惊惧风雨侵",
      "translation": null
    },
    {
      "time": 68.998,
      "time_str": "01:08.998",
      "text": "吹呀吹  让这风吹",
      "translation": null
    },
    {
      "time": 73.998,
      "time_str": "01:13.998",
      "text": "抹干眼眸里亮晶的眼泪",
      "translation": null
    },
    {
      "time": 78.998,
      "time_str": "01:18.998",
      "text": "吹呀吹  让这风吹",
      "translation": null
    },
    {
      "time": 83.998,
      "time_str": "01:23.998",
      "text": "哀伤通通带走  管风里是谁",
      "translation": null
    },
    {
      "time": 98.599,
      "time_str": "01:38.599",
      "text": "从风沙初起想到是季节变更",
      "translation": null
    },
    {
      "time": 103.897,
      "time_str": "01:43.897",
      "text": "梦中醒却岁月如飞奔",
      "translation": null
    },
    {
      "time": 108.897,
      "time_str": "01:48.897",
      "text": "是否早订下来你或我也会变心",
      "translation": null
    },
    {
      "time": 113.897,
      "time_str": "01:53.897",
      "text": "慨叹怎么会久合终要分",
      "translation": null
    },
    {
      "time": 122.897,
      "time_str": "02:02.897",
      "text": "狂风吹得起劲朗日也要被蔽隐",
      "translation": null
    },
    {
      "time": 128.198,
      "time_str": "02:08.198",
      "text": "泛起一片迷朦尘埃滚",
      "translation": null
    },
    {
      "time": 133.199,
      "time_str": "02:13.199",
      "text": "掠走心里一切美梦带去那欢欣",
      "translation": null
    },
    {
      "time": 138.199,
      "time_str": "02:18.199",
      "text": "带去我的爱只是独留恨",
      "translation": null
    },
    {
      "time": 147.498,
      "time_str": "02:27.498",
      "text": "吹呀吹  让这风吹",
      "translation": null
    },
    {
