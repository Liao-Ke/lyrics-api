  "lyrics": [
    {
      "time": 31.42,
      "time_str": "00:31.420",
      "text": "又站在你家的门口",
      "translation": null
    },
    {
      "time": 34.57,
      "time_str": "00:34.570",
      "text": "我们重复沉默",
      "translation": null
    },
    {
      "time": 37.64,
      "time_str": "00:37.640",
      "text": "这样子单方面的守候",
      "translation": null
    },
    {
      "time": 41.45,
      "time_str": "00:41.450",
      "text": "还能多久",
      "translation": null
    },
    {
      "time": 46.75,
      "time_str": "00:46.750",
      "text": "终于你开口向我诉说",
      "translation": null
    },
    {
      "time": 50.09,
      "time_str": "00:50.090",
      "text": "她有多温柔",
      "translation": null
    },
    {
      "time": 52.82,
      "time_str": "00:52.820",
      "text": "虽然你还握着我的手",
      "translation": null
    },
    {
      "time": 56.56,
      "time_str": "00:56.560",
      "text": "但我已不在你心中",
      "translation": null
    },
    {
      "time": 61.44,
      "time_str": "01:01.440",
      "text": "我真的懂",
      "translation": null
    },
    {
      "time": 64.63,
      "time_str": "01:04.630",
      "text": "你不是喜新厌旧",
      "translation": null
    },
    {
      "time": 68.69,
      "time_str": "01:08.690",
      "text": "是我没有",
      "translation": null
    },
    {
      "time": 71.88,
      "time_str": "01:11.880",
      "text": "陪在你身边",
      "translation": null
    },
    {
      "time": 73.69,
      "time_str": "01:13.690",
      "text": "当你寂寞时候",
      "translation": null
    },
    {
      "time": 77.32,
      "time_str": "01:17.320",
      "text": "别再看着我",
      "translation": null
    },
    {
      "time": 79.69,
      "time_str": "01:19.690",
      "text": "说着你爱过",
      "translation": null
    },
    {
      "time": 82.19,
      "time_str": "01:22.190",
      "text": "别太伤痛",
      "translation": null
    },
    {
      "time": 84.0,
      "time_str": "01:24.000",
      "text": "我不难过",
      "translation": null
    },
    {
      "time": 85.25,
      "time_str": "01:25.250",
      "text": "这不算什么",
      "translation": null
    },
    {
      "time": 87.06,
      "time_str": "01:27.060",
      "text": "只是为什么眼泪会流",
      "translation": null
    },
    {
      "time": 90.13,
      "time_str": "01:30.130",
      "text": "我也不懂",
      "translation": null
    },
    {
      "time": 91.32,
      "time_str": "01:31.320",
      "text": "就让我走",
      "translation": null
    },
    {
      "time": 94.44,
      "time_str": "01:34.440",
      "text": "让我开始享受自由",
      "translation": null
    },
    {
      "time": 98.75,
      "time_str": "01:38.750",
      "text": "回忆很多",
      "translation": null
    },
    {
      "time": 101.88,
      "time_str": "01:41.880",
      "text": "你的影子也会充满我生活",
      "translation": null
    },
    {
      "time": 107.19,
      "time_str": "01:47.190",
      "text": "我并不懦弱",
      "translation": null
    },
    {
      "time": 109.82,
      "time_str": "01:49.820",
      "text": "你比谁都懂",
      "translation": null
    },
    {
      "time": 112.13,
      "time_str": "01:52.130",
      "text": "虽然寂寞",
      "translation": null
    },
    {
      "time": 113.82,
      "time_str": "01:53.820",
      "text": "这会是我",
      "translation": null
