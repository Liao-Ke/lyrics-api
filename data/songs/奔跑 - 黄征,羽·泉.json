  "lyrics": [
    {
      "time": 4.74,
      "time_str": "00:04.740",
      "text": "速度七十迈",
      "translation": null
    },
    {
      "time": 7.5,
      "time_str": "00:07.500",
      "text": "心情是自由自在",
      "translation": null
    },
    {
      "time": 11.1,
      "time_str": "00:11.100",
      "text": "希望终点是爱琴海",
      "translation": null
    },
    {
      "time": 14.94,
      "time_str": "00:14.940",
      "text": "全力奔跑梦在彼岸",
      "translation": null
    },
    {
      "time": 18.96,
      "time_str": "00:18.960",
      "text": "我们想漫游世界",
      "translation": null
    },
    {
      "time": 22.83,
      "time_str": "00:22.830",
      "text": "看奇迹就在眼前",
      "translation": null
    },
    {
      "time": 26.4,
      "time_str": "00:26.400",
      "text": "等待夕阳染红了天",
      "translation": null
    },
    {
      "time": 30.21,
      "time_str": "00:30.210",
      "text": "肩并着肩许下心愿",
      "translation": null
    },
    {
      "time": 36.15,
      "time_str": "00:36.150",
      "text": "随风奔跑自由是方向",
      "translation": null
    },
    {
      "time": 40.02,
      "time_str": "00:40.020",
      "text": "追逐雷和闪电的力量",
      "translation": null
    },
    {
      "time": 43.59,
      "time_str": "00:43.590",
      "text": "把浩瀚的海洋装进我胸膛",
      "translation": null
    },
    {
      "time": 47.64,
      "time_str": "00:47.640",
      "text": "即使再小的帆也能远航",
      "translation": null
    },
    {
      "time": 51.42,
      "time_str": "00:51.420",
      "text": "随风飞翔有梦作翅膀",
      "translation": null
    },
    {
      "time": 55.26,
      "time_str": "00:55.260",
      "text": "敢爱敢做勇敢闯一闯",
      "translation": null
    },
    {
      "time": 59.01,
      "time_str": "00:59.010",
      "text": "哪怕遇见再大的风险再大的浪",
      "translation": null
    },
    {
      "time": 63.54,
      "time_str": "01:03.540",
      "text": "也会有默契的目光",
      "translation": null
