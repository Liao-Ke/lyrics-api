    {
      "time": 37.31,
      "time_str": "00:37.310",
      "text": "我听说通常在战争后就会换来和平",
      "translation": null
    },
    {
      "time": 40.45,
      "time_str": "00:40.450",
      "text": "为什么看着我的爸爸一直打我妈妈",
      "translation": null
    },
    {
      "time": 43.61,
      "time_str": "00:43.610",
      "text": "就因为喝醉酒 他就能拿我妈出气",
      "translation": null
    },
    {
      "time": 47.23,
      "time_str": "00:47.230",
      "text": "我真的看不下去 以为我较细汉 哼",
      "translation": null
    },
    {
      "time": 50.9,
      "time_str": "00:50.900",
      "text": "从小到大只有妈妈的温暖",
      "translation": null
    },
    {
      "time": 53.06,
      "time_str": "00:53.060",
      "text": "为什么我爸爸那么凶",
      "translation": null
    },
    {
      "time": 56.45,
      "time_str": "00:56.450",
      "text": "如果真的我有一双翅膀 两双翅膀",
      "translation": null
    },
    {
      "time": 59.41,
      "time_str": "00:59.410",
      "text": "随时出发 偷偷出发",
      "translation": null
    },
    {
      "time": 60.94,
      "time_str": "01:00.940",
      "text": "我一定带我妈走 哈",
      "translation": null
    },
    {
      "time": 63.12,
      "time_str": "01:03.120",
      "text": "从前的教育别人的家庭 别人的爸爸",
      "translation": null
    },
    {
      "time": 65.73,
      "time_str": "01:05.730",
      "text": "种种的暴力因素一定都会有原因",
      "translation": null
    },
    {
      "time": 68.94,
      "time_str": "01:08.940",
      "text": "但是呢 妈跟我都没有错亏我叫你一声爸",
      "translation": null
    },
    {
      "time": 72.16,
      "time_str": "01:12.160",
      "text": "爸 我回来了",
      "translation": null
    },
    {
      "time": 75.81,
      "time_str": "01:15.810",
      "text": "不要再这样打我妈妈",
      "translation": null
    },
    {
      "time": 82.12,
      "time_str": "01:22.120",
      "text": "我说的话你甘会听",
      "translation": null
    },
    {
      "time": 88.42,
      "time_str": "01:28.420",
      "text": "不要再这样打我妈妈",
      "translation": null
    },
    {
      "time": 94.7,
      "time_str": "01:34.700",
      "text": "难道你手不会痛吗",
      "translation": null
    },
    {
      "time": 125.96,
      "time_str": "02:05.960",
      "text": "其实我回家就想要阻止一切",
      "translation": null
    },
    {
      "time": 128.64,
      "time_str": "02:08.640",
      "text": "让家庭回到过去甜甜温馨的欢乐香味",
      "translation": null
    },
    {
      "time": 132.06,
      "time_str": "02:12.060",
      "text": "虽然这是我编造出来的事实",
      "translation": null
    },
    {
      "time": 134.38,
      "time_str": "02:14.380",
      "text": "有点讽刺 有点酸性",
      "translation": null
    },
    {
      "time": 135.62,
      "time_str": "02:15.620",
      "text": "但它确在这快乐社会发生产生共鸣",
      "translation": null
    },
    {
      "time": 138.36,
      "time_str": "02:18.360",
      "text": "产生共鸣来阻止一切暴力",
      "translation": null
    },
    {
      "time": 140.26,
      "time_str": "02:20.260",
      "text": "眼泪随着音符吸入血液情绪",
