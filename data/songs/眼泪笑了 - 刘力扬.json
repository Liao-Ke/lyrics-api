  "lyrics": [
    {
      "time": 26.16,
      "time_str": "00:26.160",
      "text": "比想像中更痛 你真的没回头",
      "translation": null
    },
    {
      "time": 32.98,
      "time_str": "00:32.980",
      "text": "我命令眼泪不许失控",
      "translation": null
    },
    {
      "time": 39.48,
      "time_str": "00:39.480",
      "text": "回忆不跟你走 都挤在我心中",
      "translation": null
    },
    {
      "time": 46.08,
      "time_str": "00:46.080",
      "text": "我就有责任让它值得被珍重",
      "translation": null
    },
    {
      "time": 52.538,
      "time_str": "00:52.538",
      "text": "谢谢你曾让我难过",
      "translation": null
    },
    {
      "time": 56.5,
      "time_str": "00:56.500",
      "text": "谢谢我没有想太多",
      "translation": null
    },
    {
      "time": 59.089,
      "time_str": "00:59.089",
      "text": "当爱情左盼右顾的时候",
      "translation": null
    },
    {
      "time": 64.2,
      "time_str": "01:04.200",
      "text": "我眼泪都笑了 谁还想哭呢",
      "translation": null
    },
    {
      "time": 70.529,
      "time_str": "01:10.529",
      "text": "再勇敢的站着 找回光和热",
      "translation": null
    },
    {
      "time": 77.289,
      "time_str": "01:17.289",
      "text": "面对你的时候 我不会舍不得",
      "translation": null
    },
    {
      "time": 84.518,
      "time_str": "01:24.518",
      "text": "因为你已是过客 因为路有些曲折",
      "translation": null
    },
    {
      "time": 92.289,
      "time_str": "01:32.289",
      "text": "是美的",
      "translation": null
    },
    {
      "time": 105.118,
      "time_str": "01:45.118",
      "text": "心碎成了沙漠 就快开凿绿洲",
      "translation": null
    },
    {
      "time": 111.648,
      "time_str": "01:51.648",
      "text": "我没有时间不知所措",
      "translation": null
    },
    {
      "time": 118.208,
      "time_str": "01:58.208",
      "text": "你温柔的双手 本就不属于我",
      "translation": null
    },
    {
      "time": 124.678,
      "time_str": "02:04.678",
      "text": "又何必在乎它以后属于谁呢",
      "translation": null
    },
    {
