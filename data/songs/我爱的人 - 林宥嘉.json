  "lyrics": [
    {
      "time": 0.3,
      "time_str": "00:00.300",
      "text": "原唱 : 陈小春",
      "translation": null
    },
    {
      "time": 18.714,
      "time_str": "00:18.714",
      "text": "我知道故事不会太曲折",
      "translation": null
    },
    {
      "time": 25.763,
      "time_str": "00:25.763",
      "text": "我总会遇见一个 什么人",
      "translation": null
    },
    {
      "time": 33.092,
      "time_str": "00:33.092",
      "text": "陪我过没有了她的人生",
      "translation": null
    },
    {
      "time": 40.196,
      "time_str": "00:40.196",
      "text": "成家立业之类的 等等",
      "translation": null
    },
    {
      "time": 47.765,
      "time_str": "00:47.765",
      "text": "她做了她觉得对 的选择",
      "translation": null
    },
    {
      "time": 54.775,
      "time_str": "00:54.775",
      "text": "我只好祝福她真 的对了",
      "translation": null
    },
    {
      "time": 62.077,
      "time_str": "01:02.077",
      "text": "爱不到我最想要爱的人",
      "translation": null
    },
    {
      "time": 69.274,
      "time_str": "01:09.274",
      "text": "谁还能要我怎样呢",
      "translation": null
    },
    {
      "time": 75.341,
      "time_str": "01:15.341",
      "text": "我爱的人 不是我的爱人",
      "translation": null
    },
    {
      "time": 81.817,
      "time_str": "01:21.817",
      "text": "她心里每一寸 都属于另一个人",
      "translation": null
    },
    {
      "time": 89.822,
      "time_str": "01:29.822",
      "text": "她真幸福 幸福得真残忍",
      "translation": null
    },
    {
      "time": 96.493,
      "time_str": "01:36.493",
      "text": "让我又爱又恨 她的爱",
      "translation": null
    },
    {
      "time": 100.307,
      "time_str": "01:40.307",
      "text": "怎么那么深",
      "translation": null
    },
    {
      "time": 104.407,
      "time_str": "01:44.407",
      "text": "我爱的人 她已有了爱人",
      "translation": null
    },
    {
      "time": 111.06,
      "time_str": "01:51.060",
      "text": "从他们的眼神 说明了我不可能",
      "translation": null
    },
    {
      "time": 118.955,
      "time_str": "01:58.955",
      "text": "每当听见 她或他说我们",
      "translation": null
    },
    {
      "time": 125.711,
      "time_str": "02:05.711",
      "text": "就像听见爱情 永恒的嘲笑声",
      "translation": null
    },
    {
