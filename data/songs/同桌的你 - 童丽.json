    },
    {
      "time": 128.64,
      "time_str": "02:08.640",
      "text": "谁把它丢在风里",
      "translation": null
    },
    {
      "time": 147.08,
      "time_str": "02:27.080",
      "text": "从前的日子都远去",
      "translation": null
    },
    {
      "time": 150.82,
      "time_str": "02:30.820",
      "text": "我也将有我的妻",
