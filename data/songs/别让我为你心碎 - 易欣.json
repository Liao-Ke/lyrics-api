  "lyrics": [
    {
      "time": 32.47,
      "time_str": "00:32.470",
      "text": "对于我们之间有时候有些狼狈",
      "translation": null
    },
    {
      "time": 40.0,
      "time_str": "00:40.000",
      "text": "因为到了最后分开还是很干脆",
      "translation": null
    },
    {
      "time": 47.44,
      "time_str": "00:47.440",
      "text": "其实两个人也难免会有些无谓",
      "translation": null
    },
    {
      "time": 54.91,
      "time_str": "00:54.910",
      "text": "久了以后适当也要彼此来相陪",
      "translation": null
    },
    {
      "time": 61.93,
      "time_str": "01:01.930",
      "text": "谁和谁忘了依偎",
      "translation": null
    },
    {
      "time": 65.3,
      "time_str": "01:05.300",
      "text": "我和你也掉下眼泪",
      "translation": null
    },
    {
      "time": 69.02,
      "time_str": "01:09.020",
      "text": "就在爱与不爱之间中徘徊",
      "translation": null
    },
    {
      "time": 76.57,
      "time_str": "01:16.570",
      "text": "别让我为了你心碎",
      "translation": null
    },
    {
      "time": 80.77,
      "time_str": "01:20.770",
      "text": "要好好的面对",
      "translation": null
    },
    {
      "time": 84.12,
      "time_str": "01:24.120",
      "text": "如果错过以后不后悔",
      "translation": null
    },
    {
      "time": 87.71,
      "time_str": "01:27.710",
      "text": "可能谁会忘记谁？",
      "translation": null
    },
    {
      "time": 91.62,
      "time_str": "01:31.620",
      "text": "别让我为你掉眼泪",
      "translation": null
    },
    {
      "time": 95.74,
      "time_str": "01:35.740",
      "text": "不管错与对",
      "translation": null
    },
    {
      "time": 99.18,
      "time_str": "01:39.180",
      "text": "也不能走的太干脆",
      "translation": null
    },
    {
      "time": 102.71,
      "time_str": "01:42.710",
      "text": "别让我再次为了你心碎",
      "translation": null
    },
