    },
    {
      "time": 11.3,
      "time_str": "00:11.300",
      "text": "Engineered by 黄尚伟 & Davy Chan & Amic",
      "translation": null
    },
    {
      "time": 12.3,
      "time_str": "00:12.300",
      "text": "Mixed by Simon Li at nOiz",
      "translation": null
    },
    {
      "time": 35.09,
      "time_str": "00:35.090",
      "text": "我说了所有的谎",
      "translation": null
    },
    {
      "time": 39.72,
      "time_str": "00:39.720",
      "text": "你全都相信",
      "translation": null
    },
    {
      "time": 42.68,
      "time_str": "00:42.680",
      "text": "简单的我爱你",
      "translation": null
    },
    {
      "time": 46.79,
      "time_str": "00:46.790",
      "text": "你却老不信",
      "translation": null
    },
    {
      "time": 50.66,
      "time_str": "00:50.660",
      "text": "你书里的剧情",
      "translation": null
    },
    {
      "time": 54.83,
      "time_str": "00:54.830",
      "text": "我不想上演",
      "translation": null
    },
    {
      "time": 58.31,
      "time_str": "00:58.310",
      "text": "因为我喜欢喜剧收尾",
      "translation": null
    },
    {
      "time": 67.58,
      "time_str": "01:07.580",
      "text": "我试过完美放弃",
      "translation": null
    },
    {
      "time": 72.15,
      "time_str": "01:12.150",
      "text": "的确很踏实",
      "translation": null
    },
    {
      "time": 75.42,
      "time_str": "01:15.420",
      "text": "醒来了 梦散了",
      "translation": null
    },
    {
      "time": 79.28,
      "time_str": "01:19.280",
      "text": "你我都走散了",
      "translation": null
    },
    {
      "time": 82.93,
      "time_str": "01:22.930",
      "text": "情歌的词何必押韵",
      "translation": null
    },
    {
      "time": 86.93,
      "time_str": "01:26.930",
      "text": "就算我是K歌之王",
      "translation": null
    },
    {
      "time": 91.06,
      "time_str": "01:31.060",
      "text": "也不见得把爱情唱得完美",
      "translation": null
    },
    {
      "time": 98.04,
      "time_str": "01:38.040",
      "text": "只能说我输了",
      "translation": null
    },
    {
      "time": 102.16,
      "time_str": "01:42.160",
      "text": "也许是你怕了",
      "translation": null
    },
    {
      "time": 106.09,
      "time_str": "01:46.090",
      "text": "我们的回忆没有皱褶",
      "translation": null
    },
    {
      "time": 110.84,
      "time_str": "01:50.840",
      "text": "你却用离开烫下句点",
      "translation": null
    },
    {
      "time": 114.5,
      "time_str": "01:54.500",
      "text": "只能说我认了",
      "translation": null
    },
    {
      "time": 118.29,
      "time_str": "01:58.290",
      "text": "你的不安赢得你信任",
      "translation": null
    },
    {
      "time": 123.48,
      "time_str": "02:03.480",
      "text": "我却得到你安慰的淘汰",
      "translation": null
    },
    {
