      "translation": null
    },
    {
      "time": 7.65,
      "time_str": "00:07.650",
      "text": "当你看着我",
      "translation": null
    },
    {
      "time": 10.03,
      "time_str": "00:10.030",
      "text": "我没有开口 已被你猜透",
      "translation": null
    },
    {
      "time": 16.98,
      "time_str": "00:16.980",
      "text": "还是没把握",
      "translation": null
    },
    {
      "time": 19.17,
      "time_str": "00:19.170",
      "text": "还是没有符合你的要求",
      "translation": null
    },
    {
      "time": 25.77,
      "time_str": "00:25.770",
      "text": "是我自己想得太多",
      "translation": null
    },
    {
      "time": 29.74,
      "time_str": "00:29.740",
      "text": "还是你也在闪躲",
      "translation": null
    },
    {
      "time": 34.84,
      "time_str": "00:34.840",
      "text": "如果真的选择是我",
      "translation": null
    },
    {
      "time": 38.41,
      "time_str": "00:38.410",
      "text": "我鼓起勇气去接受",
      "translation": null
    },
    {
      "time": 42.1,
      "time_str": "00:42.100",
      "text": "不知不觉让视线开始闪烁",
      "translation": null
    },
    {
      "time": 51.01,
      "time_str": "00:51.010",
      "text": "哦 第一次我说爱你的时候",
      "translation": null
    },
    {
      "time": 55.99,
      "time_str": "00:55.990",
      "text": "呼吸难过 心不停的颤抖",
      "translation": null
    },
    {
      "time": 59.96,
      "time_str": "00:59.960",
      "text": "哦 第一次我牵起你的双手",
