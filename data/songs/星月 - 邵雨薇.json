  "lyrics": [
    {
      "time": 13.05,
      "time_str": "00:13.050",
      "text": "星星怕一眨眼",
      "translation": null
    },
    {
      "time": 17.35,
      "time_str": "00:17.350",
      "text": "月就会消失不见",
      "translation": null
    },
    {
      "time": 25.36,
      "time_str": "00:25.360",
      "text": "月牵起她的手",
      "translation": null
    },
    {
      "time": 29.62,
      "time_str": "00:29.620",
      "text": "承诺会陪在身边",
      "translation": null
    },
    {
      "time": 36.94,
      "time_str": "00:36.940",
      "text": "星月相约 永远相随",
      "translation": null
    },
    {
      "time": 43.03,
      "time_str": "00:43.030",
      "text": "一起照亮世界",
      "translation": null
    },
    {
      "time": 49.25,
      "time_str": "00:49.250",
      "text": "直到那天月突然间",
      "translation": null
    },
    {
      "time": 55.49,
      "time_str": "00:55.490",
      "text": "背弃他的诺言",
      "translation": null
    },
    {
      "time": 59.68,
      "time_str": "00:59.680",
      "text": "星星挂在天边",
      "translation": null
    },
    {
      "time": 63.07,
      "time_str": "01:03.070",
      "text": "再也没有了月",
      "translation": null
    },
    {
      "time": 66.21,
      "time_str": "01:06.210",
      "text": "她不愿流泪",
      "translation": null
    },
    {
      "time": 68.48,
      "time_str": "01:08.480",
      "text": "也不会选择往下坠",
      "translation": null
    },
    {
      "time": 72.03,
      "time_str": "01:12.030",
      "text": "星星不再想念",
      "translation": null
    },
    {
      "time": 75.42,
      "time_str": "01:15.420",
      "text": "决定自己照亮这个世界",
      "translation": null
    },
    {
      "time": 79.57,
      "time_str": "01:19.570",
      "text": "闪耀在没有月的夜",
      "translation": null
    },
    {
      "time": 84.18,
      "time_str": "01:24.180",
      "text": "没有你的黑夜",
      "translation": null
    },
    {
      "time": 87.12,
      "time_str": "01:27.120",
      "text": "I'll keep upon shining",
      "translation": null
