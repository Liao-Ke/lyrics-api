    {
      "time": 11.338,
      "time_str": "00:11.338",
      "text": "在东京铁塔",
      "translation": null
    },
    {
      "time": 14.366,
      "time_str": "00:14.366",
      "text": "第一次眺望",
      "translation": null
    },
    {
      "time": 20.315,
      "time_str": "00:20.315",
      "text": "看灯火模仿",
      "translation": null
    },
    {
      "time": 22.958,
      "time_str": "00:22.958",
      "text": "坠落的星光",
      "translation": null
    },
    {
      "time": 29.13,
      "time_str": "00:29.130",
      "text": "我终于到达",
      "translation": null
    },
    {
      "time": 31.783,
      "time_str": "00:31.783",
      "text": "但却更悲伤",
      "translation": null
    },
    {
      "time": 38.0,
      "time_str": "00:38.000",
      "text": "一个人完成",
      "translation": null
    },
    {
      "time": 41.054,
      "time_str": "00:41.054",
      "text": "我们的梦想",
      "translation": null
    },
    {
      "time": 44.987,
      "time_str": "00:44.987",
      "text": "你总说 时间还很多",
      "translation": null
    },
    {
      "time": 50.796,
      "time_str": "00:50.796",
      "text": "你可以等我",
      "translation": null
    },
    {
      "time": 54.035,
      "time_str": "00:54.035",
      "text": "以前我不懂得",
      "translation": null
    },
    {
      "time": 57.281,
      "time_str": "00:57.281",
      "text": "未必明天 就有以后",
      "translation": null
    },
    {
      "time": 62.795,
      "time_str": "01:02.795",
      "text": "想念是会呼吸的痛",
      "translation": null
    },
    {
      "time": 66.918,
      "time_str": "01:06.918",
      "text": "它活在我身上所有角落",
      "translation": null
    },
    {
      "time": 71.363,
      "time_str": "01:11.363",
      "text": "哼你爱的歌会痛",
      "translation": null
    },
    {
      "time": 74.138,
      "time_str": "01:14.138",
      "text": "看你的信会痛",
      "translation": null
    },
    {
      "time": 77.023,
      "time_str": "01:17.023",
      "text": "连沉默也痛",
      "translation": null
    },
    {
      "time": 80.61,
      "time_str": "01:20.610",
      "text": "遗憾是会呼吸的痛",
      "translation": null
    },
    {
      "time": 84.719,
      "time_str": "01:24.719",
      "text": "它流在血液中来回滚动",
      "translation": null
    },
    {
      "time": 89.609,
      "time_str": "01:29.609",
      "text": "后悔不贴心会痛",
      "translation": null
    },
    {
      "time": 92.086,
      "time_str": "01:32.086",
      "text": "恨不懂你会痛",
      "translation": null
    },
    {
      "time": 94.875,
      "time_str": "01:34.875",
      "text": "想见不能见最痛",
      "translation": null
