  "lyrics": [
    {
      "time": 24.95,
      "time_str": "00:24.950",
      "text": "你早就该拒绝我",
      "translation": null
    },
    {
      "time": 31.169,
      "time_str": "00:31.169",
      "text": "不该放任我的追求",
      "translation": null
    },
    {
      "time": 36.94,
      "time_str": "00:36.940",
      "text": "给我渴望的故事",
      "translation": null
    },
    {
      "time": 43.33,
      "time_str": "00:43.330",
      "text": "留下丢不掉的名字",
      "translation": null
    },
    {
      "time": 49.7,
      "time_str": "00:49.700",
      "text": "时间难倒回空间易破碎",
      "translation": null
    },
    {
      "time": 55.63,
      "time_str": "00:55.630",
      "text": "二十四小时的爱情",
      "translation": null
    },
    {
      "time": 58.96,
      "time_str": "00:58.960",
      "text": "是我一生难忘的美丽回忆",
      "translation": null
    },
    {
      "time": 67.72,
      "time_str": "01:07.720",
      "text": "越过道德的边境",
      "translation": null
    },
    {
      "time": 73.83,
      "time_str": "01:13.830",
      "text": "我们走过爱的禁区",
      "translation": null
    },
    {
      "time": 81.7,
      "time_str": "01:21.700",
      "text": "享受幸福的错觉",
      "translation": null
    },
    {
      "time": 86.9,
      "time_str": "01:26.900",
      "text": "误解了快乐的意义",
      "translation": null
    },
    {
      "time": 92.8,
      "time_str": "01:32.800",
      "text": "是谁太勇敢说喜欢离别",
      "translation": null
    },
    {
      "time": 98.18,
      "time_str": "01:38.180",
      "text": "只要今天不要明天眼睁睁看着",
      "translation": null
    },
    {
      "time": 104.82,
      "time_str": "01:44.820",
      "text": "爱从指缝中溜走还说再见",
      "translation": null
    },
    {
      "time": 116.55,
      "time_str": "01:56.550",
      "text": "不够时间好好来爱你",
      "translation": null
    },
    {
      "time": 122.7,
      "time_str": "02:02.700",
      "text": "早该停止风流的游戏",
      "translation": null
    },
    {
      "time": 130.979,
      "time_str": "02:10.979",
      "text": "愿被你抛弃就算了解而分离",
      "translation": null
    },
    {
      "time": 135.999,
      "time_str": "02:15.999",
      "text": "不愿爱的没有答案结局",
      "translation": null
    },
    {
      "time": 142.799,
      "time_str": "02:22.799",
      "text": "不够时间好好来恨你",
      "translation": null
    },
    {
      "time": 148.719,
      "time_str": "02:28.719",
      "text": "终于明白恨人不容易",
      "translation": null
    },
    {
      "time": 154.179,
      "time_str": "02:34.179",
      "text": "爱恨消失前用手温暖我的脸",
      "translation": null
    },
    {
      "time": 160.209,
      "time_str": "02:40.209",
      "text": "为我证明我曾真心爱过你",
      "translation": null
    },
    {
      "time": 165.849,
      "time_str": "02:45.849",
      "text": "爱过你爱过你爱过你...",
      "translation": null
    },
