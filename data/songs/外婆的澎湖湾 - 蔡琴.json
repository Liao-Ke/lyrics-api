  "lyrics": [
    {
      "time": 8.68,
      "time_str": "00:08.680",
      "text": "晚风轻拂澎湖湾",
      "translation": null
    },
    {
      "time": 10.93,
      "time_str": "00:10.930",
      "text": "白浪逐沙滩",
      "translation": null
    },
    {
      "time": 13.93,
      "time_str": "00:13.930",
      "text": "没有椰林缀斜阳",
      "translation": null
    },
    {
      "time": 16.74,
      "time_str": "00:16.740",
      "text": "只是一片海蓝蓝",
      "translation": null
    },
    {
      "time": 19.49,
      "time_str": "00:19.490",
      "text": "坐在门前的矮墙上",
      "translation": null
    },
    {
      "time": 22.31,
      "time_str": "00:22.310",
      "text": "一遍遍怀想",
      "translation": null
    },
    {
      "time": 25.5,
      "time_str": "00:25.500",
      "text": "也是黄昏的沙滩上",
      "translation": null
    },
    {
      "time": 27.72,
      "time_str": "00:27.720",
      "text": "有着脚印两对半",
      "translation": null
    },
    {
      "time": 31.97,
      "time_str": "00:31.970",
      "text": "那是外婆拄着杖",
      "translation": null
    },
    {
      "time": 34.59,
      "time_str": "00:34.590",
      "text": "将我手轻轻挽",
      "translation": null
    },
    {
      "time": 37.47,
      "time_str": "00:37.470",
      "text": "踩着薄暮走向余辉",
      "translation": null
    },
    {
      "time": 40.9,
      "time_str": "00:40.900",
      "text": "暖暖的澎湖湾",
      "translation": null
    },
    {
      "time": 42.97,
      "time_str": "00:42.970",
      "text": "一个脚印是笑语一串",
      "translation": null
    },
    {
      "time": 45.74,
      "time_str": "00:45.740",
      "text": "消磨许多时光",
      "translation": null
    },
    {
      "time": 48.55,
      "time_str": "00:48.550",
      "text": "直到夜色吞没我俩",
      "translation": null
    },
    {
      "time": 50.98,
      "time_str": "00:50.980",
      "text": "在回家的路上",
      "translation": null
    },
    {
      "time": 55.46,
      "time_str": "00:55.460",
      "text": "澎湖湾澎湖湾",
      "translation": null
    },
    {
      "time": 60.59,
      "time_str": "01:00.590",
      "text": "外婆的澎湖湾",
      "translation": null
    },
    {
      "time": 66.15,
      "time_str": "01:06.150",
      "text": "有我许多的童年幻想",
      "translation": null
    },
    {
      "time": 71.59,
      "time_str": "01:11.590",
      "text": "阳光沙滩海浪仙人掌",
      "translation": null
    },
    {
      "time": 77.96,
      "time_str": "01:17.960",
      "text": "还有一位老船长",
