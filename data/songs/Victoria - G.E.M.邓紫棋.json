    },
    {
      "time": 84.6,
      "time_str": "01:24.600",
      "text": "时代门外多少挚真忆记",
      "translation": null
    },
    {
      "time": 89.64,
      "time_str": "01:29.640",
      "text": "那是有过梦想的你",
      "translation": null
    },
    {
