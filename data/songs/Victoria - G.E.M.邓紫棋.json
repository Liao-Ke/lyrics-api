  "lyrics": [
    {
      "time": 13.44,
      "time_str": "00:13.440",
      "text": "凝望对岸灯火线",
      "translation": null
    },
    {
      "time": 18.34,
      "time_str": "00:18.340",
      "text": "童年望到如今不厌",
      "translation": null
    },
    {
      "time": 23.45,
      "time_str": "00:23.450",
      "text": "流连球场内妈妈有些怨言",
      "translation": null
    },
    {
      "time": 27.72,
      "time_str": "00:27.720",
      "text": "却是那最熟悉声线",
      "translation": null
    },
    {
      "time": 33.47,
      "time_str": "00:33.470",
      "text": "常回味那蛋挞的脆",
      "translation": null
    },
    {
      "time": 38.64,
      "time_str": "00:38.640",
      "text": "人情味也属于这里",
      "translation": null
    },
    {
      "time": 44.01,
      "time_str": "00:44.010",
      "text": "谁曾离别天星下再相聚",
      "translation": null
    },
    {
      "time": 48.59,
      "time_str": "00:48.590",
      "text": "你共我已成长几岁",
      "translation": null
    },
    {
      "time": 54.25,
      "time_str": "00:54.250",
      "text": "看遍风雨和繁花",
      "translation": null
    },
    {
      "time": 59.18,
      "time_str": "00:59.180",
      "text": "共灌溉七百万童话",
      "translation": null
    },
    {
