    {
      "time": 167.35,
      "time_str": "02:47.350",
      "text": "只剩挥散不去的难过",
      "translation": null
    },
    {
      "time": 174.29,
      "time_str": "02:54.290",
      "text": "在山腰间飘逸的红雨",
      "translation": null
    },
    {
      "time": 181.28,
      "time_str": "03:01.280",
      "text": "随着北风凋零 我轻轻摇曳风铃",
      "translation": null
    },
    {
      "time": 188.87,
      "time_str": "03:08.870",
      "text": "想 唤醒被遗弃的爱情",
      "translation": null
    },
    {
      "time": 195.53,
      "time_str": "03:15.530",
      "text": "雪花已铺满了地",
      "translation": null
    },
    {
      "time": 199.6,
      "time_str": "03:19.600",
      "text": "生怕窗外枫叶已结成冰",
      "translation": null
    },
    {
