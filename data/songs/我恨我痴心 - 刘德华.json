  "lyrics": [
    {
      "time": 25.16,
      "time_str": "00:25.160",
      "text": "昨夜曾立誓离别你",
      "translation": null
    },
    {
      "time": 29.7,
      "time_str": "00:29.700",
      "text": "你厌了我又话我乏味",
      "translation": null
    },
    {
      "time": 33.71,
      "time_str": "00:33.710",
      "text": "又借着乏味将我路上遗弃",
      "translation": null
    },
    {
      "time": 37.25,
      "time_str": "00:37.250",
      "text": "昨日有双手携着你",
      "translation": null
    },
    {
      "time": 41.81,
      "time_str": "00:41.810",
      "text": "我发觉我落泪我妒忌",
      "translation": null
    },
    {
      "time": 45.84,
      "time_str": "00:45.840",
      "text": "想跟你分离将你尽量忘记",
      "translation": null
    },
    {
      "time": 50.8,
      "time_str": "00:50.800",
      "text": "我怨勇气匆匆不预备",
      "translation": null
    },
    {
      "time": 54.25,
      "time_str": "00:54.250",
      "text": "再次见你狠心不来难胜利",
      "translation": null
    },
    {
      "time": 61.92,
      "time_str": "01:01.920",
      "text": "亦爱亦恨 似笼牢被困",
      "translation": null
    },
    {
      "time": 66.21,
      "time_str": "01:06.210",
      "text": "要放弃你或是接受命运",
      "translation": null
    },
    {
      "time": 70.32,
      "time_str": "01:10.320",
      "text": "心间战争使我实在难过",
      "translation": null
    },
    {
      "time": 73.51,
      "time_str": "01:13.510",
      "text": "未恨你负义 我恨我痴心",
      "translation": null
    },
    {
      "time": 93.509,
      "time_str": "01:33.509",
      "text": "冷默情淡薄全做作",
      "translation": null
    },
    {
      "time": 97.78,
      "time_str": "01:37.780",
      "text": "你责怪我默默我亦受落",
      "translation": null
    },
    {
      "time": 101.83,
      "time_str": "01:41.830",
      "text": "只想会保留 相爱梦幻王国",
      "translation": null
    },
    {
      "time": 105.43,
      "time_str": "01:45.430",
      "text": "怎知有双手围着你",
      "translation": null
