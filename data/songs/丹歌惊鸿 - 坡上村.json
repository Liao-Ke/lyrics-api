{
  "title": "丹歌惊鸿",
  "title_raw": "丹歌惊鸿",
  "version": null,
  "artist": "坡上村",
  "group_key": "丹歌惊鸿|坡上村",
  "writers": {
    "lyricist": "浓缩排骨",
