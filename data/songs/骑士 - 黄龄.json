  },
  "lyrics": [
    {
      "time": 17.792,
      "time_str": "00:17.792",
      "text": "广场的大钟 铛铛敲了四下",
      "translation": null
    },
    {
      "time": 22.0,
      "time_str": "00:22.000",
      "text": "我跟着鸽子 在小路上溜达",
      "translation": null
    },
    {
      "time": 26.121,
      "time_str": "00:26.121",
      "text": "地铁的出口 有个人弹吉他",
      "translation": null
    },
    {
      "time": 30.069,
      "time_str": "00:30.069",
      "text": "他唱着唱着 眼泪要洒下",
      "translation": null
    },
    {
      "time": 34.134,
      "time_str": "00:34.134",
      "text": "弄堂的门口 大叔卖爆米花",
      "translation": null
    },
    {
      "time": 38.273,
      "time_str": "00:38.273",
      "text": "有队小朋友 咿咿呀呀回家",
      "translation": null
    },
    {
      "time": 42.253,
      "time_str": "00:42.253",
      "text": "男生等女生 手捧着一束花",
      "translation": null
    },
    {
      "time": 46.357,
      "time_str": "00:46.357",
      "text": "他等呀等呀 冰激凌融化",
      "translation": null
    },
    {
      "time": 50.389,
      "time_str": "00:50.389",
      "text": "眼看小小骑士 他快要饿昏头",
      "translation": null
    },
    {
      "time": 54.652,
      "time_str": "00:54.652",
      "text": "可公主大人她 还慢悠悠洗头",
      "translation": null
    },
    {
      "time": 58.604,
      "time_str": "00:58.604",
      "text": "想起有的时候 你也等我很久",
      "translation": null
    },
    {
      "time": 62.63,
      "time_str": "01:02.630",
      "text": "在我家巷子口 呆的像根木头",
      "translation": null
    },
    {
      "time": 82.968,
      "time_str": "01:22.968",
      "text": "哼一段口哨 看蚂蚁慢慢爬",
      "translation": null
    },
    {
      "time": 87.017,
      "time_str": "01:27.017",
      "text": "隔壁的小狗 汪汪地在打架",
      "translation": null
    },
    {
      "time": 91.179,
      "time_str": "01:31.179",
      "text": "热闹的弄堂 有高人玩杂耍",
      "translation": null
    },
    {
      "time": 95.196,
      "time_str": "01:35.196",
      "text": "没有人理他 他还得等哪",
      "translation": null
    },
    {
      "time": 99.189,
      "time_str": "01:39.189",
      "text": "眼看小小骑士 他快要饿昏头",
      "translation": null
    },
    {
      "time": 103.314,
      "time_str": "01:43.314",
      "text": "可公主大人她 还慢慢悠洗头",
      "translation": null
    },
    {
      "time": 107.392,
      "time_str": "01:47.392",
      "text": "想起有的时候 你也等我很久",
      "translation": null
    },
    {
      "time": 111.471,
      "time_str": "01:51.471",
      "text": "在我家巷子口 呆的像根木头",
      "translation": null
    },
    {
      "time": 115.484,
      "time_str": "01:55.484",
      "text": "也许每个骑士 都要学会等候",
      "translation": null
    },
    {
      "time": 119.141,
      "time_str": "01:59.141",
      "text": "好好吃点苦头 才能尝到甜头",
      "translation": null
    },
    {
      "time": 123.52,
      "time_str": "02:03.520",
      "text": "最最甜蜜时候 左手拉你右手",
      "translation": null
    },
    {
      "time": 127.702,
      "time_str": "02:07.702",
      "text": "带你回家吃饭 外婆大显身手",
      "translation": null
    },
    {
      "time": 150.582,
      "time_str": "02:30.582",
      "text": "等到有一天 我变成老妈妈",
      "translation": null
    },
    {
      "time": 155.656,
      "time_str": "02:35.656",
      "text": "你也要记得 经常浪漫一下",
      "translation": null
    },
    {
      "time": 159.949,
      "time_str": "02:39.949",
      "text": "像那个男生 多么人小鬼大",
      "translation": null
    },
    {
      "time": 164.015,
      "time_str": "02:44.015",
      "text": "在那个年纪 你没他潇洒",
      "translation": null
    },
    {
      "time": 168.237,
      "time_str": "02:48.237",
      "text": "眼看小小骑士 拿出凤梨罐头",
      "translation": null
    },
    {
      "time": 172.071,
      "time_str": "02:52.071",
      "text": "一口接着一口 吃完舔舔指头",
      "translation": null
    },
    {
      "time": 176.111,
      "time_str": "02:56.111",
      "text": "想必电影看过 明白过期不候",
      "translation": null
    },
    {
      "time": 180.209,
      "time_str": "03:00.209",
      "text": "抓紧时间恋爱 抓紧时间分手",
      "translation": null
    },
    {
      "time": 184.29,
      "time_str": "03:04.290",
      "text": "也许每个骑士 都要学会等候",
      "translation": null
    },
    {
      "time": 187.974,
      "time_str": "03:07.974",
      "text": "好好吃点苦头 才能尝到甜头",
      "translation": null
    },
    {
      "time": 192.491,
      "time_str": "03:12.491",
      "text": "最最甜蜜时候 左手拉你右手",
      "translation": null
    },
    {
      "time": 196.532,
      "time_str": "03:16.532",
      "text": "带你回家吃饭 外婆大显身手",
      "translation": null
    },
    {
      "time": 200.647,
      "time_str": "03:20.647",
      "text": "你是我的木头 我是你的红豆",
      "translation": null
    },
    {
      "time": 204.921,
      "time_str": "03:24.921",
      "text": "我害羞地熟透 你木讷到腐朽",
      "translation": null
    },
    {
      "time": 208.745,
      "time_str": "03:28.745",
      "text": "这样多年以后 左手拉你右手",
      "translation": null
    },
    {
      "time": 212.949,
      "time_str": "03:32.949",
      "text": "还是在巷子口 温柔地慢慢走",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "骑士 - 黄龄.lrc"
}