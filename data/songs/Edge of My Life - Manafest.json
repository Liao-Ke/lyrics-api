    {
      "time": 1.64,
      "time_str": "00:01.640",
      "text": "Edge of my life",
      "translation": "我在绝望的生活边缘挣扎"
    },
    {
      "time": 3.28,
      "time_str": "00:03.280",
      "text": "Edge of my life",
      "translation": "我在绝望的生活边缘挣扎"
    },
    {
      "time": 5.55,
      "time_str": "00:05.550",
      "text": "Edge of my life",
      "translation": "我在绝望的生活边缘挣扎"
    },
    {
      "time": 7.92,
      "time_str": "00:07.920",
      "text": "My life yeah",
      "translation": "我的生活啊"
    },
    {
      "time": 10.14,
      "time_str": "00:10.140",
      "text": "Last dollar just got spent",
      "translation": "最后一美元刚刚花完"
    },
    {
      "time": 11.71,
      "time_str": "00:11.710",
      "text": "First of the month comes",
      "translation": "月初又要到了"
    },
    {
      "time": 12.96,
      "time_str": "00:12.960",
      "text": "Got to pay rent",
      "translation": "我得去交房租"
    },
    {
      "time": 14.0,
      "time_str": "00:14.000",
      "text": "Where'd the money go",
      "translation": "钱都去哪里了"
    },
    {
      "time": 14.93,
      "time_str": "00:14.930",
      "text": "Slipping through my hands",
      "translation": "就这么从我手里溜走了"
    },
    {
      "time": 16.89,
      "time_str": "00:16.890",
      "text": "I'm working with these hands",
      "translation": "从我用来工作的双手里"
    },
    {
      "time": 19.2,
      "time_str": "00:19.200",
      "text": "Little Johnny needs a lunch box",
      "translation": "小强尼要买一个午餐盒"
    },
    {
      "time": 20.89,
      "time_str": "00:20.890",
      "text": "Little Susy needs clothes it won't stop",
      "translation": "小苏西还要买衣服了 但这远远不够"
    },
    {
      "time": 23.15,
      "time_str": "00:23.150",
      "text": "Banks calling us up",
      "translation": "银行要来打电话催款了"
    },
    {
      "time": 24.46,
      "time_str": "00:24.460",
      "text": "And they don't care",
      "translation": "他们才不会管你的死活"
    },
    {
      "time": 26.02,
      "time_str": "00:26.020",
      "text": "It's more than I can bear",
      "translation": "我已经忍无可忍了"
    },
    {
      "time": 28.28,
      "time_str": "00:28.280",
      "text": "I gotta gotta believe",
      "translation": "我一定一定要坚信"
    },
    {
      "time": 30.6,
      "time_str": "00:30.600",
      "text": "I can more than survive",
      "translation": "我还可以活下去"
    },
    {
      "time": 33.09,
      "time_str": "00:33.090",
      "text": "Still one trick up my sleeve",
      "translation": "我还有一招绝技"
    },
    {
      "time": 35.19,
      "time_str": "00:35.190",
      "text": "We're gonna make this one shine",
      "translation": "我们一定可以获得光明"
    },
    {
      "time": 37.47,
      "time_str": "00:37.470",
      "text": "I gotta gotta believe",
      "translation": "我一定一定要坚信"
    },
    {
      "time": 40.08,
