    {
      "time": 46.9,
      "time_str": "00:46.900",
      "text": "I I'm at the edge of my life",
      "translation": "我在绝望的生活边缘挣扎着"
    },
    {
      "time": 50.14,
      "time_str": "00:50.140",
      "text": "I got no time to think twice",
      "translation": "我已经没时间再多想了"
    },
    {
      "time": 52.75,
      "time_str": "00:52.750",
      "text": "When I'm standing with the weight",
      "translation": "当我不堪重负的时候"
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "Of the world on my shoulders",
      "translation": "我背负着全世界的希望"
    },
    {
      "time": 56.28,
      "time_str": "00:56.280",
      "text": "I I'm gonna fight the good fight",
      "translation": "我一定要好好拼一把"
    },
    {
      "time": 59.16,
      "time_str": "00:59.160",
      "text": "'Cause I I know I'll get by",
      "translation": "因为我知道我一定可以活下去"
    },
    {
