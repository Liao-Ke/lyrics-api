  "lyrics": [
    {
      "time": 22.62,
      "time_str": "00:22.620",
      "text": "夏天夏天悄悄过去",
      "translation": null
    },
    {
      "time": 24.9,
      "time_str": "00:24.900",
      "text": "留下小秘密",
      "translation": null
    },
    {
      "time": 27.12,
      "time_str": "00:27.120",
      "text": "压心底压心底",
      "translation": null
    },
    {
      "time": 29.34,
      "time_str": "00:29.340",
      "text": "不能告诉你",
      "translation": null
    },
    {
      "time": 31.5,
      "time_str": "00:31.500",
      "text": "晚风吹过温暖我心底",
      "translation": null
    },
    {
      "time": 33.81,
      "time_str": "00:33.810",
      "text": "我又想起你",
      "translation": null
    },
    {
      "time": 35.94,
      "time_str": "00:35.940",
      "text": "多甜蜜多甜蜜",
      "translation": null
    },
    {
      "time": 38.25,
      "time_str": "00:38.250",
      "text": "怎能忘记",
      "translation": null
    },
    {
      "time": 40.44,
      "time_str": "00:40.440",
      "text": "不能忘记你",
      "translation": null
    },
    {
      "time": 42.09,
      "time_str": "00:42.090",
      "text": "把你写在日记里",
      "translation": null
    },
    {
      "time": 44.85,
      "time_str": "00:44.850",
      "text": "不能忘记你",
      "translation": null
    },
    {
      "time": 46.5,
      "time_str": "00:46.500",
      "text": "心里想的还是你",
      "translation": null
    },
    {
      "time": 49.32,
      "time_str": "00:49.320",
      "text": "浪漫的夏季",
      "translation": null
    },
    {
      "time": 50.94,
      "time_str": "00:50.940",
      "text": "还有浪漫的一个你",
      "translation": null
    },
    {
      "time": 53.76,
      "time_str": "00:53.760",
      "text": "给我一个粉红的回忆",
      "translation": null
    },
    {
      "time": 57.63,
      "time_str": "00:57.630",
      "text": "喔夏天夏天悄悄过去",
      "translation": null
    },
    {
      "time": 60.51,
      "time_str": "01:00.510",
      "text": "依然怀念你",
      "translation": null
    },
    {
      "time": 63.03,
      "time_str": "01:03.030",
      "text": "你一言你一语",
      "translation": null
    },
    {
      "time": 64.92,
      "time_str": "01:04.920",
      "text": "都叫我回忆",
      "translation": null
    },
    {
      "time": 67.08,
      "time_str": "01:07.080",
      "text": "就在就在秋天的梦里",
      "translation": null
    },
    {
      "time": 69.39,
      "time_str": "01:09.390",
      "text": "我又遇见你",
      "translation": null
    },
    {
