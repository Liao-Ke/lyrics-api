  "lyrics": [
    {
      "time": 3.17,
      "time_str": "00:03.170",
      "text": "Let us fly-ay-ay-ay la-di-da-di-da-di-dah",
      "translation": "让我们飞翔 拉 嗒 嘀 嗒 嘀 嗒 嘀 嗒"
    },
    {
      "time": 8.4,
      "time_str": "00:08.400",
      "text": "To the golden sky",
      "translation": "到那金色的天上"
    },
    {
      "time": 10.34,
      "time_str": "00:10.340",
      "text": "It's the paradise of smile",
      "translation": "那是天堂"
    },
    {
      "time": 12.87,
      "time_str": "00:12.870",
      "text": "Where the sun will always shine",
      "translation": "在那里 太阳将会永远的照耀着"
    },
    {
      "time": 14.7,
      "time_str": "00:14.700",
      "text": "La-da-di-da-di-da-di-dah",
      "translation": "拉 嗒 嘀 嗒 嘀 嗒 嘀 嗒"
    },
    {
      "time": 32.84,
      "time_str": "00:32.840",
      "text": "Welcome to the wonderland, a place for you and me",
      "translation": "欢迎来到奇妙岛，一个属于你我的地方"
    },
    {
      "time": 35.9,
      "time_str": "00:35.900",
      "text": "If you treat me right, then maybe you will have a key",
      "translation": "如果你好好对我 也许你会得到一把钥匙"
    },
    {
      "time": 39.34,
      "time_str": "00:39.340",
      "text": "This world is very special, and I'll show it just for you",
      "translation": "这是个非常特别的世界 我只让你一个人看"
    },
    {
      "time": 43.17,
      "time_str": "00:43.170",
      "text": "All you have to say is \\Yes, I do",
      "translation": "你所需要说的就是“是的，我会的”"
    },
    {
      "time": 45.59,
      "time_str": "00:45.590",
      "text": "Let us fly-ay-ay-ay la-di-da-di-da-di-dah",
      "translation": "让我们飞翔 拉 嗒 嘀 嗒 嘀 嗒 嘀 嗒"
    },
