  "lyrics": [
    {
      "time": 35.63,
      "time_str": "00:35.630",
      "text": "你有一张好陌生的脸",
      "translation": null
    },
    {
      "time": 38.88,
      "time_str": "00:38.880",
      "text": "到今天才看见",
      "translation": null
    },
    {
      "time": 44.1,
      "time_str": "00:44.100",
      "text": "有点心酸在我们之间",
      "translation": null
    },
    {
      "time": 47.6,
      "time_str": "00:47.600",
      "text": "如此短暂的情缘",
      "translation": null
    },
    {
      "time": 52.5,
      "time_str": "00:52.500",
      "text": "看着天空不让泪流下",
      "translation": null
    },
    {
      "time": 56.0,
      "time_str": "00:56.000",
      "text": "不说一句埋怨",
      "translation": null
    },
    {
      "time": 59.7,
      "time_str": "00:59.700",
      "text": "只是心中的感慨万千",
      "translation": null
    },
    {
      "time": 64.22,
      "time_str": "01:04.220",
      "text": "当作前世来生相欠",
      "translation": null
    },
    {
      "time": 67.83,
      "time_str": "01:07.830",
      "text": "你说是我们相见恨晚",
      "translation": null
    },
    {
      "time": 72.35,
      "time_str": "01:12.350",
      "text": "我说为爱 你不够勇敢",
      "translation": null
    },
    {
      "time": 76.93,
      "time_str": "01:16.930",
      "text": "我不奢求永远 永远太遥远",
      "translation": null
    },
    {
      "time": 81.27,
      "time_str": "01:21.270",
      "text": "却陷在爱的深渊",
      "translation": null
    },
    {
      "time": 84.62,
      "time_str": "01:24.620",
      "text": "你说是我们相见恨晚",
      "translation": null
    },
    {
      "time": 89.22,
      "time_str": "01:29.220",
      "text": "我说为爱 你不够勇敢",
      "translation": null
    },
    {
      "time": 93.7,
      "time_str": "01:33.700",
      "text": "在爱与不爱间 来回千万遍",
      "translation": null
    },
    {
      "time": 98.5,
      "time_str": "01:38.500",
      "text": "哪怕已伤痕累累 我也不管",
