  },
  "lyrics": [
    {
      "time": 7.8,
      "time_str": "00:07.800",
      "text": "月光 放肆在染色的窗边",
      "translation": null
    },
    {
      "time": 11.66,
      "time_str": "00:11.660",
      "text": "转眼 魔幻所有视觉",
      "translation": null
    },
    {
      "time": 15.32,
      "time_str": "00:15.320",
      "text": "再一杯 那古老神秘恒河水",
      "translation": null
    },
    {
      "time": 19.9,
      "time_str": "00:19.900",
      "text": "我镶在额头的猫眼",
      "translation": null
    },
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "揭开了庆典",
      "translation": null
    },
    {
      "time": 23.16,
      "time_str": "00:23.160",
      "text": "为爱囚禁数千年的关节",
      "translation": null
    },
    {
      "time": 26.83,
      "time_str": "00:26.830",
      "text": "正诉说遗忘的爱恋",
      "translation": null
    },
    {
      "time": 30.72,
      "time_str": "00:30.720",
      "text": "听所有喜悲系在我的腰间",
      "translation": null
    },
    {
      "time": 34.56,
      "time_str": "00:34.560",
      "text": "让那些画面再出现",
      "translation": null
    },
    {
      "time": 36.98,
      "time_str": "00:36.980",
      "text": "再回到从前",
      "translation": null
    },
    {
      "time": 38.69,
      "time_str": "00:38.690",
      "text": "旋转 跳跃 我闭着眼",
      "translation": null
    },
    {
      "time": 42.21,
      "time_str": "00:42.210",
      "text": "尘嚣看不见 你沉醉了没",
      "translation": null
    },
    {
      "time": 46.37,
      "time_str": "00:46.370",
      "text": "白雪 夏夜 我不停歇",
      "translation": null
    },
    {
      "time": 49.98,
      "time_str": "00:49.980",
      "text": "模糊了年岁",
      "translation": null
    },
    {
      "time": 51.91,
      "time_str": "00:51.910",
      "text": "时光的沙漏被我踩碎",
      "translation": null
    },
    {
      "time": 62.11,
      "time_str": "01:02.110",
      "text": "故事 刻划在旋转的指间",
      "translation": null
    },
    {
      "time": 65.9,
      "time_str": "01:05.900",
      "text": "是谁 在痴痴的追随",
      "translation": null
    },
    {
      "time": 69.57,
      "time_str": "01:09.570",
      "text": "这一夜 那破旧皇宫的台阶",
      "translation": null
    },
    {
      "time": 74.2,
      "time_str": "01:14.200",
      "text": "我忘情抖落的汗水",
      "translation": null
    },
    {
      "time": 75.79,
      "time_str": "01:15.790",
      "text": "点亮了庆典",
      "translation": null
    },
    {
      "time": 77.47,
      "time_str": "01:17.470",
      "text": "一层一层把我紧紧包围",
      "translation": null
    },
    {
      "time": 81.08,
      "time_str": "01:21.080",
      "text": "我要让世界忘了睡",
      "translation": null
    },
    {
      "time": 84.94,
      "time_str": "01:24.940",
      "text": "你的心事倒影在我的眉间",
      "translation": null
    },
    {
      "time": 88.82,
      "time_str": "01:28.820",
      "text": "放弃的快乐都实现",
      "translation": null
    },
    {
      "time": 91.23,
      "time_str": "01:31.230",
      "text": "难过都摧毁",
      "translation": null
    },
    {
      "time": 92.93,
      "time_str": "01:32.930",
      "text": "旋转 跳跃 我闭着眼",
      "translation": null
    },
    {
      "time": 96.51,
      "time_str": "01:36.510",
      "text": "尘嚣看不见 你沉醉了没",
      "translation": null
    },
    {
      "time": 100.55,
      "time_str": "01:40.550",
      "text": "白雪 夏夜 我不停歇",
      "translation": null
    },
    {
      "time": 104.25,
      "time_str": "01:44.250",
      "text": "模糊了年岁",
      "translation": null
    },
    {
      "time": 106.21,
      "time_str": "01:46.210",
      "text": "舞娘的喜悲没人看见",
      "translation": null
    },
    {
      "time": 114.6,
      "time_str": "01:54.600",
      "text": "时光的沙漏被我踩碎",
      "translation": null
    },
    {
      "time": 122.07,
      "time_str": "02:02.070",
