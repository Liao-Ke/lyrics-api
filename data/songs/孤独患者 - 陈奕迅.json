      "time_str": "02:35.490",
      "text": "我内心挫折",
      "translation": null
    },
    {
      "time": 159.05,
      "time_str": "02:39.050",
      "text": "活像个孤独患者 自我拉扯",
      "translation": null
    },
    {
      "time": 166.07,
      "time_str": "02:46.070",
      "text": "外向的孤独患者 有何不可",
      "translation": null
    },
    {
      "time": 201.52,
      "time_str": "03:21.520",
      "text": "我不要声嘶力竭的情歌",
      "translation": null
    },
    {
      "time": 208.75,
      "time_str": "03:28.750",
      "text": "来提示我需要你的时刻",
      "translation": null
    },
    {
      "time": 215.59,
      "time_str": "03:35.590",
      "text": "表面镇定并不是保护色",
      "translation": null
    },
    {
      "time": 221.47,
      "time_str": "03:41.470",
      "text": "反而 是要你懂得",
      "translation": null
    },
    {
      "time": 226.1,
      "time_str": "03:46.100",
      "text": "我不知为何",
      "translation": null
    },
    {
      "time": 229.87,
      "time_str": "03:49.870",
      "text": "活像个孤独患者 自我拉扯",
      "translation": null
    },
    {
      "time": 237.01,
      "time_str": "03:57.010",
      "text": "外向的孤独患者 需要认可",
      "translation": null
    }
