      "time": 25.04,
      "time_str": "00:25.040",
      "text": "晓晓：都说女追男 只隔一层纱",
      "translation": null
    },
    {
      "time": 28.25,
      "time_str": "00:28.250",
      "text": "冲上去一声吼 就把他拿下",
      "translation": null
    },
    {
      "time": 32.61,
      "time_str": "00:32.610",
      "text": "Jay：只要你勇敢 真心喜欢他",
      "translation": null
    },
    {
      "time": 36.57,
      "time_str": "00:36.570",
      "text": "晓晓+Long：那怕他是冰山 也把他融化",
      "translation": null
    },
    {
      "time": 40.63,
      "time_str": "00:40.630",
      "text": "合：辣妹子为啥不怕辣",
      "translation": null
    },
    {
      "time": 44.46,
      "time_str": "00:44.460",
      "text": "因为有爱她就敢往前闯",
      "translation": null
    },
    {
      "time": 48.52,
      "time_str": "00:48.520",
      "text": "爱情的路上千千万万",
      "translation": null
    },
    {
      "time": 52.47,
      "time_str": "00:52.470",
      "text": "你要认定方向 革命路还长",
      "translation": null
    },
    {
      "time": 56.7,
      "time_str": "00:56.700",
      "text": "合：一辈子爱他告诉他",
      "translation": null
    },
    {
      "time": 60.53,
      "time_str": "01:00.530",
      "text": "真心喜欢他就该带回家",
      "translation": null
    },
    {
      "time": 64.44,
      "time_str": "01:04.440",
      "text": "爱情的路上别再观望",
