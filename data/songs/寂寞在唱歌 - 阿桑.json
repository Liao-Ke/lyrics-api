  "lyrics": [
    {
      "time": 0.73,
      "time_str": "00:00.730",
      "text": "Le ciel obscure",
      "translation": null
    },
    {
      "time": 2.33,
      "time_str": "00:02.330",
      "text": "La solitude qui nous rend la peine",
      "translation": null
    },
    {
      "time": 5.78,
      "time_str": "00:05.780",
      "text": "La ceour brise",
      "translation": null
    },
    {
      "time": 7.62,
      "time_str": "00:07.620",
      "text": "A cause qu'il y a vécu seul",
      "translation": null
    },
    {
      "time": 9.87,
      "time_str": "00:09.870",
      "text": "L'amour est parti",
      "translation": null
    },
    {
      "time": 11.58,
      "time_str": "00:11.580",
      "text": "Il y a longtemp que je t'ai vu",
      "translation": null
    },
    {
      "time": 13.87,
      "time_str": "00:13.870",
      "text": "C'est trop long",
      "translation": null
    },
    {
      "time": 15.68,
      "time_str": "00:15.680",
      "text": "C'est incroyable que je peux vivre",
      "translation": null
    },
    {
      "time": 18.58,
      "time_str": "00:18.580",
      "text": "Comme ça",
      "translation": null
    },
    {
      "time": 24.48,
      "time_str": "00:24.480",
      "text": "天黑了",
      "translation": null
    },
    {
      "time": 27.21,
      "time_str": "00:27.210",
      "text": "孤独又慢慢割着",
      "translation": null
    },
    {
      "time": 31.16,
      "time_str": "00:31.160",
      "text": "有人的心 又开始疼了",
      "translation": null
    },
    {
      "time": 37.63,
      "time_str": "00:37.630",
      "text": "爱很远了 很久没再见了",
      "translation": null
    },
    {
      "time": 44.6,
      "time_str": "00:44.600",
      "text": "就这样竟然也能活着",
      "translation": null
    },
    {
      "time": 50.63,
      "time_str": "00:50.630",
      "text": "你听寂寞在唱歌",
      "translation": null
    },
    {
      "time": 54.18,
      "time_str": "00:54.180",
      "text": "轻轻的 狠狠的",
      "translation": null
    },
    {
      "time": 57.49,
      "time_str": "00:57.490",
      "text": "歌声是这么残忍",
      "translation": null
    },
    {
      "time": 60.91,
      "time_str": "01:00.910",
      "text": "让人忍不住泪流成河",
      "translation": null
    },
    {
      "time": 75.04,
      "time_str": "01:15.040",
      "text": "谁说的",
      "translation": null
    },
    {
      "time": 77.77,
      "time_str": "01:17.770",
      "text": "人非要快乐不可",
      "translation": null
    },
    {
      "time": 81.7,
      "time_str": "01:21.700",
      "text": "好像快乐 由得人选择",
      "translation": null
    },
    {
      "time": 88.52,
      "time_str": "01:28.520",
      "text": "找不到的 那个人来不来呢",
      "translation": null
    },
    {
      "time": 95.24,
      "time_str": "01:35.240",
      "text": "我会是谁的 谁是我的",
      "translation": null
    },
    {
