    {
      "time": 7.0,
      "time_str": "00:07.000",
      "text": "贝斯 : 陈任佑",
      "translation": null
    },
    {
      "time": 36.993,
      "time_str": "00:36.993",
      "text": "后视镜里的世界",
      "translation": null
    },
    {
      "time": 44.165,
      "time_str": "00:44.165",
      "text": "越来越远的道别",
      "translation": null
    },
    {
      "time": 48.675,
      "time_str": "00:48.675",
      "text": "你转身向背",
      "translation": null
    },
    {
      "time": 51.809,
      "time_str": "00:51.809",
      "text": "侧脸还是很美",
      "translation": null
    },
    {
      "time": 55.371,
      "time_str": "00:55.371",
      "text": "我用眼光去追",
      "translation": null
    },
    {
      "time": 58.951,
      "time_str": "00:58.951",
      "text": "竟听见你的泪",
      "translation": null
    },
    {
      "time": 65.639,
      "time_str": "01:05.639",
      "text": "在车窗外面徘徊",
      "translation": null
    },
    {
      "time": 72.816,
      "time_str": "01:12.816",
      "text": "是我错失的机会",
      "translation": null
    },
    {
      "time": 77.293,
      "time_str": "01:17.293",
      "text": "你站的方位",
      "translation": null
    },
    {
      "time": 79.993,
      "time_str": "01:19.993",
      "text": "跟我中间隔着泪",
      "translation": null
    },
    {
      "time": 83.547,
      "time_str": "01:23.547",
      "text": "街景一直在后退",
      "translation": null
    },
    {
      "time": 87.171,
      "time_str": "01:27.171",
      "text": "你的崩溃在窗外零碎",
      "translation": null
    },
    {
      "time": 91.617,
      "time_str": "01:31.617",
      "text": "我一路向北",
      "translation": null
    },
    {
      "time": 94.301,
      "time_str": "01:34.301",
      "text": "离开有你的季节",
      "translation": null
    },
    {
      "time": 98.801,
      "time_str": "01:38.801",
      "text": "你说你好累",
      "translation": null
    },
    {
      "time": 101.472,
      "time_str": "01:41.472",
      "text": "已无法再爱上谁",
      "translation": null
    },
    {
      "time": 105.956,
      "time_str": "01:45.956",
      "text": "风在山路吹",
      "translation": null
    },
    {
      "time": 108.628,
      "time_str": "01:48.628",
      "text": "过往的画面全都是我不对",
      "translation": null
    },
    {
      "time": 114.012,
      "time_str": "01:54.012",
      "text": "细数惭愧 我伤你几回",
