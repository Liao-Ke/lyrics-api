  "lyrics": [
    {
      "time": 26.0,
      "time_str": "00:26.000",
      "text": "呆坐半晚 咖啡早渗着冰冷",
      "translation": null
    },
    {
      "time": 34.0,
      "time_str": "00:34.000",
      "text": "是否心已淡是挂念你的冷淡",
      "translation": null
    },
    {
      "time": 40.0,
      "time_str": "00:40.000",
      "text": "难合上眼 枕边早垫着冰冷",
      "translation": null
    },
    {
      "time": 47.0,
      "time_str": "00:47.000",
      "text": "夜深不觉冷但似躺在泥滩",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "长夜冷冷 晚风想冷漠驱散",
      "translation": null
    },
    {
      "time": 61.0,
      "time_str": "01:01.000",
      "text": "但千种慨叹在脑内快速泛滥",
      "translation": null
    },
    {
      "time": 68.0,
      "time_str": "01:08.000",
      "text": "垂下了眼 压抑想淌泪的眼",
      "translation": null
    },
    {
      "time": 75.0,
      "time_str": "01:15.000",
      "text": "但沙吹进眼令我极甚为难",
      "translation": null
    },
    {
      "time": 82.0,
      "time_str": "01:22.000",
      "text": "无助无望无奈曾立心想放弃",
      "translation": null
    },
    {
      "time": 88.0,
      "time_str": "01:28.000",
      "text": "自制自我在每日怨天怨地",
      "translation": null
    },
    {
      "time": 95.0,
      "time_str": "01:35.000",
      "text": "情话情意情路情尽都经过也是因你",
      "translation": null
    },
    {
      "time": 102.0,
      "time_str": "01:42.000",
      "text": "留下我在昨日过活但如死",
      "translation": null
    },
    {
      "time": 108.0,
      "time_str": "01:48.000",
      "text": "痴心像马戏 似小丑眼内希冀",
      "translation": null
    },
    {
      "time": 115.0,
      "time_str": "01:55.000",
      "text": "为想得到你愿竭力以心献技",
      "translation": null
    },
    {
      "time": 122.0,
      "time_str": "02:02.000",
      "text": "想你但怨你 暗街灯也在想你",
      "translation": null
    },
    {
      "time": 129.0,
      "time_str": "02:09.000",
      "text": "但却在暗示结局甚迷离",
      "translation": null
    },
    {
      "time": 174.0,
      "time_str": "02:54.000",
      "text": "无助无望无奈曾立心想放弃",
      "translation": null
