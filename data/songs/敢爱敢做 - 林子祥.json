  "lyrics": [
    {
      "time": 22.09,
      "time_str": "00:22.090",
      "text": "街边焦急的我 餐厅忧郁的你",
      "translation": null
    },
    {
      "time": 26.98,
      "time_str": "00:26.980",
      "text": "隔片沙玻璃 两眼带些伤悲",
      "translation": null
    },
    {
      "time": 32.18,
      "time_str": "00:32.180",
      "text": "交通灯边的我 紧抱深爱的你",
      "translation": null
    },
    {
      "time": 36.69,
      "time_str": "00:36.690",
      "text": "听呼吸声 确已急速到死",
      "translation": null
    },
    {
      "time": 42.41,
      "time_str": "00:42.410",
      "text": "冷雨扑向我 点点纷飞",
      "translation": null
    },
    {
      "time": 47.17,
      "time_str": "00:47.170",
      "text": "千度高温波涛 由你涌起",
      "translation": null
    },
    {
      "time": 51.5,
      "time_str": "00:51.500",
      "text": "个个说我太狂 笑我不羁",
      "translation": null
    },
    {
      "time": 56.86,
      "time_str": "00:56.860",
      "text": "敢於交出真情 哪算可鄙",
      "translation": null
    },
    {
      "time": 62.29,
      "time_str": "01:02.290",
      "text": "狂抱拥 不需休息的吻",
      "translation": null
    },
    {
      "time": 65.99,
      "time_str": "01:05.990",
      "text": "不需呼吸空气 不需街边观众远离",
      "translation": null
    },
    {
      "time": 72.06,
      "time_str": "01:12.060",
      "text": "微雨中 身边车辆飞过 街里路人走过",
      "translation": null
    },
    {
      "time": 78.17,
      "time_str": "01:18.170",
      "text": "交通灯催促过 剩下独是我跟你",
      "translation": null
    },
    {
      "time": 87.93,
      "time_str": "01:27.930",
      "text": "收紧一双手臂 箍紧身边的你",
      "translation": null
    },
    {
      "time": 92.75,
      "time_str": "01:32.750",
      "text": "透过湿恤衫 贴向你的肤肌",
      "translation": null
    },
    {
      "time": 97.67,
      "time_str": "01:37.670",
      "text": "身边多少指责 都已一概不理",
      "translation": null
    },
    {
      "time": 102.47,
      "time_str": "01:42.470",
      "text": "爱得真深 我俩应该吻死",
      "translation": null
    },
    {
      "time": 108.16,
      "time_str": "01:48.160",
      "text": "冷雨扑向我 点点纷飞",
