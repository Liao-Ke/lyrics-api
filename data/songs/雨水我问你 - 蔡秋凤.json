  "lyrics": [
    {
      "time": 22.41,
      "time_str": "00:22.410",
      "text": "又擱是落雨的晚上　雨水泼抹熄满腹酸苦味",
      "translation": null
    },
    {
      "time": 35.76,
      "time_str": "00:35.760",
      "text": "想起着彼当时　俩人淋雨的滋味　如今剩往事在稀微",
      "translation": null
    },
    {
      "time": 46.38,
      "time_str": "00:46.380",
      "text": "借着一杯酒想要醉乎死　谁知伤心是愈来愈清醒",
      "translation": null
    },
    {
      "time": 57.14,
      "time_str": "00:57.140",
      "text": "为感情来赌气　可比遇着颱風天　心痛就像雨水拨抹离",
      "translation": null
    },
    {
      "time": 68.42,
      "time_str": "01:08.420",
      "text": "啊～雨水我问你　我的感情算什么　无采爱你已经爱这多年",
      "translation": null
    },
    {
      "time": 79.6,
      "time_str": "01:19.600",
      "text": "啊～雨水我问你　谁人为爱赌生死　你敢讲我就陪你去",
      "translation": null
    },
    {
      "time": 90.99,
      "time_str": "01:30.990",
      "text": "我淋着冷冷的雨水　无奈你已经无在我身边",
      "translation": null
    },
    {
      "time": 101.18,
      "time_str": "01:41.180",
      "text": "不知你在哪裡　甘愿将我們放忘记　我只有藉雨水来想你",
      "translation": null
    },
    {
