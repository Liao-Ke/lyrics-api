  "lyrics": [
    {
      "time": 2.0,
      "time_str": "00:02.000",
      "text": "词曲 : 告五人/云安",
      "translation": null
    },
    {
      "time": 3.0,
      "time_str": "00:03.000",
      "text": "改编词曲 : G.E.M.邓紫棋",
      "translation": null
    },
    {
      "time": 13.64,
      "time_str": "00:13.640",
      "text": "你真的懂唯一的定义",
      "translation": null
    },
    {
      "time": 20.78,
      "time_str": "00:20.780",
      "text": "并不简单如呼吸",
      "translation": null
    },
    {
      "time": 26.83,
      "time_str": "00:26.830",
      "text": "你真的希望你能厘清",
      "translation": null
    },
    {
      "time": 33.18,
      "time_str": "00:33.180",
      "text": "若没交⼼怎么说明",
      "translation": null
    },
    {
      "time": 40.11,
      "time_str": "00:40.110",
      "text": "我真的爱你 句句不轻易",
      "translation": null
    },
    {
      "time": 52.91,
      "time_str": "00:52.910",
      "text": "眼神中飘移 总是在关键时刻清楚洞悉",
      "translation": null
    },
    {
      "time": 66.04,
      "time_str": "01:06.040",
      "text": "你的不坚定 配合我颠沛流离",
      "translation": null
    },
    {
      "time": 79.27,
      "time_str": "01:19.270",
      "text": "死去中清醒 明⽩你背着我聪明",
      "translation": null
    },
    {
      "time": 107.85,
      "time_str": "01:47.850",
      "text": "那些我 想说的 没说的 话",
      "translation": null
    },
    {
      "time": 113.55,
      "time_str": "01:53.550",
      "text": "有时我 怀疑呢 只是我 傻瓜",
      "translation": null
    },
    {
      "time": 120.0,
      "time_str": "02:00.000",
      "text": "但如果真的爱 不会算计",
      "translation": null
    },
    {
      "time": 124.16,
      "time_str": "02:04.160",
      "text": "爱是不嫉妒 不张狂 不求⾃⼰",
      "translation": null
    },
    {
      "time": 127.27,
      "time_str": "02:07.270",
      "text": "无关你的回应 永不⽌息",
      "translation": null
    },
    {
      "time": 131.98,
      "time_str": "02:11.980",
      "text": "你知道",
      "translation": null
    },
    {
      "time": 133.76,
      "time_str": "02:13.760",
      "text": "我真的爱你 没⼈能比拟",
      "translation": null
    },
    {
      "time": 146.4,
      "time_str": "02:26.400",
      "text": "眼神没肯定 总是在关键时刻清楚洞悉",
      "translation": null
    },
    {
      "time": 159.44,
      "time_str": "02:39.440",
      "text": "你的不坚定 配合我颠沛流离",
      "translation": null
    },
    {
      "time": 172.89,
      "time_str": "02:52.890",
      "text": "死去中清醒 明⽩你背着我聪明",
      "translation": null
    },
    {
      "time": 185.44,
      "time_str": "03:05.440",
      "text": "我知道",
      "translation": null
    },
    {
      "time": 186.95,
      "time_str": "03:06.950",
      "text": "爱本质无异 是因为⼈多得拥挤",
      "translation": null
    },
    {
      "time": 199.32,
      "time_str": "03:19.320",
      "text": "你不想证明 证明我是你唯一",
      "translation": null
    },
    {
      "time": 212.45,
      "time_str": "03:32.450",
      "text": "证明我是你唯一",
      "translation": null
    },
    {
