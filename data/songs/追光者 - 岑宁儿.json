    {
      "time": 24.88,
      "time_str": "00:24.880",
      "text": "如果说你是海上的烟火",
      "translation": null
    },
    {
      "time": 29.7,
      "time_str": "00:29.700",
      "text": "我是浪花的泡沫",
      "translation": null
    },
    {
      "time": 33.78,
      "time_str": "00:33.780",
      "text": "某一刻你的光照亮了我",
      "translation": null
    },
    {
      "time": 38.09,
      "time_str": "00:38.090",
      "text": "如果说你是遥远的星河",
      "translation": null
    },
    {
      "time": 43.11,
      "time_str": "00:43.110",
      "text": "耀眼得让人想哭",
      "translation": null
    },
    {
      "time": 48.64,
      "time_str": "00:48.640",
      "text": "我是追逐着你的眼眸",
      "translation": null
    },
    {
      "time": 52.0,
      "time_str": "00:52.000",
      "text": "总在孤单时候眺望夜空",
      "translation": null
    },
    {
      "time": 60.94,
      "time_str": "01:00.940",
      "text": "我可以跟在你身后",
      "translation": null
    },
    {
      "time": 64.36,
      "time_str": "01:04.360",
      "text": "像影子追着光梦游",
      "translation": null
    },
    {
      "time": 67.62,
      "time_str": "01:07.620",
      "text": "我可以等在这路口",
      "translation": null
    },
    {
      "time": 70.88,
      "time_str": "01:10.880",
      "text": "不管你会不会经过",
      "translation": null
    },
    {
      "time": 74.29,
      "time_str": "01:14.290",
      "text": "每当我为你抬起头",
      "translation": null
    },
    {
      "time": 77.55,
      "time_str": "01:17.550",
      "text": "连眼泪都觉得自由",
      "translation": null
    },
    {
      "time": 80.92,
      "time_str": "01:20.920",
      "text": "有的爱像阳光倾落",
      "translation": null
    },
    {
      "time": 84.62,
      "time_str": "01:24.620",
      "text": "边拥有边失去着",
      "translation": null
    },
    {
      "time": 101.44,
      "time_str": "01:41.440",
      "text": "如果说你是夏夜的萤火",
      "translation": null
    },
    {
      "time": 106.31,
      "time_str": "01:46.310",
      "text": "孩子们为你唱歌",
      "translation": null
    },
    {
      "time": 110.18,
      "time_str": "01:50.180",
      "text": "那么我是想要画你的手",
      "translation": null
    },
    {
      "time": 114.69,
      "time_str": "01:54.690",
      "text": "你看我多么渺小一个我",
      "translation": null
    },
    {
      "time": 119.66,
      "time_str": "01:59.660",
      "text": "因为你有梦可做",
      "translation": null
    },
    {
      "time": 125.28,
      "time_str": "02:05.280",
      "text": "也许你不会为我停留",
      "translation": null
    },
    {
      "time": 128.49,
      "time_str": "02:08.490",
      "text": "那就让我站在你的背后",
      "translation": null
    },
    {
