      "time_str": "00:28.530",
      "text": "时时刻刻沉醉爱河里",
      "translation": null
    },
    {
      "time": 35.07,
      "time_str": "00:35.070",
      "text": "谁知悲剧早已注定",
      "translation": null
    },
    {
      "time": 42.99,
      "time_str": "00:42.990",
      "text": "闭上眼睛想起你的情",
