{
  "title": "稀客",
  "title_raw": "稀客",
  "version": null,
  "artist": "杨千嬅",
  "group_key": "稀客|杨千嬅",
  "writers": {
    "lyricist": "黄伟文",
    "composer": "雷颂德",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 1.21,
      "time_str": "00:01.210",
      "text": "Song written by 雷颂德",
      "translation": null
    },
    {
      "time": 16.47,
      "time_str": "00:16.470",
      "text": "为何男孩都这副德性 没法忍受欲望停定",
      "translation": null
    },
    {
      "time": 23.98,
      "time_str": "00:23.980",
      "text": "年轻要任性 外出要尽兴 热恋也像驱车过境",
      "translation": null
    },
    {
      "time": 32.04,
      "time_str": "00:32.040",
      "text": "好好观光 亲手摄影 抱抱陌生的背影",
      "translation": null
    },
    {
      "time": 39.24,
      "time_str": "00:39.240",
      "text": "然后你继续行程 玩遍每座城 护照里盖上各式签证",
      "translation": null
    },
    {
      "time": 46.32,
      "time_str": "00:46.320",
      "text": "游客是你 风景是我 无法避免 让你经过",
      "translation": null
    },
    {
      "time": 54.38,
      "time_str": "00:54.380",
      "text": "蔷薇如期盛放 游人如期过路",
      "translation": null
    },
    {
      "time": 58.22,
      "time_str": "00:58.220",
      "text": "情人如期相爱至到分开",
      "translation": null
    },
    {
      "time": 61.84,
      "time_str": "01:01.840",
      "text": "就像命书中批过 在最后 都化作乌有",
      "translation": null
    },
    {
      "time": 67.19,
      "time_str": "01:07.190",
      "text": "但那天曾实在 华丽地邂逅",
      "translation": null
    },
    {
      "time": 70.86,
      "time_str": "01:10.860",
      "text": "早发生过 好等你继续走",
      "translation": null
    },
    {
      "time": 83.39,
      "time_str": "01:23.390",
      "text": "年华磨成的精致优雅 未够一夜便用完吧",
      "translation": null
    },
    {
      "time": 90.97,
      "time_str": "01:30.970",
      "text": "由稀客路过 玩赏赞誉过",
      "translation": null
    },
    {
      "time": 94.85,
      "time_str": "01:34.850",
      "text": "什么故事也没留下",
      "translation": null
    },
    {
      "time": 98.9,
      "time_str": "01:38.900",
      "text": "山光水色 芳草野花  你那日记写过吗",
      "translation": null
    },
    {
      "time": 105.94,
      "time_str": "01:45.940",
      "text": "难道我美丽年华  为装饰一下 夜里你那无聊的牵挂",
      "translation": null
    },
    {
      "time": 113.53,
      "time_str": "01:53.530",
      "text": "游客是你 风景是我 无法避免 让你经过",
      "translation": null
    },
    {
      "time": 121.1,
      "time_str": "02:01.100",
      "text": "蔷薇如期盛放 游人如期过路",
      "translation": null
    },
    {
      "time": 124.99,
      "time_str": "02:04.990",
      "text": "情人如期相爱至到分开",
      "translation": null
    },
    {
      "time": 128.53,
      "time_str": "02:08.530",
      "text": "就像命书中批过 在最后 都化作乌有",
      "translation": null
    },
    {
      "time": 133.81,
      "time_str": "02:13.810",
      "text": "但那天曾实在 华丽地邂逅",
      "translation": null
    },
    {
      "time": 137.39,
      "time_str": "02:17.390",
      "text": "早发生过 不阻你继续走",
      "translation": null
    },
    {
      "time": 156.03,
      "time_str": "02:36.030",
      "text": "命运暂且的交错 在最后都化作乌有",
      "translation": null
    },
    {
      "time": 161.0,
      "time_str": "02:41.000",
      "text": "但那天曾实在 华丽地邂逅",
      "translation": null
    },
    {
      "time": 165.13,
      "time_str": "02:45.130",
      "text": "这个诅咒 不知算应了没有",
      "translation": null
    },
    {
      "time": 172.26,
      "time_str": "02:52.260",
      "text": "即使间相恋像化缘",
      "translation": null
    },
    {
      "time": 176.52,
      "time_str": "02:56.520",
      "text": "以后 亦无内疚 还哪有借口",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "稀客 - 杨千嬅.lrc"
}