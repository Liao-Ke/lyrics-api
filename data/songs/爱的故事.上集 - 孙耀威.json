  "lyrics": [
    {
      "time": 17.1,
      "time_str": "00:17.100",
      "text": "星的光点点洒于午夜",
      "translation": null
    },
    {
      "time": 20.5,
      "time_str": "00:20.500",
      "text": "人人开开心心说说故事",
      "translation": null
    },
    {
      "time": 24.9,
      "time_str": "00:24.900",
      "text": "偏偏今宵所想讲不太易",
      "translation": null
    },
    {
      "time": 27.9,
      "time_str": "00:27.900",
      "text": "迟疑地望你想说又复迟疑",
      "translation": null
    },
    {
      "time": 32.5,
      "time_str": "00:32.500",
      "text": "秋风将涌起的某夜",
      "translation": null
    },
    {
      "time": 36.1,
      "time_str": "00:36.100",
      "text": "遗留她的窗边有个故事",
      "translation": null
    },
    {
      "time": 40.2,
      "time_str": "00:40.200",
      "text": "孤单单的小伙子不顾寂寞",
      "translation": null
    },
    {
      "time": 43.8,
      "time_str": "00:43.800",
      "text": "徘徊树下直至天际露月儿",
      "translation": null
    },
    {
      "time": 48.2,
      "time_str": "00:48.200",
      "text": "冬风吹走几多个月夜",
      "translation": null
    },
    {
      "time": 51.6,
      "time_str": "00:51.600",
      "text": "为何窗边的她欠缺注视",
      "translation": null
    },
    {
      "time": 55.9,
      "time_str": "00:55.900",
      "text": "刻于窗扉小子写的爱慕字",
      "translation": null
    },
    {
      "time": 59.6,
      "time_str": "00:59.600",
      "text": "完全没用像个飘散梦儿",
      "translation": null
    },
    {
      "time": 63.9,
      "time_str": "01:03.900",
      "text": "今宵的小伙子倾吐憾事",
      "translation": null
    },
    {
      "time": 67.2,
      "time_str": "01:07.200",
      "text": "谁人痴痴的要再听故事",
      "translation": null
    },
    {
      "time": 71.6,
      "time_str": "01:11.600",
      "text": "偏偏痴心小子只知道上集",
      "translation": null
    },
    {
      "time": 75.2,
      "time_str": "01:15.200",
      "text": "祈求下集是个可爱梦儿",
      "translation": null
    },
    {
      "time": 79.9,
      "time_str": "01:19.900",
      "text": "知不知对你牵上万缕爱意",
      "translation": null
    },
    {
      "time": 83.9,
      "time_str": "01:23.900",
      "text": "每晚也痛心空费尽心思",
      "translation": null
    },
    {
      "time": 87.7,
      "time_str": "01:27.700",
      "text": "这小子欲断难断这故事",
      "translation": null
    },
    {
      "time": 91.0,
      "time_str": "01:31.000",
      "text": "全为我爱上你偏偏你不知",
      "translation": null
    },
    {
      "time": 102.9,
      "time_str": "01:42.900",
      "text": "春风轻吹点点火花衬月夜",
      "translation": null
    },
    {
      "time": 106.3,
      "time_str": "01:46.300",
      "text": "人人开开心心说说故事",
      "translation": null
    },
    {
      "time": 110.9,
      "time_str": "01:50.900",
      "text": "终于倾出这小子的往事",
      "translation": null
    },
    {
      "time": 114.2,
      "time_str": "01:54.200",
      "text": "长年累月为你怎再自持",
      "translation": null
    },
    {
      "time": 118.5,
      "time_str": "01:58.500",
      "text": "今宵知否对你的暗示",
      "translation": null
    },
    {
      "time": 122.2,
      "time_str": "02:02.200",
      "text": "为何真的将它当故事",
      "translation": null
