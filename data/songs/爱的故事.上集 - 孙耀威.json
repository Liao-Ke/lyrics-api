    {
      "time": 145.9,
      "time_str": "02:25.900",
      "text": "全为爱上了你偏偏你不知",
      "translation": null
    },
    {
      "time": 150.2,
      "time_str": "02:30.200",
      "text": "知不知每晚想你十次百次",
      "translation": null
    },
    {
      "time": 154.2,
      "time_str": "02:34.200",
      "text": "每晚也去等因我极心痴",
      "translation": null
