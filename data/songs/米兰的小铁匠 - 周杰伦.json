{
  "title": "米兰的小铁匠",
  "title_raw": "米兰的小铁匠",
  "version": null,
  "artist": "周杰伦",
  "group_key": "米兰的小铁匠|周杰伦",
  "writers": {
    "lyricist": "方文山",
