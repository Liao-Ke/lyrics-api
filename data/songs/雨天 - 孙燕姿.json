    {
      "time": 15.77,
      "time_str": "00:15.770",
      "text": "站在十字路的交点",
      "translation": null
    },
    {
      "time": 22.82,
      "time_str": "00:22.820",
      "text": "该怎么走",
      "translation": null
    },
    {
      "time": 26.41,
      "time_str": "00:26.410",
      "text": "我却只想回头",
      "translation": null
    },
    {
      "time": 33.92,
      "time_str": "00:33.920",
      "text": "除了你给的伞我再也没有",
      "translation": null
    },
    {
      "time": 40.57,
      "time_str": "00:40.570",
      "text": "别的借口",
      "translation": null
    },
    {
      "time": 42.71,
      "time_str": "00:42.710",
      "text": "去拥有你的什么",
      "translation": null
    },
    {
      "time": 48.99,
      "time_str": "00:48.990",
      "text": "你能体谅 我有雨天",
      "translation": null
    },
    {
      "time": 53.38,
      "time_str": "00:53.380",
      "text": "偶尔胆怯 你都了解",
      "translation": null
    },
    {
      "time": 57.6,
      "time_str": "00:57.600",
      "text": "过去那些大雨落下的瞬间",
      "translation": null
    },
    {
      "time": 63.04,
      "time_str": "01:03.040",
      "text": "我突然发现",
      "translation": null
    },
    {
      "time": 65.92,
      "time_str": "01:05.920",
      "text": "谁能体谅 我的雨天",
      "translation": null
    },
    {
      "time": 70.07,
      "time_str": "01:10.070",
      "text": "所以情愿 回你身边",
      "translation": null
    },
    {
      "time": 74.16,
      "time_str": "01:14.160",
      "text": "此刻脚步会慢一些",
      "translation": null
    },
    {
      "time": 78.38,
      "time_str": "01:18.380",
      "text": "如此坚决",
      "translation": null
    },
    {
      "time": 82.31,
      "time_str": "01:22.310",
      "text": "你却越来越远",
      "translation": null
    },
    {
