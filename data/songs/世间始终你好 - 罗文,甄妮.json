  "lyrics": [
    {
      "time": 13.88,
      "time_str": "00:13.880",
      "text": "问世间",
      "translation": null
    },
    {
      "time": 16.09,
      "time_str": "00:16.090",
      "text": "是否此山最高",
      "translation": null
    },
    {
      "time": 20.79,
      "time_str": "00:20.790",
      "text": "或者",
      "translation": null
    },
    {
      "time": 23.24,
      "time_str": "00:23.240",
      "text": "另有高处比天高",
      "translation": null
    },
    {
      "time": 27.89,
      "time_str": "00:27.890",
      "text": "在世间",
      "translation": null
    },
    {
      "time": 30.2,
      "time_str": "00:30.200",
      "text": "自有山比此山更高",
      "translation": null
    },
    {
      "time": 34.73,
      "time_str": "00:34.730",
      "text": "但爱心",
      "translation": null
    },
    {
      "time": 37.0,
      "time_str": "00:37.000",
      "text": "找不到比你好",
      "translation": null
    },
    {
      "time": 41.5,
      "time_str": "00:41.500",
      "text": "一山还比一山高",
      "translation": null
    },
    {
      "time": 47.2,
      "time_str": "00:47.200",
      "text": "（无一可比你）",
      "translation": null
    },
    {
      "time": 48.2,
      "time_str": "00:48.200",
      "text": "真爱有如天高",
      "translation": null
    },
    {
      "time": 51.64,
      "time_str": "00:51.640",
      "text": "（爱更高）",
      "translation": null
    },
    {
      "time": 52.64,
      "time_str": "00:52.640",
      "text": "千百样好",
      "translation": null
    },
    {
      "time": 57.5,
      "time_str": "00:57.500",
      "text": "论武功",
      "translation": null
    },
    {
      "time": 59.55,
      "time_str": "00:59.550",
      "text": "俗世中不知边个高",
      "translation": null
    },
    {
      "time": 64.5,
      "time_str": "01:04.500",
      "text": "或者",
      "translation": null
    },
    {
      "time": 66.71,
      "time_str": "01:06.710",
      "text": "绝招同途异路",
      "translation": null
    },
    {
      "time": 71.39,
      "time_str": "01:11.390",
      "text": "但我知",
      "translation": null
    },
    {
      "time": 73.57,
      "time_str": "01:13.570",
      "text": "论爱心找不到更好",
      "translation": null
    },
    {
      "time": 78.37,
      "time_str": "01:18.370",
      "text": "待我心",
      "translation": null
    },
