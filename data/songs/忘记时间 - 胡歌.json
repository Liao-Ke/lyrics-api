  "lyrics": [
    {
      "time": 33.538,
      "time_str": "00:33.538",
      "text": "沉默着走了有 多遥远",
      "translation": null
    },
    {
      "time": 40.979,
      "time_str": "00:40.979",
      "text": "抬起头 蓦然间 才发现",
      "translation": null
    },
    {
      "time": 47.784,
      "time_str": "00:47.784",
      "text": "一直倒退 倒退到原点",
      "translation": null
    },
    {
      "time": 55.374,
      "time_str": "00:55.374",
      "text": "倔强坚持 对抗时间",
      "translation": null
    },
    {
      "time": 63.129,
      "time_str": "01:03.129",
      "text": "说好了的永远 断了线",
      "translation": null
    },
    {
      "time": 70.522,
      "time_str": "01:10.522",
      "text": "期许了 不变的 却都已改变",
      "translation": null
    },
    {
      "time": 77.331,
      "time_str": "01:17.331",
      "text": "紧闭 双眼 才能看的见",
      "translation": null
    },
    {
      "time": 84.464,
      "time_str": "01:24.464",
      "text": "那些曾经温暖 鲜艳过的画面",
      "translation": null
    },
    {
      "time": 91.29,
      "time_str": "01:31.290",
      "text": "渐渐地忘记 赶不上明天",
      "translation": null
    },
    {
      "time": 95.046,
      "time_str": "01:35.046",
      "text": "只要用力地抓紧了想念",
      "translation": null
    },
    {
      "time": 99.231,
      "time_str": "01:39.231",
      "text": "明天再也 没有你的笑脸",
      "translation": null
    },
    {
      "time": 106.106,
      "time_str": "01:46.106",
      "text": "渐渐地忘记 忘记了时间",
      "translation": null
    },
    {
      "time": 109.791,
      "time_str": "01:49.791",
      "text": "我只要沿着记忆的路线",
      "translation": null
    },
    {
      "time": 114.306,
      "time_str": "01:54.306",
      "text": "到最深处 纵然那只是瞬间",
      "translation": null
    },
    {
      "time": 122.103,
      "time_str": "02:02.103",
      "text": "当眼泪 滑落的 是句点",
      "translation": null
    },
    {
      "time": 129.437,
      "time_str": "02:09.437",
      "text": "心里面 始终你 从没有走远",
      "translation": null
    },
    {
      "time": 136.389,
      "time_str": "02:16.389",
      "text": "耳边 誓言 还在回旋",
      "translation": null
    },
    {
      "time": 143.409,
      "time_str": "02:23.409",
      "text": "我会好好珍惜 没有你的明天",
      "translation": null
    },
    {
      "time": 179.93,
      "time_str": "02:59.930",
      "text": "渐渐地忘记 赶不上明天",
      "translation": null
