  "lyrics": [
    {
      "time": 16.72,
      "time_str": "00:16.720",
      "text": "用我的晚安陪你吃早餐",
      "translation": null
    },
    {
      "time": 21.74,
      "time_str": "00:21.740",
      "text": "记得把想念存进扑满",
      "translation": null
    },
    {
      "time": 26.1,
      "time_str": "00:26.100",
      "text": "我望着满天星在闪",
      "translation": null
    },
    {
      "time": 30.74,
      "time_str": "00:30.740",
      "text": "听牛郎对织女说要勇敢",
      "translation": null
    },
    {
      "time": 36.29,
      "time_str": "00:36.290",
      "text": "别怕我们在地球的两端",
      "translation": null
    },
    {
      "time": 41.42,
      "time_str": "00:41.420",
      "text": "看我的问候骑着魔毯",
      "translation": null
    },
    {
      "time": 45.69,
      "time_str": "00:45.690",
      "text": "飞 用光速飞到你面前",
      "translation": null
    },
    {
      "time": 50.25,
      "time_str": "00:50.250",
      "text": "要你能看到十字星有北极星作伴",
      "translation": null
    },
    {
      "time": 54.89,
      "time_str": "00:54.890",
      "text": "少了我的手臂当枕头你习不习惯",
      "translation": null
    },
    {
      "time": 59.72,
      "time_str": "00:59.720",
      "text": "你的望远镜望不到我北半球的孤单",
      "translation": null
    },
    {
      "time": 64.7,
      "time_str": "01:04.700",
      "text": "太平洋的潮水跟着地球来回旋转",
      "translation": null
    },
    {
      "time": 69.58,
      "time_str": "01:09.580",
      "text": "我会耐心地等 随时欢迎你靠岸",
      "translation": null
    },
    {
      "time": 74.47,
      "time_str": "01:14.470",
      "text": "少了我的怀抱当暖炉你习不习惯",
      "translation": null
    },
    {
      "time": 79.35,
      "time_str": "01:19.350",
      "text": "E给你照片看不到我北半球的孤单",
      "translation": null
    },
    {
      "time": 84.28,
      "time_str": "01:24.280",
      "text": "世界再大两颗真心就能互相取暖",
      "translation": null
    },
    {
      "time": 89.11,
      "time_str": "01:29.110",
      "text": "想念不会偷懒",
      "translation": null
    },
    {
      "time": 91.94,
