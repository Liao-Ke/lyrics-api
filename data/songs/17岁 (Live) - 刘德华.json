  "lyrics": [
    {
      "time": 21.1,
      "time_str": "00:21.100",
      "text": "十七岁那日不要脸参加了挑战",
      "translation": null
    },
    {
      "time": 27.27,
      "time_str": "00:27.270",
      "text": "明星也有训练班",
      "translation": null
    },
    {
      "time": 29.73,
      "time_str": "00:29.730",
      "text": "短短一年太新鲜",
      "translation": null
    },
    {
      "time": 32.69,
      "time_str": "00:32.690",
      "text": "记得四哥 发哥 都早已见过面",
      "translation": null
    },
    {
      "time": 39.23,
      "time_str": "00:39.230",
      "text": "后来荣升主角太突然",
      "translation": null
    },
    {
      "time": 45.22,
      "time_str": "00:45.220",
      "text": "廿九岁颁奖的晚宴",
      "translation": null
    },
    {
      "time": 48.31,
      "time_str": "00:48.310",
      "text": "fans太疯癫",
      "translation": null
    },
    {
      "time": 51.26,
      "time_str": "00:51.260",
      "text": "来听我唱段情歌一曲",
      "translation": null
    },
    {
      "time": 54.38,
      "time_str": "00:54.380",
      "text": "歌词太经典",
      "translation": null
    },
    {
      "time": 56.66,
      "time_str": "00:56.660",
      "text": "我的震音假音都早已太熟练",
      "translation": null
    },
    {
      "time": 62.6,
      "time_str": "01:02.600",
      "text": "然而情歌总唱不厌",
      "translation": null
    },
    {
      "time": 68.66,
      "time_str": "01:08.660",
      "text": "喜欢我别遮脸任由途人发现",
      "translation": null
    },
    {
      "time": 74.61,
      "time_str": "01:14.610",
      "text": "尽管唱用心把这情绪歌中染",
      "translation": null
    },
    {
      "time": 83.04,
      "time_str": "01:23.040",
      "text": "唱情歌齐齐来一遍",
      "translation": null
    },
    {
      "time": 88.9,
      "time_str": "01:28.900",
      "text": "无时无刻都记住掌声响遍天",
      "translation": null
    },
    {
      "time": 94.7,
      "time_str": "01:34.700",
      "text": "来唱情歌由从头再一遍",
      "translation": null
    },
    {
      "time": 100.8,
      "time_str": "01:40.800",
      "text": "如情浓有点泪流难避免",
      "translation": null
    },
    {
      "time": 106.18,
      "time_str": "01:46.180",
      "text": "音阶起跌拍子改变 每首歌是每张脸",
      "translation": null
    },
    {
      "time": 136.41,
      "time_str": "02:16.410",
      "text": "喜欢我 别遮脸 任由途人发现",
      "translation": null
    },
    {
      "time": 143.19,
      "time_str": "02:23.190",
      "text": "尽管唱用心把这情绪歌声中渲染",
      "translation": null
    },
    {
      "time": 149.04,
      "time_str": "02:29.040",
      "text": "唱情歌齐齐来一遍",
      "translation": null
    },
    {
      "time": 154.85,
      "time_str": "02:34.850",
      "text": "无时无刻都记住掌声响遍天",
      "translation": null
    },
    {
      "time": 160.71,
      "time_str": "02:40.710",
      "text": "来唱情歌由从头再一遍",
      "translation": null
    },
    {
      "time": 166.96,
      "time_str": "02:46.960",
      "text": "如情浓有点泪流难避免",
      "translation": null
    },
    {
      "time": 172.21,
      "time_str": "02:52.210",
      "text": "音阶起跌拍子改变 年月变但我未变",
      "translation": null
    },
    {
      "time": 179.68,
      "time_str": "02:59.680",
      "text": "唱情歌齐齐来一遍",
      "translation": null
    },
    {
      "time": 184.9,
      "time_str": "03:04.900",
      "text": "无时无刻都记住掌声响遍天",
      "translation": null
    },
    {
      "time": 190.72,
      "time_str": "03:10.720",
      "text": "来唱情歌由从头再一遍",
      "translation": null
    },
    {
      "time": 196.77,
      "time_str": "03:16.770",
      "text": "如情浓有点泪流难避免",
      "translation": null
    },
    {
      "time": 202.29,
      "time_str": "03:22.290",
      "text": "音阶起跌拍子改变 每首歌是每张脸",
      "translation": null
    },
    {
      "time": 229.14,
      "time_str": "03:49.140",
      "text": "如今我四十看从前沙哑了声线",
      "translation": null
    },
    {
      "time": 237.78,
      "time_str": "03:57.780",
      "text": "回忆我冀望那掌声都依然到今天",
      "translation": null
    },
    {
      "time": 262.98,
      "time_str": "04:22.980",
      "text": "那首潮水忘情水不再经典",
      "translation": null
    },
    {
      "time": 271.65,
      "time_str": "04:31.650",
      "text": "仍长埋你的心中从未变",
      "translation": null
    }
  ],
