    {
      "time": 5.0,
      "time_str": "00:05.000",
      "text": "Programming : Keith Chan",
      "translation": null
    },
    {
      "time": 7.0,
      "time_str": "00:07.000",
      "text": "合成器 : Keith Chan",
      "translation": null
    },
    {
      "time": 31.84,
      "time_str": "00:31.840",
      "text": "就算天空再深 看不出裂痕",
      "translation": null
    },
    {
      "time": 35.845,
      "time_str": "00:35.845",
      "text": "眉头 仍聚满密云",
      "translation": null
    },
    {
      "time": 39.574,
      "time_str": "00:39.574",
      "text": "就算一屋暗灯 照不穿我身",
      "translation": null
    },
    {
      "time": 43.626,
      "time_str": "00:43.626",
      "text": "仍可反映你心",
      "translation": null
    },
    {
      "time": 47.867,
      "time_str": "00:47.867",
      "text": "让这口烟跳升 我身躯下沉",
      "translation": null
    },
    {
      "time": 51.687,
      "time_str": "00:51.687",
      "text": "曾多么想多么想贴近",
      "translation": null
    },
    {
      "time": 55.587,
      "time_str": "00:55.587",
      "text": "你的心和眼 口和耳亦没缘分",
      "translation": null
    },
    {
      "time": 59.546,
      "time_str": "00:59.546",
      "text": "我都捉不紧",
      "translation": null
    },
    {
      "time": 63.53,
      "time_str": "01:03.530",
      "text": "害怕悲剧重演 我的命中命中",
      "translation": null
    },
    {
      "time": 67.35,
      "time_str": "01:07.350",
      "text": "越美丽的东西我越不可碰",
      "translation": null
    },
    {
      "time": 71.495,
      "time_str": "01:11.495",
      "text": "历史在重演 这么烦嚣城中",
      "translation": null
    },
    {
      "time": 75.268,
      "time_str": "01:15.268",
      "text": "没理由 相恋可以没有暗涌",
      "translation": null
    },
    {
      "time": 79.403,
      "time_str": "01:19.403",
      "text": "其实我再去爱惜你又有何用",
      "translation": null
    },
    {
      "time": 83.327,
      "time_str": "01:23.327",
      "text": "难道这次我抱紧你未必落空",
      "translation": null
    },
    {
      "time": 87.541,
      "time_str": "01:27.541",
      "text": "仍静候着你说 我别错用神",
      "translation": null
    },
    {
      "time": 91.302,
      "time_str": "01:31.302",
      "text": "什么我 都有预感",
      "translation": null
    },
    {
      "time": 95.342,
      "time_str": "01:35.342",
      "text": "然后睁不开两眼 看命运光临",
      "translation": null
    },
    {
      "time": 99.138,
      "time_str": "01:39.138",
      "text": "然后天空又再涌起密云",
      "translation": null
    },
    {
