  "lyrics": [
    {
      "time": 0.3,
      "time_str": "00:00.300",
      "text": "Remember me",
      "translation": "请记住我吧"
    },
    {
      "time": 3.6,
      "time_str": "00:03.600",
      "text": "Though I have to say goodbye",
      "translation": "虽然我要说再见了"
    },
    {
      "time": 6.17,
      "time_str": "00:06.170",
      "text": "Remember me",
      "translation": "记住我"
    },
    {
      "time": 9.4,
      "time_str": "00:09.400",
      "text": "Don't let it make you cry",
      "translation": "希望你别哭泣"
    },
    {
      "time": 12.4,
      "time_str": "00:12.400",
      "text": "For even if I'm far away",
      "translation": "就算我远行"
    },
    {
      "time": 15.1,
      "time_str": "00:15.100",
      "text": "I hold you in my heart",
      "translation": "我也将你放在心里"
    },
    {
      "time": 18.0,
      "time_str": "00:18.000",
      "text": "I sing a secret song to you",
      "translation": "我都要唱一首秘密给你听"
    },
    {
      "time": 20.78,
      "time_str": "00:20.780",
      "text": "Each night we are apart",
      "translation": "每个分开的夜晚"
    },
    {
      "time": 22.9,
      "time_str": "00:22.900",
      "text": "Remember me",
      "translation": "记住我"
    },
    {
      "time": 26.13,
      "time_str": "00:26.130",
      "text": "Though I have to travel far",
      "translation": "虽然我要远行"
    },
    {
      "time": 28.54,
      "time_str": "00:28.540",
      "text": "Remember me",
      "translation": "记住我"
    },
    {
      "time": 31.42,
      "time_str": "00:31.420",
      "text": "Each time you hear a sad guitar",
      "translation": "每当你听见悲伤的吉他声"
    },
    {
      "time": 34.87,
      "time_str": "00:34.870",
      "text": "Know that I'm with you",
      "translation": "要知道是我与你在一起"
    },
    {
      "time": 36.87,
      "time_str": "00:36.870",
      "text": "The only way that I can be",
      "translation": "那是我能做的唯一方式"
    },
    {
      "time": 40.46,
      "time_str": "00:40.460",
      "text": "Until you're in my arms again",
      "translation": "直在你回到我的怀抱之前"
    },
    {
      "time": 45.34,
      "time_str": "00:45.340",
      "text": "Remember me",
      "translation": "记住我"
    },
    {
      "time": 46.78,
      "time_str": "00:46.780",
      "text": "Que nuestra canción no deje de latir",
      "translation": "我们的旋律不会停止"
    },
    {
      "time": 49.52,
      "time_str": "00:49.520",
      "text": "Solo con tu amor yo puedo existir",
      "translation": "我也因你的爱而存在"
    },
    {
      "time": 51.13,
      "time_str": "00:51.130",
      "text": "Recuérdame",
      "translation": "记住我"
    },
