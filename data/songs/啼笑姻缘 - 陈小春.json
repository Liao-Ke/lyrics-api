  "lyrics": [
    {
      "time": 10.145,
      "time_str": "00:10.145",
      "text": "苦恋三千年分手皆一念",
      "translation": null
    },
    {
      "time": 15.017,
      "time_str": "00:15.017",
      "text": "匆匆只一面偏偏很闪电",
      "translation": null
    },
    {
      "time": 19.517,
      "time_str": "00:19.517",
      "text": "隆重上演啼笑姻缘",
      "translation": null
    },
    {
      "time": 24.331,
      "time_str": "00:24.331",
      "text": "情侣都笑过喊过至像相恋",
      "translation": null
    },
    {
      "time": 29.692,
      "time_str": "00:29.692",
      "text": "平淡最苦烦恼很甜",
      "translation": null
    },
    {
      "time": 35.002,
      "time_str": "00:35.002",
      "text": "荣幸到爱上两个却又辛酸",
      "translation": null
    },
    {
      "time": 39.88,
      "time_str": "00:39.880",
      "text": "若我可拣选我的恋爱也要乱",
      "translation": null
    },
    {
      "time": 45.568,
      "time_str": "00:45.568",
      "text": "才算有血有肉震地惊天",
      "translation": null
    },
    {
      "time": 50.568,
      "time_str": "00:50.568",
      "text": "没有兜兜转过山车太快坐完",
      "translation": null
    },
    {
      "time": 55.88,
      "time_str": "00:55.880",
      "text": "没有分手的惊险情侣哪有戏好演",
      "translation": null
    },
    {
      "time": 61.88,
      "time_str": "01:01.880",
      "text": "心可以攻可以守可以呃可以抢",
      "translation": null
    },
    {
      "time": 65.24,
      "time_str": "01:05.240",
      "text": "可以偷可以伤可以收",
      "translation": null
    },
    {
      "time": 66.88,
      "time_str": "01:06.880",
      "text": "就算隐隐的痛都有种温柔",
      "translation": null
    },
    {
      "time": 72.192,
      "time_str": "01:12.192",
      "text": "手牵过手握过手转过手得过手",
      "translation": null
    },
    {
      "time": 75.068,
      "time_str": "01:15.068",
      "text": "失过手跟我走赶我走",
      "translation": null
    },
    {
      "time": 77.004,
      "time_str": "01:17.004",
      "text": "为你哭得出我都觉得享受",
      "translation": null
    },
    {
      "time": 82.818,
      "time_str": "01:22.818",
      "text": "未怕情深乱一生爱因种出断肠恨",
      "translation": null
    },
    {
      "time": 92.63,
      "time_str": "01:32.630",
      "text": "就算残忍亦侥倖这生碰到这个人",
      "translation": null
    },
    {
      "time": 102.443,
      "time_str": "01:42.443",
      "text": "陪着你演啼笑姻缘",
      "translation": null
    },
    {
      "time": 107.443,
      "time_str": "01:47.443",
      "text": "情侣间斗智斗勇每日新鲜",
      "translation": null
    },
    {
      "time": 112.443,
      "time_str": "01:52.443",
      "text": "行过钢线游过花园",
      "translation": null
    },
    {
      "time": 117.631,
      "time_str": "01:57.631",
      "text": "从没有碰上至算最坏的尖",
      "translation": null
    },
    {
      "time": 122.63,
      "time_str": "02:02.630",
      "text": "若我可拣选我的恋爱也要乱",
      "translation": null
    },
    {
      "time": 128.255,
      "time_str": "02:08.255",
      "text": "才算可歌可泣爱恨交煎",
      "translation": null
    },
    {
      "time": 133.319,
      "time_str": "02:13.319",
      "text": "没有兜兜转过山车太快坐完",
      "translation": null
    },
    {
      "time": 138.5,
      "time_str": "02:18.500",
      "text": "没有争执的画面情爱哪里够经典",
      "translation": null
    },
    {
      "time": 144.378,
      "time_str": "02:24.378",
      "text": "心可以攻可以守可以呃可以抢",
      "translation": null
    },
    {
      "time": 147.378,
      "time_str": "02:27.378",
      "text": "可以偷可以伤可以收",
      "translation": null
    },
    {
      "time": 149.382,
      "time_str": "02:29.382",
      "text": "就算隐隐的痛都有种温柔",
      "translation": null
    },
    {
      "time": 152.942,
      "time_str": "02:32.942",
      "text": "手牵过手握过手转过手得过手",
      "translation": null
    },
    {
      "time": 158.24,
      "time_str": "02:38.240",
      "text": "失过手跟我走赶我走",
      "translation": null
    },
    {
      "time": 159.566,
      "time_str": "02:39.566",
      "text": "为你哭得出我都觉得享受",
      "translation": null
    },
    {
      "time": 164.84,
      "time_str": "02:44.840",
      "text": "Rap 唯怕爱人你变左心",
      "translation": null
    },
    {
      "time": 168.042,
      "time_str": "02:48.042",
      "text": "我终日提心吊胆步步为营泪满襟",
      "translation": null
    },
    {
      "time": 170.729,
      "time_str": "02:50.729",
      "text": "虽然或者唔知边个系我最爱既人",
      "translation": null
    },
    {
      "time": 173.23,
      "time_str": "02:53.230",
      "text": "但我可以肯定十分唔想一个人",
      "translation": null
    },
    {
      "time": 175.854,
      "time_str": "02:55.854",
      "text": "生得相聚死人化蝶当然感人",
      "translation": null
    },
    {
      "time": 178.29,
      "time_str": "02:58.290",
      "text": "话裂痕有裂痕都算有质感",
      "translation": null
    },
    {
      "time": 180.854,
      "time_str": "03:00.854",
      "text": "落极生卑可能太震撼太过份",
      "translation": null
    },
    {
      "time": 183.291,
      "time_str": "03:03.291",
      "text": "情愿否极泰来苦尽爱你一镬金",
      "translation": null
    },
    {
