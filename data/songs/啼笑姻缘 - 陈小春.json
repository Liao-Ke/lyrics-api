    {
      "time": 212.929,
      "time_str": "03:32.929",
      "text": "就怕不分哭笑终有所保留",
      "translation": null
    },
    {
      "time": 218.489,
      "time_str": "03:38.489",
      "text": "手牵过手握过手转过手得过手",
      "translation": null
    },
    {
      "time": 221.429,
