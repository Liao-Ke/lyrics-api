    {
      "time": 24.75,
      "time_str": "00:24.750",
      "text": "那天我扬起帆",
      "translation": null
    },
    {
      "time": 29.63,
      "time_str": "00:29.630",
      "text": "想看看未知的海",
      "translation": null
    },
    {
      "time": 33.22,
      "time_str": "00:33.220",
      "text": "心里很多话想说说不出来",
      "translation": null
    },
    {
      "time": 38.75,
      "time_str": "00:38.750",
      "text": "虽然我脸上看不出来",
      "translation": null
    },
    {
      "time": 44.6,
      "time_str": "00:44.600",
      "text": "天空一样蔚蓝",
      "translation": null
    },
    {
      "time": 49.79,
      "time_str": "00:49.790",
      "text": "却换了多少云彩",
      "translation": null
    },
    {
      "time": 53.48,
      "time_str": "00:53.480",
      "text": "那时的你让我幸福百分百",
      "translation": null
    },
    {
      "time": 59.54,
      "time_str": "00:59.540",
      "text": "是否为我等待",
      "translation": null
    },
    {
      "time": 63.418,
      "time_str": "01:03.418",
      "text": "我知道 我的爱",
      "translation": null
    },
    {
      "time": 65.799,
      "time_str": "01:05.799",
      "text": "一直都会存在",
      "translation": null
    },
    {
      "time": 68.87,
      "time_str": "01:08.870",
      "text": "没有你泪停不下来",
      "translation": null
    },
    {
      "time": 73.319,
      "time_str": "01:13.319",
      "text": "你知道 我依赖",
      "translation": null
    },
    {
      "time": 76.938,
      "time_str": "01:16.938",
      "text": "多不想 Say good bye",
