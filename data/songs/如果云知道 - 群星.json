  "lyrics": [
    {
      "time": 41.6,
      "time_str": "00:41.600",
      "text": "爱一旦结冰 一切都好平静",
      "translation": null
    },
    {
      "time": 51.6,
      "time_str": "00:51.600",
      "text": "泪水它一旦流尽 只剩决心",
      "translation": null
    },
    {
      "time": 61.6,
      "time_str": "01:01.600",
      "text": "放逐自己在黑夜的边境",
      "translation": null
    },
    {
      "time": 66.6,
      "time_str": "01:06.600",
      "text": "任由黎明一步一步向我逼近",
      "translation": null
    },
    {
      "time": 73.6,
      "time_str": "01:13.600",
      "text": "想你的心 化成灰烬",
      "translation": null
    },
    {
      "time": 85.6,
      "time_str": "01:25.600",
      "text": "真的有点累了 没什么力气",
      "translation": null
    },
    {
      "time": 96.6,
      "time_str": "01:36.600",
      "text": "有太多太多的回忆 哽住呼吸",
      "translation": null
    },
    {
      "time": 106.6,
      "time_str": "01:46.600",
      "text": "爱你的心我无处投递",
      "translation": null
    },
    {
      "time": 111.6,
      "time_str": "01:51.600",
      "text": "如果可以飞檐走壁找到你",
      "translation": null
    },
    {
      "time": 118.6,
      "time_str": "01:58.600",
      "text": "爱的委屈 不必澄清",
      "translation": null
    },
    {
      "time": 123.6,
      "time_str": "02:03.600",
      "text": "只要你将我抱紧",
      "translation": null
    },
    {
      "time": 130.6,
      "time_str": "02:10.600",
      "text": "如果云知道",
      "translation": null
    },
    {
      "time": 135.6,
      "time_str": "02:15.600",
      "text": "想你的夜慢慢熬",
      "translation": null
    },
    {
      "time": 141.6,
      "time_str": "02:21.600",
      "text": "每个思念过一秒 每次呼喊过一秒",
      "translation": null
    },
    {
      "time": 147.6,
      "time_str": "02:27.600",
      "text": "只觉得生命不停燃烧",
      "translation": null
    },
    {
      "time": 152.6,
      "time_str": "02:32.600",
      "text": "如果云知道",
      "translation": null
    },
    {
      "time": 157.6,
      "time_str": "02:37.600",
      "text": "逃不开纠缠的牢",
      "translation": null
    },
    {
      "time": 163.6,
      "time_str": "02:43.600",
      "text": "每当心痛过一秒 每回哭醒过一秒",
      "translation": null
    },
    {
      "time": 170.6,
      "time_str": "02:50.600",
      "text": "只剩下心在乞讨 你不会知道",
      "translation": null
    },
