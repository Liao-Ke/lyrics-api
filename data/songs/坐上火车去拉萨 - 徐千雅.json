  "lyrics": [
    {
      "time": 25.999,
      "time_str": "00:25.999",
      "text": "山有多高啊",
      "translation": null
    },
    {
      "time": 28.459,
      "time_str": "00:28.459",
      "text": "水有多长",
      "translation": null
    },
    {
      "time": 30.869,
      "time_str": "00:30.869",
      "text": "通往天堂的路太难",
      "translation": null
    },
    {
      "time": 35.829,
      "time_str": "00:35.829",
      "text": "终于盼来啊",
      "translation": null
    },
    {
      "time": 38.89,
      "time_str": "00:38.890",
      "text": "这条天路",
      "translation": null
    },
    {
      "time": 40.409,
      "time_str": "00:40.409",
      "text": "像巨龙飞在高原上",
      "translation": null
    },
    {
      "time": 45.259,
      "time_str": "00:45.259",
      "text": "穿过草原啊",
      "translation": null
    },
    {
      "time": 48.199,
      "time_str": "00:48.199",
      "text": "越过山川",
      "translation": null
    },
    {
      "time": 50.19,
      "time_str": "00:50.190",
      "text": "载着梦想和吉祥",
      "translation": null
    },
    {
      "time": 54.819,
      "time_str": "00:54.819",
      "text": "幸福的歌啊一路的唱",
      "translation": null
    },
    {
      "time": 59.639,
      "time_str": "00:59.639",
      "text": "唱到了唐古拉山",
      "translation": null
    },
    {
      "time": 67.99,
      "time_str": "01:07.990",
      "text": "坐上了火车去拉萨",
      "translation": null
    },
    {
      "time": 71.469,
      "time_str": "01:11.469",
      "text": "去看那神奇的布达拉",
      "translation": null
    },
    {
      "time": 76.429,
      "time_str": "01:16.429",
      "text": "去看那最美的格桑花呀",
      "translation": null
    },
    {
      "time": 81.299,
      "time_str": "01:21.299",
      "text": "盛开在雪山下",
      "translation": null
    },
    {
      "time": 86.39,
      "time_str": "01:26.390",
      "text": "坐上了火车去拉萨",
      "translation": null
    },
    {
      "time": 90.689,
      "time_str": "01:30.689",
      "text": "跳起那热烈的雪山朗玛",
      "translation": null
    },
    {
      "time": 96.599,
      "time_str": "01:36.599",
      "text": "喝下那最香浓的青稞酒呀",
      "translation": null
    },
    {
      "time": 100.548,
      "time_str": "01:40.548",
      "text": "醉在神话天堂",
      "translation": null
    },
    {
