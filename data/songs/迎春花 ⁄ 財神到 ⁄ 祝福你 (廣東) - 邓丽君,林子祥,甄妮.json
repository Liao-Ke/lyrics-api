  "lyrics": [
    {
      "time": 15.4,
      "time_str": "00:15.400",
      "text": "好一朵迎春花 人人都爱它",
      "translation": null
    },
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "好一朵迎春花 迎来大地放光华",
      "translation": null
    },
    {
      "time": 28.86,
      "time_str": "00:28.860",
      "text": "好一朵迎春花 花开每一家",
      "translation": null
    },
    {
      "time": 35.17,
      "time_str": "00:35.170",
      "text": "好一朵迎春花 茂盛艳丽春色雅",
      "translation": null
    },
    {
      "time": 42.48,
      "time_str": "00:42.480",
      "text": "迎春花开 带来了好年华",
      "translation": null
    },
    {
      "time": 49.85,
      "time_str": "00:49.850",
      "text": "迎春花艳 倍觉景致如画",
      "translation": null
    },
    {
      "time": 56.18,
      "time_str": "00:56.180",
      "text": "花开富贵 人尽畅怀",
      "translation": null
    },
    {
      "time": 63.49,
      "time_str": "01:03.490",
      "text": "万事胜意 无牵挂",
      "translation": null
    },
    {
      "time": 70.0,
      "time_str": "01:10.000",
      "text": "好一朵迎春花 谁人不爱它",
      "translation": null
    },
    {
      "time": 76.33,
      "time_str": "01:16.330",
      "text": "好一朵迎春花 迎来大地绣彩霞",
      "translation": null
    },
    {
      "time": 83.57,
      "time_str": "01:23.570",
      "text": "插起那迎春花 芬芳播千家",
      "translation": null
    },
    {
      "time": 90.86,
      "time_str": "01:30.860",
      "text": "插起那迎春花 人人齐共欢乐哈",
      "translation": null
    },
    {
      "time": 97.44,
      "time_str": "01:37.440",
      "text": "财神到",
      "translation": null
    },
    {
      "time": 108.31,
      "time_str": "01:48.310",
      "text": "财神到 财神到 好心得好报",
      "translation": null
    },
    {
      "time": 110.0,
      "time_str": "01:50.000",
      "text": "财神话 财神话 揾钱依正路",
      "translation": null
    },
    {
      "time": 113.55,
      "time_str": "01:53.550",
      "text": "财神到 财神到 好走快两步",
      "translation": null
    },
    {
      "time": 117.33,
      "time_str": "01:57.330",
      "text": "得到佢睇起你 你有前途",
      "translation": null
    },
    {
      "time": 120.42,
      "time_str": "02:00.420",
      "text": "阖府庆新岁喜气盈盈",
      "translation": null
    },
    {
      "time": 123.87,
      "time_str": "02:03.870",
      "text": "齐贺你多福荫壮健强劲",
      "translation": null
    },
    {
      "time": 127.49,
      "time_str": "02:07.490",
      "text": "又祝你今年庆获荣升",
      "translation": null
    },
    {
      "time": 131.67,
      "time_str": "02:11.670",
      "text": "朝晚多多欢笑锦绣前程",
      "translation": null
    },
    {
      "time": 134.95,
      "time_str": "02:14.950",
      "text": "愿夫妇恩爱体贴入微",
      "translation": null
    },
    {
      "time": 137.86,
      "time_str": "02:17.860",
      "text": "成日有吉星照百事无忌",
      "translation": null
    },
    {
      "time": 141.25,
      "time_str": "02:21.250",
      "text": "共亲友相见说话投机",
      "translation": null
    },
    {
      "time": 144.82,
      "time_str": "02:24.820",
      "text": "充满新春喜气欢畅扬眉",
      "translation": null
    },
    {
      "time": 148.31,
      "time_str": "02:28.310",
      "text": "财神到 财神到 好心得好报",
      "translation": null
    },
    {
      "time": 151.0,
      "time_str": "02:31.000",
      "text": "财神话 财神话 揾钱依正路",
      "translation": null
    },
    {
      "time": 151.7,
      "time_str": "02:31.700",
      "text": "啦……",
      "translation": null
    },
    {
      "time": 154.55,
      "time_str": "02:34.550",
      "text": "财神到 财神到 好走快两步",
      "translation": null
    },
    {
      "time": 158.33,
      "time_str": "02:38.330",
      "text": "得到佢睇起你 你有前途",
      "translation": null
    },
    {
      "time": 168.56,
      "time_str": "02:48.560",
      "text": "财神到 财神到 好走快两步",
      "translation": null
    },
    {
      "time": 172.26,
      "time_str": "02:52.260",
      "text": "得到佢睇起你 你有前途",
      "translation": null
    },
    {
      "time": 175.88,
      "time_str": "02:55.880",
      "text": "贺所有鸳侣花结并头（结并头）",
      "translation": null
    },
    {
      "time": 178.95,
      "time_str": "02:58.950",
      "text": "还望各位工友百业成就（有成就）",
      "translation": null
    },
    {
      "time": 182.22,
      "time_str": "03:02.220",
      "text": "大家无无争斗快乐无忧（乐无忧）",
      "translation": null
    },
    {
      "time": 186.1,
      "time_str": "03:06.100",
      "text": "听只歌轻松下抛却恨愁",
      "translation": null
    },
    {
