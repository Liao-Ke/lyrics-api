      "text": "Sun shines for you",
      "translation": "太阳会闪耀着你"
    },
    {
      "time": 38.27,
      "time_str": "00:38.270",
      "text": "曲がり角を",
      "translation": "在拐角处"
    },
    {
      "time": 40.36,
      "time_str": "00:40.360",
      "text": "照らすビビットな",
      "translation": "照耀着涡动"
    },
    {
      "time": 42.0,
      "time_str": "00:42.000",
      "text": "Sky",
      "translation": "天空上"
    },
    {
      "time": 42.97,
      "time_str": "00:42.970",
      "text": "いつもと違うにおいの",
      "translation": "有平常不同的气味"
    },
    {
      "time": 45.38,
      "time_str": "00:45.380",
      "text": "風吹き抜けて",
      "translation": "一丝微风吹过"
    },
    {
      "time": 47.28,
      "time_str": "00:47.280",
      "text": "背筋しゃんと伸ばした",
      "translation": "伸个懒腰"
    },
    {
      "time": 49.68,
      "time_str": "00:49.680",
      "text": "その分だけ",
      "translation": "只有那一部分"
    },
    {
      "time": 52.02,
      "time_str": "00:52.020",
      "text": "なんだか いい事が",
      "translation": "总是觉得有好事要发生"
    },
    {
      "time": 54.38,
      "time_str": "00:54.380",
      "text": "ありそうだよね",
      "translation": "好像是有的呢"
    },
    {
      "time": 56.4,
      "time_str": "00:56.400",
      "text": "Sunshine Girl (shine girl)",
      "translation": "阳光女孩（阳光女孩）"
    },
    {
