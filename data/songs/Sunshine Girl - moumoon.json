    {
      "time": 10.04,
      "time_str": "00:10.040",
      "text": "キラキラ 陽差しを浴びて",
      "translation": "沐浴着闪闪发亮的阳光"
    },
    {
      "time": 12.4,
      "time_str": "00:12.400",
      "text": "Make up, and dressed",
      "translation": "先化妆然后穿好衣服"
    },
    {
      "time": 13.3,
      "time_str": "00:13.300",
      "text": "Are you ready to go?",
      "translation": "你准备出发了吗？"
    },
    {
      "time": 14.72,
      "time_str": "00:14.720",
      "text": "Weather is great, it's your holiday",
      "translation": "天气这么好在你的假期里"
    },
    {
      "time": 16.99,
      "time_str": "00:16.990",
      "text": "We gotta party all day long",
      "translation": "我们必须开心一整天"
    },
    {
      "time": 19.43,
      "time_str": "00:19.430",
      "text": "Happy day Summer day",
      "translation": "快乐的夏日节"
    },
    {
      "time": 21.17,
      "time_str": "00:21.170",
      "text": "Sunshine Girl",
      "translation": "阳光活泼的女孩"
    },
    {
      "time": 23.15,
      "time_str": "00:23.150",
      "text": "I like it, Happy day Summer day",
      "translation": "我喜欢它，开心的夏日节"
    },
    {
      "time": 25.77,
      "time_str": "00:25.770",
      "text": "Sun shines for you",
      "translation": "太阳会照耀着你"
    },
    {
      "time": 28.7,
      "time_str": "00:28.700",
      "text": "Happy day Summer day",
      "translation": "美好的夏日节"
