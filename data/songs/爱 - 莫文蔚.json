      "time": 13.18,
      "time_str": "00:13.180",
      "text": "你还记得吗 记忆的炎夏",
      "translation": null
    },
    {
      "time": 19.42,
      "time_str": "00:19.420",
      "text": "散落在风中的已蒸发",
      "translation": null
    },
    {
      "time": 21.94,
      "time_str": "00:21.940",
      "text": "喧哗的都已沙哑",
      "translation": null
    },
    {
      "time": 26.12,
      "time_str": "00:26.120",
      "text": "没结果的花 未完成的牵挂",
      "translation": null
    },
    {
      "time": 32.82,
      "time_str": "00:32.820",
      "text": "我们学会许多说法",
      "translation": null
    },
    {
      "time": 34.86,
      "time_str": "00:34.860",
      "text": "来掩饰不碰的伤疤",
