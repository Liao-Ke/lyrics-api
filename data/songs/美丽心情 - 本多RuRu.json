    {
      "time": 30.04,
      "time_str": "00:30.040",
      "text": "多雨的冬季 总算过去",
      "translation": null
    },
    {
      "time": 35.71,
      "time_str": "00:35.710",
      "text": "天空微露淡蓝的晴",
      "translation": null
    },
    {
      "time": 41.77,
      "time_str": "00:41.770",
      "text": "我在早春清新的阳光里",
      "translation": null
    },
    {
      "time": 47.63,
      "time_str": "00:47.630",
      "text": "看着当时写的日记",
      "translation": null
    },
    {
      "time": 53.5,
      "time_str": "00:53.500",
      "text": "原来爱 曾给我美丽心情",
      "translation": null
    },
    {
      "time": 59.32,
      "time_str": "00:59.320",
      "text": "像一面深遂的风景",
      "translation": null
    },
    {
      "time": 65.18,
      "time_str": "01:05.180",
      "text": "那深爱过他 却受伤的心",
      "translation": null
    },
    {
      "time": 71.14,
      "time_str": "01:11.140",
      "text": "丰富了 人生的记忆",
      "translation": null
    },
    {
      "time": 76.94,
      "time_str": "01:16.940",
      "text": "只有曾 天真给过的心",
      "translation": null
    },
    {
      "time": 83.29,
      "time_str": "01:23.290",
      "text": "才了解 等待中的甜蜜",
      "translation": null
    },
    {
      "time": 88.65,
      "time_str": "01:28.650",
      "text": "也只有被 辜负而长夜流过泪的心",
      "translation": null
    },
    {
      "time": 95.32,
      "time_str": "01:35.320",
      "text": "才能明白这也是种运气",
      "translation": null
    },
    {
      "time": 100.62,
      "time_str": "01:40.620",
      "text": "让他永远 记得曾经有一个人",
      "translation": null
    },
    {
      "time": 106.68,
      "time_str": "01:46.680",
      "text": "给过完完整整的爱情",
      "translation": null
    },
    {
