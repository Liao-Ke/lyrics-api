{
  "title": "披着羊皮的狼",
  "title_raw": "披着羊皮的狼",
  "version": null,
  "artist": "谭咏麟",
  "group_key": "披着羊皮的狼|谭咏麟",
  "writers": {
    "lyricist": "刀郎",
