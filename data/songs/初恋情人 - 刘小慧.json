    {
      "time": 38.682,
      "time_str": "00:38.682",
      "text": "当你要走的某天",
      "translation": null
    },
    {
      "time": 41.534,
      "time_str": "00:41.534",
      "text": "请不必慰问",
      "translation": null
    },
    {
      "time": 43.449,
      "time_str": "00:43.449",
      "text": "常道初恋终必分手 总会变心",
      "translation": null
    },
    {
      "time": 47.864,
      "time_str": "00:47.864",
      "text": "当你要走的某天",
      "translation": null
    },
    {
      "time": 50.72,
      "time_str": "00:50.720",
      "text": "也不必抱憾",
      "translation": null
    },
    {
      "time": 52.675,
      "time_str": "00:52.675",
      "text": "让我他朝好好追忆 哪需遗憾",
      "translation": null
    },
    {
      "time": 57.511,
      "time_str": "00:57.511",
      "text": "爱 永远有些缺憾",
      "translation": null
    },
    {
      "time": 62.18,
      "time_str": "01:02.180",
      "text": "不必找出那原因",
      "translation": null
    },
    {
      "time": 66.723,
      "time_str": "01:06.723",
      "text": "爱 永远有些悔恨",
      "translation": null
    },
    {
      "time": 71.267,
      "time_str": "01:11.267",
      "text": "可知相识也是缘分",
      "translation": null
    },
    {
      "time": 78.136,
      "time_str": "01:18.136",
      "text": "何妨让我依靠在你身边",
      "translation": null
    },
    {
      "time": 82.719,
      "time_str": "01:22.719",
      "text": "缠绵梦里 痴心永远",
      "translation": null
    },
    {
      "time": 87.371,
      "time_str": "01:27.371",
      "text": "明晨若要分手 带走伤感",
      "translation": null
    },
    {
      "time": 91.883,
      "time_str": "01:31.883",
      "text": "无谓让这初恋留恨",
      "translation": null
    },
    {
      "time": 96.465,
      "time_str": "01:36.465",
      "text": "何妨让你依靠在我的心",
      "translation": null
    },
    {
