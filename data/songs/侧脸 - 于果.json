  "lyrics": [
    {
      "time": 1.188,
      "time_str": "00:01.188",
      "text": "母带 : 刘天鸿",
      "translation": null
    },
    {
      "time": 15.06,
      "time_str": "00:15.060",
      "text": "秋天里的落叶挥手同树道别",
      "translation": null
    },
    {
      "time": 22.55,
      "time_str": "00:22.550",
      "text": "关于你的一切我都想要了解",
      "translation": null
    },
    {
      "time": 29.96,
      "time_str": "00:29.960",
      "text": "陪伴三个季节还是承受决裂",
      "translation": null
    },
    {
      "time": 37.32,
      "time_str": "00:37.320",
      "text": "最后一句感谢还有多余的抱歉",
      "translation": null
    },
    {
      "time": 43.76,
      "time_str": "00:43.760",
      "text": "奔跑在街上大雨淋湿的视线",
      "translation": null
    },
    {
      "time": 48.43,
      "time_str": "00:48.430",
      "text": "反反复复地自我欺骗",
      "translation": null
    },
    {
      "time": 52.46,
      "time_str": "00:52.460",
      "text": "再分开在之前",
      "translation": null
    },
    {
      "time": 56.25,
      "time_str": "00:56.250",
      "text": "没有勇气想得更远",
      "translation": null
    },
    {
      "time": 59.95,
      "time_str": "00:59.950",
      "text": "黄昏下模糊的侧脸",
      "translation": null
    },
    {
      "time": 63.779,
      "time_str": "01:03.779",
      "text": "遗忘了伤痛的少年",
      "translation": null
    },
    {
      "time": 67.308,
      "time_str": "01:07.308",
      "text": "有风险才蜕变",
      "translation": null
    },
    {
      "time": 70.959,
      "time_str": "01:10.959",
      "text": "时间总会说出再见",
      "translation": null
    },
    {
      "time": 74.668,
      "time_str": "01:14.668",
      "text": "曾经是心心念念随随便便深深浅浅",
      "translation": null
    },
    {
      "time": 78.129,
      "time_str": "01:18.129",
      "text": "爱上了不语不言不计前嫌不知疲倦",
      "translation": null
    },
    {
      "time": 81.84,
      "time_str": "01:21.840",
      "text": "向后向前遇见改变",
      "translation": null
    },
    {
      "time": 85.01,
      "time_str": "01:25.010",
      "text": "那残破的碎片",
      "translation": null
    },
    {
      "time": 89.31,
      "time_str": "01:29.310",
      "text": "我知道从一开始随随便便深深浅浅",
      "translation": null
    },
    {
      "time": 92.849,
      "time_str": "01:32.849",
      "text": "不过是爱的自由不计前嫌不知疲倦",
      "translation": null
    },
    {
      "time": 96.578,
      "time_str": "01:36.578",
      "text": "永远太远走远遥远",
      "translation": null
    },
    {
      "time": 99.578,
      "time_str": "01:39.578",
      "text": "放开不再拖欠oh",
