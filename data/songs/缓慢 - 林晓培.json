  "lyrics": [
    {
      "time": 18.54,
      "time_str": "00:18.540",
      "text": "一双铁翅膀",
      "translation": null
    },
    {
      "time": 22.28,
      "time_str": "00:22.280",
      "text": "送我到这地方",
      "translation": null
    },
    {
      "time": 26.0,
      "time_str": "00:26.000",
      "text": "天快亮 舍不得这机场",
      "translation": null
    },
    {
      "time": 32.78,
      "time_str": "00:32.780",
      "text": "缓慢的游荡",
      "translation": null
    },
    {
      "time": 35.28,
      "time_str": "00:35.280",
      "text": "在拥挤的机场",
      "translation": null
    },
    {
      "time": 38.34,
      "time_str": "00:38.340",
      "text": "风一样",
      "translation": null
    },
    {
      "time": 44.4,
      "time_str": "00:44.400",
      "text": "多少荧光屏",
      "translation": null
    },
    {
      "time": 47.74,
      "time_str": "00:47.740",
      "text": "总是闪烁不定",
      "translation": null
    },
    {
      "time": 51.43,
      "time_str": "00:51.430",
      "text": "天与地",
      "translation": null
    },
    {
      "time": 54.51,
      "time_str": "00:54.510",
      "text": "在中间它来临",
      "translation": null
    },
    {
      "time": 57.48,
      "time_str": "00:57.480",
      "text": "缓慢的飞机",
      "translation": null
    },
    {
      "time": 60.77,
      "time_str": "01:00.770",
      "text": "有否我期待的",
      "translation": null
    },
    {
      "time": 64.18,
      "time_str": "01:04.180",
      "text": "一个你",
      "translation": null
    },
    {
      "time": 71.5,
      "time_str": "01:11.500",
      "text": "忘记你说你会继续",
      "translation": null
    },
    {
      "time": 76.06,
      "time_str": "01:16.060",
      "text": "还是要结束",
      "translation": null
    },
    {
      "time": 78.82,
      "time_str": "01:18.820",
      "text": "分开时只管哭",
      "translation": null
    },
    {
      "time": 82.12,
      "time_str": "01:22.120",
      "text": "我是否太迷糊",
      "translation": null
    },
    {
      "time": 85.3,
      "time_str": "01:25.300",
      "text": "你是否仍在乎",
      "translation": null
    },
    {
      "time": 91.74,
      "time_str": "01:31.740",
      "text": "等的太久不想继续",
      "translation": null
    },
    {
      "time": 95.53,
      "time_str": "01:35.530",
      "text": "也不愿结束",
      "translation": null
    },
    {
      "time": 98.34,
      "time_str": "01:38.340",
      "text": "分开时我走出",
      "translation": null
    },
    {
      "time": 101.53,
      "time_str": "01:41.530",
      "text": "最遥远的旅途",
      "translation": null
    },
    {
      "time": 105.1,
      "time_str": "01:45.100",
      "text": "最缓慢的脚步",
      "translation": null
    },
    {
      "time": 125.61,
      "time_str": "02:05.610",
      "text": "一杯热咖啡",
      "translation": null
    },
    {
      "time": 129.46,
      "time_str": "02:09.460",
      "text": "抵不住我的泪",
      "translation": null
    },
    {
      "time": 132.87,
      "time_str": "02:12.870",
      "text": "他是谁",
      "translation": null
    },
    {
      "time": 135.63,
      "time_str": "02:15.630",
      "text": "在拥抱的是谁",
      "translation": null
    },
    {
