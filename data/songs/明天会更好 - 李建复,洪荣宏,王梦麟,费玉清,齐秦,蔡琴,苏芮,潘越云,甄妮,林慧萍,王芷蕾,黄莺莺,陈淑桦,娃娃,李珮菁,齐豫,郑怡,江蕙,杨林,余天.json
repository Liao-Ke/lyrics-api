    {
      "time": 25.1,
      "time_str": "00:25.100",
      "text": "蔡 琴：轻轻敲醒沉睡的心灵",
      "translation": null
    },
    {
      "time": 29.6,
      "time_str": "00:29.600",
      "text": "蔡 琴：慢慢张开你的眼睛",
      "translation": null
    },
    {
      "time": 32.1,
      "time_str": "00:32.100",
      "text": "余 天：看看忙碌的世界",
      "translation": null
    },
    {
      "time": 35.0,
      "time_str": "00:35.000",
      "text": "余 天：是否依然孤独地转个不停",
      "translation": null
    },
    {
      "time": 39.05,
      "time_str": "00:39.050",
      "text": "苏 芮：春风不解风情 吹动少年的心",
      "translation": null
    },
    {
      "time": 45.05,
      "time_str": "00:45.050",
      "text": "潘越云：让昨日脸上的泪痕 随记忆风干了",
      "translation": null
    },
    {
      "time": 53.38,
      "time_str": "00:53.380",
      "text": "甄 妮：抬头寻找天空的翅膀",
      "translation": null
