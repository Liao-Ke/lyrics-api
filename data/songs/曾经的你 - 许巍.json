  "lyrics": [
    {
      "time": 10.57,
      "time_str": "00:10.570",
      "text": "曾梦想仗剑走天涯",
      "translation": null
    },
    {
      "time": 15.65,
      "time_str": "00:15.650",
      "text": "看一看世界的繁华",
      "translation": null
    },
    {
      "time": 20.53,
      "time_str": "00:20.530",
      "text": "年少的心总有些轻狂",
      "translation": null
    },
    {
      "time": 25.61,
      "time_str": "00:25.610",
      "text": "如今你四海为家",
      "translation": null
    },
    {
      "time": 30.77,
      "time_str": "00:30.770",
      "text": "曾让你心疼的姑娘",
      "translation": null
    },
    {
      "time": 35.85,
      "time_str": "00:35.850",
      "text": "如今已悄然无踪影",
      "translation": null
    },
    {
      "time": 40.78,
      "time_str": "00:40.780",
      "text": "爱情总让你渴望又感到烦恼",
      "translation": null
    },
    {
      "time": 45.95,
      "time_str": "00:45.950",
      "text": "曾让你遍体鳞伤",
      "translation": null
    },
    {
      "time": 50.81,
      "time_str": "00:50.810",
      "text": "DiLiLi……",
      "translation": null
    },
    {
      "time": 65.239,
      "time_str": "01:05.239",
      "text": "走在勇往直前的路上",
      "translation": null
    },
    {
      "time": 70.92,
      "time_str": "01:10.920",
      "text": "DiLiLi……",
      "translation": null
    },
    {
      "time": 85.39,
      "time_str": "01:25.390",
      "text": "有难过也有精彩",
      "translation": null
    },
    {
      "time": 110.99,
      "time_str": "01:50.990",
      "text": "每一次难过的时候",
      "translation": null
    },
    {
      "time": 116.83,
      "time_str": "01:56.830",
      "text": "就独自看一看大海",
      "translation": null
    },
    {
      "time": 121.67,
      "time_str": "02:01.670",
      "text": "总想起身边走在路上的朋友",
      "translation": null
    },
    {
      "time": 126.72,
      "time_str": "02:06.720",
      "text": "有多少正在疗伤",
      "translation": null
    },
    {
      "time": 131.74,
      "time_str": "02:11.740",
      "text": "DiLiLi……",
      "translation": null
    },
    {
      "time": 146.17,
      "time_str": "02:26.170",
      "text": "不知多少孤独的夜晚",
      "translation": null
    },
    {
      "time": 151.24,
      "time_str": "02:31.240",
      "text": "DiLiLi……",
      "translation": null
    },
    {
      "time": 166.15,
