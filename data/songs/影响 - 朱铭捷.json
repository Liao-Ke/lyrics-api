  "lyrics": [
    {
      "time": 24.29,
      "time_str": "00:24.290",
      "text": "听说相爱的磁场",
      "translation": null
    },
    {
      "time": 27.65,
      "time_str": "00:27.650",
      "text": "有一种神秘的影响",
      "translation": null
    },
    {
      "time": 33.59,
      "time_str": "00:33.590",
      "text": "交换呼吸的波长",
      "translation": null
    },
    {
      "time": 36.83,
      "time_str": "00:36.830",
      "text": "蔓延成心跳的渴望",
      "translation": null
    },
    {
      "time": 42.8,
      "time_str": "00:42.800",
      "text": "在孤单的地平线上",
      "translation": null
    },
    {
      "time": 46.44,
      "time_str": "00:46.440",
      "text": "你是我第一道曙光",
      "translation": null
    },
    {
      "time": 51.14,
      "time_str": "00:51.140",
      "text": "仿佛看透我思量解我心肠",
      "translation": null
    },
    {
      "time": 56.77,
      "time_str": "00:56.770",
      "text": "指引我朝你的方向",
      "translation": null
    },
    {
      "time": 59.92,
      "time_str": "00:59.920",
      "text": "像海浪一样被天上月亮影响",
      "translation": null
    },
    {
      "time": 64.77,
      "time_str": "01:04.770",
      "text": "跑累了想要停靠沙滩上狂想",
      "translation": null
    },
    {
      "time": 69.49,
      "time_str": "01:09.490",
      "text": "我常想是否就是这样被你影响",
      "translation": null
    },
    {
      "time": 74.24,
      "time_str": "01:14.240",
      "text": "我以后的梦想不再是远方",
      "translation": null
    },
    {
      "time": 79.47,
      "time_str": "01:19.470",
      "text": "像鸟儿一样被夕阳西下影响",
      "translation": null
    },
    {
      "time": 83.31,
      "time_str": "01:23.310",
      "text": "忍不住栖向那一片温暖金黄",
      "translation": null
    },
    {
      "time": 88.44,
      "time_str": "01:28.440",
      "text": "我喜欢像个孩子一样被你影响",
      "translation": null
    },
    {
      "time": 93.19,
      "time_str": "01:33.190",
      "text": "我的心从此托你好意收藏",
      "translation": null
    },
