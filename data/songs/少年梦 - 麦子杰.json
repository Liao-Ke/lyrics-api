  "lyrics": [
    {
      "time": 13.46,
      "time_str": "00:13.460",
      "text": "阳光灿烂的日子",
      "translation": null
    },
    {
      "time": 16.46,
      "time_str": "00:16.460",
      "text": "少年要珍惜",
      "translation": null
    },
    {
      "time": 19.15,
      "time_str": "00:19.150",
      "text": "不要再犹豫",
      "translation": null
    },
    {
      "time": 20.98,
      "time_str": "00:20.980",
      "text": "不要再迟疑",
      "translation": null
    },
    {
      "time": 22.53,
      "time_str": "00:22.530",
      "text": "应该把成功握手里",
      "translation": null
    },
    {
      "time": 25.78,
      "time_str": "00:25.780",
      "text": "人生追逐是名利",
      "translation": null
    },
    {
      "time": 28.53,
      "time_str": "00:28.530",
      "text": "总有些要放弃",
      "translation": null
    },
    {
      "time": 31.15,
      "time_str": "00:31.150",
      "text": "悲哀要忘记",
      "translation": null
    },
    {
      "time": 33.04,
      "time_str": "00:33.040",
      "text": "失败要忘记",
      "translation": null
    },
    {
      "time": 34.54,
      "time_str": "00:34.540",
      "text": "一定要胜自己",
      "translation": null
    },
    {
      "time": 37.18,
      "time_str": "00:37.180",
      "text": "生活本来就该多姿多彩",
      "translation": null
    },
    {
      "time": 40.55,
      "time_str": "00:40.550",
      "text": "幸福需要自己的努力",
      "translation": null
    },
    {
      "time": 43.58,
      "time_str": "00:43.580",
      "text": "走遍东南西北经过四季",
      "translation": null
    },
    {
      "time": 46.38,
      "time_str": "00:46.380",
      "text": "多少坎坷你别在意",
      "translation": null
    },
    {
      "time": 49.13,
      "time_str": "00:49.130",
      "text": "生活本来就该多姿多彩",
      "translation": null
    },
    {
      "time": 52.56,
      "time_str": "00:52.560",
      "text": "精采的日子在等待你",
      "translation": null
    },
    {
      "time": 55.53,
      "time_str": "00:55.530",
      "text": "那光辉岁月得来不会容易",
      "translation": null
    },
    {
      "time": 58.54,
      "time_str": "00:58.540",
      "text": "别忘了最美的花开放在春季",
      "translation": null
    },
