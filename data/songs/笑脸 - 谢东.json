    {
      "time": 18.199,
      "time_str": "00:18.199",
      "text": "常常地想",
      "translation": null
    },
    {
      "time": 20.459,
      "time_str": "00:20.459",
      "text": "现在的你",
      "translation": null
    },
    {
      "time": 22.309,
      "time_str": "00:22.309",
      "text": "就在我身边露出笑脸",
      "translation": null
    },
    {
      "time": 26.889,
      "time_str": "00:26.889",
      "text": "可是可是我  却搞不清",
      "translation": null
    },
    {
      "time": 30.88,
      "time_str": "00:30.880",
      "text": "你离我是近还是远",
      "translation": null
    },
    {
      "time": 35.4,
      "time_str": "00:35.400",
      "text": "但我仍然  仍然相信",
      "translation": null
    },
    {
      "time": 39.23,
      "time_str": "00:39.230",
      "text": "你和我今生一定有缘",
      "translation": null
    },
    {
      "time": 44.2,
      "time_str": "00:44.200",
      "text": "于是我就让  你看看我",
      "translation": null
    },
    {
      "time": 48.59,
      "time_str": "00:48.590",
      "text": "一往情深的双眼",
      "translation": null
    },
    {
      "time": 53.96,
      "time_str": "00:53.960",
      "text": "书上说有情人千里能共婵娟",
      "translation": null
    },
    {
      "time": 58.1,
      "time_str": "00:58.100",
      "text": "可是我现在只想把你手儿牵",
      "translation": null
    },
    {
      "time": 62.8,
      "time_str": "01:02.800",
      "text": "听说过许多山盟海誓的表演",
      "translation": null
    },
    {
      "time": 66.57,
      "time_str": "01:06.570",
      "text": "突然想看看你曾经纯真的笑脸",
      "translation": null
