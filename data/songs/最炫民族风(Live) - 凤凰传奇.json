  "lyrics": [
    {
      "time": 22.6,
      "time_str": "00:22.600",
      "text": "苍茫的天涯是我的爱",
      "translation": null
    },
    {
      "time": 26.28,
      "time_str": "00:26.280",
      "text": "绵绵的青山脚下花正开",
      "translation": null
    },
    {
      "time": 30.13,
      "time_str": "00:30.130",
      "text": "什么样的节奏是最呀最摇摆",
      "translation": null
    },
    {
      "time": 33.88,
      "time_str": "00:33.880",
      "text": "什么样的歌声才是最开怀",
      "translation": null
    },
    {
      "time": 37.75,
      "time_str": "00:37.750",
      "text": "弯弯的河水从天上来",
      "translation": null
    },
    {
      "time": 41.31,
      "time_str": "00:41.310",
      "text": "流向那万紫千红一片海",
      "translation": null
    },
    {
      "time": 45.33,
      "time_str": "00:45.330",
      "text": "火辣辣的歌谣是我们的期待",
      "translation": null
    },
    {
      "time": 48.88,
      "time_str": "00:48.880",
      "text": "一路边走边唱才是最自在",
      "translation": null
    },
    {
      "time": 52.63,
      "time_str": "00:52.630",
      "text": "我们要唱就要唱得最痛快",
      "translation": null
    },
    {
      "time": 56.61,
      "time_str": "00:56.610",
      "text": "你是我天边最美的云彩",
      "translation": null
    },
    {
      "time": 60.28,
      "time_str": "01:00.280",
      "text": "让我用心把你留下来（留下来）",
      "translation": null
    },
    {
      "time": 64.34,
      "time_str": "01:04.340",
      "text": "悠悠的唱着最炫的民族风",
      "translation": null
    },
    {
      "time": 67.84,
      "time_str": "01:07.840",
      "text": "让爱卷走所有的尘埃",
      "translation": null
    },
    {
      "time": 70.47,
      "time_str": "01:10.470",
      "text": "（我知道）你是我心中最美的云彩",
      "translation": null
    },
    {
      "time": 75.38,
      "time_str": "01:15.380",
      "text": "斟满美酒让你留下来（留下来）",
      "translation": null
    },
    {
