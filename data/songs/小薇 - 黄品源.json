  "lyrics": [
    {
      "time": 27.99,
      "time_str": "00:27.990",
      "text": "有一个美丽的小女孩",
      "translation": null
    },
    {
      "time": 33.749,
      "time_str": "00:33.749",
      "text": "她的名字叫做小薇",
      "translation": null
    },
    {
      "time": 40.4,
      "time_str": "00:40.400",
      "text": "她有双温柔的眼睛",
      "translation": null
    },
    {
      "time": 45.619,
      "time_str": "00:45.619",
      "text": "她悄悄偷走我的心",
      "translation": null
    },
    {
      "time": 52.579,
      "time_str": "00:52.579",
      "text": "小薇啊",
      "translation": null
    },
    {
      "time": 54.449,
      "time_str": "00:54.449",
      "text": "你可知道我多爱你",
      "translation": null
    },
    {
      "time": 58.599,
      "time_str": "00:58.599",
      "text": "我要带你飞到天上去",
      "translation": null
    },
    {
      "time": 64.279,
      "time_str": "01:04.279",
      "text": "看那星星多美丽",
      "translation": null
    },
    {
      "time": 68.12,
      "time_str": "01:08.120",
      "text": "摘下一颗亲手送给你",
      "translation": null
