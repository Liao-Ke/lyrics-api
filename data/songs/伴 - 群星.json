    {
      "time": 29.29,
      "time_str": "00:29.290",
      "text": "我想我 还是会 把手让你紧握",
      "translation": null
    },
    {
      "time": 36.65,
      "time_str": "00:36.650",
      "text": "快乐地陪你去坎坷",
