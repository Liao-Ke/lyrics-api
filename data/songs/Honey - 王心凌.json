      "text": "Honey　Honey",
      "translation": null
    },
    {
      "time": 24.414,
      "time_str": "00:24.414",
      "text": "Honey　Honey",
      "translation": null
    },
    {
      "time": 34.137,
      "time_str": "00:34.137",
      "text": "Honey　你把爱放进我的心里",
      "translation": null
    },
    {
      "time": 39.591,
      "time_str": "00:39.591",
      "text": "关上耳朵我用心在听　你用爱为我打造贴身耳机",
      "translation": null
    },
    {
      "time": 47.679,
      "time_str": "00:47.679",
      "text": "Honey　保持神秘你还是猜中我的心",
      "translation": null
    },
    {
      "time": 53.697,
      "time_str": "00:53.697",
      "text": "播放我的心情　满满六颗心",
      "translation": null
    },
    {
      "time": 60.121,
      "time_str": "01:00.121",
      "text": "往心里微笑　哭泣　放心会有你",
      "translation": null
    },
    {
      "time": 67.388,
      "time_str": "01:07.388",
      "text": "贴着心贴得好近　每分钟零距离",
      "translation": null
    },
    {
      "time": 73.314,
      "time_str": "01:13.314",
      "text": "点一首歌给Honey　甜言蜜语",
      "translation": null
    },
    {
      "time": 76.632,
      "time_str": "01:16.632",
      "text": "隔空传递加上超多表情　更新彼此最新的秘密",
      "translation": null
    },
    {
      "time": 82.775,
      "time_str": "01:22.775",
      "text": "爱要随身听　随时感应",
      "translation": null
    },
    {
      "time": 86.781,
      "time_str": "01:26.781",
      "text": "多喜欢你叫Honey　甜言蜜语",
      "translation": null
    },
    {
      "time": 90.183,
      "time_str": "01:30.183",
      "text": "在往心里爱你 .com 写日记",
      "translation": null
    },
    {
