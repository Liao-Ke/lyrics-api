  "lyrics": [
    {
      "time": 14.95,
      "time_str": "00:14.950",
      "text": "你说",
      "translation": null
    },
    {
      "time": 17.32,
      "time_str": "00:17.320",
      "text": "我冷得像水仙",
      "translation": null
    },
    {
      "time": 22.04,
      "time_str": "00:22.040",
      "text": "冬天才看到我的笑脸",
      "translation": null
    },
    {
      "time": 29.15,
      "time_str": "00:29.150",
      "text": "你说",
      "translation": null
    },
    {
      "time": 31.52,
      "time_str": "00:31.520",
      "text": "我在等一个寓言",
      "translation": null
    },
    {
      "time": 35.89,
      "time_str": "00:35.890",
      "text": "却永远不能够",
      "translation": null
    },
    {
      "time": 38.51,
      "time_str": "00:38.510",
      "text": "不能够实现",
      "translation": null
    },
    {
      "time": 43.38,
      "time_str": "00:43.380",
      "text": "要为你改变",
      "translation": null
    },
    {
      "time": 47.31,
      "time_str": "00:47.310",
      "text": "盛开在夏天",
      "translation": null
    },
    {
      "time": 49.87,
      "time_str": "00:49.870",
      "text": "别忘了我就是水仙",
      "translation": null
    },
    {
      "time": 53.42,
      "time_str": "00:53.420",
      "text": "白雪映出了",
      "translation": null
    },
    {
      "time": 55.67,
      "time_str": "00:55.670",
      "text": "我的春天",
      "translation": null
    },
    {
      "time": 60.47,
      "time_str": "01:00.470",
      "text": "盛开在冬天的水仙",
      "translation": null
    },
    {
      "time": 64.28,
      "time_str": "01:04.280",
      "text": "你是否闻得到我的娇艳",
      "translation": null
    },
    {
      "time": 67.84,
      "time_str": "01:07.840",
      "text": "如果你给我一双舞鞋",
      "translation": null
    },
    {
      "time": 71.35,
      "time_str": "01:11.350",
      "text": "我就会为你长袖翩翩",
      "translation": null
    },
    {
      "time": 75.18,
      "time_str": "01:15.180",
      "text": "如果你看穿我的思念",
      "translation": null
    },
    {
      "time": 78.43,
      "time_str": "01:18.430",
      "text": "我就不会为你哭红双眼",
      "translation": null
    },
    {
      "time": 82.08,
      "time_str": "01:22.080",
      "text": "如果我能戒掉了思念",
      "translation": null
    },
    {
      "time": 85.57,
      "time_str": "01:25.570",
      "text": "就不会开在你的窗前",
      "translation": null
    },
    {
