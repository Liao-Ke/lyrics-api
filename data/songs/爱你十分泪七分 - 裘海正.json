  "lyrics": [
    {
      "time": 24.81,
      "time_str": "00:24.810",
      "text": "昨天的我们",
      "translation": null
    },
    {
      "time": 28.36,
      "time_str": "00:28.360",
      "text": "感觉依然那么真",
      "translation": null
    },
    {
      "time": 32.48,
      "time_str": "00:32.480",
      "text": "今天的眼神",
      "translation": null
    },
    {
      "time": 35.53,
      "time_str": "00:35.530",
      "text": "它已经有一点不诚恳",
      "translation": null
    },
    {
      "time": 40.96,
      "time_str": "00:40.960",
      "text": "我沉醉那么深",
      "translation": null
    },
    {
      "time": 44.37,
      "time_str": "00:44.370",
      "text": "比谁对你都还认真",
      "translation": null
    },
    {
      "time": 47.31,
      "time_str": "00:47.310",
      "text": "为何你对我不再心疼",
      "translation": null
    },
    {
      "time": 51.42,
      "time_str": "00:51.420",
      "text": "从信任到容忍",
      "translation": null
    },
    {
      "time": 57.16,
      "time_str": "00:57.160",
      "text": "今天的你们",
      "translation": null
    },
    {
      "time": 60.51,
      "time_str": "01:00.510",
      "text": "听说已经是情人",
      "translation": null
    },
    {
      "time": 64.83,
      "time_str": "01:04.830",
      "text": "我不想追问",
      "translation": null
    },
    {
      "time": 67.88,
      "time_str": "01:07.880",
      "text": "因为我相信你有分寸",
      "translation": null
    },
    {
      "time": 73.37,
      "time_str": "01:13.370",
      "text": "你吻过我的唇",
      "translation": null
    },
    {
      "time": 76.72,
      "time_str": "01:16.720",
      "text": "说过伴我一世一生",
      "translation": null
    },
    {
      "time": 79.57,
      "time_str": "01:19.570",
      "text": "只怪时间冲淡了缘份",
      "translation": null
    },
    {
      "time": 83.83,
      "time_str": "01:23.830",
      "text": "空留一些余温",
      "translation": null
    },
    {
      "time": 86.68,
      "time_str": "01:26.680",
      "text": "忍心让我爱你十分泪七分",
      "translation": null
    },
    {
      "time": 91.45,
      "time_str": "01:31.450",
      "text": "你却毫无眷恋地转身",
      "translation": null
    },
    {
      "time": 95.26,
      "time_str": "01:35.260",
      "text": "不能爱也不敢恨",
      "translation": null
    },
    {
      "time": 99.12,
      "time_str": "01:39.120",
      "text": "无法平息的伤痕",
      "translation": null
    },
    {
      "time": 101.96,
      "time_str": "01:41.960",
      "text": "冷眼看我爱你十分泪七分",
      "translation": null
    },
    {
      "time": 106.74,
      "time_str": "01:46.740",
      "text": "从此离分不再有温存",
      "translation": null
    },
    {
      "time": 110.44,
      "time_str": "01:50.440",
      "text": "谁能爱你比我深",
      "translation": null
    },
    {
      "time": 114.3,
      "time_str": "01:54.300",
      "text": "感情不能两头分",
      "translation": null
    },
