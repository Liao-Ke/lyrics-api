      "time": 14.82,
      "time_str": "00:14.820",
      "text": "我在清晨的路上",
      "translation": null
    },
    {
      "time": 18.92,
      "time_str": "00:18.920",
      "text": "谁被我遗忘",
      "translation": null
    },
    {
      "time": 26.85,
      "time_str": "00:26.850",
      "text": "我在深夜里旅行",
      "translation": null
    },
    {
      "time": 30.84,
      "time_str": "00:30.840",
      "text": "谁被我遗忘",
      "translation": null
    },
    {
      "time": 37.62,
      "time_str": "00:37.620",
      "text": "肩上的破旧行囊",
      "translation": null
    },
    {
      "time": 43.54,
      "time_str": "00:43.540",
      "text": "能收藏多少坚强",
      "translation": null
    },
    {
      "time": 49.64,
      "time_str": "00:49.640",
      "text": "不如全身赤裸",
      "translation": null
    },
    {
      "time": 53.4,
      "time_str": "00:53.400",
      "text": "还给我那脆弱",
      "translation": null
    },
    {
      "time": 56.82,
      "time_str": "00:56.820",
      "text": "明知这是一场意外",
      "translation": null
    },
    {
      "time": 60.847,
      "time_str": "01:00.847",
      "text": "你要不要来",
      "translation": null
    },
    {
      "time": 68.796,
      "time_str": "01:08.796",
      "text": "明知这是一场重伤害",
      "translation": null
    },
    {
      "time": 72.876,
      "time_str": "01:12.876",
      "text": "你会不会来",
      "translation": null
    },
    {
      "time": 80.408,
      "time_str": "01:20.408",
      "text": "当疯狂慢慢从爱情离开",
