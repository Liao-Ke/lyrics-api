    {
      "time": 14.29,
      "time_str": "00:14.290",
      "text": "乌黑的发尾盘成一个圈",
      "translation": null
    },
    {
      "time": 17.79,
      "time_str": "00:17.790",
      "text": "缠绕所有对你的眷恋",
      "translation": null
    },
    {
      "time": 21.36,
      "time_str": "00:21.360",
      "text": "隔着半透明门帘",
      "translation": null
    },
    {
      "time": 23.28,
      "time_str": "00:23.280",
      "text": "嘴里说的语言完全没有欺骗",
      "translation": null
    },
    {
      "time": 28.77,
      "time_str": "00:28.770",
      "text": "屋顶灰色瓦片安静的画面",
      "translation": null
    },
    {
      "time": 32.36,
      "time_str": "00:32.360",
      "text": "灯火是你美丽那张脸",
      "translation": null
    },
    {
      "time": 36.3,
      "time_str": "00:36.300",
      "text": "终于找到所有流浪的终点",
      "translation": null
    },
    {
      "time": 40.9,
      "time_str": "00:40.900",
      "text": "你的微笑结束了疲倦",
      "translation": null
    },
    {
      "time": 45.9,
      "time_str": "00:45.900",
      "text": "千万不要说天长地久",
      "translation": null
    },
    {
      "time": 48.86,
      "time_str": "00:48.860",
      "text": "免的你觉得我不切实际",
      "translation": null
    },
    {
      "time": 52.35,
      "time_str": "00:52.350",
      "text": "想多么简单就多么简单",
      "translation": null
