      "time_str": "00:59.480",
      "text": "你在说什么",
      "translation": null
    },
    {
      "time": 61.12,
      "time_str": "01:01.120",
      "text": "只听一次也会记得",
      "translation": null
    },
    {
      "time": 65.16,
      "time_str": "01:05.160",
      "text": "听两次就火热",
