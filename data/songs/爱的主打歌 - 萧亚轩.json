    {
      "time": 70.39,
      "time_str": "01:10.390",
      "text": "整个城市播着爱的主打歌",
      "translation": null
    },
    {
      "time": 74.32,
      "time_str": "01:14.320",
      "text": "主的可是你",
      "translation": null
    },
    {
      "time": 77.08,
      "time_str": "01:17.080",
      "text": "打得我好神不守舍",
      "translation": null
    },
    {
      "time": 80.93,
      "time_str": "01:20.930",
      "text": "然后 不断想起你的",
      "translation": null
    },
    {
      "time": 85.53,
      "time_str": "01:25.530",
      "text": "一言一语 是指定旋律",
