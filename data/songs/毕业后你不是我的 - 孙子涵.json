  "lyrics": [
    {
      "time": 18.47,
      "time_str": "00:18.470",
      "text": "我离开了 拥有过 我们太多的故事的校舍",
      "translation": null
    },
    {
      "time": 25.72,
      "time_str": "00:25.720",
      "text": "一个人偷偷看着你们互相祝贺着",
      "translation": null
    },
    {
      "time": 34.28,
      "time_str": "00:34.280",
      "text": "我牵强的笑着 失败的人应该隐身的",
      "translation": null
    },
    {
      "time": 42.3,
      "time_str": "00:42.300",
      "text": "我知道这一刻主角不是我",
      "translation": null
    },
    {
      "time": 50.46,
      "time_str": "00:50.460",
      "text": "照样骑着车 载着你 走过了",
      "translation": null
    },
    {
      "time": 53.96,
      "time_str": "00:53.960",
      "text": "走了三年的街道",
      "translation": null
    },
    {
      "time": 57.75,
      "time_str": "00:57.750",
      "text": "你手里那录取通知书是红色的",
      "translation": null
    },
    {
      "time": 66.3,
      "time_str": "01:06.300",
      "text": "你故意的不说话 突然间气氛有一点尴尬",
      "translation": null
    },
    {
      "time": 74.15,
      "time_str": "01:14.150",
      "text": "我说想笑就笑吧考那么好为什么愁眉苦脸的",
      "translation": null
    },
    {
      "time": 81.78,
      "time_str": "01:21.780",
      "text": "毕业后 你不是我的",
      "translation": null
    },
    {
      "time": 84.57,
      "time_str": "01:24.570",
      "text": "钟声都响了 教室已经空了",
      "translation": null
    },
    {
      "time": 90.4,
      "time_str": "01:30.400",
      "text": "偷睡的书桌 看过的小说 它们都睡着了",
      "translation": null
    },
    {
      "time": 97.75,
      "time_str": "01:37.750",
      "text": "毕业后 你不是我的",
      "translation": null
    },
    {
      "time": 100.809,
      "time_str": "01:40.809",
      "text": "别再回头了 也该想想以后了",
      "translation": null
    },
    {
      "time": 106.14,
      "time_str": "01:46.140",
      "text": "我们的世界开始不完整",
      "translation": null
    },
    {
      "time": 110.72,
      "time_str": "01:50.720",
      "text": "再渐渐陌生 心隐隐疼",
      "translation": null
    },
    {
