    {
      "time": 35.52,
      "time_str": "00:35.520",
      "text": "如果真的有一种水",
      "translation": null
    },
    {
      "time": 37.54,
      "time_str": "00:37.540",
      "text": "可以让你让我喝了不会醉",
      "translation": null
    },
    {
      "time": 43.35,
      "time_str": "00:43.350",
      "text": "那么也许有一种泪",
      "translation": null
    },
    {
      "time": 45.19,
      "time_str": "00:45.190",
      "text": "可以让你让我流了不伤悲",
      "translation": null
    },
    {
      "time": 50.04,
      "time_str": "00:50.040",
      "text": "总是把爱看得太完美",
      "translation": null
    },
    {
      "time": 53.91,
      "time_str": "00:53.910",
      "text": "那种豪赌一场的感觉",
      "translation": null
    },
    {
      "time": 57.72,
      "time_str": "00:57.720",
      "text": "今生输了前世的诺言",
      "translation": null
    },
    {
      "time": 61.61,
      "time_str": "01:01.610",
      "text": "才发现水已悄悄泛成了泪",
      "translation": null
    },
    {
      "time": 65.9,
      "time_str": "01:05.900",
      "text": "虽然看不到听不到",
      "translation": null
    },
    {
      "time": 69.68,
      "time_str": "01:09.680",
      "text": "可是逃不掉忘不了",
      "translation": null
    },
    {
      "time": 73.58,
      "time_str": "01:13.580",
      "text": "就连枕边的你的发梢",
      "translation": null
    },
    {
      "time": 76.96,
      "time_str": "01:16.960",
      "text": "都变成了煎熬",
      "translation": null
    },
    {
      "time": 81.25,
      "time_str": "01:21.250",
      "text": "虽然你知道我知道",
      "translation": null
    },
    {
      "time": 85.09,
      "time_str": "01:25.090",
      "text": "可是泪在飘心在掏",
      "translation": null
    },
    {
      "time": 88.99,
      "time_str": "01:28.990",
      "text": "过了这一秒这一个笑",
      "translation": null
    },
    {
      "time": 92.32,
      "time_str": "01:32.320",
      "text": "喝下这碗解药",
