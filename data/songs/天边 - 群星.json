  "lyrics": [
    {
      "time": 0.67,
      "time_str": "00:00.670",
      "text": "天边 - 华语群星",
      "translation": null
    },
    {
      "time": 38.19,
      "time_str": "00:38.190",
      "text": "天边有一对双星",
      "translation": null
    },
    {
      "time": 45.86,
      "time_str": "00:45.860",
      "text": "那是我梦中的眼睛",
      "translation": null
    },
    {
      "time": 54.61,
      "time_str": "00:54.610",
      "text": "山中有一片晨雾",
      "translation": null
    },
    {
      "time": 62.67,
      "time_str": "01:02.670",
      "text": "那是你昨夜的柔情",
      "translation": null
    },
    {
      "time": 71.69,
      "time_str": "01:11.690",
      "text": "我要登上",
      "translation": null
    },
    {
      "time": 75.44,
      "time_str": "01:15.440",
      "text": "登上山顶",
      "translation": null
    },
    {
      "time": 79.19,
      "time_str": "01:19.190",
      "text": "去寻觅雾中的身影",
      "translation": null
    },
    {
      "time": 87.94,
      "time_str": "01:27.940",
      "text": "我要跨上",
      "translation": null
    },
    {
      "time": 91.93,
      "time_str": "01:31.930",
      "text": "跨上骏马",
      "translation": null
    },
    {
      "time": 95.9,
      "time_str": "01:35.900",
      "text": "去追寻遥远的星星",
      "translation": null
    },
    {
      "time": 102.03,
      "time_str": "01:42.030",
      "text": "星星",
      "translation": null
    },
    {
      "time": 115.11,
      "time_str": "01:55.110",
      "text": "天边有一棵大树",
      "translation": null
    },
    {
      "time": 124.03,
      "time_str": "02:04.030",
      "text": "那是我心中的绿荫",
      "translation": null
    },
    {
      "time": 130.86,
      "time_str": "02:10.860",
      "text": "远方有一座高山",
      "translation": null
    },
    {
      "time": 139.36,
      "time_str": "02:19.360",
      "text": "那是你博大的胸襟",
      "translation": null
    },
    {
      "time": 147.88,
      "time_str": "02:27.880",
      "text": "我要树下",
      "translation": null
    },
    {
      "time": 151.67,
      "time_str": "02:31.670",
      "text": "树下采拮",
      "translation": null
    },
    {
      "time": 155.86,
      "time_str": "02:35.860",
      "text": "去编织美丽的憧憬",
      "translation": null
    },
    {
      "time": 164.19,
      "time_str": "02:44.190",
      "text": "我要山下",
      "translation": null
    },
    {
      "time": 168.19,
      "time_str": "02:48.190",
      "text": "山下放牧",
      "translation": null
    },
    {
      "time": 172.13,
      "time_str": "02:52.130",
      "text": "去追寻你的足迹",
      "translation": null
    },
    {
      "time": 181.82,
      "time_str": "03:01.820",
      "text": "足迹",
      "translation": null
    },
    {
      "time": 220.38,
      "time_str": "03:40.380",
      "text": "我愿与你策马同行",
      "translation": null
    },
    {
      "time": 227.97,
      "time_str": "03:47.970",
      "text": "奔驰在草原的深处",
      "translation": null
    },
    {
      "time": 236.54,
      "time_str": "03:56.540",
      "text": "我愿与你展翅飞翔",
      "translation": null
    },
    {
      "time": 244.85,
      "time_str": "04:04.850",
      "text": "遨游在蓝天的穹谷",
      "translation": null
    },
    {
      "time": 254.24,
      "time_str": "04:14.240",
      "text": "穹谷",
      "translation": null
    }
  ],
