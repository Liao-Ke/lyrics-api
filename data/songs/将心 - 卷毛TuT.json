    "arranger": "周果亦"
  },
  "lyrics": [
    {
      "time": 21.97,
      "time_str": "00:21.970",
      "text": "当所有 荣耀与伤疤都埋于尘底",
      "translation": null
    },
    {
      "time": 27.58,
      "time_str": "00:27.580",
      "text": "要多一往无前 才无懈可击",
      "translation": null
    },
    {
      "time": 33.75,
      "time_str": "00:33.750",
      "text": "遗失的自己 坠陷遥远星际",
      "translation": null
    },
    {
      "time": 39.73,
      "time_str": "00:39.730",
      "text": "如何逃离 才能转圜结局",
      "translation": null
    },
    {
      "time": 46.62,
      "time_str": "00:46.620",
      "text": "当一切冥冥注定 要向命运屈膝",
      "translation": null
    },
    {
      "time": 52.14,
      "time_str": "00:52.140",
      "text": "偏逢孤悬的星 携璀璨天光",
      "translation": null
    },
    {
      "time": 56.84,
      "time_str": "00:56.840",
      "text": "温柔的靠近",
      "translation": null
    },
    {
      "time": 61.56,
      "time_str": "01:01.560",
      "text": "尘蒙功勋 深埋孤独背脊",
      "translation": null
    },
    {
      "time": 67.03,
      "time_str": "01:07.030",
      "text": "如履薄冰 缝隙之中喘息",
      "translation": null
    },
    {
      "time": 73.33,
      "time_str": "01:13.330",
      "text": "怕靠的太近最后一刻与你失之交臂",
      "translation": null
    },
    {
      "time": 79.42,
      "time_str": "01:19.420",
      "text": "怕一眼望尽谁的命运轨迹",
      "translation": null
    },
    {
      "time": 98.1,
      "time_str": "01:38.100",
      "text": "努力到挫尽锐气 也要张臂抱紧",
      "translation": null
    },
    {
      "time": 103.7,
      "time_str": "01:43.700",
      "text": "为这隐忍爱意 柔软而坚毅",
      "translation": null
    },
    {
      "time": 108.94,
      "time_str": "01:48.940",
      "text": "浪漫的彻底",
      "translation": null
    },
    {
      "time": 113.21,
      "time_str": "01:53.210",
      "text": "尘蒙功勋 深埋孤独背脊",
      "translation": null
    },
    {
      "time": 118.78,
      "time_str": "01:58.780",
      "text": "如履薄冰 缝隙之中喘息",
      "translation": null
    },
    {
      "time": 125.01,
      "time_str": "02:05.010",
      "text": "怕靠的太近最后一刻与你失之交臂",
      "translation": null
    },
    {
      "time": 131.04,
      "time_str": "02:11.040",
      "text": "怕一眼望尽谁的命运轨迹",
      "translation": null
    },
    {
      "time": 137.35,
      "time_str": "02:17.350",
      "text": "只需一刻 与你掌心相抵",
      "translation": null
    },
    {
      "time": 143.23,
      "time_str": "02:23.230",
      "text": "荒芜的心 便一寸寸填平",
      "translation": null
    },
    {
      "time": 149.65,
      "time_str": "02:29.650",
      "text": "当你无畏的照进我颓唐的生命",
      "translation": null
    },
    {
      "time": 155.42,
      "time_str": "02:35.420",
      "text": "才有了与世匹敌的勇气",
      "translation": null
    },
    {
      "time": 174.91,
