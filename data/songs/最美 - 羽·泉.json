    {
      "time": 30.37,
      "time_str": "00:30.370",
      "text": "Baby 为了这次约会",
      "translation": null
    },
    {
      "time": 35.77,
      "time_str": "00:35.770",
      "text": "昨夜我无法安然入睡",
      "translation": null
    },
    {
      "time": 40.83,
      "time_str": "00:40.830",
      "text": "准备了 十二朵玫瑰",
      "translation": null
    },
    {
      "time": 45.75,
      "time_str": "00:45.750",
      "text": "每一朵都像你那样美",
      "translation": null
    },
    {
      "time": 50.75,
      "time_str": "00:50.750",
      "text": "你的美 无声无息",
      "translation": null
    },
    {
      "time": 55.48,
      "time_str": "00:55.480",
      "text": "不知不觉让我追随",
      "translation": null
    },
    {
      "time": 61.15,
      "time_str": "01:01.150",
      "text": "Baby 这次动了情",
      "translation": null
    },
    {
      "time": 65.6,
      "time_str": "01:05.600",
      "text": "彷徨失措我不后悔",
      "translation": null
    },
    {
      "time": 70.59,
      "time_str": "01:10.590",
      "text": "你在我眼中是最美",
      "translation": null
    },
    {
      "time": 75.23,
      "time_str": "01:15.230",
      "text": "每一个微笑都让我沉醉",
      "translation": null
    },
    {
      "time": 80.73,
      "time_str": "01:20.730",
      "text": "你的坏 你的好",
      "translation": null
