  "lyrics": [
    {
      "time": 27.4,
      "time_str": "00:27.400",
      "text": "黄昏骤雨过后",
      "translation": null
    },
    {
      "time": 29.1,
      "time_str": "00:29.100",
      "text": "濛濛的水边",
      "translation": null
    },
    {
      "time": 31.25,
      "time_str": "00:31.250",
      "text": "有蓝色的蝴蝶",
      "translation": null
    },
    {
      "time": 33.7,
      "time_str": "00:33.700",
      "text": "画翩翩的弧线",
      "translation": null
    },
    {
      "time": 37.1,
      "time_str": "00:37.100",
      "text": "多么缠绵",
      "translation": null
    },
    {
      "time": 39.31,
      "time_str": "00:39.310",
      "text": "酝酿着的诺言",
      "translation": null
    },
    {
      "time": 41.82,
      "time_str": "00:41.820",
      "text": "保存期又有几年",
      "translation": null
    },
    {
      "time": 47.4,
      "time_str": "00:47.400",
      "text": "夕阳如血",
      "translation": null
    },
    {
      "time": 49.79,
      "time_str": "00:49.790",
      "text": "彼岸花开得妖艳",
      "translation": null
    },
    {
      "time": 52.0,
      "time_str": "00:52.000",
      "text": "当美景都重叠",
      "translation": null
    },
    {
      "time": 54.55,
      "time_str": "00:54.550",
      "text": "视线丢了焦点",
      "translation": null
    },
    {
      "time": 58.3,
      "time_str": "00:58.300",
      "text": "车窗外面",
      "translation": null
    },
    {
      "time": 60.11,
      "time_str": "01:00.110",
      "text": "泥土清香沁入心田",
      "translation": null
    },
    {
      "time": 62.88,
      "time_str": "01:02.880",
      "text": "情绪一点一点沉淀",
      "translation": null
    },
    {
      "time": 67.89,
      "time_str": "01:07.890",
      "text": "松 松 松",
      "translation": null
    },
    {
      "time": 69.84,
      "time_str": "01:09.840",
      "text": "松开了你的手",
      "translation": null
    },
    {
      "time": 72.8,
      "time_str": "01:12.800",
      "text": "没有觉得一个人的旅途有何寂寞",
      "translation": null
    },
    {
      "time": 78.3,
      "time_str": "01:18.300",
      "text": "你有离开的理由",
      "translation": null
    },
    {
      "time": 80.69,
      "time_str": "01:20.690",
      "text": "我有闲适的理由",
      "translation": null
    },
    {
      "time": 83.38,
      "time_str": "01:23.380",
      "text": "你 我",
      "translation": null
    },
    {
      "time": 85.7,
      "time_str": "01:25.700",
      "text": "太多的不同",
      "translation": null
    },
    {
      "time": 88.98,
      "time_str": "01:28.980",
      "text": "No No No",
      "translation": null
    },
    {
      "time": 90.58,
      "time_str": "01:30.580",
      "text": "没什么参不透",
      "translation": null
    },
    {
      "time": 93.68,
