    {
      "time": 54.98,
      "time_str": "00:54.980",
      "text": "我从山中来带着兰花草",
      "translation": null
    },
    {
      "time": 59.5,
      "time_str": "00:59.500",
      "text": "种在小园中希望花开早",
      "translation": null
    },
    {
      "time": 64.41,
      "time_str": "01:04.410",
      "text": "一日看三回看得花时过",
      "translation": null
    },
    {
      "time": 69.45,
      "time_str": "01:09.450",
      "text": "兰花却依然苞也无一个",
      "translation": null
    },
    {
      "time": 84.74,
      "time_str": "01:24.740",
      "text": "转眼秋天到移兰入暖房",
      "translation": null
    },
    {
      "time": 89.29,
      "time_str": "01:29.290",
      "text": "朝朝频顾惜夜夜不相忘",
      "translation": null
    },
    {
      "time": 94.12,
      "time_str": "01:34.120",
      "text": "期待春花开能将夙愿偿",
      "translation": null
    },
    {
      "time": 99.29,
      "time_str": "01:39.290",
      "text": "满庭花簇簇添得许多香",
