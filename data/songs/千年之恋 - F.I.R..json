      "text": "竹林的灯火",
      "translation": null
    },
    {
      "time": 46.31,
      "time_str": "00:46.310",
      "text": "岛国的沙漠",
      "translation": null
    },
    {
      "time": 47.9,
      "time_str": "00:47.900",
      "text": "七色的国度",
      "translation": null
    },
    {
      "time": 49.28,
      "time_str": "00:49.280",
      "text": "不断飘逸风中",
      "translation": null
    },
    {
      "time": 51.26,
      "time_str": "00:51.260",
      "text": "有一种神秘",
      "translation": null
    },
    {
      "time": 52.62,
      "time_str": "00:52.620",
      "text": "灰色的漩涡",
      "translation": null
    },
    {
      "time": 54.57,
      "time_str": "00:54.570",
      "text": "将我卷入了迷雾中",
      "translation": null
    },
    {
      "time": 57.63,
      "time_str": "00:57.630",
      "text": "看不清的双手一朵花",
      "translation": null
    },
    {
      "time": 61.57,
      "time_str": "01:01.570",
      "text": "传来谁经过的温柔",
      "translation": null
    },
    {
      "time": 67.43,
      "time_str": "01:07.430",
      "text": "穿越千年的伤痛",
      "translation": null
    },
    {
      "time": 70.64,
      "time_str": "01:10.640",
      "text": "只为求一个结果",
      "translation": null
    },
    {
      "time": 74.07,
      "time_str": "01:14.070",
      "text": "你留下的轮廓指引我",
      "translation": null
    },
    {
      "time": 78.36,
      "time_str": "01:18.360",
      "text": "黑夜中不寂寞",
      "translation": null
    },
    {
      "time": 81.12,
      "time_str": "01:21.120",
      "text": "穿越千年的哀愁",
      "translation": null
    },
    {
      "time": 84.24,
      "time_str": "01:24.240",
      "text": "是你在尽头等我",
      "translation": null
    },
    {
      "time": 87.71,
      "time_str": "01:27.710",
      "text": "最美丽的感动会值得",
      "translation": null
    },
    {
      "time": 91.59,
      "time_str": "01:31.590",
      "text": "用一生守候",
