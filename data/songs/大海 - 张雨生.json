  "lyrics": [
    {
      "time": 19.27,
      "time_str": "00:19.270",
      "text": "从那遥远海边",
      "translation": null
    },
    {
      "time": 22.93,
      "time_str": "00:22.930",
      "text": "慢慢消失的你",
      "translation": null
    },
    {
      "time": 25.67,
      "time_str": "00:25.670",
      "text": "本来模糊的脸",
      "translation": null
    },
    {
      "time": 28.35,
      "time_str": "00:28.350",
      "text": "竟然渐渐清晰",
      "translation": null
    },
    {
      "time": 31.18,
      "time_str": "00:31.180",
      "text": "想要说些什么",
      "translation": null
    },
    {
      "time": 33.95,
      "time_str": "00:33.950",
      "text": "又不知从何说起",
      "translation": null
    },
    {
      "time": 36.85,
      "time_str": "00:36.850",
      "text": "只有把它放在心底",
      "translation": null
    },
    {
      "time": 42.39,
      "time_str": "00:42.390",
      "text": "茫然走在海边",
      "translation": null
    },
    {
      "time": 45.22,
      "time_str": "00:45.220",
      "text": "看那潮来潮去",
      "translation": null
    },
    {
      "time": 48.05,
      "time_str": "00:48.050",
      "text": "徒劳无功",
      "translation": null
    },
    {
      "time": 49.64,
      "time_str": "00:49.640",
      "text": "想把每朵浪花记清",
      "translation": null
    },
    {
      "time": 53.49,
      "time_str": "00:53.490",
      "text": "想要说声爱你",
      "translation": null
    },
    {
      "time": 56.29,
      "time_str": "00:56.290",
      "text": "却被吹散在风里",
      "translation": null
    },
    {
      "time": 59.04,
      "time_str": "00:59.040",
      "text": "猛然回头 你在那里",
      "translation": null
    },
    {
      "time": 64.72,
      "time_str": "01:04.720",
      "text": "如果大海能够",
      "translation": null
    },
    {
      "time": 67.04,
      "time_str": "01:07.040",
      "text": "唤回曾经的爱",
      "translation": null
    },
    {
      "time": 70.19,
      "time_str": "01:10.190",
      "text": "就让我用一生等待",
      "translation": null
    },
    {
      "time": 75.78,
      "time_str": "01:15.780",
      "text": "如果深情往事你已不再留恋",
      "translation": null
    },
    {
      "time": 81.36,
      "time_str": "01:21.360",
      "text": "就让它随风飘远",
      "translation": null
    },
    {
      "time": 86.85,
      "time_str": "01:26.850",
      "text": "如果大海能够",
      "translation": null
    },
    {
      "time": 89.04,
      "time_str": "01:29.040",
      "text": "带走我的哀愁",
      "translation": null
    },
    {
      "time": 92.41,
      "time_str": "01:32.410",
      "text": "就像带走每条河流",
      "translation": null
    },
    {
      "time": 98.02,
      "time_str": "01:38.020",
      "text": "所有受过的伤",
      "translation": null
    },
    {
      "time": 100.8,
      "time_str": "01:40.800",
      "text": "所有流过的泪",
      "translation": null
    },
    {
      "time": 103.65,
      "time_str": "01:43.650",
      "text": "我的爱",
      "translation": null
    },
    {
      "time": 107.96,
      "time_str": "01:47.960",
      "text": "请全部带走",
      "translation": null
    },
