  "lyrics": [
    {
      "time": 8.0,
      "time_str": "00:08.000",
      "text": "混音助理 : 刘勇志",
      "translation": null
    },
    {
      "time": 18.91,
      "time_str": "00:18.910",
      "text": "有谁能比我知道",
      "translation": null
    },
    {
      "time": 23.08,
      "time_str": "00:23.080",
      "text": "你的温柔像羽毛",
      "translation": null
    },
    {
      "time": 27.2,
      "time_str": "00:27.200",
      "text": "秘密躺在我怀抱",
      "translation": null
    },
    {
      "time": 31.31,
      "time_str": "00:31.310",
      "text": "只有你能听得到",
      "translation": null
    },
    {
      "time": 35.46,
      "time_str": "00:35.460",
      "text": "还有没有人知道",
      "translation": null
    },
    {
      "time": 39.58,
      "time_str": "00:39.580",
      "text": "你的微笑像拥抱",
      "translation": null
    },
    {
      "time": 43.72,
      "time_str": "00:43.720",
      "text": "多想藏着你的好",
      "translation": null
    },
    {
      "time": 47.82,
      "time_str": "00:47.820",
      "text": "只有我看得到",
      "translation": null
    },
    {
      "time": 51.48,
      "time_str": "00:51.480",
      "text": "站在屋顶只对风说",
      "translation": null
    },
    {
      "time": 55.11,
      "time_str": "00:55.110",
      "text": "不想被左右",
      "translation": null
    },
    {
      "time": 58.98,
      "time_str": "00:58.980",
      "text": "本来讨厌下雨的天空",
      "translation": null
    },
    {
      "time": 63.13,
      "time_str": "01:03.130",
      "text": "直到听见有人说爱我",
      "translation": null
    },
    {
      "time": 67.98,
      "time_str": "01:07.980",
      "text": "坐在电影院的二楼",
      "translation": null
    },
    {
      "time": 71.66,
      "time_str": "01:11.660",
      "text": "看人群走过",
      "translation": null
    },
    {
      "time": 75.52,
      "time_str": "01:15.520",
      "text": "怎么那一天的我们",
      "translation": null
    },
    {
      "time": 79.62,
      "time_str": "01:19.620",
      "text": "都默默的微笑很久",
      "translation": null
    },
    {
      "time": 84.55,
      "time_str": "01:24.550",
      "text": "我想我是太过依赖",
      "translation": null
    },
    {
      "time": 89.16,
      "time_str": "01:29.160",
      "text": "在挂电话的刚才",
      "translation": null
    },
    {
      "time": 93.38,
      "time_str": "01:33.380",
      "text": "坚持学单纯的小孩",
      "translation": null
    },
    {
      "time": 97.51,
      "time_str": "01:37.510",
      "text": "静静看守这份爱",
      "translation": null
    },
    {
      "time": 101.62,
      "time_str": "01:41.620",
      "text": "知道不能太依赖",
      "translation": null
    },
    {
      "time": 105.7,
      "time_str": "01:45.700",
      "text": "怕你会把我宠坏",
      "translation": null
    },
    {
      "time": 109.9,
      "time_str": "01:49.900",
      "text": "你的香味一直徘徊",
      "translation": null
    },
    {
      "time": 114.78,
      "time_str": "01:54.780",
      "text": "我舍不得离开",
      "translation": null
    },
