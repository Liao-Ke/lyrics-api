    {
      "time": 19.53,
      "time_str": "00:19.530",
      "text": "打开心灵剥去春的羞涩",
      "translation": null
    },
    {
      "time": 28.5,
      "time_str": "00:28.500",
      "text": "舞步飞旋踏破冬的沉默",
      "translation": null
    },
    {
      "time": 37.47,
      "time_str": "00:37.470",
      "text": "融融的暖意带着深情的问候",
      "translation": null
    },
    {
      "time": 44.28,
      "time_str": "00:44.280",
      "text": "绵绵细雨沐浴那昨天昨天",
      "translation": null
    },
    {
      "time": 48.66,
      "time_str": "00:48.660",
      "text": "昨天激动的时刻",
      "translation": null
    },
    {
      "time": 50.94,
      "time_str": "00:50.940",
      "text": "你用温暖的目光迎接我",
      "translation": null
    },
    {
      "time": 54.0,
      "time_str": "00:54.000",
      "text": "迎接我从昨天带来的欢乐欢乐",
      "translation": null
    },
    {
      "time": 60.03,
      "time_str": "01:00.030",
      "text": "来吧来吧相约九八",
