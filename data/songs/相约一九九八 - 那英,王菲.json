    {
      "time": 109.59,
      "time_str": "01:49.590",
      "text": "心相约心相约无论咫尺天涯",
      "translation": null
    },
    {
      "time": 129.99,
      "time_str": "02:09.990",
      "text": "歌声悠悠穿透春的绿色",
