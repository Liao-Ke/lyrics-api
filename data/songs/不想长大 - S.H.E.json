    },
    {
      "time": 128.74,
      "time_str": "02:08.740",
      "text": "为什么结局没欢笑",
      "translation": null
    },
    {
      "time": 130.91,
      "time_str": "02:10.910",
      "text": "而是泪流满面",
      "translation": null
    },
    {
      "time": 133.88,
      "time_str": "02:13.880",
      "text": "我愿意在他回来前",
      "translation": null
    },
    {
      "time": 136.34,
      "time_str": "02:16.340",
      "text": "继续安静沉睡",
      "translation": null
    },
    {
      "time": 139.01,
      "time_str": "02:19.010",
      "text": "但他已去到别座城堡",
