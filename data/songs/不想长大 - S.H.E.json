  "lyrics": [
    {
      "time": 20.67,
      "time_str": "00:20.670",
      "text": "为什么就是找不到",
      "translation": null
    },
    {
      "time": 23.08,
      "time_str": "00:23.080",
      "text": "不谢的玫瑰花",
      "translation": null
    },
    {
      "time": 25.56,
      "time_str": "00:25.560",
      "text": "为什么遇见的王子",
      "translation": null
    },
    {
      "time": 27.96,
      "time_str": "00:27.960",
      "text": "都不够王子啊",
      "translation": null
    },
    {
      "time": 30.72,
      "time_str": "00:30.720",
      "text": "我并不期盼他会有",
      "translation": null
    },
    {
      "time": 33.07,
      "time_str": "00:33.070",
      "text": "玻璃鞋和白马",
      "translation": null
    },
    {
      "time": 35.92,
      "time_str": "00:35.920",
      "text": "我惊讶的是 情话竟然",
      "translation": null
    },
    {
      "time": 38.53,
      "time_str": "00:38.530",
      "text": "会变成谎话",
      "translation": null
    },
    {
      "time": 41.3,
      "time_str": "00:41.300",
      "text": "为什么幸福的青鸟",
      "translation": null
    },
    {
      "time": 43.69,
      "time_str": "00:43.690",
      "text": "要飞得那么高",
      "translation": null
    },
    {
      "time": 46.06,
      "time_str": "00:46.060",
      "text": "为什么苹果和拥抱",
      "translation": null
    },
    {
      "time": 48.83,
      "time_str": "00:48.830",
      "text": "都可能是毒药",
      "translation": null
    },
    {
      "time": 51.31,
      "time_str": "00:51.310",
      "text": "我从没想过有了他",
      "translation": null
    },
    {
      "time": 53.96,
      "time_str": "00:53.960",
      "text": "还孤单得可怕",
      "translation": null
    },
    {
      "time": 56.5,
      "time_str": "00:56.500",
      "text": "我突然想起从前陪我那个洋娃娃",
      "translation": null
    },
    {
      "time": 61.62,
      "time_str": "01:01.620",
      "text": "我不想 我不想 不想长大",
      "translation": null
    },
    {
      "time": 64.24,
      "time_str": "01:04.240",
      "text": "长大后 世界就 没童话",
      "translation": null
    },
    {
      "time": 66.86,
      "time_str": "01:06.860",
      "text": "我不想 我不想 不想长大",
      "translation": null
    },
    {
      "time": 69.42,
      "time_str": "01:09.420",
      "text": "我宁愿 永远都 笨又傻",
      "translation": null
    },
    {
      "time": 71.21,
      "time_str": "01:11.210",
      "text": "我不想 我不想 不想长大",
