  "lyrics": [
    {
      "time": 14.41,
      "time_str": "00:14.410",
      "text": "初秋的天冰冷的夜",
      "translation": null
    },
    {
      "time": 17.4,
      "time_str": "00:17.400",
      "text": "回忆慢慢袭来",
      "translation": null
    },
    {
      "time": 20.61,
      "time_str": "00:20.610",
      "text": "真心的爱就像落叶",
      "translation": null
    },
    {
      "time": 23.63,
      "time_str": "00:23.630",
      "text": "为何却要分开",
      "translation": null
    },
    {
      "time": 26.18,
      "time_str": "00:26.180",
      "text": "灰色的天独自彷徨",
      "translation": null
    },
    {
      "time": 29.21,
      "time_str": "00:29.210",
      "text": "城市的老地方",
      "translation": null
    },
    {
      "time": 32.26,
      "time_str": "00:32.260",
      "text": "真的孤单走过忧伤",
      "translation": null
    },
    {
      "time": 35.16,
      "time_str": "00:35.160",
      "text": "心碎还要逞强",
      "translation": null
    },
    {
      "time": 38.06,
      "time_str": "00:38.060",
      "text": "想为你披件外衣",
      "translation": null
    },
    {
      "time": 41.03,
      "time_str": "00:41.030",
      "text": "天凉要爱惜自己",
      "translation": null
    },
    {
      "time": 45.47,
      "time_str": "00:45.470",
      "text": "没有人比我更疼你",
      "translation": null
    },
    {
      "time": 50.41,
      "time_str": "00:50.410",
      "text": "告诉你在每个",
      "translation": null
    },
    {
      "time": 53.49,
      "time_str": "00:53.490",
      "text": "想你的夜里",
      "translation": null
    },
    {
      "time": 57.0,
      "time_str": "00:57.000",
      "text": "我哭的好无力",
      "translation": null
    },
    {
      "time": 62.45,
      "time_str": "01:02.450",
      "text": "就让秋风带走我的思念",
      "translation": null
    },
    {
      "time": 65.83,
      "time_str": "01:05.830",
      "text": "带走我的泪",
      "translation": null
    },
    {
      "time": 68.82,
      "time_str": "01:08.820",
      "text": "我还一直静静守候在",
      "translation": null
    },
    {
      "time": 72.19,
      "time_str": "01:12.190",
      "text": "相约的地点",
      "translation": null
    },
    {
      "time": 74.93,
      "time_str": "01:14.930",
      "text": "求求老天淋湿我的双眼",
      "translation": null
    },
    {
      "time": 78.22,
      "time_str": "01:18.220",
      "text": "冰冻我的心",
      "translation": null
    },
    {
      "time": 80.75,
      "time_str": "01:20.750",
      "text": "让我不再苦苦奢求你",
      "translation": null
    },
    {
      "time": 84.25,
      "time_str": "01:24.250",
      "text": "还回来我身边",
      "translation": null
    },
    {
      "time": 88.66,
      "time_str": "01:28.660",
      "text": "我身边",
      "translation": null
    },
