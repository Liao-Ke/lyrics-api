  "lyrics": [
    {
      "time": 9.94,
      "time_str": "00:09.940",
      "text": "嘿 兄弟",
      "translation": null
    },
    {
      "time": 11.66,
      "time_str": "00:11.660",
      "text": "我们好久不见 你在哪里",
      "translation": null
    },
    {
      "time": 14.12,
      "time_str": "00:14.120",
      "text": "嘿 朋友",
      "translation": null
    },
    {
      "time": 15.65,
      "time_str": "00:15.650",
      "text": "如果真的是你 请打招呼",
      "translation": null
    },
    {
      "time": 18.08,
      "time_str": "00:18.080",
      "text": "嘿 兄弟",
      "translation": null
    },
    {
      "time": 19.63,
      "time_str": "00:19.630",
      "text": "我们好久不见 你在哪里",
      "translation": null
    },
    {
      "time": 21.97,
      "time_str": "00:21.970",
      "text": "嘿 朋友",
      "translation": null
    },
    {
      "time": 23.52,
      "time_str": "00:23.520",
      "text": "如果真的是你 请打招呼",
      "translation": null
    },
    {
      "time": 25.92,
      "time_str": "00:25.920",
      "text": "别对着我笑 没人会在乎",
      "translation": null
    },
    {
      "time": 27.95,
      "time_str": "00:27.950",
      "text": "别对着我哭 没人会无助",
      "translation": null
    },
    {
      "time": 30.03,
      "time_str": "00:30.030",
      "text": "其实大家早已经清清楚楚",
      "translation": null
    },
    {
      "time": 31.97,
      "time_str": "00:31.970",
      "text": "脚下踏上了不回头的路",
      "translation": null
    },
    {
      "time": 33.86,
      "time_str": "00:33.860",
      "text": "我说好久不见 你去何处",
      "translation": null
    },
    {
      "time": 36.08,
      "time_str": "00:36.080",
      "text": "你却对我说 我去江湖",
      "translation": null
    },
    {
      "time": 38.19,
      "time_str": "00:38.190",
      "text": "恩恩怨怨 没人会认输",
      "translation": null
    },
    {
      "time": 39.97,
      "time_str": "00:39.970",
      "text": "舞刀弄剑 一点都不酷",
      "translation": null
    },
    {
      "time": 41.96,
      "time_str": "00:41.960",
      "text": "来吧 热上一壶好酒",
      "translation": null
    },
    {
      "time": 44.04,
      "time_str": "00:44.040",
      "text": "说吧 这些年来的辛苦",
      "translation": null
    },
    {
      "time": 45.97,
      "time_str": "00:45.970",
      "text": "难得知己 聪明又糊涂",
      "translation": null
    },
    {
      "time": 48.01,
      "time_str": "00:48.010",
      "text": "儿女情长 牵肠又挂肚",
      "translation": null
    },
    {
      "time": 50.0,
      "time_str": "00:50.000",
      "text": "你我更需要忍受孤独",
      "translation": null
    },
    {
      "time": 52.04,
      "time_str": "00:52.040",
      "text": "独来独往 英雄不问出处",
      "translation": null
    },
    {
      "time": 53.94,
      "time_str": "00:53.940",
      "text": "笑一笑朋友 快乐会无数",
      "translation": null
    },
    {
      "time": 55.99,
      "time_str": "00:55.990",
      "text": "喝完了这壶 让我们上路",
      "translation": null
    },
    {
