  "lyrics": [
    {
      "time": 15.5,
      "time_str": "00:15.500",
      "text": "我的眼睛并不向往另一片天空",
      "translation": null
    },
    {
      "time": 22.97,
      "time_str": "00:22.970",
      "text": "禁止进入爱情 是我说的",
      "translation": null
    },
    {
      "time": 29.27,
      "time_str": "00:29.270",
      "text": "谁也听不见",
      "translation": null
    },
    {
      "time": 33.3,
      "time_str": "00:33.300",
      "text": "这种孤单真可怜",
      "translation": null
    },
    {
      "time": 36.63,
      "time_str": "00:36.630",
      "text": "多爱一次",
      "translation": null
    },
    {
      "time": 40.07,
      "time_str": "00:40.070",
      "text": "就多些寂寞",
      "translation": null
    },
    {
      "time": 44.78,
      "time_str": "00:44.780",
      "text": "你为什么还是不懂我要的自由",
      "translation": null
    },
    {
      "time": 52.02,
      "time_str": "00:52.020",
      "text": "一句话 就让你离我远了",
      "translation": null
    },
    {
      "time": 58.4,
      "time_str": "00:58.400",
      "text": "别让我以为",
      "translation": null
    },
    {
      "time": 62.43,
      "time_str": "01:02.430",
      "text": "快乐最后会粉碎",
      "translation": null
    },
    {
      "time": 65.43,
      "time_str": "01:05.430",
      "text": "人最孤单的时候 绝不会掉眼泪",
      "translation": null
    },
    {
      "time": 71.87,
      "time_str": "01:11.870",
      "text": "说爱我",
      "translation": null
    },
    {
      "time": 75.2,
      "time_str": "01:15.200",
      "text": "在我的耳边对我说",
      "translation": null
    },
    {
      "time": 80.44,
      "time_str": "01:20.440",
      "text": "我已经真的太久 忘了这种心动",
      "translation": null
    },
    {
      "time": 88.3,
      "time_str": "01:28.300",
      "text": "爱太难了解了",
      "translation": null
    },
    {
      "time": 91.85,
      "time_str": "01:31.850",
      "text": "我们还看不懂",
      "translation": null
    },
    {
      "time": 95.16,
      "time_str": "01:35.160",
      "text": "那一些心酸快乐",
      "translation": null
    },
    {
      "time": 97.22,
      "time_str": "01:37.220",
      "text": "有多少还很真呢",
      "translation": null
    },
    {
      "time": 101.03,
      "time_str": "01:41.030",
      "text": "说爱我",
      "translation": null
    },
    {
      "time": 104.33,
      "time_str": "01:44.330",
      "text": "用你的手心温暖我",
      "translation": null
    },
    {
      "time": 109.6,
      "time_str": "01:49.600",
      "text": "就算你不能证明爱我 能爱多久",
      "translation": null
    },
    {
      "time": 117.27,
      "time_str": "01:57.270",
      "text": "我知道你想过",
      "translation": null
    },
    {
      "time": 120.94,
      "time_str": "02:00.940",
      "text": "我要的并不多",
      "translation": null
    },
    {
      "time": 124.17,
      "time_str": "02:04.170",
      "text": "一起看天空好吗",
      "translation": null
    },
    {
