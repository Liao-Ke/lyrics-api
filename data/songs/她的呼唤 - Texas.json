  "lyrics": [
    {
      "time": 11.64,
      "time_str": "00:11.640",
      "text": "她依然走在这一条路上",
      "translation": null
    },
    {
      "time": 37.925,
      "time_str": "00:37.925",
      "text": "从她的眼睛看得出些忧伤",
      "translation": null
    },
    {
      "time": 44.219,
      "time_str": "00:44.219",
      "text": "你依然是你没太多考虑",
      "translation": null
    },
    {
      "time": 50.67,
      "time_str": "00:50.670",
      "text": "也许这只是你的一场游戏",
      "translation": null
    },
    {
      "time": 57.153,
      "time_str": "00:57.153",
      "text": "你你送给她的礼物",
      "translation": null
    },
    {
      "time": 61.102,
      "time_str": "01:01.102",
      "text": "只是一句对不起和再见",
      "translation": null
    },
    {
      "time": 68.301,
      "time_str": "01:08.301",
      "text": "她她却把所有包容和爱",
      "translation": null
    },
    {
      "time": 73.649,
      "time_str": "01:13.649",
      "text": "全放在一起还给你",
      "translation": null
    },
    {
      "time": 79.484,
      "time_str": "01:19.484",
      "text": "你回来吧别让她孤独的承受",
      "translation": null
    },
    {
      "time": 95.46,
      "time_str": "01:35.460",
      "text": "她轻轻闭上眼用眼泪感受你的爱",
      "translation": null
    },
    {
      "time": 121.184,
      "time_str": "02:01.184",
      "text": "爱有一种魔力会让人昏迷不醒",
      "translation": null
    },
    {
      "time": 144.338,
      "time_str": "02:24.338",
      "text": "没有爱情的生命多么苍白无力",
      "translation": null
    },
    {
      "time": 149.89,
      "time_str": "02:29.890",
      "text": "她投入其中没太多考虑",
      "translation": null
    },
    {
      "time": 156.225,
      "time_str": "02:36.225",
      "text": "可是她忽然成了爱情的牺牲品",
      "translation": null
    },
    {
      "time": 161.214,
      "time_str": "02:41.214",
      "text": "爱也许只是那么一个转瞬即逝的东西",
      "translation": null
    },
    {
      "time": 168.714,
      "time_str": "02:48.714",
      "text": "没道理",
      "translation": null
    },
    {
      "time": 174.771,
      "time_str": "02:54.771",
      "text": "谁谁又能没有经过爱情残酷的洗礼",
      "translation": null
    },
    {
      "time": 181.607,
      "time_str": "03:01.607",
      "text": "想开吧你",
      "translation": null
    },
    {
      "time": 188.84,
      "time_str": "03:08.840",
      "text": "痛不是你得远走而是她无尽的寂寞",
      "translation": null
    },
    {
      "time": 200.425,
      "time_str": "03:20.425",
      "text": "原来爱只是种折磨可却没有人躲得过",
      "translation": null
    },
    {
      "time": 221.173,
      "time_str": "03:41.173",
      "text": "你回来吧别让她孤独的承受",
      "translation": null
    },
    {
      "time": 233.519,
      "time_str": "03:53.519",
      "text": "她轻轻闭上眼用眼泪感受你的爱",
      "translation": null
    },
    {
      "time": 246.2,
