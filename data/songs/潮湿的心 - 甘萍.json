  "lyrics": [
    {
      "time": 26.81,
      "time_str": "00:26.810",
      "text": "是什么淋湿了我的眼睛",
      "translation": null
    },
    {
      "time": 33.17,
      "time_str": "00:33.170",
      "text": "看不清你远去的背影",
      "translation": null
    },
    {
      "time": 39.59,
      "time_str": "00:39.590",
      "text": "是什么冰冷了我的心情",
      "translation": null
    },
    {
      "time": 45.95,
      "time_str": "00:45.950",
      "text": "握不住你从前的温馨",
      "translation": null
    },
    {
      "time": 52.31,
      "time_str": "00:52.310",
      "text": "是雨声喧哗了我的安宁",
      "translation": null
    },
    {
      "time": 58.72,
      "time_str": "00:58.720",
      "text": "听不清自己哭泣的声音",
      "translation": null
    },
    {
      "time": 65.16,
      "time_str": "01:05.160",
      "text": "是雨伞美丽了城市的风景",
      "translation": null
    },
    {
      "time": 71.36,
      "time_str": "01:11.360",
      "text": "留不住身边匆忙的爱情",
      "translation": null
    },
    {
      "time": 77.68,
      "time_str": "01:17.680",
      "text": "谁能用爱烘干我这颗潮湿的心",
      "translation": null
    },
    {
      "time": 84.21,
      "time_str": "01:24.210",
      "text": "给我一声问候 一点温情",
      "translation": null
    },
    {
      "time": 90.19,
      "time_str": "01:30.190",
      "text": "谁能用心感受我这份滴水的痴情",
      "translation": null
    },
    {
      "time": 97.23,
      "time_str": "01:37.230",
      "text": "给我一片晴空 一声叮咛",
      "translation": null
    },
