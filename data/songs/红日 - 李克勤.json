      "text": "AH.. OH.. AH.. OH.. AH",
      "translation": null
    },
    {
      "time": 60.831,
      "time_str": "01:00.831",
      "text": "一生之中兜兜转转",
      "translation": null
    },
    {
      "time": 62.736,
      "time_str": "01:02.736",
      "text": "哪会看清楚",
      "translation": null
    },
    {
      "time": 63.972,
      "time_str": "01:03.972",
      "text": "彷徨时我也试过",
      "translation": null
    },
    {
      "time": 65.686,
      "time_str": "01:05.686",
      "text": "独坐一角 像是没协助",
      "translation": null
    },
    {
      "time": 68.792,
      "time_str": "01:08.792",
      "text": "在某年 那幼小的我",
      "translation": null
    },
    {
      "time": 72.029,
      "time_str": "01:12.029",
      "text": "跌倒过几多几多落泪",
      "translation": null
    },
    {
      "time": 74.261,
      "time_str": "01:14.261",
      "text": "在雨夜滂沱",
      "translation": null
    },
    {
      "time": 76.761,
      "time_str": "01:16.761",
      "text": "一生之中弯弯曲曲",
      "translation": null
    },
    {
      "time": 78.77,
      "time_str": "01:18.770",
      "text": "我也要走过",
      "translation": null
    },
    {
      "time": 79.999,
      "time_str": "01:19.999",
      "text": "从何时有你有你",
      "translation": null
    },
    {
      "time": 81.732,
      "time_str": "01:21.732",
      "text": "伴我给我热烈地拍和",
      "translation": null
    },
    {
      "time": 84.239,
      "time_str": "01:24.239",
      "text": "像红日之火 燃点真的我",
      "translation": null
    },
    {
      "time": 88.263,
      "time_str": "01:28.263",
      "text": "结伴行 千山也定能踏过",
      "translation": null
    },
    {
      "time": 91.758,
      "time_str": "01:31.758",
      "text": "让晚风 轻轻吹过",
      "translation": null
    },
    {
      "time": 95.981,
      "time_str": "01:35.981",
      "text": "伴送着清幽花香",
      "translation": null
    },
    {
      "time": 97.75,
      "time_str": "01:37.750",
      "text": "像是在祝福你我",
      "translation": null
    },
    {
      "time": 99.973,
      "time_str": "01:39.973",
      "text": "让晚星 轻轻闪过",
      "translation": null
    },
    {
      "time": 103.968,
      "time_str": "01:43.968",
      "text": "闪出你每个希冀如浪花",
      "translation": null
    },
    {
      "time": 107.478,
      "time_str": "01:47.478",
      "text": "快要沾湿我 WOO...",
      "translation": null
    },
    {
