    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "Publisher : Publisher House Amuse Inc (PolyGram)",
      "translation": null
    },
    {
      "time": 30.25,
      "time_str": "00:30.250",
      "text": "又见雪飘过",
      "translation": null
    },
    {
      "time": 32.89,
      "time_str": "00:32.890",
      "text": "飘于伤心记忆中",
      "translation": null
    },
    {
      "time": 36.91,
      "time_str": "00:36.910",
      "text": "让我再想你",
      "translation": null
    },
    {
      "time": 39.43,
      "time_str": "00:39.430",
      "text": "却掀起我心痛",
      "translation": null
    },
    {
      "time": 43.57,
      "time_str": "00:43.570",
      "text": "早经分了手",
      "translation": null
    },
    {
      "time": 46.09,
      "time_str": "00:46.090",
      "text": "为何热爱尚情重",
      "translation": null
    },
    {
      "time": 49.41,
      "time_str": "00:49.410",
      "text": "独过追忆岁月",
      "translation": null
    },
    {
      "time": 52.69,
      "time_str": "00:52.690",
      "text": "或许此生不会懂",
      "translation": null
    },
    {
      "time": 56.87,
      "time_str": "00:56.870",
      "text": "又再想起你",
      "translation": null
    },
    {
      "time": 59.46,
      "time_str": "00:59.460",
      "text": "抱拥飘飘白雪中",
      "translation": null
    },
    {
      "time": 63.49,
      "time_str": "01:03.490",
      "text": "让你心中暖",
      "translation": null
    },
    {
      "time": 66.08,
      "time_str": "01:06.080",
      "text": "去驱走我冰冻",
      "translation": null
    },
    {
      "time": 70.25,
      "time_str": "01:10.250",
      "text": "冷风吹我醒",
      "translation": null
    },
    {
      "time": 72.72,
      "time_str": "01:12.720",
      "text": "原来共你是场梦",
      "translation": null
    },
    {
      "time": 76.15,
      "time_str": "01:16.150",
      "text": "像那飘飘雪泪下",
      "translation": null
    },
    {
      "time": 79.38,
      "time_str": "01:19.380",
      "text": "弄湿冷清的晚空",
      "translation": null
    },
    {
      "time": 83.5,
      "time_str": "01:23.500",
      "text": "原来是那么 深爱你",
      "translation": null
    },
    {
      "time": 89.23,
      "time_str": "01:29.230",
      "text": "此际伴着我追忆的心痛",
      "translation": null
    },
    {
