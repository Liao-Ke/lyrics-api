    {
      "time": 2.42,
      "time_str": "00:02.420",
      "text": "Lost in your mind",
      "translation": "迷失于你脑海之中"
    },
    {
      "time": 8.97,
      "time_str": "00:08.970",
      "text": "I wanna know",
      "translation": "此刻我只想知道"
    },
    {
      "time": 11.73,
      "time_str": "00:11.730",
      "text": "Am I losing my mind",
      "translation": "我是否已迷失自我"
    },
    {
      "time": 18.76,
      "time_str": "00:18.760",
      "text": "Never let me go",
      "translation": "请别离开我"
    },
    {
      "time": 20.87,
      "time_str": "00:20.870",
      "text": "If this night is not forever",
      "translation": "漫漫长夜终将迎来黎明之时"
    },
    {
      "time": 24.28,
      "time_str": "00:24.280",
      "text": "At least we are together",
      "translation": "可我们仍然凝聚在一起"
    },
    {
      "time": 26.73,
      "time_str": "00:26.730",
      "text": "I know I'm not alone",
      "translation": "从未曾孤身一人"
    },
    {
      "time": 29.28,
      "time_str": "00:29.280",
      "text": "I know I'm not alone",
      "translation": "我明白我从未一人"
    },
    {
