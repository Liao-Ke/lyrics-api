  "lyrics": [
    {
      "time": 21.96,
      "time_str": "00:21.960",
      "text": "旋律伴随故事响起",
      "translation": null
    },
    {
      "time": 26.78,
      "time_str": "00:26.780",
      "text": "揭开你 不平凡的传记",
      "translation": null
    },
    {
      "time": 32.25,
      "time_str": "00:32.250",
      "text": "在夜里 天使在黎明前降临",
      "translation": null
    },
    {
      "time": 38.76,
      "time_str": "00:38.760",
      "text": "唤醒 充满奇迹的命运",
      "translation": null
    },
    {
      "time": 43.98,
      "time_str": "00:43.980",
      "text": "倾听 爱丽丝的旋律",
      "translation": null
    },
    {
      "time": 48.72,
      "time_str": "00:48.720",
      "text": "若别离 撕毁我写的信",
      "translation": null
    },
    {
      "time": 54.09,
      "time_str": "00:54.090",
      "text": "当序曲 落幕后拆穿的回忆",
      "translation": null
    },
    {
      "time": 60.74,
      "time_str": "01:00.740",
      "text": "抚慰你 心灵悠扬的协奏曲",
      "translation": null
    },
    {
      "time": 65.54,
      "time_str": "01:05.540",
      "text": "在莱茵河畔 贝多芬的悲伤在徜徉",
      "translation": null
    },
    {
      "time": 71.17,
      "time_str": "01:11.170",
      "text": "诙谐夜晚 遗留在波恩城的泪光",
      "translation": null
    },
    {
      "time": 76.63,
      "time_str": "01:16.630",
      "text": "维也纳 推开 窗 风景却如此委婉",
      "translation": null
    },
    {
      "time": 82.57,
      "time_str": "01:22.570",
      "text": "黑白琴键上 谱写华丽的乐章",
      "translation": null
    },
    {
      "time": 87.53,
      "time_str": "01:27.530",
      "text": "在破旧琴房 弹唱出贝多芬的悲伤",
      "translation": null
    },
    {
      "time": 93.25,
      "time_str": "01:33.250",
      "text": "诙谐街上 探望绚烂欲望的橱窗",
      "translation": null
    },
    {
      "time": 98.67,
      "time_str": "01:38.670",
      "text": "小木船 被遗忘 剩下黯淡的月光",
      "translation": null
    },
    {
      "time": 104.5,
      "time_str": "01:44.500",
      "text": "无力哀叹 谁的情绪彷徨 结局被凌乱",
      "translation": null
    },
    {
