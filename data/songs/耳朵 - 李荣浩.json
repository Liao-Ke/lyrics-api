  "lyrics": [
    {
      "time": 15.39,
      "time_str": "00:15.39",
      "text": "谁的脚步 近了 谁的脚步 远了",
      "translation": null
    },
    {
      "time": 23.47,
      "time_str": "00:23.47",
      "text": "我都竖起 耳朵",
      "translation": null
    },
    {
      "time": 26.67,
      "time_str": "00:26.67",
      "text": "听着楼道里还是 空空荡荡的",
      "translation": null
    },
    {
      "time": 31.72,
      "time_str": "00:31.72",
      "text": "我没听你倾诉 没驱赶你孤独",
      "translation": null
    },
    {
      "time": 39.1,
      "time_str": "00:39.10",
      "text": "总是闭着 耳朵",
      "translation": null
    },
    {
      "time": 42.21,
      "time_str": "00:42.21",
      "text": "直到心房里变得 空空荡荡的",
      "translation": null
    },
    {
      "time": 46.68,
      "time_str": "00:46.68",
      "text": "所有的感官都要变迟钝",
      "translation": null
    },
    {
      "time": 50.22,
      "time_str": "00:50.22",
      "text": "茶饭不思 呆呆的凝望着",
      "translation": null
    },
    {
      "time": 54.32,
      "time_str": "00:54.32",
      "text": "只有耳朵不听话了",
      "translation": null
    },
    {
      "time": 58.0,
      "time_str": "00:58.00",
      "text": "非要我听那首最爱的老歌",
      "translation": null
    },
    {
      "time": 61.71,
      "time_str": "01:01.71",
      "text": "所有的情绪都要变脆弱",
      "translation": null
    },
    {
      "time": 65.53,
      "time_str": "01:05.53",
      "text": "烂俗桥段 眼睛却湿透了",
      "translation": null
    },
    {
      "time": 71.94,
      "time_str": "01:11.94",
      "text": "左右耳朵也埋怨着",
      "translation": null
    },
    {
      "time": 75.14,
      "time_str": "01:15.14",
      "text": "最近好像少了些什么",
