    {
      "time": 15.0,
      "time_str": "00:15.000",
      "text": "像我这样优秀的人",
      "translation": null
    },
    {
      "time": 18.77,
      "time_str": "00:18.770",
      "text": "本该灿烂过一生",
      "translation": null
    },
    {
      "time": 22.62,
      "time_str": "00:22.620",
      "text": "怎么二十多年到头来",
      "translation": null
    },
    {
      "time": 26.7,
      "time_str": "00:26.700",
      "text": "还在人海里浮沉",
      "translation": null
    },
    {
      "time": 30.35,
      "time_str": "00:30.350",
      "text": "像我这样聪明的人",
      "translation": null
    },
    {
      "time": 34.5,
      "time_str": "00:34.500",
      "text": "早就告别了单纯",
      "translation": null
    },
    {
      "time": 38.38,
      "time_str": "00:38.380",
      "text": "怎么还是用了一段情",
      "translation": null
    },
    {
      "time": 42.36,
      "time_str": "00:42.360",
      "text": "去换一身伤痕",
      "translation": null
    },
    {
      "time": 46.15,
      "time_str": "00:46.150",
      "text": "像我这样迷茫的人",
      "translation": null
    },
    {
      "time": 49.84,
      "time_str": "00:49.840",
      "text": "像我这样寻找的人",
      "translation": null
    },
    {
      "time": 53.8,
      "time_str": "00:53.800",
      "text": "像我这样碌碌无为的人",
      "translation": null
    },
    {
      "time": 57.59,
      "time_str": "00:57.590",
      "text": "你还见过多少人",
      "translation": null
    },
    {
      "time": 78.64,
      "time_str": "01:18.640",
      "text": "像我这样庸俗的人",
      "translation": null
    },
    {
      "time": 82.83,
      "time_str": "01:22.830",
      "text": "从不喜欢装深沉",
      "translation": null
    },
    {
      "time": 86.54,
      "time_str": "01:26.540",
      "text": "怎么偶尔听到老歌时",
      "translation": null
    },
    {
      "time": 90.62,
      "time_str": "01:30.620",
      "text": "忽然也晃了神",
      "translation": null
    },
    {
      "time": 94.38,
      "time_str": "01:34.380",
      "text": "像我这样懦弱的人",
      "translation": null
    },
    {
      "time": 98.24,
      "time_str": "01:38.240",
      "text": "凡事都要留几分",
      "translation": null
    },
    {
      "time": 102.2,
