  "lyrics": [
    {
      "time": 13.671,
      "time_str": "00:13.671",
      "text": "冷咖啡离开了杯垫",
      "translation": null
    },
    {
      "time": 17.211,
      "time_str": "00:17.211",
      "text": "我忍住的情绪在很后面",
      "translation": null
    },
    {
      "time": 27.02,
      "time_str": "00:27.020",
      "text": "拼命想挽回的从前",
      "translation": null
    },
    {
      "time": 30.551,
      "time_str": "00:30.551",
      "text": "在我脸上依旧清晰可见",
      "translation": null
    },
    {
      "time": 40.329,
      "time_str": "00:40.329",
      "text": "最美的不是下雨天",
      "translation": null
    },
    {
      "time": 43.846,
      "time_str": "00:43.846",
      "text": "是曾与你躲过雨的屋檐",
      "translation": null
    },
    {
      "time": 52.613,
      "time_str": "00:52.613",
      "text": "回忆的画面",
      "translation": null
    },
    {
      "time": 57.23,
      "time_str": "00:57.230",
      "text": "在荡着秋千 梦开始不甜",
      "translation": null
    },
    {
      "time": 65.102,
      "time_str": "01:05.102",
      "text": "你说把爱渐渐 放下会走更远",
      "translation": null
    },
    {
      "time": 71.782,
      "time_str": "01:11.782",
      "text": "又何必去改变 已错过的时间",
      "translation": null
    },
    {
      "time": 78.406,
      "time_str": "01:18.406",
      "text": "你用你的指尖",
      "translation": null
    },
    {
      "time": 81.769,
      "time_str": "01:21.769",
      "text": "阻止我说再见",
      "translation": null
    },
    {
      "time": 85.073,
      "time_str": "01:25.073",
      "text": "想象你在身边 在完全失去之前",
      "translation": null
    },
    {
      "time": 91.755,
      "time_str": "01:31.755",
      "text": "你说把爱渐渐 放下会走更远",
      "translation": null
    },
    {
      "time": 98.411,
      "time_str": "01:38.411",
      "text": "或许命运的签 只让我们遇见",
      "translation": null
    },
    {
      "time": 105.076,
      "time_str": "01:45.076",
      "text": "只让我们相恋",
      "translation": null
    },
    {
      "time": 108.412,
      "time_str": "01:48.412",
      "text": "这一季的秋天",
      "translation": null
    },
    {
      "time": 111.761,
      "time_str": "01:51.761",
      "text": "飘落后才发现 这幸福的碎片",
      "translation": null
    },
    {
      "time": 118.399,
      "time_str": "01:58.399",
      "text": "要我怎么捡",
      "translation": null
    },
