    {
      "time": 18.62,
      "time_str": "00:18.620",
      "text": "长路漫漫伴你闯",
      "translation": null
    },
    {
      "time": 22.54,
      "time_str": "00:22.540",
      "text": "带一身胆色与热肠",
      "translation": null
    },
    {
      "time": 26.61,
      "time_str": "00:26.610",
      "text": "寻自我觅真情",
      "translation": null
    },
    {
      "time": 30.75,
      "time_str": "00:30.750",
      "text": "停步处视作家乡",
      "translation": null
    },
    {
      "time": 34.91,
      "time_str": "00:34.910",
      "text": "投入命运万劫火",
      "translation": null
    },
    {
      "time": 39.0,
      "time_str": "00:39.000",
      "text": "那得失怎么去量",
      "translation": null
    },
    {
      "time": 43.11,
      "time_str": "00:43.110",
      "text": "驰马荡江湖",
      "translation": null
    },
    {
      "time": 47.25,
      "time_str": "00:47.250",
      "text": "谁为往事再紧张",
      "translation": null
    },
    {
      "time": 51.56,
      "time_str": "00:51.560",
      "text": "江湖中...",
      "translation": null
    },
    {
      "time": 53.24,
      "time_str": "00:53.240",
      "text": "英雄汉....",
      "translation": null
    },
    {
      "time": 55.89,
      "time_str": "00:55.890",
      "text": "开心唱....",
      "translation": null
    },
    {
      "time": 59.9,
      "time_str": "00:59.900",
      "text": "谁是最高最强",
      "translation": null
    },
    {
      "time": 63.89,
      "time_str": "01:03.890",
      "text": "我是谁",
      "translation": null
    },
    {
      "time": 67.58,
      "time_str": "01:07.580",
      "text": "从未理俗世欣不欣赏",
      "translation": null
    },
    {
      "time": 73.0,
      "time_str": "01:13.000",
      "text": "迎入日月万里风",
      "translation": null
    },
    {
      "time": 76.18,
      "time_str": "01:16.180",
      "text": "笑揖清风洗我狂",
      "translation": null
    },
    {
      "time": 81.0,
      "time_str": "01:21.000",
      "text": "来日醉卧逍遥",
      "translation": null
    },
    {
      "time": 84.53,
      "time_str": "01:24.530",
      "text": "宁愿锈蚀我缨枪",
      "translation": null
    },
    {
      "time": 88.69,
      "time_str": "01:28.690",
      "text": "Music....",
      "translation": null
    },
    {
      "time": 92.83,
