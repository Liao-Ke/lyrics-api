    },
    {
      "time": 95.27,
      "time_str": "01:35.270",
      "text": "无端白事打一场",
      "translation": null
    },
    {
      "time": 97.3,
      "time_str": "01:37.300",
      "text": "呢个要做大哥",
      "translation": null
    },
    {
      "time": 98.35,
      "time_str": "01:38.350",
      "text": "个个要做王",
      "translation": null
    },
    {
      "time": 99.389,
      "time_str": "01:39.389",
      "text": "搞到精神鬼咁紧张",
      "translation": null
    },
    {
      "time": 101.43,
      "time_str": "01:41.430",
      "text": "我宁愿同你四围荡",
      "translation": null
    },
    {
      "time": 103.23,
      "time_str": "01:43.230",
      "text": "天黑陪你到天光",
      "translation": null
    },
    {
      "time": 105.52,
      "time_str": "01:45.520",
      "text": "同花讲古 同鱼沖凉",
      "translation": null
    },
    {
      "time": 107.9,
      "time_str": "01:47.900",
      "text": "得闲加料燉鸡汤",
      "translation": null
    },
    {
      "time": 109.76,
      "time_str": "01:49.760",
      "text": "望下武林 个个疯狂",
      "translation": null
    },
    {
      "time": 111.44,
      "time_str": "01:51.440",
      "text": "四大天王当四人帮",
      "translation": null
    },
    {
      "time": 113.84,
      "time_str": "01:53.840",
      "text": "无情无义兼无立场",
      "translation": null
    },
    {
      "time": 115.91,
      "time_str": "01:55.910",
      "text": "出刀出棍重出埋枪",
      "translation": null
    },
    {
      "time": 117.93,
      "time_str": "01:57.930",
      "text": "话之佢江湖点鬼样",
      "translation": null
    },
    {
      "time": 120.03,
      "time_str": "02:00.030",
      "text": "长城游罢游长江",
      "translation": null
    },
    {
      "time": 122.25,
      "time_str": "02:02.250",
      "text": "一生陪你做逍遥帮",
      "translation": null
    },
    {
      "time": 124.12,
      "time_str": "02:04.120",
      "text": "要你叫我做拍拖王",
      "translation": null
    },
