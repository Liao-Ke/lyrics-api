  "lyrics": [
    {
      "time": 42.6,
      "time_str": "00:42.600",
      "text": "一个人在这个夜里",
      "translation": null
    },
    {
      "time": 47.21,
      "time_str": "00:47.210",
      "text": "孤单得难以入睡",
      "translation": null
    },
    {
      "time": 51.41,
      "time_str": "00:51.410",
      "text": "真的想找个人来陪",
      "translation": null
    },
    {
      "time": 55.37,
      "time_str": "00:55.370",
      "text": "不愿意一个人喝醉",
      "translation": null
    },
    {
      "time": 59.6,
      "time_str": "00:59.600",
      "text": "醉了以后就会流泪",
      "translation": null
    },
    {
      "time": 62.87,
      "time_str": "01:02.870",
      "text": "数着你给的伤悲",
      "translation": null
    },
    {
      "time": 67.6,
      "time_str": "01:07.600",
      "text": "为什么你总让我憔悴",
      "translation": null
    },
    {
      "time": 71.17,
      "time_str": "01:11.170",
      "text": "别说我的眼泪你无所谓",
      "translation": null
    },
    {
      "time": 74.5,
      "time_str": "01:14.500",
      "text": "看我流泪你头也不回",
      "translation": null
    },
    {
      "time": 78.52,
      "time_str": "01:18.520",
      "text": "哭过了泪干了心变成灰",
      "translation": null
    },
    {
      "time": 82.41,
      "time_str": "01:22.410",
      "text": "我想要的美你还不想给",
      "translation": null
    },
    {
      "time": 86.35,
      "time_str": "01:26.350",
      "text": "伤了的我的心怎去面对",
      "translation": null
    },
    {
      "time": 90.37,
      "time_str": "01:30.370",
      "text": "爱给了你我不后悔",
      "translation": null
    },
    {
      "time": 94.32,
      "time_str": "01:34.320",
      "text": "只希望你给我一次机会",
      "translation": null
    },
    {
      "time": 98.27,
      "time_str": "01:38.270",
      "text": "让我去追让我去飞",
      "translation": null
    },
    {
      "time": 102.32,
      "time_str": "01:42.320",
      "text": "毕竟爱过的心需要安慰",
      "translation": null
    },
    {
      "time": 106.27,
      "time_str": "01:46.270",
      "text": "需要你安慰",
      "translation": null
    },
