      "text": "填词：郑国江",
      "translation": null
    },
    {
      "time": 26.96,
      "time_str": "00:26.960",
      "text": "爱恋没经验",
      "translation": null
    },
    {
      "time": 29.85,
      "time_str": "00:29.850",
      "text": "今天初发现",
      "translation": null
    },
    {
      "time": 34.7,
      "time_str": "00:34.700",
      "text": "遥遥共他见一面",
      "translation": null
    },
    {
      "time": 37.7,
      "time_str": "00:37.700",
      "text": "那份快乐太新鲜",
      "translation": null
    },
    {
      "time": 40.67,
      "time_str": "00:40.670",
      "text": "我一夜失眠",
      "translation": null
    },
    {
      "time": 43.94,
      "time_str": "00:43.940",
      "text": "影子心里现",
      "translation": null
    },
    {
      "time": 48.4,
      "time_str": "00:48.400",
      "text": "问为何共他见一面",
      "translation": null
    },
    {
      "time": 52.45,
      "time_str": "00:52.450",
      "text": "美丽印象似初恋",
      "translation": null
    },
    {
      "time": 58.12,
      "time_str": "00:58.120",
      "text": "默默望著是 默默望著那目光似电",
      "translation": null
    },
    {
      "time": 64.25,
      "time_str": "01:04.250",
      "text": "那刹那接触已令我倒颠",
      "translation": null
    },
    {
      "time": 71.51,
      "time_str": "01:11.510",
      "text": "分分钟都盼望跟他见面",
      "translation": null
    },
    {
      "time": 76.5,
      "time_str": "01:16.500",
      "text": "默默地伫侯亦从来没怨",
      "translation": null
    },
    {
      "time": 79.18,
      "time_str": "01:19.180",
      "text": "分分钟都渴望 与他相见",
      "translation": null
    },
    {
      "time": 83.12,
      "time_str": "01:23.120",
      "text": "在路上碰著亦乐上几天",
      "translation": null
    },
    {
      "time": 87.75,
      "time_str": "01:27.750",
      "text": "轻快的感觉飘上面",
      "translation": null
    },
    {
