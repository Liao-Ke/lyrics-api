    {
      "time": 24.57,
      "time_str": "00:24.570",
      "text": "温柔的星空 应该让你感动",
      "translation": null
    },
    {
      "time": 32.0,
      "time_str": "00:32.000",
      "text": "我在你身后 为你布置一片天空",
      "translation": null
    },
    {
      "time": 38.9,
      "time_str": "00:38.900",
      "text": "不准你难过 替你摆平寂寞",
      "translation": null
    },
    {
      "time": 46.2,
      "time_str": "00:46.200",
      "text": "梦想的重量 全部都交给我",
      "translation": null
    },
    {
      "time": 51.96,
      "time_str": "00:51.960",
      "text": "牵你手 跟着我走 风再大又怎样",
      "translation": null
    },
    {
      "time": 58.64,
      "time_str": "00:58.640",
      "text": "你有了我 再也不会迷路方向",
      "translation": null
    },
    {
      "time": 67.26,
      "time_str": "01:07.260",
      "text": "陪你去看流星雨落在这地球上",
      "translation": null
    },
    {
      "time": 74.32,
      "time_str": "01:14.320",
      "text": "让你的泪落在我肩膀",
      "translation": null
    },
    {
      "time": 81.46,
      "time_str": "01:21.460",
      "text": "要你相信我的爱只肯为你勇敢",
      "translation": null
    },
    {
      "time": 87.6,
      "time_str": "01:27.600",
      "text": "你会看见幸福的所在",
      "translation": null
    },
    {
      "time": 99.0,
      "time_str": "01:39.000",
      "text": "伤感若太多 心丢给我保护",
      "translation": null
    },
    {
      "time": 106.12,
      "time_str": "01:46.120",
      "text": "疲倦的烟火 我会替你都赶走",
      "translation": null
