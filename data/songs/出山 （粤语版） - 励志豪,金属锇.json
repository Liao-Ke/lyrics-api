  "lyrics": [
    {
      "time": 4.349,
      "time_str": "00:04.349",
      "text": "原唱：花粥/王胜男",
      "translation": null
    },
    {
      "time": 20.139,
      "time_str": "00:20.139",
      "text": "闲绕峰铺水碧山间 色潋美湖赏一番",
      "translation": null
    },
    {
      "time": 24.649,
      "time_str": "00:24.649",
      "text": "路上骤遇天姿国色 紫醉翠林戏竹间",
      "translation": null
    },
    {
      "time": 28.908,
      "time_str": "00:28.908",
      "text": "闻青衣小妹舞湿衫 一介素白绣钗簪",
      "translation": null
    },
    {
      "time": 33.418,
      "time_str": "00:33.418",
      "text": "夜魅落下孤身化妖 三界纵未有分隔",
      "translation": null
    },
    {
      "time": 37.93,
      "time_str": "00:37.930",
      "text": "隐隐炼修千祀 善斗法 好周施",
      "translation": null
    },
    {
      "time": 42.44,
      "time_str": "00:42.440",
      "text": "法说道听千遍 誓要探俗世几番",
      "translation": null
    },
    {
      "time": 46.699,
      "time_str": "00:46.699",
      "text": "乱世受爱痴缠 为救侣 淹金山",
      "translation": null
    },
    {
      "time": 51.211,
      "time_str": "00:51.211",
      "text": "眷伫梦碎断桥 仍愿困塔里千个夜晚",
      "translation": null
    },
    {
      "time": 57.726,
      "time_str": "00:57.726",
      "text": "求神破戒远就两相安 然而同途殊命曲终奏散",
      "translation": null
    },
    {
      "time": 64.489,
      "time_str": "01:04.489",
      "text": "浮生千种积劫 屡教世俗苦贪痴",
      "translation": null
    },
    {
      "time": 69.0,
      "time_str": "01:09.000",
      "text": "缘始悲喜交接 屡煞燕侣寄空思",
      "translation": null
    },
    {
      "time": 73.259,
      "time_str": "01:13.259",
      "text": "仇怨恩丝斩断 你我再没有相依",
      "translation": null
    },
    {
      "time": 77.767,
      "time_str": "01:17.767",
      "text": "凡间方知苦涩 情爱有变故世一曲了之",
      "translation": null
    },
    {
      "time": 85.784,
      "time_str": "01:25.784",
      "text": "RAP:",
      "translation": null
    },
    {
      "time": 91.296,
      "time_str": "01:31.296",
      "text": "色即是空 空即是色",
      "translation": null
    },
    {
      "time": 93.3,
      "time_str": "01:33.300",
      "text": "红尘俗世扰清静",
      "translation": null
    },
    {
      "time": 95.806,
      "time_str": "01:35.806",
      "text": "色不异空 空不异色",
      "translation": null
    },
    {
      "time": 98.062,
      "time_str": "01:38.062",
      "text": "颠倒乾坤 六根不净",
      "translation": null
    },
    {
      "time": 100.066,
      "time_str": "01:40.066",
      "text": "人若是无情不如妖",
      "translation": null
    },
    {
      "time": 102.32,
      "time_str": "01:42.320",
      "text": "只要是有情妖亦人",
      "translation": null
    },
    {
      "time": 104.576,
      "time_str": "01:44.576",
      "text": "借问世间情为何物",
      "translation": null
    },
    {
      "time": 106.83,
      "time_str": "01:46.830",
      "text": "直教人生死相许",
      "translation": null
    },
    {
      "time": 109.337,
      "time_str": "01:49.337",
      "text": "浮生千种积劫 屡教世俗苦贪痴",
      "translation": null
