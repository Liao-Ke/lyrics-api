  "lyrics": [
    {
      "time": 28.19,
      "time_str": "00:28.190",
      "text": "常常习惯性的想你的需要",
      "translation": null
    },
    {
      "time": 34.4,
      "time_str": "00:34.400",
      "text": "不知你现在可好",
      "translation": null
    },
    {
      "time": 39.22,
      "time_str": "00:39.220",
      "text": "换你一个微笑",
      "translation": null
    },
    {
      "time": 42.58,
      "time_str": "00:42.580",
      "text": "我愿为爱乞讨",
      "translation": null
    },
    {
      "time": 45.78,
      "time_str": "00:45.780",
      "text": "愿永远做你的依靠",
      "translation": null
    },
    {
      "time": 52.87,
      "time_str": "00:52.870",
      "text": "果然没有爱也没有了烦恼",
      "translation": null
    },
    {
      "time": 58.94,
      "time_str": "00:58.940",
      "text": "只是记忆抹不掉",
      "translation": null
    },
    {
      "time": 64.22,
      "time_str": "01:04.220",
      "text": "你烫过的衣服",
      "translation": null
    },
    {
      "time": 67.12,
      "time_str": "01:07.120",
      "text": "仿佛还有温度",
      "translation": null
    },
    {
      "time": 70.46,
      "time_str": "01:10.460",
      "text": "却抵挡不了我寒冷孤独",
      "translation": null
    },
    {
      "time": 76.98,
      "time_str": "01:16.980",
      "text": "回忆总想哭",
      "translation": null
    },
    {
      "time": 79.67,
      "time_str": "01:19.670",
      "text": "一个人太孤独",
      "translation": null
    },
    {
      "time": 82.37,
      "time_str": "01:22.370",
      "text": "这段情千山万水却迷了路",
      "translation": null
    },
    {
      "time": 88.58,
      "time_str": "01:28.580",
      "text": "千辛万苦的付出",
      "translation": null
    },
    {
      "time": 91.58,
      "time_str": "01:31.580",
      "text": "早已放弃了归路",
      "translation": null
    },
    {
      "time": 94.58,
      "time_str": "01:34.580",
      "text": "爱到深处却只剩下无助",
      "translation": null
    },
    {
      "time": 101.44,
      "time_str": "01:41.440",
      "text": "回忆总想哭",
      "translation": null
    },
    {
      "time": 104.28,
      "time_str": "01:44.280",
      "text": "一个人的幸福",
      "translation": null
    },
    {
      "time": 106.97,
      "time_str": "01:46.970",
      "text": "就像你最后给我那些叮嘱",
      "translation": null
    },
    {
      "time": 113.1,
      "time_str": "01:53.100",
      "text": "爱如何形同陌路",
      "translation": null
    },
    {
      "time": 116.16,
      "time_str": "01:56.160",
      "text": "你走有你走的苦",
      "translation": null
    },
    {
      "time": 119.24,
      "time_str": "01:59.240",
      "text": "怎知你走以后不会为我哭",
