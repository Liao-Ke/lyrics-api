  "lyrics": [
    {
      "time": 22.89,
      "time_str": "00:22.890",
      "text": "可不可不要这么样徘徊在目光内",
      "translation": null
    },
    {
      "time": 29.76,
      "time_str": "00:29.760",
      "text": "你会察觉到我根本寂寞难耐",
      "translation": null
    },
    {
      "time": 37.66,
      "time_str": "00:37.660",
      "text": "即使千多百个深夜曾在梦境内",
      "translation": null
    },
    {
      "time": 44.07,
      "time_str": "00:44.070",
      "text": "我有吻过你这毕竟并没存在",
      "translation": null
    },
    {
      "time": 51.45,
      "time_str": "00:51.450",
      "text": "人声车声开始消和逝",
      "translation": null
    },
    {
      "time": 55.02,
      "time_str": "00:55.020",
      "text": "无声挣扎有个情感奴隶",
      "translation": null
    },
    {
      "time": 58.43,
      "time_str": "00:58.430",
      "text": "是我多么的想她",
      "translation": null
    },
    {
      "time": 60.149,
      "time_str": "01:00.149",
      "text": "但我偏偏只得无尽叹谓",
      "translation": null
    },
    {
      "time": 65.659,
      "time_str": "01:05.659",
      "text": "其实每次见你我也着迷",
      "translation": null
    },
    {
      "time": 69.06,
      "time_str": "01:09.060",
      "text": "无奈你我各有角色范围",
      "translation": null
    },
    {
      "time": 72.709,
      "time_str": "01:12.709",
      "text": "就算在寂寞梦内超出好友关系",
      "translation": null
    },
    {
      "time": 79.959,
      "time_str": "01:19.959",
      "text": "唯在暗里爱你暗里着迷",
      "translation": null
    },
    {
      "time": 83.239,
      "time_str": "01:23.239",
      "text": "无谓要你惹上各种问题",
