    {
      "time": 32.446,
      "time_str": "00:32.446",
      "text": "自从认识你的那一天开始",
      "translation": null
    },
    {
      "time": 36.24,
      "time_str": "00:36.240",
      "text": "我的生活就变了模样",
      "translation": null
    },
    {
      "time": 40.367,
      "time_str": "00:40.367",
      "text": "心里装的一切全都是你",
      "translation": null
    },
    {
      "time": 44.329,
      "time_str": "00:44.329",
      "text": "已经不能没有你",
      "translation": null
    },
    {
      "time": 48.167,
      "time_str": "00:48.167",
      "text": "自从和你在一起那天开始",
      "translation": null
    },
    {
      "time": 52.279,
      "time_str": "00:52.279",
      "text": "我费尽心机努力爱你",
      "translation": null
    },
    {
      "time": 56.375,
      "time_str": "00:56.375",
      "text": "再苦再累再艰难我愿意",
      "translation": null
    },
    {
      "time": 60.224,
      "time_str": "01:00.224",
      "text": "只要你开心",
      "translation": null
    },
    {
      "time": 64.857,
      "time_str": "01:04.857",
      "text": "上帝请保佑我的爱",
      "translation": null
    },
    {
      "time": 72.687,
      "time_str": "01:12.687",
      "text": "我愿意用一切来换取",
      "translation": null
    },
    {
      "time": 80.444,
      "time_str": "01:20.444",
      "text": "可是到最后我却为什么就是留不住你的心",
      "translation": null
    },
    {
      "time": 92.442,
      "time_str": "01:32.442",
      "text": "你曾说过会给我永远的爱",
      "translation": null
    },
    {
      "time": 96.439,
      "time_str": "01:36.439",
      "text": "现在我却独自一人在徘徊",
      "translation": null
    },
    {
      "time": 100.29,
      "time_str": "01:40.290",
      "text": "你根本做不到",
      "translation": null
    },
    {
      "time": 102.411,
      "time_str": "01:42.411",
      "text": "为何还要欺骗一颗已经属于你的心",
      "translation": null
    },
    {
      "time": 108.474,
      "time_str": "01:48.474",
      "text": "难道这就是你曾经说得爱",
      "translation": null
    },
    {
      "time": 112.41,
      "time_str": "01:52.410",
      "text": "你就这样悄然无声的离开",
      "translation": null
    },
    {
      "time": 117.907,
      "time_str": "01:57.907",
      "text": "你可知道我的心",
      "translation": null
    },
    {
      "time": 120.423,
      "time_str": "02:00.423",
      "text": "痛苦的就像被活埋",
      "translation": null
    },
    {
      "time": 144.257,
      "time_str": "02:24.257",
      "text": "自从丢了你那一天开始",
      "translation": null
    },
    {
      "time": 148.281,
      "time_str": "02:28.281",
      "text": "我费劲心机四处找你",
      "translation": null
    },
    {
      "time": 152.548,
      "time_str": "02:32.548",
      "text": "忽然看到你们走在一起",
