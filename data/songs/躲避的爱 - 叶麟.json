{
  "title": "躲避的爱",
  "title_raw": "躲避的爱",
  "version": null,
  "artist": "叶麟",
  "group_key": "躲避的爱|叶麟",
  "writers": {
    "lyricist": null,
    "composer": null,
    "arranger": null
  },
  "lyrics": [
    {
      "time": 2.536,
      "time_str": "00:02.536",
      "text": "让我喜欢上了你",
      "translation": null
    },
    {
      "time": 4.44,
      "time_str": "00:04.440",
      "text": "你却开始后悔",
      "translation": null
    },
    {
      "time": 6.34,
      "time_str": "00:06.340",
      "text": "我不是你想象中的那个人",
      "translation": null
    },
    {
      "time": 9.44,
      "time_str": "00:09.440",
      "text": "在别人眼中我是微不足道的",
      "translation": null
    },
    {
      "time": 12.144,
      "time_str": "00:12.144",
      "text": "当每天你给我的爱更多",
      "translation": null
    },
    {
      "time": 15.16,
      "time_str": "00:15.160",
      "text": "我就是越在痛苦之中",
      "translation": null
    },
    {
      "time": 17.66,
      "time_str": "00:17.660",
      "text": "面对我你没有勇气",
      "translation": null
    },
    {
      "time": 19.668,
      "time_str": "00:19.668",
      "text": "真的没有想去伤害我",
      "translation": null
    },
    {
      "time": 22.459,
      "time_str": "00:22.459",
      "text": "现在你除了对我说对不起",
      "translation": null
    },
    {
      "time": 25.386,
      "time_str": "00:25.386",
      "text": "你还能说些什么",
      "translation": null
    },
    {
      "time": 27.439,
      "time_str": "00:27.439",
      "text": "难道说我真的爱过你",
      "translation": null
    },
    {
      "time": 30.677,
      "time_str": "00:30.677",
      "text": "我的宝贝呵呵",
      "translation": null
    },
    {
      "time": 44.632,
      "time_str": "00:44.632",
      "text": "在秋天的季节下自己像个傻瓜似的",
      "translation": null
    },
    {
      "time": 47.232,
      "time_str": "00:47.232",
      "text": "为什么这么讨厌明媚的阳光",
      "translation": null
    },
    {
      "time": 49.132,
      "time_str": "00:49.132",
      "text": "喜欢黑色的人就是缺乏安全感",
      "translation": null
    },
    {
      "time": 51.886,
      "time_str": "00:51.886",
      "text": "讨厌阳光",
      "translation": null
    },
    {
      "time": 53.409,
      "time_str": "00:53.409",
      "text": "喜欢躲避在阴暗的地方",
      "translation": null
    },
    {
      "time": 56.114,
      "time_str": "00:56.114",
      "text": "对如果有人认出我",
      "translation": null
    },
    {
      "time": 57.914,
      "time_str": "00:57.914",
      "text": "问我为什么伤心流泪",
      "translation": null
    },
    {
      "time": 59.565,
      "time_str": "00:59.565",
      "text": "我也不会告诉他",
      "translation": null
    },
    {
      "time": 60.715,
      "time_str": "01:00.715",
      "text": "我讨厌这样这样的生活",
      "translation": null
    },
    {
      "time": 62.515,
      "time_str": "01:02.515",
      "text": "我讨厌这样迷失的自我",
      "translation": null
    },
    {
      "time": 64.805,
      "time_str": "01:04.805",
      "text": "我习惯这样躲避阳光耶",
      "translation": null
    },
    {
      "time": 67.95,
      "time_str": "01:07.950",
      "text": "拼命地努力在奔跑",
      "translation": null
    },
    {
      "time": 70.01,
      "time_str": "01:10.010",
      "text": "但是没有躲避的地方",
      "translation": null
    },
    {
      "time": 71.901,
      "time_str": "01:11.901",
      "text": "真的很想马上忘掉你",
      "translation": null
    },
    {
      "time": 73.651,
      "time_str": "01:13.651",
      "text": "可是自己无论怎样努力",
      "translation": null
    },
    {
      "time": 75.502,
      "time_str": "01:15.502",
      "text": "终究还是于事无补耶啊哈",
      "translation": null
    },
    {
      "time": 79.776,
      "time_str": "01:19.776",
      "text": "回忆过去你的微笑曾经抚摩过我两道双手",
      "translation": null
    },
    {
      "time": 83.327,
      "time_str": "01:23.327",
      "text": "厌倦了思念疲惫了再去想你",
      "translation": null
    },
    {
      "time": 85.69,
      "time_str": "01:25.690",
      "text": "掩埋在人群中",
      "translation": null
    },
    {
      "time": 87.254,
      "time_str": "01:27.254",
      "text": "有说有笑好想忘记你",
      "translation": null
    },
    {
      "time": 89.06,
      "time_str": "01:29.060",
      "text": "但是眼泪划落却是无声无息",
      "translation": null
    },
    {
      "time": 91.644,
      "time_str": "01:31.644",
      "text": "我要躲避太阳的照射",
      "translation": null
    },
    {
      "time": 93.445,
      "time_str": "01:33.445",
      "text": "我拼命地奔跑",
      "translation": null
    },
    {
      "time": 95.16,
      "time_str": "01:35.160",
      "text": "但是太阳为什么总在你我头上",
      "translation": null
    },
    {
      "time": 97.677,
      "time_str": "01:37.677",
      "text": "我真的想把你忘地一干二净",
      "translation": null
    },
    {
      "time": 99.954,
      "time_str": "01:39.954",
      "text": "但是你在我的心里怎么也无法抹去",
      "translation": null
    },
    {
      "time": 103.76,
      "time_str": "01:43.760",
      "text": "朋友们都认为我已经忘掉你",
      "translation": null
    },
    {
      "time": 105.972,
      "time_str": "01:45.972",
      "text": "但是我快要崩溃了自己",
      "translation": null
    },
    {
      "time": 108.73,
      "time_str": "01:48.730",
      "text": "很想忘记你",
      "translation": null
    },
    {
      "time": 109.173,
      "time_str": "01:49.173",
      "text": "想把记忆抹去",
      "translation": null
    },
    {
      "time": 110.159,
      "time_str": "01:50.159",
      "text": "但力不从心很像扎在肉里的一根针一根刺",
      "translation": null
    },
    {
      "time": 114.908,
      "time_str": "01:54.908",
      "text": "在伤口上撒把盐痛得麻痹自己",
      "translation": null
    },
    {
      "time": 117.806,
      "time_str": "01:57.806",
      "text": "但是你的名字还是挥之不去",
      "translation": null
    },
    {
      "time": 120.721,
      "time_str": "02:00.721",
      "text": "回忆死去的爱情就好象现在还在一起",
      "translation": null
    },
    {
      "time": 126.464,
      "time_str": "02:06.464",
      "text": "如果眼泪能够充当你的身影",
      "translation": null
    },
    {
      "time": 128.714,
      "time_str": "02:08.714",
      "text": "哪怕我宁可一直这样哭泣",
      "translation": null
    },
    {
      "time": 130.915,
      "time_str": "02:10.915",
      "text": "哪怕海水泪水汇成海水",
      "translation": null
    },
    {
      "time": 133.7,
      "time_str": "02:13.700",
      "text": "我也会选择忘记继续好好活下去",
      "translation": null
    },
    {
      "time": 139.141,
      "time_str": "02:19.141",
      "text": "其实我想这样继续唱下去",
      "translation": null
    },
    {
      "time": 141.546,
      "time_str": "02:21.546",
      "text": "但是已经忍不住了",
      "translation": null
    },
    {
      "time": 144.558,
      "time_str": "02:24.558",
      "text": "我想说盼盼",
      "translation": null
    },
    {
      "time": 150.774,
      "time_str": "02:30.774",
      "text": "我真的好爱你",
      "translation": null
    },
    {
      "time": 153.681,
      "time_str": "02:33.681",
      "text": "我真的没有办法去忘记你",
      "translation": null
    },
    {
      "time": 162.222,
      "time_str": "02:42.222",
      "text": "要我怎么做",
      "translation": null
    },
    {
      "time": 164.121,
      "time_str": "02:44.121",
      "text": "你才能回到我身边",
      "translation": null
    },
    {
      "time": 174.216,
      "time_str": "02:54.216",
      "text": "你说过不会放弃我的",
      "translation": null
    },
    {
      "time": 177.25,
      "time_str": "02:57.250",
      "text": "你说过会爱我一生一世的",
      "translation": null
    },
    {
      "time": 180.522,
      "time_str": "03:00.522",
      "text": "为什么到最后你还是选择了离去",
      "translation": null
    },
    {
      "time": 187.291,
      "time_str": "03:07.291",
      "text": "我说过可以为你改变的",
      "translation": null
    },
    {
      "time": 191.34,
      "time_str": "03:11.340",
      "text": "为什么你连一次机会都不给我",
      "translation": null
    },
    {
      "time": 199.54,
      "time_str": "03:19.540",
      "text": "你说你很喜欢小孩",
      "translation": null
    },
    {
      "time": 202.377,
      "time_str": "03:22.377",
      "text": "我答应你不抽烟不喝酒",
      "translation": null
    },
    {
      "time": 207.519,
      "time_str": "03:27.519",
      "text": "你说我不懂事我可以改",
      "translation": null
    },
    {
      "time": 211.816,
      "time_str": "03:31.816",
      "text": "为什么你说分手的时候是那么的坚决",
      "translation": null
    },
    {
      "time": 216.458,
      "time_str": "03:36.458",
      "text": "我哭的如此伤心你都不再理会我了",
      "translation": null
    },
    {
      "time": 221.132,
      "time_str": "03:41.132",
      "text": "触摸手上的烟疤",
      "translation": null
    },
    {
      "time": 223.764,
      "time_str": "03:43.764",
      "text": "回想起我们以前的日子",
      "translation": null
    },
    {
      "time": 226.627,
      "time_str": "03:46.627",
      "text": "昨天每一个地方",
      "translation": null
    },
    {
      "time": 230.934,
      "time_str": "03:50.934",
      "text": "我真的好想你",
      "translation": null
    },
    {
      "time": 233.85,
      "time_str": "03:53.850",
      "text": "想打电话给你时",
      "translation": null
    },
    {
      "time": 237.128,
      "time_str": "03:57.128",
      "text": "拿了又放下拿了又放下",
      "translation": null
    },
    {
      "time": 241.134,
      "time_str": "04:01.134",
      "text": "天天晚上睡不着觉",
      "translation": null
    },
    {
      "time": 245.867,
      "time_str": "04:05.867",
      "text": "求你别离开我",
      "translation": null
    },
    {
      "time": 252.146,
      "time_str": "04:12.146",
      "text": "我真的爱你啊",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "躲避的爱 - 叶麟.lrc"
}