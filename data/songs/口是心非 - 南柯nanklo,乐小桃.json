  "lyrics": [
    {
      "time": 8.446,
      "time_str": "00:08.446",
      "text": "改编原唱：丫蛋蛋/崔铭浩",
      "translation": null
    },
    {
      "time": 9.444,
      "time_str": "00:09.444",
      "text": "翻唱：南柯nanklo/舒岚",
      "translation": null
    },
    {
      "time": 10.942,
      "time_str": "00:10.942",
      "text": "后期：商陆",
      "translation": null
    },
    {
      "time": 13.691,
      "time_str": "00:13.691",
      "text": "美工：艾米",
      "translation": null
    },
    {
      "time": 15.945,
      "time_str": "00:15.945",
      "text": "岚：",
      "translation": null
    },
    {
      "time": 17.198,
      "time_str": "00:17.198",
      "text": "口是心非你深情的承诺",
      "translation": null
    },
    {
      "time": 19.94,
      "time_str": "00:19.940",
      "text": "都随着西风飘渺远走",
      "translation": null
    },
    {
      "time": 24.377,
      "time_str": "00:24.377",
      "text": "痴人梦话我钟情的倚托",
      "translation": null
    },
    {
      "time": 27.627,
      "time_str": "00:27.627",
      "text": "就像枯萎凋零的花朵",
      "translation": null
    },
    {
      "time": 30.879,
      "time_str": "00:30.879",
      "text": "柯：",
      "translation": null
    },
    {
      "time": 31.587,
      "time_str": "00:31.587",
      "text": "星火燎原我热情的眼眸",
      "translation": null
    },
    {
      "time": 34.797,
      "time_str": "00:34.797",
      "text": "曾点亮最灿烂的天空",
      "translation": null
    },
    {
      "time": 39.045,
      "time_str": "00:39.045",
      "text": "晴天霹雳你绝情的放手",
      "translation": null
    },
    {
      "time": 42.044,
      "time_str": "00:42.044",
      "text": "在我最需要你的时候",
      "translation": null
    },
    {
      "time": 45.046,
      "time_str": "00:45.046",
      "text": "岚：",
      "translation": null
    },
    {
      "time": 45.791,
      "time_str": "00:45.791",
      "text": "于是爱恨交错人消瘦",
      "translation": null
    },
    {
      "time": 49.539,
      "time_str": "00:49.539",
      "text": "怕是怕这些苦没来由",
      "translation": null
    },
    {
      "time": 52.491,
      "time_str": "00:52.491",
      "text": "柯：",
      "translation": null
    },
    {
      "time": 52.991,
      "time_str": "00:52.991",
      "text": "于是悲欢起落人静默",
      "translation": null
    },
    {
      "time": 56.743,
      "time_str": "00:56.743",
      "text": "等一等这些伤会自由",
      "translation": null
    },
    {
      "time": 59.75,
      "time_str": "00:59.750",
      "text": "合：",
      "translation": null
    },
    {
