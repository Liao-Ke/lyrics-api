      "text": "岚：",
      "translation": null
    },
    {
      "time": 90.492,
      "time_str": "01:30.492",
      "text": "口是心非你矫情的面容",
      "translation": null
    },
    {
      "time": 93.499,
      "time_str": "01:33.499",
      "text": "都烙印在心灵的角落",
      "translation": null
    },
    {
      "time": 97.751,
      "time_str": "01:37.751",
      "text": "无话可说我纵情的结果",
      "translation": null
    },
    {
      "time": 100.714,
      "time_str": "01:40.714",
      "text": "就像残破光秃的山头",
      "translation": null
    },
    {
      "time": 103.963,
      "time_str": "01:43.963",
      "text": "柯：",
      "translation": null
    },
    {
      "time": 104.962,
      "time_str": "01:44.962",
      "text": "浑然天成我纯情的悸动",
      "translation": null
    },
    {
      "time": 108.215,
      "time_str": "01:48.215",
      "text": "曾奔放最滚烫的节奏",
      "translation": null
    },
    {
      "time": 112.461,
      "time_str": "01:52.461",
      "text": "不可收拾你滥情的抛空",
      "translation": null
    },
    {
      "time": 115.469,
      "time_str": "01:55.469",
      "text": "所有晶莹剔透的感受",
      "translation": null
    },
    {
