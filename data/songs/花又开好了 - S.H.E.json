  "lyrics": [
    {
      "time": 7.35,
      "time_str": "00:07.350",
      "text": "终于思念的人相聚",
      "translation": null
    },
    {
      "time": 12.28,
      "time_str": "00:12.280",
      "text": "终于所有的伤痊愈",
      "translation": null
    },
    {
      "time": 15.46,
      "time_str": "00:15.460",
      "text": "花又开好了 终于",
      "translation": null
    },
    {
      "time": 19.51,
      "time_str": "00:19.510",
      "text": "心又长满了 勇气",
      "translation": null
    },
    {
      "time": 40.23,
      "time_str": "00:40.230",
      "text": "看一场电影 主角是自己",
      "translation": null
    },
    {
      "time": 43.98,
      "time_str": "00:43.980",
      "text": "倒放着人生的缩影",
      "translation": null
    },
    {
      "time": 48.28,
      "time_str": "00:48.280",
      "text": "回忆是天赋 也是种天敌",
      "translation": null
    },
    {
      "time": 52.28,
      "time_str": "00:52.280",
      "text": "让眼泪 无尽",
      "translation": null
    },
    {
      "time": 56.52,
      "time_str": "00:56.520",
      "text": "不想长大曾经 回不去的光阴",
      "translation": null
    },
    {
      "time": 60.39,
      "time_str": "01:00.390",
      "text": "谁带我到陌生的境地",
      "translation": null
    },
    {
      "time": 64.439,
      "time_str": "01:04.439",
      "text": "蒸发一颗泪滴 需要多少叹息 谁懂我",
      "translation": null
    },
    {
      "time": 72.31,
      "time_str": "01:12.310",
      "text": "SHERO TO ZERO",
      "translation": null
    },
    {
      "time": 75.239,
      "time_str": "01:15.239",
      "text": "落入最孤单的决堤",
      "translation": null
    },
    {
      "time": 79.55,
      "time_str": "01:19.550",
      "text": "我一次一次想放弃",
      "translation": null
    },
    {
      "time": 83.16,
      "time_str": "01:23.160",
      "text": "花又开好的 可能",
      "translation": null
    },
    {
      "time": 87.22,
      "time_str": "01:27.220",
      "text": "或许不存在 机率",
      "translation": null
    },
    {
      "time": 91.34,
      "time_str": "01:31.340",
      "text": "走过最绝望的崎岖",
      "translation": null
    },
    {
      "time": 95.83,
      "time_str": "01:35.830",
      "text": "我一次一次问自己",
      "translation": null
    },
    {
      "time": 99.45,
      "time_str": "01:39.450",
      "text": "花又开好的 那天",
      "translation": null
    },
    {
      "time": 103.51,
      "time_str": "01:43.510",
      "text": "还有多遥远 距离",
      "translation": null
    },
    {
      "time": 121.0,
      "time_str": "02:01.000",
      "text": "唱一首歌 主角是自己",
      "translation": null
    },
    {
      "time": 124.54,
      "time_str": "02:04.540",
      "text": "当时你人生在哪里",
      "translation": null
    },
    {
      "time": 128.6,
      "time_str": "02:08.600",
      "text": "那年搬进 女生宿舍里",
      "translation": null
    },
    {
      "time": 132.8,
      "time_str": "02:12.800",
      "text": "从此笑和泪都有你",
      "translation": null
    },
    {
      "time": 136.95,
      "time_str": "02:16.950",
      "text": "闯进一座雨林 奇幻旅程有你",
      "translation": null
    },
    {
      "time": 141.07,
      "time_str": "02:21.070",
      "text": "新的世界才学会美丽",
      "translation": null
    },
    {
      "time": 144.94,
      "time_str": "02:24.940",
      "text": "当恶梦都过去 睁开眼睛是你 在等我",
      "translation": null
    },
    {
