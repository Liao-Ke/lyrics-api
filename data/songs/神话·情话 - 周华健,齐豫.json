  "lyrics": [
    {
      "time": 24.097,
      "time_str": "00:24.097",
      "text": "合：爱是愉快是难过是陶醉是情绪",
      "translation": null
    },
    {
      "time": 27.333,
      "time_str": "00:27.333",
      "text": "或在日后视作传奇",
      "translation": null
    },
    {
      "time": 30.556,
      "time_str": "00:30.556",
      "text": "爱是盟约是习惯是时间是白发",
      "translation": null
    },
    {
      "time": 33.78,
      "time_str": "00:33.780",
      "text": "也叫你我乍惊乍喜",
      "translation": null
    },
    {
      "time": 37.294,
      "time_str": "00:37.294",
      "text": "完全遗忘自己",
      "translation": null
    },
    {
      "time": 40.334,
      "time_str": "00:40.334",
      "text": "竟可相许生与死",
      "translation": null
    },
    {
      "time": 43.765,
      "time_str": "00:43.765",
      "text": "来日谁来问起",
      "translation": null
    },
    {
      "time": 46.82,
      "time_str": "00:46.820",
      "text": "天高风急双双远飞",
      "translation": null
    },
    {
      "time": 50.047,
      "time_str": "00:50.047",
      "text": "爱是微笑是狂笑是傻笑是玩笑",
      "translation": null
    },
    {
      "time": 53.3,
      "time_str": "00:53.300",
      "text": "或是为着害怕寂寥",
      "translation": null
    },
    {
      "time": 56.537,
      "time_str": "00:56.537",
      "text": "爱是何价是何故在何世",
      "translation": null
    },
    {
      "time": 59.186,
      "time_str": "00:59.186",
      "text": "又何以对这世界雪中送火",
      "translation": null
    },
    {
      "time": 63.245,
      "time_str": "01:03.245",
      "text": "谁还祈求什么",
      "translation": null
    },
    {
      "time": 66.259,
      "time_str": "01:06.259",
      "text": "可歌可泣的结果",
      "translation": null
    },
    {
      "time": 69.707,
      "time_str": "01:09.707",
      "text": "谁能承受后果",
      "translation": null
    },
    {
      "time": 72.768,
      "time_str": "01:12.768",
      "text": "翻天覆海不枉最初",
      "translation": null
    },
    {
      "time": 75.248,
      "time_str": "01:15.248",
      "text": "啊……",
      "translation": null
    },
    {
      "time": 85.733,
      "time_str": "01:25.733",
      "text": "有你有我雪中送火",
      "translation": null
    },
    {
      "time": 88.151,
      "time_str": "01:28.151",
      "text": "男：爱在迷迷糊糊",
      "translation": null
    },
    {
      "time": 89.802,
      "time_str": "01:29.802",
      "text": "盘古初开便开始",
      "translation": null
    },
    {
      "time": 91.751,
      "time_str": "01:31.751",
      "text": "这浪浪漫漫旧故事",
      "translation": null
    },
    {
      "time": 94.634,
      "time_str": "01:34.634",
      "text": "女：爱在朦朦胧胧",
      "translation": null
    },
    {
      "time": 96.261,
      "time_str": "01:36.261",
      "text": "前生今生和他生",
      "translation": null
    },
    {
      "time": 98.651,
      "time_str": "01:38.651",
      "text": "怕错过了也不会知",
      "translation": null
    },
    {
      "time": 101.181,
      "time_str": "01:41.181",
      "text": "男：跌落茫茫红尘",
      "translation": null
    },
    {
      "time": 102.728,
      "time_str": "01:42.728",
      "text": "南北西东亦相依",
      "translation": null
    },
    {
      "time": 104.75,
      "time_str": "01:44.750",
      "text": "怕独自活着没意义",
      "translation": null
    },
    {
      "time": 107.578,
      "time_str": "01:47.578",
      "text": "女：爱是来来回回",
      "translation": null
    },
    {
      "time": 109.235,
      "time_str": "01:49.235",
      "text": "情丝一丝又一丝",
      "translation": null
    },
    {
      "time": 111.708,
      "time_str": "01:51.708",
      "text": "合：至你与我此生永不阔别时",
      "translation": null
    },
