  "lyrics": [
    {
      "time": 15.29,
      "time_str": "00:15.290",
      "text": "她说她找不到能爱的人",
      "translation": null
    },
    {
      "time": 18.92,
      "time_str": "00:18.920",
      "text": "所以宁愿居无定所的过一生",
      "translation": null
    },
    {
      "time": 23.34,
      "time_str": "00:23.340",
      "text": "从这个安静的镇",
      "translation": null
    },
    {
      "time": 25.35,
      "time_str": "00:25.350",
      "text": "到下一个热闹的城",
      "translation": null
    },
    {
      "time": 27.4,
      "time_str": "00:27.400",
      "text": "来去自由从来不等红绿灯",
      "translation": null
    },
    {
      "time": 32.76,
      "time_str": "00:32.760",
      "text": "酒吧里头喧哗的音乐声",
      "translation": null
    },
    {
      "time": 36.36,
      "time_str": "00:36.360",
      "text": "让她暂时忘了女人的身份",
      "translation": null
    },
    {
      "time": 40.23,
      "time_str": "00:40.230",
      "text": "放肆摇动着灵魂",
      "translation": null
    },
    {
      "time": 42.53,
      "time_str": "00:42.530",
      "text": "贴着每个耳朵问",
      "translation": null
    },
    {
      "time": 44.61,
      "time_str": "00:44.610",
      "text": "到底哪里才有够好的男人",
      "translation": null
    },
    {
      "time": 49.93,
      "time_str": "00:49.930",
      "text": "没有爱情发生",
      "translation": null
    },
    {
      "time": 53.24,
      "time_str": "00:53.240",
      "text": "她只好趁着酒意释放青春",
      "translation": null
    },
    {
      "time": 57.52,
      "time_str": "00:57.520",
      "text": "刻意凝视每个眼神",
      "translation": null
    },
    {
      "time": 61.4,
      "time_str": "01:01.400",
      "text": "却只看见自己也不够诚恳",
      "translation": null
    },
    {
      "time": 65.25,
      "time_str": "01:05.250",
      "text": "推开关了的门",
      "translation": null
    },
    {
      "time": 68.61,
      "time_str": "01:08.610",
      "text": "在风中晾干脸上的泪痕",
      "translation": null
    },
    {
      "time": 72.889,
      "time_str": "01:12.889",
      "text": "然后在早春陌生的街头狂奔",
      "translation": null
    },
    {
      "time": 77.4,
      "time_str": "01:17.400",
      "text": "直到这世界忘了她这个人",
      "translation": null
    },
    {
      "time": 96.74,
      "time_str": "01:36.740",
      "text": "酒吧里头喧哗的音乐声",
