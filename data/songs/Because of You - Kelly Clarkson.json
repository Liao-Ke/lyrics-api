    {
      "time": 15.01,
      "time_str": "00:15.010",
      "text": "I will not make the same mistakes that you did",
      "translation": "我不会重复你犯过的错误"
    },
    {
      "time": 20.56,
      "time_str": "00:20.560",
      "text": "I will not let myself cause my heart so much misery",
      "translation": "也不会让内心承受如此痛苦"
    },
    {
      "time": 28.69,
      "time_str": "00:28.690",
