  "lyrics": [
    {
      "time": 24.36,
      "time_str": "00:24.360",
      "text": "也许我一直害怕有答案",
      "translation": null
    },
    {
      "time": 29.9,
      "time_str": "00:29.900",
      "text": "也许爱静静在风里打转",
      "translation": null
    },
    {
      "time": 35.69,
      "time_str": "00:35.690",
      "text": "离开 释怀 很短暂 又重来",
      "translation": null
    },
    {
      "time": 41.84,
      "time_str": "00:41.840",
      "text": "有时候自问自答",
      "translation": null
    },
    {
      "time": 46.83,
      "time_str": "00:46.830",
      "text": "我不要困难把我们挤散",
      "translation": null
    },
    {
      "time": 52.34,
      "time_str": "00:52.340",
      "text": "我责备自己那么不勇敢",
      "translation": null
    },
    {
      "time": 57.89,
      "time_str": "00:57.890",
      "text": "遗憾没有到达",
      "translation": null
    },
    {
      "time": 60.7,
      "time_str": "01:00.700",
      "text": "拥抱过还是害怕",
      "translation": null
    },
    {
      "time": 63.44,
      "time_str": "01:03.440",
      "text": "用力推开你 我依然留下",
      "translation": null
    },
    {
      "time": 69.19,
      "time_str": "01:09.190",
      "text": "有一束光 那瞬间",
      "translation": null
    },
    {
      "time": 72.35,
      "time_str": "01:12.350",
      "text": "是什么痛得刺眼",
      "translation": null
    },
    {
      "time": 74.88,
      "time_str": "01:14.880",
      "text": "你的视线 是谅解",
      "translation": null
    },
    {
      "time": 77.69,
      "time_str": "01:17.690",
      "text": "为什么舍不得熄灭",
      "translation": null
    },
    {
      "time": 82.02,
      "time_str": "01:22.020",
      "text": "我逆着光 却看见",
      "translation": null
    },
    {
      "time": 91.06,
      "time_str": "01:31.060",
      "text": "那是泪光 那力量",
      "translation": null
    },
    {
      "time": 94.0,
      "time_str": "01:34.000",
      "text": "我不想再去抵挡",
      "translation": null
    },
    {
      "time": 96.59,
      "time_str": "01:36.590",
      "text": "面对希望 逆着光",
      "translation": null
    },
    {
      "time": 99.56,
      "time_str": "01:39.560",
      "text": "感觉爱存在的地方",
      "translation": null
    },
    {
      "time": 103.69,
      "time_str": "01:43.690",
      "text": "一直就在 我身旁",
      "translation": null
