  "lyrics": [
    {
      "time": 16.618,
      "time_str": "00:16.618",
      "text": "你给我一场戏",
      "translation": null
    },
    {
      "time": 20.243,
      "time_str": "00:20.243",
      "text": "你看着我入迷",
      "translation": null
    },
    {
      "time": 23.886,
      "time_str": "00:23.886",
      "text": "被你从心里剥落的感情",
      "translation": null
    },
    {
      "time": 27.49,
      "time_str": "00:27.490",
      "text": "痛得不知怎么舍去",
      "translation": null
    },
    {
      "time": 31.36,
      "time_str": "00:31.360",
      "text": "不要这场记忆",
      "translation": null
    },
    {
      "time": 34.8,
      "time_str": "00:34.800",
      "text": "不要问我结局",
      "translation": null
    },
    {
      "time": 38.402,
      "time_str": "00:38.402",
      "text": "心底的酸楚和脸上的笑容",
      "translation": null
    },
    {
      "time": 42.05,
      "time_str": "00:42.050",
      "text": "早就合而为一",
      "translation": null
    },
    {
      "time": 46.114,
      "time_str": "00:46.114",
      "text": "迟迟不能相信这感觉",
      "translation": null
    },
    {
      "time": 49.092,
      "time_str": "00:49.092",
      "text": "像自己和自己分离",
      "translation": null
    },
    {
      "time": 52.239,
      "time_str": "00:52.239",
      "text": "而信誓旦旦的爱情 在哪里",
      "translation": null
    },
    {
      "time": 59.258,
      "time_str": "00:59.258",
      "text": "我一言难尽 忍不住伤心",
      "translation": null
    },
    {
      "time": 62.951,
      "time_str": "01:02.951",
      "text": "衡量不出爱或不爱之间的距离",
      "translation": null
    },
    {
      "time": 66.591,
      "time_str": "01:06.591",
      "text": "你说你的心 不再温热如昔",
      "translation": null
    },
    {
      "time": 70.228,
      "time_str": "01:10.228",
      "text": "从哪里开始 从哪里失去",
      "translation": null
    },
    {
      "time": 73.848,
      "time_str": "01:13.848",
      "text": "我一言难尽 忍不住伤心",
      "translation": null
    },
    {
      "time": 77.506,
      "time_str": "01:17.506",
