    {
      "time": 81.159,
      "time_str": "01:21.159",
      "text": "隐隐约约中 明白你的决定",
      "translation": null
    },
    {
      "time": 84.843,
      "time_str": "01:24.843",
      "text": "不敢勉强你 只好为难自己",
