  "lyrics": [
    {
      "time": 11.67,
      "time_str": "00:11.670",
      "text": "天气 冷暖不确定",
      "translation": null
    },
    {
      "time": 17.17,
      "time_str": "00:17.170",
      "text": "每个人 躲在人海里",
      "translation": null
    },
    {
      "time": 23.38,
      "time_str": "00:23.380",
      "text": "相遇 总是没道理",
      "translation": null
    },
    {
      "time": 29.26,
      "time_str": "00:29.260",
      "text": "弄错后 轻轻说对不起",
      "translation": null
    },
    {
      "time": 35.63,
      "time_str": "00:35.630",
      "text": "没关系 不论失去了什么",
      "translation": null
    },
    {
      "time": 42.22,
      "time_str": "00:42.220",
      "text": "都没痕迹",
      "translation": null
    },
    {
      "time": 47.8,
      "time_str": "00:47.800",
      "text": "每一次 让泪水流回心里",
      "translation": null
    },
    {
      "time": 53.81,
      "time_str": "00:53.810",
      "text": "去灌溉梦想 开出奇迹",
      "translation": null
    },
    {
      "time": 59.05,
      "time_str": "00:59.050",
      "text": "我要的坚强 不是谁的肩膀",
      "translation": null
    },
    {
      "time": 64.56,
      "time_str": "01:04.560",
      "text": "怀抱是个不能停留的地方",
      "translation": null
    },
    {
      "time": 71.83,
      "time_str": "01:11.830",
      "text": "这世界多拥挤 就有多匆忙",
      "translation": null
    },
    {
      "time": 77.72,
      "time_str": "01:17.720",
      "text": "用所有的寂寞时光给自己鼓掌",
      "translation": null
    },
    {
      "time": 83.17,
      "time_str": "01:23.170",
      "text": "我要的飞翔 不是借双翅膀",
      "translation": null
    },
    {
      "time": 88.61,
      "time_str": "01:28.610",
      "text": "自由是个不能代替的远方",
      "translation": null
    },
    {
      "time": 95.71,
      "time_str": "01:35.710",
      "text": "用旅途的孤单 来收获成长",
      "translation": null
    },
    {
      "time": 101.81,
      "time_str": "01:41.810",
      "text": "直到遇见了你一起分享",
      "translation": null
