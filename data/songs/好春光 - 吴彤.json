  },
  "lyrics": [
    {
      "time": 13.85,
      "time_str": "00:13.850",
      "text": "好春光 不如梦一场",
      "translation": null
    },
    {
      "time": 16.88,
      "time_str": "00:16.880",
      "text": "梦里青草香",
      "translation": null
    },
    {
      "time": 19.85,
      "time_str": "00:19.850",
      "text": "你把梦想带身上",
      "translation": null
    },
    {
      "time": 23.08,
      "time_str": "00:23.080",
      "text": "蓝天白云 青山绿水",
      "translation": null
    },
    {
      "time": 26.9,
      "time_str": "00:26.900",
      "text": "还有轻风吹 斜阳",
      "translation": null
    },
    {
      "time": 32.85,
      "time_str": "00:32.850",
      "text": "一千年 年年花开放 天天好时光",
      "translation": null
    },
    {
      "time": 38.97,
      "time_str": "00:38.970",
      "text": "来一次人间也匆忙",
      "translation": null
    },
    {
      "time": 42.09,
      "time_str": "00:42.090",
      "text": "小风大浪 地狱天堂",
      "translation": null
    },
    {
      "time": 45.58,
      "time_str": "00:45.580",
      "text": "还有你的灿烂 脸庞",
      "translation": null
    },
    {
      "time": 51.77,
      "time_str": "00:51.770",
      "text": "开心一刻 也是地久天长",
      "translation": null
    },
    {
      "time": 55.17,
      "time_str": "00:55.170",
      "text": "痛痛快快 向前走决不回望",
      "translation": null
    },
    {
      "time": 58.22,
      "time_str": "00:58.220",
      "text": "这花开花落 一千年一切形状",
      "translation": null
    },
    {
      "time": 62.3,
      "time_str": "01:02.300",
      "text": "我还是自己模样",
      "translation": null
    },
    {
      "time": 64.359,
      "time_str": "01:04.359",
      "text": "不是神仙自己 编造的翅膀",
      "translation": null
    },
    {
      "time": 70.5,
      "time_str": "01:10.500",
      "text": "晃晃悠悠 飞起来 飞过四大洋",
      "translation": null
    },
    {
      "time": 78.29,
      "time_str": "01:18.290",
      "text": "好春光",
      "translation": null
    },
