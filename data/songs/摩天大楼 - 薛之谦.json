{
  "title": "摩天大楼",
  "title_raw": "摩天大楼",
  "version": null,
  "artist": "薛之谦",
  "group_key": "摩天大楼|薛之谦",
  "writers": {
    "lyricist": "薛之谦",
    "composer": "唐汉霄",
