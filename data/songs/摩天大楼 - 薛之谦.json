  },
  "lyrics": [
    {
      "time": 7.93,
      "time_str": "00:07.930",
      "text": "结构",
      "translation": null
    },
    {
      "time": 10.81,
      "time_str": "00:10.810",
      "text": "让平分的阳光已穿不透",
      "translation": null
    },
    {
      "time": 17.49,
      "time_str": "00:17.490",
      "text": "诱人的方式是绝无仅有",
      "translation": null
    },
    {
      "time": 24.29,
      "time_str": "00:24.290",
      "text": "要平静的生活都抬起头",
      "translation": null
    },
    {
      "time": 30.72,
      "time_str": "00:30.720",
      "text": "学喜新厌旧  后",
      "translation": null
    },
    {
      "time": 37.06,
      "time_str": "00:37.060",
      "text": "寸草不留 赞不绝口",
      "translation": null
    },
    {
      "time": 43.83,
      "time_str": "00:43.830",
      "text": "欢迎钢筋野兽",
      "translation": null
    },
    {
      "time": 48.73,
      "time_str": "00:48.730",
      "text": "摩天大楼 太稀有 人人高贵富有",
      "translation": null
    },
    {
      "time": 55.57,
      "time_str": "00:55.570",
      "text": "表情温柔 怕献丑 没人吐出骨头",
      "translation": null
    },
    {
      "time": 63.75,
      "time_str": "01:03.750",
      "text": "你们谁位居榜首",
      "translation": null
    },
    {
      "time": 68.71,
      "time_str": "01:08.710",
      "text": "摩天大楼 云里走 谢绝衣衫简陋",
      "translation": null
    },
    {
      "time": 75.85,
      "time_str": "01:15.850",
      "text": "粉饰骷髅 气质有 人们争先恐后",
      "translation": null
    },
    {
      "time": 83.92,
      "time_str": "01:23.920",
      "text": "她离开你心爱的蚁楼",
      "translation": null
    },
    {
      "time": 96.75,
      "time_str": "01:36.750",
      "text": "午后",
      "translation": null
    },
    {
      "time": 99.56,
      "time_str": "01:39.560",
      "text": "诱人的方式是半推半就",
      "translation": null
    },
    {
      "time": 106.05,
      "time_str": "01:46.050",
      "text": "都供不应求的往云里走",
      "translation": null
    },
    {
      "time": 112.94,
      "time_str": "01:52.940",
      "text": "已没人顾及小草的感受",
      "translation": null
    },
    {
      "time": 119.23,
      "time_str": "01:59.230",
      "text": "自作自受",
      "translation": null
    },
    {
      "time": 123.6,
      "time_str": "02:03.600",
      "text": "摩天大楼 想拥有 让人爱不释手",
      "translation": null
    },
    {
      "time": 130.29,
      "time_str": "02:10.290",
      "text": "晶莹剔透 攀比后 才能高枕无忧",
      "translation": null
    },
    {
      "time": 138.53,
      "time_str": "02:18.530",
      "text": "请遮住我低级伤口",
      "translation": null
    },
    {
      "time": 144.2,
      "time_str": "02:24.200",
      "text": "摩天大楼 得到后 羡慕谁的自由",
      "translation": null
    },
    {
      "time": 150.85,
      "time_str": "02:30.850",
      "text": "霓虹过后 我自首 欢愉只剩皮肉",
      "translation": null
    },
    {
      "time": 158.93,
      "time_str": "02:38.930",
      "text": "在海市蜃楼喋喋不休",
      "translation": null
    },
    {
      "time": 166.53,
      "time_str": "02:46.530",
      "text": "自由 自由 我尽量献丑",
      "translation": null
    },
    {
      "time": 181.33,
      "time_str": "03:01.330",
      "text": "破旧蚁楼 往里走 见我年幼时候",
      "translation": null
    },
    {
      "time": 188.35,
      "time_str": "03:08.350",
      "text": "带泥小手 多自由 对我微笑点头",
      "translation": null
    },
    {
      "time": 196.5,
      "time_str": "03:16.500",
      "text": "我肮脏的不敢伸出手",
      "translation": null
    },
    {
      "time": 208.98,
      "time_str": "03:28.980",
      "text": "请毁掉我的摩天大楼",
      "translation": null
    },
    {
      "time": 227.23,
      "time_str": "03:47.230",
      "text": "伴唱：薛之谦",
      "translation": null
    },
    {
      "time": 227.67,
      "time_str": "03:47.670",
      "text": "弦乐编配：田汨",
      "translation": null
    },
    {
      "time": 228.1,
      "time_str": "03:48.100",
      "text": "弦乐乐团：灵魂室内乐团",
      "translation": null
    },
    {
      "time": 228.53,
      "time_str": "03:48.530",
      "text": "弦乐监制：刘辉",
      "translation": null
    },
    {
      "time": 229.4,
      "time_str": "03:49.400",
      "text": "人声录制：汝文博 （录制：BigJ Studio）",
