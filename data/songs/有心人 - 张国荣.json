  "lyrics": [
    {
      "time": 18.03,
      "time_str": "00:18.030",
      "text": "寂寞也挥发着余香",
      "translation": null
    },
    {
      "time": 24.63,
      "time_str": "00:24.630",
      "text": "原来情动正是这样",
      "translation": null
    },
    {
      "time": 31.22,
      "time_str": "00:31.220",
      "text": "曾忘掉这种遐想",
      "translation": null
    },
    {
      "time": 37.2,
      "time_str": "00:37.200",
      "text": "这麽超乎我想像",
      "translation": null
    },
    {
      "time": 44.55,
      "time_str": "00:44.550",
      "text": "但愿我可以没成长",
      "translation": null
    },
    {
      "time": 51.08,
      "time_str": "00:51.080",
      "text": "完全凭直觉觅对象",
      "translation": null
    },
    {
      "time": 57.75,
      "time_str": "00:57.750",
      "text": "模糊地迷恋你一场",
      "translation": null
    },
    {
      "time": 63.54,
      "time_str": "01:03.540",
      "text": "就当风雨下潮涨",
      "translation": null
    },
    {
      "time": 70.41,
      "time_str": "01:10.410",
      "text": "如果真的太好",
      "translation": null
    },
    {
      "time": 73.79,
      "time_str": "01:13.790",
      "text": "如错看了都好",
      "translation": null
    },
    {
      "time": 77.08,
      "time_str": "01:17.080",
      "text": "不想证实有没有过倾慕",
      "translation": null
    },
    {
      "time": 83.67,
      "time_str": "01:23.670",
      "text": "是无力 或有心",
      "translation": null
    },
    {
      "time": 86.92,
      "time_str": "01:26.920",
      "text": "像谜 像戏",
      "translation": null
    },
    {
      "time": 90.27,
      "time_str": "01:30.270",
      "text": "谁又会 似我演得更好",
      "translation": null
    },
    {
      "time": 96.91,
      "time_str": "01:36.910",
      "text": "从眉梢中感觉到",
      "translation": null
    },
    {
      "time": 100.36,
      "time_str": "01:40.360",
      "text": "从眼角看不到",
      "translation": null
    },
    {
      "time": 103.45,
      "time_str": "01:43.450",
      "text": "彷佛已是最直接的裸露",
      "translation": null
    },
    {
      "time": 110.09,
      "time_str": "01:50.090",
      "text": "是无力 但有心",
      "translation": null
    },
    {
      "time": 113.53,
      "time_str": "01:53.530",
      "text": "暗来 明往",
      "translation": null
    },
    {
      "time": 116.88,
      "time_str": "01:56.880",
      "text": "谁说 这算是情愫",
      "translation": null
