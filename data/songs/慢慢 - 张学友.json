  "lyrics": [
    {
      "time": 29.6,
      "time_str": "00:29.600",
      "text": "心慢慢疼慢慢冷",
      "translation": null
    },
    {
      "time": 34.68,
      "time_str": "00:34.680",
      "text": "慢慢等不到爱人",
      "translation": null
    },
    {
      "time": 39.84,
      "time_str": "00:39.840",
      "text": "付出一生收回几成",
      "translation": null
    },
    {
      "time": 47.81,
      "time_str": "00:47.810",
      "text": "情不能分不能恨",
      "translation": null
    },
    {
      "time": 52.85,
      "time_str": "00:52.850",
      "text": "不能太轻易信任",
      "translation": null
    },
    {
      "time": 56.19,
      "time_str": "00:56.190",
      "text": "真爱一回尽是伤痕",
      "translation": null
    },
    {
      "time": 62.35,
      "time_str": "01:02.350",
      "text": "泪慢慢流慢慢收",
      "translation": null
    },
    {
      "time": 67.31,
      "time_str": "01:07.310",
      "text": "慢慢变成了朋友",
      "translation": null
    },
    {
      "time": 72.51,
      "time_str": "01:12.510",
      "text": "寂寞的夜独自承受",
      "translation": null
    },
    {
      "time": 80.7,
      "time_str": "01:20.700",
      "text": "爱不能久不能够",
      "translation": null
    },
    {
      "time": 85.54,
      "time_str": "01:25.540",
      "text": "不能太容易拥有",
      "translation": null
    },
    {
      "time": 88.81,
      "time_str": "01:28.810",
      "text": "伤人的爱不堪回首",
      "translation": null
    },
    {
      "time": 95.22,
      "time_str": "01:35.220",
      "text": "慢慢慢慢没有感觉",
      "translation": null
    },
    {
      "time": 98.81,
      "time_str": "01:38.810",
      "text": "慢慢慢慢我被忽略",
      "translation": null
    },
    {
      "time": 102.46,
      "time_str": "01:42.460",
      "text": "你何忍看我憔悴",
      "translation": null
    },
    {
      "time": 106.08,
      "time_str": "01:46.080",
      "text": "没有一点点安慰",
      "translation": null
    },
    {
      "time": 109.67,
      "time_str": "01:49.670",
      "text": "慢慢慢慢心变成铁",
      "translation": null
    },
    {
      "time": 113.37,
      "time_str": "01:53.370",
      "text": "慢慢慢慢我被拒绝",
      "translation": null
    },
    {
      "time": 117.07,
      "time_str": "01:57.070",
      "text": "你何忍远走高飞",
      "translation": null
    },
    {
      "time": 120.55,
      "time_str": "02:00.550",
      "text": "要我如何收拾这爱的残缺",
      "translation": null
    },
