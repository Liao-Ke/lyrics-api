  "lyrics": [
    {
      "time": 60.3,
      "time_str": "01:00.300",
      "text": "台北的机场是一个分手老地方",
      "translation": null
    },
    {
      "time": 67.0,
      "time_str": "01:07.000",
      "text": "你的心情也和我一样",
      "translation": null
    },
    {
      "time": 70.7,
      "time_str": "01:10.700",
      "text": "难过却无法去抵挡",
      "translation": null
    },
    {
      "time": 76.4,
      "time_str": "01:16.400",
      "text": "不再有浪漫",
      "translation": null
    },
    {
      "time": 79.2,
      "time_str": "01:19.200",
      "text": "也不会有地久天长",
      "translation": null
    },
    {
      "time": 83.3,
      "time_str": "01:23.300",
      "text": "只有一种无奈的习惯留在我身旁",
      "translation": null
    },
    {
      "time": 90.8,
      "time_str": "01:30.800",
      "text": "我不是不温柔",
      "translation": null
    },
    {
      "time": 93.7,
      "time_str": "01:33.700",
      "text": "对你的要求总是做不够",
      "translation": null
    },
    {
      "time": 99.1,
      "time_str": "01:39.100",
      "text": "还是我给你过分的自由",
      "translation": null
    },
    {
      "time": 103.1,
      "time_str": "01:43.100",
      "text": "变成我俩现在分手的理由",
      "translation": null
    },
    {
      "time": 107.3,
      "time_str": "01:47.300",
      "text": "我不是不温柔",
      "translation": null
    },
    {
      "time": 110.1,
      "time_str": "01:50.100",
      "text": "只要你想走",
      "translation": null
    },
    {
      "time": 112.9,
      "time_str": "01:52.900",
      "text": "向我挥挥手",
      "translation": null
    },
    {
      "time": 115.6,
      "time_str": "01:55.600",
      "text": "请你答应我最后的要求",
      "translation": null
    },
    {
      "time": 119.9,
      "time_str": "01:59.900",
      "text": "不要再回头",
      "translation": null
    },
