  "lyrics": [
    {
      "time": 38.871,
      "time_str": "00:38.871",
      "text": "我无法帮你预言",
      "translation": null
    },
    {
      "time": 41.874,
      "time_str": "00:41.874",
      "text": "委屈求全有没有用",
      "translation": null
    },
    {
      "time": 45.79,
      "time_str": "00:45.790",
      "text": "可是我多么不舍",
      "translation": null
    },
    {
      "time": 48.829,
      "time_str": "00:48.829",
      "text": "朋友爱得那么苦痛",
      "translation": null
    },
    {
      "time": 52.692,
      "time_str": "00:52.692",
      "text": "爱可以不问对错",
      "translation": null
    },
    {
      "time": 55.848,
      "time_str": "00:55.848",
      "text": "至少要喜悦感动",
      "translation": null
    },
    {
      "time": 58.487,
      "time_str": "00:58.487",
      "text": "如果他总为别人撑伞",
      "translation": null
    },
    {
      "time": 61.64,
      "time_str": "01:01.640",
      "text": "你何苦非为他等在雨中",
      "translation": null
    },
    {
      "time": 66.592,
      "time_str": "01:06.592",
      "text": "泡咖啡让你暖手",
      "translation": null
    },
    {
      "time": 69.7,
      "time_str": "01:09.700",
      "text": "想挡挡你心口里的风",
      "translation": null
    },
    {
      "time": 73.695,
      "time_str": "01:13.695",
      "text": "你却想上街走走",
      "translation": null
    },
    {
      "time": 76.588,
      "time_str": "01:16.588",
      "text": "吹吹冷风会清醒得多",
      "translation": null
    },
    {
      "time": 80.526,
      "time_str": "01:20.526",
      "text": "你说你不怕分手",
      "translation": null
    },
    {
      "time": 83.623,
      "time_str": "01:23.623",
      "text": "只有点遗憾难过",
      "translation": null
    },
    {
      "time": 86.279,
      "time_str": "01:26.279",
      "text": "情人节就要来了",
      "translation": null
    },
    {
      "time": 88.591,
      "time_str": "01:28.591",
      "text": "剩自己一个",
      "translation": null
    },
    {
      "time": 90.32,
      "time_str": "01:30.320",
      "text": "其实爱对了人",
      "translation": null
    },
    {
      "time": 92.1,
      "time_str": "01:32.100",
      "text": "情人节每天都过",
      "translation": null
    },
    {
      "time": 96.262,
      "time_str": "01:36.262",
      "text": "分手快乐 祝你快乐",
      "translation": null
    },
    {
      "time": 99.665,
      "time_str": "01:39.665",
      "text": "你可以找到更好的",
      "translation": null
    },
    {
      "time": 103.158,
      "time_str": "01:43.158",
      "text": "不想过冬 厌倦沉重",
      "translation": null
    },
    {
      "time": 106.665,
      "time_str": "01:46.665",
      "text": "就飞去热带的岛屿游泳",
      "translation": null
    },
    {
      "time": 110.146,
      "time_str": "01:50.146",
      "text": "分手快乐 请你快乐",
      "translation": null
    },
    {
      "time": 113.533,
      "time_str": "01:53.533",
      "text": "挥别错的才能和对的相逢",
      "translation": null
    },
    {
      "time": 117.341,
      "time_str": "01:57.341",
      "text": "离开旧爱 像坐慢车",
      "translation": null
    },
    {
      "time": 120.492,
      "time_str": "02:00.492",
      "text": "看透彻了心就会是晴朗的",
      "translation": null
    },
    {
      "time": 124.931,
      "time_str": "02:04.931",
      "text": "没人能把谁的幸福没收",
      "translation": null
    },
    {
      "time": 130.867,
      "time_str": "02:10.867",
      "text": "你发誓你会活得有笑容",
      "translation": null
    },
    {
