  "lyrics": [
    {
      "time": 15.82,
      "time_str": "00:15.820",
      "text": "I always needed time on my own",
      "translation": "我总是需要自己独处的时间"
    },
    {
      "time": 20.69,
      "time_str": "00:20.690",
      "text": "I never thought",
      "translation": "我从未想过"
    },
    {
      "time": 22.03,
      "time_str": "00:22.030",
      "text": "I'd need you there when I cry",
      "translation": "当我哭泣时需要你"
    },
    {
      "time": 28.89,
      "time_str": "00:28.890",
      "text": "And the days feel like years",
      "translation": "当我独自一人时"
    },
    {
      "time": 31.48,
      "time_str": "00:31.480",
      "text": "when I'm alone",
      "translation": "却度日如年"
    },
    {
      "time": 33.79,
      "time_str": "00:33.790",
      "text": "And the bed where you lie",
      "translation": "床上你躺的位置"
    },
    {
      "time": 37.06,
      "time_str": "00:37.060",
      "text": "Is made up on your side",
      "translation": "已经为你准备好"
    },
    {
      "time": 45.5,
      "time_str": "00:45.500",
      "text": "When you walk away",
      "translation": "当你离开时"
    },
    {
      "time": 47.82,
      "time_str": "00:47.820",
      "text": "I count the steps that you take",
      "translation": "我计算着你的脚步"
    },
    {
      "time": 51.64,
      "time_str": "00:51.640",
      "text": "Do you see how much I need you right now?",
      "translation": "你明白此刻我有多需要你吗"
    },
    {
      "time": 57.03,
      "time_str": "00:57.030",
      "text": "When you're gone",
      "translation": "当你离去"
    },
    {
      "time": 59.47,
      "time_str": "00:59.470",
      "text": "The pieces of my heart",
      "translation": "我碎成一片的心"
    },
    {
      "time": 62.32,
      "time_str": "01:02.320",
      "text": "are missing you",
      "translation": "想念着你"
    },
    {
      "time": 63.98,
      "time_str": "01:03.980",
      "text": "When you're gone",
      "translation": "当你离去"
    },
    {
      "time": 66.5,
      "time_str": "01:06.500",
      "text": "The face I came to know",
      "translation": "熟悉的面容"
    },
    {
      "time": 69.08,
      "time_str": "01:09.080",
      "text": "is missing too",
      "translation": "也消失了"
    },
    {
      "time": 70.77,
      "time_str": "01:10.770",
      "text": "When you're gone",
      "translation": "当你离去"
    },
    {
      "time": 73.36,
      "time_str": "01:13.360",
      "text": "The words I need to hear",
      "translation": "曾经的甜言蜜语"
    },
    {
      "time": 75.31,
      "time_str": "01:15.310",
      "text": "to always get me through the day",
      "translation": "让我撑过了每一天"
    },
    {
      "time": 80.15,
      "time_str": "01:20.150",
      "text": "And make it ok",
      "translation": "所以日子才没那么漫长"
    },
    {
      "time": 84.59,
      "time_str": "01:24.590",
      "text": "I miss you",
      "translation": "我想你"
    },
    {
      "time": 99.2,
      "time_str": "01:39.200",
      "text": "I've never felt this way before",
      "translation": "以前从未有过这种感觉"
    },
    {
      "time": 103.79,
      "time_str": "01:43.790",
      "text": "Everything that I do",
      "translation": "我做的每件事情"
    },
    {
      "time": 106.98,
      "time_str": "01:46.980",
      "text": "reminds me of you",
      "translation": "都会联想到你"
    },
    {
      "time": 112.87,
      "time_str": "01:52.870",
      "text": "And the clothes you left",
      "translation": "你留下的衣服"
    },
    {
      "time": 114.32,
      "time_str": "01:54.320",
      "text": "they lie on the floor",
      "translation": "仍在地板上"
    },
    {
      "time": 117.56,
      "time_str": "01:57.560",
      "text": "And they smell just like you",
