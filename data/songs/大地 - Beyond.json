  "lyrics": [
    {
      "time": 27.14,
      "time_str": "00:27.140",
      "text": "在那些苍翠的路上",
      "translation": null
    },
    {
      "time": 30.63,
      "time_str": "00:30.630",
      "text": "历遍了多少创伤",
      "translation": null
    },
    {
      "time": 33.87,
      "time_str": "00:33.870",
      "text": "在那张苍老的面上",
      "translation": null
    },
    {
      "time": 37.41,
      "time_str": "00:37.410",
      "text": "亦记载了风霜",
      "translation": null
    },
    {
      "time": 41.43,
      "time_str": "00:41.430",
      "text": "秋风秋雨的度日",
      "translation": null
    },
    {
      "time": 44.06,
      "time_str": "00:44.060",
      "text": "是青春少年时",
      "translation": null
    },
    {
      "time": 48.13,
      "time_str": "00:48.130",
      "text": "迫不得已的话别",
      "translation": null
    },
    {
      "time": 50.85,
      "time_str": "00:50.850",
      "text": "没说再见",
      "translation": null
    },
    {
      "time": 53.53,
      "time_str": "00:53.530",
      "text": "回望昨日在异乡那门前",
      "translation": null
    },
    {
      "time": 57.77,
      "time_str": "00:57.770",
      "text": "唏嘘的感慨一年年",
      "translation": null
    },
    {
      "time": 61.13,
      "time_str": "01:01.130",
      "text": "但日落日出永没变迁",
      "translation": null
    },
    {
      "time": 66.96,
      "time_str": "01:06.960",
      "text": "这刻在望着父亲笑容时",
      "translation": null
    },
    {
      "time": 71.17,
      "time_str": "01:11.170",
      "text": "竟不知不觉的无言",
      "translation": null
    },
    {
      "time": 74.54,
      "time_str": "01:14.540",
      "text": "让日落暮色渗满泪眼",
      "translation": null
    },
    {
      "time": 94.31,
      "time_str": "01:34.310",
      "text": "在那些开放的路上",
      "translation": null
    },
    {
      "time": 97.82,
      "time_str": "01:37.820",
      "text": "踏碎过多少理想",
      "translation": null
    },
    {
      "time": 100.92,
      "time_str": "01:40.920",
      "text": "在那张高挂的面上",
      "translation": null
    },
    {
      "time": 104.57,
      "time_str": "01:44.570",
      "text": "被引证了几多",
      "translation": null
    },
    {
      "time": 108.57,
      "time_str": "01:48.570",
      "text": "千秋不变的日月",
      "translation": null
    },
    {
      "time": 111.3,
      "time_str": "01:51.300",
      "text": "在相识里共存",
      "translation": null
    },
    {
      "time": 115.3,
      "time_str": "01:55.300",
      "text": "姑息分割的大地",
      "translation": null
    },
    {
      "time": 118.06,
      "time_str": "01:58.060",
      "text": "划了界线",
      "translation": null
    },
    {
      "time": 120.83,
      "time_str": "02:00.830",
      "text": "回望昨日在异乡那门前",
      "translation": null
