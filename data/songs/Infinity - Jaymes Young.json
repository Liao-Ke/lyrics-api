    {
      "time": 14.91,
      "time_str": "00:14.910",
      "text": "Baby this love",
      "translation": "亲爱的"
    },
    {
      "time": 17.86,
      "time_str": "00:17.860",
      "text": "I'll never let it die",
      "translation": "我不会让这份爱枯萎"
    },
    {
      "time": 21.62,
      "time_str": "00:21.620",
      "text": "Can't be touched by no one",
      "translation": "除了你"
    },
    {
      "time": 25.81,
      "time_str": "00:25.810",
      "text": "I'd like to see him try",
      "translation": "无人可以触及我的灵魂"
    },
    {
      "time": 31.36,
      "time_str": "00:31.360",
      "text": "I'm a mad man for your touch girl I've lost control",
      "translation": "我如坠云雾 犹如脱缰之马 只为得到你的爱抚"
    },
    {
      "time": 38.7,
      "time_str": "00:38.700",
      "text": "I'm gonna make this last forever don't tell me it's impossible",
      "translation": "我要将这份爱持续到永远 不要对我说不可能"
    },
    {
      "time": 45.64,
      "time_str": "00:45.640",
      "text": "'Cause I love you for infinity",
      "translation": "因为我对你的爱无穷无尽"
    },
    {
