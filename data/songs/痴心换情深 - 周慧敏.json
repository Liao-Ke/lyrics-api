  "lyrics": [
    {
      "time": 36.86,
      "time_str": "00:36.860",
      "text": "这个世界或有别人",
      "translation": null
    },
    {
      "time": 40.39,
      "time_str": "00:40.390",
      "text": "亦能令我放肆爱一阵",
      "translation": null
    },
    {
      "time": 44.48,
      "time_str": "00:44.480",
      "text": "对你飘忽的爱为何认真",
      "translation": null
    },
    {
      "time": 48.8,
      "time_str": "00:48.800",
      "text": "热情热爱倍难枕",
      "translation": null
    },
    {
      "time": 52.88,
      "time_str": "00:52.880",
      "text": "怎知道爱上了你像似自焚",
      "translation": null
    },
    {
      "time": 57.2,
      "time_str": "00:57.200",
      "text": "仍然愿意靠向你亲近",
      "translation": null
    },
    {
      "time": 61.276,
      "time_str": "01:01.276",
      "text": "也许痴心可以换情深",
      "translation": null
    },
    {
      "time": 65.506,
      "time_str": "01:05.506",
      "text": "在无望盼天悯",
      "translation": null
    },
    {
      "time": 71.786,
      "time_str": "01:11.786",
      "text": "随缘分过去你不再问",
      "translation": null
    },
    {
      "time": 74.229,
      "time_str": "01:14.229",
      "text": "不懂珍惜此际",
      "translation": null
    },
    {
      "time": 76.418,
      "time_str": "01:16.418",
      "text": "每每看着我伤心",
      "translation": null
    },
    {
      "time": 79.927,
      "time_str": "01:19.927",
      "text": "只因你看惯我的泪痕",
      "translation": null
    },
    {
      "time": 82.668,
      "time_str": "01:22.668",
      "text": "对你再不震撼",
      "translation": null
    },
    {
      "time": 84.857,
      "time_str": "01:24.857",
      "text": "看见了都不痛心",
      "translation": null
    },
    {
      "time": 88.576,
      "time_str": "01:28.576",
      "text": "如何像戏里说的对白",
      "translation": null
    },
    {
      "time": 91.067,
      "time_str": "01:31.067",
      "text": "相恋一生一世",
      "translation": null
    },
    {
      "time": 93.309,
      "time_str": "01:33.309",
      "text": "说了当没有发生",
      "translation": null
    },
    {
      "time": 96.878,
      "time_str": "01:36.878",
      "text": "思想已永远退不回头",
      "translation": null
    },
    {
      "time": 99.53,
      "time_str": "01:39.530",
      "text": "爱过痛苦一生",
      "translation": null
    },
    {
      "time": 101.768,
      "time_str": "01:41.768",
      "text": "沾满心中的泪印",
      "translation": null
    },
