    {
      "time": 19.95,
      "time_str": "00:19.950",
      "text": "头上一片青天",
      "translation": null
    },
    {
      "time": 23.32,
      "time_str": "00:23.320",
      "text": "心中一个信念",
      "translation": null
    },
    {
      "time": 27.0,
      "time_str": "00:27.000",
      "text": "不是年少无知",
      "translation": null
    },
    {
      "time": 30.74,
      "time_str": "00:30.740",
      "text": "只是不惧挑战",
      "translation": null
    },
    {
      "time": 34.42,
      "time_str": "00:34.420",
      "text": "凡事求个明白",
      "translation": null
    },
    {
      "time": 38.17,
      "time_str": "00:38.170",
      "text": "算是本性难改",
      "translation": null
    },
    {
      "time": 41.97,
      "time_str": "00:41.970",
      "text": "可以还你公道",
      "translation": null
    },
    {
      "time": 45.84,
      "time_str": "00:45.840",
      "text": "我又何乐不为",
      "translation": null
    },
    {
      "time": 51.58,
      "time_str": "00:51.580",
      "text": "一些漫不经心的说话",
      "translation": null
    },
    {
      "time": 54.95,
      "time_str": "00:54.950",
      "text": "将我疑惑解开",
      "translation": null
