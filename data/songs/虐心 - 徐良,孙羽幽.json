  "lyrics": [
    {
      "time": 19.08,
      "time_str": "00:19.080",
      "text": "落叶飘过一个曾经",
      "translation": null
    },
    {
      "time": 22.08,
      "time_str": "00:22.080",
      "text": "曾经许下一个约定",
      "translation": null
    },
    {
      "time": 24.28,
      "time_str": "00:24.280",
      "text": "两个人的手深深握紧",
      "translation": null
    },
    {
      "time": 28.43,
      "time_str": "00:28.430",
      "text": "同样的街景",
      "translation": null
    },
    {
      "time": 30.33,
      "time_str": "00:30.330",
      "text": "熟悉的声音",
      "translation": null
    },
    {
      "time": 32.81,
      "time_str": "00:32.810",
      "text": "你说了对不起",
      "translation": null
    },
    {
      "time": 36.6,
      "time_str": "00:36.600",
      "text": "男：坚强从来都是故意",
      "translation": null
    },
    {
      "time": 39.55,
      "time_str": "00:39.550",
      "text": "故意假装着不在意",
      "translation": null
    },
    {
      "time": 41.67,
      "time_str": "00:41.670",
      "text": "亲爱的请你不要哭泣",
      "translation": null
    },
    {
      "time": 45.81,
      "time_str": "00:45.810",
      "text": "只要你幸福",
      "translation": null
    },
    {
      "time": 47.81,
      "time_str": "00:47.810",
      "text": "我愿意忘记",
      "translation": null
    },
    {
      "time": 50.18,
      "time_str": "00:50.180",
      "text": "记忆中全部的你",
      "translation": null
    },
    {
      "time": 53.19,
      "time_str": "00:53.190",
      "text": "女：下一次我们会在",
      "translation": null
    },
    {
      "time": 55.64,
      "time_str": "00:55.640",
      "text": "某个路口相遇",
      "translation": null
    },
    {
      "time": 58.13,
      "time_str": "00:58.130",
      "text": "请告诉我你过得很开心",
      "translation": null
    },
    {
      "time": 62.74,
      "time_str": "01:02.740",
      "text": "想念你的眼睛",
      "translation": null
    },
    {
      "time": 64.39,
      "time_str": "01:04.390",
      "text": "你的表情 你的身影",
      "translation": null
    },
    {
      "time": 66.9,
      "time_str": "01:06.900",
      "text": "泪湿在一个人的夜里",
      "translation": null
    },
    {
      "time": 70.71,
      "time_str": "01:10.710",
      "text": "男：下一次我们会",
      "translation": null
    },
    {
      "time": 72.81,
      "time_str": "01:12.810",
      "text": "在某个路口相遇",
      "translation": null
    },
    {
      "time": 75.56,
      "time_str": "01:15.560",
      "text": "请告诉我怎么能不想你",
      "translation": null
    },
    {
      "time": 80.17,
      "time_str": "01:20.170",
      "text": "忘掉你的真心",
      "translation": null
    },
    {
      "time": 81.82,
      "time_str": "01:21.820",
      "text": "你的用心你的伤心",
      "translation": null
    },
    {
      "time": 84.25,
      "time_str": "01:24.250",
      "text": "忘掉牵挂着你的自己",
      "translation": null
    },
    {
      "time": 88.01,
      "time_str": "01:28.010",
      "text": "和尘封的记忆",
