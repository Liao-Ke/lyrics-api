  "lyrics": [
    {
      "time": 38.79,
      "time_str": "00:38.790",
      "text": "那一天知道你要走",
      "translation": null
    },
    {
      "time": 42.73,
      "time_str": "00:42.730",
      "text": "我们一句话也没有说",
      "translation": null
    },
    {
      "time": 47.56,
      "time_str": "00:47.560",
      "text": "当午夜的钟声敲痛离别的心门",
      "translation": null
    },
    {
      "time": 52.21,
      "time_str": "00:52.210",
      "text": "却打不开你深深的沉默",
      "translation": null
    },
    {
      "time": 57.16,
      "time_str": "00:57.160",
      "text": "那一天送你送到最后",
      "translation": null
    },
    {
      "time": 61.15,
      "time_str": "01:01.150",
      "text": "我们一句话也没有留",
      "translation": null
    },
    {
      "time": 66.11,
      "time_str": "01:06.110",
      "text": "当拥挤的月台挤痛送别的人们",
      "translation": null
    },
    {
      "time": 70.66,
      "time_str": "01:10.660",
      "text": "却挤不掉我深深的离愁",
      "translation": null
    },
    {
      "time": 75.32,
      "time_str": "01:15.320",
      "text": "我知道你有千言你有万语",
      "translation": null
    },
    {
      "time": 79.8,
      "time_str": "01:19.800",
      "text": "却不肯说出口",
      "translation": null
    },
    {
      "time": 84.45,
      "time_str": "01:24.450",
      "text": "你知道我好担心我好难过",
      "translation": null
    },
    {
      "time": 89.08,
      "time_str": "01:29.080",
      "text": "却不敢说出口",
      "translation": null
    },
    {
      "time": 93.37,
      "time_str": "01:33.370",
      "text": "当你背上行囊 卸下那份荣耀",
      "translation": null
    },
    {
      "time": 97.66,
      "time_str": "01:37.660",
      "text": "我只能让眼泪留在心底",
      "translation": null
    },
    {
      "time": 102.3,
      "time_str": "01:42.300",
      "text": "面带着微微笑 用力的挥挥手",
      "translation": null
    },
    {
      "time": 106.91,
      "time_str": "01:46.910",
      "text": "祝你一路顺风",
      "translation": null
    },
    {
      "time": 111.8,
      "time_str": "01:51.800",
      "text": "当你踏上月台 从此一个人走",
      "translation": null
    },
    {
      "time": 116.19,
      "time_str": "01:56.190",
      "text": "我只能深深的祝福你",
      "translation": null
    },
    {
      "time": 120.69,
      "time_str": "02:00.690",
      "text": "深深的祝福你 最亲爱的朋友",
      "translation": null
    },
    {
