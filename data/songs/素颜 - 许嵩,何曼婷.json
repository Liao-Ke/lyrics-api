  "lyrics": [
    {
      "time": 13.05,
      "time_str": "00:13.050",
      "text": "又是一个安静的晚上",
      "translation": null
    },
    {
      "time": 15.9,
      "time_str": "00:15.900",
      "text": "一个人窝在摇椅里乘凉",
      "translation": null
    },
    {
      "time": 18.84,
      "time_str": "00:18.840",
      "text": "我承认这样真的很安详",
      "translation": null
    },
    {
      "time": 21.17,
      "time_str": "00:21.170",
      "text": "和楼下老爷爷一样",
      "translation": null
    },
    {
      "time": 24.53,
      "time_str": "00:24.530",
      "text": "听说你还在搞什么原创",
      "translation": null
    },
    {
      "time": 27.35,
      "time_str": "00:27.350",
      "text": "搞来搞去好像也就这样",
      "translation": null
    },
    {
      "time": 30.21,
      "time_str": "00:30.210",
      "text": "不如花点时间想想",
      "translation": null
    },
    {
      "time": 32.3,
      "time_str": "00:32.300",
      "text": "琢磨一下模样",
      "translation": null
    },
    {
      "time": 35.63,
      "time_str": "00:35.630",
      "text": "今夜化了美美的妆",
      "translation": null
    },
    {
      "time": 38.45,
      "time_str": "00:38.450",
      "text": "(我相信是很美美的装)",
      "translation": null
    },
    {
      "time": 41.48,
      "time_str": "00:41.480",
      "text": "我摇晃在舞池中央",
      "translation": null
    },
    {
      "time": 44.31,
      "time_str": "00:44.310",
      "text": "(那种体态可以想象)",
      "translation": null
    },
    {
      "time": 47.45,
      "time_str": "00:47.450",
      "text": "我做我的改变 又何必纠结",
      "translation": null
    },
    {
      "time": 51.51,
      "time_str": "00:51.510",
      "text": "那就拜托别和我碰面",
      "translation": null
    },
    {
      "time": 57.16,
      "time_str": "00:57.160",
      "text": "如果再看你一眼",
      "translation": null
    },
    {
      "time": 59.87,
      "time_str": "00:59.870",
      "text": "是否还会有感觉",
      "translation": null
    },
    {
      "time": 62.59,
      "time_str": "01:02.590",
      "text": "当年素面朝天要多纯洁就有多纯洁",
      "translation": null
    },
    {
      "time": 68.31,
      "time_str": "01:08.310",
      "text": "不画扮熟的眼线",
      "translation": null
    },
    {
      "time": 71.04,
      "time_str": "01:11.040",
      "text": "不用抹匀粉底液",
      "translation": null
    },
    {
      "time": 74.069,
      "time_str": "01:14.069",
      "text": "暴雨天 照逛街",
      "translation": null
    },
    {
      "time": 76.86,
      "time_str": "01:16.860",
      "text": "偷笑别人花了脸",
      "translation": null
    },
    {
      "time": 79.59,
      "time_str": "01:19.590",
      "text": "如果再看你一眼",
      "translation": null
    },
    {
      "time": 82.489,
      "time_str": "01:22.489",
      "text": "是否还会有感觉",
      "translation": null
    },
    {
      "time": 85.36,
      "time_str": "01:25.360",
      "text": "最真实的喜怒哀乐全都埋葬在昨天",
      "translation": null
    },
    {
      "time": 90.9,
      "time_str": "01:30.900",
      "text": "不掺任何的表演",
      "translation": null
    },
    {
      "time": 93.58,
      "time_str": "01:33.580",
      "text": "轰轰烈烈那几年",
      "translation": null
    },
    {
      "time": 96.54,
      "time_str": "01:36.540",
      "text": "我怀念 别怀念",
      "translation": null
    },
    {
      "time": 99.43,
      "time_str": "01:39.430",
      "text": "怀念也回不到从前",
      "translation": null
    },
    {
