  "lyrics": [
    {
      "time": 16.87,
      "time_str": "00:16.870",
      "text": "他将是你的新郎",
      "translation": null
    },
    {
      "time": 21.22,
      "time_str": "00:21.220",
      "text": "从今以后他就是你一生的伴",
      "translation": null
    },
    {
      "time": 25.86,
      "time_str": "00:25.860",
      "text": "他的一切都将和你紧密相关 福和祸都要同当",
      "translation": null
    },
    {
      "time": 34.91,
      "time_str": "00:34.910",
      "text": "她将是你的新娘",
      "translation": null
    },
    {
      "time": 39.47,
      "time_str": "00:39.470",
      "text": "她是别人用心托付在你手上",
      "translation": null
    },
    {
      "time": 44.02,
      "time_str": "00:44.020",
      "text": "你要用你一生加倍照顾对待 苦或喜都要同享",
      "translation": null
    },
    {
      "time": 53.18,
      "time_str": "00:53.180",
      "text": "一定是特别的缘分",
      "translation": null
    },
    {
      "time": 57.59,
      "time_str": "00:57.590",
      "text": "才可以一路走来变成了一家人",
      "translation": null
    },
    {
      "time": 62.7,
      "time_str": "01:02.700",
      "text": "他多爱你几分 你多还他几分 找幸福的可能",
      "translation": null
    },
    {
      "time": 71.34,
      "time_str": "01:11.340",
      "text": "从此不再是一个人",
      "translation": null
    },
    {
      "time": 75.85,
      "time_str": "01:15.850",
      "text": "要处处时时想着念的都是我们",
      "translation": null
    },
    {
      "time": 80.97,
      "time_str": "01:20.970",
      "text": "你付出了几分",
      "translation": null
    },
    {
      "time": 85.09,
      "time_str": "01:25.090",
      "text": "爱就圆满了几分",
      "translation": null
    },
