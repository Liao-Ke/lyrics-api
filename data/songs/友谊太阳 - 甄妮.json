    {
      "time": 37.546,
      "time_str": "00:37.546",
      "text": "人尽了已完场",
      "translation": null
    },
    {
      "time": 41.197,
      "time_str": "00:41.197",
      "text": "瞭望今生气象",
      "translation": null
    },
    {
      "time": 44.627,
      "time_str": "00:44.627",
      "text": "延续那无尽路向",
      "translation": null
    },
    {
      "time": 47.735,
      "time_str": "00:47.735",
      "text": "心底的光辉总照亮",
      "translation": null
    },
    {
      "time": 51.727,
      "time_str": "00:51.727",
      "text": "年月似乎很绵长",
      "translation": null
    },
    {
      "time": 55.701,
      "time_str": "00:55.701",
      "text": "难及你的友谊长",
      "translation": null
    },
    {
      "time": 59.212,
      "time_str": "00:59.212",
      "text": "带引又上路觅我方向",
      "translation": null
    },
    {
      "time": 66.962,
      "time_str": "01:06.962",
      "text": "美好的自会印在我心间",
      "translation": null
    },
    {
      "time": 72.48,
      "time_str": "01:12.480",
      "text": "忘掉了满眼泪的喟叹",
      "translation": null
    },
    {
      "time": 79.653,
      "time_str": "01:19.653",
      "text": "别了他纸醉金迷于梦幻",
      "translation": null
    },
    {
      "time": 87.652,
      "time_str": "01:27.652",
      "text": "挽着我是友善的臂弯",
      "translation": null
    },
    {
      "time": 96.284,
      "time_str": "01:36.284",
      "text": "每一天是你暖在我心间",
      "translation": null
    },
    {
      "time": 102.165,
      "time_str": "01:42.165",
      "text": "携着我极快乐的步上",
      "translation": null
    },
    {
      "time": 109.131,
      "time_str": "01:49.131",
      "text": "友爱的臂弯超越了极限",
      "translation": null
    },
    {
      "time": 116.82,
      "time_str": "01:56.820",
      "text": "你令我长夜更浪漫",
      "translation": null
    },
    {
      "time": 128.755,
      "time_str": "02:08.755",
      "text": "燃亮友谊太阳",
      "translation": null
    },
    {
