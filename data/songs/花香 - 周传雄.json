  "lyrics": [
    {
      "time": 31.57,
      "time_str": "00:31.570",
      "text": "风　没有方向的吹来　雨　也跟著悲伤起来",
      "translation": null
    },
    {
      "time": 42.82,
      "time_str": "00:42.820",
      "text": "没有人能告诉我　爱是在什么时候　悄悄走开",
      "translation": null
    },
    {
      "time": 53.23,
      "time_str": "00:53.230",
      "text": "风　伴著花谢了又开　雨　把眼泪落向大海",
      "translation": null
    },
    {
      "time": 63.22,
      "time_str": "01:03.220",
      "text": "现在的我才明白　妳抱著紫色的梦　选择等待",
      "translation": null
    },
    {
      "time": 73.7,
      "time_str": "01:13.700",
      "text": "记忆是阵阵花香　我们说好谁都不能忘",
      "translation": null
    },
    {
      "time": 83.47,
      "time_str": "01:23.470",
      "text": "守著黑夜的阳光　难过却假装坚强　等待的日子里妳比我勇敢",
      "translation": null
    },
    {
      "time": 94.23,
      "time_str": "01:34.230",
      "text": "记忆是阵阵花香　一起走过永远不能忘",
      "translation": null
    },
    {
      "time": 103.82,
      "time_str": "01:43.820",
      "text": "妳的温柔是阳光　把我的未来填满",
      "translation": null
    },
    {
      "time": 108.85,
      "time_str": "01:48.850",
      "text": "提醒我花香常在就像我的爱",
      "translation": null
    },
