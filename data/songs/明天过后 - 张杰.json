  "lyrics": [
    {
      "time": 19.07,
      "time_str": "00:19.070",
      "text": "没有星星的夜空",
      "translation": null
    },
    {
      "time": 23.01,
      "time_str": "00:23.010",
      "text": "没有话题能补充",
      "translation": null
    },
    {
      "time": 26.93,
      "time_str": "00:26.930",
      "text": "太多承诺从指缝中流走",
      "translation": null
    },
    {
      "time": 31.1,
      "time_str": "00:31.100",
      "text": "不敢奢求什么",
      "translation": null
    },
    {
      "time": 34.97,
      "time_str": "00:34.970",
      "text": "回忆将我们扣留",
      "translation": null
    },
    {
      "time": 38.1,
      "time_str": "00:38.100",
      "text": "呜~一瞬间亲吻的时候",
      "translation": null
    },
    {
      "time": 42.97,
      "time_str": "00:42.970",
      "text": "一切就好像轮回般朦胧",
      "translation": null
    },
    {
      "time": 46.95,
      "time_str": "00:46.950",
      "text": "心动渐渐地失控",
      "translation": null
    },
    {
      "time": 51.83,
      "time_str": "00:51.830",
      "text": "是否两个人足够捕捉爱的镜头",
      "translation": null
    },
    {
      "time": 56.92,
      "time_str": "00:56.920",
      "text": "闭上了眼睛 记得你的笑容",
      "translation": null
    },
    {
      "time": 60.82,
      "time_str": "01:00.820",
      "text": "幸福的从容 将灵魂都掏空",
      "translation": null
    },
    {
      "time": 64.67,
      "time_str": "01:04.670",
      "text": "享受一分钟的感动",
      "translation": null
    },
    {
      "time": 67.89,
      "time_str": "01:07.890",
      "text": "是否爱上一个人 不问明天过后",
      "translation": null
    },
    {
      "time": 72.74,
      "time_str": "01:12.740",
      "text": "山明和水秀 不比你有看头",
      "translation": null
    },
    {
      "time": 76.92,
      "time_str": "01:16.920",
      "text": "牵着你的手 一直走到最后",
      "translation": null
    },
    {
      "time": 80.67,
      "time_str": "01:20.670",
      "text": "这一刻 怎么回头",
      "translation": null
    },
    {
