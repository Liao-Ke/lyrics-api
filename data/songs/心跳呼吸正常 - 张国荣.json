    {
      "time": 28.5,
      "time_str": "00:28.500",
      "text": "有心 仍来电关心 关注近况",
      "translation": null
    },
    {
      "time": 36.5,
      "time_str": "00:36.500",
      "text": "放心 仍承受得起 虽已受创",
      "translation": null
    },
    {
      "time": 44.3,
      "time_str": "00:44.300",
      "text": "其实我即使孤单依旧甚忙",
      "translation": null
    },
    {
      "time": 48.3,
      "time_str": "00:48.300",
      "text": "其实你不必担心我无事干",
      "translation": null
    },
    {
      "time": 52.3,
      "time_str": "00:52.300",
      "text": "有心 然而无谓探望",
      "translation": null
    },
    {
      "time": 61.5,
      "time_str": "01:01.500",
      "text": "放心 无穷尽空虚 总会面对",
      "translation": null
    },
    {
      "time": 70.0,
      "time_str": "01:10.000",
      "text": "放心 无涯岸漆黑 总会渐退",
      "translation": null
    },
    {
      "time": 76.5,
      "time_str": "01:16.500",
      "text": "无论你 当天撕得我心多破碎",
      "translation": null
    },
    {
