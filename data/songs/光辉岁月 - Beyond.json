  "lyrics": [
    {
      "time": 28.65,
      "time_str": "00:28.650",
      "text": "钟声响起归家的讯号",
      "translation": null
    },
    {
      "time": 33.036,
      "time_str": "00:33.036",
      "text": "在他生命里",
      "translation": null
    },
    {
      "time": 36.281,
      "time_str": "00:36.281",
      "text": "仿佛带点唏嘘",
      "translation": null
    },
    {
      "time": 41.564,
      "time_str": "00:41.564",
      "text": "黑色肌肤给他的意义",
      "translation": null
    },
    {
      "time": 46.038,
      "time_str": "00:46.038",
      "text": "是一生奉献 肤色斗争中",
      "translation": null
    },
    {
      "time": 54.543,
      "time_str": "00:54.543",
      "text": "年月把拥有变做失去",
      "translation": null
    },
    {
      "time": 61.056,
      "time_str": "01:01.056",
      "text": "疲倦的双眼带着期望",
      "translation": null
    },
    {
      "time": 67.551,
      "time_str": "01:07.551",
      "text": "今天只有残留的躯壳",
      "translation": null
    },
    {
      "time": 71.162,
      "time_str": "01:11.162",
      "text": "迎接光辉岁月",
      "translation": null
    },
    {
      "time": 74.391,
      "time_str": "01:14.391",
      "text": "风雨中抱紧自由",
      "translation": null
    },
    {
      "time": 80.515,
      "time_str": "01:20.515",
      "text": "一生经过彷徨的挣扎",
      "translation": null
    },
    {
      "time": 84.167,
      "time_str": "01:24.167",
      "text": "自信可改变未来",
      "translation": null
    },
    {
      "time": 87.343,
      "time_str": "01:27.343",
      "text": "问谁又能做到",
      "translation": null
    },
    {
      "time": 103.174,
      "time_str": "01:43.174",
      "text": "可否不分肤色的界限",
      "translation": null
    },
    {
      "time": 107.643,
      "time_str": "01:47.643",
      "text": "愿这土地里",
      "translation": null
    },
    {
      "time": 110.774,
      "time_str": "01:50.774",
      "text": "不分你我高低",
      "translation": null
    },
    {
      "time": 116.103,
      "time_str": "01:56.103",
      "text": "缤纷色彩闪出的美丽",
      "translation": null
    },
    {
      "time": 120.572,
      "time_str": "02:00.572",
      "text": "是因它没有",
      "translation": null
    },
    {
      "time": 123.764,
      "time_str": "02:03.764",
      "text": "分开每种色彩",
      "translation": null
    },
