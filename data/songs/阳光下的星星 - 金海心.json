    },
    {
      "time": 40.25,
      "time_str": "00:40.250",
      "text": "你说云落泪了风会吹干它",
      "translation": null
    },
    {
      "time": 46.87,
      "time_str": "00:46.870",
      "text": "我问风叹息又怎么安慰呢",
      "translation": null
    },
    {
      "time": 53.56,
      "time_str": "00:53.560",
      "text": "你只笑笑不回答",
      "translation": null
    },
    {
      "time": 56.68,
      "time_str": "00:56.680",
      "text": "说小姑娘别犯傻",
      "translation": null
