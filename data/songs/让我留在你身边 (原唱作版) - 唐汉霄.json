{
  "title": "让我留在你身边",
  "title_raw": "让我留在你身边 (原唱作版)",
  "version": "原唱作版",
  "artist": "唐汉霄",
  "group_key": "让我留在你身边|唐汉霄",
  "writers": {
    "lyricist": "唐汉霄",
    "composer": "唐汉霄",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 11.65,
      "time_str": "00:11.650",
      "text": "我从来不说话",
      "translation": null
    },
    {
      "time": 14.73,
      "time_str": "00:14.730",
      "text": "因为我害怕 没有人回答",
      "translation": null
    },
    {
      "time": 22.51,
      "time_str": "00:22.510",
      "text": "我从来不挣扎",
      "translation": null
    },
    {
      "time": 25.65,
      "time_str": "00:25.650",
      "text": "因为我知道 这世界太大",
      "translation": null
    },
    {
      "time": 33.48,
      "time_str": "00:33.480",
      "text": "太多时间浪费 太多事要面对",
      "translation": null
    },
    {
      "time": 38.92,
      "time_str": "00:38.920",
      "text": "太多已无所谓 太多难辨真伪",
      "translation": null
    },
    {
      "time": 47.07,
      "time_str": "00:47.070",
      "text": "太多纷扰是非 在你身边是谁",
      "translation": null
    },
    {
      "time": 55.74,
      "time_str": "00:55.740",
      "text": "最渺小的我 有大大的梦",
      "translation": null
    },
    {
      "time": 61.1,
      "time_str": "01:01.100",
      "text": "时间向前走一定只有路口没有尽头",
      "translation": null
    },
    {
      "time": 67.18,
      "time_str": "01:07.180",
      "text": "纷纷扰扰这个世界 所有的了解",
      "translation": null
    },
    {
      "time": 73.03,
      "time_str": "01:13.030",
      "text": "只要 让我留在你身边",
      "translation": null
    },
    {
      "time": 77.53,
      "time_str": "01:17.530",
      "text": "最渺小的我 有大大的梦",
      "translation": null
    },
    {
      "time": 82.99,
      "time_str": "01:22.990",
      "text": "我愿意安静的活在每个有你的角落",
      "translation": null
    },
    {
      "time": 88.99,
      "time_str": "01:28.990",
      "text": "如果生活还有什么 会让你难过",
      "translation": null
    },
    {
      "time": 94.9,
      "time_str": "01:34.900",
      "text": "别怕 让我留在你身边 都陪你度过",
      "translation": null
    },
    {
      "time": 126.64,
      "time_str": "02:06.640",
      "text": "最渺小的我 最卑微的梦",
      "translation": null
    },
    {
      "time": 132.04,
      "time_str": "02:12.040",
      "text": "我发现这世界没有那么那么的不同",
      "translation": null
    },
    {
      "time": 138.18,
      "time_str": "02:18.180",
      "text": "现实如果对你不公 别计较太多",
      "translation": null
    },
    {
      "time": 143.93,
      "time_str": "02:23.930",
      "text": "走吧 暴风雨后的彩虹",
      "translation": null
    },
    {
      "time": 151.14,
      "time_str": "02:31.140",
      "text": "也许会落空 也许会普通",
      "translation": null
    },
    {
      "time": 156.39,
      "time_str": "02:36.390",
      "text": "也许这庸庸碌碌的黑白世界你不懂",
      "translation": null
    },
    {
      "time": 162.69,
      "time_str": "02:42.690",
      "text": "生命中所有的路口 绝不是尽头",
      "translation": null
    },
    {
      "time": 168.46,
      "time_str": "02:48.460",
      "text": "别怕 让我留在你身边 都陪你度过",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "让我留在你身边 (原唱作版) - 唐汉霄.lrc"
}