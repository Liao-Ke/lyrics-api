  "lyrics": [
    {
      "time": 40.83,
      "time_str": "00:40.830",
      "text": "朦胧之间 仿佛我又看见你的脸",
      "translation": null
    },
    {
      "time": 49.24,
      "time_str": "00:49.240",
      "text": "依然带着淡淡忧愁的双眼",
      "translation": null
    },
    {
      "time": 52.4,
      "time_str": "00:52.400",
      "text": "忽隐忽现",
      "translation": null
    },
    {
      "time": 55.81,
      "time_str": "00:55.810",
      "text": "就当全是一场梦",
      "translation": null
    },
    {
      "time": 59.64,
      "time_str": "00:59.640",
      "text": "不必掩饰我的错",
      "translation": null
    },
    {
      "time": 62.71,
      "time_str": "01:02.710",
      "text": "无奈的苦笑不必找牵强的理由",
      "translation": null
    },
    {
      "time": 69.62,
      "time_str": "01:09.620",
      "text": "就让它日日夜夜刺痛我胸口",
      "translation": null
    },
    {
      "time": 77.46,
      "time_str": "01:17.460",
      "text": "让我眼神没有焦点",
      "translation": null
    },
    {
      "time": 80.88,
      "time_str": "01:20.880",
      "text": "泪水模糊我的视线",
      "translation": null
    },
    {
      "time": 89.23,
      "time_str": "01:29.230",
      "text": "输了你 赢了世界又如何",
      "translation": null
    },
    {
      "time": 96.37,
      "time_str": "01:36.370",
      "text": "你曾渴望的梦",
      "translation": null
    },
    {
      "time": 100.61,
      "time_str": "01:40.610",
      "text": "我想我永远不会懂我",
      "translation": null
    },
    {
      "time": 103.11,
      "time_str": "01:43.110",
      "text": "失去你 赢了一切却依然如此冷清",
      "translation": null
    },
    {
      "time": 114.78,
      "time_str": "01:54.780",
      "text": "有谁又能让我倾心 除了你",
      "translation": null
    },
    {
      "time": 137.94,
      "time_str": "02:17.940",
      "text": "你我之间 难道没有剩下一点点",
      "translation": null
    },
    {
      "time": 146.18,
      "time_str": "02:26.180",
      "text": "一点曾经刻骨铭心的眷恋 让你挂念",
      "translation": null
    },
    {
      "time": 152.6,
      "time_str": "02:32.600",
      "text": "我只能说如今我已无处可躲",
      "translation": null
    },
    {
      "time": 160.36,
      "time_str": "02:40.360",
      "text": "当我默默黯然回首",
      "translation": null
    },
    {
      "time": 163.85,
      "time_str": "02:43.850",
      "text": "当我看尽潮起潮落",
      "translation": null
