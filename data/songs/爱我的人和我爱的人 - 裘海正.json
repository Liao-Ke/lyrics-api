  "lyrics": [
    {
      "time": 19.965,
      "time_str": "00:19.965",
      "text": "盼不到我爱的人",
      "translation": null
    },
    {
      "time": 22.929,
      "time_str": "00:22.929",
      "text": "我知道我愿意再等",
      "translation": null
    },
    {
      "time": 27.379,
      "time_str": "00:27.379",
      "text": "疼不了爱我的人",
      "translation": null
    },
    {
      "time": 30.254,
      "time_str": "00:30.254",
      "text": "片刻柔情它骗不了人",
      "translation": null
    },
    {
      "time": 34.255,
      "time_str": "00:34.255",
      "text": "我不是无情的人",
      "translation": null
    },
    {
      "time": 36.12,
      "time_str": "00:36.120",
      "text": "却将你伤的最深",
      "translation": null
    },
    {
      "time": 38.467,
      "time_str": "00:38.467",
      "text": "我不忍 我不能",
      "translation": null
    },
    {
      "time": 42.34,
      "time_str": "00:42.340",
      "text": "别再认真",
      "translation": null
    },
    {
      "time": 44.285,
      "time_str": "00:44.285",
      "text": "忘了我的人",
      "translation": null
    },
    {
      "time": 49.916,
      "time_str": "00:49.916",
      "text": "离不开我爱的人",
      "translation": null
    },
    {
      "time": 52.935,
      "time_str": "00:52.935",
      "text": "我知道爱需要缘分",
      "translation": null
    },
    {
      "time": 57.46,
      "time_str": "00:57.460",
      "text": "放不下爱我的人",
      "translation": null
    },
    {
      "time": 60.168,
      "time_str": "01:00.168",
      "text": "因为了解他多么认真",
      "translation": null
    },
    {
      "time": 64.29,
      "time_str": "01:04.290",
      "text": "为什么最真的心",
      "translation": null
    },
    {
      "time": 66.187,
      "time_str": "01:06.187",
      "text": "碰不到最好的人",
      "translation": null
    },
    {
      "time": 68.547,
      "time_str": "01:08.547",
      "text": "我不问 我不能",
      "translation": null
    },
    {
      "time": 72.375,
      "time_str": "01:12.375",
      "text": "拥在怀中",
      "translation": null
    },
    {
      "time": 74.291,
      "time_str": "01:14.291",
      "text": "直到它变冷",
      "translation": null
    },
    {
      "time": 79.192,
      "time_str": "01:19.192",
      "text": "爱我的人对我痴心不悔",
      "translation": null
    },
    {
      "time": 83.01,
      "time_str": "01:23.010",
      "text": "我却为我爱的人甘心一生伤悲",
      "translation": null
    },
    {
      "time": 87.388,
      "time_str": "01:27.388",
      "text": "在乎的人始终不对",
      "translation": null
    },
    {
      "time": 90.902,
      "time_str": "01:30.902",
      "text": "谁对谁不必虚伪",
      "translation": null
    },
    {
      "time": 94.244,
      "time_str": "01:34.244",
      "text": "爱我的人为我付出一切",
      "translation": null
    },
    {
      "time": 97.881,
      "time_str": "01:37.881",
      "text": "我却为我爱的人流泪狂乱心碎",
      "translation": null
    },
    {
      "time": 102.395,
      "time_str": "01:42.395",
      "text": "爱与被爱同样受罪",
      "translation": null
    },
    {
      "time": 105.874,
      "time_str": "01:45.874",
      "text": "为什么不懂拒绝痴情的包围",
      "translation": null
    },
