      "time": 0.003,
      "time_str": "00:00.003",
      "text": "原唱 : 黄格选",
      "translation": null
    },
    {
      "time": 26.131,
      "time_str": "00:26.131",
      "text": "总想留住你匆匆的身影",
      "translation": null
    },
    {
      "time": 32.571,
      "time_str": "00:32.571",
      "text": "让我能有片刻的安宁",
      "translation": null
    },
    {
      "time": 39.191,
      "time_str": "00:39.191",
      "text": "明知我的梦像那飘忽的风",
      "translation": null
    },
    {
      "time": 45.509,
      "time_str": "00:45.509",
      "text": "却把我的心托付在梦中",
      "translation": null
    },
    {
      "time": 52.11,
      "time_str": "00:52.110",
      "text": "总想留住你回眸的笑容",
      "translation": null
    },
    {
      "time": 58.511,
      "time_str": "00:58.511",
      "text": "遮住我心忧伤的阴影",
      "translation": null
    },
    {
      "time": 65.11,
      "time_str": "01:05.110",
      "text": "明知你的心再也看不懂",
      "translation": null
    },
    {
      "time": 71.26,
      "time_str": "01:11.260",
      "text": "却宁愿相信你痴痴等",
      "translation": null
    },
    {
      "time": 77.761,
      "time_str": "01:17.761",
      "text": "总想拥有自己的天空",
      "translation": null
    },
    {
      "time": 84.135,
      "time_str": "01:24.135",
      "text": "却无奈流逝太多的青春",
