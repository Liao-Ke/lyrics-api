    {
      "time": 14.2,
      "time_str": "00:14.200",
      "text": "愁绪挥不去苦闷散不去",
      "translation": null
    },
    {
      "time": 21.2,
      "time_str": "00:21.200",
      "text": "为何我心一片空虚",
      "translation": null
    },
    {
      "time": 27.2,
      "time_str": "00:27.200",
      "text": "感情已失去一切都失去",
      "translation": null
    },
    {
      "time": 32.2,
      "time_str": "00:32.200",
      "text": "满腔恨愁不可消除",
      "translation": null
    },
    {
      "time": 39.2,
      "time_str": "00:39.200",
      "text": "为何你的嘴里总是那一句",
      "translation": null
    },
    {
      "time": 45.2,
      "time_str": "00:45.200",
      "text": "为何我的心不会死",
      "translation": null
    },
    {
      "time": 51.2,
      "time_str": "00:51.200",
      "text": "明白到爱失去一切都失去",
      "translation": null
    },
    {
      "time": 57.2,
      "time_str": "00:57.200",
      "text": "我又为何偏偏喜欢你",
      "translation": null
    },
    {
      "time": 62.2,
      "time_str": "01:02.200",
      "text": "爱已是负累 相爱似受罪",
      "translation": null
    },
    {
      "time": 69.2,
      "time_str": "01:09.200",
      "text": "心底如今满苦泪",
      "translation": null
    },
    {
      "time": 75.2,
      "time_str": "01:15.200",
      "text": "旧日情如醉 此际怕再追",
      "translation": null
    },
    {
      "time": 82.2,
      "time_str": "01:22.200",
      "text": "偏偏痴心想见你",
      "translation": null
    },
    {
      "time": 87.2,
      "time_str": "01:27.200",
      "text": "为何我心分秒想着过去",
      "translation": null
    },
    {
      "time": 93.2,
      "time_str": "01:33.200",
      "text": "为何你一点都不记起",
      "translation": null
    },
    {
      "time": 99.2,
