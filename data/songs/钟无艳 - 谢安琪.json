  "lyrics": [
    {
      "time": 21.076,
      "time_str": "00:21.076",
      "text": "其实我怕你 总夸奖高估我坚忍",
      "translation": null
    },
    {
      "time": 25.318,
      "time_str": "00:25.318",
      "text": "其实更怕你 只懂得欣赏我品行",
      "translation": null
    },
    {
      "time": 29.53,
      "time_str": "00:29.530",
      "text": "无人及我用字绝 重拾了你信心",
      "translation": null
    },
    {
      "time": 33.542,
      "time_str": "00:33.542",
      "text": "无人问我可甘心 演这伟大化身",
      "translation": null
    },
    {
      "time": 38.154,
      "time_str": "00:38.154",
      "text": "其实我想间中崩溃 脆弱如恋人",
      "translation": null
    },
    {
      "time": 42.392,
      "time_str": "00:42.392",
      "text": "垂在你两臂中 低得不需要身份",
      "translation": null
    },
    {
      "time": 46.67,
      "time_str": "00:46.670",
      "text": "无奈被你识穿这个念头",
      "translation": null
    },
    {
      "time": 49.601,
      "time_str": "00:49.601",
      "text": "得到好处的你 明示不想失去绝世好友",
      "translation": null
    },
    {
      "time": 55.313,
      "time_str": "00:55.313",
      "text": "没有得你的允许 我都会爱下去",
      "translation": null
    },
    {
      "time": 60.093,
      "time_str": "01:00.093",
      "text": "互相祝福心软之际 或者准我吻下去",
      "translation": null
    },
    {
      "time": 64.601,
      "time_str": "01:04.601",
      "text": "我痛恨成熟到 不要你望着我流泪",
      "translation": null
    },
    {
      "time": 68.879,
      "time_str": "01:08.879",
      "text": "但漂亮笑下去 仿佛冬天饮雪水",
      "translation": null
    },
    {
      "time": 72.866,
      "time_str": "01:12.866",
      "text": "被你一贯的赞许 却不配爱下去",
      "translation": null
    },
    {
      "time": 77.172,
      "time_str": "01:17.172",
      "text": "在你悲伤一刻必须解慰 找到我乐趣",
      "translation": null
    },
    {
      "time": 81.717,
      "time_str": "01:21.717",
      "text": "我甘于当副车 也是快乐着唏嘘",
      "translation": null
    },
    {
      "time": 86.034,
      "time_str": "01:26.034",
      "text": "彼此这么了解 难怪注定似兄妹 一对",
      "translation": null
    },
    {
      "time": 123.869,
      "time_str": "02:03.869",
      "text": "其实我怕你的好感 基于我修养",
      "translation": null
    },
    {
      "time": 128.116,
      "time_str": "02:08.116",
      "text": "其实最怕你的私心 窥准我体谅",
      "translation": null
    },
    {
      "time": 132.353,
      "time_str": "02:12.353",
      "text": "无人问我寂寞尽头 何处去养伤",
      "translation": null
    },
    {
      "time": 136.369,
      "time_str": "02:16.369",
      "text": "原来是我的心境高到 变为偶像",
      "translation": null
    },
    {
      "time": 140.937,
      "time_str": "02:20.937",
      "text": "谁情愿照耀着别人 就如月亮",
      "translation": null
    },
    {
      "time": 144.949,
      "time_str": "02:24.949",
      "text": "为奴婢为你备饭奉茶 是残忍真相",
      "translation": null
    },
    {
      "time": 149.476,
      "time_str": "02:29.476",
      "text": "无奈被你识穿这个念头",
      "translation": null
    },
    {
      "time": 152.406,
      "time_str": "02:32.406",
      "text": "得到好处的你 明示不想失去绝世好友",
      "translation": null
