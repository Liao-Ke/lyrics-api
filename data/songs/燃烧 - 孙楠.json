    {
      "time": 34.89,
      "time_str": "00:34.890",
      "text": "你 躲在我心里",
      "translation": null
    },
    {
      "time": 41.45,
      "time_str": "00:41.450",
      "text": "让我有心跳",
      "translation": null
    },
    {
      "time": 45.45,
      "time_str": "00:45.450",
      "text": "忘了你我就活不了",
      "translation": null
    },
    {
      "time": 49.85,
      "time_str": "00:49.850",
      "text": "时间的刀",
      "translation": null
    },
    {
      "time": 53.4,
      "time_str": "00:53.400",
      "text": "在它把记忆切断那一秒",
      "translation": null
    },
    {
      "time": 58.32,
      "time_str": "00:58.320",
      "text": "却没有带走",
      "translation": null
    },
    {
      "time": 61.16,
      "time_str": "01:01.160",
      "text": "爱附赠的烦恼",
      "translation": null
    },
    {
      "time": 66.52,
      "time_str": "01:06.520",
      "text": "爱 已经不太重要",
      "translation": null
    },
    {
      "time": 72.82,
      "time_str": "01:12.820",
      "text": "重要的只是",
      "translation": null
    },
    {
      "time": 76.9,
      "time_str": "01:16.900",
      "text": "我忘了把你忘掉",
      "translation": null
    },
    {
      "time": 81.27,
      "time_str": "01:21.270",
      "text": "时间很糟",
      "translation": null
    },
    {
      "time": 84.62,
      "time_str": "01:24.620",
      "text": "就算那吻过的人已老",
      "translation": null
    },
    {
      "time": 89.58,
      "time_str": "01:29.580",
      "text": "心在隐隐作痛",
      "translation": null
    },
    {
      "time": 92.58,
      "time_str": "01:32.580",
      "text": "哪管你要或不要",
      "translation": null
    },
    {
      "time": 97.239,
      "time_str": "01:37.239",
      "text": "燃烧",
      "translation": null
    },
    {
      "time": 99.99,
      "time_str": "01:39.990",
      "text": "想象不到痛还在燃烧",
      "translation": null
    },
    {
      "time": 104.489,
      "time_str": "01:44.489",
      "text": "以为火早已扑灭了",
      "translation": null
    },
    {
      "time": 108.28,
      "time_str": "01:48.280",
      "text": "怎么一见你",
      "translation": null
    },
    {
      "time": 110.19,
      "time_str": "01:50.190",
      "text": "心又被后悔灼伤了",
      "translation": null
    },
    {
