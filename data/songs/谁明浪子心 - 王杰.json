  "lyrics": [
    {
      "time": 28.527,
      "time_str": "00:28.527",
      "text": "可以笑的话 不会哭",
      "translation": null
    },
    {
      "time": 35.107,
      "time_str": "00:35.107",
      "text": "可找到知己 哪会孤独",
      "translation": null
    },
    {
      "time": 41.513,
      "time_str": "00:41.513",
      "text": "偏偏我永没有遇上",
      "translation": null
    },
    {
      "time": 43.968,
      "time_str": "00:43.968",
      "text": "问我一双足印的风霜 怎可结束",
      "translation": null
    },
    {
      "time": 52.135,
      "time_str": "00:52.135",
      "text": "可以爱的话 不退缩",
      "translation": null
    },
    {
      "time": 59.019,
      "time_str": "00:59.019",
      "text": "可相知的心 哪怕追逐",
      "translation": null
    },
    {
      "time": 65.335,
      "time_str": "01:05.335",
      "text": "可惜每次遇上热爱",
      "translation": null
    },
    {
      "time": 67.955,
      "time_str": "01:07.955",
      "text": "没法使我感觉我终于 遇上幸福",
      "translation": null
    },
    {
      "time": 76.063,
      "time_str": "01:16.063",
      "text": "你说爱我等于要把我捕捉",
      "translation": null
    },
    {
      "time": 82.758,
      "time_str": "01:22.758",
      "text": "实在没法担起这一种爱",
      "translation": null
    },
    {
      "time": 89.089,
      "time_str": "01:29.089",
      "text": "在这夜我又再度漂泊",
      "translation": null
    },
    {
      "time": 92.286,
      "time_str": "01:32.286",
      "text": "你的痴情 请勿继续",
      "translation": null
    },
    {
      "time": 95.846,
      "time_str": "01:35.846",
      "text": "请你收起一切",
      "translation": null
    },
    {
      "time": 96.543,
      "time_str": "01:36.543",
      "text": "相信这晚是结局",
      "translation": null
    },
    {
      "time": 103.335,
      "time_str": "01:43.335",
      "text": "听说太理想的恋爱",
      "translation": null
    },
    {
      "time": 106.233,
      "time_str": "01:46.233",
      "text": "总不可接触",
      "translation": null
    },
    {
      "time": 110.184,
      "time_str": "01:50.184",
      "text": "我却哪管千山走遍",
      "translation": null
    },
    {
      "time": 113.228,
      "time_str": "01:53.228",
      "text": "亦要设法去捕捉",
      "translation": null
    },
    {
      "time": 117.087,
      "time_str": "01:57.087",
      "text": "听说太理想的一切",
      "translation": null
    },
    {
      "time": 119.922,
      "time_str": "01:59.922",
      "text": "都不可接触",
      "translation": null
    },
    {
      "time": 123.835,
      "time_str": "02:03.835",
      "text": "我再置身寂寞路途",
      "translation": null
    },
    {
      "time": 126.796,
      "time_str": "02:06.796",
      "text": "在哪里会有幸福 幸福",
      "translation": null
    },
    {
      "time": 173.581,
      "time_str": "02:53.581",
      "text": "家与国的梦 不结束",
      "translation": null
    },
    {
      "time": 180.167,
      "time_str": "03:00.167",
      "text": "偏偏一颗心 抗拒屈服",
      "translation": null
    },
    {
      "time": 186.737,
      "time_str": "03:06.737",
      "text": "必须要确实领略到",
      "translation": null
    },
    {
      "time": 189.211,
      "time_str": "03:09.211",
      "text": "就算一生一世也甘心 没有侷促",
