  "lyrics": [
    {
      "time": 19.9,
      "time_str": "00:19.900",
      "text": "总想对你有些话要说",
      "translation": null
    },
    {
      "time": 23.44,
      "time_str": "00:23.440",
      "text": "可不知道该说些什么",
      "translation": null
    },
    {
      "time": 28.52,
      "time_str": "00:28.520",
      "text": "总想给你带来些欢乐",
      "translation": null
    },
    {
      "time": 32.6,
      "time_str": "00:32.600",
      "text": "可不知道你喜欢什么",
      "translation": null
    },
    {
      "time": 37.29,
      "time_str": "00:37.290",
      "text": "过了一夜又多了一天",
      "translation": null
    },
    {
      "time": 40.499,
      "time_str": "00:40.499",
      "text": "时间让人变的好心烦",
      "translation": null
    },
    {
      "time": 45.639,
      "time_str": "00:45.639",
      "text": "不知何时又才能见面",
      "translation": null
    },
    {
      "time": 49.179,
      "time_str": "00:49.179",
      "text": "难道就这样天各一边",
      "translation": null
    },
    {
      "time": 53.469,
      "time_str": "00:53.469",
      "text": "我不想让你哭",
      "translation": null
    },
    {
      "time": 55.549,
      "time_str": "00:55.549",
      "text": "我也不想认输",
      "translation": null
    },
    {
      "time": 58.499,
      "time_str": "00:58.499",
      "text": "只想用我的爱再次把你留住",
      "translation": null
    },
    {
      "time": 62.239,
      "time_str": "01:02.239",
      "text": "谁的眼泪随风飘向了远处",
      "translation": null
    },
    {
