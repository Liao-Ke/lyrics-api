      "text": "多么伤人",
      "translation": null
    },
    {
      "time": 145.98,
      "time_str": "02:25.980",
      "text": "让我爱上",
      "translation": null
    },
    {
      "time": 147.33,
      "time_str": "02:27.330",
      "text": "薄情的红唇",
      "translation": null
    },
    {
      "time": 151.7,
      "time_str": "02:31.700",
      "text": "深渊万丈你把我的爱",
      "translation": null
    },
    {
      "time": 154.86,
      "time_str": "02:34.860",
      "text": "用尽后丢弃荒野埋葬",
      "translation": null
    },
    {
      "time": 157.99,
      "time_str": "02:37.990",
      "text": "你犯的罪状没人知道",
      "translation": null
    },
    {
      "time": 161.47,
      "time_str": "02:41.470",
      "text": "用什么证明你的亲吻",
      "translation": null
    },
    {
      "time": 165.36,
      "time_str": "02:45.360",
      "text": "真的残忍",
      "translation": null
    },
    {
      "time": 168.96,
      "time_str": "02:48.960",
      "text": "我不知为什么",
      "translation": null
    },
    {
      "time": 170.05,
      "time_str": "02:50.050",
      "text": "你现在对我毫无感觉",
      "translation": null
    },
    {
      "time": 172.27,
      "time_str": "02:52.270",
      "text": "以前种种快乐",
      "translation": null
    },
    {
      "time": 173.47,
      "time_str": "02:53.470",
      "text": "就好像成为一种罪恶",
      "translation": null
    },
    {
      "time": 175.57,
      "time_str": "02:55.570",
      "text": "我的心情你不闻不问",
      "translation": null
    },
    {
      "time": 178.17,
      "time_str": "02:58.170",
      "text": "或者其实所谓爱情",
      "translation": null
    },
    {
      "time": 179.8,
      "time_str": "02:59.800",
      "text": "都只是彼此填满寂寞空虚",
      "translation": null
    },
    {
      "time": 182.43,
      "time_str": "03:02.430",
      "text": "或者是一种冲动的幻觉",
      "translation": null
    },
    {
      "time": 185.02,
      "time_str": "03:05.020",
      "text": "让自己失去理智",
      "translation": null
    },
    {
      "time": 186.58,
      "time_str": "03:06.580",
      "text": "到最后得到教训",
      "translation": null
    },
    {
      "time": 188.33,
      "time_str": "03:08.330",
      "text": "何时有感觉到何时没有知觉",
      "translation": null
    },
    {
      "time": 191.38,
      "time_str": "03:11.380",
      "text": "就算你突然失去音讯",
      "translation": null
    },
    {
      "time": 193.25,
      "time_str": "03:13.250",
      "text": "你我之间早就可能不该继续",
      "translation": null
    },
    {
      "time": 196.46,
      "time_str": "03:16.460",
      "text": "你吻得太逼真",
      "translation": null
    },
    {
      "time": 199.7,
      "time_str": "03:19.700",
      "text": "我已无法脱身",
      "translation": null
    },
    {
      "time": 203.2,
      "time_str": "03:23.200",
      "text": "Ooh",
      "translation": null
    },
    {
      "time": 204.11,
      "time_str": "03:24.110",
      "text": "最后悲剧发生",
      "translation": null
    },
    {
      "time": 206.05,
      "time_str": "03:26.050",
      "text": "我爱的深你没责任",
      "translation": null
    },
    {
      "time": 209.92,
      "time_str": "03:29.920",
      "text": "都怪我太认真",
      "translation": null
    },
    {
      "time": 213.45,
      "time_str": "03:33.450",
      "text": "把薄情的红唇亲吻",
      "translation": null
    }
