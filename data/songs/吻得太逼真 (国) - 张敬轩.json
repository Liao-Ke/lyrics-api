  "lyrics": [
    {
      "time": 27.7,
      "time_str": "00:27.700",
      "text": "无论怎么讲我都觉得虚伪",
      "translation": null
    },
    {
      "time": 30.85,
      "time_str": "00:30.850",
      "text": "陪伴你那么久你说是受罪",
      "translation": null
    },
    {
      "time": 34.32,
      "time_str": "00:34.320",
      "text": "从前到现在当我是谁",
      "translation": null
    },
    {
      "time": 37.96,
      "time_str": "00:37.960",
      "text": "你这花心蝴蝶",
      "translation": null
    },
    {
      "time": 41.29,
      "time_str": "00:41.290",
      "text": "昨夜陪你醉伤到我心碎",
      "translation": null
    },
    {
      "time": 44.89,
      "time_str": "00:44.890",
      "text": "你竟说我和你不配",
      "translation": null
    },
    {
      "time": 48.88,
      "time_str": "00:48.880",
      "text": "完全忘记往日为何",
      "translation": null
    },
    {
      "time": 51.9,
      "time_str": "00:51.900",
      "text": "能与我彻夜缠绵",
      "translation": null
    },
    {
      "time": 55.05,
      "time_str": "00:55.050",
      "text": "和你吻吻吻吻吻",
      "translation": null
    },
    {
      "time": 56.36,
      "time_str": "00:56.360",
      "text": "你吻得太逼真",
      "translation": null
    },
    {
      "time": 58.13,
      "time_str": "00:58.130",
      "text": "让我把虚情假意",
      "translation": null
    },
    {
      "time": 59.94,
      "time_str": "00:59.940",
      "text": "当作最真心的亲吻",
      "translation": null
    },
    {
      "time": 62.61,
      "time_str": "01:02.610",
      "text": "怪自己来不及区分",
      "translation": null
    },
    {
      "time": 65.17,
      "time_str": "01:05.170",
      "text": "你对我是酷爱是敷衍",
      "translation": null
    },
    {
      "time": 68.6,
      "time_str": "01:08.600",
      "text": "我想问问问问问",
      "translation": null
    },
    {
      "time": 70.04,
      "time_str": "01:10.040",
      "text": "我该怎么脱身",
      "translation": null
    },
    {
      "time": 71.87,
      "time_str": "01:11.870",
      "text": "你却说花花世界不必当真",
      "translation": null
    },
    {
      "time": 75.26,
      "time_str": "01:15.260",
      "text": "多么伤人",
      "translation": null
    },
    {
      "time": 77.35,
      "time_str": "01:17.350",
      "text": "让我爱上",
      "translation": null
    },
    {
      "time": 78.85,
      "time_str": "01:18.850",
      "text": "薄情的红唇",
      "translation": null
    },
    {
      "time": 96.32,
      "time_str": "01:36.320",
      "text": "拿什么心肠面对我的善良",
      "translation": null
    },
    {
      "time": 99.26,
      "time_str": "01:39.260",
      "text": "能不能想一想你让我多伤",
      "translation": null
    },
    {
      "time": 102.83,
      "time_str": "01:42.830",
      "text": "你的爱就像完美毒药",
      "translation": null
    },
    {
      "time": 106.52,
      "time_str": "01:46.520",
      "text": "对手断肠你依然漂亮",
      "translation": null
    },
    {
      "time": 110.0,
      "time_str": "01:50.000",
      "text": "不敢想曾与你度过",
      "translation": null
    },
    {
      "time": 113.48,
      "time_str": "01:53.480",
      "text": "多少真实的晚上",
      "translation": null
    },
    {
      "time": 117.02,
      "time_str": "01:57.020",
      "text": "一转眼热恋后身受重伤",
      "translation": null
    },
    {
      "time": 123.59,
      "time_str": "02:03.590",
      "text": "和你吻吻吻吻吻",
      "translation": null
    },
    {
      "time": 124.97,
      "time_str": "02:04.970",
      "text": "你吻得太逼真",
      "translation": null
    },
    {
      "time": 126.73,
