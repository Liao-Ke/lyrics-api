  "lyrics": [
    {
      "time": 12.19,
      "time_str": "00:12.190",
      "text": "我不懂是什么改变了我们",
      "translation": null
    },
    {
      "time": 17.73,
      "time_str": "00:17.730",
      "text": "再找不回信任的眼神",
      "translation": null
    },
    {
      "time": 23.49,
      "time_str": "00:23.490",
      "text": "时光穿梭在回忆里的愚笨",
      "translation": null
    },
    {
      "time": 28.25,
      "time_str": "00:28.250",
      "text": "没关系 我愿意一直等",
      "translation": null
    },
    {
      "time": 34.45,
      "time_str": "00:34.450",
      "text": "有时候心情就像缠绕的藤",
      "translation": null
    },
    {
      "time": 40.66,
      "time_str": "00:40.660",
      "text": "牢牢锁住由爱恨生的根",
      "translation": null
    },
    {
      "time": 45.91,
      "time_str": "00:45.910",
      "text": "是否感情滋生了情绪矛盾",
      "translation": null
    },
    {
      "time": 51.37,
      "time_str": "00:51.370",
      "text": "才会在 离别的时候喊疼",
      "translation": null
    },
    {
      "time": 57.73,
      "time_str": "00:57.730",
      "text": "连借口都没有",
      "translation": null
    },
    {
      "time": 60.18,
      "time_str": "01:00.180",
      "text": "连谎言都难厮守",
      "translation": null
    },
    {
      "time": 62.92,
      "time_str": "01:02.920",
      "text": "对不起你只会言不由衷",
      "translation": null
    },
    {
      "time": 69.05,
      "time_str": "01:09.050",
      "text": "连挽留都没用",
      "translation": null
    },
    {
      "time": 71.4,
      "time_str": "01:11.400",
      "text": "连转身都不回头",
      "translation": null
    },
    {
      "time": 74.45,
      "time_str": "01:14.450",
      "text": "你就像一道伤留在心中",
      "translation": null
    },
