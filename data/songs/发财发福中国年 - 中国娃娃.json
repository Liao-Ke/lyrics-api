    {
      "time": 73.19,
      "time_str": "01:13.190",
      "text": "祝大家快快乐乐见财有福",
      "translation": null
    },
    {
      "time": 75.77,
      "time_str": "01:15.770",
      "text": "（台）福气啦",
      "translation": null
    },
    {
      "time": 76.83,
      "time_str": "01:16.830",
      "text": "祝大家新年 恭喜恭喜发财",
      "translation": null
    },
    {
      "time": 78.86,
      "time_str": "01:18.860",
      "text": "中国娃娃祝大家",
      "translation": null
    },
    {
      "time": 80.48,
      "time_str": "01:20.480",
      "text": "Happy happy new year",
      "translation": null
    },
    {
      "time": 82.17,
      "time_str": "01:22.170",
      "text": "一天一天的过去",
      "translation": null
    },
    {
