      "time": 11.392,
      "time_str": "00:11.392",
      "text": "像断了线 消失人海里面",
      "translation": null
    },
    {
      "time": 18.868,
      "time_str": "00:18.868",
      "text": "我的眼终于失去 你的脸",
      "translation": null
    },
    {
      "time": 26.375,
      "time_str": "00:26.375",
      "text": "再等一会 奢望流星会出现",
      "translation": null
    },
    {
      "time": 33.898,
      "time_str": "00:33.898",
      "text": "愿 如果真的实现",
      "translation": null
    },
    {
      "time": 39.029,
      "time_str": "00:39.029",
      "text": "爱能不能永远",
      "translation": null
    },
    {
      "time": 42.799,
      "time_str": "00:42.799",
      "text": "明天 或许来不及变",
      "translation": null
    },
    {
      "time": 48.023,
      "time_str": "00:48.023",
      "text": "但曾经走过的昨天 越来越远",
      "translation": null
    },
    {
      "time": 56.855,
      "time_str": "00:56.855",
      "text": "北极星的眼泪 说不出的想念",
      "translation": null
    },
    {
      "time": 65.313,
      "time_str": "01:05.313",
      "text": "原来我们活在 两个世界",
      "translation": null
