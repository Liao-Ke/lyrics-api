  "lyrics": [
    {
      "time": 34.72,
      "time_str": "00:34.720",
      "text": "也许是玫瑰的香味",
      "translation": null
    },
    {
      "time": 38.36,
      "time_str": "00:38.360",
      "text": "让我尝到了爱的滋味",
      "translation": null
    },
    {
      "time": 42.15,
      "time_str": "00:42.150",
      "text": "卸下自己的防备",
      "translation": null
    },
    {
      "time": 44.79,
      "time_str": "00:44.790",
      "text": "也给了你伤害我的机会",
      "translation": null
    },
    {
      "time": 49.64,
      "time_str": "00:49.640",
      "text": "也许是我伪装不够完美",
      "translation": null
    },
    {
      "time": 53.34,
      "time_str": "00:53.340",
      "text": "让你轻易看出爱的纯粹",
      "translation": null
    },
    {
      "time": 57.03,
      "time_str": "00:57.030",
      "text": "我还在这里执迷不悔",
      "translation": null
    },
    {
      "time": 60.33,
      "time_str": "01:00.330",
      "text": "而你已决定要远走高飞",
      "translation": null
    },
    {
      "time": 66.96,
      "time_str": "01:06.960",
      "text": "爱上了你 我死心塌地",
      "translation": null
    },
    {
      "time": 70.3,
      "time_str": "01:10.300",
      "text": "就算你走了至少还有回忆",
      "translation": null
    },
    {
      "time": 74.53,
      "time_str": "01:14.530",
      "text": "爱到了底 害了自己",
      "translation": null
    },
    {
      "time": 78.67,
      "time_str": "01:18.670",
      "text": "再美的回忆里",
      "translation": null
    },
    {
      "time": 80.59,
      "time_str": "01:20.590",
      "text": "也只是冷冰的泪滴",
      "translation": null
    },
