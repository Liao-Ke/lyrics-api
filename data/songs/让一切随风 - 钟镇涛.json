  },
  "lyrics": [
    {
      "time": 44.68,
      "time_str": "00:44.680",
      "text": "风中风中 心里冷风",
      "translation": null
    },
    {
      "time": 48.49,
      "time_str": "00:48.490",
      "text": "吹失了梦",
      "translation": null
    },
    {
      "time": 51.81,
      "time_str": "00:51.810",
      "text": "事未过去 就已失踪",
      "translation": null
    },
    {
      "time": 55.68,
      "time_str": "00:55.680",
      "text": "此刻有种种心痛",
      "translation": null
    },
    {
      "time": 59.37,
      "time_str": "00:59.370",
      "text": "心中心中 一切似空",
      "translation": null
    },
    {
      "time": 63.12,
      "time_str": "01:03.120",
      "text": "天黑天光都似梦",
      "translation": null
    },
    {
      "time": 65.99,
      "time_str": "01:05.990",
      "text": "迷迷惘惘 聚满心中",
      "translation": null
    },
    {
      "time": 70.43,
      "time_str": "01:10.430",
      "text": "追踪一片冷的风",
      "translation": null
    },
    {
      "time": 73.56,
      "time_str": "01:13.560",
      "text": "各种空虚 冷冷冷",
      "translation": null
    },
    {
      "time": 77.99,
      "time_str": "01:17.990",
      "text": "吹起吹起风里梦",
      "translation": null
    },
    {
      "time": 81.12,
      "time_str": "01:21.120",
      "text": "过去的心 火般灼热",
      "translation": null
    },
    {
      "time": 85.24,
      "time_str": "01:25.240",
      "text": "今天已变了冰冻",
      "translation": null
    },
    {
      "time": 88.37,
      "time_str": "01:28.370",
      "text": "记忆中 突然又痛",
      "translation": null
    },
    {
      "time": 92.62,
      "time_str": "01:32.620",
      "text": "只因空虚再作弄",
      "translation": null
    },
    {
      "time": 95.81,
      "time_str": "01:35.810",
      "text": "你似北风 吹走我梦",
      "translation": null
    },
    {
      "time": 99.93,
      "time_str": "01:39.930",
      "text": "就让一切随风",
      "translation": null
    },
    {
