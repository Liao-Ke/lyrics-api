  "lyrics": [
    {
      "time": 13.42,
      "time_str": "00:13.420",
      "text": "当羁绊销声匿迹 按下暂停",
      "translation": null
    },
    {
      "time": 18.8,
      "time_str": "00:18.800",
      "text": "当欲望埋葬彻底 誓为贪欢行刑",
      "translation": null
    },
    {
      "time": 25.28,
      "time_str": "00:25.280",
      "text": "谁是盒中的巧克力 不见身影",
      "translation": null
    },
    {
      "time": 30.89,
      "time_str": "00:30.890",
      "text": "亦或是 可望不可即的星",
      "translation": null
    },
    {
      "time": 37.98,
      "time_str": "00:37.980",
      "text": "步步试探 精心设计剧情",
      "translation": null
    },
    {
      "time": 43.8,
      "time_str": "00:43.800",
      "text": "别轻易沉迷 琥珀瞳孔中的倒影",
      "translation": null
    },
    {
      "time": 46.75,
      "time_str": "00:46.750",
      "text": "注定跌入陷阱",
      "translation": null
    },
    {
      "time": 52.83,
      "time_str": "00:52.830",
      "text": "银色藤蔓 经久不息缠迷",
      "translation": null
    },
    {
      "time": 58.76,
      "time_str": "00:58.760",
      "text": "情难自禁 无法抑制上瘾。",
      "translation": null
    },
    {
      "time": 64.85,
      "time_str": "01:04.850",
      "text": "红光闪烁映照调皮游戏，",
      "translation": null
    },
    {
      "time": 71.03,
      "time_str": "01:11.030",
      "text": "鼓足勇气诉说 旖旎言语。",
      "translation": null
    },
    {
      "time": 77.11,
      "time_str": "01:17.110",
      "text": "触手可及 谁在悄悄靠近",
      "translation": null
    },
    {
      "time": 83.2,
      "time_str": "01:23.200",
      "text": "情潮汹涌 还需几分耐心",
      "translation": null
    },
    {
      "time": 89.42,
      "time_str": "01:29.420",
      "text": "请试着相信 我将全心奉献自己",
      "translation": null
    },
    {
      "time": 95.6,
      "time_str": "01:35.600",
      "text": "去证明 真爱 矢志不渝",
      "translation": null
    },
    {
      "time": 115.42,
      "time_str": "01:55.420",
      "text": "警戒响起 命定灵魂相吸",
      "translation": null
    },
    {
      "time": 121.05,
      "time_str": "02:01.050",
      "text": "将每个亲吻都变成盛大的窃喜",
      "translation": null
    },
    {
      "time": 124.29,
      "time_str": "02:04.290",
      "text": "欲望泛滥彻底",
      "translation": null
    },
    {
      "time": 129.63,
      "time_str": "02:09.630",
      "text": "银色藤蔓 经久不息缠迷",
      "translation": null
    },
    {
      "time": 135.74,
      "time_str": "02:15.740",
      "text": "情难自禁 无法抑制上瘾",
      "translation": null
    },
    {
      "time": 142.16,
      "time_str": "02:22.160",
      "text": "灼人目光 融化所有冰雪凉意",
      "translation": null
    },
    {
      "time": 148.26,
      "time_str": "02:28.260",
      "text": "耳边轻柔低吟 残酷蜜语",
      "translation": null
    },
    {
      "time": 154.28,
      "time_str": "02:34.280",
      "text": "触手可及 谁也不曾远离",
      "translation": null
    },
    {
      "time": 160.45,
      "time_str": "02:40.450",
      "text": "情潮汹涌 冲破封存爱意",
      "translation": null
    },
    {
      "time": 166.6,
      "time_str": "02:46.600",
      "text": "当星破碎 坠落深渊 缔结印记",
      "translation": null
    },
    {
      "time": 172.84,
      "time_str": "02:52.840",
      "text": "我将宣告 真爱 矢志不渝",
      "translation": null
    },
    {
      "time": 196.24,
      "time_str": "03:16.240",
