    {
      "time": 3.3,
      "time_str": "00:03.300",
      "text": "原唱 : 黄仲昆",
      "translation": null
    },
    {
      "time": 24.4,
      "time_str": "00:24.400",
      "text": "常常责怪自己当初不应该",
      "translation": null
    },
    {
      "time": 32.78,
      "time_str": "00:32.780",
      "text": "常常后悔没有把你留下来",
      "translation": null
    },
    {
      "time": 40.45,
      "time_str": "00:40.450",
      "text": "为什么明明相爱",
      "translation": null
    },
    {
      "time": 46.15,
      "time_str": "00:46.150",
      "text": "到最后还是要分开",
      "translation": null
    },
    {
      "time": 48.89,
      "time_str": "00:48.890",
      "text": "是否我们总是徘徊在心门之外",
      "translation": null
    },
    {
      "time": 57.68,
      "time_str": "00:57.680",
      "text": "谁知道又和你相遇在人海",
      "translation": null
    },
    {
      "time": 65.47,
      "time_str": "01:05.470",
      "text": "命运如此安排总叫人无奈",
      "translation": null
    },
    {
      "time": 74.08,
      "time_str": "01:14.080",
      "text": "这些年过得不好不坏",
      "translation": null
    },
    {
      "time": 78.75,
      "time_str": "01:18.750",
      "text": "只是好像少了一个人存在",
      "translation": null
    },
    {
      "time": 83.07,
      "time_str": "01:23.070",
      "text": "而我渐渐明白",
      "translation": null
    },
    {
      "time": 85.51,
      "time_str": "01:25.510",
      "text": "你仍然是我不变的关怀",
      "translation": null
    },
    {
      "time": 91.5,
      "time_str": "01:31.500",
      "text": "有多少爱可以重来",
      "translation": null
    },
    {
      "time": 95.87,
      "time_str": "01:35.870",
      "text": "有多少人愿意等待",
      "translation": null
    },
    {
      "time": 100.13,
      "time_str": "01:40.130",
      "text": "当懂得珍惜以后归来",
      "translation": null
    },
    {
      "time": 103.07,
      "time_str": "01:43.070",
      "text": "却不知那份爱会不会还在",
      "translation": null
    },
    {
