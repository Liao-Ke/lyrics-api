    {
      "time": 220.333,
      "time_str": "03:40.333",
      "text": "请你不要再迷恋哥",
      "translation": null
    },
    {
      "time": 222.177,
      "time_str": "03:42.177",
      "text": "（我荣耀 我落魄 我期盼）",
      "translation": null
    },
    {
      "time": 224.056,
      "time_str": "03:44.056",
      "text": "哥只是一个传说",
      "translation": null
    },
    {
      "time": 225.571,
      "time_str": "03:45.571",
      "text": "（我堕落 我挥霍 我窘迫 我漂泊 我稳固）",
      "translation": null
    },
    {
      "time": 226.765,
      "time_str": "03:46.765",
      "text": "虽然我 舍不得",
      "translation": null
    },
    {
      "time": 227.718,
      "time_str": "03:47.718",
      "text": "（我深爱 我幸福 我放纵 我悔恨）",
      "translation": null
    },
    {
      "time": 229.326,
      "time_str": "03:49.326",
      "text": "可是我 还是要说",
      "translation": null
    },
    {
      "time": 230.178,
      "time_str": "03:50.178",
      "text": "（我醒悟 我失落 我一切都做过）",
      "translation": null
    },
    {
      "time": 231.882,
      "time_str": "03:51.882",
      "text": "你不要再迷恋我",
      "translation": null
    },
    {
      "time": 233.0,
      "time_str": "03:53.000",
      "text": "（现在我清醒了 玩够了 释然了）",
      "translation": null
    },
    {
      "time": 234.511,
      "time_str": "03:54.511",
      "text": "我只是一个传说",
      "translation": null
    },
    {
      "time": 235.597,
      "time_str": "03:55.597",
      "text": "（看透了 回头了 承受了 从此之后）",
      "translation": null
    },
    {
      "time": 237.685,
      "time_str": "03:57.685",
      "text": "我 不曾寂寞",
      "translation": null
    },
    {
      "time": 238.5,
      "time_str": "03:58.500",
      "text": "（不再争斗了不再奢求了也就）",
      "translation": null
    },
    {
      "time": 239.709,
      "time_str": "03:59.709",
      "text": "因为有你曾陪着我",
      "translation": null
    },
    {
      "time": 241.028,
