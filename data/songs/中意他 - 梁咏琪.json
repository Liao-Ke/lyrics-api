  "lyrics": [
    {
      "time": 13.34,
      "time_str": "00:13.340",
      "text": "半夜三更还在讲电话",
      "translation": null
    },
    {
      "time": 16.33,
      "time_str": "00:16.330",
      "text": "你没有勇气说出那句话",
      "translation": null
    },
    {
      "time": 19.42,
      "time_str": "00:19.420",
      "text": "相信未来你已有计划",
      "translation": null
    },
    {
      "time": 22.46,
      "time_str": "00:22.460",
      "text": "左等右等只差一个说法",
      "translation": null
    },
    {
      "time": 25.56,
      "time_str": "00:25.560",
      "text": "挂掉了电话 拨乱了头发",
      "translation": null
    },
    {
      "time": 28.62,
      "time_str": "00:28.620",
      "text": "我们的世界 已没有时差",
      "translation": null
    },
    {
      "time": 31.67,
      "time_str": "00:31.670",
      "text": "防备已放假 心不再挣扎",
      "translation": null
    },
    {
      "time": 34.77,
      "time_str": "00:34.770",
      "text": "摒住呼吸告诉他 我是多么的中意他",
      "translation": null
    },
    {
      "time": 39.43,
      "time_str": "00:39.430",
      "text": "没有害怕 每次约会",
      "translation": null
    },
    {
      "time": 42.47,
      "time_str": "00:42.470",
      "text": "心中总会有火花",
      "translation": null
    },
    {
      "time": 43.99,
      "time_str": "00:43.990",
      "text": "梦见一幅画 有我和他",
      "translation": null
    },
    {
      "time": 47.08,
      "time_str": "00:47.080",
      "text": "微笑的我 穿着长长的白纱",
      "translation": null
    },
    {
      "time": 50.15,
      "time_str": "00:50.150",
      "text": "Da-da-di-da 中意他 中意他 他的步伐",
      "translation": null
    },
    {
      "time": 53.57,
      "time_str": "00:53.570",
      "text": "让我的世界 起了大变化",
      "translation": null
    },
    {
      "time": 56.29,
      "time_str": "00:56.290",
      "text": "Da-da-di-da 中意他 中意他 他的胡渣",
      "translation": null
    },
    {
      "time": 59.69,
      "time_str": "00:59.690",
      "text": "幻想一个家 为他生一个胖娃娃",
      "translation": null
    },
    {
      "time": 74.77,
      "time_str": "01:14.770",
      "text": "半夜三更还在讲电话",
      "translation": null
