    {
      "time": 0.4,
      "time_str": "00:00.400",
      "text": "没有什么能够阻挡",
      "translation": null
    },
    {
      "time": 5.71,
      "time_str": "00:05.710",
      "text": "你对自由的向往",
      "translation": null
    },
    {
      "time": 11.13,
      "time_str": "00:11.130",
      "text": "天马行空的生涯",
      "translation": null
    },
    {
      "time": 16.69,
      "time_str": "00:16.690",
      "text": "你的心了无牵挂",
      "translation": null
    },
    {
      "time": 22.33,
      "time_str": "00:22.330",
      "text": "穿过幽暗的岁月",
      "translation": null
    },
    {
      "time": 27.51,
      "time_str": "00:27.510",
      "text": "也曾感到彷徨",
      "translation": null
    },
    {
      "time": 32.83,
      "time_str": "00:32.830",
      "text": "当你低头的瞬间",
      "translation": null
    },
    {
      "time": 38.02,
      "time_str": "00:38.020",
      "text": "才发觉脚下的路",
      "translation": null
    },
    {
      "time": 43.49,
      "time_str": "00:43.490",
      "text": "心中那自由的世界",
      "translation": null
    },
    {
      "time": 49.2,
      "time_str": "00:49.200",
      "text": "如此的清澈高远",
      "translation": null
    },
    {
      "time": 54.01,
      "time_str": "00:54.010",
      "text": "盛开着永不凋零",
      "translation": null
    },
    {
      "time": 58.2,
      "time_str": "00:58.200",
      "text": "蓝莲花",
