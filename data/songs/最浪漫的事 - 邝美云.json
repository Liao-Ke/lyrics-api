  "lyrics": [
    {
      "time": 18.29,
      "time_str": "00:18.290",
      "text": "背靠着背 坐在地毯上",
      "translation": null
    },
    {
      "time": 22.99,
      "time_str": "00:22.990",
      "text": "听听音乐 聊聊愿望",
      "translation": null
    },
    {
      "time": 26.61,
      "time_str": "00:26.610",
      "text": "你希望我越来越温柔",
      "translation": null
    },
    {
      "time": 30.599,
      "time_str": "00:30.599",
      "text": "我希望你放我在心上",
      "translation": null
    },
    {
      "time": 36.58,
      "time_str": "00:36.580",
      "text": "你说想送我个浪漫的梦想",
      "translation": null
    },
    {
      "time": 40.53,
      "time_str": "00:40.530",
      "text": "谢谢我带你找到天堂",
      "translation": null
    },
    {
      "time": 45.04,
      "time_str": "00:45.040",
      "text": "哪怕用一辈子才能完成",
      "translation": null
    },
    {
      "time": 49.22,
      "time_str": "00:49.220",
      "text": "只要我讲你就记住不忘",
      "translation": null
    },
    {
      "time": 55.58,
      "time_str": "00:55.580",
      "text": "我能想到最浪漫的事",
      "translation": null
    },
    {
      "time": 59.37,
      "time_str": "00:59.370",
      "text": "就是和你一起慢慢变老",
      "translation": null
    },
    {
      "time": 63.89,
      "time_str": "01:03.890",
      "text": "一路上收藏点点滴滴的欢笑",
      "translation": null
    },
    {
      "time": 67.67,
      "time_str": "01:07.670",
      "text": "留到以后 坐着摇椅 慢慢聊",
      "translation": null
    },
    {
      "time": 72.25,
      "time_str": "01:12.250",
      "text": "我能想到最浪漫的事",
      "translation": null
    },
    {
      "time": 77.2,
      "time_str": "01:17.200",
      "text": "就是和你一起慢慢变老",
      "translation": null
    },
    {
      "time": 80.86,
      "time_str": "01:20.860",
      "text": "直到我们老的哪儿也去不了",
      "translation": null
    },
    {
      "time": 84.98,
      "time_str": "01:24.980",
      "text": "你还依然 把我当成 手心里的宝",
