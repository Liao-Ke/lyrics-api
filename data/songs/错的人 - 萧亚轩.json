    {
      "time": 15.28,
      "time_str": "00:15.280",
      "text": "明知道爱情并不牢靠",
      "translation": null
    },
    {
      "time": 21.47,
      "time_str": "00:21.470",
      "text": "但是我还是拼命往里跳",
      "translation": null
    },
    {
      "time": 29.97,
      "time_str": "00:29.970",
      "text": "明知道再走可能是监牢",
      "translation": null
    },
    {
      "time": 36.6,
      "time_str": "00:36.600",
      "text": "但是我还是相信只是煎熬",
      "translation": null
    },
    {
      "time": 45.04,
      "time_str": "00:45.040",
      "text": "朋友都劝我不要不要",
      "translation": null
    },
    {
      "time": 51.6,
      "time_str": "00:51.600",
      "text": "不要拿自己的幸福开玩笑",
      "translation": null
    },
    {
      "time": 59.1,
      "time_str": "00:59.100",
      "text": "但是做人已经那么累",
      "translation": null
    },
    {
      "time": 62.85,
      "time_str": "01:02.850",
      "text": "假惺惺的想要逃",
      "translation": null
    },
    {
      "time": 66.66,
      "time_str": "01:06.660",
      "text": "在爱里连真心都不能给",
      "translation": null
    },
    {
      "time": 70.35,
      "time_str": "01:10.350",
      "text": "这才真正的可笑",
      "translation": null
    },
    {
      "time": 75.1,
      "time_str": "01:15.100",
      "text": "爱得太真 太容易 让自己牺牲",
      "translation": null
    },
    {
      "time": 80.79,
      "time_str": "01:20.790",
      "text": "太容易让自己沉沦",
      "translation": null
    },
    {
