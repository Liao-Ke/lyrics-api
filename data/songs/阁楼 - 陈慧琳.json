  "lyrics": [
    {
      "time": 6.04,
      "time_str": "00:06.040",
      "text": "他隐居在阁楼 与我情同密友",
      "translation": null
    },
    {
      "time": 12.14,
      "time_str": "00:12.140",
      "text": "当初一双怨偶 逐点修复了温柔",
      "translation": null
    },
    {
      "time": 18.3,
      "time_str": "00:18.300",
      "text": "昨晚一直挽手 吻到黎明亮透",
      "translation": null
    },
    {
      "time": 25.03,
      "time_str": "00:25.030",
      "text": "何以各位都说 我跟他已经分手",
      "translation": null
    },
    {
      "time": 31.37,
      "time_str": "00:31.370",
      "text": "由得他 如隐居 从此窝藏心里",
      "translation": null
    },
    {
      "time": 38.16,
      "time_str": "00:38.160",
      "text": "长居我那 幻想的世界 填满我空虚",
      "translation": null
    },
    {
      "time": 43.81,
      "time_str": "00:43.810",
      "text": "不许 谁不许",
      "translation": null
    },
    {
      "time": 46.28,
      "time_str": "00:46.280",
      "text": "陶醉到 不出去",
      "translation": null
    },
    {
      "time": 50.35,
      "time_str": "00:50.350",
      "text": "若全世界的街里 没人与我登对",
      "translation": null
    },
    {
      "time": 56.55,
      "time_str": "00:56.550",
      "text": "何妨让我作个 伴侣",
      "translation": null
    },
    {
      "time": 81.37,
      "time_str": "01:21.370",
      "text": "他根本没有走 那厚爱同样厚",
      "translation": null
    },
    {
      "time": 87.06,
      "time_str": "01:27.060",
      "text": "当周遭伤透我 但他总待我温柔",
      "translation": null
    },
    {
      "time": 93.16,
      "time_str": "01:33.160",
      "text": "说我家没阁楼 我信存在就有",
      "translation": null
    },
    {
      "time": 100.37,
      "time_str": "01:40.370",
      "text": "唯有我先知道 放他出去的出口",
      "translation": null
    },
    {
      "time": 106.2,
      "time_str": "01:46.200",
      "text": "由得他 如隐居 从此窝藏心里",
      "translation": null
    },
    {
      "time": 113.19,
      "time_str": "01:53.190",
      "text": "长居我那 幻想的世界 填满我空虚",
      "translation": null
    },
    {
      "time": 118.82,
      "time_str": "01:58.820",
      "text": "不许 谁不许",
      "translation": null
    },
    {
      "time": 121.02,
      "time_str": "02:01.020",
      "text": "陶醉到 不归队",
      "translation": null
    },
    {
      "time": 125.06,
      "time_str": "02:05.060",
      "text": "若全世界的街里 没人与我登对",
      "translation": null
    },
    {
      "time": 131.22,
      "time_str": "02:11.220",
      "text": "何妨让我作个 伴侣",
      "translation": null
    },
    {
      "time": 146.06,
      "time_str": "02:26.060",
      "text": "由得他 如隐居 从此窝藏心里",
      "translation": null
    },
    {
      "time": 152.48,
      "time_str": "02:32.480",
      "text": "毋需世界 在七嘴八舌 还替我唏嘘",
      "translation": null
    },
    {
      "time": 158.12,
      "time_str": "02:38.120",
      "text": "不许 谁不许 唯有我 可拣取",
      "translation": null
    },
    {
      "time": 164.61,
      "time_str": "02:44.610",
      "text": "共谁每晚都相对 让谁赐我生趣",
      "translation": null
    },
    {
      "time": 170.97,
      "time_str": "02:50.970",
      "text": "闲人莫进 劝你后退",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "阁楼 - 陈慧琳.lrc"
}