  "lyrics": [
    {
      "time": 1.124,
      "time_str": "00:01.124",
      "text": "指挥家 : 钟兴民",
      "translation": null
    },
    {
      "time": 2.248,
      "time_str": "00:02.248",
      "text": "贝斯 : 陈任佑",
      "translation": null
    },
    {
      "time": 2.529,
      "time_str": "00:02.529",
      "text": "弦乐编写 : 钟兴民",
      "translation": null
    },
    {
      "time": 16.196,
      "time_str": "00:16.196",
      "text": "久未放晴的天空",
      "translation": null
    },
    {
      "time": 20.112,
      "time_str": "00:20.112",
      "text": "依旧留着你的笑容",
      "translation": null
    },
    {
      "time": 24.481,
      "time_str": "00:24.481",
      "text": "哭过 却无法掩埋歉疚",
      "translation": null
    },
    {
      "time": 31.818,
      "time_str": "00:31.818",
      "text": "风筝在阴天搁浅",
      "translation": null
    },
    {
      "time": 35.775,
      "time_str": "00:35.775",
      "text": "想念还在等待救援",
      "translation": null
    },
    {
      "time": 40.116,
      "time_str": "00:40.116",
      "text": "我拉着线 复习你给的温柔",
      "translation": null
    },
    {
      "time": 46.44,
      "time_str": "00:46.440",
      "text": "曝晒在一旁的寂寞",
      "translation": null
    },
    {
      "time": 50.567,
      "time_str": "00:50.567",
      "text": "笑我给不起承诺",
      "translation": null
    },
    {
      "time": 53.756,
      "time_str": "00:53.756",
      "text": "怎么会 怎么会",
      "translation": null
    },
    {
      "time": 56.406,
      "time_str": "00:56.406",
      "text": "你竟原谅了我",
      "translation": null
    },
    {
      "time": 61.051,
      "time_str": "01:01.051",
      "text": "我只能永远读着对白",
      "translation": null
    },
    {
      "time": 65.516,
      "time_str": "01:05.516",
      "text": "读着我给你的伤害",
      "translation": null
    },
    {
      "time": 69.366,
      "time_str": "01:09.366",
      "text": "我原谅不了我",
      "translation": null
    },
    {
      "time": 72.044,
      "time_str": "01:12.044",
      "text": "就请你当作我已不在",
      "translation": null
    },
    {
      "time": 76.725,
      "time_str": "01:16.725",
      "text": "我睁开双眼 看着空白",
      "translation": null
    },
    {
      "time": 81.169,
      "time_str": "01:21.169",
      "text": "忘记你对我的期待",
      "translation": null
    },
    {
      "time": 85.075,
      "time_str": "01:25.075",
      "text": "读完了依赖 我很快就离开",
      "translation": null
    },
