  "lyrics": [
    {
      "time": 26.58,
      "time_str": "00:26.580",
      "text": "离开你一百个星期",
      "translation": null
    },
    {
      "time": 28.52,
      "time_str": "00:28.520",
      "text": "我回到了这里",
      "translation": null
    },
    {
      "time": 29.37,
      "time_str": "00:29.370",
      "text": "寻找我们爱过的证据",
      "translation": null
    },
    {
      "time": 31.96,
      "time_str": "00:31.960",
      "text": "没有人愿意提起",
      "translation": null
    },
    {
      "time": 33.27,
      "time_str": "00:33.270",
      "text": "玫瑰花它的过去",
      "translation": null
    },
    {
      "time": 34.89,
      "time_str": "00:34.890",
      "text": "今天这里的主题",
      "translation": null
    },
    {
      "time": 36.17,
      "time_str": "00:36.170",
      "text": "我把它叫作 回忆",
      "translation": null
    },
    {
      "time": 37.78,
      "time_str": "00:37.780",
      "text": "我知道 爱情这东西",
      "translation": null
    },
    {
      "time": 39.53,
      "time_str": "00:39.530",
      "text": "他没什么道理",
      "translation": null
    },
    {
      "time": 40.65,
      "time_str": "00:40.650",
      "text": "过去我和你在一起",
      "translation": null
    },
    {
      "time": 42.33,
      "time_str": "00:42.330",
      "text": "是我太叛逆",
      "translation": null
    },
    {
      "time": 43.64,
      "time_str": "00:43.640",
      "text": "现在只剩我自己",
      "translation": null
    },
    {
      "time": 45.51,
      "time_str": "00:45.510",
      "text": "偷偷的想你",
      "translation": null
    },
    {
      "time": 49.01,
      "time_str": "00:49.010",
      "text": "玫瑰花的葬礼",
      "translation": null
    },
    {
      "time": 51.75,
      "time_str": "00:51.750",
      "text": "埋葬关于你的回忆",
      "translation": null
    },
    {
      "time": 54.94,
      "time_str": "00:54.940",
      "text": "感觉双手麻痹",
      "translation": null
    },
    {
      "time": 57.3,
      "time_str": "00:57.300",
      "text": "不能自已",
      "translation": null
    },
    {
      "time": 58.8,
      "time_str": "00:58.800",
      "text": "已拉不住你",
      "translation": null
    },
    {
      "time": 60.98,
      "time_str": "01:00.980",
      "text": "真的好美丽",
      "translation": null
    },
    {
      "time": 63.54,
      "time_str": "01:03.540",
      "text": "那天的烟花雨",
      "translation": null
    },
    {
      "time": 66.79,
      "time_str": "01:06.790",
      "text": "我说要娶穿碎花洋裙的你",
      "translation": null
    },
    {
      "time": 72.41,
      "time_str": "01:12.410",
      "text": "玫瑰花的葬礼",
      "translation": null
    },
    {
      "time": 75.33,
      "time_str": "01:15.330",
      "text": "埋葬深深爱着的你",
      "translation": null
    },
    {
      "time": 78.39,
      "time_str": "01:18.390",
      "text": "残朵停止呼吸",
      "translation": null
    },
    {
      "time": 80.77,
      "time_str": "01:20.770",
      "text": "渗入大地",
      "translation": null
    },
    {
      "time": 82.2,
      "time_str": "01:22.200",
      "text": "没人会注意",
      "translation": null
    },
    {
      "time": 84.32,
      "time_str": "01:24.320",
      "text": "一片小雨滴",
      "translation": null
    },
    {
      "time": 86.95,
      "time_str": "01:26.950",
      "text": "陪着我等天明",
      "translation": null
    },
    {
      "time": 90.32,
      "time_str": "01:30.320",
      "text": "我用这最后一分钟怀念你",
      "translation": null
    },
    {
      "time": 96.92,
      "time_str": "01:36.920",
      "text": "我在夜幕笼罩的天桥上潜行",
      "translation": null
    },
    {
      "time": 99.74,
      "time_str": "01:39.740",
      "text": "每一级阶梯",
      "translation": null
    },
    {
      "time": 100.85,
      "time_str": "01:40.850",
      "text": "都留着你我昔日印迹",
      "translation": null
    },
    {
      "time": 102.86,
      "time_str": "01:42.860",
      "text": "温存迷醉 吵闹清醒",
      "translation": null
    },
    {
      "time": 105.16,
      "time_str": "01:45.160",
      "text": "都还在我的脚畔",
      "translation": null
    },
    {
      "time": 106.28,
      "time_str": "01:46.280",
      "text": "兜兜兜兜兜转不清",
      "translation": null
    },
    {
      "time": 108.01,
      "time_str": "01:48.010",
      "text": "没来得及把红色玫瑰递给你",
      "translation": null
    },
    {
      "time": 110.32,
      "time_str": "01:50.320",
      "text": "爱就像是一场雨",
      "translation": null
    },
    {
      "time": 111.76,
      "time_str": "01:51.760",
      "text": "已经离我而去",
      "translation": null
    },
    {
      "time": 113.25,
      "time_str": "01:53.250",
      "text": "你说过",
      "translation": null
    },
    {
      "time": 113.89,
      "time_str": "01:53.890",
      "text": "太过鲜艳的爱情 终将凋零",
      "translation": null
    },
