{
  "title": "空港",
  "title_raw": "空港",
  "version": null,
  "artist": "戴爱玲",
  "group_key": "空港|戴爱玲",
  "writers": {
    "lyricist": "武雄",
    "composer": "周恒毅",
    "arranger": "周恒毅/蔡科俊"
  },
  "lyrics": [
    {
      "time": 27.11,
      "time_str": "00:27.110",
      "text": "话 已经讲完 爱已风干",
      "translation": null
    },
    {
      "time": 33.99,
      "time_str": "00:33.990",
      "text": "心 不再摇晃 梦早已存档",
      "translation": null
    },
    {
      "time": 40.159,
      "time_str": "00:40.159",
      "text": "谁在寂寞的空港 催促着离去的航班",
      "translation": null
    },
    {
      "time": 50.849,
      "time_str": "00:50.849",
      "text": "只能这样 删去你的影像 就没有遗憾",
      "translation": null
    },
    {
      "time": 60.109,
      "time_str": "01:00.109",
      "text": "这次我很坚强 不再有幻想",
      "translation": null
    },
    {
      "time": 66.519,
      "time_str": "01:06.519",
      "text": "你的梦不够宽敞 装不下我的泪两行",
      "translation": null
    },
    {
      "time": 75.599,
      "time_str": "01:15.599",
      "text": "今夜我就要离航",
      "translation": null
    },
    {
      "time": 79.549,
      "time_str": "01:19.549",
      "text": "点亮月光 走进没有爱情的空港",
      "translation": null
    },
    {
      "time": 86.179,
      "time_str": "01:26.179",
      "text": "忘掉感伤 忘掉所有替你圆的谎",
      "translation": null
    },
    {
      "time": 93.3,
      "time_str": "01:33.300",
      "text": "不必伪装 天塌下来就让别人去扛",
      "translation": null
    },
    {
      "time": 101.749,
      "time_str": "01:41.749",
      "text": "没有你那又怎样 你真的不必再勉强",
      "translation": null
    },
    {
      "time": 114.789,
      "time_str": "01:54.789",
      "text": "我不会再有期望 今夜就要把你释放",
      "translation": null
    },
    {
      "time": 132.229,
      "time_str": "02:12.229",
      "text": "乘着月光 航向没有梦想的空港",
      "translation": null
    },
    {
      "time": 139.059,
      "time_str": "02:19.059",
      "text": "面对忧伤 面对明天我会更勇敢",
      "translation": null
    },
    {
      "time": 145.519,
      "time_str": "02:25.519",
      "text": "不怕风霜 告诉自己就在这里松绑",
      "translation": null
    },
    {
      "time": 154.179,
      "time_str": "02:34.179",
      "text": "没有你 就是这样",
      "translation": null
    },
    {
      "time": 158.6,
      "time_str": "02:38.600",
      "text": "剪断月光 停在没有回忆的空港",
      "translation": null
    },
    {
      "time": 165.399,
      "time_str": "02:45.399",
      "text": "独自疗伤 抱着自己好好哭一场",
      "translation": null
    },
    {
      "time": 171.459,
      "time_str": "02:51.459",
      "text": "不再迷惘 不再对你存有任何遐想",
      "translation": null
    },
    {
      "time": 180.29,
      "time_str": "03:00.290",
      "text": "没有你 不会怎样",
      "translation": null
    },
    {
      "time": 201.029,
      "time_str": "03:21.029",
      "text": "就把你遗忘 把你遗忘",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "空港 - 戴爱玲.lrc"
}