  "lyrics": [
    {
      "time": 27.6,
      "time_str": "00:27.600",
      "text": "水花只能开在雨天",
      "translation": null
    },
    {
      "time": 33.44,
      "time_str": "00:33.440",
      "text": "烟花要绽放在黑夜",
      "translation": null
    },
    {
      "time": 39.51,
      "time_str": "00:39.510",
      "text": "雪花多舍不得冬天",
      "translation": null
    },
    {
      "time": 45.54,
      "time_str": "00:45.540",
      "text": "像我舍不得和你说再见",
      "translation": null
    },
    {
      "time": 51.4,
      "time_str": "00:51.400",
      "text": "谎言并不代表欺骗",
      "translation": null
    },
    {
      "time": 57.46,
      "time_str": "00:57.460",
      "text": "诺言也不一定兑现",
      "translation": null
    },
    {
      "time": 63.43,
      "time_str": "01:03.430",
      "text": "誓言就都留给时间",
      "translation": null
    },
    {
      "time": 69.49,
      "time_str": "01:09.490",
      "text": "就请把从前留在今天",
      "translation": null
    },
    {
      "time": 76.31,
      "time_str": "01:16.310",
      "text": "天亮以前说再见",
      "translation": null
    },
    {
      "time": 79.14,
      "time_str": "01:19.140",
      "text": "笑着泪流满面",
      "translation": null
    },
    {
      "time": 82.17,
      "time_str": "01:22.170",
      "text": "去迎接",
      "translation": null
    },
    {
      "time": 83.24,
      "time_str": "01:23.240",
      "text": "应该你的",
      "translation": null
    },
    {
      "time": 85.21,
      "time_str": "01:25.210",
      "text": "更好的明天",
      "translation": null
    },
    {
      "time": 88.19,
      "time_str": "01:28.190",
      "text": "昙花若只一现",
      "translation": null
    },
    {
      "time": 91.13,
      "time_str": "01:31.130",
      "text": "更要开的耀眼",
      "translation": null
    },
    {
      "time": 94.21,
      "time_str": "01:34.210",
      "text": "别回头去拥有",
      "translation": null
    },
    {
      "time": 96.5,
      "time_str": "01:36.500",
      "text": "属于你更好的世界",
      "translation": null
    },
    {
      "time": 100.24,
      "time_str": "01:40.240",
      "text": "天亮以前说再见",
      "translation": null
    },
    {
      "time": 103.12,
      "time_str": "01:43.120",
      "text": "让我留在今天",
      "translation": null
    },
    {
      "time": 106.31,
      "time_str": "01:46.310",
      "text": "去保护",
      "translation": null
    },
    {
      "time": 107.22,
      "time_str": "01:47.220",
      "text": "我和你的",
      "translation": null
    },
    {
      "time": 109.19,
      "time_str": "01:49.190",
      "text": "最好的夏天",
      "translation": null
    },
    {
      "time": 112.08,
      "time_str": "01:52.080",
      "text": "情丝若水三千",
      "translation": null
    },
    {
      "time": 115.17,
      "time_str": "01:55.170",
      "text": "只取一瓢眷恋",
      "translation": null
    },
    {
      "time": 117.75,
      "time_str": "01:57.750",
      "text": "当你来过的纪念",
      "translation": null
    },
