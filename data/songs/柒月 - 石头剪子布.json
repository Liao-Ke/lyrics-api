  "lyrics": [
    {
      "time": 28.264,
      "time_str": "00:28.264",
      "text": "时光倔强的从我指缝中慢慢溜去",
      "translation": null
    },
    {
      "time": 31.544,
      "time_str": "00:31.544",
      "text": "一滴一滴划破平静掩面叹息",
      "translation": null
    },
    {
      "time": 33.761,
      "time_str": "00:33.761",
      "text": "或许我无力抗拒",
      "translation": null
    },
    {
      "time": 35.591,
      "time_str": "00:35.591",
      "text": "或许我还记得曾经",
      "translation": null
    },
    {
      "time": 37.105,
      "time_str": "00:37.105",
      "text": "记得你和我一起路过那些烂漫风景",
      "translation": null
    },
    {
      "time": 40.816,
      "time_str": "00:40.816",
      "text": "心被冷漠拍打翻滚了几个世纪",
      "translation": null
    },
    {
      "time": 44.97,
      "time_str": "00:44.970",
      "text": "爱情原来只是自己蒙蔽自己的东西",
      "translation": null
    },
    {
      "time": 47.28,
      "time_str": "00:47.280",
      "text": "潇洒了谁又寂寞了谁",
      "translation": null
    },
    {
      "time": 50.157,
      "time_str": "00:50.157",
      "text": "双手合十期盼命运不会再度让我沦陷",
      "translation": null
    },
    {
      "time": 53.77,
      "time_str": "00:53.770",
      "text": "七月的风偷恋花的香气",
      "translation": null
    },
    {
      "time": 56.156,
      "time_str": "00:56.156",
      "text": "七月的你又住进谁的心",
      "translation": null
    },
    {
      "time": 59.44,
      "time_str": "00:59.440",
      "text": "烟花耀眼灼伤我的回忆",
      "translation": null
    },
    {
      "time": 62.515,
      "time_str": "01:02.515",
      "text": "泪决了堤",
      "translation": null
    },
    {
      "time": 65.851,
      "time_str": "01:05.851",
      "text": "你的承诺让我分辨不清",
      "translation": null
    },
    {
      "time": 68.779,
      "time_str": "01:08.779",
      "text": "人说不定该更信自己",
      "translation": null
    },
    {
      "time": 72.04,
      "time_str": "01:12.040",
      "text": "纪念你让我相信爱的美丽",
      "translation": null
    },
    {
      "time": 75.79,
      "time_str": "01:15.790",
      "text": "现在就拥抱自己然后看清自己",
      "translation": null
    },
    {
      "time": 79.167,
      "time_str": "01:19.167",
      "text": "我被半个人的生活一步一步的渐渐掩埋",
      "translation": null
    },
    {
      "time": 82.93,
      "time_str": "01:22.930",
      "text": "我该害怕未来",
      "translation": null
    },
    {
      "time": 83.157,
      "time_str": "01:23.157",
      "text": "怎么面对我的付出和你的离开",
      "translation": null
    },
    {
      "time": 85.427,
      "time_str": "01:25.427",
      "text": "我用力呼吸让我感到生命的存在",
      "translation": null
    },
    {
      "time": 88.399,
      "time_str": "01:28.399",
      "text": "我们经历的一切只是故事而结局太伤感",
      "translation": null
    },
    {
      "time": 91.223,
      "time_str": "01:31.223",
      "text": "那些欣赏那些鼓励",
      "translation": null
    },
    {
      "time": 92.691,
      "time_str": "01:32.691",
      "text": "像是皇帝的新装那么无奈",
      "translation": null
    },
    {
      "time": 94.865,
      "time_str": "01:34.865",
      "text": "那些理解那些包容",
      "translation": null
    },
    {
      "time": 96.227,
      "time_str": "01:36.227",
      "text": "只是人类那纯粹的伪善",
      "translation": null
    },
    {
      "time": 97.791,
      "time_str": "01:37.791",
      "text": "我会记住你今天给我带来的一切伤害",
      "translation": null
    },
    {
      "time": 100.718,
      "time_str": "01:40.718",
      "text": "我会怀念你昨天拿走的我心的另一半",
      "translation": null
    },
    {
      "time": 129.34,
      "time_str": "02:09.340",
      "text": "七月的星偷恋云的神秘",
