  "lyrics": [
    {
      "time": 16.894,
      "time_str": "00:16.894",
      "text": "沒有花",
      "translation": null
    },
    {
      "time": 20.146,
      "time_str": "00:20.146",
      "text": "這剎那被破壞嗎",
      "translation": null
    },
    {
      "time": 23.894,
      "time_str": "00:23.894",
      "text": "無野火都會溫暖嗎",
      "translation": null
    },
    {
      "time": 28.886,
      "time_str": "00:28.886",
      "text": "無菸花一起慶祝好嗎",
      "translation": null
    },
    {
      "time": 34.647,
      "time_str": "00:34.647",
      "text": "若愛戀",
      "translation": null
    },
    {
      "time": 37.642,
      "time_str": "00:37.642",
      "text": "彷似戲劇那樣假",
      "translation": null
    },
    {
      "time": 41.391,
      "time_str": "00:41.391",
      "text": "如佈景一切都美化",
      "translation": null
    },
    {
      "time": 46.394,
      "time_str": "00:46.394",
      "text": "連相擁都參照主角嗎",
      "translation": null
    },
    {
      "time": 52.143,
      "time_str": "00:52.143",
      "text": "你說我未能定時",
      "translation": null
    },
    {
      "time": 55.638,
      "time_str": "00:55.638",
      "text": "令你每天歡笑一次",
      "translation": null
    },
    {
      "time": 59.897,
      "time_str": "00:59.897",
      "text": "我沒說出一句美麗臺詞",
      "translation": null
    },
    {
      "time": 63.391,
      "time_str": "01:03.391",
      "text": "是你心中一種缺陷定義",
      "translation": null
    },
    {
      "time": 67.642,
      "time_str": "01:07.642",
      "text": "流進了眼角里的刺",
      "translation": null
    },
    {
      "time": 70.637,
      "time_str": "01:10.637",
      "text": "為何不浪漫亦是罪名",
      "translation": null
    },
    {
      "time": 74.398,
      "time_str": "01:14.398",
      "text": "為何不轟烈是件壞事情",
      "translation": null
    },
    {
      "time": 78.138,
      "time_str": "01:18.138",
      "text": "從來未察覺我每個動作",
      "translation": null
    },
    {
      "time": 82.143,
      "time_str": "01:22.143",
      "text": "沒有聲都有愛你的鐵證",
      "translation": null
    },
    {
      "time": 85.891,
      "time_str": "01:25.891",
      "text": "為何苦不浪漫亦是罪名",
      "translation": null
    },
    {
      "time": 89.897,
      "time_str": "01:29.897",
      "text": "為何總等待著特別事情",
      "translation": null
    },
    {
      "time": 93.637,
      "time_str": "01:33.637",
      "text": "從來未察覺我語氣動聽",
      "translation": null
    },
    {
