  "lyrics": [
    {
      "time": 18.58,
      "time_str": "00:18.580",
      "text": "假使不能公开妒忌",
      "translation": null
    },
    {
      "time": 22.55,
      "time_str": "00:22.550",
      "text": "学习大方接受",
      "translation": null
    },
    {
      "time": 26.91,
      "time_str": "00:26.910",
      "text": "同行时要殿后",
      "translation": null
    },
    {
      "time": 29.35,
      "time_str": "00:29.350",
      "text": "谁冷落旧朋友",
      "translation": null
    },
    {
      "time": 35.4,
      "time_str": "00:35.400",
      "text": "节日约我三位一体的庆祝",
      "translation": null
    },
    {
      "time": 39.71,
      "time_str": "00:39.710",
      "text": "沿途明亮灯饰闪映着沉重",
      "translation": null
    },
    {
      "time": 44.23,
      "time_str": "00:44.230",
      "text": "言谈越炽热内在更冰冻",
      "translation": null
    },
    {
      "time": 51.55,
      "time_str": "00:51.550",
      "text": "谁当初无心将两方撮合",
      "translation": null
    },
    {
      "time": 55.3,
      "time_str": "00:55.300",
      "text": "然后留低只得这寂寞人",
      "translation": null
    },
    {
      "time": 59.819,
      "time_str": "00:59.819",
      "text": "仍是你们密友呆望你们热吻",
      "translation": null
    },
    {
      "time": 63.529,
      "time_str": "01:03.529",
      "text": "应该伤感还是快感",
      "translation": null
    },
    {
      "time": 68.049,
      "time_str": "01:08.049",
      "text": "能回避嘛我怕了当那电灯胆",
      "translation": null
    },
    {
      "time": 72.299,
      "time_str": "01:12.299",
      "text": "黏着你们来来回委曲中受难",
      "translation": null
    },
    {
      "time": 77.019,
      "time_str": "01:17.019",
      "text": "一个我被撇低却又很不惯",
      "translation": null
    },
    {
      "time": 81.34,
      "time_str": "01:21.340",
      "text": "要走的一剎又折返",
      "translation": null
    },
    {
      "time": 84.998,
      "time_str": "01:24.998",
      "text": "能承认嘛我故意当那电灯胆",
      "translation": null
    },
    {
      "time": 89.26,
      "time_str": "01:29.260",
      "text": "他日你们完场时入替也不难",
      "translation": null
    },
    {
      "time": 94.03,
      "time_str": "01:34.030",
      "text": "善良人埋藏着最坏的心眼",
      "translation": null
    },
    {
      "time": 98.299,
      "time_str": "01:38.299",
      "text": "妄想一天你们会散",
      "translation": null
    },
    {
      "time": 101.4,
      "time_str": "01:41.400",
      "text": "会选我吗",
      "translation": null
    },
    {
      "time": 124.65,
      "time_str": "02:04.650",
      "text": "对换了你身份可应该满足",
      "translation": null
    },
    {
      "time": 128.869,
      "time_str": "02:08.869",
      "text": "情人还是知己都拥入怀抱",
      "translation": null
    },
    {
      "time": 133.338,
      "time_str": "02:13.338",
      "text": "同情或眼泪让别个得到",
      "translation": null
    },
    {
      "time": 140.759,
      "time_str": "02:20.759",
      "text": "留低的原因一世的秘密",
      "translation": null
    },
    {
      "time": 144.459,
      "time_str": "02:24.459",
      "text": "其实明知只得我是外人",
      "translation": null
    },
    {
      "time": 149.03,
      "time_str": "02:29.030",
      "text": "仍是你们密友呆望你们热吻",
      "translation": null
    },
    {
