  "lyrics": [
    {
      "time": 18.42,
      "time_str": "00:18.420",
      "text": "有人浪迹江湖，有人寒窗苦读",
      "translation": null
    },
    {
      "time": 22.26,
      "time_str": "00:22.260",
      "text": "有人阿谀奉承，有人早已麻木",
      "translation": null
    },
    {
      "time": 26.22,
      "time_str": "00:26.220",
      "text": "有人嫌贫爱富，有人唯利是图",
      "translation": null
    },
    {
      "time": 30.24,
      "time_str": "00:30.240",
      "text": "有人精打细算，有人满不在乎",
      "translation": null
    },
    {
      "time": 34.17,
      "time_str": "00:34.170",
      "text": "他们，竖起了耳朵猜喜怒，咧开了笑脸躲城府",
      "translation": null
    },
    {
      "time": 41.64,
      "time_str": "00:41.640",
      "text": "不过想在平凡世界里找宝物，才会哭着笑着装糊涂",
      "translation": null
    },
    {
      "time": 52.05,
      "time_str": "00:52.050",
      "text": "有人家财万贯却还失声痛哭",
      "translation": null
    },
    {
      "time": 55.5,
      "time_str": "00:55.500",
      "text": "有人身无分文却也活的舒服",
      "translation": null
    },
    {
      "time": 59.97,
      "time_str": "00:59.970",
      "text": "有人入不敷出半杯酒便再无贪图",
      "translation": null
    },
    {
      "time": 67.89,
      "time_str": "01:07.890",
      "text": "有人换了张脸企图脱颖而出",
      "translation": null
    },
    {
      "time": 71.34,
      "time_str": "01:11.340",
      "text": "有人躲躲藏藏不想引人注目",
      "translation": null
    },
    {
      "time": 75.75,
      "time_str": "01:15.750",
      "text": "有人狰狞面目却还装得衣冠楚楚",
      "translation": null
    },
    {
      "time": 99.42,
      "time_str": "01:39.420",
      "text": "有人爱的盲目，有人有眼无珠",
      "translation": null
    },
    {
      "time": 103.38,
      "time_str": "01:43.380",
      "text": "有人付之全部，有人一文不出",
      "translation": null
    },
    {
      "time": 107.22,
      "time_str": "01:47.220",
      "text": "有人强求幸福，有人庆幸孤独",
      "translation": null
    },
    {
      "time": 111.18,
      "time_str": "01:51.180",
      "text": "有人撞破头颅，有人原地踟蹰",
      "translation": null
    },
    {
      "time": 115.14,
      "time_str": "01:55.140",
      "text": "我们，瞪大了眼睛猜世故，磨尖了牙齿学谈吐",
      "translation": null
    },
    {
      "time": 122.49,
      "time_str": "02:02.490",
      "text": "不过想在平凡世界里找宝物，才会哭着笑着装糊涂",
      "translation": null
    },
    {
      "time": 130.71,
      "time_str": "02:10.710",
      "text": "有人家财万贯却还失声痛哭",
      "translation": null
    },
    {
      "time": 134.19,
      "time_str": "02:14.190",
      "text": "有人身无分文却也活的舒服",
      "translation": null
    },
    {
      "time": 138.57,
      "time_str": "02:18.570",
      "text": "有人入不敷出半杯酒便再无贪图",
      "translation": null
    },
    {
      "time": 146.34,
      "time_str": "02:26.340",
      "text": "有人换了张脸企图脱颖而出",
      "translation": null
    },
    {
      "time": 149.79,
      "time_str": "02:29.790",
      "text": "有人躲躲藏藏不想引人注目",
      "translation": null
    },
    {
      "time": 154.14,
      "time_str": "02:34.140",
      "text": "有人狰狞面目却还装的衣冠楚楚",
      "translation": null
    },
    {
      "time": 177.51,
      "time_str": "02:57.510",
      "text": "有人爬上高楼大厦一跃而死",
      "translation": null
    },
    {
      "time": 180.93,
      "time_str": "03:00.930",
      "text": "只为让亏欠他的人吃场人命官司",
      "translation": null
    },
    {
      "time": 185.4,
      "time_str": "03:05.400",
      "text": "落下时才看见楼里多少难以启齿",
      "translation": null
    },
    {
      "time": 193.2,
      "time_str": "03:13.200",
      "text": "有人白天笑脸迎人附炎趋势",
      "translation": null
    },
    {
      "time": 196.59,
      "time_str": "03:16.590",
      "text": "只为半夜酒后含泪说的雄心壮志",
      "translation": null
    },
    {
      "time": 200.88,
      "time_str": "03:20.880",
      "text": "醒来时再继续对着生活咬牙切齿，日复一日，却不自知",
      "translation": null
    },
    {
      "time": 216.03,
      "time_str": "03:36.030",
      "text": "多年后老人看着来时路",
      "translation": null
    },
    {
      "time": 220.47,
      "time_str": "03:40.470",
      "text": "有人悔不当初，有人难得糊涂",
      "translation": null
    },
    {
      "time": 224.46,
      "time_str": "03:44.460",
      "text": "有人感慨万千，说你我，不过一把土",
      "translation": null
    },
    {
      "time": 243.54,
      "time_str": "04:03.540",
