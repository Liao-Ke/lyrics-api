  "lyrics": [
    {
      "time": 0.25,
      "time_str": "00:00.250",
      "text": "混音编曲: Alan Walker/Anders \"Mood Melodies\" Froen/Jesper Borgen/Tor Erik Hermansen/Mikkel S. Eriksen",
      "translation": null
    },
    {
      "time": 0.65,
      "time_str": "00:00.650",
      "text": "I, oh I, oh I",
      "translation": "我...我...我..."
    },
    {
      "time": 4.98,
      "time_str": "00:04.980",
      "text": "I, so high, so high",
      "translation": "如同在九重云霄"
    },
    {
      "time": 9.09,
      "time_str": "00:09.090",
      "text": "Oh, angel sent from up above",
      "translation": "你如同天仙下凡般"
    },
    {
      "time": 13.79,
      "time_str": "00:13.790",
      "text": "You know you make my world light up",
      "translation": "我的世界因你而熠熠生辉"
    },
    {
      "time": 18.75,
      "time_str": "00:18.750",
      "text": "When I was down, when I was hurt",
      "translation": "当我落魄，千疮百孔"
    },
    {
      "time": 23.92,
      "time_str": "00:23.920",
      "text": "You came to lift me up",
      "translation": "你令我重新振作"
    },
    {
      "time": 29.07,
      "time_str": "00:29.070",
      "text": "Life is a drink, and love's a drug",
      "translation": "生活令人迷醉，爱情令人沉醉"
    },
    {
      "time": 33.69,
      "time_str": "00:33.690",
      "text": "Oh, now I think I must be miles up",
      "translation": "噢，我想我现在已迷茫不已"
    },
    {
      "time": 38.87,
      "time_str": "00:38.870",
      "text": "When I was a river, dried up",
      "translation": "当我如同河流，干涸枯竭时"
    },
    {
      "time": 43.75,
      "time_str": "00:43.750",
      "text": "You came to rain a flood",
      "translation": "你为我降下甘霖"
    },
    {
      "time": 49.37,
      "time_str": "00:49.370",
      "text": "I, oh, I, oh I",
      "translation": "我...我...我..."
    },
    {
