      "time": 28.99,
      "time_str": "00:28.990",
      "text": "相见难别亦难",
      "translation": null
    },
    {
      "time": 35.18,
      "time_str": "00:35.180",
      "text": "怎诉这胸中语万千",
      "translation": null
    },
    {
      "time": 41.33,
      "time_str": "00:41.330",
      "text": "我柔情万种",
      "translation": null
    },
    {
      "time": 44.45,
      "time_str": "00:44.450",
      "text": "他去志更坚",
      "translation": null
    },
    {
      "time": 47.58,
      "time_str": "00:47.580",
      "text": "只怨今生无缘",
      "translation": null
    },
    {
      "time": 54.96,
      "time_str": "00:54.960",
      "text": "道不尽声声珍重",
      "translation": null
    },
    {
      "time": 61.21,
      "time_str": "01:01.210",
      "text": "默默地祝福平安",
      "translation": null
    },
    {
      "time": 66.38,
      "time_str": "01:06.380",
      "text": "人间事常难遂人愿",
      "translation": null
    },
    {
      "time": 72.52,
      "time_str": "01:12.520",
      "text": "且看明月又有几回圆",
      "translation": null
    },
    {
