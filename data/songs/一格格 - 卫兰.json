    {
      "time": 1.21,
      "time_str": "00:01.210",
      "text": "每次上机 都幻想",
      "translation": null
    },
    {
      "time": 7.93,
      "time_str": "00:07.930",
      "text": "谁带我远飞 找梦乡",
      "translation": null
    },
    {
      "time": 15.4,
      "time_str": "00:15.400",
      "text": "谈情令我心痒痒",
      "translation": null
    },
    {
      "time": 20.81,
      "time_str": "00:20.810",
      "text": "期待着什么人 会遇上",
      "translation": null
    },
    {
      "time": 29.65,
      "time_str": "00:29.650",
      "text": "旅客揭揭袋装小说便发梦",
      "translation": null
    },
    {
      "time": 37.18,
      "time_str": "00:37.180",
      "text": "教堂有钟声诗班要合唱",
      "translation": null
    },
    {
      "time": 44.05,
      "time_str": "00:44.050",
      "text": "到处看看漫天花瓣 难以想像",
      "translation": null
    },
    {
      "time": 49.51,
      "time_str": "00:49.510",
      "text": "期待着什么人 会遇上",
      "translation": null
    },
    {
      "time": 56.63,
      "time_str": "00:56.630",
      "text": "缠住吻住春风吹住我吗",
      "translation": null
    },
    {
      "time": 60.01,
      "time_str": "01:00.010",
      "text": "缠住吻住郁金香是你吗",
      "translation": null
    },
    {
      "time": 63.7,
      "time_str": "01:03.700",
      "text": "缠住吻住诗画歌颂爱吗",
      "translation": null
    },
    {
      "time": 67.24,
      "time_str": "01:07.240",
      "text": "拍 逐幅逐幅恋爱定格",
      "translation": null
    },
    {
      "time": 70.77,
      "time_str": "01:10.770",
      "text": "缠住吻住Cream cheese点缀我吗",
      "translation": null
    },
    {
      "time": 74.51,
      "time_str": "01:14.510",
      "text": "缠住吻住古雕刻似你吗",
      "translation": null
    },
    {
      "time": 77.99,
      "time_str": "01:17.990",
      "text": "缠住爱慢身边一拍 轻轻一拍",
      "translation": null
