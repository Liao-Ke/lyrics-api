{
  "title": "父亲写的散文诗",
  "title_raw": "父亲写的散文诗",
  "version": null,
  "artist": "许飞",
  "group_key": "父亲写的散文诗|许飞",
  "writers": {
    "lyricist": "董玉方",
    "composer": "许飞",
    "arranger": null
  },
  "lyrics": [
    {
      "time": 14.4,
      "time_str": "00:14.400",
      "text": "一九八四年 庄稼早已收割完",
      "translation": null
    },
    {
      "time": 21.74,
      "time_str": "00:21.740",
      "text": "女儿躺在我怀里 睡得那么甜",
      "translation": null
    },
    {
      "time": 28.9,
      "time_str": "00:28.900",
      "text": "今天的露天电影 没时间去看",
      "translation": null
    },
    {
      "time": 36.07,
      "time_str": "00:36.070",
      "text": "妻子提醒我 修修缝纫机的踏板",
      "translation": null
    },
    {
      "time": 44.66,
      "time_str": "00:44.660",
      "text": "明天我要去 邻居家再借点钱",
      "translation": null
    },
    {
      "time": 50.78,
      "time_str": "00:50.780",
      "text": "孩子哭了一整天呐 闹着要吃饼干",
      "translation": null
    },
    {
      "time": 58.19,
      "time_str": "00:58.190",
      "text": "蓝色的涤卡上衣 痛往心里钻",
      "translation": null
    },
    {
      "time": 65.66,
      "time_str": "01:05.660",
      "text": "蹲在池塘边上 给了自己两拳",
      "translation": null
    },
    {
      "time": 73.39,
      "time_str": "01:13.390",
      "text": "这是我父亲 日记里的文字",
      "translation": null
    },
    {
      "time": 81.0,
      "time_str": "01:21.000",
      "text": "这是他的青春 留下来的散文诗",
      "translation": null
    },
    {
      "time": 88.42,
      "time_str": "01:28.420",
      "text": "几十年后，我看着泪流不止",
      "translation": null
    },
    {
      "time": 94.96,
      "time_str": "01:34.960",
      "text": "可我的父亲已经 老得像一个影子",
      "translation": null
    },
    {
      "time": 107.39,
      "time_str": "01:47.390",
      "text": "一九九四年 庄稼早已收割完",
      "translation": null
    },
    {
      "time": 113.82,
      "time_str": "01:53.820",
      "text": "我的老母亲去年 离开了人间",
      "translation": null
    },
    {
      "time": 120.83,
      "time_str": "02:00.830",
      "text": "女儿扎着马尾辫 跑进了校园",
      "translation": null
    },
    {
      "time": 127.58,
      "time_str": "02:07.580",
      "text": "可是她最近 有点孤单瘦了一大圈",
      "translation": null
    },
    {
      "time": 135.53,
      "time_str": "02:15.530",
      "text": "想一想未来 我老成了一堆旧纸钱",
      "translation": null
    },
    {
      "time": 142.83,
      "time_str": "02:22.830",
      "text": "那时的女儿一定 会美得很惊艳",
      "translation": null
    },
    {
      "time": 148.89,
      "time_str": "02:28.890",
      "text": "有个爱她的男人 要娶她回家",
      "translation": null
    },
    {
      "time": 157.61,
      "time_str": "02:37.610",
      "text": "可想到这些 我却不忍看她一眼",
      "translation": null
    },
    {
      "time": 166.15,
      "time_str": "02:46.150",
      "text": "这是我父亲 日记里的文字",
      "translation": null
    },
    {
      "time": 172.91,
      "time_str": "02:52.910",
      "text": "这是他的生命 留下 留下来的散文诗",
      "translation": null
    },
    {
      "time": 181.04,
      "time_str": "03:01.040",
      "text": "几十年后，我看着泪流不止",
      "translation": null
    },
    {
      "time": 187.24,
      "time_str": "03:07.240",
      "text": "可我的父亲已经 老得像一张旧报纸 旧报纸",
      "translation": null
    },
    {
      "time": 206.26,
      "time_str": "03:26.260",
      "text": "那上面的故事 就是一辈子",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "父亲写的散文诗 - 许飞.lrc"
}