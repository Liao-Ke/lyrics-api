  "lyrics": [
    {
      "time": 22.33,
      "time_str": "00:22.330",
      "text": "晚风轻拂澎湖湾",
      "translation": null
    },
    {
      "time": 24.87,
      "time_str": "00:24.870",
      "text": "海浪逐沙滩",
      "translation": null
    },
    {
      "time": 27.53,
      "time_str": "00:27.530",
      "text": "没有椰林醉斜阳",
      "translation": null
    },
    {
      "time": 30.18,
      "time_str": "00:30.180",
      "text": "只是一片海蓝蓝",
      "translation": null
    },
    {
      "time": 32.86,
      "time_str": "00:32.860",
      "text": "坐在门前的矮墙上一遍遍幻想",
      "translation": null
    },
    {
      "time": 38.24,
      "time_str": "00:38.240",
      "text": "也许黄昏的沙滩上有着脚印两对半",
      "translation": null
    },
    {
      "time": 43.69,
      "time_str": "00:43.690",
      "text": "那是外婆拄着杖将我手轻轻挽",
      "translation": null
    },
    {
      "time": 48.93,
      "time_str": "00:48.930",
      "text": "踩着薄暮走向余晖暖暖的澎湖湾",
      "translation": null
    },
    {
      "time": 54.26,
      "time_str": "00:54.260",
      "text": "一个脚印是笑语一串消磨许多时光",
      "translation": null
    },
    {
      "time": 59.61,
      "time_str": "00:59.610",
      "text": "直到夜色吞没我俩回家的路上",
      "translation": null
    },
    {
      "time": 64.88,
      "time_str": "01:04.880",
      "text": "澎湖湾澎湖湾外婆的澎湖湾",
      "translation": null
    },
    {
      "time": 75.37,
      "time_str": "01:15.370",
      "text": "有我许多的童年幻想",
      "translation": null
    },
    {
      "time": 80.63,
      "time_str": "01:20.630",
      "text": "阳光沙滩海浪仙人掌",
      "translation": null
    },
    {
      "time": 86.29,
      "time_str": "01:26.290",
      "text": "还有一位老船长",
