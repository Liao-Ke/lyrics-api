  "lyrics": [
    {
      "time": 2.0,
      "time_str": "00:02.000",
      "text": "指挥家 : Marko Ivanović",
      "translation": null
    },
    {
      "time": 6.9,
      "time_str": "00:06.900",
      "text": ".",
      "translation": null
    },
    {
      "time": 12.77,
      "time_str": "00:12.770",
      "text": "Staring at you",
      "translation": "凝视着你"
    },
    {
      "time": 14.64,
      "time_str": "00:14.640",
      "text": "Staring at me",
      "translation": "凝视着我"
    },
    {
      "time": 17.89,
      "time_str": "00:17.890",
      "text": "It's a slow dance",
      "translation": "这是场慢舞"
    },
    {
      "time": 19.51,
      "time_str": "00:19.510",
      "text": "But I believe",
      "translation": "但我相信"
    },
    {
      "time": 22.7,
      "time_str": "00:22.700",
      "text": "Mona Lisa",
      "translation": "蒙娜丽莎"
    },
    {
      "time": 24.33,
      "time_str": "00:24.330",
      "text": "Who do you see",
      "translation": "你看到了什么"
    },
    {
      "time": 27.47,
      "time_str": "00:27.470",
      "text": "It's your one chance",
      "translation": "这是你的一次机会"
    },
    {
      "time": 29.15,
      "time_str": "00:29.150",
      "text": "Do you believe",
      "translation": "你是否相信"
    },
    {
      "time": 31.77,
      "time_str": "00:31.770",
      "text": ".",
      "translation": null
    },
    {
      "time": 32.45,
      "time_str": "00:32.450",
      "text": "Let's get naked",
      "translation": "赤裸相见吧"
    },
    {
      "time": 34.08,
      "time_str": "00:34.080",
      "text": "Under the knife",
      "translation": "在刀锋下"
    },
    {
      "time": 37.02,
      "time_str": "00:37.020",
      "text": "We are dreamers",
      "translation": "我们是梦想家"
    },
    {
      "time": 38.83,
      "time_str": "00:38.830",
      "text": "Larger than life",
      "translation": "大于生活"
    },
    {
      "time": 42.08,
      "time_str": "00:42.080",
      "text": "Staring at you",
      "translation": "凝视着你"
    },
    {
      "time": 43.89,
      "time_str": "00:43.890",
      "text": "Staring at me",
      "translation": "凝视着我"
    },
    {
      "time": 47.08,
      "time_str": "00:47.080",
      "text": "It's a slow dance",
      "translation": "这是场慢舞"
    },
    {
      "time": 48.76,
      "time_str": "00:48.760",
      "text": "But I believe",
      "translation": "但我相信"
    },
    {
      "time": 50.52,
      "time_str": "00:50.520",
      "text": ".",
      "translation": null
    },
    {
      "time": 51.63,
      "time_str": "00:51.630",
      "text": "Lock up all the doors",
      "translation": "锁上所有的门吧"
    },
    {
      "time": 53.44,
      "time_str": "00:53.440",
      "text": "Better seal your heart up tight",
      "translation": "最好密封你的心"
    },
    {
      "time": 61.39,
      "time_str": "01:01.390",
      "text": "Block out all the noise",
      "translation": "屏蔽所有的声音"
    },
    {
      "time": 63.13,
      "time_str": "01:03.130",
      "text": "But you can't escape the light",
      "translation": "但你无法逃离光线"
    },
    {
      "time": 66.88,
      "time_str": "01:06.880",
      "text": "Staring at you",
      "translation": "凝视着你"
    },
    {
      "time": 68.63,
      "time_str": "01:08.630",
      "text": "Staring at me",
      "translation": "凝视着我"
    },
    {
      "time": 70.51,
      "time_str": "01:10.510",
      "text": ".",
      "translation": null
    },
    {
      "time": 70.82,
      "time_str": "01:10.820",
      "text": "'Cause your love creeps slow like a thief in the night",
      "translation": "因为你的爱如窃贼般在黑夜爬行"
    },
    {
      "time": 76.39,
      "time_str": "01:16.390",
      "text": "You take my breath and you hold it inside",
      "translation": "你拿走我的呼吸，收于心底"
    },
    {
      "time": 81.33,
      "time_str": "01:21.330",
      "text": "You creep slow like a thief in the night",
      "translation": "你如窃贼般在黑夜爬行"
    },
    {
      "time": 86.22,
      "time_str": "01:26.220",
      "text": "You take my breath and you hold it inside",
      "translation": "你拿走我的呼吸，收于心底"
    },
    {
      "time": 89.8,
      "time_str": "01:29.800",
      "text": ".",
      "translation": null
    },
    {
      "time": 101.24,
      "time_str": "01:41.240",
      "text": "There's an ocean",
      "translation": "这里有一片汪洋"
    },
    {
      "time": 102.74,
      "time_str": "01:42.740",
      "text": "Inside of your head",
      "translation": "存在于你的脑海"
    },
    {
      "time": 105.93,
      "time_str": "01:45.930",
      "text": "With all the words",
      "translation": "伴随着那些"
    },
    {
      "time": 107.31,
      "time_str": "01:47.310",
      "text": "You wish you had said",
      "translation": "你盼望却未曾说出口的词语"
    },
    {
      "time": 111.04,
      "time_str": "01:51.040",
      "text": "We are broken",
      "translation": "我们破碎了"
    },
    {
      "time": 112.79,
      "time_str": "01:52.790",
      "text": "We have no pain",
      "translation": "我们没有了痛苦"
    },
    {
      "time": 115.79,
      "time_str": "01:55.790",
      "text": "You're the needle",
      "translation": "你是针"
    },
    {
      "time": 117.67,
      "time_str": "01:57.670",
      "text": "I am the vein",
      "translation": "而我是血管"
    },
    {
      "time": 119.54,
      "time_str": "01:59.540",
      "text": ".",
      "translation": null
    },
    {
      "time": 120.78,
      "time_str": "02:00.780",
      "text": "Lock up all the doors",
      "translation": "锁上所有的门吧"
    },
    {
      "time": 122.41,
      "time_str": "02:02.410",
      "text": "Gonna seal them out tonight",
      "translation": "今夜就将它们关在门外"
    },
    {
      "time": 130.47,
      "time_str": "02:10.470",
      "text": "Block out all the noise",
      "translation": "屏蔽所有的声音"
    },
    {
      "time": 132.03,
      "time_str": "02:12.030",
      "text": "'Cause the only place that's right",
      "translation": "因为唯一正确的地点"
    },
    {
