    {
      "time": 40.95,
      "time_str": "00:40.950",
      "text": "接受无奈 承认失败",
      "translation": null
    },
    {
      "time": 45.25,
      "time_str": "00:45.250",
      "text": "她才是你的爱",
      "translation": null
    },
    {
      "time": 48.57,
      "time_str": "00:48.570",
      "text": "寂寞伴随 自由色彩 迎面来",
      "translation": null
    },
    {
      "time": 54.96,
      "time_str": "00:54.960",
      "text": "头发甩甩 大步的走开",
