      "time_str": "00:24.930",
      "text": "那天醒来 忽然想开",
      "translation": null
    },
    {
      "time": 28.9,
      "time_str": "00:28.900",
      "text": "不愿再做等待的女孩",
      "translation": null
    },
    {
      "time": 32.73,
      "time_str": "00:32.730",
      "text": "拿掉戒指 扎起马尾",
      "translation": null
    },
    {
      "time": 36.29,
      "time_str": "00:36.290",
      "text": "开始不再想你姿态",
