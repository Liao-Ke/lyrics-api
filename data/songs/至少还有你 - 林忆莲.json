  "lyrics": [
    {
      "time": 17.57,
      "time_str": "00:17.570",
      "text": "我怕来不及",
      "translation": null
    },
    {
      "time": 21.06,
      "time_str": "00:21.060",
      "text": "我要抱着你",
      "translation": null
    },
    {
      "time": 24.91,
      "time_str": "00:24.910",
      "text": "直到感觉你的皱纹",
      "translation": null
    },
    {
      "time": 28.75,
      "time_str": "00:28.750",
      "text": "有了岁月的痕迹",
      "translation": null
    },
    {
      "time": 32.55,
      "time_str": "00:32.550",
      "text": "直到肯定你是真的",
      "translation": null
    },
    {
      "time": 36.91,
      "time_str": "00:36.910",
      "text": "直到失去力气",
      "translation": null
    },
    {
      "time": 40.74,
      "time_str": "00:40.740",
      "text": "为了你 我愿意",
      "translation": null
    },
    {
      "time": 47.91,
      "time_str": "00:47.910",
      "text": "动也不能动",
      "translation": null
    },
    {
      "time": 51.91,
      "time_str": "00:51.910",
      "text": "也要看着你",
      "translation": null
    },
    {
      "time": 55.62,
      "time_str": "00:55.620",
      "text": "直到感觉你的发线",
      "translation": null
    },
    {
      "time": 59.46,
      "time_str": "00:59.460",
      "text": "有了白雪的痕迹",
      "translation": null
    },
    {
      "time": 63.21,
      "time_str": "01:03.210",
      "text": "直到视线变得模糊",
      "translation": null
    },
    {
      "time": 67.61,
      "time_str": "01:07.610",
      "text": "直到不能呼吸",
      "translation": null
    },
    {
      "time": 71.39,
      "time_str": "01:11.390",
      "text": "让我们 形影不离",
      "translation": null
    },
    {
      "time": 77.22,
      "time_str": "01:17.220",
      "text": "如果 全世界我也可以放弃",
      "translation": null
    },
    {
      "time": 82.55,
      "time_str": "01:22.550",
      "text": "至少还有你 值得我去珍惜",
      "translation": null
    },
    {
      "time": 86.45,
      "time_str": "01:26.450",
      "text": "而你在这里 就是生命的奇迹",
      "translation": null
    },
    {
      "time": 92.56,
      "time_str": "01:32.560",
      "text": "也许 全世界我也可以忘记",
      "translation": null
    },
    {
