  "lyrics": [
    {
      "time": 13.65,
      "time_str": "00:13.650",
      "text": "红尘多可笑",
      "translation": null
    },
    {
      "time": 15.84,
      "time_str": "00:15.840",
      "text": "痴情最无聊",
      "translation": null
    },
    {
      "time": 18.21,
      "time_str": "00:18.210",
      "text": "目空一切也好",
      "translation": null
    },
    {
      "time": 22.9,
      "time_str": "00:22.900",
      "text": "此生未了",
      "translation": null
    },
    {
      "time": 24.71,
      "time_str": "00:24.710",
      "text": "心却已无所扰",
      "translation": null
    },
    {
      "time": 26.02,
      "time_str": "00:26.020",
      "text": "只想换得半世逍遥",
      "translation": null
    },
    {
      "time": 30.46,
      "time_str": "00:30.460",
      "text": "醒时对人笑",
      "translation": null
    },
    {
      "time": 32.58,
      "time_str": "00:32.580",
      "text": "梦中全忘掉",
      "translation": null
    },
    {
      "time": 35.84,
      "time_str": "00:35.840",
      "text": "叹天黑得太早",
      "translation": null
    },
    {
      "time": 39.71,
      "time_str": "00:39.710",
      "text": "来生难料",
      "translation": null
    },
    {
      "time": 41.4,
      "time_str": "00:41.400",
      "text": "爱恨一笔勾销",
      "translation": null
    },
    {
      "time": 43.71,
      "time_str": "00:43.710",
      "text": "对酒当歌我只愿开心到老",
      "translation": null
    },
    {
      "time": 47.33,
      "time_str": "00:47.330",
      "text": "风再冷不想逃",
      "translation": null
    },
    {
      "time": 49.34,
      "time_str": "00:49.340",
      "text": "花再美也不想要",
      "translation": null
    },
    {
      "time": 51.58,
      "time_str": "00:51.580",
      "text": "任我飘摇",
      "translation": null
    },
    {
      "time": 56.02,
      "time_str": "00:56.020",
      "text": "天越高心越小",
      "translation": null
    },
    {
      "time": 58.08,
      "time_str": "00:58.080",
      "text": "不问因果有多少",
      "translation": null
    },
    {
      "time": 60.21,
      "time_str": "01:00.210",
      "text": "独自醉倒",
      "translation": null
    },
    {
      "time": 65.96,
      "time_str": "01:05.960",
      "text": "今天哭明天笑",
      "translation": null
    },
    {
      "time": 66.06,
      "time_str": "01:06.060",
      "text": "爱恨一笔勾销",
      "translation": null
    },
    {
      "time": 66.21,
      "time_str": "01:06.210",
      "text": "不求有人能明了",
      "translation": null
    },
    {
      "time": 70.41,
      "time_str": "01:10.410",
      "text": "一身骄傲",
      "translation": null
    },
    {
      "time": 73.91,
      "time_str": "01:13.910",
      "text": "歌在唱舞在跳",
      "translation": null
    },
    {
