  "lyrics": [
    {
      "time": 8.27,
      "time_str": "00:08.270",
      "text": "Let's go out and be wild",
      "translation": "让我们出门狂野"
    },
    {
      "time": 10.28,
      "time_str": "00:10.280",
      "text": "Do it while we can (do, do)",
      "translation": "在我们能做的时候"
    },
    {
      "time": 16.9,
      "time_str": "00:16.900",
      "text": "Runnin' free in the world",
      "translation": "在这个世界自由的奔跑"
    },
    {
      "time": 18.11,
      "time_str": "00:18.110",
      "text": "We've got all weekend (do, do)",
      "translation": "我们有一整个周末"
    },
    {
      "time": 22.67,
      "time_str": "00:22.670",
      "text": "Tear it up, tear it down",
      "translation": "撕碎它"
    },
    {
      "time": 24.67,
      "time_str": "00:24.670",
      "text": "Gettin' lost in the sound of our hearts beatin'",
      "translation": "在我们心跳声中迷失"
    },
    {
      "time": 30.46,
      "time_str": "00:30.460",
      "text": "Take me here, take me now",
      "translation": "带我来这里，就现在"
    },
    {
      "time": 32.41,
      "time_str": "00:32.410",
      "text": "Gettin' lost in a crowd with you",
      "translation": "和你一起迷失在人群中"
    },
    {
      "time": 38.98,
      "time_str": "00:38.980",
      "text": "Up, all night",
      "translation": "一整夜"
    },
    {
      "time": 41.62,
      "time_str": "00:41.620",
      "text": "I waited for you all my life",
      "translation": "我倾尽一生等待你"
    },
    {
      "time": 45.35,
      "time_str": "00:45.350",
      "text": "Hold my hand and keep me close",
      "translation": "握住我的手靠近我"
    },
    {
      "time": 47.54,
      "time_str": "00:47.540",
      "text": "I'll never let you go",
      "translation": "我不会让你走"
    },
    {
      "time": 49.47,
      "time_str": "00:49.470",
      "text": "No not tonight",
      "translation": "别在今夜走"
    },
    {
      "time": 52.63,
      "time_str": "00:52.630",
      "text": "Keep me by your side",
      "translation": "让我留在你身边"
    },
