  "lyrics": [
    {
      "time": 15.32,
      "time_str": "00:15.320",
      "text": "「未经许可 不得翻唱翻录或使用」",
      "translation": null
    },
    {
      "time": 32.52,
      "time_str": "00:32.520",
      "text": "天边的云一望无际",
      "translation": null
    },
    {
      "time": 39.67,
      "time_str": "00:39.670",
      "text": "俯瞰那双眺望的眼睛",
      "translation": null
    },
    {
      "time": 45.68,
      "time_str": "00:45.680",
      "text": "时间还在远行",
      "translation": null
    },
    {
      "time": 49.25,
      "time_str": "00:49.250",
      "text": "留下谁的脚印",
      "translation": null
    },
    {
      "time": 52.18,
      "time_str": "00:52.180",
      "text": "不只是贪恋的勇气",
      "translation": null
    },
    {
      "time": 60.5,
      "time_str": "01:00.500",
      "text": "命中注定不能靠近",
      "translation": null
    },
    {
      "time": 63.83,
      "time_str": "01:03.830",
      "text": "爱你的事当做秘密",
      "translation": null
    },
    {
      "time": 67.5,
      "time_str": "01:07.500",
      "text": "怕惊扰你从此远离",
      "translation": null
    },
    {
      "time": 70.19,
      "time_str": "01:10.190",
      "text": "无穷尽",
      "translation": null
    },
    {
      "time": 74.85,
      "time_str": "01:14.850",
      "text": "多想能够潜入海底",
      "translation": null
    },
    {
      "time": 78.47,
      "time_str": "01:18.470",
      "text": "温柔的栖息",
      "translation": null
    },
    {
      "time": 81.35,
      "time_str": "01:21.350",
      "text": "是抚平 你心口的原因",
      "translation": null
    },
    {
      "time": 88.55,
      "time_str": "01:28.550",
      "text": "如果世间万物能跨越能相爱",
      "translation": null
    },
    {
      "time": 92.88,
      "time_str": "01:32.880",
      "text": "也能成全云与海",
      "translation": null
    },
    {
      "time": 95.69,
      "time_str": "01:35.690",
      "text": "忘了离岸多远多危险",
      "translation": null
    },
    {
      "time": 99.07,
      "time_str": "01:39.070",
      "text": "都看不见",
      "translation": null
    },
    {
      "time": 102.91,
      "time_str": "01:42.910",
      "text": "如果海角天涯不分开不难捱",
      "translation": null
    },
    {
      "time": 107.42,
      "time_str": "01:47.420",
      "text": "眼泪终会厮守",
      "translation": null
    },
    {
      "time": 110.29,
      "time_str": "01:50.290",
      "text": "别忘了 它们的爱而 不得",
      "translation": null
    },
