  "lyrics": [
    {
      "time": 7.59,
      "time_str": "00:07.590",
      "text": "This ain't a song for the broken-hearted",
      "translation": "这首歌并不是写给那些伤心的人"
    },
    {
      "time": 15.64,
      "time_str": "00:15.640",
      "text": "No silent prayer for the faith-departed",
      "translation": "上帝不会庇护那些没有信仰的祈祷者"
    },
    {
      "time": 23.95,
      "time_str": "00:23.950",
      "text": "I ain't gonna be just a face in the crowd",
      "translation": "我不希望自己只是芸芸众生之一"
    },
    {
      "time": 27.32,
      "time_str": "00:27.320",
      "text": "You're gonna hear my voice",
      "translation": "你将会听到我的心声"
    },
    {
      "time": 29.57,
      "time_str": "00:29.570",
      "text": "When I shout it out aloud",
      "translation": "当我大声呐喊出来"
    },
    {
      "time": 33.2,
      "time_str": "00:33.200",
      "text": "It's my life",
      "translation": "这就是我的人生"
    },
    {
      "time": 35.54,
      "time_str": "00:35.540",
      "text": "It's now or never",
      "translation": "把握现在，机会稍纵即逝"
    },
    {
      "time": 38.97,
      "time_str": "00:38.970",
      "text": "I ain't gonna live forever",
      "translation": "我不祈望能够长生不老"
    },
    {
      "time": 43.1,
      "time_str": "00:43.100",
      "text": "I just wanna live while I'm alive",
      "translation": "我只想趁我活着的时候认真生活"
    },
    {
      "time": 48.98,
      "time_str": "00:48.980",
      "text": "（It's my life）",
      "translation": "（这就是我的人生）"
    },
    {
      "time": 51.13,
      "time_str": "00:51.130",
      "text": "My heart is like an open highway",
      "translation": "我的心就像飞驰在公路上"
    },
    {
      "time": 55.06,
      "time_str": "00:55.060",
      "text": "Like Frankie said",
      "translation": "就像Frankie说的那样（弗兰克.辛纳屈歌曲《My Way》中的最后一句就是I did it my way）"
    },
    {
