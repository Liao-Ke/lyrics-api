  "lyrics": [
    {
      "time": 40.34,
      "time_str": "00:40.340",
      "text": "我低头 向山沟",
      "translation": null
    },
    {
      "time": 43.96,
      "time_str": "00:43.960",
      "text": "追逐流逝的岁月",
      "translation": null
    },
    {
      "time": 47.91,
      "time_str": "00:47.910",
      "text": "风沙茫茫满山谷",
      "translation": null
    },
    {
      "time": 51.9,
      "time_str": "00:51.900",
      "text": "不见我的童年",
      "translation": null
    },
    {
      "time": 55.59,
      "time_str": "00:55.590",
      "text": "我抬头 向青天",
      "translation": null
    },
    {
      "time": 59.41,
      "time_str": "00:59.410",
      "text": "搜寻远去的从前",
      "translation": null
    },
    {
      "time": 63.41,
      "time_str": "01:03.410",
      "text": "白云悠悠尽情地游",
      "translation": null
    },
    {
      "time": 67.22,
      "time_str": "01:07.220",
      "text": "什么都没改变",
      "translation": null
    },
    {
      "time": 71.22,
      "time_str": "01:11.220",
      "text": "大雁听过我的歌",
      "translation": null
    },
    {
      "time": 74.9,
      "time_str": "01:14.900",
      "text": "小河亲过我的脸",
      "translation": null
    },
    {
      "time": 78.84,
      "time_str": "01:18.840",
      "text": "山丹丹花开花又落",
      "translation": null
    },
    {
      "time": 82.59,
      "time_str": "01:22.590",
      "text": "一遍又一遍",
      "translation": null
    },
    {
      "time": 86.53,
      "time_str": "01:26.530",
      "text": "大地留下我的梦",
      "translation": null
    },
    {
      "time": 90.35,
      "time_str": "01:30.350",
      "text": "信天游带走我的情",
      "translation": null
    },
    {
      "time": 94.22,
      "time_str": "01:34.220",
      "text": "天上星星一点点",
      "translation": null
    },
    {
      "time": 98.16,
      "time_str": "01:38.160",
      "text": "思念到永远",
      "translation": null
    },
