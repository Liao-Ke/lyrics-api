  "lyrics": [
    {
      "time": 35.31,
      "time_str": "00:35.310",
      "text": "送你的白色沙漏",
      "translation": null
    },
    {
      "time": 39.13,
      "time_str": "00:39.130",
      "text": "是一个关于成长的礼物",
      "translation": null
    },
    {
      "time": 43.51,
      "time_str": "00:43.510",
      "text": "如果能给你爱和感动",
      "translation": null
    },
    {
      "time": 47.39,
      "time_str": "00:47.390",
      "text": "我是多么的幸福",
      "translation": null
    },
    {
      "time": 51.73,
      "time_str": "00:51.730",
      "text": "我有过很多的朋友",
      "translation": null
    },
    {
      "time": 55.61,
      "time_str": "00:55.610",
      "text": "没有谁像你一样的懂我",
      "translation": null
    },
    {
      "time": 60.04,
      "time_str": "01:00.040",
      "text": "是你给我最倔强的勇气",
      "translation": null
    },
    {
      "time": 64.9,
      "time_str": "01:04.900",
      "text": "青春才开出最绚烂的花朵",
      "translation": null
    },
    {
      "time": 71.9,
      "time_str": "01:11.900",
      "text": "沙漏的爱",
      "translation": null
    },
    {
      "time": 73.88,
      "time_str": "01:13.880",
      "text": "反反复复",
      "translation": null
    },
    {
      "time": 75.83,
      "time_str": "01:15.830",
      "text": "像一首不知疲倦的歌",
      "translation": null
    },
    {
      "time": 79.88,
      "time_str": "01:19.880",
      "text": "哼唱着你，美丽的名字",
      "translation": null
    },
    {
      "time": 84.15,
      "time_str": "01:24.150",
      "text": "和我们不为人知的痛",
      "translation": null
    },
    {
      "time": 88.18,
      "time_str": "01:28.180",
      "text": "沙漏的爱",
      "translation": null
    },
    {
      "time": 90.31,
      "time_str": "01:30.310",
      "text": "点点滴滴",
      "translation": null
    },
    {
      "time": 92.38,
      "time_str": "01:32.380",
      "text": "是永不熄灭的灯火",
      "translation": null
    },
    {
      "time": 96.44,
      "time_str": "01:36.440",
      "text": "照亮仰望星空的孩子",
      "translation": null
    },
    {
      "time": 101.07,
      "time_str": "01:41.070",
      "text": "等待一回灿烂的日出",
      "translation": null
    },
    {
      "time": 108.45,
      "time_str": "01:48.450",
      "text": "MUSIC",
      "translation": null
    },
    {
      "time": 126.26,
      "time_str": "02:06.260",
      "text": "那一年夏天的雨",
      "translation": null
    },
    {
      "time": 130.13,
      "time_str": "02:10.130",
      "text": "像天上的星星一样多",
      "translation": null
    },
    {
      "time": 134.42,
      "time_str": "02:14.420",
      "text": "你的爱是把大大的伞",
      "translation": null
    },
    {
      "time": 138.3,
      "time_str": "02:18.300",
      "text": "给我最美的晴空",
      "translation": null
    },
    {
      "time": 142.85,
      "time_str": "02:22.850",
      "text": "我们都有小小的伤口",
      "translation": null
    },
    {
      "time": 146.59,
      "time_str": "02:26.590",
      "text": "把年轻的爱缝缝又补补",
      "translation": null
    },
    {
      "time": 151.95,
      "time_str": "02:31.950",
      "text": "剪一双叫做遗忘的翅膀",
