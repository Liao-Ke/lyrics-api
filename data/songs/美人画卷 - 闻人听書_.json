    {
      "time": 28.54,
      "time_str": "00:28.540",
      "text": "一袭白裳梅花泪",
      "translation": null
    },
    {
      "time": 31.49,
      "time_str": "00:31.490",
      "text": "一山水旁映一枚",
      "translation": null
    },
    {
      "time": 34.59,
      "time_str": "00:34.590",
      "text": "厌红尘独怜花红眼眉",
      "translation": null
    },
    {
      "time": 40.89,
      "time_str": "00:40.890",
      "text": "回首不见人痴嗔",
      "translation": null
    },
    {
      "time": 44.07,
      "time_str": "00:44.070",
      "text": "那景那物触了神",
      "translation": null
    },
    {
      "time": 47.33,
      "time_str": "00:47.330",
      "text": "春去秋来花开了几分",
      "translation": null
    },
    {
      "time": 53.94,
      "time_str": "00:53.940",
      "text": "时光怎不经一生",
      "translation": null
    },
    {
      "time": 55.53,
      "time_str": "00:55.530",
      "text": "浮浮沉沉已半生",
      "translation": null
    },
    {
      "time": 57.12,
      "time_str": "00:57.120",
      "text": "一壶浊酒欲随风",
      "translation": null
    },
    {
      "time": 58.84,
      "time_str": "00:58.840",
      "text": "一步一瞥似惊鸿",
      "translation": null
    },
    {
      "time": 60.44,
      "time_str": "01:00.440",
      "text": "情字要如何追问",
      "translation": null
    },
    {
      "time": 61.94,
      "time_str": "01:01.940",
      "text": "一指兰花为谁挽留",
      "translation": null
    },
    {
      "time": 66.35,
      "time_str": "01:06.350",
      "text": "青山常伴绿水",
      "translation": null
    },
    {
      "time": 69.76,
      "time_str": "01:09.760",
      "text": "燕雀已是南飞",
      "translation": null
    },
    {
      "time": 72.94,
      "time_str": "01:12.940",
      "text": "美人画卷残留",
      "translation": null
    },
    {
      "time": 75.98,
