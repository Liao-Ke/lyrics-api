  "lyrics": [
    {
      "time": 24.78,
      "time_str": "00:24.780",
      "text": "天空的雾来得漫不经心",
      "translation": null
    },
    {
      "time": 28.76,
      "time_str": "00:28.760",
      "text": "河水像油画一样安静",
      "translation": null
    },
    {
      "time": 32.37,
      "time_str": "00:32.370",
      "text": "和平鸽慵懒步伐押着韵",
      "translation": null
    },
    {
      "time": 36.27,
      "time_str": "00:36.270",
      "text": "心偷偷的放晴",
      "translation": null
    },
    {
      "time": 38.92,
      "time_str": "00:38.920",
      "text": "祈祷你像英勇的禁卫军",
      "translation": null
    },
    {
      "time": 43.64,
      "time_str": "00:43.640",
      "text": "动也不动的守护爱情",
      "translation": null
    },
    {
      "time": 47.03,
      "time_str": "00:47.030",
      "text": "你在回忆里留下的脚印",
      "translation": null
    },
    {
      "time": 51.17,
      "time_str": "00:51.170",
      "text": "是我爱的风景",
      "translation": null
    },
    {
      "time": 54.34,
      "time_str": "00:54.340",
      "text": "我要送你 日不落的想念",
      "translation": null
    },
    {
      "time": 58.66,
      "time_str": "00:58.660",
      "text": "寄出代表爱的明信片",
      "translation": null
    },
    {
      "time": 62.54,
      "time_str": "01:02.540",
      "text": "我要送你 日不落的爱恋",
      "translation": null
    },
    {
      "time": 66.16,
      "time_str": "01:06.160",
      "text": "心牵着心把世界走遍",
      "translation": null
    },
    {
      "time": 70.02,
      "time_str": "01:10.020",
      "text": "你就是庆典 你就是晴天",
      "translation": null
    },
    {
      "time": 73.64,
      "time_str": "01:13.640",
      "text": "我的爱未眠（我的爱未眠）",
      "translation": null
    },
    {
      "time": 77.48,
      "time_str": "01:17.480",
      "text": "不落的想念 飞在你身边",
      "translation": null
    },
    {
      "time": 81.32,
      "time_str": "01:21.320",
      "text": "我的爱未眠",
      "translation": null
    },
    {
      "time": 84.28,
      "time_str": "01:24.280",
      "text": "爱的巴士总是走了又停",
      "translation": null
    },
    {
      "time": 88.69,
      "time_str": "01:28.690",
      "text": "微笑望着广场上人群",
      "translation": null
    },
    {
      "time": 92.53,
      "time_str": "01:32.530",
      "text": "我要把爱全都装进行李",
      "translation": null
    },
    {
      "time": 96.21,
      "time_str": "01:36.210",
      "text": "陪我一起旅行",
      "translation": null
    },
