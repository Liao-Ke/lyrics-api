  "lyrics": [
    {
      "time": 18.64,
      "time_str": "00:18.640",
      "text": "用起伏的背影挡住哭泣的心",
      "translation": null
    },
    {
      "time": 26.839,
      "time_str": "00:26.839",
      "text": "有些故事不必说给每个人听",
      "translation": null
    },
    {
      "time": 34.629,
      "time_str": "00:34.629",
      "text": "许多眼睛看的太浅太近",
      "translation": null
    },
    {
      "time": 41.809,
      "time_str": "00:41.809",
      "text": "错过我没被看见那个自己",
      "translation": null
    },
    {
      "time": 50.399,
      "time_str": "00:50.399",
      "text": "用简单的言语解开超载的心",
      "translation": null
    },
    {
      "time": 58.289,
      "time_str": "00:58.289",
      "text": "有些情绪是该说给懂的人听",
      "translation": null
    },
    {
      "time": 66.309,
      "time_str": "01:06.309",
      "text": "你的热泪比我激动怜惜",
      "translation": null
    },
    {
      "time": 73.35,
      "time_str": "01:13.350",
      "text": "我发誓要更努力更有勇气",
      "translation": null
    },
    {
      "time": 81.27,
      "time_str": "01:21.270",
      "text": "等下一个天亮",
      "translation": null
    },
    {
      "time": 85.09,
      "time_str": "01:25.090",
      "text": "去上次牵手赏花那里散步好吗",
      "translation": null
    },
    {
      "time": 89.649,
      "time_str": "01:29.649",
      "text": "有些积雪会自己融化",
      "translation": null
    },
    {
      "time": 93.499,
      "time_str": "01:33.499",
      "text": "你的肩膀是我豁达的天堂",
      "translation": null
    },
    {
      "time": 97.8,
      "time_str": "01:37.800",
      "text": "等下一个天亮",
      "translation": null
    },
    {
      "time": 100.219,
      "time_str": "01:40.219",
      "text": "把偷拍我看海的照片送我好吗",
