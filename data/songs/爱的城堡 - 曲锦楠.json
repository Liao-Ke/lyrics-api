  "lyrics": [
    {
      "time": 5.445,
      "time_str": "00:05.445",
      "text": "小肥羊要开心哦",
      "translation": null
    },
    {
      "time": 39.241,
      "time_str": "00:39.241",
      "text": "你是谁等待千年的轮回",
      "translation": null
    },
    {
      "time": 47.53,
      "time_str": "00:47.530",
      "text": "爱相随不后退感觉像在飞",
      "translation": null
    },
    {
      "time": 54.991,
      "time_str": "00:54.991",
      "text": "我以为再多苦难也面对",
      "translation": null
    },
    {
      "time": 62.741,
      "time_str": "01:02.741",
      "text": "你的美如花蕾夜晚不再黑",
      "translation": null
    },
    {
      "time": 69.553,
      "time_str": "01:09.553",
      "text": "梦缠绵几回你的话让我心醉哦",
      "translation": null
    },
    {
      "time": 79.192,
      "time_str": "01:19.192",
      "text": "不在乎太多伤悲因为有了你相随",
      "translation": null
    },
    {
      "time": 90.129,
      "time_str": "01:30.129",
      "text": "爱的城堡不可摧你是我的美",
      "translation": null
    },
    {
      "time": 97.898,
      "time_str": "01:37.898",
      "text": "爱无悔这一回用一生去追",
      "translation": null
    },
    {
      "time": 105.96,
      "time_str": "01:45.960",
      "text": "爱的城堡花娇贵蝴蝶双双飞",
      "translation": null
    },
    {
      "time": 113.585,
      "time_str": "01:53.585",
      "text": "永远都为你陶醉",
      "translation": null
    },
    {
      "time": 153.507,
      "time_str": "02:33.507",
      "text": "伴你飞跃过千山和万水",
      "translation": null
    },
    {
      "time": 161.211,
      "time_str": "02:41.211",
      "text": "不伤悲或憔悴一切都面对",
      "translation": null
    },
    {
      "time": 168.898,
      "time_str": "02:48.898",
      "text": "有你陪和你去看夕阳美",
      "translation": null
    },
    {
      "time": 176.734,
      "time_str": "02:56.734",
      "text": "没有泪太完美靠在你的背",
