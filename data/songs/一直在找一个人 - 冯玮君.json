    {
      "time": 22.58,
      "time_str": "00:22.580",
      "text": "直到我遇见了你",
      "translation": null
    },
    {
      "time": 25.64,
      "time_str": "00:25.640",
      "text": "才开始了解爱",
      "translation": null
    },
    {
      "time": 30.27,
      "time_str": "00:30.270",
      "text": "控制不住的心跳",
      "translation": null
    },
    {
      "time": 33.11,
      "time_str": "00:33.110",
      "text": "等待你轻轻呼唤",
      "translation": null
    },
    {
      "time": 37.18,
      "time_str": "00:37.180",
      "text": "才知道我一点都不勇敢",
      "translation": null
    },
    {
      "time": 40.94,
      "time_str": "00:40.940",
      "text": "才知道越在乎也越不安",
      "translation": null
    },
    {
      "time": 44.9,
      "time_str": "00:44.900",
      "text": "要不是那天你伸出的手",
      "translation": null
    },
    {
      "time": 50.14,
      "time_str": "00:50.140",
      "text": "那么温暖",
      "translation": null
    },
    {
      "time": 52.17,
      "time_str": "00:52.170",
      "text": "我一直在找一个人",
      "translation": null
    },
    {
      "time": 56.14,
      "time_str": "00:56.140",
      "text": "就算盲目都快乐",
      "translation": null
    },
    {
      "time": 60.09,
      "time_str": "01:00.090",
      "text": "也只有真心相爱才可能",
      "translation": null
    },
    {
      "time": 65.5,
      "time_str": "01:05.500",
      "text": "了解什么叫深刻",
      "translation": null
    },
    {
      "time": 67.86,
      "time_str": "01:07.860",
      "text": "我一直在找一个人",
      "translation": null
