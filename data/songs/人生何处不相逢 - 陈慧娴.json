  "lyrics": [
    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "Publisher : PolyGram",
      "translation": null
    },
    {
      "time": 17.319,
      "time_str": "00:17.319",
      "text": "随浪随风飘荡",
      "translation": null
    },
    {
      "time": 21.295,
      "time_str": "00:21.295",
      "text": "随着一生里的浪",
      "translation": null
    },
    {
      "time": 25.34,
      "time_str": "00:25.340",
      "text": "你我在重叠那一刹",
      "translation": null
    },
    {
      "time": 29.247,
      "time_str": "00:29.247",
      "text": "顷刻各在一方",
      "translation": null
    },
    {
      "time": 33.263,
      "time_str": "00:33.263",
      "text": "缘分随风飘荡",
      "translation": null
    },
    {
      "time": 37.223,
      "time_str": "00:37.223",
      "text": "缘尽此生也守望",
      "translation": null
    },
    {
      "time": 41.238,
      "time_str": "00:41.238",
      "text": "你我在凝望那一刹",
      "translation": null
    },
    {
      "time": 45.18,
      "time_str": "00:45.180",
      "text": "心中有泪飘降",
      "translation": null
    },
    {
      "time": 49.282,
      "time_str": "00:49.282",
      "text": "纵是告别也交出真心意",
      "translation": null
    },
    {
      "time": 53.262,
      "time_str": "00:53.262",
      "text": "默默承受际遇",
      "translation": null
    },
    {
      "time": 57.255,
      "time_str": "00:57.255",
      "text": "某月某日也许再可跟你",
      "translation": null
    },
    {
      "time": 61.227,
      "time_str": "01:01.227",
      "text": "共聚重拾往事",
      "translation": null
    },
    {
      "time": 65.31,
      "time_str": "01:05.310",
      "text": "无奈重遇那天存在永远",
      "translation": null
    },
    {
      "time": 73.26,
      "time_str": "01:13.260",
      "text": "他方的晚空更是遥远",
      "translation": null
    },
    {
      "time": 81.204,
      "time_str": "01:21.204",
      "text": "谁在黄金海岸",
      "translation": null
    },
    {
      "time": 85.202,
      "time_str": "01:25.202",
      "text": "谁在烽烟彼岸",
      "translation": null
    },
    {
      "time": 89.237,
      "time_str": "01:29.237",
      "text": "你我在回望那一刹",
      "translation": null
    },
    {
      "time": 93.235,
      "time_str": "01:33.235",
      "text": "彼此慰问境况",
      "translation": null
    },
    {
