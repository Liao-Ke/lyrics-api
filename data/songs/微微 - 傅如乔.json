      "translation": null
    },
    {
      "time": 60.54,
      "time_str": "01:00.540",
      "text": "多少次跌跌撞撞才学会坚强",
      "translation": null
    },
    {
      "time": 64.66,
      "time_str": "01:04.660",
      "text": "多少次在迷茫之中寻找方向",
      "translation": null
    },
    {
      "time": 69.08,
      "time_str": "01:09.080",
      "text": "多少次跌倒之后再站起来面对",
