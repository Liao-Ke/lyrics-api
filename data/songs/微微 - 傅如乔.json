      "translation": null
    },
    {
      "time": 9.33,
      "time_str": "00:09.330",
      "text": "微微晨光点亮这喧嚣世界",
      "translation": null
    },
    {
      "time": 13.58,
      "time_str": "00:13.580",
      "text": "微微温暖融化昨夜的冰雪",
      "translation": null
    },
    {
      "time": 18.0,
      "time_str": "00:18.000",
      "text": "就像是每一秒都称为岁月",
      "translation": null
    },
    {
      "time": 22.11,
      "time_str": "00:22.110",
      "text": "微微从不停歇",
      "translation": null
    },
    {
      "time": 26.63,
      "time_str": "00:26.630",
      "text": "微微就是秋天里每片落叶",
      "translation": null
    },
    {
      "time": 30.93,
      "time_str": "00:30.930",
      "text": "微微就是彩虹里每滴雨点",
      "translation": null
    },
    {
      "time": 35.25,
      "time_str": "00:35.250",
      "text": "微微她很渺小却从不疲倦",
      "translation": null
    },
    {
      "time": 39.74,
      "time_str": "00:39.740",
      "text": "微微就是我们",
      "translation": null
    },
    {
      "time": 43.06,
      "time_str": "00:43.060",
      "text": "微 微 微 微",
      "translation": null
    },
    {
      "time": 48.09,
