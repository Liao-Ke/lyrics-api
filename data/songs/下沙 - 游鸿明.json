  "lyrics": [
    {
      "time": 47.198,
      "time_str": "00:47.198",
      "text": "每个人都有无法忘记的人",
      "translation": null
    },
    {
      "time": 49.859,
      "time_str": "00:49.859",
      "text": "思念会像细沙穿过你的灵魂",
      "translation": null
    },
    {
      "time": 54.478,
      "time_str": "00:54.478",
      "text": "轻轻开了门 只有风雨声",
      "translation": null
    },
    {
      "time": 62.038,
      "time_str": "01:02.038",
      "text": "我觉得爱情让人变得残忍",
      "translation": null
    },
    {
      "time": 67.219,
      "time_str": "01:07.219",
      "text": "原本相爱的人变成心头的针",
      "translation": null
    },
    {
      "time": 71.098,
      "time_str": "01:11.098",
      "text": "越是爱的真 越是伤的深",
      "translation": null
    },
    {
      "time": 79.639,
      "time_str": "01:19.639",
      "text": "就像黑夜和白天相隔一瞬间",
      "translation": null
    },
    {
      "time": 88.629,
      "time_str": "01:28.629",
      "text": "明知道说再见 再见面也只有明天",
      "translation": null
    },
    {
      "time": 97.09,
      "time_str": "01:37.090",
      "text": "天空啊下着沙 也在笑我太傻",
      "translation": null
    },
    {
      "time": 106.178,
      "time_str": "01:46.178",
      "text": "你就别再追寻看不清的脚印",
      "translation": null
    },
    {
      "time": 114.048,
      "time_str": "01:54.048",
      "text": "天空啊下着沙 也在为我牵挂",
      "translation": null
    },
    {
      "time": 124.68,
      "time_str": "02:04.680",
      "text": "把爱葬在沙里 还有你的消息",
      "translation": null
    },
    {
      "time": 132.239,
      "time_str": "02:12.239",
      "text": "你走了 就走了 不要想起",
      "translation": null
    },
    {
      "time": 142.799,
      "time_str": "02:22.799",
      "text": "风走了 沙走了 不要想起",
      "translation": null
    },
    {
