    {
      "time": 0.659,
      "time_str": "00:00.659",
      "text": "让我为你唱一首歌 全世界都陪你听着",
      "translation": null
    },
    {
      "time": 7.5,
      "time_str": "00:07.500",
      "text": "这是爱 你会明白 你是唯一不可替代",
      "translation": null
    },
    {
      "time": 14.18,
      "time_str": "00:14.180",
      "text": "让我为你唱一首歌 闭上眼睛把心交给我",
      "translation": null
    },
    {
      "time": 22.36,
      "time_str": "00:22.360",
      "text": "这一刻 要你听见幸福的颜色",
      "translation": null
    },
    {
      "time": 34.819,
      "time_str": "00:34.819",
      "text": "琴弦的快乐 在我手中为你颤抖着",
      "translation": null
    },
    {
      "time": 41.969,
      "time_str": "00:41.969",
      "text": "多一秒你的笑容 付出什么都值得",
      "translation": null
    },
    {
      "time": 48.909,
      "time_str": "00:48.909",
      "text": "旋转八音盒 每一个音符都记录着",
      "translation": null
    },
    {
