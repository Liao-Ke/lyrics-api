      "time_str": "00:31.460",
      "text": "某年某月的某一天",
      "translation": null
    },
    {
      "time": 38.87,
      "time_str": "00:38.870",
      "text": "就象一张破碎的脸",
      "translation": null
    },
    {
      "time": 45.51,
      "time_str": "00:45.510",
      "text": "难以开口道再见",
      "translation": null
    },
    {
      "time": 53.03,
      "time_str": "00:53.030",
      "text": "就让一切走远",
      "translation": null
    },
    {
      "time": 60.82,
      "time_str": "01:00.820",
      "text": "这不是件容易的事",
      "translation": null
    },
    {
      "time": 68.14,
      "time_str": "01:08.140",
      "text": "我们却都没有哭泣",
      "translation": null
    },
    {
      "time": 74.51,
      "time_str": "01:14.510",
      "text": "让它淡淡地来",
      "translation": null
    },
    {
      "time": 81.84,
      "time_str": "01:21.840",
      "text": "让它好好地去",
      "translation": null
    },
    {
      "time": 87.63,
      "time_str": "01:27.630",
      "text": "到如今年复一年",
      "translation": null
    },
    {
      "time": 92.04,
      "time_str": "01:32.040",
      "text": "我不能停止怀念",
