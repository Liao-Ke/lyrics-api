  "lyrics": [
    {
      "time": 13.92,
      "time_str": "00:13.920",
      "text": "头沾湿无可避免",
      "translation": null
    },
    {
      "time": 21.23,
      "time_str": "00:21.230",
      "text": "伦敦总依恋雨点",
      "translation": null
    },
    {
      "time": 27.44,
      "time_str": "00:27.440",
      "text": "乘早机忍耐着呵欠",
      "translation": null
    },
    {
      "time": 33.64,
      "time_str": "00:33.640",
      "text": "完全为见你一面",
      "translation": null
    },
    {
      "time": 40.79,
      "time_str": "00:40.790",
      "text": "寻得到尘封小店",
      "translation": null
    },
    {
      "time": 47.49,
      "time_str": "00:47.490",
      "text": "回不到相恋那天",
      "translation": null
    },
    {
      "time": 53.71,
      "time_str": "00:53.710",
      "text": "灵气大概早被污染",
      "translation": null
    },
    {
      "time": 59.6,
      "time_str": "00:59.600",
      "text": "谁为了生活不变",
      "translation": null
    },
    {
      "time": 66.718,
      "time_str": "01:06.718",
      "text": "越渴望见面然后发现",
      "translation": null
    },
    {
      "time": 73.977,
      "time_str": "01:13.977",
      "text": "中间隔着那十年",
      "translation": null
    },
    {
      "time": 79.718,
      "time_str": "01:19.718",
      "text": "我想见的笑脸只有怀念",
      "translation": null
    },
    {
      "time": 86.197,
      "time_str": "01:26.197",
      "text": "不懂怎去再聊天",
      "translation": null
    },
    {
      "time": 92.727,
      "time_str": "01:32.727",
      "text": "像我在往日还未抽烟",
      "translation": null
    },
    {
      "time": 99.65,
      "time_str": "01:39.650",
      "text": "不知你怎么变迁",
      "translation": null
    },
    {
      "time": 105.569,
      "time_str": "01:45.569",
      "text": "似等了一百年忽已明白",
      "translation": null
    },
    {
      "time": 112.01,
      "time_str": "01:52.010",
      "text": "即使再见面",
      "translation": null
    },
    {
      "time": 114.977,
      "time_str": "01:54.977",
      "text": "成熟地表演",
      "translation": null
    },
    {
