    {
      "time": 16.102,
      "time_str": "00:16.102",
      "text": "已经听了一百遍",
      "translation": null
    },
    {
      "time": 19.54,
      "time_str": "00:19.540",
      "text": "怎么听都不会倦",
      "translation": null
    },
    {
      "time": 22.907,
      "time_str": "00:22.907",
      "text": "从白天唱到黑夜",
      "translation": null
    },
    {
      "time": 26.185,
      "time_str": "00:26.185",
      "text": "你一直在身边",
      "translation": null
    },
    {
      "time": 29.854,
      "time_str": "00:29.854",
      "text": "如果世界太危险",
      "translation": null
    },
    {
      "time": 33.247,
      "time_str": "00:33.247",
      "text": "只有音乐最安全",
      "translation": null
    },
    {
      "time": 36.692,
      "time_str": "00:36.692",
      "text": "带着我进梦里面",
      "translation": null
    },
    {
      "time": 39.859,
      "time_str": "00:39.859",
      "text": "让歌词都实现",
      "translation": null
    },
    {
      "time": 42.909,
      "time_str": "00:42.909",
      "text": "无论是开心还是难过我的爱一直不变",
      "translation": null
    },
    {
      "time": 46.746,
      "time_str": "00:46.746",
      "text": "不必担心时间流逝带走一切",
      "translation": null
    },
    {
      "time": 49.738,
      "time_str": "00:49.738",
      "text": "无论是Hip-Hop 还是摇滚我的爱一直不变",
      "translation": null
    },
    {
      "time": 53.574,
      "time_str": "00:53.574",
      "text": "所有美好回忆记录在里面",
      "translation": null
    },
    {
      "time": 56.606,
      "time_str": "00:56.606",
      "text": "这种 Forever Love 那么深",
      "translation": null
    },
    {
      "time": 58.955,
      "time_str": "00:58.955",
      "text": "我们的歌 那么真",
      "translation": null
    },
    {
      "time": 60.692,
      "time_str": "01:00.692",
      "text": "无国界跨时代",
