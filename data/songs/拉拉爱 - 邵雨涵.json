  "lyrics": [
    {
      "time": 1.69,
      "time_str": "00:01.690",
      "text": "拉拉拉拉拉拉拉拉拉",
      "translation": null
    },
    {
      "time": 8.35,
      "time_str": "00:08.350",
      "text": "只有跳舞才能",
      "translation": null
    },
    {
      "time": 9.82,
      "time_str": "00:09.820",
      "text": "让我的心情自由散发",
      "translation": null
    },
    {
      "time": 47.26,
      "time_str": "00:47.260",
      "text": "一起来跳吧 没有人喊CUT",
      "translation": null
    },
    {
      "time": 51.0,
      "time_str": "00:51.000",
      "text": "凌晨两点以前 谁也别回家",
      "translation": null
    },
    {
      "time": 54.96,
      "time_str": "00:54.960",
      "text": "可爱MADUSHA 甩动着头发",
      "translation": null
    },
    {
      "time": 59.16,
      "time_str": "00:59.160",
      "text": "我的麦当娜",
      "translation": null
    },
    {
      "time": 62.12,
      "time_str": "01:02.120",
      "text": "不管是它他她 还是菲奥娜",
      "translation": null
    },
    {
      "time": 66.45,
      "time_str": "01:06.450",
      "text": "空气中的温度 把一切蒸发",
      "translation": null
    },
    {
      "time": 70.19,
      "time_str": "01:10.190",
      "text": "冰淇淋融化在 旋转的木马",
      "translation": null
    },
    {
      "time": 74.29,
      "time_str": "01:14.290",
      "text": "盛开灿烂的烟花",
      "translation": null
    },
    {
      "time": 77.04,
      "time_str": "01:17.040",
      "text": "跟着音乐拉拉拉 不想他",
      "translation": null
    },
    {
      "time": 81.56,
      "time_str": "01:21.560",
      "text": "跟着音乐拉拉拉 不回家",
      "translation": null
