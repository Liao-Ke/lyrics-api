  },
  "lyrics": [
    {
      "time": 17.7,
      "time_str": "00:17.700",
      "text": "我曾和你走过多少个的秋末",
      "translation": null
    },
    {
      "time": 21.16,
      "time_str": "00:21.160",
      "text": "我曾紧紧握着你手臂的脉搏",
      "translation": null
    },
    {
      "time": 24.89,
      "time_str": "00:24.890",
      "text": "看你脸上的酒窝",
      "translation": null
    },
    {
      "time": 26.69,
      "time_str": "00:26.690",
      "text": "唱着背叛的情歌 情绪不由我",
      "translation": null
    },
    {
      "time": 31.11,
      "time_str": "00:31.110",
      "text": "我曾带你去看星空下的花火",
      "translation": null
    },
    {
      "time": 35.26,
      "time_str": "00:35.260",
      "text": "我曾把我的爱都交给你挥霍",
      "translation": null
    },
    {
      "time": 38.85,
      "time_str": "00:38.850",
      "text": "这世界爱情好多",
      "translation": null
    },
    {
      "time": 40.7,
      "time_str": "00:40.700",
      "text": "结局未必有几个 这痛算什么",
      "translation": null
    },
    {
      "time": 44.6,
      "time_str": "00:44.600",
      "text": "我在无人的街头 想念着某某",
      "translation": null
    },
    {
      "time": 48.14,
      "time_str": "00:48.140",
      "text": "你在别人的宇宙 施舍着温柔",
      "translation": null
    },
    {
      "time": 51.73,
      "time_str": "00:51.730",
      "text": "我能给的风度是微笑着默默放开手",
      "translation": null
    },
    {
      "time": 58.14,
      "time_str": "00:58.140",
      "text": "我知道你的眼泪只是一种无奈",
      "translation": null
    },
    {
      "time": 62.19,
      "time_str": "01:02.190",
      "text": "何必虚情假意的勾勒着未来",
      "translation": null
    },
    {
      "time": 65.67,
      "time_str": "01:05.670",
      "text": "当爱已不存在 我又为谁等待",
      "translation": null
    },
    {
      "time": 69.25,
      "time_str": "01:09.250",
      "text": "嘲笑命运这幽默的安排",
      "translation": null
    },
    {
      "time": 72.48,
      "time_str": "01:12.480",
      "text": "我知道你的挽回只是一种习惯",
      "translation": null
    },
    {
      "time": 76.09,
      "time_str": "01:16.090",
      "text": "也曾为难你有多么害怕孤单",
      "translation": null
    },
    {
      "time": 79.95,
      "time_str": "01:19.950",
      "text": "故事可以重来 时光却已不再",
      "translation": null
    },
    {
      "time": 83.39,
      "time_str": "01:23.390",
      "text": "感情需要一点点的空白",
      "translation": null
    },
    {
      "time": 86.49,
      "time_str": "01:26.490",
      "text": "来整理遗憾",
      "translation": null
    },
    {
