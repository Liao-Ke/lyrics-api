  "lyrics": [
    {
      "time": 20.02,
      "time_str": "00:20.020",
      "text": "鸟一对  天空海阔分飞",
      "translation": null
    },
    {
      "time": 33.42,
      "time_str": "00:33.420",
      "text": "酒一杯  各自天南地北",
      "translation": null
    },
    {
      "time": 41.25,
      "time_str": "00:41.250",
      "text": "两双腿  踏着时间去追 一个完美",
      "translation": null
    },
    {
      "time": 45.62,
      "time_str": "00:45.620",
      "text": "不后悔  我们一去不回",
      "translation": null
    },
    {
      "time": 49.83,
      "time_str": "00:49.830",
      "text": "你是谁  沾染日月清辉  我是谁  喝过银河之水",
      "translation": null
    },
    {
      "time": 57.88,
      "time_str": "00:57.880",
      "text": "趁酒醉  双双到人间度一场是非",
      "translation": null
    },
    {
      "time": 62.27,
      "time_str": "01:02.270",
      "text": "下一回  七度空间相会",
      "translation": null
    },
    {
      "time": 66.68,
      "time_str": "01:06.680",
      "text": "我跟你相隔中国遥遥十万八千里",
      "translation": null
    },
    {
      "time": 70.36,
      "time_str": "01:10.360",
      "text": "我跟你相遇在不属于自己的土地 是缘分 是巧合",
      "translation": null
    },
    {
      "time": 76.32,
      "time_str": "01:16.320",
      "text": "让你我成为兄弟 是可遇 不可求那种无形的默契",
      "translation": null
    },
    {
      "time": 82.92,
      "time_str": "01:22.920",
      "text": "鸟一对  在天空中相会  酒一杯  冲淡是是非非",
      "translation": null
    },
    {
      "time": 90.96,
      "time_str": "01:30.960",
      "text": "两双腿  踏过千山万水 从来不累",
      "translation": null
    },
    {
      "time": 95.37,
      "time_str": "01:35.370",
      "text": "纵不回  也在他乡交汇",
      "translation": null
    },
    {
      "time": 99.83,
      "time_str": "01:39.830",
      "text": "你是谁  为我插刀两肋  我是谁  对你掏心掏肺",
      "translation": null
    },
    {
      "time": 108.15,
      "time_str": "01:48.150",
      "text": "风一吹  世间的传说转眼就破碎",
      "translation": null
    },
    {
      "time": 111.97,
      "time_str": "01:51.970",
      "text": "不后退  我们尽力而为",
      "translation": null
    },
    {
      "time": 116.78,
      "time_str": "01:56.780",
      "text": "手一挥  掌一推  浩瀚宇宙没有极限的范围",
      "translation": null
    },
    {
      "time": 124.26,
      "time_str": "02:04.260",
      "text": "小天地  大智慧  无极世界其实在你我心扉",
      "translation": null
    },
    {
      "time": 132.84,
      "time_str": "02:12.840",
      "text": "手一挥  掌一推  清静心灵没有极限的范围",
      "translation": null
    },
    {
      "time": 140.88,
      "time_str": "02:20.880",
      "text": "小天地  大智慧  无极世界其实没什么绝对",
      "translation": null
    },
    {
      "time": 161.51,
      "time_str": "02:41.510",
      "text": "m",
      "translation": null
    },
    {
      "time": 180.64,
      "time_str": "03:00.640",
      "text": "已经忘记与你一起经历了多少血和泪",
      "translation": null
    },
    {
      "time": 183.81,
      "time_str": "03:03.810",
      "text": "这种感情已经超过了时间超越了年和岁 面对任何眼泪",
      "translation": null
    },
    {
      "time": 189.36,
      "time_str": "03:09.360",
      "text": "受过多少罪 我们也不撤退一齐来吧喝醉 装满烈酒的杯 怎么碰 不会碎",
      "translation": null
    },
    {
      "time": 196.28,
      "time_str": "03:16.280",
      "text": "鸟一对  在天空中相会  酒一杯  冲淡是是非非",
      "translation": null
    },
    {
