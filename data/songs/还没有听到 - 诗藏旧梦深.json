  "lyrics": [
    {
      "time": 14.82,
      "time_str": "00:14.820",
      "text": "这寂静 是你送我的诀别之礼",
      "translation": null
    },
    {
      "time": 24.363,
      "time_str": "00:24.363",
      "text": "不是不想听 要假装很随性",
      "translation": null
    },
    {
      "time": 36.184,
      "time_str": "00:36.184",
      "text": "我悔恨不识趣的任性",
      "translation": null
    },
    {
      "time": 43.904,
      "time_str": "00:43.904",
      "text": "上演着烂剧情 把话都说的太狠心",
      "translation": null
    },
    {
      "time": 56.9,
      "time_str": "00:56.900",
      "text": "可惜了 固执的嘴硬",
      "translation": null
    },
    {
      "time": 63.638,
      "time_str": "01:03.638",
      "text": "又在情绪泛滥时软下心",
      "translation": null
    },
    {
      "time": 71.59,
      "time_str": "01:11.590",
      "text": "就算没结果的结局 故事要动听",
      "translation": null
    },
    {
      "time": 84.02,
      "time_str": "01:24.020",
      "text": "怎么你还没有听到",
      "translation": null
    },
    {
      "time": 91.02,
      "time_str": "01:31.020",
      "text": "思念又突出棱角",
      "translation": null
    },
    {
      "time": 97.058,
      "time_str": "01:37.058",
      "text": "回忆顷刻到达 肆意席卷着每一秒",
      "translation": null
    },
    {
      "time": 110.572,
      "time_str": "01:50.572",
      "text": "怎么你还没有听到",
      "translation": null
    },
    {
      "time": 117.267,
      "time_str": "01:57.267",
      "text": "就把我放逐在寒冷的人潮",
      "translation": null
    },
    {
      "time": 124.671,
      "time_str": "02:04.671",
      "text": "我苦笑 困在循环的寂寥",
