  "lyrics": [
    {
      "time": 23.9,
      "time_str": "00:23.900",
      "text": "如果不是她钱多 你会不会来娶我",
      "translation": null
    },
    {
      "time": 34.599,
      "time_str": "00:34.599",
      "text": "你为何非走不可 不能留下来陪我",
      "translation": null
    },
    {
      "time": 45.59,
      "time_str": "00:45.590",
      "text": "你对我是真心的",
      "translation": null
    },
    {
      "time": 50.259,
      "time_str": "00:50.259",
      "text": "抵不过名利的诱惑",
      "translation": null
    },
    {
      "time": 56.189,
      "time_str": "00:56.189",
      "text": "你难道不担心我 没有你不能活",
      "translation": null
    },
    {
      "time": 66.548,
      "time_str": "01:06.548",
      "text": "男朋友结婚了 新娘却不是我",
      "translation": null
    },
    {
      "time": 71.949,
      "time_str": "01:11.949",
      "text": "就算眼泪再多 也没人心疼我",
      "translation": null
    },
    {
      "time": 78.19,
      "time_str": "01:18.190",
      "text": "我想要的不多 你的爱就够了",
      "translation": null
    },
    {
      "time": 82.859,
      "time_str": "01:22.859",
      "text": "千万别怕养不起我",
      "translation": null
    },
    {
      "time": 89.29,
      "time_str": "01:29.290",
      "text": "男朋友结婚了 新娘却不是我",
      "translation": null
    },
    {
      "time": 93.869,
      "time_str": "01:33.869",
      "text": "所有你想要的 唯独缺我一个",
      "translation": null
    },
    {
      "time": 99.58,
      "time_str": "01:39.580",
      "text": "有手有脚拼搏 总想不劳而获",
      "translation": null
    },
    {
