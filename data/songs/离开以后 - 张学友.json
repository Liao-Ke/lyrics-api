  "lyrics": [
    {
      "time": 14.79,
      "time_str": "00:14.790",
      "text": "近日像每样话题总不适合你",
      "translation": null
    },
    {
      "time": 21.79,
      "time_str": "00:21.790",
      "text": "近日夜深相聚",
      "translation": null
    },
    {
      "time": 23.93,
      "time_str": "00:23.930",
      "text": "飘起一抹冷漠空气",
      "translation": null
    },
    {
      "time": 27.96,
      "time_str": "00:27.960",
      "text": "在这天",
      "translation": null
    },
    {
      "time": 29.92,
      "time_str": "00:29.920",
      "text": "是你事无大小多么生气",
      "translation": null
    },
    {
      "time": 36.109,
      "time_str": "00:36.109",
      "text": "谁人亦可知你将别离",
      "translation": null
    },
    {
      "time": 43.049,
      "time_str": "00:43.049",
      "text": "落寞地躺在睡床试试抱紧你",
      "translation": null
    },
    {
      "time": 50.509,
      "time_str": "00:50.509",
      "text": "但是目光躲避",
      "translation": null
    },
    {
      "time": 52.549,
      "time_str": "00:52.549",
      "text": "令我可感到你在喘气",
      "translation": null
    },
    {
      "time": 57.39,
      "time_str": "00:57.390",
      "text": "没说出",
      "translation": null
    },
    {
      "time": 58.519,
      "time_str": "00:58.519",
      "text": "亦领会谁在撩动你",
      "translation": null
    },
    {
      "time": 63.499,
      "time_str": "01:03.499",
      "text": "抛开苦痛去解脱自己",
      "translation": null
    },
    {
      "time": 66.969,
      "time_str": "01:06.969",
      "text": "让你那些冷却热情另有生机",
      "translation": null
    },
    {
      "time": 70.429,
      "time_str": "01:10.429",
      "text": "离开我以后我会习惯自卑",
      "translation": null
    },
    {
      "time": 74.089,
      "time_str": "01:14.089",
      "text": "明天再偶遇我也不敢偷望你",
      "translation": null
    },
    {
      "time": 78.19,
      "time_str": "01:18.190",
      "text": "离开我以后季节冷暖天气",
      "translation": null
    },
    {
      "time": 80.169,
      "time_str": "01:20.169",
      "text": "我也置诸不理",
      "translation": null
    },
    {
      "time": 81.779,
      "time_str": "01:21.779",
      "text": "愿名字也再不记起",
      "translation": null
    },
    {
      "time": 85.49,
      "time_str": "01:25.490",
      "text": "离开我以后我会长留这地",
      "translation": null
    },
    {
      "time": 88.299,
      "time_str": "01:28.299",
      "text": "晨早到午夜扑进漆黑想念你",
      "translation": null
    },
    {
      "time": 91.929,
      "time_str": "01:31.929",
      "text": "离开我以后醉了会看到你",
      "translation": null
    },
    {
      "time": 94.519,
      "time_str": "01:34.519",
      "text": "梦中方可永久地",
      "translation": null
    },
    {
      "time": 99.139,
      "time_str": "01:39.139",
      "text": "接近你",
      "translation": null
    },
    {
      "time": 101.409,
      "time_str": "01:41.409",
      "text": "oh-----",
      "translation": null
    },
    {
      "time": 132.93,
      "time_str": "02:12.930",
      "text": "伴着但我在预期你会说舍弃",
      "translation": null
    },
    {
      "time": 140.08,
      "time_str": "02:20.080",
      "text": "问事实怎躲避",
      "translation": null
    },
    {
      "time": 142.0,
      "time_str": "02:22.000",
      "text": "在倒数将要每日想你",
      "translation": null
    },
    {
      "time": 146.3,
      "time_str": "02:26.300",
      "text": "若这刻",
      "translation": null
    },
    {
      "time": 148.37,
      "time_str": "02:28.370",
      "text": "若最后无力留下你",
      "translation": null
    },
    {
      "time": 153.04,
      "time_str": "02:33.040",
      "text": "将消失勇气释放自己",
      "translation": null
    },
    {
      "time": 156.6,
      "time_str": "02:36.600",
      "text": "就算某天我吻别人亦当亲你",
      "translation": null
    },
    {
