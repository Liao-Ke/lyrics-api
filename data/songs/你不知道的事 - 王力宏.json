  "lyrics": [
    {
      "time": 6.06,
      "time_str": "00:06.060",
      "text": "蝴蝶眨几次眼睛 才学会飞行",
      "translation": null
    },
    {
      "time": 17.38,
      "time_str": "00:17.380",
      "text": "夜空洒满了星星 但几颗会落地",
      "translation": null
    },
    {
      "time": 27.91,
      "time_str": "00:27.910",
      "text": "我飞行 但你坠落之际",
      "translation": null
    },
    {
      "time": 33.31,
      "time_str": "00:33.310",
      "text": "很靠近 还听见呼吸",
      "translation": null
    },
    {
      "time": 38.88,
      "time_str": "00:38.880",
      "text": "对不起 我却没捉紧你",
      "translation": null
    },
    {
      "time": 48.05,
      "time_str": "00:48.050",
      "text": "你不知道我为什么离开你",
      "translation": null
    },
    {
      "time": 53.66,
      "time_str": "00:53.660",
      "text": "我坚持不能说放任你哭泣",
      "translation": null
    },
    {
      "time": 59.23,
      "time_str": "00:59.230",
      "text": "你的泪滴像 倾盆大雨",
      "translation": null
    },
    {
      "time": 63.75,
      "time_str": "01:03.750",
      "text": "碎了满地 在心里清晰",
      "translation": null
    },
    {
      "time": 70.42,
      "time_str": "01:10.420",
      "text": "你不知道我为什么狠下心",
      "translation": null
    },
    {
      "time": 75.74,
      "time_str": "01:15.740",
      "text": "盘旋在你看不见的高空里",
      "translation": null
    },
    {
      "time": 82.67,
      "time_str": "01:22.670",
      "text": "多的是 你不知道的事",
      "translation": null
    },
    {
