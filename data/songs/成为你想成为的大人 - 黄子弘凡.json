    {
      "time": 19.59,
      "time_str": "00:19.590",
      "text": "拥抱过后 像蒲公英 四散天涯",
      "translation": null
    },
    {
      "time": 24.66,
      "time_str": "00:24.660",
      "text": "下场山海 有没有风 加入步伐",
      "translation": null
    },
    {
      "time": 29.88,
      "time_str": "00:29.880",
      "text": "还没走到 人声鼎沸 没簇拥繁花",
      "translation": null
    },
    {
      "time": 34.98,
      "time_str": "00:34.980",
      "text": "世界太大 我要去哪 oh",
      "translation": null
    },
    {
      "time": 40.41,
      "time_str": "00:40.410",
      "text": "篮球吉他 全部遗落 那个长假",
      "translation": null
    },
    {
      "time": 45.39,
      "time_str": "00:45.390",
      "text": "再见过后 谁能抓住 夏天尾巴",
      "translation": null
    },
    {
      "time": 50.61,
      "time_str": "00:50.610",
      "text": "那些心跳 没有机会 再去告诉她",
      "translation": null
    },
    {
      "time": 55.77,
      "time_str": "00:55.770",
      "text": "爱这道题 还没找到 解答",
      "translation": null
    },
    {
      "time": 61.05,
      "time_str": "01:01.050",
      "text": "就去成为 你想成为 那个大人啊",
      "translation": null
    },
    {
      "time": 66.06,
      "time_str": "01:06.060",
      "text": "继续兴致 盎然跟世界 交手啊",
      "translation": null
    },
    {
      "time": 71.28,
      "time_str": "01:11.280",
      "text": "宇宙和 生活都很大",
      "translation": null
    },
    {
      "time": 73.77,
      "time_str": "01:13.770",
      "text": "去尽兴 去灿烂年华",
      "translation": null
    },
    {
      "time": 76.41,
      "time_str": "01:16.410",
      "text": "你就是你 自己最好的回答",
      "translation": null
    },
    {
      "time": 91.92,
      "time_str": "01:31.920",
      "text": "我们不会 再比今天 更年轻啊",
      "translation": null
    },
    {
      "time": 97.02,
      "time_str": "01:37.020",
      "text": "渺小的梦 就放肆做 到无限大",
      "translation": null
    },
    {
      "time": 100.68,
      "time_str": "01:40.680",
      "text": "就祝我们 热烈自由 顶峰相见啊",
      "translation": null
    },
    {
