  "lyrics": [
    {
      "time": 35.544,
      "time_str": "00:35.544",
      "text": "这晚在街中偶遇心中的她",
      "translation": null
    },
    {
      "time": 38.672,
      "time_str": "00:38.672",
      "text": "两脚决定不听叫唤跟她归家",
      "translation": null
    },
    {
      "time": 41.784,
      "time_str": "00:41.784",
      "text": "深宵的冷风 不准吹去她",
      "translation": null
    },
    {
      "time": 44.908,
      "time_str": "00:44.908",
      "text": "她那幽幽眼神快要对我说话",
      "translation": null
    },
    {
      "time": 48.023,
      "time_str": "00:48.023",
      "text": "纤纤身影 飘飘身影 默默转来吧",
      "translation": null
    },
    {
      "time": 51.117,
      "time_str": "00:51.117",
      "text": "对我说浪漫情人爱我吗",
      "translation": null
    },
    {
      "time": 54.232,
      "time_str": "00:54.232",
      "text": "贪心的晚风 竟敢拥吻她",
      "translation": null
    },
    {
      "time": 57.302,
      "time_str": "00:57.302",
      "text": "将她秀发温温柔柔每缕每缕放下",
      "translation": null
    },
    {
      "time": 60.477,
      "time_str": "01:00.477",
      "text": "卑污的晚风 不应抚慰她",
      "translation": null
    },
    {
      "time": 63.578,
      "time_str": "01:03.578",
      "text": "我已决意一生护着心中的她",
      "translation": null
