  },
  "lyrics": [
    {
      "time": 24.279,
      "time_str": "00:24.279",
      "text": "徘徊过多少橱窗 住过多少旅馆",
      "translation": null
    },
    {
      "time": 28.736,
      "time_str": "00:28.736",
      "text": "才会觉得分离也并不冤枉",
      "translation": null
    },
    {
      "time": 33.27,
      "time_str": "00:33.270",
      "text": "感情是用来浏览 还是用来珍藏",
      "translation": null
    },
    {
      "time": 37.927,
      "time_str": "00:37.927",
      "text": "好让日子天天都过得难忘",
      "translation": null
    },
    {
      "time": 42.49,
      "time_str": "00:42.490",
      "text": "熬过了多久患难 湿了多长眼眶",
      "translation": null
    },
    {
      "time": 47.032,
      "time_str": "00:47.032",
      "text": "才能知道伤感是爱的遗产",
      "translation": null
    },
    {
      "time": 51.629,
      "time_str": "00:51.629",
      "text": "流浪几张双人床 换过几次信仰",
      "translation": null
    },
    {
      "time": 56.213,
      "time_str": "00:56.213",
      "text": "才让戒指义无反顾的交换",
      "translation": null
    },
    {
      "time": 60.77,
      "time_str": "01:00.770",
      "text": "把一个人的温暖 转移到另一个的胸膛",
      "translation": null
    },
    {
      "time": 65.92,
      "time_str": "01:05.920",
      "text": "让上次犯的错反省出梦想",
      "translation": null
    },
    {
      "time": 70.485,
      "time_str": "01:10.485",
      "text": "每个人都是这样 享受过提心吊胆",
      "translation": null
    },
    {
      "time": 74.992,
      "time_str": "01:14.992",
      "text": "才拒绝做爱情待罪的羔羊",
      "translation": null
    },
    {
      "time": 79.62,
      "time_str": "01:19.620",
      "text": "回忆是抓不到的月光握紧就变黑暗",
      "translation": null
    },
    {
      "time": 84.218,
      "time_str": "01:24.218",
      "text": "等虚假的背影消失于晴朗",
      "translation": null
    },
    {
      "time": 88.769,
      "time_str": "01:28.769",
      "text": "阳光在身上流转 等所有业障被原谅",
      "translation": null
    },
    {
      "time": 96.297,
      "time_str": "01:36.297",
      "text": "爱情不停站 想开往地老天荒",
      "translation": null
    },
    {
      "time": 100.652,
      "time_str": "01:40.652",
      "text": "需要多勇敢",
      "translation": null
    },
    {
      "time": 104.944,
      "time_str": "01:44.944",
      "text": "烛光照亮了晚餐 照不出个答案",
      "translation": null
    },
    {
      "time": 109.521,
      "time_str": "01:49.521",
      "text": "恋爱不是温馨的请客吃饭",
      "translation": null
    },
    {
      "time": 114.081,
      "time_str": "01:54.081",
      "text": "床单上铺满花瓣 拥抱让它成长",
      "translation": null
    },
    {
      "time": 118.646,
      "time_str": "01:58.646",
      "text": "太拥挤就开到了别的土壤",
      "translation": null
    },
    {
      "time": 123.236,
      "time_str": "02:03.236",
      "text": "感情需要人接班 接近换来期望",
      "translation": null
    },
    {
      "time": 127.81,
      "time_str": "02:07.810",
      "text": "期望带来失望的恶性循环",
      "translation": null
    },
    {
      "time": 132.379,
      "time_str": "02:12.379",
      "text": "短暂的总是浪漫 漫长总会不满",
      "translation": null
    },
    {
      "time": 136.941,
      "time_str": "02:16.941",
      "text": "烧完美好青春换一个老伴",
      "translation": null
    },
    {
