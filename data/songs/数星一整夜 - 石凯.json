  "lyrics": [
    {
      "time": 1.28,
      "time_str": "00:01.280",
      "text": "数星一整夜",
      "translation": null
    },
    {
      "time": 20.99,
      "time_str": "00:20.990",
      "text": "我怎么又患失眠症",
      "translation": null
    },
    {
      "time": 23.29,
      "time_str": "00:23.290",
      "text": "怪气温怪可恶的钟声",
      "translation": null
    },
    {
      "time": 25.77,
      "time_str": "00:25.770",
      "text": "同时间你也没想关灯",
      "translation": null
    },
    {
      "time": 30.72,
      "time_str": "00:30.720",
      "text": "互相怕打扰",
      "translation": null
    },
    {
      "time": 32.11,
      "time_str": "00:32.110",
      "text": "只靠推敲",
      "translation": null
    },
    {
      "time": 33.14,
      "time_str": "00:33.140",
      "text": "同步在思考 每分每秒",
      "translation": null
    },
    {
      "time": 35.43,
      "time_str": "00:35.430",
      "text": "像倒数读表 望向天空",
      "translation": null
    },
    {
      "time": 39.6,
      "time_str": "00:39.600",
      "text": "与你相距 几百公里",
      "translation": null
    },
    {
      "time": 44.23,
      "time_str": "00:44.230",
      "text": "或更遥远 在不同屋檐",
      "translation": null
    },
    {
      "time": 48.86,
      "time_str": "00:48.860",
      "text": "等星相遇 亿万公里",
      "translation": null
    },
    {
      "time": 53.03,
      "time_str": "00:53.030",
      "text": "这一颗像我 那一颗像你",
      "translation": null
    },
    {
      "time": 60.37,
      "time_str": "01:00.370",
      "text": "数星一整夜 有错过有重叠",
      "translation": null
    },
    {
      "time": 66.29,
      "time_str": "01:06.290",
      "text": "亮一些暗了一些",
      "translation": null
    },
    {
      "time": 69.66,
      "time_str": "01:09.660",
      "text": "数星一整夜 拉过钩的直觉",
      "translation": null
    },
    {
      "time": 74.88,
      "time_str": "01:14.880",
      "text": "只是身边有个空缺",
      "translation": null
    },
    {
      "time": 81.47,
      "time_str": "01:21.470",
      "text": "我想化作那流星",
      "translation": null
    },
    {
      "time": 83.69,
      "time_str": "01:23.690",
      "text": "瞬间划入你眼睛",
      "translation": null
    },
    {
      "time": 86.22,
      "time_str": "01:26.220",
      "text": "无视距离时间流浪 追寻",
      "translation": null
    },
    {
      "time": 90.27,
      "time_str": "01:30.270",
      "text": "追寻着你的 现在未来",
      "translation": null
    },
    {
      "time": 92.31,
      "time_str": "01:32.310",
      "text": "这夜深人静",
      "translation": null
    },
    {
      "time": 96.98,
      "time_str": "01:36.980",
      "text": "该相拥着星空入睡",
      "translation": null
    },
    {
      "time": 100.08,
      "time_str": "01:40.080",
      "text": "星星会许愿",
      "translation": null
    },
    {
      "time": 101.92,
      "time_str": "01:41.920",
      "text": "虽然 难懂 流星 会实现",
      "translation": null
    },
    {
      "time": 105.47,
      "time_str": "01:45.470",
      "text": "要怎么心安 站你左边",
      "translation": null
    },
    {
      "time": 109.62,
      "time_str": "01:49.620",
      "text": "在 这 不完整的深夜",
      "translation": null
    },
    {
      "time": 112.34,
      "time_str": "01:52.340",
      "text": "难熬的分秒",
      "translation": null
    },
    {
      "time": 115.04,
      "time_str": "01:55.040",
      "text": "只因你不在身边",
      "translation": null
    },
    {
      "time": 117.91,
      "time_str": "01:57.910",
      "text": "与你相距 几百公里",
