      "translation": null
    },
    {
      "time": 156.26,
      "time_str": "02:36.260",
      "text": "你每天做了些什么",
      "translation": null
    },
    {
      "time": 160.27,
      "time_str": "02:40.270",
      "text": "我都了然于胸",
      "translation": null
    },
    {
      "time": 164.45,
      "time_str": "02:44.450",
      "text": "当时嫌你的蠢话太多",
      "translation": null
    },
    {
      "time": 168.46,
      "time_str": "02:48.460",
      "text": "现在回想起画面已泛旧",
      "translation": null
