  "lyrics": [
    {
      "time": 35.379,
      "time_str": "00:35.379",
      "text": "在远方的时候",
      "translation": null
    },
    {
      "time": 37.298,
      "time_str": "00:37.298",
      "text": "又想你到泪流",
      "translation": null
    },
    {
      "time": 42.438,
      "time_str": "00:42.438",
      "text": "这矫情的措辞结构",
      "translation": null
    },
    {
      "time": 46.698,
      "time_str": "00:46.698",
      "text": "经历过的人会懂",
      "translation": null
    },
    {
      "time": 50.779,
      "time_str": "00:50.779",
      "text": "那些不堪言的疼痛",
      "translation": null
    },
    {
      "time": 54.989,
      "time_str": "00:54.989",
      "text": "也就是我自作自受",
      "translation": null
    },
    {
      "time": 59.298,
      "time_str": "00:59.298",
      "text": "你没有装聋",
      "translation": null
    },
    {
      "time": 62.809,
      "time_str": "01:02.809",
      "text": "你真没感动",
      "translation": null
    },
    {
      "time": 67.908,
      "time_str": "01:07.908",
      "text": "一个人的时候",
      "translation": null
    },
    {
      "time": 70.699,
      "time_str": "01:10.699",
      "text": "偷偷看你的微博",
      "translation": null
    },
    {
      "time": 75.288,
      "time_str": "01:15.288",
      "text": "你转播的歌好耳熟",
      "translation": null
    },
    {
      "time": 78.408,
      "time_str": "01:18.408",
      "text": "我们坐一起听过",
      "translation": null
    },
    {
      "time": 83.359,
      "time_str": "01:23.359",
      "text": "当日嫌它的唱法做作",
      "translation": null
    },
    {
      "time": 87.899,
      "time_str": "01:27.899",
      "text": "现在听起来竟然很生动",
      "translation": null
    },
    {
      "time": 92.219,
      "time_str": "01:32.219",
      "text": "可能是时光让耳朵变得宽容",
      "translation": null
    },
    {
      "time": 100.21,
      "time_str": "01:40.210",
      "text": "如今一个人听歌总是会觉得失落",
      "translation": null
    },
    {
      "time": 104.728,
      "time_str": "01:44.728",
      "text": "幻听你在我的耳边轻轻诉说",
      "translation": null
    },
    {
      "time": 109.3,
      "time_str": "01:49.300",
      "text": "夜色多温柔",
      "translation": null
    },
    {
      "time": 111.8,
      "time_str": "01:51.800",
      "text": "你有多爱我",
      "translation": null
    },
    {
      "time": 116.288,
      "time_str": "01:56.288",
      "text": "如今一个人听歌总是会觉得难过",
      "translation": null
    },
    {
      "time": 121.219,
      "time_str": "02:01.219",
      "text": "爱已不在这里我却还没走脱",
      "translation": null
    },
    {
      "time": 124.899,
      "time_str": "02:04.899",
      "text": "列表里的歌",
      "translation": null
    },
    {
      "time": 128.0,
      "time_str": "02:08.000",
      "text": "随过往流动",
      "translation": null
    },
    {
