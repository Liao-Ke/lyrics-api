  "lyrics": [
    {
      "time": 16.925,
      "time_str": "00:16.925",
      "text": "抓不住爱情的我",
      "translation": null
    },
    {
      "time": 20.143,
      "time_str": "00:20.143",
      "text": "总是眼睁睁看它溜走",
      "translation": null
    },
    {
      "time": 24.66,
      "time_str": "00:24.660",
      "text": "世界上幸福的人到处有",
      "translation": null
    },
    {
      "time": 28.22,
      "time_str": "00:28.220",
      "text": "为何不能算我一个",
      "translation": null
    },
    {
      "time": 32.426,
      "time_str": "00:32.426",
      "text": "为了爱孤军奋斗",
      "translation": null
    },
    {
      "time": 35.566,
      "time_str": "00:35.566",
      "text": "早就吃够了爱情的苦",
      "translation": null
    },
    {
      "time": 40.17,
      "time_str": "00:40.170",
      "text": "在爱中失落的人到处有",
      "translation": null
    },
    {
      "time": 43.711,
      "time_str": "00:43.711",
      "text": "而我只是其中一个",
      "translation": null
    },
    {
      "time": 47.911,
      "time_str": "00:47.911",
      "text": "爱要越挫越勇",
      "translation": null
    },
    {
      "time": 51.787,
      "time_str": "00:51.787",
      "text": "爱要肯定执着",
      "translation": null
    },
    {
      "time": 55.672,
      "time_str": "00:55.672",
      "text": "每一个单身的人得看透",
      "translation": null
    },
    {
      "time": 59.154,
      "time_str": "00:59.154",
      "text": "想爱就别怕伤痛",
      "translation": null
    },
    {
      "time": 66.255,
      "time_str": "01:06.255",
      "text": "找一个最爱的 深爱的",
      "translation": null
    },
    {
      "time": 69.193,
      "time_str": "01:09.193",
      "text": "相爱的 亲爱的人",
      "translation": null
    },
    {
      "time": 71.77,
      "time_str": "01:11.770",
      "text": "来告别单身",
      "translation": null
    },
    {
      "time": 74.291,
      "time_str": "01:14.291",
      "text": "一个多情的 痴情的",
      "translation": null
    },
    {
      "time": 76.912,
      "time_str": "01:16.912",
      "text": "绝情的 无情的人",
      "translation": null
    },
    {
      "time": 79.481,
      "time_str": "01:19.481",
      "text": "来给我伤痕",
      "translation": null
    },
    {
      "time": 82.716,
      "time_str": "01:22.716",
      "text": "孤单的人那么多",
      "translation": null
    },
    {
      "time": 86.621,
      "time_str": "01:26.621",
      "text": "快乐的没有几个",
      "translation": null
    },
    {
      "time": 89.815,
      "time_str": "01:29.815",
      "text": "不要爱过了 错过了",
      "translation": null
    },
    {
      "time": 92.366,
      "time_str": "01:32.366",
      "text": "留下了单身的我",
