  "lyrics": [
    {
      "time": 40.27,
      "time_str": "00:40.270",
      "text": "梦不见皎皎的月光",
      "translation": null
    },
    {
      "time": 44.18,
      "time_str": "00:44.180",
      "text": "就像迷失眼睛 陷入荒城",
      "translation": null
    },
    {
      "time": 49.35,
      "time_str": "00:49.350",
      "text": "吻不到浓浓的花香",
      "translation": null
    },
    {
      "time": 52.88,
      "time_str": "00:52.880",
      "text": "就像丢了灵魂 寂寞丛生",
      "translation": null
    },
    {
      "time": 60.29,
      "time_str": "01:00.290",
      "text": "听不见哒哒马蹄声",
      "translation": null
    },
    {
      "time": 63.8,
      "time_str": "01:03.800",
      "text": "世界一片沉静 不见归程",
      "translation": null
    },
    {
      "time": 68.94,
      "time_str": "01:08.940",
      "text": "如果再不把我唤醒",
      "translation": null
    },
    {
      "time": 72.48,
      "time_str": "01:12.480",
      "text": "又要等待来生 天涯纵横",
      "translation": null
    },
    {
      "time": 79.6,
      "time_str": "01:19.600",
      "text": "我要策马奔腾 向你怀中",
      "translation": null
    },
    {
      "time": 83.38,
      "time_str": "01:23.380",
      "text": "解开思念的谜 千年的梦",
      "translation": null
    },
    {
      "time": 87.62,
      "time_str": "01:27.620",
      "text": "穿越茫茫云海 蓝天依旧",
      "translation": null
    },
    {
      "time": 92.7,
      "time_str": "01:32.700",
      "text": "马琴响起 心事瞬间消融",
      "translation": null
    },
    {
      "time": 96.41,
      "time_str": "01:36.410",
      "text": "我要策马奔腾 无尽苍穹",
      "translation": null
    },
    {
      "time": 100.8,
      "time_str": "01:40.800",
      "text": "卷落一路风雨 腾起彩虹",
      "translation": null
    },
    {
      "time": 105.19,
      "time_str": "01:45.190",
      "text": "漂泊在你心海 幸福依旧",
      "translation": null
    },
    {
      "time": 109.5,
      "time_str": "01:49.500",
      "text": "清风一缕 前世今生相逢",
      "translation": null
    },
    {
      "time": 114.75,
      "time_str": "01:54.750",
      "text": "RAP：豪饮几杯马奶酒",
      "translation": null
    },
    {
      "time": 116.55,
      "time_str": "01:56.550",
      "text": "难解千年的哀愁",
      "translation": null
    },
    {
      "time": 118.83,
      "time_str": "01:58.830",
      "text": "再唱几首情歌 寂寞你才会懂",
      "translation": null
    },
    {
      "time": 123.16,
      "time_str": "02:03.160",
      "text": "快乐洒满了山坡",
      "translation": null
    },
    {
      "time": 125.43,
      "time_str": "02:05.430",
      "text": "是羊还是那云朵",
      "translation": null
    },
    {
      "time": 127.51,
      "time_str": "02:07.510",
      "text": "从此不再放手 厮守茫茫的自由",
      "translation": null
    },
    {
      "time": 134.57,
      "time_str": "02:14.570",
      "text": "望不见暖暖的阳光",
      "translation": null
    },
    {
      "time": 137.98,
      "time_str": "02:17.980",
      "text": "你用万朵祥云 为我壮行",
      "translation": null
    },
    {
      "time": 142.85,
      "time_str": "02:22.850",
      "text": "闻不到鲜鲜的草香",
      "translation": null
    },
    {
      "time": 146.65,
      "time_str": "02:26.650",
      "text": "苍茫岁月荒草 也恨春风",
      "translation": null
    },
    {
      "time": 154.24,
      "time_str": "02:34.240",
      "text": "听不见悠悠的长调",
      "translation": null
    },
    {
      "time": 157.69,
      "time_str": "02:37.690",
      "text": "天地为谁辽阔 你为谁等",
      "translation": null
    },
    {
      "time": 162.1,
      "time_str": "02:42.100",
      "text": "如果你肯与我相拥",
      "translation": null
    },
    {
      "time": 166.3,
      "time_str": "02:46.300",
      "text": "纵有万座山峰 也要踏平",
      "translation": null
    },
    {
      "time": 172.9,
      "time_str": "02:52.900",
      "text": "我要策马奔腾 向你怀中",
      "translation": null
    },
    {
