    {
      "time": 3.7,
      "time_str": "00:03.700",
      "text": "弦乐编排 : 林邝培",
      "translation": null
    },
    {
      "time": 24.406,
      "time_str": "00:24.406",
      "text": "家驹：",
      "translation": null
    },
    {
      "time": 24.98,
      "time_str": "00:24.980",
      "text": "无法可修饰的一对手",
      "translation": null
    },
    {
      "time": 28.758,
      "time_str": "00:28.758",
      "text": "带出温暖永远在背后",
      "translation": null
    },
    {
      "time": 31.863,
      "time_str": "00:31.863",
      "text": "纵使啰嗦始终关注",
      "translation": null
    },
    {
      "time": 33.821,
      "time_str": "00:33.821",
      "text": "不懂珍惜太内疚",
      "translation": null
    },
    {
      "time": 36.677,
      "time_str": "00:36.677",
      "text": "家强：",
      "translation": null
    },
    {
      "time": 37.372,
      "time_str": "00:37.372",
      "text": "沉醉于音阶她不赞赏",
      "translation": null
    },
    {
      "time": 41.197,
      "time_str": "00:41.197",
      "text": "母亲的爱却永未退让",
      "translation": null
    },
    {
      "time": 44.312,
      "time_str": "00:44.312",
      "text": "决心冲开心中挣扎",
      "translation": null
    },
    {
      "time": 46.328,
      "time_str": "00:46.328",
      "text": "亲恩终可报答",
      "translation": null
    },
    {
      "time": 49.334,
      "time_str": "00:49.334",
      "text": "家驹：",
      "translation": null
    },
    {
      "time": 50.152,
      "time_str": "00:50.152",
      "text": "春风化雨暖透我的心",
      "translation": null
    },
    {
      "time": 53.244,
      "time_str": "00:53.244",
      "text": "一生眷顾无言地送赠",
      "translation": null
    },
    {
      "time": 57.939,
      "time_str": "00:57.939",
      "text": "是你多么温馨的目光",
      "translation": null
    },
    {
      "time": 61.412,
      "time_str": "01:01.412",
      "text": "教我坚毅望着前路",
      "translation": null
    },
    {
      "time": 64.543,
      "time_str": "01:04.543",
      "text": "叮嘱我跌倒不应放弃",
      "translation": null
    },
    {
      "time": 70.379,
      "time_str": "01:10.379",
      "text": "没法解释怎可报尽亲恩",
      "translation": null
    },
    {
      "time": 73.893,
      "time_str": "01:13.893",
      "text": "爱意宽大是无限",
      "translation": null
    },
    {
      "time": 76.995,
      "time_str": "01:16.995",
      "text": "请准我说声真的爱你",
      "translation": null
