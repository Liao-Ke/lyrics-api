    {
      "time": 15.51,
      "time_str": "00:15.510",
      "text": "还没好好的感受",
      "translation": null
    },
    {
      "time": 20.45,
      "time_str": "00:20.450",
      "text": "雪花绽放的气候",
      "translation": null
    },
    {
      "time": 24.77,
      "time_str": "00:24.770",
      "text": "我们一起颤抖会更明白",
      "translation": null
    },
    {
      "time": 30.1,
      "time_str": "00:30.100",
      "text": "什么是温柔",
      "translation": null
    },
    {
      "time": 33.35,
      "time_str": "00:33.350",
      "text": "还没跟你牵着手",
      "translation": null
    },
    {
      "time": 37.63,
      "time_str": "00:37.630",
      "text": "走过荒芜的沙丘",
      "translation": null
    },
    {
      "time": 41.91,
      "time_str": "00:41.910",
      "text": "可能从此以后学会珍惜",
      "translation": null
    },
    {
      "time": 47.34,
      "time_str": "00:47.340",
      "text": "天长和地久",
      "translation": null
    },
    {
      "time": 50.44,
      "time_str": "00:50.440",
      "text": "有时候有时候",
      "translation": null
    },
    {
      "time": 54.86,
      "time_str": "00:54.860",
      "text": "我会相信一切有尽头",
      "translation": null
    },
    {
      "time": 59.08,
      "time_str": "00:59.080",
      "text": "相聚离开都有时候",
      "translation": null
    },
    {
      "time": 63.4,
      "time_str": "01:03.400",
      "text": "没有什么会永垂不朽",
      "translation": null
    },
    {
      "time": 67.86,
      "time_str": "01:07.860",
      "text": "可是我有时候",
      "translation": null
    },
    {
      "time": 71.96,
      "time_str": "01:11.960",
      "text": "宁愿选择留恋不放手",
      "translation": null
    },
    {
      "time": 76.29,
      "time_str": "01:16.290",
      "text": "等到风景都看透",
      "translation": null
    },
    {
      "time": 80.51,
      "time_str": "01:20.510",
      "text": "也许你会",
      "translation": null
    },
    {
      "time": 82.18,
      "time_str": "01:22.180",
      "text": "陪我看细水长流",
      "translation": null
