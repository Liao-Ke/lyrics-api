  "lyrics": [
    {
      "time": 9.64,
      "time_str": "00:09.640",
      "text": "我要带你到处去飞翔",
      "translation": null
    },
    {
      "time": 15.85,
      "time_str": "00:15.850",
      "text": "走遍世界各地去观赏",
      "translation": null
    },
    {
      "time": 22.12,
      "time_str": "00:22.120",
      "text": "没有烦恼没有那悲伤",
      "translation": null
    },
    {
      "time": 28.14,
      "time_str": "00:28.140",
      "text": "自由自在身心多开朗",
      "translation": null
    },
    {
      "time": 34.48,
      "time_str": "00:34.480",
      "text": "忘掉痛苦忘掉那悲伤",
      "translation": null
    },
    {
      "time": 40.75,
      "time_str": "00:40.750",
      "text": "我们一起启程去流浪",
      "translation": null
    },
    {
      "time": 46.99,
      "time_str": "00:46.990",
      "text": "虽然没有华厦美衣裳",
      "translation": null
    },
    {
      "time": 53.47,
      "time_str": "00:53.470",
      "text": "但是心里充满著希望",
      "translation": null
    },
    {
      "time": 58.5,
      "time_str": "00:58.500",
      "text": "我们要飞到那遥远地方",
      "translation": null
    },
    {
      "time": 63.67,
      "time_str": "01:03.670",
      "text": "看一看这世界",
      "translation": null
    },
    {
      "time": 66.82,
      "time_str": "01:06.820",
      "text": "并非那么凄凉",
      "translation": null
    },
    {
      "time": 71.42,
      "time_str": "01:11.420",
      "text": "我们要飞到那遥远地方",
      "translation": null
    },
    {
      "time": 76.58,
      "time_str": "01:16.580",
      "text": "望一望",
      "translation": null
    },
    {
      "time": 78.17,
      "time_str": "01:18.170",
      "text": "这世界还是一片的光亮",
      "translation": null
    },
