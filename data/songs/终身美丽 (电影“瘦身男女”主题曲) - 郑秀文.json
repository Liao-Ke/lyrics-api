    {
      "time": 13.4,
      "time_str": "00:13.400",
      "text": "塔尖仍旧记得",
      "translation": null
    },
    {
      "time": 16.23,
      "time_str": "00:16.230",
      "text": "这拥抱极美好",
      "translation": null
    },
    {
      "time": 20.13,
      "time_str": "00:20.130",
      "text": "爱有千斤重",
      "translation": null
    },
    {
      "time": 23.31,
      "time_str": "00:23.310",
      "text": "重过无涯的铁路",
      "translation": null
    },
    {
      "time": 26.81,
      "time_str": "00:26.810",
      "text": "你那手指再笨拙再粗",
      "translation": null
    },
    {
      "time": 30.06,
      "time_str": "00:30.060",
      "text": "肌肤也被你修补",
      "translation": null
    },
    {
      "time": 33.85,
      "time_str": "00:33.850",
      "text": "从前那一位",
      "translation": null
    },
    {
      "time": 37.2,
      "time_str": "00:37.200",
      "text": "永未能做到",
      "translation": null
    },
    {
      "time": 40.92,
      "time_str": "00:40.920",
      "text": "是你去唤醒我",
      "translation": null
    },
    {
      "time": 44.24,
      "time_str": "00:44.240",
      "text": "努力才能被爱慕",
      "translation": null
    },
    {
      "time": 47.88,
      "time_str": "00:47.880",
      "text": "但回头目睹你",
      "translation": null
    },
    {
      "time": 51.23,
      "time_str": "00:51.230",
      "text": "为我好自己不好",
      "translation": null
    },
    {
      "time": 54.66,
      "time_str": "00:54.660",
      "text": "我这幸运儿合着眼睛",
      "translation": null
    },
    {
      "time": 57.88,
      "time_str": "00:57.880",
      "text": "只得你沉重身影",
      "translation": null
    },
    {
      "time": 61.8,
      "time_str": "01:01.800",
      "text": "如果这记忆非爱情",
      "translation": null
    },
    {
      "time": 65.39,
      "time_str": "01:05.390",
      "text": "连天都不会太高兴",
      "translation": null
    },
    {
      "time": 68.76,
      "time_str": "01:08.760",
      "text": "莫非可终身美丽",
      "translation": null
    },
    {
      "time": 71.72,
      "time_str": "01:11.720",
      "text": "才值得勾勾手指发誓",
