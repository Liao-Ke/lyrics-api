    },
    {
      "time": 75.41,
      "time_str": "01:15.410",
      "text": "对你不止感激敬礼",
      "translation": null
    },
    {
      "time": 78.88,
      "time_str": "01:18.880",
      "text": "当你知己才是虚伪",
