    },
    {
      "time": 82.58,
      "time_str": "01:22.580",
      "text": "莫非多一分秀丽",
      "translation": null
    },
    {
      "time": 85.51,
      "time_str": "01:25.510",
      "text": "才值得分享我的一切",
      "translation": null
    },
    {
      "time": 89.2,
      "time_str": "01:29.200",
      "text": "给我自信给我地位",
      "translation": null
    },
    {
      "time": 92.71,
      "time_str": "01:32.710",
      "text": "这叫幸福不怕流逝",
      "translation": null
    },
    {
      "time": 96.29,
      "time_str": "01:36.290",
      "text": "任他们多漂亮",
      "translation": null
    },
    {
      "time": 99.35,
      "time_str": "01:39.350",
      "text": "未及你矜贵",
      "translation": null
    },
    {
      "time": 112.87,
      "time_str": "01:52.870",
      "text": "记忆无论再轻",
