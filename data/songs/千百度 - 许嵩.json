  "lyrics": [
    {
      "time": 37.6,
      "time_str": "00:37.600",
      "text": "关外野店 烟火绝 客怎眠",
      "translation": null
    },
    {
      "time": 42.78,
      "time_str": "00:42.780",
      "text": "寒来袖间 谁为我 添两件",
      "translation": null
    },
    {
      "time": 48.52,
      "time_str": "00:48.520",
      "text": "三四更雪 风不减 吹袭一夜",
      "translation": null
    },
    {
      "time": 54.07,
      "time_str": "00:54.070",
      "text": "只是可怜 瘦马未得好歇",
      "translation": null
    },
    {
      "time": 59.82,
      "time_str": "00:59.820",
      "text": "怅然入梦 梦几月 醒几年",
      "translation": null
    },
    {
      "time": 65.31,
      "time_str": "01:05.310",
      "text": "往事凄艳 用情浅 两手缘",
      "translation": null
    },
    {
      "time": 70.8,
      "time_str": "01:10.800",
      "text": "鹧鸪清怨 听得见 飞不回堂前",
      "translation": null
    },
    {
      "time": 77.3,
      "time_str": "01:17.300",
      "text": "旧楹联红褪墨残谁来揭",
      "translation": null
    },
    {
      "time": 84.91,
      "time_str": "01:24.910",
      "text": "我寻你千百度 日出到迟暮",
      "translation": null
    },
    {
      "time": 90.84,
      "time_str": "01:30.840",
      "text": "一瓢江湖我沉浮",
      "translation": null
    },
    {
      "time": 95.89,
      "time_str": "01:35.890",
      "text": "我寻你千百度 又一岁荣枯",
      "translation": null
    },
    {
      "time": 102.53,
      "time_str": "01:42.530",
      "text": "可你从不在 灯火阑珊处",
      "translation": null
    },
    {
