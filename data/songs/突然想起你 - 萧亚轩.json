    {
      "time": 11.19,
      "time_str": "00:11.190",
      "text": "都是因为那灯泡",
      "translation": null
    },
    {
      "time": 16.03,
      "time_str": "00:16.030",
      "text": "突然闪了一下",
      "translation": null
    },
    {
      "time": 18.82,
      "time_str": "00:18.820",
      "text": "于是想起你",
      "translation": null
    },
    {
      "time": 22.31,
      "time_str": "00:22.310",
      "text": "怕你 还没休息",
      "translation": null
    },
    {
      "time": 30.91,
      "time_str": "00:30.910",
      "text": "都是因为这场雨",
      "translation": null
    },
    {
