      "time_str": "00:35.620",
      "text": "忽然间下的那么大",
      "translation": null
    },
    {
      "time": 38.68,
      "time_str": "00:38.680",
      "text": "怕来不及",
      "translation": null
    },
    {
      "time": 42.06,
      "time_str": "00:42.060",
      "text": "跟你 走在一起",
      "translation": null
    },
    {
      "time": 48.7,
      "time_str": "00:48.700",
      "text": "一个人的夜 我的心",
      "translation": null
    },
    {
      "time": 51.93,
      "time_str": "00:51.930",
      "text": "应该放在哪里",
      "translation": null
    },
    {
      "time": 54.09,
      "time_str": "00:54.090",
      "text": "拥抱过后",
      "translation": null
    },
    {
      "time": 55.64,
      "time_str": "00:55.640",
      "text": "我的双手 应该放在哪里",
      "translation": null
    },
    {
      "time": 59.01,
      "time_str": "00:59.010",
      "text": "我始终学不会控制",
      "translation": null
    },
    {
