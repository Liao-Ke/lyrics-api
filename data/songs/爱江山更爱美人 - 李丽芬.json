    {
      "time": 0.71,
      "time_str": "00:00.710",
      "text": "爱江山更爱美人 (1994年台视版电视剧《倚天屠龙记》片尾曲) - 李丽芬 (Lily Lee)",
      "translation": null
    },
    {
      "time": 8.0,
      "time_str": "00:08.000",
      "text": "专辑：李丽芬的东西(爱不释手)",
      "translation": null
    },
    {
      "time": 32.27,
      "time_str": "00:32.270",
      "text": "道不尽红尘奢恋",
      "translation": null
    },
    {
      "time": 35.2,
      "time_str": "00:35.200",
      "text": "诉不完人间恩怨",
      "translation": null
    },
    {
      "time": 38.1,
      "time_str": "00:38.100",
      "text": "世世代代都是缘",
      "translation": null
    },
    {
      "time": 44.36,
      "time_str": "00:44.360",
      "text": "流着相同的血",
      "translation": null
    },
    {
      "time": 47.29,
      "time_str": "00:47.290",
      "text": "喝着相同的水",
      "translation": null
    },
    {
      "time": 51.04,
      "time_str": "00:51.040",
      "text": "这条路漫漫又长远",
      "translation": null
    },
    {
      "time": 56.45,
      "time_str": "00:56.450",
      "text": "红花当然配绿叶",
      "translation": null
    },
    {
      "time": 59.43,
      "time_str": "00:59.430",
      "text": "这一辈子谁来陪",
      "translation": null
    },
    {
      "time": 63.27,
      "time_str": "01:03.270",
      "text": "渺渺茫茫来又回",
      "translation": null
    },
    {
      "time": 68.58,
      "time_str": "01:08.580",
      "text": "往日情景再浮现",
      "translation": null
    },
    {
      "time": 71.62,
      "time_str": "01:11.620",
      "text": "藕虽断了丝还连",
      "translation": null
    },
    {
      "time": 75.26,
      "time_str": "01:15.260",
      "text": "轻叹世间事多变迁",
