  "lyrics": [
    {
      "time": 26.2,
      "time_str": "00:26.200",
      "text": "尘封在星蕴重明的魂魄",
      "translation": null
    },
    {
      "time": 32.35,
      "time_str": "00:32.350",
      "text": "叫醒了恍惚梦魇的无措",
      "translation": null
    },
    {
      "time": 38.44,
      "time_str": "00:38.440",
      "text": "揭开这宿命的脉络",
      "translation": null
    },
    {
      "time": 44.23,
      "time_str": "00:44.230",
      "text": "逃不开这一世的寂寞",
      "translation": null
    },
    {
      "time": 50.12,
      "time_str": "00:50.120",
      "text": "往后是阴霾",
      "translation": null
    },
    {
      "time": 51.74,
      "time_str": "00:51.740",
      "text": "往前是山隘",
      "translation": null
    },
    {
      "time": 53.27,
      "time_str": "00:53.270",
      "text": "想逃也逃不开",
      "translation": null
    },
    {
      "time": 56.25,
      "time_str": "00:56.250",
      "text": "命运再主宰",
      "translation": null
    },
    {
      "time": 57.78,
      "time_str": "00:57.780",
      "text": "执着的心也不会更改",
      "translation": null
    },
    {
      "time": 62.29,
      "time_str": "01:02.290",
      "text": "哪管桑田",
      "translation": null
    },
    {
      "time": 64.66,
      "time_str": "01:04.660",
      "text": "哪管沧海",
      "translation": null
    },
    {
      "time": 71.68,
      "time_str": "01:11.680",
      "text": "听琴声潇潇",
      "translation": null
    },
    {
      "time": 74.64,
      "time_str": "01:14.640",
      "text": "该忘的忘不掉",
      "translation": null
    },
    {
      "time": 77.67,
      "time_str": "01:17.670",
      "text": "红尘困住我年少",
      "translation": null
    },
    {
      "time": 83.99,
      "time_str": "01:23.990",
      "text": "原谅我藏在心里燎燎的狂傲",
      "translation": null
    },
    {
      "time": 90.1,
      "time_str": "01:30.100",
      "text": "去战面对天地荡浩",
      "translation": null
    },
    {
      "time": 96.31,
      "time_str": "01:36.310",
      "text": "人生也潇潇",
      "translation": null
    },
    {
      "time": 98.04,
      "time_str": "01:38.040",
      "text": "魂牵梦绕",
      "translation": null
    },
    {
      "time": 99.55,
      "time_str": "01:39.550",
      "text": "像烈焰燃烧",
      "translation": null
    },
    {
      "time": 102.31,
      "time_str": "01:42.310",
      "text": "前尘看浮沉走一遭",
      "translation": null
    },
    {
      "time": 108.62,
      "time_str": "01:48.620",
      "text": "用冷的锋刃琴的寂寥",
      "translation": null
    },
    {
      "time": 111.79,
      "time_str": "01:51.790",
      "text": "写往事今朝",
      "translation": null
    },
    {
      "time": 114.63,
      "time_str": "01:54.630",
      "text": "孤剑指尖谈笑",
      "translation": null
    },
    {
      "time": 134.01,
      "time_str": "02:14.010",
      "text": "人心间有没有一种解药",
      "translation": null
    },
    {
      "time": 140.12,
      "time_str": "02:20.120",
      "text": "能覆盖是非恩仇的喧嚣",
      "translation": null
    },
    {
      "time": 146.21,
      "time_str": "02:26.210",
      "text": "屠俘了焚寂的剑鞘",
      "translation": null
    },
    {
      "time": 151.92,
      "time_str": "02:31.920",
      "text": "斩不断这一生的桀骜",
      "translation": null
    },
    {
