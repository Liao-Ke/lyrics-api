  },
  "lyrics": [
    {
      "time": 20.35,
      "time_str": "00:20.350",
      "text": "我跟人群逆向 在街上",
      "translation": null
    },
    {
      "time": 23.09,
      "time_str": "00:23.090",
      "text": "从道路的两旁 转小巷",
      "translation": null
    },
    {
      "time": 25.65,
      "time_str": "00:25.650",
      "text": "在一栋被废弃的工厂墙上",
      "translation": null
    },
    {
      "time": 28.52,
      "time_str": "00:28.520",
      "text": "Oh 涂鸦小时候单纯的愿望",
      "translation": null
    },
    {
      "time": 31.03,
      "time_str": "00:31.030",
      "text": "穿白纱 当新娘",
      "translation": null
    },
    {
      "time": 37.21,
      "time_str": "00:37.210",
      "text": "Hey 我又绕到广场 看一看",
      "translation": null
    },
    {
      "time": 40.08,
      "time_str": "00:40.080",
      "text": "闹区的电视墙 在歌唱",
      "translation": null
    },
    {
      "time": 42.76,
      "time_str": "00:42.760",
      "text": "歌词内容跟我的心情很像",
      "translation": null
    },
    {
      "time": 45.54,
      "time_str": "00:45.540",
      "text": "Oh 我一个人站在红绿灯前",
      "translation": null
    },
    {
      "time": 48.13,
      "time_str": "00:48.130",
      "text": "看天上 看天上",
      "translation": null
    },
    {
      "time": 60.08,
      "time_str": "01:00.080",
      "text": "我继续在街上 晃一晃",
      "translation": null
    },
    {
      "time": 62.94,
      "time_str": "01:02.940",
      "text": "花店的落地窗 很漂亮",
      "translation": null
    },
    {
      "time": 65.49,
      "time_str": "01:05.490",
      "text": "确定了感情应该走的方向",
      "translation": null
    },
    {
      "time": 68.27,
      "time_str": "01:08.270",
      "text": "爱可以是一种习惯 单纯的喜欢",
      "translation": null
    },
    {
      "time": 73.05,
      "time_str": "01:13.050",
      "text": "对爱恨欣赏 直来直往",
      "translation": null
    },
    {
      "time": 83.33,
      "time_str": "01:23.330",
      "text": "有一种勇敢 叫做原谅",
      "translation": null
    },
    {
      "time": 94.67,
      "time_str": "01:34.670",
      "text": "在回家的路上 想一想",
      "translation": null
    },
    {
      "time": 97.37,
      "time_str": "01:37.370",
      "text": "爱如果变难堪 就要放",
      "translation": null
    },
    {
      "time": 99.97,
      "time_str": "01:39.970",
      "text": "感情的事没有标准的答案",
      "translation": null
    },
    {
      "time": 102.74,
      "time_str": "01:42.740",
      "text": "但欠人家的 你一定就得还",
      "translation": null
    },
    {
      "time": 106.81,
      "time_str": "01:46.810",
      "text": "注意 踩到狗尾巴 就像触电一样",
      "translation": null
    },
    {
      "time": 110.0,
      "time_str": "01:50.000",
      "text": "千万别攻击别人最脆弱的地方",
      "translation": null
    },
    {
      "time": 112.65,
      "time_str": "01:52.650",
      "text": "在餐厅打破玻璃杯 也别慌张",
      "translation": null
    },
    {
      "time": 115.57,
      "time_str": "01:55.570",
      "text": "碎碎平安保持仪态 准备付帐",
      "translation": null
    },
    {
      "time": 118.39,
      "time_str": "01:58.390",
      "text": "就算看到恐怖画面 先故作坚强",
      "translation": null
    },
    {
      "time": 121.41,
      "time_str": "02:01.410",
      "text": "嘴唇发紫 脸色发青 干脆扑到你肩膀",
      "translation": null
    },
    {
      "time": 124.26,
      "time_str": "02:04.260",
      "text": "看电影 感动就哭 好笑就笑 以免得内伤",
      "translation": null
    },
    {
      "time": 128.28,
      "time_str": "02:08.280",
      "text": "如果男朋友 偷瞄辣妹 流口水",
      "translation": null
    },
    {
      "time": 131.47,
      "time_str": "02:11.470",
      "text": "揍他几拳 捏他一把 问他懂不懂欣赏",
      "translation": null
    },
    {
      "time": 137.65,
      "time_str": "02:17.650",
      "text": "对爱恨欣赏 直来直往",
      "translation": null
    },
    {
      "time": 148.92,
      "time_str": "02:28.920",
      "text": "有一种勇敢 叫做原谅",
      "translation": null
    },
    {
      "time": 159.38,
      "time_str": "02:39.380",
      "text": "我还在 跟人群逆向 在街上",
      "translation": null
    },
    {
      "time": 163.89,
      "time_str": "02:43.890",
      "text": "从道路的两旁 转小巷",
      "translation": null
    },
    {
      "time": 166.36,
      "time_str": "02:46.360",
      "text": "在一栋被废弃的工厂墙上",
      "translation": null
    },
    {
      "time": 169.21,
      "time_str": "02:49.210",
      "text": "Oh 涂鸦我对你的种种不满",
      "translation": null
    },
    {
      "time": 171.8,
      "time_str": "02:51.800",
      "text": "你自己 看着办",
      "translation": null
    },
    {
      "time": 177.91,
      "time_str": "02:57.910",
      "text": "Hey 我又绕到广场 看一看",
      "translation": null
    },
    {
      "time": 180.9,
      "time_str": "03:00.900",
      "text": "闹区的电视墙 在歌唱",
      "translation": null
    },
    {
      "time": 183.64,
      "time_str": "03:03.640",
      "text": "歌词内容跟我的心情很像",
      "translation": null
    },
    {
      "time": 186.39,
      "time_str": "03:06.390",
      "text": "Oh 我一个人站在红绿灯前 看天上",
      "translation": null
    },
    {
      "time": 194.16,
      "time_str": "03:14.160",
      "text": "我看天上 看天上",
      "translation": null
    },
    {
      "time": 205.07,
      "time_str": "03:25.070",
      "text": "来来来来一起看天上",
      "translation": null
    }
