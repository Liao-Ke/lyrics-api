    {
      "time": 35.04,
      "time_str": "00:35.040",
      "text": "那是一个秋天",
      "translation": null
    },
    {
      "time": 38.54,
      "time_str": "00:38.540",
      "text": "风儿那么缠绵",
      "translation": null
    },
    {
      "time": 42.14,
      "time_str": "00:42.140",
      "text": "让我想起他们",
      "translation": null
    },
    {
      "time": 45.6,
      "time_str": "00:45.600",
      "text": "那双无助的眼",
      "translation": null
    },
    {
      "time": 48.89,
      "time_str": "00:48.890",
      "text": "就在那美丽风景相伴的地方",
      "translation": null
    },
    {
      "time": 55.78,
      "time_str": "00:55.780",
      "text": "我听到一声巨响震彻山谷",
      "translation": null
    },
    {
      "time": 63.31,
      "time_str": "01:03.310",
      "text": "就是那个秋天",
      "translation": null
    },
    {
      "time": 65.8,
      "time_str": "01:05.800",
      "text": "再看不到爸爸的脸",
      "translation": null
    },
    {
      "time": 70.28,
      "time_str": "01:10.280",
      "text": "他用他的双肩",
      "translation": null
    },
    {
      "time": 72.96,
      "time_str": "01:12.960",
      "text": "托起我重生的起点",
      "translation": null
    },
    {
      "time": 76.99,
      "time_str": "01:16.990",
      "text": "黑暗中泪水沾满了双眼",
      "translation": null
    },
    {
      "time": 84.34,
      "time_str": "01:24.340",
      "text": "不要离开不要伤害",
      "translation": null
    },
    {
      "time": 91.21,
      "time_str": "01:31.210",
      "text": "我看到爸爸妈妈就这么走远",
      "translation": null
    },
    {
      "time": 94.9,
      "time_str": "01:34.900",
      "text": "留下我在这陌生的人世间",
      "translation": null
    },
    {
      "time": 98.45,
      "time_str": "01:38.450",
      "text": "不知道未来还会有什么风险",
      "translation": null
    },
    {
      "time": 105.38,
      "time_str": "01:45.380",
      "text": "我想要紧紧抓住他的手",
      "translation": null
    },
    {
      "time": 109.18,
      "time_str": "01:49.180",
      "text": "妈妈告诉我希望还会有",
      "translation": null
    },
    {
      "time": 112.71,
      "time_str": "01:52.710",
      "text": "看到太阳出来妈妈笑了",
      "translation": null
    },
    {
      "time": 120.08,
      "time_str": "02:00.080",
      "text": "天亮了",
      "translation": null
    },
    {
      "time": 153.16,
