    "arranger": "Martin Tang"
  },
  "lyrics": [
    {
      "time": 21.45,
      "time_str": "00:21.450",
      "text": "摇晃的红酒杯 嘴唇像染着鲜血",
      "translation": null
    },
    {
      "time": 25.48,
      "time_str": "00:25.480",
      "text": "那不寻常的美 难赦免的罪",
      "translation": null
    },
    {
      "time": 29.28,
      "time_str": "00:29.280",
      "text": "谁忠心的跟随 充其量当个侍卫",
      "translation": null
    },
    {
      "time": 33.0,
      "time_str": "00:33.000",
      "text": "脚下踩着玫瑰 回敬一个吻当安慰",
      "translation": null
    },
    {
      "time": 41.2,
      "time_str": "00:41.200",
      "text": "可怜",
      "translation": null
    },
    {
      "time": 44.31,
      "time_str": "00:44.310",
      "text": "像蠢动的音乐 教人们怎么成眠",
      "translation": null
    },
    {
      "time": 47.94,
      "time_str": "00:47.940",
      "text": "不知名的香水 窒息的鬼魅",
      "translation": null
    },
    {
      "time": 51.78,
      "time_str": "00:51.780",
      "text": "锋利的高跟鞋 让多少心肠破碎",
      "translation": null
    },
    {
      "time": 55.58,
      "time_str": "00:55.580",
      "text": "弯刀一般的眉 捍卫你的秘密花园",
      "translation": null
    },
    {
      "time": 61.12,
      "time_str": "01:01.120",
      "text": "夜太美 尽管再危险",
      "translation": null
    },
    {
      "time": 64.57,
      "time_str": "01:04.570",
      "text": "总有人黑着眼眶 熬着夜",
      "translation": null
    },
    {
      "time": 68.3,
      "time_str": "01:08.300",
      "text": "爱太美 尽管再危险",
      "translation": null
    },
    {
      "time": 72.12,
      "time_str": "01:12.120",
      "text": "愿赔上了一切 超支千年的泪",
      "translation": null
    },
    {
      "time": 76.05,
      "time_str": "01:16.050",
      "text": "痛太美 尽管再卑微",
      "translation": null
    },
    {
      "time": 79.73,
      "time_str": "01:19.730",
      "text": "也想尝粉身碎骨的滋味",
      "translation": null
    },
    {
      "time": 83.42,
      "time_str": "01:23.420",
      "text": "你太美 尽管再无言",
      "translation": null
    },
    {
      "time": 87.27,
      "time_str": "01:27.270",
      "text": "我都想用石堆隔绝世界",
      "translation": null
    },
    {
      "time": 90.19,
      "time_str": "01:30.190",
      "text": "我的王妃 我要霸占你的美",
      "translation": null
    },
    {
      "time": 100.95,
      "time_str": "01:40.950",
      "text": "那催情的音乐 听起来多么愚昧",
      "translation": null
    },
    {
      "time": 104.79,
      "time_str": "01:44.790",
      "text": "你武装的防备 伤你的是谁",
      "translation": null
    },
    {
      "time": 108.67,
      "time_str": "01:48.670",
      "text": "靠近我一点点 是不一样的世界",
      "translation": null
    },
    {
      "time": 112.28,
      "time_str": "01:52.280",
      "text": "安睡在我的肩 我用生命为你加冕",
      "translation": null
    },
    {
      "time": 117.9,
      "time_str": "01:57.900",
      "text": "夜太美 尽管再危险",
