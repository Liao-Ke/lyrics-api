  "lyrics": [
    {
      "time": 37.95,
      "time_str": "00:37.950",
      "text": "前提是能控制我的思念",
      "translation": null
    },
    {
      "time": 44.76,
      "time_str": "00:44.760",
      "text": "能如我所愿",
      "translation": null
    },
    {
      "time": 52.98,
      "time_str": "00:52.980",
      "text": "我才会兑现放下的誓言",
      "translation": null
    },
    {
      "time": 60.72,
      "time_str": "01:00.720",
      "text": "淡出热闹的画面",
      "translation": null
    },
    {
      "time": 68.25,
      "time_str": "01:08.250",
      "text": "几百遍重复上演",
      "translation": null
    },
    {
      "time": 75.72,
      "time_str": "01:15.720",
      "text": "太厌倦一切都败给时间",
      "translation": null
    },
    {
      "time": 81.93,
      "time_str": "01:21.930",
      "text": "你说未来在眼前但你也没实现",
      "translation": null
    },
    {
      "time": 92.04,
      "time_str": "01:32.040",
      "text": "说永远太遥远盼望永不变",
      "translation": null
    },
    {
      "time": 100.8,
      "time_str": "01:40.800",
      "text": "我把真实那面藏在句点",
      "translation": null
    },
    {
      "time": 107.01,
      "time_str": "01:47.010",
      "text": "说永远太遥远到底多少年",
      "translation": null
    },
    {
      "time": 115.86,
      "time_str": "01:55.860",
      "text": "我也划不清我们的界限",
      "translation": null
    },
    {
      "time": 143.22,
      "time_str": "02:23.220",
      "text": "言辞间反复遮掩",
      "translation": null
    },
    {
      "time": 150.78,
      "time_str": "02:30.780",
      "text": "连亏欠措辞都说的敷衍",
      "translation": null
    },
    {
      "time": 156.9,
      "time_str": "02:36.900",
      "text": "你说的永远到底怎样才算永远",
