    {
      "time": 4.0,
      "time_str": "00:04.000",
      "text": "弦乐编写 : 钟兴民",
      "translation": null
    },
    {
      "time": 13.0,
      "time_str": "00:13.000",
      "text": "中提琴 : 颜琬蕙",
      "translation": null
    },
    {
      "time": 14.0,
      "time_str": "00:14.000",
      "text": "大提琴 : 罗月廷",
      "translation": null
    },
    {
      "time": 20.4,
      "time_str": "00:20.400",
      "text": "你的回话凌乱着 在这个时刻",
      "translation": null
    },
    {
      "time": 29.639,
      "time_str": "00:29.639",
      "text": "我想起喷泉旁的白鸽 甜蜜散落了",
      "translation": null
    },
    {
      "time": 37.99,
      "time_str": "00:37.990",
      "text": "情绪莫名的拉扯 我还爱你呢",
      "translation": null
    },
    {
      "time": 45.949,
      "time_str": "00:45.949",
      "text": "而你断断续续唱着歌 假装没事了",
      "translation": null
    },
    {
      "time": 53.609,
      "time_str": "00:53.609",
      "text": "时间过了 走了 爱情面临选择",
      "translation": null
    },
    {
      "time": 58.899,
      "time_str": "00:58.899",
      "text": "你冷了 倦了 我哭了",
      "translation": null
    },
    {
      "time": 62.549,
      "time_str": "01:02.549",
      "text": "离开时的不快乐 你用卡片手写着",
      "translation": null
    },
    {
      "time": 65.989,
      "time_str": "01:05.989",
      "text": "有些爱只给到这 真的痛了",
      "translation": null
    },
    {
      "time": 72.489,
      "time_str": "01:12.489",
      "text": "怎么了 你累了说好的 幸福呢",
      "translation": null
    },
    {
      "time": 75.669,
      "time_str": "01:15.669",
      "text": "我懂了 不说了 爱淡了 梦远了",
      "translation": null
    },
    {
      "time": 80.399,
      "time_str": "01:20.399",
      "text": "开心与不开心一一细数着你再不舍",
      "translation": null
    },
    {
      "time": 84.429,
      "time_str": "01:24.429",
      "text": "那些爱过的感觉都太深刻 我都还记得",
      "translation": null
    },
    {
      "time": 88.449,
      "time_str": "01:28.449",
      "text": "你不等了 说好的 幸福呢",
      "translation": null
    },
    {
      "time": 93.019,
      "time_str": "01:33.019",
      "text": "我错了 泪干了 放手了 后悔了",
      "translation": null
    },
    {
      "time": 96.999,
      "time_str": "01:36.999",
      "text": "只是回忆的音乐盒还旋转着 要怎么停呢",
      "translation": null
    },
    {
