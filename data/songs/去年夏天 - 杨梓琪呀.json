  "lyrics": [
    {
      "time": 17.61,
      "time_str": "00:17.610",
      "text": "还有什么等待还有什么悲哀",
      "translation": null
    },
    {
      "time": 21.41,
      "time_str": "00:21.410",
      "text": "这故事中的人不太精彩",
      "translation": null
    },
    {
      "time": 25.42,
      "time_str": "00:25.420",
      "text": "夏去了又回来而人却已不在",
      "translation": null
    },
    {
      "time": 29.16,
      "time_str": "00:29.160",
      "text": "它重复着我汹涌的忍耐",
      "translation": null
    },
    {
      "time": 32.98,
      "time_str": "00:32.980",
      "text": "今年兰花又开开了它也会败",
      "translation": null
    },
    {
      "time": 36.96,
      "time_str": "00:36.960",
      "text": "我想要一个人活得精彩",
      "translation": null
    },
    {
      "time": 40.79,
      "time_str": "00:40.790",
      "text": "有些人总会来",
      "translation": null
    },
    {
      "time": 42.62,
      "time_str": "00:42.620",
      "text": "有些人在我心中在徘徊",
      "translation": null
    },
    {
      "time": 48.42,
      "time_str": "00:48.420",
      "text": "我拿了总会还你拿了就逃开",
      "translation": null
    },
    {
      "time": 52.42,
      "time_str": "00:52.420",
      "text": "在失去中我慢慢的变呆",
      "translation": null
    },
    {
      "time": 56.36,
      "time_str": "00:56.360",
      "text": "是不同步的未来",
      "translation": null
    },
    {
      "time": 60.03,
      "time_str": "01:00.030",
      "text": "却把书包中的日记更改",
      "translation": null
    },
    {
      "time": 63.95,
      "time_str": "01:03.950",
      "text": "把虚伪的尘埃也全部都掩盖",
      "translation": null
    },
    {
      "time": 67.95,
      "time_str": "01:07.950",
      "text": "把每次心痛都当成活该",
      "translation": null
    },
    {
      "time": 71.92,
      "time_str": "01:11.920",
      "text": "把心慢慢的释怀",
      "translation": null
    },
    {
      "time": 75.45,
      "time_str": "01:15.450",
      "text": "我相信总有一天你会明白",
      "translation": null
    },
    {
      "time": 79.52,
      "time_str": "01:19.520",
      "text": "我给你的爱",
      "translation": null
    },
    {
      "time": 81.26,
      "time_str": "01:21.260",
      "text": "我给你的爱",
      "translation": null
