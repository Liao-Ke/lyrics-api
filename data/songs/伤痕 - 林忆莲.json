  "lyrics": [
    {
      "time": 22.97,
      "time_str": "00:22.970",
      "text": "夜已深 还有什么人",
      "translation": null
    },
    {
      "time": 28.15,
      "time_str": "00:28.150",
      "text": "让你这样醒着数伤痕",
      "translation": null
    },
    {
      "time": 32.839,
      "time_str": "00:32.839",
      "text": "为何临睡前会想要留一盏灯",
      "translation": null
    },
    {
      "time": 37.869,
      "time_str": "00:37.869",
      "text": "你若不肯说 我就不问",
      "translation": null
    },
    {
      "time": 42.859,
      "time_str": "00:42.859",
      "text": "只是你现在不得不承认",
      "translation": null
    },
    {
      "time": 48.339,
      "time_str": "00:48.339",
      "text": "爱情有时候是一种沉沦",
      "translation": null
    },
    {
      "time": 53.019,
      "time_str": "00:53.019",
      "text": "让人失望的虽然是恋情本身",
      "translation": null
    },
    {
      "time": 57.969,
      "time_str": "00:57.969",
      "text": "但是不要只是因为你是女人",
      "translation": null
    },
    {
      "time": 63.459,
      "time_str": "01:03.459",
      "text": "若爱得深会不能平衡",
      "translation": null
    },
    {
      "time": 68.389,
      "time_str": "01:08.389",
      "text": "为情困 磨折了灵魂",
      "translation": null
    },
    {
      "time": 74.339,
      "time_str": "01:14.339",
      "text": "该爱就爱 该恨的就恨",
      "translation": null
    },
    {
      "time": 79.289,
      "time_str": "01:19.289",
      "text": "要为自己保留几分",
      "translation": null
    },
    {
      "time": 83.259,
      "time_str": "01:23.259",
      "text": "女人独有的天真和温柔的天分",
      "translation": null
    },
    {
      "time": 90.139,
      "time_str": "01:30.139",
      "text": "要留给真爱你的人",
      "translation": null
    },
    {
      "time": 94.129,
      "time_str": "01:34.129",
      "text": "不管未来多苦多难 有他陪你完成",
      "translation": null
    },
    {
      "time": 103.329,
      "time_str": "01:43.329",
      "text": "虽然爱是种责任 给要给得完整",
      "translation": null
    },
    {
      "time": 109.969,
      "time_str": "01:49.969",
      "text": "有时爱美在无法永恆",
      "translation": null
    },
    {
      "time": 114.229,
      "time_str": "01:54.229",
      "text": "爱有多销魂 就有多伤人",
      "translation": null
    },
    {
      "time": 119.579,
      "time_str": "01:59.579",
      "text": "你若勇敢爱了 就要勇敢分",
      "translation": null
    },
