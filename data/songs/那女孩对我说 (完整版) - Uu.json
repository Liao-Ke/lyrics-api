    {
      "time": 0.43,
      "time_str": "00:00.430",
      "text": "那女孩对我说",
      "translation": null
    },
    {
      "time": 2.51,
      "time_str": "00:02.510",
      "text": "说我保护她的梦",
      "translation": null
    },
    {
      "time": 5.94,
      "time_str": "00:05.940",
      "text": "说这个世界",
      "translation": null
    },
    {
      "time": 8.42,
      "time_str": "00:08.420",
      "text": "对她这样的不多",
      "translation": null
    },
    {
      "time": 25.86,
      "time_str": "00:25.860",
      "text": "心很空 天很大 云很重",
      "translation": null
    },
    {
      "time": 30.89,
      "time_str": "00:30.890",
      "text": "我恨孤单 却赶不走",
      "translation": null
    },
    {
      "time": 38.16,
      "time_str": "00:38.160",
      "text": "捧着她的名字",
      "translation": null
    },
    {
      "time": 40.92,
      "time_str": "00:40.920",
      "text": "她的喜怒哀乐",
      "translation": null
    },
    {
      "time": 44.52,
      "time_str": "00:44.520",
      "text": "往前走 多久了",
      "translation": null
    },
    {
      "time": 50.7,
      "time_str": "00:50.700",
      "text": "一个人心中",
      "translation": null
    },
    {
      "time": 52.74,
      "time_str": "00:52.740",
      "text": "只有一个宝贝",
      "translation": null
    },
    {
      "time": 55.42,
      "time_str": "00:55.420",
      "text": "久了之后",
      "translation": null
    },
    {
      "time": 57.36,
      "time_str": "00:57.360",
      "text": "她变成了眼泪",
      "translation": null
    },
    {
      "time": 62.78,
      "time_str": "01:02.780",
      "text": "泪一滴在左手",
      "translation": null
    },
    {
      "time": 65.67,
      "time_str": "01:05.670",
      "text": "凝固成为寂寞",
      "translation": null
    },
    {
      "time": 68.659,
      "time_str": "01:08.659",
      "text": "往回看 有什么",
      "translation": null
    },
    {
      "time": 72.81,
      "time_str": "01:12.810",
      "text": "那女孩对我说",
      "translation": null
    },
    {
      "time": 75.219,
      "time_str": "01:15.219",
      "text": "说我保护她的梦",
      "translation": null
    },
    {
      "time": 78.909,
      "time_str": "01:18.909",
      "text": "说这个世界",
      "translation": null
    },
    {
      "time": 81.56,
      "time_str": "01:21.560",
      "text": "对她这样的不多",
      "translation": null
    },
    {
      "time": 85.11,
      "time_str": "01:25.110",
      "text": "她渐渐忘了我",
      "translation": null
    },
    {
      "time": 87.54,
      "time_str": "01:27.540",
      "text": "但是她并不晓得",
      "translation": null
    },
    {
      "time": 91.209,
      "time_str": "01:31.209",
      "text": "遍体鳞伤的我",
      "translation": null
    },
    {
      "time": 93.709,
      "time_str": "01:33.709",
      "text": "一天也没再爱过",
      "translation": null
    },
    {
      "time": 97.34,
      "time_str": "01:37.340",
      "text": "那女孩对我说",
      "translation": null
    },
    {
      "time": 99.84,
      "time_str": "01:39.840",
      "text": "说我是一个小偷",
      "translation": null
    },
    {
      "time": 103.48,
      "time_str": "01:43.480",
      "text": "偷她的回忆",
      "translation": null
    },
    {
      "time": 106.04,
      "time_str": "01:46.040",
      "text": "塞进我的脑海中",
      "translation": null
    },
    {
      "time": 109.67,
      "time_str": "01:49.670",
      "text": "我不需要自由",
      "translation": null
    },
    {
      "time": 112.04,
      "time_str": "01:52.040",
      "text": "只想背着她的梦",
      "translation": null
    },
    {
      "time": 115.73,
      "time_str": "01:55.730",
      "text": "一步步向前走",
      "translation": null
    },
    {
      "time": 118.459,
      "time_str": "01:58.459",
      "text": "她给的永远 不重",
      "translation": null
    },
