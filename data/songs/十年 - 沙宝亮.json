    {
      "time": 15.31,
      "time_str": "00:15.310",
      "text": "如果那两个字没有颤抖",
      "translation": null
    },
    {
      "time": 19.25,
      "time_str": "00:19.250",
      "text": "我不会发现   我难受",
      "translation": null
    },
    {
      "time": 22.37,
      "time_str": "00:22.370",
      "text": "怎么说出口  也不过是分手",
      "translation": null
    },
    {
      "time": 30.4,
      "time_str": "00:30.400",
      "text": "如果对于明天没有要求",
      "translation": null
    },
    {
      "time": 34.58,
      "time_str": "00:34.580",
      "text": "牵牵手就像旅游",
      "translation": null
    },
    {
      "time": 37.64,
      "time_str": "00:37.640",
      "text": "成千上万个门口",
      "translation": null
    },
    {
      "time": 41.57,
      "time_str": "00:41.570",
      "text": "总有一个人要先走",
      "translation": null
    },
    {
      "time": 47.5,
      "time_str": "00:47.500",
      "text": "怀抱既然不能逗留",
      "translation": null
    },
    {
      "time": 50.82,
      "time_str": "00:50.820",
      "text": "何不在离开的时候",
      "translation": null
    },
    {
      "time": 53.55,
      "time_str": "00:53.550",
      "text": "一边享受   一边泪流",
      "translation": null
    },
    {
      "time": 60.83,
      "time_str": "01:00.830",
      "text": "十年之前",
      "translation": null
    },
    {
      "time": 62.9,
      "time_str": "01:02.900",
      "text": "我不认识你   你不属于我",
      "translation": null
    },
    {
      "time": 66.65,
      "time_str": "01:06.650",
      "text": "我们还是一样",
      "translation": null
    },
    {
      "time": 68.96,
      "time_str": "01:08.960",
      "text": "陪在一个陌生人左右",
      "translation": null
    },
    {
      "time": 72.52,
      "time_str": "01:12.520",
      "text": "走过渐渐熟悉的街头",
      "translation": null
    },
    {
      "time": 76.39,
      "time_str": "01:16.390",
      "text": "十年之后",
      "translation": null
