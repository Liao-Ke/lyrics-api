  "lyrics": [
    {
      "time": 17.42,
      "time_str": "00:17.420",
      "text": "钟声敲醒萌芽的爱情",
      "translation": null
    },
    {
      "time": 21.37,
      "time_str": "00:21.370",
      "text": "微风透露春来的讯息",
      "translation": null
    },
    {
      "time": 25.49,
      "time_str": "00:25.490",
      "text": "我成天躲在被窝",
      "translation": null
    },
    {
      "time": 29.42,
      "time_str": "00:29.420",
      "text": "幻想和你手牵手",
      "translation": null
    },
    {
      "time": 33.28,
      "time_str": "00:33.280",
      "text": "天空不禁飘起了小雨",
      "translation": null
    },
    {
      "time": 37.13,
      "time_str": "00:37.130",
      "text": "校门口没有人来接你",
      "translation": null
    },
    {
      "time": 40.99,
      "time_str": "00:40.990",
      "text": "如果你允许 能否让我",
      "translation": null
    },
    {
      "time": 44.95,
      "time_str": "00:44.950",
      "text": "帮你撑伞陪你走",
      "translation": null
    },
    {
      "time": 50.98,
      "time_str": "00:50.980",
      "text": "彩虹射穿太阳雨（射穿太阳雨）",
      "translation": null
    },
    {
      "time": 54.34,
      "time_str": "00:54.340",
      "text": "像爱情穿梭四季（穿梭了四季）",
      "translation": null
    },
    {
      "time": 58.53,
      "time_str": "00:58.530",
      "text": "蓝天赶走了乌云",
      "translation": null
    },
    {
      "time": 61.29,
      "time_str": "01:01.290",
      "text": "教室里偷吻了你",
      "translation": null
    },
    {
      "time": 66.64,
      "time_str": "01:06.640",
      "text": "初恋的粉色系 脸颊旁的唇蜜",
      "translation": null
    },
    {
      "time": 70.5,
      "time_str": "01:10.500",
      "text": "透露爱情来临的小秘密",
      "translation": null
    },
    {
      "time": 74.38,
      "time_str": "01:14.380",
      "text": "催眠般的魔力 陷入你的陷阱",
      "translation": null
    },
    {
      "time": 78.3,
      "time_str": "01:18.300",
      "text": "抽钥匙希望能够载到你",
      "translation": null
    },
    {
      "time": 82.43,
      "time_str": "01:22.430",
      "text": "初恋的粉色系 任性的大眼睛",
      "translation": null
    },
    {
      "time": 86.28,
      "time_str": "01:26.280",
      "text": "像棉花糖般俏皮又淘气",
      "translation": null
    },
    {
      "time": 90.2,
      "time_str": "01:30.200",
      "text": "没有云好天气 像恋爱的心情",
      "translation": null
    },
    {
      "time": 94.1,
      "time_str": "01:34.100",
      "text": "骑我的BUBU载着你 搭乘甜蜜",
      "translation": null
    },
    {
      "time": 114.75,
      "time_str": "01:54.750",
      "text": "低腰裤搭上淡蓝眼影",
      "translation": null
    },
    {
      "time": 118.58,
      "time_str": "01:58.580",
      "text": "训导主任都被你吸引",
      "translation": null
    },
    {
      "time": 122.47,
      "time_str": "02:02.470",
      "text": "没痊愈的草莓印",
      "translation": null
    },
    {
      "time": 126.29,
      "time_str": "02:06.290",
      "text": "躲在围巾里喘息",
      "translation": null
    },
    {
      "time": 130.2,
      "time_str": "02:10.200",
      "text": "挂在班牌上的棒球帽",
      "translation": null
    },
    {
      "time": 134.09,
      "time_str": "02:14.090",
      "text": "是下课想约你的暗号",
      "translation": null
    },
    {
      "time": 137.98,
      "time_str": "02:17.980",
      "text": "手机没讯号 也能收到",
      "translation": null
    },
    {
      "time": 141.85,
      "time_str": "02:21.850",
      "text": "放学一起吃汉堡",
      "translation": null
