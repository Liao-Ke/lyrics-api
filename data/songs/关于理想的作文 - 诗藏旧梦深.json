  "lyrics": [
    {
      "time": 17.94,
      "time_str": "00:17.940",
      "text": "那一年九月",
      "translation": null
    },
    {
      "time": 19.68,
      "time_str": "00:19.680",
      "text": "告别了田野",
      "translation": null
    },
    {
      "time": 21.54,
      "time_str": "00:21.540",
      "text": "她帮我收拾好书包把铅笔削尖",
      "translation": null
    },
    {
      "time": 24.87,
      "time_str": "00:24.870",
      "text": "看着黑板上老师留的作业",
      "translation": null
    },
    {
      "time": 28.47,
      "time_str": "00:28.470",
      "text": "写下第一篇",
      "translation": null
    },
    {
      "time": 31.98,
      "time_str": "00:31.980",
      "text": "我写了开学第一天",
      "translation": null
    },
    {
      "time": 34.23,
      "time_str": "00:34.230",
      "text": "同学认不全",
      "translation": null
    },
    {
      "time": 35.76,
      "time_str": "00:35.760",
      "text": "弯曲的拼音",
      "translation": null
    },
    {
      "time": 37.2,
      "time_str": "00:37.200",
      "text": "写了小红小绿和小蓝",
      "translation": null
    },
    {
      "time": 39.36,
      "time_str": "00:39.360",
      "text": "写了晴朗的天",
      "translation": null
    },
    {
      "time": 42.12,
      "time_str": "00:42.120",
      "text": "写了无忧无虑的脸",
      "translation": null
    },
    {
      "time": 47.1,
      "time_str": "00:47.100",
      "text": "懵懂的时光总是一转眼",
      "translation": null
    },
    {
      "time": 50.28,
      "time_str": "00:50.280",
      "text": "我从天真无邪的小孩",
      "translation": null
    },
    {
      "time": 52.65,
      "time_str": "00:52.650",
      "text": "变成了少年",
      "translation": null
    },
    {
      "time": 54.12,
      "time_str": "00:54.120",
      "text": "关于理想的那篇作文",
      "translation": null
    },
    {
      "time": 56.64,
      "time_str": "00:56.640",
      "text": "也从放学变成要当飞行员",
      "translation": null
    },
    {
      "time": 61.65,
      "time_str": "01:01.650",
      "text": "后来慢慢我懂事为她红过脸",
      "translation": null
    },
    {
      "time": 64.86,
      "time_str": "01:04.860",
      "text": "十八岁的那天他们说我已成年",
      "translation": null
    },
    {
      "time": 68.46,
      "time_str": "01:08.460",
      "text": "他说孩子你该好好梳洗打扮",
      "translation": null
    },
    {
      "time": 72.39,
      "time_str": "01:12.390",
      "text": "去看看这世界",
      "translation": null
    },
    {
      "time": 76.02,
      "time_str": "01:16.020",
      "text": "我坐上了火车去追赶日落",
      "translation": null
    },
    {
      "time": 79.68,
      "time_str": "01:19.680",
      "text": "我轻轻的跳起来亲吻云朵",
      "translation": null
    },
    {
      "time": 83.49,
      "time_str": "01:23.490",
      "text": "从野三坡到日喀则",
      "translation": null
    },
    {
      "time": 86.73,
      "time_str": "01:26.730",
      "text": "一路都是我爱听的歌",
      "translation": null
    },
    {
      "time": 90.54,
      "time_str": "01:30.540",
      "text": "快看看这生活是什么颜色",
      "translation": null
    },
    {
      "time": 94.23,
      "time_str": "01:34.230",
      "text": "别朝九晚五等岁月蹉跎",
      "translation": null
    },
    {
      "time": 97.56,
      "time_str": "01:37.560",
      "text": "小时候写下的理想",
      "translation": null
    },
    {
      "time": 101.1,
      "time_str": "01:41.100",
      "text": "别忘了",
      "translation": null
    },
    {
