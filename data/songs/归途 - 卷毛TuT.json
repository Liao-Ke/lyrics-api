  "lyrics": [
    {
      "time": 2.79,
      "time_str": "00:02.790",
      "text": "《归途》- 星一问水",
      "translation": null
    },
    {
      "time": 23.59,
      "time_str": "00:23.590",
      "text": "苍穹热血一身傲骨的少年",
      "translation": null
    },
    {
      "time": 28.38,
      "time_str": "00:28.380",
      "text": "欲望火烧遍野间",
      "translation": null
    },
    {
      "time": 30.98,
      "time_str": "00:30.980",
      "text": "踏过着山河边",
      "translation": null
    },
    {
      "time": 34.17,
      "time_str": "00:34.170",
      "text": "任凭刀剑一声笑看过云烟",
      "translation": null
    },
    {
      "time": 39.19,
      "time_str": "00:39.190",
      "text": "难渡自我不妥协",
      "translation": null
    },
    {
      "time": 41.86,
      "time_str": "00:41.860",
      "text": "淤泥也盛红莲",
      "translation": null
    },
    {
      "time": 45.07,
      "time_str": "00:45.070",
      "text": "我走自己的路",
      "translation": null
    },
    {
      "time": 46.19,
      "time_str": "00:46.190",
      "text": "鞋脏无惧招数",
      "translation": null
    },
    {
      "time": 47.62,
      "time_str": "00:47.620",
      "text": "葫中酒入半腹",
      "translation": null
    },
    {
      "time": 48.86,
      "time_str": "00:48.860",
      "text": "抬头仰望着归途",
      "translation": null
    },
    {
      "time": 50.23,
      "time_str": "00:50.230",
      "text": "山间飘起大雾",
      "translation": null
    },
    {
      "time": 51.46,
      "time_str": "00:51.460",
      "text": "任凭寒风刺入骨",
      "translation": null
    },
    {
      "time": 52.83,
      "time_str": "00:52.830",
      "text": "喔喔",
      "translation": null
    },
    {
      "time": 53.45,
      "time_str": "00:53.450",
      "text": "吾从哪里来就是哪里的骨",
      "translation": null
    },
    {
      "time": 56.05,
      "time_str": "00:56.050",
      "text": "上刀山下海红尘早已退出",
      "translation": null
    },
    {
      "time": 58.71,
      "time_str": "00:58.710",
      "text": "命中里有路脚下荆棘稳住",
      "translation": null
    },
    {
      "time": 61.38,
      "time_str": "01:01.380",
      "text": "望着天山靠地英雄不问归处Yeah~",
      "translation": null
    },
    {
      "time": 63.9,
      "time_str": "01:03.900",
      "text": "马蹄赤兔随我去血染沙场疆土",
      "translation": null
    },
    {
      "time": 66.56,
      "time_str": "01:06.560",
      "text": "长戟刺下在黎明的黑暗之下",
      "translation": null
    },
    {
      "time": 68.99,
      "time_str": "01:08.990",
      "text": "硝烟号角响起了红色的警告",
      "translation": null
    },
    {
      "time": 71.71,
      "time_str": "01:11.710",
      "text": "一人脚下踩着滚烫的荣耀",
      "translation": null
    },
    {
      "time": 74.12,
      "time_str": "01:14.120",
      "text": "信号 扛起了无畏的旗帜展示着完美记号",
      "translation": null
    },
    {
      "time": 77.41,
      "time_str": "01:17.410",
      "text": "无声的高歌内心的火热",
      "translation": null
    },
    {
      "time": 80.02,
      "time_str": "01:20.020",
      "text": "烽烟还记得沙场中撕扯",
      "translation": null
    },
    {
      "time": 82.75,
      "time_str": "01:22.750",
      "text": "血液流淌着一生的长河",
      "translation": null
    },
    {
      "time": 85.41,
      "time_str": "01:25.410",
