    {
      "time": 11.13,
      "time_str": "00:11.130",
      "text": "男：啊啊啊啊啊啊啊",
      "translation": null
    },
    {
      "time": 21.09,
      "time_str": "00:21.090",
      "text": "啊啊啊啊啊啊哈",
      "translation": null
    },
    {
      "time": 30.34,
      "time_str": "00:30.340",
      "text": "女：沉鱼落雁 闭月羞花",
      "translation": null
    },
    {
      "time": 35.05,
      "time_str": "00:35.050",
      "text": "美得无处藏",
      "translation": null
    },
    {
      "time": 37.04,
      "time_str": "00:37.040",
      "text": "男：美得无处藏",
      "translation": null
    },
    {
      "time": 39.19,
      "time_str": "00:39.190",
      "text": "女：人在身旁 如沐春光",
      "translation": null
    },
    {
      "time": 44.34,
      "time_str": "00:44.340",
      "text": "宁死也无憾",
      "translation": null
    },
    {
      "time": 47.14,
      "time_str": "00:47.140",
      "text": "男：哈哈",
      "translation": null
    },
    {
      "time": 48.19,
      "time_str": "00:48.190",
      "text": "女：国色天香 任由纠缠",
      "translation": null
    },
    {
      "time": 53.59,
      "time_str": "00:53.590",
      "text": "哪怕人生短",
      "translation": null
    },
    {
      "time": 56.67,
      "time_str": "00:56.670",
      "text": "男：哪怕人生短",
      "translation": null
    },
    {
      "time": 58.47,
      "time_str": "00:58.470",
      "text": "女：你情我愿 你来我往",
      "translation": null
    },
    {
      "time": 63.02,
      "time_str": "01:03.020",
      "text": "何等有幸配成双",
      "translation": null
    },
    {
