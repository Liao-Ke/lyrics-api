    {
      "time": 28.28,
      "time_str": "00:28.280",
      "text": "怎恋爱 总有太多障碍",
      "translation": null
    },
    {
      "time": 33.94,
      "time_str": "00:33.940",
      "text": "或是太耐 或热爱并非存在",
      "translation": null
    },
    {
      "time": 38.24,
      "time_str": "00:38.240",
      "text": "让伤害 摆放意粉里面",
      "translation": null
    },
    {
      "time": 43.86,
      "time_str": "00:43.860",
      "text": "陪同热泪落入白醋爱意化开",
      "translation": null
    },
    {
      "time": 47.86,
      "time_str": "00:47.860",
      "text": "就擦去过去色彩我要分开 Cuz Baby～",
      "translation": null
    },
    {
      "time": 53.1,
      "time_str": "00:53.100",
      "text": "将从前 伤悲放於一边",
      "translation": null
    },
    {
      "time": 55.41,
      "time_str": "00:55.410",
      "text": "离开绝地 别做谁後备",
      "translation": null
    },
    {
      "time": 57.78,
      "time_str": "00:57.780",
      "text": "爱意大利面但就是别 爱你",
      "translation": null
    },
    {
      "time": 62.77,
      "time_str": "01:02.770",
      "text": "如果乏味 混入甜味辣味",
