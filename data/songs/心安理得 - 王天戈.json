    {
      "time": 8.73,
      "time_str": "00:08.730",
      "text": "录混：91音乐",
      "translation": null
    },
    {
      "time": 30.44,
      "time_str": "00:30.440",
      "text": "寥寥几句算多",
      "translation": null
    },
    {
      "time": 35.19,
      "time_str": "00:35.190",
      "text": "陌生熟悉轮廓",
      "translation": null
    },
    {
      "time": 39.33,
      "time_str": "00:39.330",
      "text": "回忆 此时又算什么",
      "translation": null
    },
    {
      "time": 48.4,
      "time_str": "00:48.400",
      "text": "责怪都舍不得",
      "translation": null
    },
    {
      "time": 52.43,
      "time_str": "00:52.430",
      "text": "算不算是懦弱",
      "translation": null
    },
    {
      "time": 57.07,
      "time_str": "00:57.070",
      "text": "爱情 本就无关对错",
      "translation": null
    },
    {
      "time": 65.33,
      "time_str": "01:05.330",
      "text": "只是你太粗心大意忽略了我的感受",
      "translation": null
    },
    {
      "time": 69.55,
      "time_str": "01:09.550",
      "text": "只是我太执着在意拥有你给的温柔",
      "translation": null
    },
    {
      "time": 74.05,
      "time_str": "01:14.050",
      "text": "你的借口理由 我照单全收",
      "translation": null
    },
    {
      "time": 82.57,
      "time_str": "01:22.570",
      "text": "如果说是我太过迁就所以沦为爱囚",
      "translation": null
    },
    {
      "time": 86.75,
      "time_str": "01:26.750",
      "text": "活该我独自承受独自寂寞转身怀旧",
      "translation": null
    },
    {
      "time": 91.08,
      "time_str": "01:31.080",
      "text": "真心付出不够 不适合厮守",
      "translation": null
    },
    {
      "time": 99.95,
      "time_str": "01:39.950",
      "text": "如果说放手是种解脱挽留又有何用",
      "translation": null
    },
    {
      "time": 104.13,
      "time_str": "01:44.130",
      "text": "为何还会依依不舍",
      "translation": null
    },
    {
      "time": 108.7,
      "time_str": "01:48.700",
      "text": "配合你要的结果 我心安理得",
      "translation": null
    },
    {
