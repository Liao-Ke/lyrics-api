  "lyrics": [
    {
      "time": 57.8,
      "time_str": "00:57.800",
      "text": "你独自站在街角",
      "translation": null
    },
    {
      "time": 62.14,
      "time_str": "01:02.140",
      "text": "脸上的伤痕没消",
      "translation": null
    },
    {
      "time": 66.43,
      "time_str": "01:06.430",
      "text": "你哭着对我微笑",
      "translation": null
    },
    {
      "time": 70.92,
      "time_str": "01:10.920",
      "text": "这画面像一把刀",
      "translation": null
    },
    {
      "time": 75.52,
      "time_str": "01:15.520",
      "text": "我跪着向天祈祷",
      "translation": null
    },
    {
      "time": 79.05,
      "time_str": "01:19.050",
      "text": "给我勇气面对一切好不好",
      "translation": null
    },
    {
      "time": 83.24,
      "time_str": "01:23.240",
      "text": "我却懦弱地让你转身走掉",
      "translation": null
    },
    {
      "time": 87.98,
      "time_str": "01:27.980",
      "text": "错过你一切已不再重要",
      "translation": null
    },
    {
      "time": 91.76,
      "time_str": "01:31.760",
      "text": "放手去爱不要逃",
      "translation": null
    },
    {
      "time": 96.42,
      "time_str": "01:36.420",
      "text": "爱不是想要得到就能得到",
      "translation": null
    },
    {
      "time": 100.71,
      "time_str": "01:40.710",
      "text": "谁赢谁输已不再重要",
      "translation": null
    },
    {
      "time": 105.71,
      "time_str": "01:45.710",
      "text": "能痛痛快快一场就好",
      "translation": null
    },
    {
      "time": 109.47,
      "time_str": "01:49.470",
      "text": "放手去爱不要逃",
      "translation": null
    },
    {
      "time": 113.94,
      "time_str": "01:53.940",
      "text": "一辈子能有几次机会寻找",
      "translation": null
    },
    {
      "time": 118.38,
      "time_str": "01:58.380",
      "text": "有多少辛苦值得去炫耀",
      "translation": null
    },
    {
      "time": 123.28,
      "time_str": "02:03.280",
      "text": "能看你一生幸福到老",
      "translation": null
    },
    {
      "time": 126.95,
      "time_str": "02:06.950",
      "text": "这样就好～",
      "translation": null
    },
