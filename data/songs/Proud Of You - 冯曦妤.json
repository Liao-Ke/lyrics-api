    {
      "time": 11.899,
      "time_str": "00:11.899",
      "text": "Love in your eyes",
      "translation": "你的眼中闪烁着爱意"
    },
    {
      "time": 14.329,
      "time_str": "00:14.329",
      "text": "Sitting silent by my side",
      "translation": "静静地坐在我身旁"
    },
    {
      "time": 17.579,
      "time_str": "00:17.579",
      "text": "Going on Holding hands",
      "translation": "请牵着我的手一起"
    },
    {
      "time": 19.889,
      "time_str": "00:19.889",
      "text": "Walking through the nights",
      "translation": "度过这美好的夜晚"
    },
    {
      "time": 22.689,
      "time_str": "00:22.689",
      "text": "Hold me up Hold me tight",
      "translation": "请紧紧地抱住我"
    },
    {
      "time": 25.439,
      "time_str": "00:25.439",
      "text": "Lift me up to touch the sky",
      "translation": "让我感受这天空的辽阔"
    },
    {
      "time": 28.59,
      "time_str": "00:28.590",
      "text": "Teaching me to love with heart",
      "translation": "让我用心爱这世界"
    },
    {
      "time": 31.268,
      "time_str": "00:31.268",
      "text": "Helping me open my mind",
      "translation": "让我看到未来的精彩"
    },
    {
      "time": 34.688,
      "time_str": "00:34.688",
      "text": "I can fly",
      "translation": "我可以飞翔"
    },
    {
      "time": 36.187,
      "time_str": "00:36.187",
      "text": "I'm proud that I can fly",
