    {
      "time": 1.75,
      "time_str": "00:01.750",
      "text": "原唱 : 成龙 / 周华健 / 李宗盛",
      "translation": null
    },
    {
      "time": 9.75,
      "time_str": "00:09.750",
      "text": "佟大为：在我心中曾经有一个梦",
      "translation": null
    },
    {
      "time": 13.58,
      "time_str": "00:13.580",
      "text": "要用歌声让你忘了所有的痛",
      "translation": null
    },
    {
      "time": 18.26,
      "time_str": "00:18.260",
      "text": "陈学冬：灿烂星空谁是真的英雄",
      "translation": null
    },
    {
      "time": 22.08,
      "time_str": "00:22.080",
      "text": "平凡的人们给我最多感动",
      "translation": null
    },
    {
      "time": 26.61,
      "time_str": "00:26.610",
      "text": "郑元畅：再没有恨也没有了痛",
      "translation": null
    },
    {
      "time": 30.37,
      "time_str": "00:30.370",
      "text": "但愿人间处处都有爱的影踪",
      "translation": null
    },
    {
      "time": 35.15,
      "time_str": "00:35.150",
      "text": "杨坤：用我们的歌换你真心笑容",
      "translation": null
    },
    {
      "time": 39.04,
      "time_str": "00:39.040",
      "text": "祝福你的人生从此与众不同",
      "translation": null
    },
    {
      "time": 43.63,
      "time_str": "00:43.630",
      "text": "把握生命里的每一分钟",
      "translation": null
    },
    {
      "time": 47.39,
      "time_str": "00:47.390",
      "text": "全力以赴我们心中的梦",
      "translation": null
    },
    {
      "time": 52.12,
      "time_str": "00:52.120",
      "text": "朱亚文：不经历风雨怎么见彩虹",
      "translation": null
    },
    {
      "time": 56.29,
      "time_str": "00:56.290",
      "text": "没有人能随随便便成功",
      "translation": null
    },
    {
      "time": 60.58,
      "time_str": "01:00.580",
      "text": "张杰：把握生命里每一次感动",
      "translation": null
    },
    {
      "time": 64.5,
      "time_str": "01:04.500",
      "text": "和心爱的朋友热情相拥",
      "translation": null
    },
    {
