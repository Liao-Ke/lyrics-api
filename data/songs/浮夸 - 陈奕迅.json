{
  "title": "浮夸",
  "title_raw": "浮夸",
  "version": null,
  "artist": "陈奕迅",
  "group_key": "浮夸|陈奕迅",
  "writers": {
    "lyricist": "黄伟文",
    "composer": "C. Y. Kong",
    "arranger": "C. Y. Kong"
  },
  "lyrics": [
    {
      "time": 28.773,
      "time_str": "00:28.773",
      "text": "有人问我 我就会讲 但是无人来",
      "translation": null
    },
    {
      "time": 35.937,
      "time_str": "00:35.937",
      "text": "我期待 到无奈 有话要讲 得不到装载",
      "translation": null
    },
    {
      "time": 42.578,
      "time_str": "00:42.578",
      "text": "我的心情犹像樽盖 等被揭开",
      "translation": null
    },
    {
      "time": 46.628,
      "time_str": "00:46.628",
      "text": "嘴巴却在养青苔",
      "translation": null
    },
    {
      "time": 49.359,
      "time_str": "00:49.359",
      "text": "人潮内 愈文静 愈变得 不受理睬",
      "translation": null
    },
    {
      "time": 53.563,
      "time_str": "00:53.563",
      "text": "自己要搞出意外 像突然地高歌",
      "translation": null
    },
    {
      "time": 60.16,
      "time_str": "01:00.160",
      "text": "任何地方也像开四面台",
      "translation": null
    },
    {
      "time": 63.442,
      "time_str": "01:03.442",
      "text": "着最闪的衫 扮十分感慨",
      "translation": null
    },
    {
      "time": 67.172,
      "time_str": "01:07.172",
      "text": "有人来拍照要记住插袋",
      "translation": null
    },
    {
      "time": 71.614,
      "time_str": "01:11.614",
      "text": "你当我是浮夸吧 夸张只因我很怕",
      "translation": null
    },
    {
      "time": 78.82,
      "time_str": "01:18.820",
      "text": "似木头 似石头的话 得到注意吗",
      "translation": null
    },
    {
      "time": 84.638,
      "time_str": "01:24.638",
      "text": "其实怕被忘记 至放大来演吧",
      "translation": null
    },
    {
      "time": 89.822,
      "time_str": "01:29.822",
      "text": "很不安 怎去优雅",
      "translation": null
    },
    {
      "time": 93.183,
      "time_str": "01:33.183",
      "text": "世上还赞颂沉默吗 不够爆炸",
      "translation": null
    },
    {
      "time": 99.4,
      "time_str": "01:39.400",
      "text": "怎么有话题 让我夸 做大娱乐家",
      "translation": null
    },
    {
      "time": 111.05,
      "time_str": "01:51.050",
      "text": "那年十八 母校舞会 站着如喽啰",
      "translation": null
    },
    {
      "time": 118.18,
      "time_str": "01:58.180",
      "text": "那时候 我含泪发誓各位 必须看到我",
      "translation": null
    },
    {
      "time": 124.924,
      "time_str": "02:04.924",
      "text": "在世间 平凡又普通的路太多",
      "translation": null
    },
    {
      "time": 128.991,
      "time_str": "02:08.991",
      "text": "屋邨你住哪一座",
      "translation": null
    },
    {
      "time": 131.878,
      "time_str": "02:11.878",
      "text": "情爱中 工作中 受过的忽视太多",
      "translation": null
    },
    {
      "time": 135.94,
      "time_str": "02:15.940",
      "text": "自尊已饱经跌堕 重视能治肚饿",
      "translation": null
    },
    {
      "time": 142.441,
      "time_str": "02:22.441",
      "text": "未曾获得过便知我为何",
      "translation": null
    },
    {
      "time": 145.739,
      "time_str": "02:25.739",
      "text": "大动作很多 犯下这些错",
      "translation": null
    },
    {
      "time": 149.542,
      "time_str": "02:29.542",
      "text": "搏人们看看我 算病态么",
      "translation": null
    },
    {
      "time": 154.008,
      "time_str": "02:34.008",
      "text": "你当我是浮夸吧 夸张只因我很怕",
      "translation": null
    },
    {
      "time": 161.123,
      "time_str": "02:41.123",
      "text": "似木头 似石头的话 得到注意吗",
      "translation": null
    },
    {
      "time": 166.899,
      "time_str": "02:46.899",
      "text": "其实怕被忘记 至放大来演吧",
      "translation": null
    },
    {
      "time": 172.22,
      "time_str": "02:52.220",
      "text": "很不安 怎去优雅",
      "translation": null
    },
    {
      "time": 175.525,
      "time_str": "02:55.525",
      "text": "世上还赞颂沉默吗 不够爆炸",
      "translation": null
    },
    {
      "time": 181.927,
      "time_str": "03:01.927",
      "text": "怎么有话题 让我夸 做大娱乐家",
      "translation": null
    },
    {
      "time": 199.838,
      "time_str": "03:19.838",
      "text": "幸运儿并不多 若然未当过就知我为何",
      "translation": null
    },
    {
      "time": 206.66,
      "time_str": "03:26.660",
      "text": "用十倍苦心 做突出一个",
      "translation": null
    },
    {
      "time": 210.505,
      "time_str": "03:30.505",
      "text": "正常人够我富议论性么",
      "translation": null
    },
    {
      "time": 215.06,
      "time_str": "03:35.060",
      "text": "你 叫我做浮夸吧 加几声嘘声也不怕",
      "translation": null
    },
    {
      "time": 222.142,
      "time_str": "03:42.142",
      "text": "我在场 有闷场的话",
      "translation": null
    },
    {
      "time": 225.542,
      "time_str": "03:45.542",
      "text": "表演你看吗 够歇斯底里吗",
      "translation": null
    },
    {
      "time": 229.958,
      "time_str": "03:49.958",
      "text": "以眼泪淋花吧 一心只想你惊讶",
      "translation": null
    },
    {
      "time": 236.531,
      "time_str": "03:56.531",
      "text": "我旧时似未存在吗 加重注码",
      "translation": null
    },
    {
      "time": 242.792,
      "time_str": "04:02.792",
      "text": "青筋也现形 话我知 现在存在吗",
      "translation": null
    },
    {
      "time": 250.369,
      "time_str": "04:10.369",
      "text": "凝视我 别再只看天花",
      "translation": null
    },
    {
      "time": 258.196,
      "time_str": "04:18.196",
      "text": "我非你杯茶 也可尽情地喝吧",
      "translation": null
    },
    {
      "time": 264.167,
      "time_str": "04:24.167",
      "text": "别遗忘有人在 为你声沙",
      "translation": null
    }
  ],
  "has_translation": false,
  "source_file": "浮夸 - 陈奕迅.lrc"
}