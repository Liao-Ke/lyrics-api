  },
  "lyrics": [
    {
      "time": 28.335,
      "time_str": "00:28.335",
      "text": "无论怎得罪你说我是负累",
      "translation": null
    },
    {
      "time": 31.562,
      "time_str": "00:31.562",
      "text": "陪着我等于死去了无情趣",
      "translation": null
    },
    {
      "time": 35.083,
      "time_str": "00:35.083",
      "text": "从前或现在当我是谁",
      "translation": null
    },
    {
      "time": 38.772,
      "time_str": "00:38.772",
      "text": "你这一种伴侣",
      "translation": null
    },
    {
      "time": 42.221,
      "time_str": "00:42.221",
      "text": "前夜一起睡 你却没廉耻",
      "translation": null
    },
    {
      "time": 45.649,
      "time_str": "00:45.649",
      "text": "竟讲出口你怕受罪",
      "translation": null
    },
    {
      "time": 49.701,
      "time_str": "00:49.701",
      "text": "完全忘记往日为何",
      "translation": null
    },
    {
      "time": 52.723,
      "time_str": "00:52.723",
      "text": "凌晨仍潮浪戏水",
      "translation": null
    },
    {
      "time": 55.783,
      "time_str": "00:55.783",
      "text": "难道爱爱爱爱爱对爱情已死心",
      "translation": null
    },
    {
      "time": 59.012,
      "time_str": "00:59.012",
      "text": "贪高兴好心敷衍一下却逼真的亲吻",
      "translation": null
    },
    {
      "time": 63.396,
      "time_str": "01:03.396",
      "text": "我们这结局太不堪",
      "translation": null
    },
    {
      "time": 65.965,
      "time_str": "01:05.965",
      "text": "分不出真假的爱恨",
      "translation": null
    },
    {
      "time": 69.406,
      "time_str": "01:09.406",
      "text": "无谓爱爱爱爱爱太过动魄惊心",
      "translation": null
    },
    {
      "time": 72.644,
      "time_str": "01:12.644",
      "text": "我估错这个世界得到教训",
      "translation": null
    },
    {
      "time": 76.075,
      "time_str": "01:16.075",
      "text": "怎相信人 命中怎么爱着你为人",
      "translation": null
    },
    {
      "time": 96.869,
      "time_str": "01:36.869",
      "text": "立甚么心肠 我对你极善良",
      "translation": null
    },
    {
      "time": 100.135,
      "time_str": "01:40.135",
      "text": "如若你肯想想我这样受伤",
      "translation": null
    },
    {
      "time": 103.659,
      "time_str": "01:43.659",
      "text": "你会知爱情毒于砒霜",
      "translation": null
    },
    {
      "time": 107.34,
      "time_str": "01:47.340",
      "text": "你怎安心可不改漂亮",
      "translation": null
    },
    {
      "time": 111.114,
      "time_str": "01:51.114",
      "text": "怎想象 共你已同享多少很真确晚上",
      "translation": null
    },
    {
      "time": 117.805,
      "time_str": "01:57.805",
      "text": "一转头 缠绵后要罚离场",
      "translation": null
    },
    {
      "time": 124.424,
      "time_str": "02:04.424",
      "text": "难道爱爱爱爱爱对爱情已死心",
      "translation": null
    },
    {
      "time": 127.468,
      "time_str": "02:07.468",
      "text": "贪高兴好心敷衍一下却逼真的亲吻",
      "translation": null
    },
    {
      "time": 131.961,
      "time_str": "02:11.961",
      "text": "我们这结局太不堪",
      "translation": null
    },
    {
      "time": 134.507,
      "time_str": "02:14.507",
      "text": "分不出真假的爱恨",
      "translation": null
    },
    {
      "time": 137.901,
      "time_str": "02:17.901",
      "text": "无谓爱爱爱爱爱太过动魄惊心",
      "translation": null
    },
    {
      "time": 141.165,
      "time_str": "02:21.165",
      "text": "我估错这个世界得到教训",
      "translation": null
    },
    {
      "time": 144.631,
      "time_str": "02:24.631",
      "text": "怎相信人 命中怎么爱着你为人",
      "translation": null
    },
    {
      "time": 152.504,
      "time_str": "02:32.504",
      "text": "彷似幻像你给我的爱是玩具磨烂后变绝情",
      "translation": null
    },
    {
      "time": 158.75,
      "time_str": "02:38.750",
      "text": "难为这洗劫永没罪证",
      "translation": null
    },
    {
      "time": 162.355,
      "time_str": "02:42.355",
      "text": "道别并无罪也没权问你内情话",
      "translation": null
    },
    {
      "time": 169.105,
      "time_str": "02:49.105",
      "text": "Rap：",
      "translation": null
    },
    {
      "time": 169.738,
      "time_str": "02:49.738",
      "text": "我都唔知点解你现时对我冇晒感觉",
      "translation": null
    },
    {
      "time": 172.976,
      "time_str": "02:52.976",
      "text": "以前嗰种快乐就好似成为一种罪恶",
      "translation": null
    },
    {
      "time": 176.578,
      "time_str": "02:56.578",
      "text": "连我失眠 你都唔多觉",
      "translation": null
    },
    {
      "time": 179.067,
      "time_str": "02:59.067",
      "text": "或者其实所谓爱情都只系互相搵个寄托",
      "translation": null
    },
    {
      "time": 183.155,
      "time_str": "03:03.155",
      "text": "或者系一场即兴嘅幻觉",
      "translation": null
    },
    {
      "time": 185.945,
      "time_str": "03:05.945",
      "text": "连自己都唔知道 乜嘢系喜 乜嘢系乐",
      "translation": null
    },
    {
      "time": 189.649,
      "time_str": "03:09.649",
      "text": "几时有感觉 又几时冇晒知觉",
      "translation": null
    },
    {
      "time": 192.512,
      "time_str": "03:12.512",
      "text": "就算你无突然失去下落",
      "translation": null
    },
    {
      "time": 194.609,
      "time_str": "03:14.609",
      "text": "我哋之间都可能已经没落幕",
      "translation": null
    },
    {
      "time": 197.36,
      "time_str": "03:17.360",
      "text": "把失败换教训 不死总算幸运",
      "translation": null
    },
    {
      "time": 204.057,
      "time_str": "03:24.057",
      "text": "看 全没罪案发生",
      "translation": null
    },
    {
      "time": 207.369,
      "time_str": "03:27.369",
      "text": "为着聚散不需责任",
      "translation": null
    },
    {
      "time": 210.848,
      "time_str": "03:30.848",
      "text": "一起若像软禁 无疑离开先更合衬",
      "translation": null
    },
    {
      "time": 232.31,
      "time_str": "03:52.310",
      "text": "Prodused : Alvin Leong",
      "translation": null
    },
    {
