  "lyrics": [
    {
      "time": 18.709,
      "time_str": "00:18.709",
      "text": "爱恋没经验",
      "translation": null
    },
    {
      "time": 23.082,
      "time_str": "00:23.082",
      "text": "今天初发现",
      "translation": null
    },
    {
      "time": 27.134,
      "time_str": "00:27.134",
      "text": "遥遥共他见一面",
      "translation": null
    },
    {
      "time": 31.19,
      "time_str": "00:31.190",
      "text": "那份快乐太新鲜",
      "translation": null
    },
    {
      "time": 35.339,
      "time_str": "00:35.339",
      "text": "我一夜失眠",
      "translation": null
    },
    {
      "time": 39.691,
      "time_str": "00:39.691",
      "text": "影子心里现",
      "translation": null
    },
    {
      "time": 43.817,
      "time_str": "00:43.817",
      "text": "问为何共他见一面",
      "translation": null
    },
    {
      "time": 47.907,
      "time_str": "00:47.907",
      "text": "美丽印象似初恋",
      "translation": null
    },
    {
      "time": 54.275,
      "time_str": "00:54.275",
      "text": "默默望着是",
      "translation": null
    },
    {
      "time": 56.75,
      "time_str": "00:56.750",
      "text": "默默望着那目光似电",
      "translation": null
    },
    {
      "time": 62.786,
      "time_str": "01:02.786",
      "text": "那剎那接触已令我倒颠",
      "translation": null
    },
    {
      "time": 70.111,
      "time_str": "01:10.111",
      "text": "分分钟都盼望跟他见面",
      "translation": null
    },
    {
      "time": 74.513,
      "time_str": "01:14.513",
      "text": "默默地伫候亦从来没怨",
      "translation": null
    },
    {
      "time": 78.48,
      "time_str": "01:18.480",
      "text": "分分钟都渴望与他相见",
      "translation": null
    },
    {
      "time": 82.866,
      "time_str": "01:22.866",
      "text": "在路上碰着亦乐上几天",
      "translation": null
    },
    {
      "time": 88.007,
      "time_str": "01:28.007",
      "text": "轻快的感觉飘上面",
      "translation": null
    },
    {
      "time": 92.278,
      "time_str": "01:32.278",
      "text": "可爱的一个初恋",
      "translation": null
    },
