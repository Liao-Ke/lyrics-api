  "lyrics": [
    {
      "time": 18.55,
      "time_str": "00:18.550",
      "text": "要用多少个晴天 交换多少张相片",
      "translation": null
    },
    {
      "time": 25.99,
      "time_str": "00:25.990",
      "text": "还记得锁在抽屉里面的滴滴点点",
      "translation": null
    },
    {
      "time": 33.24,
      "time_str": "00:33.240",
      "text": "小而温馨的空间 因为有你在身边",
      "translation": null
    },
    {
      "time": 40.67,
      "time_str": "00:40.670",
      "text": "就不再感觉到害怕  大步走向前",
      "translation": null
    },
    {
      "time": 47.05,
      "time_str": "00:47.050",
      "text": "一天一月一起一年  像不像永远",
      "translation": null
    },
    {
      "time": 53.36,
      "time_str": "00:53.360",
      "text": "我们在同一个屋檐下",
      "translation": null
    },
    {
      "time": 56.55,
      "time_str": "00:56.550",
      "text": "写着属于我们  未来的诗篇",
      "translation": null
    },
    {
      "time": 64.67,
      "time_str": "01:04.670",
      "text": "在这温暖的房间",
      "translation": null
    },
    {
      "time": 68.42,
      "time_str": "01:08.420",
      "text": "我于是慢慢发现",
      "translation": null
    },
    {
      "time": 72.74,
      "time_str": "01:12.740",
      "text": "相聚其实就是一种缘",
      "translation": null
    },
    {
      "time": 76.69,
      "time_str": "01:16.690",
      "text": "多值得纪念",
      "translation": null
    },
    {
      "time": 79.32,
      "time_str": "01:19.320",
      "text": "在这温暖的房间",
      "translation": null
    },
    {
      "time": 83.63,
      "time_str": "01:23.630",
      "text": "我们都笑得很甜",
      "translation": null
    },
    {
      "time": 87.32,
      "time_str": "01:27.320",
      "text": "一切  停格在一瞬间",
      "translation": null
