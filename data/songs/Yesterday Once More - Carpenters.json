{
  "title": "Yesterday Once More",
  "title_raw": "Yesterday Once More",
  "version": null,
  "artist": "Carpenters",
  "group_key": "yesterday once more|carpenters",
  "writers": {
    "lyricist": "Richard Carpenter/JOHN & BETTY",
