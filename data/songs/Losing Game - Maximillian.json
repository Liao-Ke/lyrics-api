  "lyrics": [
    {
      "time": 6.194,
      "time_str": "00:06.194",
      "text": "I think I lost my mind",
      "translation": "我想我失去了理智"
    },
    {
      "time": 8.879,
      "time_str": "00:08.879",
      "text": "I got a feeling something's wrong",
      "translation": "我感觉有种不对劲"
    },
    {
      "time": 11.449,
      "time_str": "00:11.449",
      "text": "It's like I'm falling down",
      "translation": "就像我要倒下一样"
    },
    {
      "time": 14.111,
      "time_str": "00:14.111",
      "text": "Like the world I know is gone",
      "translation": "就像我所知道的世界已经消失"
    },
    {
      "time": 16.723,
      "time_str": "00:16.723",
      "text": "And I'm on my own",
      "translation": "我自己一个人"
    },
    {
      "time": 19.188,
      "time_str": "00:19.188",
      "text": "Yeah I'm all alone",
      "translation": "是的，我一个人"
    },
    {
      "time": 21.98,
      "time_str": "00:21.980",
      "text": "I must've lost my mind",
      "translation": "我一定是疯了"
    },
    {
      "time": 23.817,
      "time_str": "00:23.817",
      "text": "Lost my mind",
      "translation": "失去理智"
    },
    {
      "time": 25.502,
      "time_str": "00:25.502",
      "text": "I'm playing all or nothing",
      "translation": "我要么全力以赴，要么一无所获"
    },
    {
      "time": 27.702,
      "time_str": "00:27.702",
      "text": "With the devil watching",
      "translation": "随着魔鬼的注视"
    },
    {
      "time": 30.638,
      "time_str": "00:30.638",
      "text": "Love is a losing game",
      "translation": "爱情是一场失败的游戏"
    },
    {
      "time": 32.663,
      "time_str": "00:32.663",
      "text": "Deceiving",
      "translation": "欺骗"
    },
    {
      "time": 33.948,
      "time_str": "00:33.948",
      "text": "Believe it",
      "translation": "相信它"
    },
    {
      "time": 35.406,
      "time_str": "00:35.406",
      "text": "That love is a losing game",
      "translation": "爱情是一场失败的游戏"
    },
    {
      "time": 37.787,
      "time_str": "00:37.787",
      "text": "My heart is",
      "translation": "我的心是"
    },
    {
      "time": 39.142,
      "time_str": "00:39.142",
      "text": "Defeated",
      "translation": "被打败了"
    },
    {
      "time": 40.488,
      "time_str": "00:40.488",
      "text": "I'm trapped and I can't escape",
      "translation": "我被困住了无法逃脱"
    },
    {
      "time": 43.093,
      "time_str": "00:43.093",
      "text": "Oh baby",
      "translation": "哦，宝贝"
    },
    {
      "time": 44.404,
      "time_str": "00:44.404",
      "text": "Just tell me",
      "translation": "就告诉我嘛"
    },
    {
      "time": 45.763,
      "time_str": "00:45.763",
      "text": "What do you want from me?",
      "translation": "你想从我这里得到什么？"
    },
    {
      "time": 48.257,
      "time_str": "00:48.257",
      "text": "Yeah what can I even say",
      "translation": "是啊，我还能说什么呢"
    },
    {
      "time": 51.004,
      "time_str": "00:51.004",
      "text": "This love is a losing game",
      "translation": "这份爱是一场失败的游戏"
    },
    {
      "time": 64.472,
      "time_str": "01:04.472",
      "text": "I'm throwing loaded dice",
      "translation": "我正在掷骰子"
    },
    {
      "time": 66.829,
      "time_str": "01:06.829",
      "text": "Playing dirty 'cause I wanna win",
      "translation": "耍诈是因为我想赢"
    },
    {
      "time": 69.551,
      "time_str": "01:09.551",
      "text": "Something about your eyes",
      "translation": "关于你的眼睛的东西"
    },
    {
      "time": 72.077,
      "time_str": "01:12.077",
      "text": "It got me betting on my every spin",
      "translation": "它让我押注我的每一次旋转"
    },
    {
      "time": 74.611,
      "time_str": "01:14.611",
      "text": "Will you keep me close",
      "translation": "你会让我靠近吗"
    },
    {
      "time": 77.204,
      "time_str": "01:17.204",
      "text": "Never let me go",
      "translation": "永远别让我走"
    },
    {
      "time": 79.964,
      "time_str": "01:19.964",
      "text": "And never tell me lies",
      "translation": "永远不要告诉我谎言"
