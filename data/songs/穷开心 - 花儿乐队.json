  "lyrics": [
    {
      "time": 13.59,
      "time_str": "00:13.590",
      "text": "小小的人儿啊 风生水起呀",
      "translation": null
    },
    {
      "time": 16.78,
      "time_str": "00:16.780",
      "text": "天天就爱穷开心那",
      "translation": null
    },
    {
      "time": 19.94,
      "time_str": "00:19.940",
      "text": "逍遥的魂儿啊 假不正经吧",
      "translation": null
    },
    {
      "time": 23.33,
      "time_str": "00:23.330",
      "text": "嘻嘻哈哈我们穷开心",
      "translation": null
    },
    {
      "time": 25.77,
      "time_str": "00:25.770",
      "text": "我是谁家那小谁 身强赛过活李逵",
      "translation": null
    },
    {
      "time": 29.03,
      "time_str": "00:29.030",
      "text": "貌俊赛过猛张飞 擀毡发型亮又黑",
      "translation": null
    },
    {
      "time": 32.48,
      "time_str": "00:32.480",
      "text": "是走南闯过北 气质出众又拔萃",
      "translation": null
    },
    {
      "time": 35.44,
      "time_str": "00:35.440",
      "text": "长江黄河喝过水 和鞭炮地雷亲过嘴",
      "translation": null
    },
    {
      "time": 39.02,
      "time_str": "00:39.020",
      "text": "可嗔很憔悴 是满脸欠人捶",
      "translation": null
    },
    {
      "time": 41.87,
      "time_str": "00:41.870",
      "text": "你是西山挖过煤",
      "translation": null
    },
    {
      "time": 43.47,
      "time_str": "00:43.470",
      "text": "还是东山见过鬼（真的？）",
      "translation": null
    },
    {
      "time": 45.27,
      "time_str": "00:45.270",
      "text": "这人生苦短累",
      "translation": null
    },
    {
      "time": 46.65,
      "time_str": "00:46.650",
      "text": "今朝有酒今朝醉（啊对！）",
      "translation": null
    },
    {
      "time": 48.32,
      "time_str": "00:48.320",
      "text": "为了不哭大声笑",
      "translation": null
    },
    {
      "time": 50.19,
      "time_str": "00:50.190",
      "text": "为了不烦大声呸",
      "translation": null
    },
    {
      "time": 52.65,
      "time_str": "00:52.650",
      "text": "小小的人儿啊 风生水起呀",
      "translation": null
    },
    {
      "time": 55.87,
      "time_str": "00:55.870",
      "text": "天天就爱穷开心那",
      "translation": null
    },
    {
      "time": 58.96,
      "time_str": "00:58.960",
      "text": "逍遥的魂儿啊 假不正经吧",
      "translation": null
    },
    {
