    {
      "time": 21.84,
      "time_str": "00:21.840",
      "text": "盼望你没有为我又再渡暗中淌泪",
      "translation": null
    },
    {
      "time": 28.62,
      "time_str": "00:28.620",
      "text": "我不想留底你的心空虚",
      "translation": null
    },
    {
      "time": 35.22,
      "time_str": "00:35.220",
      "text": "盼望你别再让我像背负太深的罪",
      "translation": null
    },
    {
      "time": 41.82,
      "time_str": "00:41.820",
      "text": "我的心如水你不必痴醉",
      "translation": null
    },
    {
      "time": 47.19,
      "time_str": "00:47.190",
      "text": "哦～你可知谁甘心归去",
      "translation": null
    },
    {
      "time": 55.26,
      "time_str": "00:55.260",
      "text": "你与我之间有谁",
      "translation": null
    },
    {
      "time": 59.1,
      "time_str": "00:59.100",
      "text": "是缘是情是童真还是意外",
      "translation": null
    },
    {
      "time": 71.73,
      "time_str": "01:11.730",
      "text": "有泪有罪有付出还有忍耐",
      "translation": null
    },
    {
      "time": 78.45,
      "time_str": "01:18.450",
      "text": "是人是墙是寒冬藏在眼内",
      "translation": null
    },
    {
      "time": 85.38,
      "time_str": "01:25.380",
      "text": "有日有夜有幻想无法等待",
      "translation": null
    },
    {
      "time": 105.24,
      "time_str": "01:45.240",
      "text": "盼望我别去后会共你在远方相聚",
      "translation": null
    },
    {
      "time": 111.87,
      "time_str": "01:51.870",
      "text": "每一天望海每一天相对",
