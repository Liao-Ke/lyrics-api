  },
  "lyrics": [
    {
      "time": 6.699,
      "time_str": "00:06.699",
      "text": "Passion is sweet",
      "translation": "激情是甜蜜的"
    },
    {
      "time": 9.199,
      "time_str": "00:09.199",
      "text": "Love makes weak",
      "translation": "爱却带来脆弱"
    },
    {
      "time": 10.889,
      "time_str": "00:10.889",
      "text": "You said you cherished freedom",
      "translation": "你曾说自由至上"
    },
    {
      "time": 13.789,
      "time_str": "00:13.789",
      "text": "so you refuse to let it go",
      "translation": "因此你不愿被束缚"
    },
    {
      "time": 20.919,
      "time_str": "00:20.919",
      "text": "Follow your fate",
      "translation": "跟随你的命运"
    },
    {
      "time": 23.469,
      "time_str": "00:23.469",
      "text": "Love and hate",
      "translation": "爱恨情仇"
    },
    {
      "time": 25.059,
      "time_str": "00:25.059",
      "text": "Never fail to seize the day",
      "translation": "决不失去每一天"
    },
    {
      "time": 29.299,
      "time_str": "00:29.299",
      "text": "don't give yourself away .",
      "translation": "但不要放弃你自己"
    },
    {
      "time": 35.419,
      "time_str": "00:35.419",
      "text": "Oh when the night falls",
      "translation": "哦 当夜晚降临"
    },
    {
      "time": 39.29,
      "time_str": "00:39.290",
      "text": "And you're all alone",
      "translation": "你孤身一人"
    },
    {
      "time": 42.309,
      "time_str": "00:42.309",
      "text": "In your deepest sleep",
      "translation": "在你沉睡之时"
    },
    {
      "time": 45.069,
      "time_str": "00:45.069",
      "text": "what Are you dreaming of",
      "translation": "你梦见了什么"
    },
    {
      "time": 49.069,
      "time_str": "00:49.069",
      "text": "My skin's still burning from your touch",
      "translation": "肌肤之亲 让我陶醉"
    },
    {
      "time": 52.929,
      "time_str": "00:52.929",
      "text": "Oh I just can't get enough",
      "translation": "哦 我只是无法满足"
    },
    {
      "time": 57.119,
      "time_str": "00:57.119",
      "text": "I Said I wouldn't ask for much",
      "translation": "曾答应不再向你索取"
    },
    {
      "time": 61.089,
      "time_str": "01:01.089",
      "text": "But your eyes are dangerous",
      "translation": "然而你的眼睛摄人心魄"
    },
    {
      "time": 64.018,
      "time_str": "01:04.018",
      "text": "So the thought keeps spinning in my head",
      "translation": "对你的思念 挥之不去"
    },
    {
      "time": 68.309,
      "time_str": "01:08.309",
      "text": "Can we drop this masquerade",
      "translation": "我们可否坦诚相对"
    },
    {
      "time": 71.089,
      "time_str": "01:11.089",
      "text": "I can't predict where it ends",
      "translation": "纵使结局无法预料"
    },
    {
      "time": 75.039,
      "time_str": "01:15.039",
      "text": "If you are the rock I'll crush against",
      "translation": "我仍然甘愿飞蛾扑火"
    },
    {
      "time": 80.349,
      "time_str": "01:20.349",
      "text": "Trapped in a crowd",
      "translation": "置身于茫茫人海之中"
    },
    {
      "time": 82.529,
      "time_str": "01:22.529",
      "text": "The music is loud",
      "translation": "乐声嘈杂"
    },
    {
      "time": 84.59,
      "time_str": "01:24.590",
      "text": "I said I love my freedom too",
      "translation": "我说我同样珍爱自由"
    },
    {
      "time": 87.888,
      "time_str": "01:27.888",
      "text": "Now I'm not so sure I do",
      "translation": "可现在我却又不那么确定我珍爱"
    },
    {
      "time": 94.49,
      "time_str": "01:34.490",
      "text": "All eyes on you",
      "translation": "看到你的一切"
    },
    {
      "time": 96.579,
      "time_str": "01:36.579",
      "text": "wings so true",
      "translation": "那么真实地告诫着我"
    },
    {
      "time": 98.639,
      "time_str": "01:38.639",
      "text": "Better quit while you're ahead",
      "translation": "最好在你还在前面的时候就离开"
    },
    {
