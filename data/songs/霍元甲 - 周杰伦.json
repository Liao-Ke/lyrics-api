    {
      "time": 54.14,
      "time_str": "00:54.140",
      "text": "吓 命有几回合擂台等着",
      "translation": null
    },
    {
      "time": 57.27,
      "time_str": "00:57.270",
      "text": "生死状赢了什么冷笑着",
      "translation": null
    },
    {
      "time": 59.72,
      "time_str": "00:59.720",
      "text": "天下谁的第一又如何",
      "translation": null
    },
    {
      "time": 62.19,
      "time_str": "01:02.190",
      "text": "止干戈我辈尚武德",
      "translation": null
    },
    {
      "time": 64.32,
      "time_str": "01:04.320",
      "text": "我的拳脚了得",
      "translation": null
    },
    {
      "time": 66.45,
      "time_str": "01:06.450",
      "text": "却奈何徒增虚名一个",
      "translation": null
    },
    {
      "time": 68.93,
      "time_str": "01:08.930",
      "text": "江湖难测谁是强者",
      "translation": null
    },
    {
      "time": 71.35,
      "time_str": "01:11.350",
      "text": "谁争一统武林的资格",
      "translation": null
    },
    {
      "time": 73.78,
      "time_str": "01:13.780",
      "text": "小城里岁月流过去",
      "translation": null
    },
    {
      "time": 78.68,
      "time_str": "01:18.680",
      "text": "清澈的勇气",
      "translation": null
    },
    {
      "time": 82.72,
      "time_str": "01:22.720",
      "text": "洗涤过的回忆",
      "translation": null
    },
    {
      "time": 85.76,
      "time_str": "01:25.760",
      "text": "我记得你",
      "translation": null
    },
    {
      "time": 88.19,
      "time_str": "01:28.190",
      "text": "骄傲地活下去",
      "translation": null
    },
    {
      "time": 93.35,
      "time_str": "01:33.350",
      "text": "霍霍 霍霍 霍霍霍霍",
      "translation": null
    },
    {
      "time": 95.58,
      "time_str": "01:35.580",
      "text": "霍家拳的套路招式灵活",
      "translation": null
    },
    {
      "time": 98.36,
      "time_str": "01:38.360",
      "text": "活活 活活 活活活活",
      "translation": null
    },
    {
      "time": 100.45,
      "time_str": "01:40.450",
      "text": "活着生命就该完整地过",
      "translation": null
    },
    {
      "time": 103.18,
      "time_str": "01:43.180",
      "text": "过过 过过 过过过过",
      "translation": null
    },
    {
      "time": 105.35,
      "time_str": "01:45.350",
      "text": "过错软弱从来不属于我",
      "translation": null
    },
    {
      "time": 108.08,
      "time_str": "01:48.080",
      "text": "我我 我我 我我我我",
      "translation": null
    },
    {
      "time": 110.26,
      "time_str": "01:50.260",
      "text": "我们精武出手无人能躲",
