  "lyrics": [
    {
      "time": 51.99,
      "time_str": "00:51.990",
      "text": "从前冬天冷呀夏天雨呀水呀",
      "translation": null
    },
    {
      "time": 58.09,
      "time_str": "00:58.090",
      "text": "秋天远处传来你声音暖呀暖呀",
      "translation": null
    },
    {
      "time": 63.75,
      "time_str": "01:03.750",
      "text": "你说那时屋后面有白茫茫茫雪呀",
      "translation": null
    },
    {
      "time": 70.05,
      "time_str": "01:10.050",
      "text": "山谷里有金黄旗子在大风里飘呀",
      "translation": null
    },
    {
      "time": 76.6,
      "time_str": "01:16.600",
      "text": "我看见山鹰在寂寞两条鱼上飞",
      "translation": null
    },
    {
      "time": 83.2,
      "time_str": "01:23.200",
      "text": "两条鱼儿穿过海一样咸的河水",
      "translation": null
    },
    {
      "time": 89.47,
      "time_str": "01:29.470",
      "text": "一片河水落下来遇见人们破碎",
      "translation": null
    },
    {
      "time": 95.77,
      "time_str": "01:35.770",
      "text": "人们在行走身上落满山鹰的灰",
      "translation": null
    },
    {
