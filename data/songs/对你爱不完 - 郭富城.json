  "lyrics": [
    {
      "time": 42.671,
      "time_str": "00:42.671",
      "text": "灯初上夜未央",
      "translation": null
    },
    {
      "time": 44.643,
      "time_str": "00:44.643",
      "text": "来往的人多匆忙",
      "translation": null
    },
    {
      "time": 46.906,
      "time_str": "00:46.906",
      "text": "我不要太紧张",
      "translation": null
    },
    {
      "time": 48.895,
      "time_str": "00:48.895",
      "text": "和别人一模样",
      "translation": null
    },
    {
      "time": 50.676,
      "time_str": "00:50.676",
      "text": "但是你对我望",
      "translation": null
    },
    {
      "time": 52.72,
      "time_str": "00:52.720",
      "text": "两只眼睛大又亮",
      "translation": null
    },
    {
      "time": 54.933,
      "time_str": "00:54.933",
      "text": "我开始失去了主张",
      "translation": null
    },
    {
      "time": 58.7,
      "time_str": "00:58.700",
      "text": "风吹得路好长",
      "translation": null
    },
    {
      "time": 60.776,
      "time_str": "01:00.776",
      "text": "一颗心晃呀晃",
      "translation": null
    },
    {
      "time": 62.766,
      "time_str": "01:02.766",
      "text": "多想找人陪我逛",
      "translation": null
    },
    {
      "time": 64.712,
      "time_str": "01:04.712",
      "text": "累了睡在马路上",
      "translation": null
    },
    {
      "time": 66.721,
      "time_str": "01:06.721",
      "text": "表面上很倔强",
      "translation": null
    },
    {
      "time": 68.752,
      "time_str": "01:08.752",
      "text": "其实内心一团糟",
      "translation": null
    },
    {
      "time": 71.057,
      "time_str": "01:11.057",
      "text": "怕自己爱得像太阳",
      "translation": null
    },
    {
      "time": 74.789,
      "time_str": "01:14.789",
      "text": "(Hey, let's go)",
      "translation": null
    },
    {
      "time": 76.766,
      "time_str": "01:16.766",
      "text": "胸中藏着一把火",
      "translation": null
    },
    {
      "time": 78.819,
      "time_str": "01:18.819",
      "text": "(Dancing in the night)",
      "translation": null
    },
    {
      "time": 80.828,
      "time_str": "01:20.828",
      "text": "这种日子不好过",
      "translation": null
    },
    {
      "time": 83.039,
      "time_str": "01:23.039",
      "text": "把承诺交给你",
      "translation": null
    },
    {
      "time": 85.023,
      "time_str": "01:25.023",
      "text": "把微笑当作信",
      "translation": null
    },
    {
      "time": 87.071,
      "time_str": "01:27.071",
      "text": "却怎么也抓不住你",
      "translation": null
    },
    {
      "time": 90.379,
      "time_str": "01:30.379",
      "text": "对你爱爱爱不完",
      "translation": null
    },
    {
      "time": 94.09,
      "time_str": "01:34.090",
      "text": "我可以天天月月年年到永远",
      "translation": null
    },
    {
      "time": 98.359,
      "time_str": "01:38.359",
      "text": "So we love love love tonight",
      "translation": null
    },
    {
      "time": 102.082,
      "time_str": "01:42.082",
      "text": "不愿意丝丝点点些些去面对",
      "translation": null
    },
    {
      "time": 106.412,
      "time_str": "01:46.412",
      "text": "对你爱爱爱不完",
      "translation": null
    },
    {
      "time": 110.181,
      "time_str": "01:50.181",
      "text": "相爱 原本 总是 这么难",
      "translation": null
