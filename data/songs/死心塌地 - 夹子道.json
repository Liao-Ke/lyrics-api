  "lyrics": [
    {
      "time": 4.31,
      "time_str": "00:04.310",
      "text": "我爱你爱的死心塌地",
      "translation": null
    },
    {
      "time": 8.69,
      "time_str": "00:08.690",
      "text": "奋不顾身为你献出自己",
      "translation": null
    },
    {
      "time": 12.43,
      "time_str": "00:12.430",
      "text": "如果痛苦是开始的原因",
      "translation": null
    },
    {
      "time": 15.82,
      "time_str": "00:15.820",
      "text": "求你吻我吧",
      "translation": null
    },
    {
      "time": 16.9,
      "time_str": "00:16.900",
      "text": "至少让我死的安心",
      "translation": null
    },
    {
      "time": 37.36,
      "time_str": "00:37.360",
      "text": "心甘情愿跳进了你爱的陷阱",
      "translation": null
    },
    {
      "time": 44.19,
      "time_str": "00:44.190",
      "text": "哪怕为此而丢了性命",
      "translation": null
    },
    {
      "time": 50.87,
      "time_str": "00:50.870",
      "text": "留住你在身边一秒都行",
      "translation": null
    },
    {
      "time": 55.08,
      "time_str": "00:55.080",
      "text": "哪怕是同情",
      "translation": null
    },
    {
      "time": 57.91,
      "time_str": "00:57.910",
      "text": "至少让我可以有回忆的剧情",
      "translation": null
    },
    {
      "time": 65.4,
      "time_str": "01:05.400",
      "text": "太多诱惑凝固在你美丽的眼睛",
      "translation": null
    },
    {
      "time": 72.28,
      "time_str": "01:12.280",
      "text": "仿佛俘虏了魔鬼的精灵",
      "translation": null
    },
    {
      "time": 78.64,
      "time_str": "01:18.640",
      "text": "只要靠近一天一秒都行",
      "translation": null
    },
    {
      "time": 83.06,
      "time_str": "01:23.060",
      "text": "哪怕是怜悯",
      "translation": null
    },
    {
      "time": 86.02,
      "time_str": "01:26.020",
      "text": "至少我还有线索找回曾经",
      "translation": null
    },
    {
      "time": 93.34,
      "time_str": "01:33.340",
      "text": "我爱你爱的死心塌地",
      "translation": null
    },
    {
      "time": 96.47,
      "time_str": "01:36.470",
      "text": "你却伤我伤的那么彻底",
      "translation": null
    },
    {
      "time": 100.17,
      "time_str": "01:40.170",
      "text": "早知道这是你导演的戏",
      "translation": null
    },
    {
