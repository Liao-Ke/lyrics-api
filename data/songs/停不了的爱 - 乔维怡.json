  "lyrics": [
    {
      "time": 5.55,
      "time_str": "00:05.550",
      "text": "叶瑷菱-停不了的爱",
      "translation": null
    },
    {
      "time": 47.02,
      "time_str": "00:47.020",
      "text": "淋了一身的雨",
      "translation": null
    },
    {
      "time": 52.57,
      "time_str": "00:52.570",
      "text": "彷徨的不知该往那里去",
      "translation": null
    },
    {
      "time": 56.58,
      "time_str": "00:56.580",
      "text": "不愿再与你相见",
      "translation": null
    },
    {
      "time": 60.56,
      "time_str": "01:00.560",
      "text": "又怕不能平抚自己的情绪",
      "translation": null
    },
    {
      "time": 64.07,
      "time_str": "01:04.070",
      "text": "是你让我深情的驻留",
      "translation": null
    },
    {
      "time": 67.0,
      "time_str": "01:07.000",
      "text": "如今又让我孤独地走",
      "translation": null
    },
    {
      "time": 70.43,
      "time_str": "01:10.430",
      "text": "其实你一直是我唯一不忍离去的理由",
      "translation": null
    },
    {
      "time": 84.3,
      "time_str": "01:24.30",
      "text": "付出那麽地多",
      "translation": null
    },
    {
      "time": 96.27,
      "time_str": "01:36.27",
      "text": "从来没想过失去的感受",
      "translation": null
    },
    {
      "time": 100.39,
      "time_str": "01:40.39",
      "text": "早知道这样的结果",
      "translation": null
    },
    {
      "time": 103.15,
      "time_str": "01:43.15",
      "text": "我们是不是应该要的更多",
      "translation": null
    },
    {
      "time": 106.71,
      "time_str": "01:46.71",
      "text": "事情真的不能再挽留",
      "translation": null
    },
    {
      "time": 110.31,
      "time_str": "01:50.31",
      "text": "还是我们的努力不够",
      "translation": null
    },
    {
      "time": 114.36,
      "time_str": "01:54.36",
      "text": "我还是一直不能不能克制对你的伤痛",
      "translation": null
    },
    {
      "time": 121.83,
      "time_str": "02:01.83",
      "text": "我对你停不了的爱",
      "translation": null
    },
    {
      "time": 124.65,
      "time_str": "02:04.65",
      "text": "该如何取代",
      "translation": null
    },
    {
      "time": 129.34,
      "time_str": "02:09.34",
      "text": "我又何尝愿意离开教我怎麽能够将你忘怀",
      "translation": null
    },
    {
      "time": 136.09,
      "time_str": "02:16.09",
      "text": "我对你停不了的爱",
      "translation": null
    },
    {
      "time": 140.02,
      "time_str": "02:20.02",
      "text": "该如何禁止",
      "translation": null
    },
    {
      "time": 145.16,
      "time_str": "02:25.16",
      "text": "付出愈多愈受伤害",
      "translation": null
    },
    {
      "time": 147.59,
      "time_str": "02:27.59",
      "text": "无论我如何做都无法减少对你的一份爱",
