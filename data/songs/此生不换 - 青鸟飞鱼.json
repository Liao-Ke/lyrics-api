  "lyrics": [
    {
      "time": 33.1,
      "time_str": "00:33.100",
      "text": "时光穿不断流转在从前",
      "translation": null
    },
    {
      "time": 40.52,
      "time_str": "00:40.520",
      "text": "刻骨的变迁不是遥远",
      "translation": null
    },
    {
      "time": 46.94,
      "time_str": "00:46.940",
      "text": "再有一万年深情也不变",
      "translation": null
    },
    {
      "time": 54.36,
      "time_str": "00:54.360",
      "text": "爱像烈火般蔓延",
      "translation": null
    },
    {
      "time": 62.65,
      "time_str": "01:02.650",
      "text": "记忆是条长线盘旋在天边",
      "translation": null
    },
    {
      "time": 70.02,
      "time_str": "01:10.020",
      "text": "沉浮中以为情深缘浅",
      "translation": null
    },
    {
      "time": 76.43,
      "time_str": "01:16.430",
      "text": "你再度出现我看见誓言",
      "translation": null
    },
    {
      "time": 83.76,
      "time_str": "01:23.760",
      "text": "承诺在水天之间",
      "translation": null
    },
    {
      "time": 91.19,
      "time_str": "01:31.190",
      "text": "回头看不曾走远",
      "translation": null
    },
    {
      "time": 98.65,
      "time_str": "01:38.650",
      "text": "依依目光此生不换",
      "translation": null
    },
    {
      "time": 105.99,
      "time_str": "01:45.990",
      "text": "要分散不习惯",
      "translation": null
    },
    {
      "time": 109.64,
      "time_str": "01:49.640",
      "text": "怎么算都太难",
      "translation": null
    },
    {
      "time": 113.29,
      "time_str": "01:53.290",
      "text": "分开之后更勇敢",
      "translation": null
    },
    {
      "time": 120.84,
      "time_str": "02:00.840",
      "text": "愿这爱世代相传",
      "translation": null
    },
    {
      "time": 132.81,
      "time_str": "02:12.810",
      "text": "喝不完忘情水",
      "translation": null
    },
    {
      "time": 134.95,
      "time_str": "02:14.950",
      "text": "不让你如烟",
      "translation": null
    },
    {
      "time": 140.13,
      "time_str": "02:20.130",
      "text": "前尘再怀恋望剑如面",
      "translation": null
    },
    {
      "time": 146.58,
      "time_str": "02:26.580",
      "text": "挥舞的瞬间别再闭上眼",
      "translation": null
    },
    {
      "time": 153.89,
      "time_str": "02:33.890",
      "text": "错过惊世的依恋",
      "translation": null
    },
    {
      "time": 160.82,
      "time_str": "02:40.820",
      "text": "回头看不曾走远",
      "translation": null
    },
    {
      "time": 168.68,
      "time_str": "02:48.680",
      "text": "眷恋一人流连忘返",
      "translation": null
    },
    {
      "time": 176.2,
      "time_str": "02:56.200",
      "text": "多少汗够温暖",
      "translation": null
    },
    {
      "time": 179.86,
      "time_str": "02:59.860",
      "text": "你哭喊我呼唤",
      "translation": null
    },
    {
      "time": 183.53,
      "time_str": "03:03.530",
      "text": "听清耳边的呢喃",
      "translation": null
    },
    {
      "time": 190.87,
      "time_str": "03:10.870",
      "text": "别害怕风轻云淡",
      "translation": null
    },
    {
      "time": 212.73,
      "time_str": "03:32.730",
      "text": "回头看不曾走远",
      "translation": null
